<?xml version='1.0' encoding='UTF-8'?>
<odoo noupdate="1">
  <record id="project_project_3" model="project.project" context="{'mail_auto_subscribe_no_notify': True}">
    <field name="name">Event Management Template</field>
    <field name="allow_billable" eval="True"/>
    <field name="user_id" ref="base.user_admin"/>
    <field name="type_ids" eval="[(6, 0, [ref('project_task_type_20'), ref('project_task_type_21'), ref('project_task_type_22')])]"/>
    <field name="stage_id" ref="project_project_stage_5"/>
    <field name="is_template" eval="True"/>
    <field name="documents_folder_id" ref="documents_document_20"/>
  </record>
  <record id="project_project_3_top_bar" model="res.users.settings.embedded.action">
      <field name="user_setting_id" model="res.users.settings" search="[('user_id', '=', ref('base.user_admin'))]"/>
      <field name="action_id" ref="project.act_project_project_2_project_task_all"/>
      <field name="res_model">project.project</field>
      <field name="res_id" ref="project_project_3"/>
      <field name="embedded_actions_order"
          eval="','.join([
              'false',
              str(ref('project.project_embedded_action_all_tasks_dashboard')),
              str(ref('documents_project.project_embedded_action_documents')),
              str(ref('project_forecast.project_embedded_action_planning')),
              str(ref('sale_project.project_embedded_action_sales_orders')),
              str(ref('sale_renting_project.project_embedded_action_rental_orders')),
              str(ref('project_purchase.project_embedded_action_purchase_orders')),
              str(ref('project_stock.project_embedded_action_all_pickings')),
          ])"
      />
      <field name="embedded_actions_visibility"
          eval="','.join([
              'false',
              str(ref('project.project_embedded_action_all_tasks_dashboard')),
              str(ref('documents_project.project_embedded_action_documents')),
              str(ref('sale_project.project_embedded_action_sales_orders')),
              str(ref('project_forecast.project_embedded_action_planning')),
              str(ref('sale_renting_project.project_embedded_action_rental_orders')),
              str(ref('project_purchase.project_embedded_action_purchase_orders')),
              str(ref('project_stock.project_embedded_action_all_pickings')),
          ])"
      />
      <field name="embedded_visibility">True</field>
  </record>
</odoo>
