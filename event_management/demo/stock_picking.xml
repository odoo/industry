<?xml version='1.0' encoding='UTF-8'?>
<odoo noupdate="1" context="{'mail_auto_subscribe_no_notify': True}">
    <record id="stock_picking_in_2" model="stock.picking">
        <field name="picking_type_id" ref="stock.picking_type_out"/>
        <field name="move_type">direct</field>
        <field name="scheduled_date" eval="datetime.today().date() + relativedelta(days=2)"/>
        <field name="location_id" ref="stock.stock_location_stock"/>
        <field name="location_dest_id" ref="stock.stock_location_customers"/>
        <field name="user_id" ref="base.user_admin"/>
        <field name="partner_id" ref="base_industry_data.res_partner_21"/>
        <field name="project_id" ref="project_project_5"/>
    </record>
    <record id="stock_move_14" model="stock.move">
        <field name="picking_id" ref="stock_picking_in_2"/>
        <field name="product_id" ref="product_product_25"/>
        <field name="product_uom_qty">50.0</field>
    </record>
    <record id="stock_move_15" model="stock.move">
        <field name="picking_id" ref="stock_picking_in_2"/>
        <field name="product_id" ref="product_product_40"/>
        <field name="product_uom_qty">50.0</field>
    </record>
    <function name="action_confirm" model="stock.picking">
        <value eval="[ref('stock_picking_in_2')]"/>
    </function>
</odoo>
