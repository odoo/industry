<?xml version='1.0' encoding='UTF-8'?>
<odoo noupdate="1">
    <record id="document_layout_custom" model="base.document.layout">
        <field name="external_report_layout_id" ref='web.external_layout_wave'/>
        <field name="report_tables_id">bubble</field>
        <field name="qr_code" eval="True"/>
    </record>
    <function model="base.document.layout" name="write">
        <value eval="[ref('document_layout_custom')]" />
        <value model="base.document.layout" eval="{'account_number': obj().env.ref('event_management.document_layout_custom').account_number or 'BE0477472705'}" />
    </function>
</odoo>
