#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>1. Recruitment: Finding the Right Talent</b>"
msgstr "<b>1. Personalbeschaffung: Die richtigen Talente finden</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>2. Employee Setup: Defining Roles</b>"
msgstr "<b>2. Einrichtung der Mitarbeiter: Rollen definieren</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>3. Planning: The Three-Step Workflow</b>"
msgstr "<b>3. Planung: Der dreistufige Arbeitsablauf</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Access Settings:</b> Navigate to <b>Settings</b> &gt; <b>Calendar</b> "
"&gt; <b>Sync External Calendar</b>."
msgstr ""
"<b>Zugriffseinstellungen:</b> Navigieren Sie zu <b>Einstellungen</b> &gt; "
"<b> Kalender</b> &gt; <b> Externen Kalender synchronisieren</b>."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Attendee Management:</b> Track your guest list in real-time and send "
"digital tickets/badges via email\n"
"                automatically."
msgstr ""
"<b>Teilnehmerverwaltung:</b> Verfolgen Sie Ihre Gästeliste in Echtzeit und "
"versenden Sie digitale Tickets/Ausweise automatisch per E-Mail\n"
"                ."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Automated Booking:</b> Enable online registration to let attendees book "
"their spots instantly."
msgstr ""
"<b>Automatisierte Buchung:</b> Aktivieren Sie die Online-Registrierung, "
"damit Teilnehmer ihre Plätze sofort buchen können."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Automated Stock Transfers</b>"
msgstr "<b>Automatisierte Bestandstransfers</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Automatic Conflict Prevention:</b> If you have already scheduled an "
"internal event or a staff\n"
"                        \"Montage\" (setup) in the <b>Planning app</b> for "
"that location, Odoo will automatically gray out\n"
"                        those dates on your website."
msgstr ""
"<b>Automatische Konfliktvermeidung:</b> Wenn Sie bereits eine interne "
"Veranstaltung oder eine Einrichtung für\n"
"                        „Montage“ in der <b>Planungsapp</b> für diesen "
"Standort geplant haben, wird Odoo diese Termine auf Ihrer Website "
"automatisch ausgrauen\n"
"                        ."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Centralized Documentation</b>"
msgstr "<b>Zentralisierte Dokumentation</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Centralized Logistics Overview</b>"
msgstr "<b>Übersicht über zentralisierte Logistik</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Client Rentals:</b> Standard orders with specific pricing and automated "
"invoicing. (like Jessica Martinez in the demo data)"
msgstr ""
"<b>Kundenvermietungen:</b> Standardbestellungen mit spezifischen Preisen und "
"automatisierter Rechnungsstellung. (wie Jessica Martinez in den Demodaten)"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Complex Project Management: </b>Open the \"City Festival – Summer in the "
"Square – Brussels\" opportunity."
msgstr ""
"<b>Komplexes Projektmanagement: </b>Öffnen Sie die Verkaufschance „Stadtfest "
"– Sommer auf dem Platz – Brüssel“."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Conflict Alerts:</b> When creating a rental quotation, a <b>red icon</b> "
"will appear next to a line item\n"
"                if Odoo detects a stock shortage for those dates."
msgstr ""
"<b>Konfliktwarnungen:</b> Beim Erstellen eines Mietangebots erscheint ein "
"<b>rotes Symbol</b> neben einer Zeile,\n"
"                wenn Odoo für diese Daten einen Lagerbestandsmangel "
"feststellt."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Consumable Products:</b> Items that appear on your picking lists but do "
"not require strict inventory\n"
"                tracking."
msgstr ""
"<b>Verbrauchsmaterialien:</b> Artikel, die auf Ihren Listen für die "
"Kommissionierung erscheinen, aber keine strenge Verfolgung des "
"Lagerbestandes\n"
"                erfordern."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Custom Stages:</b> Tailor project and task stages to align perfectly with "
"your team’s specific internal\n"
"                processes."
msgstr ""
"<b>Benutzerdefinierte Phasen:</b> Passen Sie Projekt- und Aufgabenphasen so "
"an, dass sie perfekt mit den spezifischen internen\n"
"                Prozessen Ihres Teams übereinstimmen."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Delivery:</b> From your Warehouse to the Client."
msgstr "<b>Lieferung:</b> Von Ihrem Lager zum Kunden."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Direct-to-Event (Dropshipping):</b> For items that should go straight to "
"the venue, change the\n"
"                <b>\"Deliver To\"</b> field to <b>\"Dropship\"</b> and "
"select the event location as the address."
msgstr ""
"<b>Direktlieferung (Streckengeschäft):</b> Für Artikel, die direkt zum "
"Veranstaltungsort geliefert werden sollen, ändern Sie das\n"
"               <b> Feld „Liefern an“</b> in <b> „Streckengeschäft“</b> und "
"wählen Sie den Veranstaltungsort als Adresse aus."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Discounts:</b> Apply price adjustments directly to line items."
msgstr ""
"<b>Rabatte:</b> Wenden Sie Preisanpassungen direkt auf Einzelposten an."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Easy Sharing:</b> Simply copy the <b>Share Link</b> for any document and "
"send it to your team along with\n"
"                their schedule (see planning section)"
msgstr ""
"<b>Einfaches Teilen:</b> Kopieren Sie einfach den <b>Link zum Teilen</b> für "
"jedes Dokument und senden Sie ihn zusammen mit\n"
"                dem Zeitplan an Ihr Team (siehe Abschnitt „Planung“)"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Establish the Connection:</b> Link each user’s external account to the "
"Odoo Calendar app."
msgstr ""
"<b>Verbindung herstellen:</b> Verknüpfen Sie das externe Konto jedes "
"Benutzers mit der Odoo-Kalender-App."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>External Calendar Synchronization</b>"
msgstr "<b>Synchronisation externer Kalender</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Flexible Delivery &amp; Dropshipping</b>"
msgstr "<b>Flexible Lieferung &amp; Streckengeschäft</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Flexible Rental Management</b>"
msgstr "<b>Flexibles Mietmanagement</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Flexible Ticketing:</b> Configure multiple ticket tiers (e.g., Early "
"Bird, VIP, or General Admission)\n"
"                with custom pricing."
msgstr ""
"<b>Flexibler Ticketverkauf:</b> Konfigurieren Sie mehrere Ticketkategorien "
"(z. B. Frühbucher, VIP oder allgemeiner Zugang)\n"
"                mit benutzerdefinierten Preisen."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Granular Control:</b> Manage deadlines, assignees, internal notes, and "
"sub-tasks for every stage of the\n"
"                project."
msgstr ""
"<b>Detaillierte Kontrolle:</b> Verwalten Sie Fristen, Bearbeiter, interne "
"Notizen und Unteraufgaben für jede Phase des\n"
"                Projekts."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>How it Works in Practice</b>"
msgstr "<b>So funktioniert es in der Praxis</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Install eCommerce:</b> Ensure the <b>eCommerce app</b> is active."
msgstr ""
"<b>Installieren Sie E-Commerce:</b> Stellen Sie sicher, dass die <b>E-"
"Commerce-App</b> aktiv ist."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Integrated Budgeting:</b> Launch a <b>Request for Quotation (RFQ)</b> "
"directly from the project’s smart\n"
"                buttons to ensure all costs are automatically factored into "
"your <b>Project Profitability</b>."
msgstr ""
"<b>Integrierte Budgetierung:</b> Starten Sie eine <b>Angebotsanfrage</b> "
"direkt über die intelligenten Schaltflächen s des Projekts,\n"
"                um sicherzustellen, dass alle Kosten automatisch in Ihre "
"<b>Projektrentabilität</b> einfließen."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Internal Maintenance:</b> Blocks off equipment for repairs or quality "
"checks so it isn't accidentally\n"
"                booked."
msgstr ""
"<b>Interne Wartung:</b> Sperrt Geräte für Reparaturen oder "
"Qualitätsprüfungen, damit sie nicht versehentlich\n"
"                gebucht werden."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Internal Picking Lists:</b> For items not covered by rentals (like "
"consumables), you can manually create\n"
"                a <b>Picking List</b>. Simply set the <i>Destination</i> to "
"the event location, select your products, and\n"
"                set the date."
msgstr ""
"<b>Interne Kommissionierlisten:</b> Für Artikel, die nicht durch "
"Vermietungen abgedeckt sind (wie Verbrauchsmaterialien), können Sie manuell\n"
"                eine <b>Kommissionierliste</b> erstellen. Setzen Sie einfach "
"das <i>Ziel</i> auf den Veranstaltungsort, wählen Sie Ihre Produkte aus und\n"
"                legen Sie das Datum fest."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Internal Warehouse:</b> By default, Odoo assumes items (like new stock) "
"are coming to your warehouse."
msgstr ""
"<b>Internes Lagerhaus:</b> Standardmäßig geht Odoo davon aus, dass Artikel "
"(wie neue Lagerbestände) in Ihr Lagerhaus gelangen."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Large-Scale Events:</b> Rentals bundled into a larger project at $0 "
"(since the cost is already covered in\n"
"                the overall package)."
msgstr ""
"<b>Großveranstaltungen:</b> Vermietungen, die in ein größeres Projekt zu 0 € "
"gebündelt sind (da die Kosten bereits im\n"
"                Gesamtpaket enthalten sind)."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Live Availability:</b> Customers can only book the dates where the venue "
"is free."
msgstr ""
"<b>Verfügbarkeit in Echtzeit:</b> Kunden können nur Termine buchen, an denen "
"der Veranstaltungsort frei ist."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Logistics Overview</b>"
msgstr "<b>Logistik-Übersicht</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Managing Your Own Venue &amp; Location Bookings: </b>If you own the venue "
"where your events take place, you can\n"
"            use Odoo to manage its availability and even allow external "
"clients to book the space online when you aren't\n"
"            using it."
msgstr ""
"<b>Eigene Veranstaltungsorte &amp; Standortbuchungen verwalten: </b>Wenn Sie "
"Eigentümer des Veranstaltungsortes sind, in der Ihre Veranstaltungen "
"stattfinden, können Sie\n"
"            Odoo nutzen, um deren Verfügbarkeit zu verwalten und sogar "
"externen Kunden zu ermöglichen, den Raum online zu buchen, wenn Sie ihn "
"nicht\n"
"            nutzen."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Official Paperwork:</b> Contracts and legal authorizations (City, Police, "
"etc.)."
msgstr ""
"<b>Offizielle Unterlagen:</b> Verträge und gesetzliche Genehmigungen (Stadt, "
"Polizei usw.)."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Online Presence:</b> Create beautiful event pages and publish them "
"directly to your website."
msgstr ""
"<b>Online-Präsenz:</b> Erstellen Sie ansprechende Veranstaltungsseiten und "
"veröffentlichen Sie diese direkt auf Ihrer Website."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Pipeline Management:</b> Track applications, conduct interviews, and hire "
"your team in one centralized\n"
"                dashboard."
msgstr ""
"<b>Pipeline-Verwaltung:</b> Verfolgen Sie Bewerbungen, führen Sie "
"Vorstellungsgespräche und stellen Sie Ihr Team über ein zentrales\n"
"                Dashboard ein."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Post &amp; Publish:</b> Create job openings and publish them directly to "
"your Odoo website."
msgstr ""
"<b>Veröffentlichen:</b> Erstellen Sie Stellenangebote und veröffentlichen "
"Sie diese direkt auf Ihrer Odoo-Website."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Predefined Templates:</b> Speed up your process with standard layouts."
msgstr ""
"<b>Vordefinierte Vorlagen:</b> Beschleunigen Sie Ihren Prozess mit "
"Standardlayouts."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Purchases &amp; Dropshipping:</b> Transfers coming from suppliers."
msgstr "<b>Einkäufe &amp; Streckengeschäft:</b> Lieferungen von Lieferanten."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Rapid Entry:</b> Use Odoo’s built-in <b>scanning feature</b> to manage "
"high-traffic entrances and check\n"
"                in attendees in seconds."
msgstr ""
"<b>Schnelleintritt:</b> Nutzen Sie die in Odoo integrierte <b>Funktion zum "
"Scannen</b>, um stark besuchte Eintrittszeiten zu verwalten und\n"
"                Teilnehmer in Sekundenschnelle einzuchecken."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Rentals:</b> Equipment moving to and from the client."
msgstr "<b>Vermietung:</b> Transport von Ausrüstung zum und vom Kunden."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Resources:</b> Set the number of resources that can be booked "
"simultaneously (e.g., if\n"
"                                you have two conference rooms, create two "
"resources)."
msgstr ""
"<b>Ressourcen:</b> Legen Sie die Anzahl der Ressourcen fest, die "
"gleichzeitig gebucht werden können (z. B. wenn\n"
"                                Sie zwei Konferenzräume haben, erstellen Sie "
"zwei Ressourcen)."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Return:</b> From the Client back to your Warehouse."
msgstr "<b>Rückgabe:</b> Vom Kunden zurück an Ihr Lager."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Sections &amp; Notes:</b> Organize your offer and add context for the "
"client."
msgstr ""
"<b>Abschnitte &amp;Notizen:</b> Organisieren Sie Ihr Angebot und fügen Sie "
"Kontext für den Kunden hinzu."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>See it for yourself!</b> (Requires demo data)"
msgstr "<b>Überzeugen Sie sich selbst!</b> (erfordert Demodaten)"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Service Products:</b> Used for high-level quoting or purchasing."
msgstr ""
"<b>Dienstleistungsprodukte:</b> Wird für allgemeine Angebotsanfragen oder "
"den Kauf verwendet."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Services:</b> Link the specific service product you want to track as "
"\"rented\" within the\n"
"                                <b>Rental</b> app."
msgstr ""
"<b>Dienstleistungen:</b> Verknüpfen Sie das spezifische "
"Dienstleistungsprodukt, das Sie als „gemietet“ verfolgen möchten, innerhalb "
"der\n"
"                               <b>Vermietungsapp</b>."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Setup Guide</b>"
msgstr "<b>Einrichtungsanleitung</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Smart Comparisons:</b> Add alternative products or vendors to a single "
"RFQ. Once you select the best\n"
"                offer, Odoo automatically cancels the other options for you."
msgstr ""
"<b>Intelligente Vergleiche:</b> Fügen Sie alternative Produkte oder Anbieter "
"zu einer einzigen Angebotsanfrage hinzu. Sobald Sie das beste\n"
"                Angebot ausgewählt haben, storniert Odoo automatisch die "
"anderen Optionen für Sie."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Sourcing &amp; Comparison</b>"
msgstr "<b>Beschaffung &amp; Vergleich</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Staff Resources:</b> Site plans, emergency contact lists, and event "
"agendas."
msgstr ""
"<b>Personalressourcen:</b> Lagepläne, Notfallkontaktlisten und "
"Veranstaltungsprogramme."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Step 1: Define the Shifts</b> Create all necessary time slots (e.g., 6 "
"staff for \"Setup\" from 07:00 to\n"
"                15:00, 4 for \"Security\" from 10:00 to 16:00)."
msgstr ""
"<b>Schritt 1: Schichten festlegen</b> Erstellen Sie alle erforderlichen "
"Zeitfenster (z. B. 6 Mitarbeiter für „Aufbau“ von 07:00 bis\n"
"                15:00 Uhr, 4 für „Sicherheit“ von 10:00 bis 16:00 Uhr)."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Step 2: Assign the Team</b> You can manually drag and drop employees into "
"slots or use the\n"
"                <b>\"Auto-Assign\"</b> button. Odoo will automatically match "
"staff based on their defined <b>Roles</b> and\n"
"                <b>Availability</b>."
msgstr ""
"<b>Schritt 2: Team zuweisen</b> Sie können Mitarbeiter manuell per Drag & "
"Drop in die Zeitfenster ziehen oder die\n"
"               Schaltfläche <b>„Automatisch zuweisen“</b> verwenden. Odoo "
"ordnet die Mitarbeiter automatisch anhand ihrer definierten <b>Rollen</b> "
"und\n"
"               <b> Verfügbarkeit</b> zu."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Step 3: Publish &amp; Sync</b> Once the schedule is finalized, click "
"<b>\"Publish.\"</b> Your team will\n"
"                receive:"
msgstr ""
"<b>Schritt 3: Veröffentlichen &amp; Synchronisieren</b> Sobald der Zeitplan "
"feststeht, klicken Sie auf <b> „Veröffentlichen“.</b> Ihr Team erhält\n"
"                Folgendes:"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Step-by-Step Integration Guides</b>"
msgstr "<b>Schritt-für-Schritt-Anleitungen zur Integration</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Storable (Traced) Products:</b> Strategic assets that require exact stock "
"counts at all times."
msgstr ""
"<b>Lagerfähige (verfolgte) Produkte:</b> Strategische Vermögenswerte, die "
"jederzeit eine genaue Bestandsaufnahme erfordern."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Sync:</b> Enable <b>Sync Shifts and Rental Orders</b> to activate the "
"integration between\n"
"                                the two modules."
msgstr ""
"<b>Synchronisierung:</b> Aktivieren Sie „ <b>Schichten und Mietaufträge "
"synchronisieren“</b>, um die Integration zwischen\n"
"                                den beiden Modulen zu aktivieren."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Task Management &amp; Custom Workflows</b>"
msgstr "<b>Aufgabenmanagement &amp; benutzerdefinierte Arbeitsabläufe</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Terms &amp; Conditions:</b> Ensure legal clarity on every deal."
msgstr "<b>AGBs:</b> Sorgen Sie bei jedem Geschäft für rechtliche Klarheit."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>The Schedule View:</b> Click on <b>\"Schedule\"</b> for a timeline of "
"your equipment."
msgstr ""
"<b>Die Zeitplanansicht:</b> Klicken Sie auf <b> „Planen“</b>, um eine "
"Zeitleiste Ihrer Geräte anzuzeigen."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Tip:</b> Remove the <i>\"Confirmed Orders\"</i> filter to see pending "
"quotations. This allows you to\n"
"                    spot potential conflicts before they happen."
msgstr ""
"<b> Tipp:</b> Entfernen Sie den Filter <i>„Bestätigte Aufträge“</i>, um "
"ausstehende Angebote anzuzeigen. So können Sie\n"
"                    potenzielle Konflikte erkennen, bevor sie auftreten."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Visualizing Availability</b>"
msgstr "<b>Verfügbarkeit visualisieren</b>"

