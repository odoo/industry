#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>1. Recruitment: Finding the Right Talent</b>"
msgstr "<b>1. Assunzioni: trovare il talento giusto</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>2. Employee Setup: Defining Roles</b>"
msgstr "<b>2. Configurazione dei dipendenti: definizione dei ruoli</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>3. Planning: The Three-Step Workflow</b>"
msgstr "<b>3. Pianificazione: il flusso di lavoro in tre fasi</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Access Settings:</b> Navigate to <b>Settings</b> &gt; <b>Calendar</b> "
"&gt; <b>Sync External Calendar</b>."
msgstr ""
"<b>Impostazioni di accesso:</b> vaisu <b>Impostazioni</b> &gt; <b> "
"Calendario</b> &gt; <b> Sincronizza calendario esterno</b>."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Attendee Management:</b> Track your guest list in real-time and send "
"digital tickets/badges via email\n"
"                automatically."
msgstr ""
"<b>gestione dei partecipanti:</b> tieni traccia della tua lista degli ospiti "
"in tempo reale e invia biglietti/badge digitali via e-mail\n"
"                automaticamente;"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Automated Booking:</b> Enable online registration to let attendees book "
"their spots instantly."
msgstr ""
"<b>prenotazioni automatizzate:</b> abilita la registrazione online per "
"consentire ai partecipanti di prenotare i propri posti all'istante;"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Automated Stock Transfers</b>"
msgstr "<b>Trasferimenti automatici delle scorte</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Automatic Conflict Prevention:</b> If you have already scheduled an "
"internal event or a staff\n"
"                        \"Montage\" (setup) in the <b>Planning app</b> for "
"that location, Odoo will automatically gray out\n"
"                        those dates on your website."
msgstr ""
"<b>prevenzione automatica dei conflitti:</b> se hai già programmato un "
"evento interno o un\n"
"                        \"Allestimento\" nell'app <b>Pianificazione</b> per "
"quella sede, Odoo disattiverà automaticamente\n"
"                        quelle date sul tuo sito web."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Centralized Documentation</b>"
msgstr "<b>Documentazione centralizzata</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Centralized Logistics Overview</b>"
msgstr "<b>Panoramica della logistica centralizzata</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Client Rentals:</b> Standard orders with specific pricing and automated "
"invoicing. (like Jessica Martinez in the demo data)"
msgstr ""
"<b>noleggi per clienti:</b> ordini standard con prezzi specifici e "
"fatturazione automatizzata (come Jessica Martinez nei dati demo);"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Complex Project Management: </b>Open the \"City Festival – Summer in the "
"Square – Brussels\" opportunity."
msgstr ""
"<b>Gestione di progetti complessi: </b>apri l'opportunità \"Festival della "
"città – Estate in piazza – Bruxelles\"."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Conflict Alerts:</b> When creating a rental quotation, a <b>red icon</b> "
"will appear next to a line item\n"
"                if Odoo detects a stock shortage for those dates."
msgstr ""
"<b>Avvisi di conflitto:</b> durante la creazione di un preventivo di "
"noleggio, <b>un'icona rossa</b> apparirà accanto a una voce\n"
"                se Odoo rileva una carenza di scorte per quelle date."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Consumable Products:</b> Items that appear on your picking lists but do "
"not require strict inventory\n"
"                tracking."
msgstr ""
"<b>Prodotti di consumo:</b> articoli che compaiono nelle liste di prelievo "
"ma non richiedono un rigoroso\n"
"                monitoraggio del magazzino."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Custom Stages:</b> Tailor project and task stages to align perfectly with "
"your team’s specific internal\n"
"                processes."
msgstr ""
"<b>Fasi personalizzate:</b> adatta le fasi dei progetti e dei lavori per "
"allinearle perfettamente ai processi interni specifici del tuo team\n"
"                ."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Delivery:</b> From your Warehouse to the Client."
msgstr "<b>Consegna:</b> dal tuo magazzino al cliente."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Direct-to-Event (Dropshipping):</b> For items that should go straight to "
"the venue, change the\n"
"                <b>\"Deliver To\"</b> field to <b>\"Dropship\"</b> and "
"select the event location as the address."
msgstr ""
"<b> <b>Direttamente all'evento (dropshipping):</b> per gli articoli che "
"devono essere spediti direttamente alla sede dell'evento, modifica il\n"
"                campo \"Consegna a\"</b> di <b> in \"Dropshipping\"</b> e "
"seleziona la sede dell'evento come indirizzo."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Discounts:</b> Apply price adjustments directly to line items."
msgstr ""
"<b>Sconti:</b> applica gli adeguamenti di prezzo direttamente alle voci "
"della riga."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Easy Sharing:</b> Simply copy the <b>Share Link</b> for any document and "
"send it to your team along with\n"
"                their schedule (see planning section)"
msgstr ""
"<b>Condivisione facile:</b> basta copiare il <b>link di condivisione</b> per "
"qualsiasi documento e inviarlo al proprio team insieme al\n"
"                loro programma (vedi la sezione sulla pianificazione)"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Establish the Connection:</b> Link each user’s external account to the "
"Odoo Calendar app."
msgstr ""
"<b>stabilire la connessione:</b> collega l'account esterno di ciascun utente "
"all'app Calendario di Odoo."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>External Calendar Synchronization</b>"
msgstr "<b>Sincronizzazione con calendari esterni</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Flexible Delivery &amp; Dropshipping</b>"
msgstr "<b>Consegna flessibile &amp; Dropshipping</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Flexible Rental Management</b>"
msgstr "<b>Gestione flessibile degli affitti</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Flexible Ticketing:</b> Configure multiple ticket tiers (e.g., Early "
"Bird, VIP, or General Admission)\n"
"                with custom pricing."
msgstr ""
"<b>biglietteria flessibile:</b> configura più tipi di biglietti (ad es. "
"Early bird, VIP o Ingresso generale)\n"
"                con prezzi personalizzati;"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Granular Control:</b> Manage deadlines, assignees, internal notes, and "
"sub-tasks for every stage of the\n"
"                project."
msgstr ""
"<b>Controllo granulare:</b> gestisci scadenze, assegnatari, note interne e "
"attività secondarie per ogni fase del\n"
"                progetto;"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>How it Works in Practice</b>"
msgstr "<b>Come funziona nella pratica</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Install eCommerce:</b> Ensure the <b>eCommerce app</b> is active."
msgstr ""
"<b>Installa l'app E-commerce:</b> assicurati che l'app <b>e-commerce</b> sia "
"attiva."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Integrated Budgeting:</b> Launch a <b>Request for Quotation (RFQ)</b> "
"directly from the project’s smart\n"
"                buttons to ensure all costs are automatically factored into "
"your <b>Project Profitability</b>."
msgstr ""
"<b> <b>Bilancio integrato:</b> avvia una <b>richiesta di preventivo (RdP)</"
"b> direttamente dai pulsanti intelligenti presenti nei progetti\n"
"                per garantire che tutti i costi vengano automaticamente "
"inclusi nella <b>redditività</b> ."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Internal Maintenance:</b> Blocks off equipment for repairs or quality "
"checks so it isn't accidentally\n"
"                booked."
msgstr ""
"<b>manutenzione interna:</b> blocca le attrezzature per riparazioni o "
"controlli di qualità in modo che non vengano accidentalmente\n"
"                prenotate."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Internal Picking Lists:</b> For items not covered by rentals (like "
"consumables), you can manually create\n"
"                a <b>Picking List</b>. Simply set the <i>Destination</i> to "
"the event location, select your products, and\n"
"                set the date."
msgstr ""
"<b>elenchi di prelievo interni:</b> per gli articoli non coperti dai noleggi "
"(come i materiali di consumo), è possibile creare manualmente\n"
"                un <b>elenco di prelievo</b> . È sufficiente impostare la "
"<i>Destinazione</i> sul luogo dell'evento, selezionare i prodotti e\n"
"                impostare la data."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Internal Warehouse:</b> By default, Odoo assumes items (like new stock) "
"are coming to your warehouse."
msgstr ""
"<b>magazzino interno:</b> per impostazione predefinita, Odoo suppone che gli "
"articoli (come le nuove scorte) arrivano direttamente al tuo deposito"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Large-Scale Events:</b> Rentals bundled into a larger project at $0 "
"(since the cost is already covered in\n"
"                the overall package)."
msgstr ""
"<b>eventi a grande scala:</b> gli affitti inclusi in un progetto più grande "
"a 0 € (in quanto il costo è già incluso\n"
"                nel pacchetto completo)"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Live Availability:</b> Customers can only book the dates where the venue "
"is free."
msgstr ""
"<b>disponibilità in tempo reale:</b> i clienti possono prenotare solo le "
"date in cui la location è libera"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Logistics Overview</b>"
msgstr "<b>Panoramica logistica</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Managing Your Own Venue &amp; Location Bookings: </b>If you own the venue "
"where your events take place, you can\n"
"            use Odoo to manage its availability and even allow external "
"clients to book the space online when you aren't\n"
"            using it."
msgstr ""
"<b>Gestire location e prenotazioni: </b>Ise sei il proprietario del luogo "
"dove avvengono gli eventi, puoi\n"
"            usare Odoo per gestire le disponibilità e permettere anche ai "
"clienti esterni di prenotare online gli spazi quando\n"
"            non li usi."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Official Paperwork:</b> Contracts and legal authorizations (City, Police, "
"etc.)."
msgstr ""
"<b>documenti ufficiali:</b> i contratti e le autorizzazioni legali (città, "
"polizia, ecc.)"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Online Presence:</b> Create beautiful event pages and publish them "
"directly to your website."
msgstr ""
"<b>presenza online:</b> crea bellissime pagine di eventi e pubblicale "
"direttamente sul tuo sito web"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Pipeline Management:</b> Track applications, conduct interviews, and hire "
"your team in one centralized\n"
"                dashboard."
msgstr ""
"<b>gestione della pipeline:</b> tieni traccia delle candidature, conduci i "
"colloqui e assumi il tuo team da un'unica\n"
"                dashboard centralizzata."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Post &amp; Publish:</b> Create job openings and publish them directly to "
"your Odoo website."
msgstr ""
"<b>crea un post e pubblica:</b> crea offerte di lavoro e pubblicale "
"direttamente sul tuo sito web Odoo"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Predefined Templates:</b> Speed up your process with standard layouts."
msgstr ""
"<b>modelli predefiniti:</b> velocizza il tuo processo con layout standard"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Purchases &amp; Dropshipping:</b> Transfers coming from suppliers."
msgstr ""
"<b>acquisti e dropshipping:</b> trasferimenti che vengono dai fornitori"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Rapid Entry:</b> Use Odoo’s built-in <b>scanning feature</b> to manage "
"high-traffic entrances and check\n"
"                in attendees in seconds."
msgstr ""
"<b>inserimento rapido:</b> utilizza la funzione di scansione <b>integrata in "
"Odoo</b> per gestire gli ingressi ad alto traffico e registrare\n"
"                i partecipanti in pochi secondi."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Rentals:</b> Equipment moving to and from the client."
msgstr "<b>affitti:</b> attrezzature in transito da e verso il cliente"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Resources:</b> Set the number of resources that can be booked "
"simultaneously (e.g., if\n"
"                                you have two conference rooms, create two "
"resources)."
msgstr ""
"<b>risorse:</b> imposta il numero di risorse che possono essere prenotate "
"contemporaneamente (ad es., se\n"
"                                disponi di due sale conferenze, crea due "
"risorse)"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Return:</b> From the Client back to your Warehouse."
msgstr "<b>reso:</b> dal cliente al tuo magazzino."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Sections &amp; Notes:</b> Organize your offer and add context for the "
"client."
msgstr ""
"<b>sezioni e note:</b> organizza la tua offerta e aggiungi contesto per il "
"cliente"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>See it for yourself!</b> (Requires demo data)"
msgstr "<b>Testalo!</b> (Hai bisogno dei dati demo)"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Service Products:</b> Used for high-level quoting or purchasing."
msgstr ""
"<b>Prodotti di servizio:</b> usali per preventivi o acquisti di alto livello"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Services:</b> Link the specific service product you want to track as "
"\"rented\" within the\n"
"                                <b>Rental</b> app."
msgstr ""
"<b>servizi:</b> collega il prodotto di servizio specifico che desideri "
"monitorare come \"noleggiato\" all'interno\n"
"                                dell'app <b>Noleggi</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Setup Guide</b>"
msgstr "<b>Guida alla configurazione</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Smart Comparisons:</b> Add alternative products or vendors to a single "
"RFQ. Once you select the best\n"
"                offer, Odoo automatically cancels the other options for you."
msgstr ""
"<b>Confronto intelligente:</b> aggiungi prodotti o fornitori alternativi a "
"una singola richiesta di preventivo. Una volta selezionata l'offerta "
"migliore,\n"
"                Odoo cancella automaticamente le altre opzioni per te."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Sourcing &amp; Comparison</b>"
msgstr "<b>Fornitura e confronto</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Staff Resources:</b> Site plans, emergency contact lists, and event "
"agendas."
msgstr ""
"<b>Risorse dello staff:</b> mappe dei siti, elenchi dei contatti di "
"emergenza e programmi degli eventi."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Step 1: Define the Shifts</b> Create all necessary time slots (e.g., 6 "
"staff for \"Setup\" from 07:00 to\n"
"                15:00, 4 for \"Security\" from 10:00 to 16:00)."
msgstr ""
"<b>step 1: definisci i turni</b> Crea tutte le fasce orarie necessarie (ad "
"es., 6 membri dello staff per \"Allestimento\" dalle 07:00 alle\n"
"                15:00, 4 per \"Sicurezza\" dalle 10:00 alle 16:00)."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Step 2: Assign the Team</b> You can manually drag and drop employees into "
"slots or use the\n"
"                <b>\"Auto-Assign\"</b> button. Odoo will automatically match "
"staff based on their defined <b>Roles</b> and\n"
"                <b>Availability</b>."
msgstr ""
"<b>Step 2: assegna il team</b> È possibile trascinare manualmente i "
"dipendenti negli slot oppure utilizzare il\n"
"                pulsante <b>Assegna automaticamente</b>. Odoo abbinerà "
"automaticamente il personale in base ai <b>ruoli</b> definiti e alla\n"
"                <b>disponibilità</b> ."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Step 3: Publish &amp; Sync</b> Once the schedule is finalized, click "
"<b>\"Publish.\"</b> Your team will\n"
"                receive:"
msgstr ""
"<b>Step 3: pubblica e sincronizza</b> Una volta finalizzata la "
"pianificazione, clicca su <b>\"Pubblica.\"</b> Il tuo team\n"
"                riceverà:"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Step-by-Step Integration Guides</b>"
msgstr "<b>Guide di integrazione passo passo</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Storable (Traced) Products:</b> Strategic assets that require exact stock "
"counts at all times."
msgstr ""
"<b>Prodotti stoccabili (tracciati):</b> risorse strategiche che richiedono "
"un conteggio esatto delle scorte in ogni momento."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Sync:</b> Enable <b>Sync Shifts and Rental Orders</b> to activate the "
"integration between\n"
"                                the two modules."
msgstr ""
"<b>sincronizzazione:</b> abilitare <b>Sincronizza turni e ordini di "
"noleggio</b> per attivare l'integrazione tra\n"
"                                i due moduli."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Task Management &amp; Custom Workflows</b>"
msgstr "<b>Gestione dei lavori e flussi di lavoro personalizzati</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Terms &amp; Conditions:</b> Ensure legal clarity on every deal."
msgstr "<b>termini e condizioni:</b> assicurati che gli accordi siano chiari"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>The Schedule View:</b> Click on <b>\"Schedule\"</b> for a timeline of "
"your equipment."
msgstr ""
"<b>La vista Programmazione:</b> clicca su <b>\"Programmazione\"</b> per "
"visualizzare la cronologia delle apparecchiature."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Tip:</b> Remove the <i>\"Confirmed Orders\"</i> filter to see pending "
"quotations. This allows you to\n"
"                    spot potential conflicts before they happen."
msgstr ""
"<b>Consiglio:</b> rimuovi il filtro <i>\"Ordini confermati\"</i> per "
"visualizzare i preventivi in sospeso. Ciò consente di\n"
"                    individuare potenziali conflitti prima che si "
"verifichino."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Visualizing Availability</b>"
msgstr "<b>Visualizzazione della disponibilità</b>"

