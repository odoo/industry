#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>1. Recruitment: Finding the Right Talent</b>"
msgstr "<b>1. Reclutamiento: Encuentra al talento adecuado</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>2. Employee Setup: Defining Roles</b>"
msgstr "<b>2. Configuración de empleados: Define funciones</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>3. Planning: The Three-Step Workflow</b>"
msgstr "<b>3. Planeación: Flujo de trabajo en tres pasos</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Access Settings:</b> Navigate to <b>Settings</b> &gt; <b>Calendar</b> "
"&gt; <b>Sync External Calendar</b>."
msgstr ""
"<b>Acceso a ajustes:</b> Ve a <b>Ajustes</b> > <b>Calendario</b> > "
"<b>Sincronizar calendario externo</b>."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Attendee Management:</b> Track your guest list in real-time and send "
"digital tickets/badges via email\n"
"                automatically."
msgstr ""
"<b>Gestión de asistentes:</b> Lleva seguimiento de tu lista de invitados en "
"tiempo real y envía boletos o credenciales digitales por correo "
"electrónico \n"
"                de forma automática."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Automated Booking:</b> Enable online registration to let attendees book "
"their spots instantly."
msgstr ""
"<b>Reservaciones automatizadas:</b> Activa el registro en línea para que los "
"asistentes reserven su lugar al instante."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Automated Stock Transfers</b>"
msgstr "<b>Traslados de inventario automatizados</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Automatic Conflict Prevention:</b> If you have already scheduled an "
"internal event or a staff\n"
"                        \"Montage\" (setup) in the <b>Planning app</b> for "
"that location, Odoo will automatically gray out\n"
"                        those dates on your website."
msgstr ""
"<b>Prevención automática de conflictos:</b> Si ya agendaste un evento "
"interno o un \"montaje\"\n"
"                        en la <b>aplicación Planeación</b> para esa "
"ubicación, Odoo marcará esas fechas en gris\n"
"                        en tu sitio web de forma automática."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Centralized Documentation</b>"
msgstr "<b>Documentación centralizada</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Centralized Logistics Overview</b>"
msgstr "<b>Vista general logística centralizada</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Client Rentals:</b> Standard orders with specific pricing and automated "
"invoicing. (like Jessica Martinez in the demo data)"
msgstr ""
"<b>Alquileres para clientes:</b> Órdenes estándar con precios específicos y "
"facturación automática (como la de Jessica Martínez en los datos de "
"demostración)."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Complex Project Management: </b>Open the \"City Festival – Summer in the "
"Square – Brussels\" opportunity."
msgstr ""
"<b>Gestión de proyectos complejos: </b>Abre la oportunidad \"Festival de la "
"ciudad - Verano en la plaza - Bruselas\"."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Conflict Alerts:</b> When creating a rental quotation, a <b>red icon</b> "
"will appear next to a line item\n"
"                if Odoo detects a stock shortage for those dates."
msgstr ""
"<b>Alertas de conflicto:</b> Al crear una cotización de alquiler, aparecerá "
"un <b>icono rojo</b> junto\n"
"                a una línea si Odoo detecta falta de inventario en esas "
"fechas."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Consumable Products:</b> Items that appear on your picking lists but do "
"not require strict inventory\n"
"                tracking."
msgstr ""
"<b>Productos consumibles:</b> Artículos que aparecen en tus listas de "
"recolección pero que no requieren control estricto de su \n"
"                inventario."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Custom Stages:</b> Tailor project and task stages to align perfectly with "
"your team’s specific internal\n"
"                processes."
msgstr ""
"<b>Etapas personalizadas:</b> Ajusta las etapas de los proyectos y las "
"tareas para que coincidan con los procesos internos específicos de tu\n"
"                equipo."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Delivery:</b> From your Warehouse to the Client."
msgstr "<b>Entrega:</b> Desde tu almacén hasta el cliente."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Direct-to-Event (Dropshipping):</b> For items that should go straight to "
"the venue, change the\n"
"                <b>\"Deliver To\"</b> field to <b>\"Dropship\"</b> and "
"select the event location as the address."
msgstr ""
"<b>Directo al evento (envío directo):</b> Para artículos que deben ir "
"directo al lugar, cambia el campo\n"
"            <b>\"Entregar a\"</b> a <b>\"Envío directo\"</b> y selecciona la "
"ubicación del evento como dirección."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Discounts:</b> Apply price adjustments directly to line items."
msgstr "<b>Descuentos:</b> Aplica ajustes de precio directo en las líneas."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Easy Sharing:</b> Simply copy the <b>Share Link</b> for any document and "
"send it to your team along with\n"
"                their schedule (see planning section)"
msgstr ""
"<b>Comparte con facilidad:</b> Copia el <b>enlace para compartir</b> de "
"cualquier documento y envíaselo a tu equipo junto con\n"
"            su horario (consulta la sección de planificación)"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Establish the Connection:</b> Link each user’s external account to the "
"Odoo Calendar app."
msgstr ""
"<b>Establece la conexión:</b> Vincula la cuenta externa de cada usuario con "
"la aplicación Calendario de Odoo."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>External Calendar Synchronization</b>"
msgstr "<b>Sincronización con calendarios externos</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Flexible Delivery &amp; Dropshipping</b>"
msgstr "<b>Entrega flexible y directa</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Flexible Rental Management</b>"
msgstr "<b>Gestión flexible de alquileres</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Flexible Ticketing:</b> Configure multiple ticket tiers (e.g., Early "
"Bird, VIP, or General Admission)\n"
"                with custom pricing."
msgstr ""
"<b>Venta de boletos flexible:</b> Configura varios tipos de boletos (por "
"ejemplo, venta anticipada, VIP o boleto general)\n"
"            con precios personalizados."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Granular Control:</b> Manage deadlines, assignees, internal notes, and "
"sub-tasks for every stage of the\n"
"                project."
msgstr ""
"<b>Control detallado:</b> Gestiona fechas límite, personas asignadas, notas "
"internas y subtareas en cada etapa del\n"
"            proyecto."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>How it Works in Practice</b>"
msgstr "<b>Cómo funciona en la práctica</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Install eCommerce:</b> Ensure the <b>eCommerce app</b> is active."
msgstr ""
"<b>Instala Comercio electrónico:</b> Asegúrate de que la <b>aplicación "
"Comercio electrónico</b> esté activa."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Integrated Budgeting:</b> Launch a <b>Request for Quotation (RFQ)</b> "
"directly from the project’s smart\n"
"                buttons to ensure all costs are automatically factored into "
"your <b>Project Profitability</b>."
msgstr ""
"<b>Presupuestos integrados:</b> Crea una <b>solicitud de cotización</b> "
"directo desde los botones inteligentes\n"
"                del proyecto para que todos los costos influyan de forma "
"automática en la <b>rentabilidad del proyecto</b>."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Internal Maintenance:</b> Blocks off equipment for repairs or quality "
"checks so it isn't accidentally\n"
"                booked."
msgstr ""
"<b>Mantenimiento interno:</b> Bloquea equipos para reparaciones o controles "
"de calidad y evita reservas por\n"
"                error."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Internal Picking Lists:</b> For items not covered by rentals (like "
"consumables), you can manually create\n"
"                a <b>Picking List</b>. Simply set the <i>Destination</i> to "
"the event location, select your products, and\n"
"                set the date."
msgstr ""
"<b>Listas de recolección internas:</b> Para artículos que no están cubiertos "
"por los alquileres (como consumibles), crea una\n"
"                <b>lista de recolección</b> de forma manual. Define el "
"<i>destino</i> como la ubicación del evento, selecciona los productos\n"
"                y define la fecha."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Internal Warehouse:</b> By default, Odoo assumes items (like new stock) "
"are coming to your warehouse."
msgstr ""
"<b>Almacén interno:</b> De forma predeterminada, Odoo asume que los "
"artículos (como las nuevas existencias) llegan a tu almacén."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Large-Scale Events:</b> Rentals bundled into a larger project at $0 "
"(since the cost is already covered in\n"
"                the overall package)."
msgstr ""
"<b>Eventos a gran escala:</b> Alquileres incluidos en un proyecto más grande "
"a $0 (porque el costo ya está incluido en \n"
"                el paquete general)."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Live Availability:</b> Customers can only book the dates where the venue "
"is free."
msgstr ""
"<b>Disponibilidad en tiempo real:</b> Los clientes solo pueden reservar las "
"fechas en las que el lugar está disponible."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Logistics Overview</b>"
msgstr "<b>Resumen logístico</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Managing Your Own Venue &amp; Location Bookings: </b>If you own the venue "
"where your events take place, you can\n"
"            use Odoo to manage its availability and even allow external "
"clients to book the space online when you aren't\n"
"            using it."
msgstr ""
"<b>Gestiona tu propio recinto y la reservación de ubicaciones: </b>Si el "
"lugar donde realizas tus eventos es tuyo, puedes\n"
"        usar Odoo para gestionar su disponibilidad e incluso permitir que "
"clientes externos reserven el espacio en línea cuando\n"
"        no lo uses."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Official Paperwork:</b> Contracts and legal authorizations (City, Police, "
"etc.)."
msgstr ""
"<b>Documentación oficial:</b> Contratos y autorizaciones legales "
"(Ayuntamiento, Policía, etc.)."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Online Presence:</b> Create beautiful event pages and publish them "
"directly to your website."
msgstr ""
"<b>Presencia en línea:</b> Crea páginas llamativas para tus eventos y "
"publícalas directo en tu sitio web."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Pipeline Management:</b> Track applications, conduct interviews, and hire "
"your team in one centralized\n"
"                dashboard."
msgstr ""
"<b>Gestión del flujo:</b> Da seguimiento a las postulaciones, realiza "
"entrevistas y contrata a tu equipo en un tablero\n"
"                centralizado."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Post &amp; Publish:</b> Create job openings and publish them directly to "
"your Odoo website."
msgstr ""
"<b>Publicar y difundir:</b> Crea vacantes y publícalas directo en tu sitio "
"web de Odoo."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Predefined Templates:</b> Speed up your process with standard layouts."
msgstr ""
"<b>Plantillas predefinidas:</b> Agiliza tu proceso con diseños estándar."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Purchases &amp; Dropshipping:</b> Transfers coming from suppliers."
msgstr ""
"<b>Compras y envío directo:</b> Traslados que provienen de los proveedores."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Rapid Entry:</b> Use Odoo’s built-in <b>scanning feature</b> to manage "
"high-traffic entrances and check\n"
"                in attendees in seconds."
msgstr ""
"<b>Entrada rápida:</b> Usa la <b>función de escaneo</b> integrada de Odoo "
"para gestionar accesos con alto flujo y registrar \n"
"                asistentes en segundos."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Rentals:</b> Equipment moving to and from the client."
msgstr "<b>Alquileres:</b> Equipos que se trasladan desde y hacia el cliente."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Resources:</b> Set the number of resources that can be booked "
"simultaneously (e.g., if\n"
"                                you have two conference rooms, create two "
"resources)."
msgstr ""
"<b>Recursos:</b> Define la cantidad de recursos que se pueden reservar al "
"mismo tiempo (por ejemplo,\n"
"                            si tienes dos salas de conferencias, crea dos "
"recursos)."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Return:</b> From the Client back to your Warehouse."
msgstr "<b>Devolución:</b> Del cliente de regreso a tu almacén."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Sections &amp; Notes:</b> Organize your offer and add context for the "
"client."
msgstr ""
"<b>Secciones y notas:</b> Organiza tu propuesta y agrega contexto para el "
"cliente."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>See it for yourself!</b> (Requires demo data)"
msgstr ""
"<b>¡Compruébalo por tu cuenta!</b> (necesitas los datos de demostración)"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Service Products:</b> Used for high-level quoting or purchasing."
msgstr ""
"<b>Productos de servicio:</b> Úsalos para cotizaciones o compras de alto "
"nivel."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Services:</b> Link the specific service product you want to track as "
"\"rented\" within the\n"
"                                <b>Rental</b> app."
msgstr ""
"<b>Servicios:</b> Vincula el producto de servicio específico que quieres "
"registrar como \"alquilado\" en la\n"
"                            <b>aplicación Alquiler</b>."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Setup Guide</b>"
msgstr "<b>Guía de configuración</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Smart Comparisons:</b> Add alternative products or vendors to a single "
"RFQ. Once you select the best\n"
"                offer, Odoo automatically cancels the other options for you."
msgstr ""
"<b>Comparaciones inteligentes:</b> Agrega productos o proveedores "
"alternativos a una sola solicitud de cotización. Cuando eliges la mejor "
"oferta, \n"
"                Odoo cancela las otras opciones por ti de forma automática."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Sourcing &amp; Comparison</b>"
msgstr "<b>Abastecimiento y comparación</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Staff Resources:</b> Site plans, emergency contact lists, and event "
"agendas."
msgstr ""
"<b>Recursos para el personal:</b> Planos del sitio, listas de contactos de "
"emergencia y agendas del evento."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Step 1: Define the Shifts</b> Create all necessary time slots (e.g., 6 "
"staff for \"Setup\" from 07:00 to\n"
"                15:00, 4 for \"Security\" from 10:00 to 16:00)."
msgstr ""
"<b>Paso 1: Define los turnos.</b> Crea todos los horarios necesarios (por "
"ejemplo, 6 personas para \"Montaje\" de 07:00 a\n"
"            15:00 y 4 para \"Seguridad\" de 10:00 a 16:00)."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Step 2: Assign the Team</b> You can manually drag and drop employees into "
"slots or use the\n"
"                <b>\"Auto-Assign\"</b> button. Odoo will automatically match "
"staff based on their defined <b>Roles</b> and\n"
"                <b>Availability</b>."
msgstr ""
"<b>Paso 2: Asigna el equipo.</b> Puedes arrastrar y soltar empleados en los "
"espacios de forma manual o usar el botón\n"
"            <b>\"Asignar de forma automática\"</b>. Odoo asigna al personal "
"según sus <b>funciones</b> y su\n"
"            <b>disponibilidad</b>."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Step 3: Publish &amp; Sync</b> Once the schedule is finalized, click "
"<b>\"Publish.\"</b> Your team will\n"
"                receive:"
msgstr ""
"<b>Paso 3: Publicar y sincronizar.</b> Cuando el horario quede listo, haz "
"clic en <b>\"Publicar\"</b>. Tu equipo\n"
"            recibirá:"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Step-by-Step Integration Guides</b>"
msgstr "<b>Guías de integración paso a paso</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Storable (Traced) Products:</b> Strategic assets that require exact stock "
"counts at all times."
msgstr ""
"<b>Productos almacenables (con trazabilidad):</b> Activos estratégicos que "
"requieren conteos exactos de existencias en todo momento."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Sync:</b> Enable <b>Sync Shifts and Rental Orders</b> to activate the "
"integration between\n"
"                                the two modules."
msgstr ""
"<b>Sincronización:</b> Activa <b>Sincronizar turnos y órdenes de alquiler</"
"b> para habilitar la integración entre\n"
"                            ambos módulos."

#. module: event_management
