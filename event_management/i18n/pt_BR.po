#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>1. Recruitment: Finding the Right Talent</b>"
msgstr "<b>1. Recrutamento: Encontrando o Talento Certo</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>2. Employee Setup: Defining Roles</b>"
msgstr "<b>2. Configuração do funcionário: Definição de funções</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>3. Planning: The Three-Step Workflow</b>"
msgstr "<b>3. Planejamento: O fluxo de trabalho em três etapas</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Access Settings:</b> Navigate to <b>Settings</b> &gt; <b>Calendar</b> "
"&gt; <b>Sync External Calendar</b>."
msgstr ""
"<b>Acesse as Definições:</b> Navegue para <b>Definições</b> &gt; <b> "
"Calendário</b> &gt; <b> Sincronizar calendário externo</b>."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Attendee Management:</b> Track your guest list in real-time and send "
"digital tickets/badges via email\n"
"                automatically."
msgstr ""
"<b>Gerenciamento de participantes:</b> Acompanhe sua lista de convidados em "
"tempo real e envie ingressos/crachás digitais por e-mail\n"
"                automaticamente."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Automated Booking:</b> Enable online registration to let attendees book "
"their spots instantly."
msgstr ""
"<b>Reserva automatizada:</b> Habilite o registro online para permitir que os "
"participantes reservem suas vagas instantaneamente."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Automated Stock Transfers</b>"
msgstr "<b>Transferências automáticas de estoque</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Automatic Conflict Prevention:</b> If you have already scheduled an "
"internal event or a staff\n"
"                        \"Montage\" (setup) in the <b>Planning app</b> for "
"that location, Odoo will automatically gray out\n"
"                        those dates on your website."
msgstr ""
"<b>Prevenção automática de conflitos:</b> Se você já agendou um evento "
"interno ou uma\n"
"                        \"Montagem\" (configuração) da equipe no aplicativo "
"de <b>Planejamento</b> para esse local, o Odoo automaticamente desativará\n"
"                        essas datas no seu site."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Centralized Documentation</b>"
msgstr "<b>Documentação Centralizada</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Centralized Logistics Overview</b>"
msgstr "<b>Visão geral da logística centralizada</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Client Rentals:</b> Standard orders with specific pricing and automated "
"invoicing. (like Jessica Martinez in the demo data)"
msgstr ""
"<b>Aluguel de clientes:</b> Pedidos padrão com preços específicos e "
"faturamento automatizado. (como Jessica Martinez nos dados de demonstração)"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Complex Project Management: </b>Open the \"City Festival – Summer in the "
"Square – Brussels\" opportunity."
msgstr ""
"<b>Gerenciamento de Projetos Complexos: </b>Abra a oportunidade “Festival da "
"Cidade – Verão na Praça – Bruxelas”."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Conflict Alerts:</b> When creating a rental quotation, a <b>red icon</b> "
"will appear next to a line item\n"
"                if Odoo detects a stock shortage for those dates."
msgstr ""
"<b>Alertas de conflito:</b> Ao criar uma cotação de aluguel, um <b>ícone "
"vermelho</b> aparecerá ao lado de um item de linha\n"
"                se o Odoo detectar falta de estoque para essas datas."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Consumable Products:</b> Items that appear on your picking lists but do "
"not require strict inventory\n"
"                tracking."
msgstr ""
"<b>Produtos consumíveis:</b> Itens que aparecem em suas listas de separação, "
"mas não exigem\n"
"                rastreamento rigoroso de Inventário."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Custom Stages:</b> Tailor project and task stages to align perfectly with "
"your team’s specific internal\n"
"                processes."
msgstr ""
"<b>Etapas personalizadas:</b> Adapte as etapas do Projeto e das tarefas para "
"se alinharem perfeitamente aos processos internos específicos\n"
"                da sua equipe."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Delivery:</b> From your Warehouse to the Client."
msgstr "<b>Entrega:</b> Do seu armazém até o cliente."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Direct-to-Event (Dropshipping):</b> For items that should go straight to "
"the venue, change the\n"
"                <b>\"Deliver To\"</b> field to <b>\"Dropship\"</b> and "
"select the event location as the address."
msgstr ""
"<b>Entrega direta no evento (Dropshipping):</b> Para itens que devem ir "
"diretamente para o local do evento, altere o\n"
"               <b> \"Deliver To\"</b> campo para <b>\"Dropship\"</b> e "
"selecione o local do evento como endereço."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Discounts:</b> Apply price adjustments directly to line items."
msgstr ""
"<b>Descontos:</b> Aplique ajustes de preço diretamente aos itens de linha."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Easy Sharing:</b> Simply copy the <b>Share Link</b> for any document and "
"send it to your team along with\n"
"                their schedule (see planning section)"
msgstr ""
"<b>Compartilhamento fácil:</b> Basta copiar o <b>link de compartilhamento</"
"b> de qualquer documento e enviá-lo à sua equipe junto com\n"
"                a programação deles (consulte a seção de planejamento)"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Establish the Connection:</b> Link each user’s external account to the "
"Odoo Calendar app."
msgstr ""
"<b>Estabeleça a conexão:</b> Vincule a conta externa de cada usuário ao "
"aplicativo Calendário do Odoo."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>External Calendar Synchronization</b>"
msgstr "<b>Sincronização de calendário externo</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Flexible Delivery &amp; Dropshipping</b>"
msgstr "<b>Entrega flexível &amp; Envio Direto</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Flexible Rental Management</b>"
msgstr "<b>Gerenciamento flexível de aluguéis</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Flexible Ticketing:</b> Configure multiple ticket tiers (e.g., Early "
"Bird, VIP, or General Admission)\n"
"                with custom pricing."
msgstr ""
"<b>Venda flexível de ingressos:</b> Configure vários níveis de ingressos "
"(ex.: Early Bird, VIP ou Entrada Geral)\n"
"                com preços personalizados."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Granular Control:</b> Manage deadlines, assignees, internal notes, and "
"sub-tasks for every stage of the\n"
"                project."
msgstr ""
"<b>Controle granular:</b> Gerencie prazos, responsáveis, notas internas e "
"subtarefas para cada etapa do\n"
"                Projeto."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>How it Works in Practice</b>"
msgstr "<b>Como funciona na prática</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Install eCommerce:</b> Ensure the <b>eCommerce app</b> is active."
msgstr ""
"<b>Instale o e-Commerce:</b> Certifique-se de que o aplicativo e-Commerce "
"<b></b> esteja ativo."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Integrated Budgeting:</b> Launch a <b>Request for Quotation (RFQ)</b> "
"directly from the project’s smart\n"
"                buttons to ensure all costs are automatically factored into "
"your <b>Project Profitability</b>."
msgstr ""
"<b> <b>Orçamento Integrado:</b> Inicie uma Solicitação de Cotação (RFQ)</b> "
"diretamente dos botões inteligentes do Projeto\n"
"                para garantir que todos os custos sejam automaticamente "
"considerados na Rentabilidade do Projeto <b></b> ."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Internal Maintenance:</b> Blocks off equipment for repairs or quality "
"checks so it isn't accidentally\n"
"                booked."
msgstr ""
"<b>Manutenção interna:</b> Bloqueia equipamentos para reparos ou "
"verificações de qualidade, para que não sejam acidentalmente\n"
"                reservados."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Internal Picking Lists:</b> For items not covered by rentals (like "
"consumables), you can manually create\n"
"                a <b>Picking List</b>. Simply set the <i>Destination</i> to "
"the event location, select your products, and\n"
"                set the date."
msgstr ""
"<b>Listas de separação internas:</b> Para itens não cobertos por aluguéis "
"(como consumíveis), você pode criar manualmente\n"
"                uma <b>Lista de Separação</b> . Basta definir o <i>Destino</"
"i> como o local do evento, selecionar seus produtos e\n"
"                definir a data."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Internal Warehouse:</b> By default, Odoo assumes items (like new stock) "
"are coming to your warehouse."
msgstr ""
"<b>Armazém Interno:</b> Por padrão, o Odoo assume que os itens (como novos "
"estoques) estão chegando ao seu armazém."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Large-Scale Events:</b> Rentals bundled into a larger project at $0 "
"(since the cost is already covered in\n"
"                the overall package)."
msgstr ""
"<b>Eventos de grande escala:</b> Aluguéis incluídos em um Projeto maior por "
"US$ 0 (já que o custo já está coberto no\n"
"                pacote geral)."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Live Availability:</b> Customers can only book the dates where the venue "
"is free."
msgstr ""
"<b>Disponibilidade em tempo real:</b> Os clientes só podem reservar datas em "
"que o local esteja disponível."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Logistics Overview</b>"
msgstr "<b>Visão geral da logística</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Managing Your Own Venue &amp; Location Bookings: </b>If you own the venue "
"where your events take place, you can\n"
"            use Odoo to manage its availability and even allow external "
"clients to book the space online when you aren't\n"
"            using it."
msgstr ""
"<b>Gerenciarseu próprio local &amp; Reservas de locais: </b>Se você é "
"proprietário do local onde seus eventos acontecem, pode\n"
"            usar o Odoo para gerenciar sua disponibilidade e até mesmo "
"permitir que clientes externos reservem o espaço online quando você não "
"estiver\n"
"            usando-o."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Official Paperwork:</b> Contracts and legal authorizations (City, Police, "
"etc.)."
msgstr ""
"<b>Documentação oficial:</b> Contratos e autorizações legais (Prefeitura, "
"Polícia, etc.)."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Online Presence:</b> Create beautiful event pages and publish them "
"directly to your website."
msgstr ""
"<b>Presença online:</b> Crie belas páginas de eventos e publique-as "
"diretamente em seu site."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Pipeline Management:</b> Track applications, conduct interviews, and hire "
"your team in one centralized\n"
"                dashboard."
msgstr ""
"<b>Gerenciamento de funil:</b> Acompanhe candidaturas, realize entrevistas e "
"contrate sua equipe em um\n"
"                Painel centralizado."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Post &amp; Publish:</b> Create job openings and publish them directly to "
"your Odoo website."
msgstr ""
"<b>Postar &amp; Publicar:</b> Crie vagas de emprego e publique-as "
"diretamente no seu site Odoo."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Predefined Templates:</b> Speed up your process with standard layouts."
msgstr "<b>Modelos predefinidos:</b> Acelere seu processo com layouts padrão."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Purchases &amp; Dropshipping:</b> Transfers coming from suppliers."
msgstr ""
"<b>Compras &amp; Envio Direto:</b> Transferências provenientes de "
"fornecedores."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Rapid Entry:</b> Use Odoo’s built-in <b>scanning feature</b> to manage "
"high-traffic entrances and check\n"
"                in attendees in seconds."
msgstr ""
"<b>Entrada rápida:</b> Use o <b>recurso integrado de leitura de cartões de "
"identificação</b> do Odoo para gerenciar alto tráfego entradas e fazer o\n"
"                check-in de participantes em segundos."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Rentals:</b> Equipment moving to and from the client."
msgstr "<b>Aluguéis:</b> Equipamentos transportados de e para o cliente."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Resources:</b> Set the number of resources that can be booked "
"simultaneously (e.g., if\n"
"                                you have two conference rooms, create two "
"resources)."
msgstr ""
"<b>Recursos:</b> Defina o número de recursos que podem ser reservados "
"simultaneamente (por exemplo, se\n"
"                                você tiver duas salas de conferência, crie "
"dois recursos)."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Return:</b> From the Client back to your Warehouse."
msgstr "<b>Devolução:</b> Do Cliente de volta ao seu Armazém."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Sections &amp; Notes:</b> Organize your offer and add context for the "
"client."
msgstr ""
"<b>Seções &amp; Notas:</b> Organize sua proposta e adicione contexto para o "
"cliente."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>See it for yourself!</b> (Requires demo data)"
msgstr "<b>Veja você mesmo!</b> (Requer dados de demonstração)"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Service Products:</b> Used for high-level quoting or purchasing."
msgstr ""
"<b>Produtos de serviço:</b> Usado para cotações ou compras de alto nível."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Services:</b> Link the specific service product you want to track as "
"\"rented\" within the\n"
"                                <b>Rental</b> app."
msgstr ""
"<b>Serviços:</b> Vincule o produto de serviço específico que você pretende "
