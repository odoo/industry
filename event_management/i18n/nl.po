#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>1. Recruitment: Finding the Right Talent</b>"
msgstr "<b>1. Werving: het juiste talent vinden</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>2. Employee Setup: Defining Roles</b>"
msgstr "<b>2. Werknemers configureren: rollen definiëren</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>3. Planning: The Three-Step Workflow</b>"
msgstr "<b>3. Planning: De workflow in drie stappen</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Access Settings:</b> Navigate to <b>Settings</b> &gt; <b>Calendar</b> "
"&gt; <b>Sync External Calendar</b>."
msgstr ""
"<b>Toegangsinstellingen:</b> Ga naar <b>Instellingen</b> &gt; <b>Agenda</b> "
"&gt; <b>Externe agenda synchroniseren</b>."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Attendee Management:</b> Track your guest list in real-time and send "
"digital tickets/badges via email\n"
"                automatically."
msgstr ""
"<b>Deelnemersbeheer:</b> Houd je gastenlijst realtime bij en verstuur "
"automatisch digitale tickets/badges via e-mail."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Automated Booking:</b> Enable online registration to let attendees book "
"their spots instantly."
msgstr ""
"<b>Geautomatiseerde boeking:</b> Schakel online registratie in zodat "
"deelnemers direct hun plek kunnen reserveren."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Automated Stock Transfers</b>"
msgstr "<b>Geautomatiseerde voorraadverplaatsingen</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Automatic Conflict Prevention:</b> If you have already scheduled an "
"internal event or a staff\n"
"                        \"Montage\" (setup) in the <b>Planning app</b> for "
"that location, Odoo will automatically gray out\n"
"                        those dates on your website."
msgstr ""
"<b>Automatische conflictpreventie:</b> Als je al een intern evenement of een "
"opbouwshift in de <b>Planning-app</b> voor die locatie hebt gepland, zal "
"Odoo die datums automatisch grijs maken op je website."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Centralized Documentation</b>"
msgstr "<b>Gecentraliseerde documentatie</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Centralized Logistics Overview</b>"
msgstr "<b>Gecentraliseerd overzicht van logistiek</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Client Rentals:</b> Standard orders with specific pricing and automated "
"invoicing. (like Jessica Martinez in the demo data)"
msgstr ""
"<b>Verhuur aan klanten:</b> Standaardbestellingen met specifieke prijzen en "
"geautomatiseerde facturatie. (zoals Jessica Martinez in de demodata)"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Complex Project Management: </b>Open the \"City Festival – Summer in the "
"Square – Brussels\" opportunity."
msgstr ""
"<b>Complex projectbeheer: </b>Open de verkoopkans 'Stadsfestival – Zomer op "
"het plein – Brussel'."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Conflict Alerts:</b> When creating a rental quotation, a <b>red icon</b> "
"will appear next to a line item\n"
"                if Odoo detects a stock shortage for those dates."
msgstr ""
"<b>Conflictwaarschuwingen:</b> Bij het aanmaken van een verhuurofferte "
"verschijnt een rood <b>icoon</b> naast een regelitem als Odoo een "
"voorraadtekort voor die data detecteert."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Consumable Products:</b> Items that appear on your picking lists but do "
"not require strict inventory\n"
"                tracking."
msgstr ""
"<b>Consumptiegoederen:</b> Artikelen die op je picklijsten staan, maar geen "
"strikte voorraadregistratie vereisen ."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Custom Stages:</b> Tailor project and task stages to align perfectly with "
"your team’s specific internal\n"
"                processes."
msgstr ""
"<b>Gepersonaliseerde fases:</b> Pas fases in projecten en taken aan zodat ze "
"perfect aansluiten bij de specifieke interne processen van je team."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Delivery:</b> From your Warehouse to the Client."
msgstr "<b>Levering:</b> Van je magazijn naar de klant."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Direct-to-Event (Dropshipping):</b> For items that should go straight to "
"the venue, change the\n"
"                <b>\"Deliver To\"</b> field to <b>\"Dropship\"</b> and "
"select the event location as the address."
msgstr ""
"<b>Rechtstreepse levering (Dropshipping):</b> Voor artikelen die "
"rechtstreeks naar de locatie moeten gaan, wijzig je het veld <b>'Leveren "
"aan'</b> naar <b>'Dropshippen'</b> en selecteer je de evenementlocatie als "
"adres."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Discounts:</b> Apply price adjustments directly to line items."
msgstr ""
"<b>Kortingen:</b> Pas prijsaanpassingen rechtstreeks toe op regelitems."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Easy Sharing:</b> Simply copy the <b>Share Link</b> for any document and "
"send it to your team along with\n"
"                their schedule (see planning section)"
msgstr ""
"<b>Eenvoudig delen:</b> Kopieer gewoon de <b>Deellink</b> voor eender welk "
"document en stuur hem naar je team samen met hun werkschema (zie de sectie "
"'planning')"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Establish the Connection:</b> Link each user’s external account to the "
"Odoo Calendar app."
msgstr ""
"<b>Verbinding tot stand brengen:</b> Koppel het externe account van de "
"gebruiker aan de Agenda-app van Odoo."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>External Calendar Synchronization</b>"
msgstr "<b>Externe agendasynchronisatie</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Flexible Delivery &amp; Dropshipping</b>"
msgstr "<b>Flexibele levering &amp; dropshipping</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Flexible Rental Management</b>"
msgstr "<b>Flexibel verhuurbeheer</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Flexible Ticketing:</b> Configure multiple ticket tiers (e.g., Early "
"Bird, VIP, or General Admission)\n"
"                with custom pricing."
msgstr ""
"<b>Flexibel ticketsysteem:</b> Configureer meerdere ticketcategorieën (bv. "
"Early Bird, VIP of Algemene Toegang) met aangepaste prijzen."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Granular Control:</b> Manage deadlines, assignees, internal notes, and "
"sub-tasks for every stage of the\n"
"                project."
msgstr ""
"<b>Gedetailleerde controle:</b> Beheer deadlines, toegewezen personen, "
"interne notities en subtaken voor elke fase van het project."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>How it Works in Practice</b>"
msgstr "<b>Hoe dit in de praktijk werkt</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Install eCommerce:</b> Ensure the <b>eCommerce app</b> is active."
msgstr ""
"<b>E-commerce installeren:</b> Zorg ervoor dat de <b>E-commerce-app</b> "
"actief is."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Integrated Budgeting:</b> Launch a <b>Request for Quotation (RFQ)</b> "
"directly from the project’s smart\n"
"                buttons to ensure all costs are automatically factored into "
"your <b>Project Profitability</b>."
msgstr ""
"<b>Geïntegreerde budgettering:</b> Creëer een <b>offerteaanvraag</b> via de "
"slimme knoppen van het project om ervoor te zorgen dat alle kosten "
"automatisch worden meegenomen in je <b>projectwinstgevendheid</b>."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Internal Maintenance:</b> Blocks off equipment for repairs or quality "
"checks so it isn't accidentally\n"
"                booked."
msgstr ""
"<b>Intern onderhoud:</b> Blokkeert materialen voor reparaties of "
"kwaliteitscontroles, zodat deze niet per ongeluk worden gereserveerd."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Internal Picking Lists:</b> For items not covered by rentals (like "
"consumables), you can manually create\n"
"                a <b>Picking List</b>. Simply set the <i>Destination</i> to "
"the event location, select your products, and\n"
"                set the date."
msgstr ""
"<b>Interne picking-lijsten:</b> Voor artikelen die niet onder verhuur vallen "
"(zoals verbruiksartikelen) kun je handmatig een <b>picking-lijst</b> "
"aanmaken. Stel gewoon de locatie van het evenement in als <i>bestemming</i>, "
"selecteer je producten en stel de datum in."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Internal Warehouse:</b> By default, Odoo assumes items (like new stock) "
"are coming to your warehouse."
msgstr ""
"<b>Intern magazijn:</b> Standaard gaat Odoo ervan uit dat artikelen (zoals "
"nieuwe voorraad) naar je magazijn komen."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Large-Scale Events:</b> Rentals bundled into a larger project at $0 "
"(since the cost is already covered in\n"
"                the overall package)."
msgstr ""
"<b>Grote evenementen:</b> Verhuur gebundeld in een groter project voor € 0 "
"(aangezien de kosten al gedekt zijn in het totale pakket)."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Live Availability:</b> Customers can only book the dates where the venue "
"is free."
msgstr ""
"<b>Live beschikbaarheid:</b> Klanten kunnen alleen datums boeken waarop de "
"locatie beschikbaar is."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Logistics Overview</b>"
msgstr "<b>Logistiek overzicht</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Managing Your Own Venue &amp; Location Bookings: </b>If you own the venue "
"where your events take place, you can\n"
"            use Odoo to manage its availability and even allow external "
"clients to book the space online when you aren't\n"
"            using it."
msgstr ""
"<b>Je eigen locatie beheren &amp; Locatieboekingen: </b>Als je eigenaar bent "
"van de locatie waar je evenementen plaatsvinden, kun je Odoo gebruiken om de "
"beschikbaarheid ervan te beheren en zelfs externe klanten toestaan de ruimte "
"online te boeken wanneer ze beschikbaar zijn."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Official Paperwork:</b> Contracts and legal authorizations (City, Police, "
"etc.)."
msgstr ""
"<b>Officiële documenten:</b> Contracten en wettelijke vergunningen "
"(gemeente, politie, enz.)."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Online Presence:</b> Create beautiful event pages and publish them "
"directly to your website."
msgstr ""
"<b>Online aanwezigheid:</b> Maak prachtige websitepagina's voor je "
"evenementen en publiceer ze rechtstreeks op je website."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Pipeline Management:</b> Track applications, conduct interviews, and hire "
"your team in one centralized\n"
"                dashboard."
msgstr ""
"<b>Pijplijn beheren:</b> Volg sollicitaties op, voer sollicitatiegesprekken "
"en stel je team samen via één centraal dashboard."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Post &amp; Publish:</b> Create job openings and publish them directly to "
"your Odoo website."
msgstr ""
"<b>Publiceren:</b> Maak vacatures aan en publiceer ze rechtstreeks op je "
"Odoo-website."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Predefined Templates:</b> Speed up your process with standard layouts."
msgstr ""
"<b>Vooraf opgestelde sjablonen:</b> Versnel je proces met standaardlay-outs."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Purchases &amp; Dropshipping:</b> Transfers coming from suppliers."
msgstr ""
"<b>Inkoop &amp; Dropshipping:</b> Verplaatsingen afkomstig van leveranciers."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Rapid Entry:</b> Use Odoo’s built-in <b>scanning feature</b> to manage "
"high-traffic entrances and check\n"
"                in attendees in seconds."
msgstr ""
"<b>Snelle toegang:</b> Gebruik de ingebouwde <b>scanfunctie</b> van Odoo bij "
"drukbezochte ingangen om deelnemers binnen enkele seconden in te checken."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Rentals:</b> Equipment moving to and from the client."
msgstr "<b>Verhuur:</b> Apparatuur die van en naar de klant wordt vervoerd."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Resources:</b> Set the number of resources that can be booked "
"simultaneously (e.g., if\n"
"                                you have two conference rooms, create two "
"resources)."
msgstr ""
"<b>Resources:</b> Stel het aantal resources in dat tegelijkertijd kan worden "
"gereserveerd (bv. als je twee vergaderruimtes hebt, maak dan twee resources "
"aan)."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Return:</b> From the Client back to your Warehouse."
msgstr "<b>Inlevering:</b> Van de klant terug naar je magazijn."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Sections &amp; Notes:</b> Organize your offer and add context for the "
"client."
msgstr ""
"<b>Secties &amp; Notities:</b> Structureer je offerte en voeg context toe "
"voor de klant."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>See it for yourself!</b> (Requires demo data)"
msgstr "<b>Ontdek het zelf eens!</b> (Demodata vereist)"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Service Products:</b> Used for high-level quoting or purchasing."
msgstr "<b>Diensten:</b> Gebruikt voor offertes of inkoop op hoog niveau."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Services:</b> Link the specific service product you want to track as "
"\"rented\" within the\n"
"                                <b>Rental</b> app."
msgstr ""
"<b>Diensten:</b> Koppel het specifieke dienstproduct dat je als 'verhuurd' "
"wilt volgen binnen de <b>Verhuur-app</b>."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Setup Guide</b>"
msgstr "<b>Handleiding</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Smart Comparisons:</b> Add alternative products or vendors to a single "
"RFQ. Once you select the best\n"
"                offer, Odoo automatically cancels the other options for you."
msgstr ""
"<b>Slimme vergelijking:</b> Voeg alternatieve producten of leveranciers toe "
"aan één offerteaanvraag. Zodra je de beste aanbieding selecteert, annuleert "
"Odoo automatisch de andere opties voor je."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid "<b>Sourcing &amp; Comparison</b>"
msgstr "<b>Inkoop &amp; vergelijking</b>"

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Staff Resources:</b> Site plans, emergency contact lists, and event "
"agendas."
msgstr ""
"<b>Documenten voor personeel:</b> Locatieplannen, lijsten met "
"noodcontactencontacten en programma's van evenementen."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Step 1: Define the Shifts</b> Create all necessary time slots (e.g., 6 "
"staff for \"Setup\" from 07:00 to\n"
"                15:00, 4 for \"Security\" from 10:00 to 16:00)."
msgstr ""
"<b>Stap 1: Shifts definiëren</b> Maak alle benodigde tijdsloten aan (bv. 6 "
"medewerkers voor 'Opbouw' van 07:00 tot 15:00, 4 voor 'Beveiliging' van "
"10:00 tot 16:00)."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Step 2: Assign the Team</b> You can manually drag and drop employees into "
"slots or use the\n"
"                <b>\"Auto-Assign\"</b> button. Odoo will automatically match "
"staff based on their defined <b>Roles</b> and\n"
"                <b>Availability</b>."
msgstr ""
"<b>Stap 2: Team toewijzen</b> Je kunt werknemers handmatig naar de "
"tijdsloten slepen of de knop <b>'Automatisch toewijzen'</b> gebruiken. Odoo "
"koppelt automatisch werknemers op basis van hun gedefinieerde <b>Rollen</b> "
"en <b>Beschikbaarheid</b>."

#. module: event_management
#: model_terms:ir.ui.view,arch_db:event_management.welcome_article_body
msgid ""
"<b>Step 3: Publish &amp; Sync</b> Once the schedule is finalized, click "
"<b>\"Publish.\"</b> Your team will\n"
"                receive:"
msgstr ""
"<b>Stap 3: Publiceren &amp; Synchroniseren</b> Zodra het schema definitief "
"is, klik je op <b>'Publiceren'.</b> Je team ontvangt:"

