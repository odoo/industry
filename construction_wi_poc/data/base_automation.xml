<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="automation_create_delivery_location_on_so_confirm" model="base.automation">
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="action_server_ids" eval="[(6, 0, [ref('action_create_delivery_location_on_sales_order_confirm')])]"/>
        <field name="trigger">on_create_or_write</field>
        <field name="name">Construction Developer: Create delivery location on Sales Order confirm</field>
        <field name="trigger_field_ids" eval="[(6, 0, [ref('sale.field_sale_order__state')])]"/>
    </record>
    <record id="automation_on_mo_creation" model="base.automation">
        <field name="model_id" ref="mrp.model_mrp_production"/>
        <field name="action_server_ids" eval="[(6, 0, [ref('action_apply_locations_on_mo')])]"/>
        <field name="trigger">on_create</field>
        <field name="filter_domain" eval="[
            ('location_src_id',  '=', ref('construction_wi_poc.stock_location_worksites')),
            ('location_dest_id', '=', ref('stock.stock_location_customers')),
            ('sale_line_id', '!=', False),
        ]"/>
        <field name="name">Construction Developer: On Procurement MO Created from SO</field>
    </record>
</odoo>
