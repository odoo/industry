msgid "<strong><span class=\"h4-fs\">Goods</span></strong>"
msgstr "<strong><span class=\"h4-fs\">ເຄື່ອງຂອງ</span></strong>"

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid "<strong><span class=\"h4-fs\">Services</span></strong>"
msgstr "<strong><span class=\"h4-fs\">ການບໍລິການ</span></strong>"

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>Based on timesheets, subcontracted</strong> (Design presentation "
"&amp; revisions, this config will create a new Purchase Order to buy this "
"prestation and create a task in the dedicated project)."
msgstr ""
"<strong>ອີງຕາມໃບບັນທຶກເວລາ, ຈ້າງເໝົາຊ່ວງ</strong> (ການນຳສະເໜີການອອກແບບ ແລະ ການປັບປຸງ, "
"ການກຳນົດຄ່ານີ້ຈະສ້າງໃບສັ່ງຊື້ໃໝ່ເພື່ອຊື້ການບໍລິການນີ້ ແລະ ສ້າງວຽກໃນໂຄງການທີ່ກ່ຽວຂ້ອງ)."

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>Based on timesheets</strong> (Concept Development and 3D renderings,"
" this one will create a specific task in the existing \"3D Renderings\" "
"Project)"
msgstr ""
"<strong>ອີງຕາມໃບບັນທຶກເວລາ</strong> (ການພັດທະນາແນວຄວາມຄິດ ແລະ ການສະແດງພາບ 3D, ອັນນີ້ຈ"
"ະສ້າງວຽກສະເພາະໃນໂຄງການ \"3D Renderings\" ທີ່ມີຢູ່)"

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>Based on timesheets</strong> - Field services (Delivery and "
"installation &amp; Electrical and lighting installation) will automatically "
"create a task in the Field Service App."
msgstr ""
"<strong>ອີງຕາມໃບບັນທຶກເວລາ</strong> - ການບໍລິການພາກສະໜາມ (ການຈັດສົ່ງ ແລະ ການຕິດຕັ້ງ "
"&amp; ການຕິດຕັ້ງລະບົບໄຟຟ້າ ແລະ ແສງສະຫວ່າງ) ຈະສ້າງວຽກໃນແອັບບໍລິການພາກສະໜາມໂດຍອັດຕະໂນມັດ."

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid "<strong>Basics:</strong>"
msgstr "<strong>ພື້ນຖານ:</strong>"

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>Components </strong>that will serve to create manufactured products."
msgstr "<strong>ສ່ວນປະກອບ </strong>ທີ່ຈະໃຊ້ເພື່ອສ້າງສິນຄ້າທີ່ຜະລິດ."

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>Consumable goods:</strong> These will not be tracked (Such as bolts,"
" finish painting, and sandpaper)."
msgstr ""
"<strong>ສິນຄ້າບໍລິໂພກ:</strong> ເຫຼົ່ານີ້ຈະບໍ່ຖືກຕິດຕາມ (ເຊັ່ນ: ສະລັກ, ສີທາສຳເລັດຮູບ, ແລະ ເຈ້ຍຊາ"
"ຍ)."

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>Field Service Automation:</strong> Certain products trigger the "
"creation of Field Service tasks specifically for onsite installation."
msgstr ""
"<strong>ລະບົບການບໍລິການພາກສະໜາມອັດຕະໂນມັດ:</strong> ສິນຄ້າບາງຢ່າງຈະກະຕຸ້ນການສ້າງວຽກບໍລິການ"
"ພາກສະໜາມ ໂດຍສະເພາະສຳລັບການຕິດຕັ້ງຢູ່ໜ້າວຽກ."

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>Jane Design</strong>: She is your subcontractor for Design "
"presentations and revisions."
msgstr ""
"<strong>Jane Design</strong>: ລາວແມ່ນຜູ້ຮັບເໝົາຊ່ວງຂອງທ່ານສຳລັບການນຳສະເໜີການອອກແບບ ແລ"
"ະ ການປັບປຸງ."

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>Manufactured Goods </strong>will be manufactured based on a Bill of "
"Material."
msgstr "<strong>ສິນຄ້າທີ່ຜະລິດ </strong>ຈະຖືກຜະລິດໂດຍອີງຕາມລາຍການວັດສະດຸ (BOM)."

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>My Chairs Vendor</strong>: Will provide you Conference chairs to "
"complete your order."
msgstr ""
"<strong>ຜູ້ສະໜອງຕັ່ງຂອງຂ້ອຍ</strong>: ຈະສະໜອງຕັ່ງປະຊຸມໃຫ້ທ່ານເພື່ອເຮັດໃຫ້ຄຳສັ່ງຊື້ຂອງທ່ານສົມບູນ."

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>My Metal Vendor</strong>: Will provide the Conference Table Metal "
"Legs you need to manufacture the conference table."
msgstr ""
"<strong>ຜູ້ສະໜອງໂລຫະຂອງຂ້ອຍ</strong>: ຈະສະໜອງຂາໂລຫະຂອງໂຕະປະຊຸມທີ່ທ່ານຕ້ອງການເພື່ອຜະລິດໂຕ"
"ະປະຊຸມ."

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>My Rug Vendor</strong>: Will provide you the custom area rug in "
"sufficient square meters."
msgstr ""
"<strong>ຜູ້ສະໜອງພົມຂອງຂ້ອຍ</strong>: ຈະສະໜອງພົມຕາມສັ່ງໃຫ້ທ່ານໃນຈຳນວນຕາແມັດທີ່ພຽງພໍ."

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>My Wood Vendor</strong>: Will send you the Oak Wood Panels you need "
"to create the tables."
msgstr ""
"<strong>ຜູ້ສະໜອງໄມ້ຂອງຂ້ອຍ</strong>: ຈະສົ່ງແຜ່ນໄມ້ໂອກທີ່ທ່ານຕ້ອງການເພື່ອສ້າງໂຕະ."

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>Prepaid services, fixed price</strong> (Initial design consultation "
"&amp; Final Inspection. Note that the first one will also create a new "
"project for each confirmed order to ensure Project follow-up)."
msgstr ""
"<strong>ການບໍລິການແບບຈ່າຍລ່ວງໜ້າ, ລາຄາຄົງທີ່</strong> (ການປຶກສາຫາລືການອອກແບບເບື້ອງຕົ້ນ "
"&amp; ການກວດກາຂັ້ນສຸດທ້າຍ. ສັງເກດວ່າອັນທຳອິດຈະສ້າງໂຄງການໃໝ່ສຳລັບແຕ່ລະຄຳສັ່ງຊື້ທີ່ຢືນຢັນແລ້ວ ເພື່ອຮັບປ"
"ະກັນການຕິດຕາມໂຄງການ)."

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>Project Templates</strong>: Create reusable models with pre-set "
"tasks and dates."
msgstr ""
"<strong>ແບບຢ່າງໂຄງການ</strong>: ສ້າງຮູບແບບທີ່ສາມາດນຳມາໃຊ້ໃໝ່ໄດ້ ພ້ອມກັບວຽກ ແລະ ວັນທີທີ່ກຳນົດ"
"ໄວ້ລ່ວງໜ້າ."

#. module: custom_furniture
