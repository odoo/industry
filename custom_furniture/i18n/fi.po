#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid "<strong><span class=\"h4-fs\">Services</span></strong>"
msgstr "<strong><span class=\"h4-fs\">Palvelut</span></strong>"

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>Based on timesheets, subcontracted</strong> (Design presentation "
"&amp; revisions, this config will create a new Purchase Order to buy this "
"prestation and create a task in the dedicated project)."
msgstr ""
"<strong>Työaikataulujen perusteella, alihankinta</strong> (Design "
"presentaatiot &amp; tarkistukset, tämä asetus luo uuden ostotilauksen tämän "
"esiasetuksen ostamiseen ja luo tehtävän vastaavaan projektiin)."

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>Based on timesheets</strong> (Concept Development and 3D renderings, "
"this one will create a specific task in the existing \"3D Renderings\" "
"Project)"
msgstr ""
"<strong>Työaikataulujen perusteella</strong> (konseptin kehittäminen ja 3D-"
"versiot, tämä luo erityisen tehtävän olemassa olevaan \"3D-versiot\"-"
"projektiin)"

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>Based on timesheets</strong> - Field services (Delivery and "
"installation &amp; Electrical and lighting installation) will automatically "
"create a task in the Field Service App."
msgstr ""
"<strong>Perustuu työaikakirjauksiin</strong> - Kenttäpalvelut (toimitus ja "
"asennus &amp; sähkö- ja valaistusasennus) luo automaattisesti tehtävän "
"Kenttähuolto-sovellukseen."

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid "<strong>Basics:</strong>"
msgstr "<strong>Perustiedot:</strong>"

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>Components </strong>that will serve to create manufactured products."
msgstr "<strong>Komponentit </strong>, joista luodaan valmistettuja tuotteita."

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>Consumable goods:</strong> These will not be tracked (Such as bolts, "
"finish painting, and sandpaper)."
msgstr ""
"<strong>Kulutustavarat:</strong> (Kuten pultit, maalaus ja hiekkapaperi)."

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>Field Service Automation:</strong> Certain products trigger the "
"creation of Field Service tasks specifically for onsite installation."
msgstr ""

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>Jane Design</strong>: She is your subcontractor for Design "
"presentations and revisions."
msgstr ""
"<strong>Jane Design</strong>: Hän on alihankkijasi design presentaatioiden "
"ja tarkistusten osalta."

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>Manufactured Goods </strong>will be manufactured based on a Bill of "
"Material."
msgstr ""
"<strong>Valmistetut tavarat </strong>valmistetaan materiaaliluettelon "
"perusteella."

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>My Chairs Vendor</strong>: Will provide you Conference chairs to "
"complete your order."
msgstr ""
"<strong>Tuolieni toimittaja</strong>: Tarjoaa sinulle tuoleja "
"konferensseihin tilauksesi loppuun saattamiseksi."

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>My Metal Vendor</strong>: Will provide the Conference Table Metal "
"Legs you need to manufacture the conference table."
msgstr ""
"<strong>Metallin toimittaja</strong>: Tarjoaa konferenssipöytiin "
"metallijalat, joita tarvitset konferenssipöydän valmistamiseen."

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>My Rug Vendor</strong>: Will provide you the custom area rug in "
"sufficient square meters."
msgstr ""
"<strong>Mattojen toimittaja</strong>: Tarjoaa sinulle mittatilaustyönä "
"tehdyn maton."

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>My Wood Vendor</strong>: Will send you the Oak Wood Panels you need "
"to create the tables."
msgstr ""
"<strong>Puun toimittaja</strong>: Lähettää sinulle pöytien luomiseen "
"tarvitsemasi tammipuupaneelit."

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>Prepaid services, fixed price</strong> (Initial design consultation "
"&amp; Final Inspection. Note that the first one will also create a new "
"project for each confirmed order to ensure Project follow-up)."
msgstr ""
"<strong>Ennakkoon maksetut palvelut, kiinteään hintaan</strong> "
"(Alkuperäinen suunnittelukonsultaatio &amp; lopputarkastus. Huomaa, että "
"ensimmäinen luo myös uuden projektin jokaiselle vahvistetulle tilaukselle "
"projektin seurannan varmistamiseksi)."

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>Project Templates</strong>: Create reusable models with pre-set "
"tasks and dates."
msgstr ""

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>Purchased Goods</strong> that will be purchased and sold to your "
"customers."
msgstr ""
"<strong>Ostetut tavarat</strong>, jotka ostetaan ja myydään asiakkaillesi."

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>Sales Order Integration:</strong> Automatically generate project and/"
"or tasks when certain products are included on a Sales Order."
msgstr ""

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"A Quality Check Point has been set for each product. It requires your worker "
"or the Quality Team to take a picture of any manufactured item. Use any "
"image to pass the check for this demo."
msgstr ""
"Kullekin tuotteelle on asetettu laaduntarkistuspiste. Asetus edellyttää, "
"että työntekijäsi tai laatutiimi ottaa kuvan valmistetusta tuotteesta. Voit "
"käyttää mitä tahansa kuvaa läpäistäksesi tarkastuksen tässä demossa."

