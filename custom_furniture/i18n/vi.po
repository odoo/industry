msgid "<strong><span class=\"h4-fs\">Goods</span></strong>"
msgstr "<strong><span class=\"h4-fs\">Hàng hoá</span></strong>"

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid "<strong><span class=\"h4-fs\">Services</span></strong>"
msgstr "<strong><span class=\"h4-fs\">Dịch vụ</span></strong>"

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>Based on timesheets, subcontracted</strong> (Design presentation "
"&amp; revisions, this config will create a new Purchase Order to buy this "
"prestation and create a task in the dedicated project)."
msgstr ""
"<strong>Dựa trên bảng chấm công, gia công</strong> (Trình bày thiết kế & sửa "
"đổi, cấu hình này sẽ tạo Đơn mua hàng mới để mua trạm này và tạo nhiệm vụ "
"trong dự án riêng)."

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>Based on timesheets</strong> (Concept Development and 3D renderings, "
"this one will create a specific task in the existing \"3D Renderings\" "
"Project)"
msgstr ""
"<strong>Dựa trên bảng chấm công</strong> (Phát triển ý tưởng và kết xuất 3D, "
"bảng này sẽ tạo ra một nhiệm vụ cụ thể trong Dự án \"Kết xuất 3D\" hiện có)"

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>Based on timesheets</strong> - Field services (Delivery and "
"installation &amp; Electrical and lighting installation) will automatically "
"create a task in the Field Service App."
msgstr ""
"<strong>Dựa trên bảng chấm công</strong> - Dịch vụ hiện trường (Giao hàng và "
"lắp đặt & Lắp đặt điện và hệ thống chiếu sáng) sẽ tự động tạo nhiệm vụ trong "
"Ứng dụng Dịch vụ hiện trường."

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid "<strong>Basics:</strong>"
msgstr "<strong>Cơ sở:</strong>"

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>Components </strong>that will serve to create manufactured products."
msgstr ""
"<strong>Thành phần</strong>sẽ phục vụ cho việc tạo ra các sản phẩm được sản "
"xuất."

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>Consumable goods:</strong> These will not be tracked (Such as bolts, "
"finish painting, and sandpaper)."
msgstr ""
"<strong>Sản phẩm tiêu thụ:</strong> Những mặt hàng này sẽ không được theo "
"dõi (chẳng hạn như bu lông, sơn hoàn thiện và giấy ráp)."

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>Field Service Automation:</strong> Certain products trigger the "
"creation of Field Service tasks specifically for onsite installation."
msgstr ""

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>Jane Design</strong>: She is your subcontractor for Design "
"presentations and revisions."
msgstr ""
"<strong>Jane Design</strong>: Cô ấy là nhà thầu phụ của bạn về các bài "
"thuyết trình và bản sửa đổi thiết kế."

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>Manufactured Goods </strong>will be manufactured based on a Bill of "
"Material."
msgstr ""
"<strong>Hàng sản xuất</strong> sẽ được sản xuất dựa trên Danh mục vật tư."

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>My Chairs Vendor</strong>: Will provide you Conference chairs to "
"complete your order."
msgstr ""
"<strong>Nhà cung cấp ghế của tôi:</strong> Sẽ cung cấp cho bạn ghế phòng hội "
"nghị để hoàn tất đơn hàng của bạn."

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>My Metal Vendor</strong>: Will provide the Conference Table Metal "
"Legs you need to manufacture the conference table."
msgstr ""
"<strong>Nhà cung cấp kim loại của tôi</strong>: Sẽ cung cấp chân kim loại "
"cho bàn phòng hội nghị mà bạn cần để sản xuất bàn phòng hội nghị."

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>My Rug Vendor</strong>: Will provide you the custom area rug in "
"sufficient square meters."
msgstr ""
"<strong>Nhà cung cấp thảm của tôi</strong>: Sẽ cung cấp cho bạn tấm thảm "
"trải sàn theo yêu cầu với diện tích mét vuông phù hợp."

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>My Wood Vendor</strong>: Will send you the Oak Wood Panels you need "
"to create the tables."
msgstr ""
"<strong>Nhà cung cấp gỗ của tôi</strong>: Sẽ gửi cho bạn các tấm gỗ sồi mà "
"bạn cần để làm bàn."

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>Prepaid services, fixed price</strong> (Initial design consultation "
"&amp; Final Inspection. Note that the first one will also create a new "
"project for each confirmed order to ensure Project follow-up)."
msgstr ""
"<strong>Dịch vụ trả trước, giá cố định</strong> (Tư vấn thiết kế ban đầu & "
"Kiểm tra hoàn thiện. Lưu ý rằng hoạt động đầu tiên cũng sẽ tạo một dự án mới "
"cho mỗi đơn hàng đã xác nhận để đảm bảo follow-up Dự án)."

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>Project Templates</strong>: Create reusable models with pre-set "
"tasks and dates."
msgstr ""

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>Purchased Goods</strong> that will be purchased and sold to your "
"customers."
msgstr "<strong>Hàng mua</strong> sẽ được mua và bán cho khách hàng của bạn."

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"<strong>Sales Order Integration:</strong> Automatically generate project and/"
"or tasks when certain products are included on a Sales Order."
msgstr ""
"<strong>Tích hợp đơn bán hàng:</strong> Tự động tạo dự án và/hoặc nhiệm vụ "
"khi các sản phẩm cụ thể được bao gồm trong đơn bán hàng."

#. module: custom_furniture
#: model_terms:ir.ui.view,arch_db:custom_furniture.welcome_article_body
msgid ""
"A Quality Check Point has been set for each product. It requires your worker "
"or the Quality Team to take a picture of any manufactured item. Use any "
"image to pass the check for this demo."
msgstr ""
"Điểm kiểm tra chất lượng đã được thiết lập cho mỗi sản phẩm. Yêu cầu nhân "
"viên của bạn hoặc Bộ phận chất lượng chụp ảnh bất kỳ sản phẩm nào được sản "
"xuất. Sử dụng bất kỳ hình ảnh nào để vượt qua kiểm tra trong bản demo này."

#. module: custom_furniture
#: model:product.template,name:custom_furniture.product_product_7_product_template
msgid "Accent chairs"
msgstr "Ghế accent"

