<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <function model="hr.expense" name="action_submit_expenses">
        <value model="hr.expense" eval="[ref('architects.hr_expense_1'),ref('architects.hr_expense_2')]"/>
    </function>

    <function model="hr.expense.sheet" name="action_submit_sheet">
        <value model="hr.expense.sheet" eval="[
            obj().env.ref('architects.hr_expense_1').sheet_id.id,
            obj().env.ref('architects.hr_expense_2').sheet_id.id
        ]"/>
    </function>

    <function model="hr.expense.sheet" name="action_approve_expense_sheets">
        <value model="hr.expense.sheet" eval="[
            obj().env.ref('architects.hr_expense_1').sheet_id.id,
            obj().env.ref('architects.hr_expense_2').sheet_id.id
        ]"/>
    </function>
</odoo>
