<odoo>
    <record id="default_map_view_for_4ab87c01-aa44-4ade-a53f-9beb040d5fc3" model="ir.ui.view">
        <field name="name">Default map view for ir.model(586,)</field>
        <field name="model">project.project</field>
        <field name="type">map</field>
        <field name="arch" type="xml">
            <map res_partner="partner_id" />
        </field>
    </record>
    <record id="odoo_studio_crm_lead_9b81830c-f164-48da-9916-c68328583887" model="ir.ui.view">
        <field name="name">Odoo Studio: crm.lead.kanban.lead customization</field>
        <field name="model">crm.lead</field>
        <field name="type">kanban</field>
        <field name="inherit_id" ref="crm.crm_case_kanban_view_leads" />
        <field name="mode">extension</field>
        <field name="priority">320</field>
        <field name="arch" type="xml">
            <data>
                <xpath expr="//kanban[1]/templates[1]/t[2]/div[1]/div[2]/div[2]/t[1]/field[@name='expected_revenue']" position="after">
                    <field name="x_studio_request_date" display="full" />
                </xpath>
            </data>
        </field>
    </record>
    <record id="odoo_studio_crm_lead_e88e73a4-125f-457a-a266-6a5c2e58aafd" model="ir.ui.view">
        <field name="name">Odoo Studio: crm.lead.form customization</field>
        <field name="model">crm.lead</field>
        <field name="type">form</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form" />
        <field name="mode">extension</field>
        <field name="priority">160</field>
        <field name="arch" type="xml">
            <data>
                <xpath expr="//form[1]/sheet[1]/group[1]" position="after">
                    <group name="studio_group_h7X3q">
                        <group name="studio_group_h7X3q_left" string="Request Details">
                            <field name="x_studio_request_date" string="Request date" />
                            <field name="x_studio_project_expected_start_date" string="Project expected start date" />
                            <field name="x_studio_project_type" string="Project type" />
                        </group>
                    </group>
                </xpath>
            </data>
        </field>
    </record>
    <record id="odoo_studio_default__986080b9-0971-440f-8094-107e91194604" model="ir.ui.view">
        <field name="name">Odoo Studio: Default map view for ir.model(586,) customization</field>
        <field name="model">project.project</field>
        <field name="type">map</field>
        <field name="inherit_id" ref="architects.default_map_view_for_4ab87c01-aa44-4ade-a53f-9beb040d5fc3" />
        <field name="mode">extension</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <data>
                <xpath expr="//map[1]" position="attributes">
                    <attribute name="res_partner">x_studio_associated_location</attribute>
                </xpath>
            </data>
        </field>
    </record>
    <record id="odoo_studio_project__1b8558da-cd78-4f38-b790-c037890e2c04" model="ir.ui.view">
        <field name="name">Odoo Studio: project.project.kanban customization</field>
        <field name="model">project.project</field>
        <field name="type">kanban</field>
        <field name="inherit_id" ref="project.view_project_kanban" />
        <field name="mode">extension</field>
        <field name="priority">2000</field>
        <field name="arch" type="xml">
            <data>
                <xpath expr="//kanban[1]/templates[1]/t[2]/div[1]/div[1]/div[1]/div[1]/div[1]/field[@name='tag_ids']" position="after">
                    <field name="x_studio_project_reference" display="full" />
                </xpath>
            </data>
        </field>
    </record>
    <record id="odoo_studio_project__96d33977-59cc-43a6-a884-dc95c7a4f4b7" model="ir.ui.view">
        <field name="name">Odoo Studio: project.project.form customization</field>
        <field name="model">project.project</field>
        <field name="type">form</field>
        <field name="inherit_id" ref="project.edit_project" />
        <field name="mode">extension</field>
        <field name="priority">330</field>
        <field name="arch" type="xml">
            <data>
                <xpath expr="//form[1]/sheet[1]/group[1]/group[1]/field[@name='partner_id']" position="after">
                    <field name="x_studio_promoter" string="Promoter" />
                    <field name="x_studio_associated_location" string="Associated Location" />
                </xpath>
                <xpath expr="//field[@name='active']" position="after">
                    <field name="x_studio_project_reference" string="Project reference" />
                </xpath>
                <xpath expr="//field[@name='allocated_hours']" position="after">
                    <field name="x_studio_cadastral_number" string="Cadastral number" />
                </xpath>
            </data>
        </field>
    </record>
    <record id="odoo_studio_res_part_1416acbc-325d-476c-81a6-393bed65f283" model="ir.ui.view">
        <field name="name">Odoo Studio: res.partner.form customization</field>
        <field name="model">res.partner</field>
        <field name="type">form</field>
        <field name="inherit_id" ref="base.view_partner_form" />
        <field name="mode">extension</field>
        <field name="priority">170</field>
        <field name="arch" type="xml">
            <data>
                <xpath expr="//form[1]/sheet[1]/group[1]/group[1]/div[1]" position="after">
                    <field name="x_studio_is_a_project_location" string="Is a project location" />
                </xpath>
            </data>
        </field>
    </record>
</odoo>
