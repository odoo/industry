#. module: architects
#: model_terms:ir.ui.view,arch_db:architects.welcome_article_body
msgid ""
"<b>CRM App</b>: Centralize client interactions to effectively manage leads "
"and convert design proposals into\n"
"                signed contracts."
msgstr ""
"<b>Aplikasi CRM</b>: Pusatkan interaksi dengan klien untuk mengelola lead "
"secara efektif dan mengubah proposal desain menjadi\n"
"                kontrak bertanda tangan."

#. module: architects
#: model_terms:ir.ui.view,arch_db:architects.welcome_article_body
msgid ""
"<b>Documents App</b>: Securely organize, version, and share critical files "
"such as architectural drawings,\n"
"                permits, and blueprints."
msgstr ""
"<b>Aplikasi Dokumen</b>: Atur, kelompokkan, dan bagikan file penting seperti "
"gambar arsitektur,\n"
"                izin, dan cetak biru dengan aman."

#. module: architects
#: model_terms:ir.ui.view,arch_db:architects.welcome_article_body
msgid ""
"<b>Invoicing App</b>: Maintain healthy cash flow by billing clients flexibly "
"based on project milestones or\n"
"                actual time spent."
msgstr ""
"<b>Aplikasi Faktur</b>: Jaga arus kas yang sehat dengan menagih klien secara "
"fleksibel berdasarkan milestone proyek atau\n"
"                jam kerja aktual."

#. module: architects
#: model_terms:ir.ui.view,arch_db:architects.welcome_article_body
msgid ""
"<b>Knowledge App</b>: Centralize design standards, building codes, and "
"internal guidelines to ensure consistency\n"
"                across the team."
msgstr ""
"<b>Aplikasi Pengetahuan</b>: Pusatkan standar desain, kode bangunan, dan "
"pedoman internal agar konsistensi\n"
"                terjaga di seluruh tim."

#. module: architects
#: model_terms:ir.ui.view,arch_db:architects.welcome_article_body
msgid ""
"<b>Project App</b>: Orchestrate complex architectural projects by managing "
"distinct phases like schematic\n"
"                design, development, and construction."
msgstr ""
"<b>Aplikasi Project</b>: Koordinasikan proyek arsitektur yang kompleks "
"dengan mengelola berbagai fase seperti desain skematik,\n"
"                pengembangan, dan konstruksi."

#. module: architects
#: model_terms:ir.ui.view,arch_db:architects.welcome_article_body
msgid ""
"<b>Sales App</b>: Create professional proposals and contracts tailored for "
"architectural services, streamlining\n"
"                the agreement process."
msgstr ""
"<b>Aplikasi Sales</b>: Buat proposal dan kontrak yang profesional dan sesuai "
"untuk layanan arsitektur, sehingga\n"
"                proses perjanjian menjadi lebih efisien."

#. module: architects
#: model_terms:ir.ui.view,arch_db:architects.welcome_article_body
msgid ""
"<b>Timesheets App</b>: Ensure profitability by accurately tracking time "
"spent on design drafting, client\n"
"                meetings, and site visits."
msgstr ""
"<b>Aplikasi Timesheet</b>: Jaga profitabilitas dengan melacak waktu yang "
"dihabiskan secara akurat untuk penyusunan desain,\n"
"                pertemuan klien, dan kunjungan lokasi."

