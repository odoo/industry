#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid "<span style=\"font-size: 36px;\"><strong>Cake shop</strong></span>"
msgstr "<span style=\"font-size: 36px;\"><strong>Cukrárna</strong></span>"

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Accept flexible payments</strong>: Provide multiple payment options "
"(cash, card, mobile)."
msgstr ""
"<strong>Přijimejte flexibilní platby</strong>: Poskytněte více možnosti "
"platby (hotovost, karta, mobil)."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Choose the best vendor</strong>: Pick the vendor offering the best "
"deal for the requested materials."
msgstr ""
"<strong>Vyberte nejlepšího dodavatele</strong>: Zvolte dodavatele, který "
"nabízí nejlepší ceny za požadované materiály."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Create a purchase order</strong>: Select the materials you need for "
"your cakes and pastries."
msgstr ""
"<strong>Vytvořte nákupní objednávku</strong>: Vyberte materiály, které "
"potřebujete pro své dorty a moučníky."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Custom orders</strong>: Let customers place custom cake orders for "
"special occasions via your online store by allowing them to specify details "
"like size, flavor, and decoration in a custom order form."
msgstr ""
"<strong>Vlastní objednávky</strong>: Nechte zákazníky zadávat objednávky "
"dortů na zakázku pro speciální příležitosti prostřednictvím vašeho "
"internetového obchodu a vybrat si detaily, jako jsou velikost, příchuť a "
"dekorace."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.ir_ui_view_1538
msgid "<strong>Made with love</strong>"
msgstr "<strong>Vyrobeno s láskou</strong>"

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Marketing automation</strong>: Manage all communication channels "
"(email, social media, SMS) in one place."
msgstr ""
"<strong>Marketingová automatizace</strong>: Spravujte všechny komunikační "
"kanály (e-mail, sociální sítě, SMS) z jednoho místa."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Online orders, In-shop pickup</strong>: Allow customers to order "
"online, pay in-store, and pick up at the shop."
msgstr ""
"<strong>Online objednávky, vyzvednutí na místě</strong>: Nechte zákazníky "
"objednat online, zaplatit u pokladny a vyzvednout na místě."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Take orders in Point of Sales</strong>: Process in-store cake and "
"pastry orders quickly using the Point of Sales system."
msgstr ""
"<strong>Sbírejte objednávky v Pokladním systému</strong>: Rychlé zpracování "
"objednávek dortů a pečiva v prodejně pomocí Pokladního systému."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>You didn't import demo data?</strong> You can still do it. Go to "
"<strong>Apps &gt; Industries &gt; Upgrade your Cake Shop Package</strong> "
"and check the related box."
msgstr ""
"<strong>Nenaimportovali jste demo data?</strong> Stále to můžete udělat. "
"Přejděte do sekce <strong>Aplikace &gt; Odvětví &gt; Aktualizujte balíček "
"Cukrárny</strong> a zaškrtněte příslušné políčko."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.ir_ui_view_1538
