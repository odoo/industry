#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid "<span style=\"font-size: 36px;\"><strong>Cake shop</strong></span>"
msgstr "<span style=\"font-size: 36px;\"><strong>Pâtisserie</strong></span>"

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Accept flexible payments</strong>: Provide multiple payment options "
"(cash, card, mobile)."
msgstr ""
"<strong>Acceptez des paiements flexibles</strong> : proposez plusieurs "
"options de paiement (espèces, carte, téléphone mobile)."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Choose the best vendor</strong>: Pick the vendor offering the best "
"deal for the requested materials."
msgstr ""
"<strong>Choisissez le meilleur fournisseur</strong> : sélectionnez la "
"meilleure offre pour votre demande."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Create a purchase order</strong>: Select the materials you need for "
"your cakes and pastries."
msgstr ""
"<strong>Créez un bon de commande</strong> : choisissez les ingrédients "
"nécessaires pour vos gâteaux et pâtisseries."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Custom orders</strong>: Let customers place custom cake orders for "
"special occasions via your online store by allowing them to specify details "
"like size, flavor, and decoration in a custom order form."
msgstr ""
"<strong>Commandes personnalisées</strong> : offrez la possibilité aux "
"clients de commander des gâteaux personnalisés pour des occasions spéciales. "
"Ils peuvent spécifier la taille, le goût et la décoration via un formulaire "
"dédié sur votre boutique en ligne."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.ir_ui_view_1538
msgid "<strong>Made with love</strong>"
msgstr "<strong>Fait avec amour</strong>"

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Marketing automation</strong>: Manage all communication channels "
"(email, social media, SMS) in one place."
msgstr ""
"<strong>Automatisation dmarketing</strong> : gérez tous vos canaux de "
"communication (e-mail, réseaux sociaux, SMS) depuis un seul endroit."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Online orders, In-shop pickup</strong>: Allow customers to order "
"online, pay in-store, and pick up at the shop."
msgstr ""
"<strong>Commandes en ligne, retrait en boutique</strong> : offrez la "
"possibilité aux clients de commander en ligne, de payer en magasin et de "
"retirer leur commande en boutique."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Take orders in Point of Sales</strong>: Process in-store cake and "
"pastry orders quickly using the Point of Sales system."
msgstr ""
"<strong>Prenez des commandes dans le Point de Vente</strong> : traitez "
"rapidement les commandes de gâteaux et pâtisseries en magasin grâce au "
"système de Point de Vente."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>You didn't import demo data?</strong> You can still do it. Go to "
"<strong>Apps &gt; Industries &gt; Upgrade your Cake Shop Package</strong> "
"and check the related box."
msgstr ""
"<strong>Vous n’avez pas importé les données de démonstration ?</strong> Vous "
"pouvez encore le faire. Allez dans <strong>Applications > Industries > "
"Mettre à niveau le pack Pâtisserie</strong> et cochez la case correspondante."

