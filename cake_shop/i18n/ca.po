#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid "<span style=\"font-size: 36px;\"><strong>Cake shop</strong></span>"
msgstr "<span style=\"font-size: 36px;\"><strong>Pastisseria</strong></span>"

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Accept flexible payments</strong>: Provide multiple payment options "
"(cash, card, mobile)."
msgstr ""
"<strong>Accepta pagaments flexibles</strong>: proporciona diverses opcions "
"de pagament (en efectiu, en targeta o amb el mòbil)."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Choose the best vendor</strong>: Pick the vendor offering the best "
"deal for the requested materials."
msgstr ""
"<strong>Tria al millor proveïdor</strong>: selecciona el proveïdor que "
"ofereix els millors preus."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Create a purchase order</strong>: Select the materials you need for "
"your cakes and pastries."
msgstr ""
"<strong>Crea una comanda de compra</strong>: selecciona els ingredients que "
"necessites per als pastissos i per als productes de rebosteria."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Custom orders</strong>: Let customers place custom cake orders for "
"special occasions via your online store by allowing them to specify details "
"like size, flavor, and decoration in a custom order form."
msgstr ""
"<strong>Comandes personalitzades</strong>: permet que els clients puguin "
"encarregar pastissos personalitzats per a ocasions especials a través de la "
"teva botiga en línia. Així, aquests poden especificar la mida, el sabor, la "
"decoració i qualsevol altre detall en un formulari de comandes "
"personalitzades."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.ir_ui_view_1538
msgid "<strong>Made with love</strong>"
msgstr "<strong>Elaborat amb amor</strong>"

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Marketing automation</strong>: Manage all communication channels "
"(email, social media, SMS) in one place."
msgstr ""
"<strong>Automatització del màrqueting</strong>: gestiona tots els canals de "
"comunicació (correu, xarxes socials, missatges SMS), tot des d'un mateix "
"lloc."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Online orders, In-shop pickup</strong>: Allow customers to order "
"online, pay in-store, and pick up at the shop."
msgstr ""
"<strong>Comandes en línia i recollida a la botiga</strong>: permet que els "
"teus clients puguin fer comandes en línia, però efectuar el pagament i la "
"recollida a la botiga."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Take orders in Point of Sales</strong>: Process in-store cake and "
"pastry orders quickly using the Point of Sales system."
msgstr ""
"<strong>Agafa comandes al TPV</strong>: processa les comandes ràpidament a "
"la teva botiga gràcies al sistema de TPV."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>You didn't import demo data?</strong> You can still do it. Go to "
"<strong>Apps &gt; Industries &gt; Upgrade your Cake Shop Package</strong> "
"and check the related box."
msgstr ""
"<strong>No has importat les dades demo?</strong> Encara pots fer-ho. "
"Dirigeix-te a <strong>Aplicacions &gt; Sectors &gt; Actualitza el teu paquet "
"per a pastisseries</strong> i selecciona la casella corresponent."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.ir_ui_view_1538
msgid "Baked with Love, Just for you"
msgstr "Fet amb amor, només per a tu"

