msgid ""
"\"<em>Cosy and friendly, good atmosphere and super food. Especially the "
"spiced fruit crumble.</em>\""
msgstr ""
"\"<em>Acollidor i agradable, ambient molt bo i menjar deliciós. El crumble "
"de fruita amb espècies està especialment bo.</em>\""

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.ir_ui_view_1538
msgid ""
"\"<em>I've been a regular customer for months now, and every cake I’ve had "
"has been amazing!</em>\"&amp;nbsp;"
msgstr ""
"\"<em>Soc un client regular que ha fet comandes els darrers mesos i cada "
"pastís que he encarregat ha estat magnífic!</em>\"&amp;nbsp;"

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.ir_ui_view_1538
msgid ""
"&amp;nbsp;Every cake tells a story, crafted with passion and the finest "
"ingredients.&amp;nbsp;"
msgstr ""
"&amp;nbsp;Cadascun dels nostres pastissos conta una història, elaborats amb "
"passió i amb els millors ingredients.&amp;nbsp;"

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.ir_ui_view_1538
