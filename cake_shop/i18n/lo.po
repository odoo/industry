#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid "<span style=\"font-size: 36px;\"><strong>Cake shop</strong></span>"
msgstr "<span style=\"font-size: 36px;\"><strong>ຮ້ານເຄັກ</strong></span>"

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Accept flexible payments</strong>: Provide multiple payment options "
"(cash, card, mobile)."
msgstr ""
"<strong>ຮັບການຊຳລະເງິນທີ່ຫຼາກຫຼາຍ</strong>: ໃຫ້ທາງເລືອກໃນການຊຳລະເງິນຫຼາຍຮູບແບບ (ເງິນສົດ, ບັ"
"ດ, ຜ່ານມືຖື)."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Choose the best vendor</strong>: Pick the vendor offering the best "
"deal for the requested materials."
msgstr ""
"<strong>ເລືອກຜູ້ສະໜອງທີ່ດີທີ່ສຸດ</strong>: ເລືອກຜູ້ສະໜອງທີ່ສະເໜີຂໍ້ຕົກລົງທີ່ດີທີ່ສຸດສຳລັບວັດຖຸດິບທີ່ຕ້ອງການ."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Create a purchase order</strong>: Select the materials you need for "
"your cakes and pastries."
msgstr ""
"<strong>ສ້າງໃບສັ່ງຊື້</strong>: ເລືອກວັດຖຸດິບທີ່ທ່ານຕ້ອງການສຳລັບເຄັກ ແລະ ເຂົ້າໜົມຂອງທ່ານ."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Custom orders</strong>: Let customers place custom cake orders for "
"special occasions via your online store by allowing them to specify details "
"like size, flavor, and decoration in a custom order form."
msgstr ""
"<strong>ຄຳສັ່ງຊື້ແບບພິເສດ</strong>: ໃຫ້ລູກຄ້າສັ່ງເຄັກຕາມຄວາມຕ້ອງການສຳລັບໂອກາດພິເສດຜ່ານຮ້ານຄ້າອ"
"ອນລາຍຂອງທ່ານ ໂດຍໃຫ້ພວກເຂົາລະບຸລາຍລະອຽດເຊັ່ນ: ຂະໜາດ, ລົດຊາດ, ແລະ ການຕົກແຕ່ງ ໃນແບບຟອມສັ່ງ"
"ຊື້."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.ir_ui_view_1538
msgid "<strong>Made with love</strong>"
msgstr "<strong>ເຮັດດ້ວຍຄວາມຮັກ</strong>"

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Marketing automation</strong>: Manage all communication channels "
"(email, social media, SMS) in one place."
msgstr ""
"<strong>ການຕະຫຼາດອັດຕະໂນມັດ</strong>: ຈັດການທຸກຊ່ອງທາງການສື່ສານ (ອີເມວ, ໂຊຊ່ຽວມີເດຍ, "
"SMS) ໃນບ່ອນດຽວ."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Online orders, In-shop pickup</strong>: Allow customers to order "
"online, pay in-store, and pick up at the shop."
msgstr ""
"<strong>ສັ່ງອອນລາຍ, ຮັບຢູ່ຮ້ານ</strong>: ອະນຸຍາດໃຫ້ລູກຄ້າສັ່ງອອນລາຍ, ຊຳລະເງິນຢູ່ຮ້ານ, ແລະ ມາຮັ"
"ບຢູ່ຮ້ານ."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Take orders in Point of Sales</strong>: Process in-store cake and "
"pastry orders quickly using the Point of Sales system."
msgstr ""
"<strong>ຮັບຄຳສັ່ງຊື້ຢູ່ໜ້າຮ້ານ</strong>: ຈັດການຄຳສັ່ງຊື້ເຄັກ ແລະ ເຂົ້າໜົມຢູ່ໜ້າຮ້ານຢ່າງວ່ອງໄວໂດຍໃຊ້ລະບົ"
"ບ Point of Sales."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>You didn't import demo data?</strong> You can still do it. Go to "
"<strong>Apps &gt; Industries &gt; Upgrade your Cake Shop Package</strong> "
"and check the related box."
msgstr ""
"<strong>ທ່ານບໍ່ໄດ້ນຳເຂົ້າຂໍ້ມູນຕົວຢ່າງແມ່ນບໍ່?</strong> ທ່ານຍັງສາມາດເຮັດໄດ້. ໄປທີ່ <strong>ແອັບ "
"&gt; ອຸດສາຫະກຳ &gt; ອັບເກຣດແພັກເກດຮ້ານເຄັກຂອງທ່ານ</strong> ແລະ ໝາຍເອົາຫ້ອງທີ່ກ່ຽວຂ້ອງ."

