msgstr "<font class=\"text-o-color-3\">ເມນູພິເສດມື້ນີ້</font>"

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.ir_ui_view_1538
msgid ""
"<font class=\"text-o-color-4\">Enjoy our chef’s almond macaroon shells "
"filled with creamy orange blossom flavor.</font>"
msgstr ""
"<font class=\"text-o-color-4\">ເພີດເພີນໄປກັບມາຄາຣູນອັນມອນ ສູດພິເສດຈາກເຊຟ ທີ່ເຕັມໄປດ້ວຍລົດ"
"ຊາດຄຣີມດອກສົ້ມ.</font>"

