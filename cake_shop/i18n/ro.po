#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid "<span style=\"font-size: 36px;\"><strong>Cake shop</strong></span>"
msgstr "<span style=\"font-size: 36px;\"><strong>Cofetărie</strong></span>"

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Accept flexible payments</strong>: Provide multiple payment options "
"(cash, card, mobile)."
msgstr ""
"<strong>Acceptă plăți flexibile</strong>: Oferă mai multe opțiuni de plată "
"(numerar, card, mobil)."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Choose the best vendor</strong>: Pick the vendor offering the best "
"deal for the requested materials."
msgstr ""
"<strong>Alege cel mai bun furnizor</strong>: Selectează furnizorul care "
"oferă cea mai bună ofertă pentru materialele solicitate."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Create a purchase order</strong>: Select the materials you need for "
"your cakes and pastries."
msgstr ""
"<strong>Creează o comandă de achiziție</strong>: Selectează materialele de "
"care ai nevoie pentru prăjiturile și produsele tale de patiserie."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Custom orders</strong>: Let customers place custom cake orders for "
"special occasions via your online store by allowing them to specify details "
"like size, flavor, and decoration in a custom order form."
msgstr ""
"<strong>Comenzi personalizate</strong>: Permite clienților să plaseze "
"comenzi personalizate pentru prăjituri de ocazie prin magazinul tău online, "
"oferindu-le posibilitatea să specifice detalii precum dimensiunea, aroma și "
"decorul într-un formular de comandă personalizat."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.ir_ui_view_1538
msgid "<strong>Made with love</strong>"
msgstr "<strong>Făcut cu dragoste</strong>"

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Marketing automation</strong>: Manage all communication channels "
"(email, social media, SMS) in one place."
msgstr ""
"<strong>Automatizare marketing</strong>: Gestionează toate canalele de "
"comunicare (email, social media, SMS) într-un singur loc."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Online orders, In-shop pickup</strong>: Allow customers to order "
"online, pay in-store, and pick up at the shop."
msgstr ""
"<strong>Comenzi online, ridicare din magazin</strong>: Permite clienților să "
"comande online, să plătească în magazin și să ridice produsele de la sediu."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Take orders in Point of Sales</strong>: Process in-store cake and "
"pastry orders quickly using the Point of Sales system."
msgstr ""
"<strong>Preia comenzi în sistemul POS</strong>: Procesează rapid comenzile "
"de prăjituri și produse de patiserie din magazin folosind sistemul Point of "
"Sales."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>You didn't import demo data?</strong> You can still do it. Go to "
"<strong>Apps &gt; Industries &gt; Upgrade your Cake Shop Package</strong> "
"and check the related box."
msgstr ""
"<strong>Nu ai importat datele demo?</strong> Poți face acest lucru oricând. "
"Mergi la <strong>Aplicații &gt; Industrii &gt; Upgradează pachetul "
"Cofetărie</strong> și bifează căsuța corespunzătoare."

