msgid ""
"\"<em>Cosy and friendly, good atmosphere and super food. Especially the "
"spiced fruit crumble.</em>\""
msgstr ""
"\"<em>Atmosferă primitoare și prietenoasă, mâncare excelentă. Mai ales "
"crumble-ul cu fructe condimentate.</em>\""

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.ir_ui_view_1538
