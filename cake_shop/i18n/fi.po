#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid "<span style=\"font-size: 36px;\"><strong>Cake shop</strong></span>"
msgstr "<span style=\"font-size: 36px;\"><strong>Kakkukauppa</strong></span>"

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Accept flexible payments</strong>: Provide multiple payment options "
"(cash, card, mobile)."
msgstr ""
"<strong>Hyväksy joustavat maksut</strong>: Tarjoa useita maksuvaihtoehtoja "
"(käteinen, kortti, matkapuhelin)."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Choose the best vendor</strong>: Pick the vendor offering the best "
"deal for the requested materials."
msgstr ""
"<strong>Valitse paras toimittaja</strong>: Valitse toimittaja, joka tarjoaa "
"parhaan tarjouksen pyydetyistä materiaaleista."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Create a purchase order</strong>: Select the materials you need for "
"your cakes and pastries."
msgstr ""
"<strong>Luo ostotilaus</strong>: Valitse kakkujen ja leivonnaisten "
"valmistukseen tarvitsemasi materiaalit."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Custom orders</strong>: Let customers place custom cake orders for "
"special occasions via your online store by allowing them to specify details "
"like size, flavor, and decoration in a custom order form."
msgstr ""
"<strong>Asiakaskohtaiset tilaukset</strong>: Anna asiakkaiden tehdä "
"tilauksia erikoistilaisuuksia varten verkkokaupassasi antamalla heidän "
"määrittää koon, maun ja koristelun kaltaiset yksityiskohdat mukautetussa "
"tilauslomakkeessa."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.ir_ui_view_1538
msgid "<strong>Made with love</strong>"
msgstr "<strong>Rakkaudella tehty</strong>"

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Marketing automation</strong>: Manage all communication channels "
"(email, social media, SMS) in one place."
msgstr ""
"<strong>Markkinointiautomaatio</strong>: Hallitse kaikkia viestintäkanavia "
"(sähköposti, sosiaalinen media, tekstiviestit) yhdessä paikassa."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Online orders, In-shop pickup</strong>: Allow customers to order "
"online, pay in-store, and pick up at the shop."
msgstr ""
"<strong>Online-tilaukset, nouto myymälästä</strong>: Anna asiakkaiden tilata"
" verkossa, maksaa myymälässä ja noutaa tuotteet myymälästä."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Take orders in Point of Sales</strong>: Process in-store cake and "
"pastry orders quickly using the Point of Sales system."
msgstr ""
"<strong>Ota tilauksia vastaan kassalla</strong>: Käsittele myymälän kakku- "
"ja leivonnaistilaukset nopeasti kassalla."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>You didn't import demo data?</strong> You can still do it. Go to "
"<strong>Apps &gt; Industries &gt; Upgrade your Cake Shop Package</strong> "
"and check the related box."
msgstr ""
"<strong>Etkö tuonut demotietoja?</strong> Voit silti tehdä sen. Mene kohtaan"
" <strong>Sovellukset &gt; Toimialat &gt; Päivitä Cake Shop "
"-pakettisi</strong> ja merkitse siihen liittyvä ruutu."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.ir_ui_view_1538
msgid "Baked with Love, Just for you"
msgstr "Rakkaudella leivottu, juuri sinua varten"

