#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.ir_ui_view_1538
msgid ""
"\"<em>Cosy and friendly, good atmosphere and super food. Especially the "
"spiced fruit crumble.</em>\""
msgstr ""
"<em>\"Viihtyisä ja ystävällinen, hyvä ilmapiiri ja hyvää ruokaa. Erityisesti"
" maustettu hedelmäinen crumble</em>.\""

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.ir_ui_view_1538
msgid ""
"\"<em>I've been a regular customer for months now, and every cake I’ve had "
"has been amazing!</em>\"&amp;nbsp;"
msgstr ""
"<em>\"Olen ollut vakioasiakas jo kuukausia, ja jokainen kakku, jonka olen "
"syönyt, on ollut uskomaton!</em>\"&amp;nbsp;"

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.ir_ui_view_1538
msgid ""
"&amp;nbsp;Every cake tells a story, crafted with passion and the finest "
"ingredients.&amp;nbsp;"
msgstr ""
"&amp;nbsp;Jokainen kakku kertoo tarinan, joka on valmistettu intohimolla ja "
"hienoimmista raaka-aineista.&amp;nbsp;"

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.ir_ui_view_1538
msgid ""
"<em>\"Write a quote here from one of your customers. Quotes are a great way "
"to build confidence in your products or services.</em>\""
msgstr ""
"<em>\"Kirjoita tähän palaute asiakkaaltasi. Julkiset palautteet ja "
"arvostelut ovat loistavia tapoja rakentaa luottamusta tuotteisiisi tai "
"palveluihisi</em>.\""

