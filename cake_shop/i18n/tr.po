#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid "<span style=\"font-size: 36px;\"><strong>Cake shop</strong></span>"
msgstr "<span style=\"font-size: 36px;\"><strong>Pasta dükkanı</strong></span>"

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Accept flexible payments</strong>: Provide multiple payment options "
"(cash, card, mobile)."
msgstr ""
"<strong>Esnek ödemeleri kabul edin</strong>: Nakit, kart veya mobil gibi "
"birden fazla ödeme seçeneği sunun."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Choose the best vendor</strong>: Pick the vendor offering the best "
"deal for the requested materials."
msgstr ""
"<strong>En iyi tedarikçiyi seçin</strong>: İstenen malzemeler için en iyi "
"teklifi sunan tedarikçiyi tercih edin."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Create a purchase order</strong>: Select the materials you need for "
"your cakes and pastries."
msgstr ""
"<strong>Bir satın alma siparişi oluşturun</strong>: Kek ve pastalarınız için "
"ihtiyacınız olan malzemeleri seçin."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Custom orders</strong>: Let customers place custom cake orders for "
"special occasions via your online store by allowing them to specify details "
"like size, flavor, and decoration in a custom order form."
msgstr ""
"<strong>Özel siparişler</strong>: Müşterilerin özel sipariş formunda boyut, "
"lezzet ve dekorasyon gibi ayrıntıları belirtmelerine izin vererek çevrimiçi "
"mağazanız aracılığıyla özel günler için özel pasta siparişleri vermelerini "
"sağlayın."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.ir_ui_view_1538
msgid "<strong>Made with love</strong>"
msgstr "<strong>Sevgi ile yapılmıştır</strong>"

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Marketing automation</strong>: Manage all communication channels "
"(email, social media, SMS) in one place."
msgstr ""
"<strong>Pazarlama otomasyonu</strong>: Tüm iletişim kanallarını (e-posta, "
"sosyal medya, SMS) tek bir yerden yönetin."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Online orders, In-shop pickup</strong>: Allow customers to order "
"online, pay in-store, and pick up at the shop."
msgstr ""
"<strong>Online siparişler, Mağazadan teslim alma</strong>: Müşterilerin "
"çevrimiçi sipariş vermesine, mağazada ödeme yapmasına ve mağazadan teslim "
"almasına izin verin."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Take orders in Point of Sales</strong>: Process in-store cake and "
"pastry orders quickly using the Point of Sales system."
msgstr ""
"<strong>Satış Noktasında sipariş alın</strong>: Satış Noktası sistemini "
"kullanarak mağaza içi kek ve pasta siparişlerini hızlı bir şekilde işleyin."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>You didn't import demo data?</strong> You can still do it. Go to "
"<strong>Apps &gt; Industries &gt; Upgrade your Cake Shop Package</strong> "
"and check the related box."
msgstr ""
"<strong>Demo verilerini içe aktarmadınız mı?</strong> Yine de "
"yapabilirsiniz. <strong> Uygulamalar &gt; Endüstriler &gt; Pastane "
"Paketinizi Yükseltin</strong> adresine gidin ve ilgili kutuyu işaretleyin."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.ir_ui_view_1538
msgid "Baked with Love, Just for you"
msgstr "Sevgiyle Pişirildi, Sadece Sizin İçin"

