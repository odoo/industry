msgid ""
"\"<em>Cosy and friendly, good atmosphere and super food. Especially the "
"spiced fruit crumble.</em>\""
msgstr ""
"\"<em>Rahat ve samimi, iyi bir atmosfer ve süper yemekler. Özellikle "
"baharatlı meyveli crumble.</em>\""

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.ir_ui_view_1538
msgid ""
"\"<em>I've been a regular customer for months now, and every cake I’ve had "
"has been amazing!</em>\"&amp;nbsp;"
msgstr ""
"\"<em>Aylardır düzenli bir müşteriyim ve yediğim her pasta harikaydı!</"
"em>\"&amp;nbsp;"

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.ir_ui_view_1538
msgid ""
"&amp;nbsp;Every cake tells a story, crafted with passion and the finest "
"ingredients.&amp;nbsp;"
msgstr ""
"&amp;nbsp;Her pasta, tutku ve en iyi malzemelerle hazırlanmış bir hikaye "
"anlatır.&amp;nbsp;"

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.ir_ui_view_1538
