#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.ir_ui_view_1538
msgid ""
"\"<em>Cosy and friendly, good atmosphere and super food. Especially the "
"spiced fruit crumble.</em>\""
msgstr ""
"\"<em>Przytulnie i miło, przyjazna atmosfera i wspaniałe jedzenie. Zwłaszcza "
"korzenny owocowy crumble.</em>\""

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.ir_ui_view_1538
msgid ""
"\"<em>I've been a regular customer for months now, and every cake I’ve had "
"has been amazing!</em>\"&amp;nbsp;"
msgstr ""
"\"<em>Jestem stałym klientem już od miesięcy i każde ciasto, które jadłem "
"było przepyszne!</em>\"&amp;nbsp;"

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.ir_ui_view_1538
msgid ""
"&amp;nbsp;Every cake tells a story, crafted with passion and the finest "
"ingredients.&amp;nbsp;"
msgstr ""
"&amp;nbsp;Każde ciasto opowiada historię, jest przygotowane z pasją i z "
"najlepszych składników.&amp;nbsp;"

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.ir_ui_view_1538
msgid ""
"<em>\"Write a quote here from one of your customers. Quotes are a great way "
"to build confidence in your products or services.</em>\""
msgstr ""
"<em>\"Wpisz tutaj cytat jednego z twoich klientów. Cytaty to świetny sposób "
"na budowanie zaufania do twoich produktów lub usług..</em>\""

