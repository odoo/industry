#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid "<span style=\"font-size: 36px;\"><strong>Cake shop</strong></span>"
msgstr "<span style=\"font-size: 36px;\"><strong>Cukiernia</strong></span>"

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Accept flexible payments</strong>: Provide multiple payment options "
"(cash, card, mobile)."
msgstr ""
"<strong>Akceptuj elastyczne płatności</strong>: zapewnij wiele możliwości "
"płatności (gotówka, karta, płatności mobilne)."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Choose the best vendor</strong>: Pick the vendor offering the best "
"deal for the requested materials."
msgstr ""
"<strong>Wybierz najlepszego dostawcę</strong>: Wybierz dostawcę, który ma "
"najlepszą ofertę potrzebnych materiałów."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Create a purchase order</strong>: Select the materials you need for "
"your cakes and pastries."
msgstr ""
"<strong>Stwórz zamówienie zakupu</strong>: Wybierz materiały, których "
"potrzebujesz do swoich ciast i wypieków."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Custom orders</strong>: Let customers place custom cake orders for "
"special occasions via your online store by allowing them to specify details "
"like size, flavor, and decoration in a custom order form."
msgstr ""
"<strong> Niestandardowe zamówienia</strong>: Pozwalaj klientom składać "
"niestandardowe zamówienia na specjalne okazje w Twoim sklepie internetowym, "
"pozwalając im na określenie szczegółów, takich jak wielkość, smak i rodzaj "
"dekoracji."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.ir_ui_view_1538
msgid "<strong>Made with love</strong>"
msgstr "<strong>Zrobione z miłością</strong>"

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Marketing automation</strong>: Manage all communication channels "
"(email, social media, SMS) in one place."
msgstr ""
"<strong>Automatyzacja marketingu</strong>: Zarządzaj wszystkimi kanałami "
"komunikacji (email, media społecznościowe, SMS) z jednego miejsca."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Online orders, In-shop pickup</strong>: Allow customers to order "
"online, pay in-store, and pick up at the shop."
msgstr ""
"<strong>Zamówienia online, odbiór w sklepie</strong>: Pozwalaj klientom "
"zamawiać online, płacić w sklepie i odbierać na miejscu."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Take orders in Point of Sales</strong>: Process in-store cake and "
"pastry orders quickly using the Point of Sales system."
msgstr ""
"<strong>Zbieraj zamówienia w Punkcie Sprzedaży</strong>: Przetwarzaj "
"zamówienia na ciasta i wypieki z użyciem systemu Punktu Sprzedaży."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>You didn't import demo data?</strong> You can still do it. Go to "
"<strong>Apps &gt; Industries &gt; Upgrade your Cake Shop Package</strong> "
"and check the related box."
msgstr ""
"<strong>Nie zaimportowałeś danych demo?</strong> Wciąż możesz to zrobić. "
"Przejdź do <strong>Aplikacji &gt; Branże &gt; Zaktualizuj swój pakiet "
"Cukierni</strong> i odznacz odpowiednie pole."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.ir_ui_view_1538
msgid "Baked with Love, Just for you"
msgstr "Wypieczone z miłością, tylko dla Ciebie"

