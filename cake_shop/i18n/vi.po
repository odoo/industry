#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.ir_ui_view_1538
msgid ""
"\"<em>Cosy and friendly, good atmosphere and super food. Especially the "
"spiced fruit crumble.</em>\""
msgstr ""
"\"<em>Ấm cúng và thân thiện, không khí tuyệt vời và đồ ăn ngon miệng. Đặc "
"biệt là món bánh crumble trái cây vị cay.</em>\""

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.ir_ui_view_1538
msgid ""
"\"<em>I've been a regular customer for months now, and every cake I’ve had "
"has been amazing!</em>\"&amp;nbsp;"
msgstr ""
"\"<em>Tôi đã là khách hàng thân thiết trong nhiều tháng nay, và mỗi chiếc "
"bánh tôi thử đều tuyệt vời!</em>\"&amp;nbsp;"

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.ir_ui_view_1538
msgid ""
"&amp;nbsp;Every cake tells a story, crafted with passion and the finest "
"ingredients.&amp;nbsp;"
msgstr ""
"&amp;nbsp;Mỗi chiếc bánh kể một câu chuyện, được tạo nên với đam mê và những "
"nguyên liệu hảo hạng nhất.&amp;nbsp;"

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.ir_ui_view_1538
msgid ""
"<em>\"Write a quote here from one of your customers. Quotes are a great way "
"to build confidence in your products or services.</em>\""
msgstr ""
"<em>\"Viết một lời đánh giá từ khách hàng của bạn tại đây. Đánh giá là một "
"cách tuyệt vời để xây dựng niềm tin vào sản phẩm hoặc dịch vụ của bạn.</em>\""

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.ir_ui_view_1538
msgid "<font class=\"text-o-color-3\">Today's special</font>"
msgstr "<font class=\"text-o-color-3\">Món đặc biệt hôm nay</font>"

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.ir_ui_view_1538
msgid ""
"<font class=\"text-o-color-4\">Enjoy our chef’s almond macaroon shells "
"filled with creamy orange blossom flavor.</font>"
msgstr ""
"<font class=\"text-o-color-4\">Thưởng thức vỏ bánh macaron hạnh nhân của bếp "
"trưởng, nhân kem hương hoa cam thơm ngon.</font>"

