#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid "<span style=\"font-size: 36px;\"><strong>Cake shop</strong></span>"
msgstr "<span style=\"font-size: 36px;\"><strong>Cửa hành bánh</strong></span>"

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Accept flexible payments</strong>: Provide multiple payment options "
"(cash, card, mobile)."
msgstr ""
"<strong>Chấp nhận thanh toán linh hoạt</strong>: Cung cấp nhiều phương thức "
"thanh toán (tiền mặt, thẻ, di động)."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Choose the best vendor</strong>: Pick the vendor offering the best "
"deal for the requested materials."
msgstr ""
"<strong>Chọn nhà cung cấp tốt nhất</strong>: Lựa chọn nhà cung cấp đưa ra ưu "
"đãi tốt nhất cho nguyên liệu cần thiết."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Create a purchase order</strong>: Select the materials you need for "
"your cakes and pastries."
msgstr ""
"<strong>Tạo đơn mua hàng:</strong> Chọn nguyên liệu bạn cần cho bánh và bánh "
"ngọt của mình."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Custom orders</strong>: Let customers place custom cake orders for "
"special occasions via your online store by allowing them to specify details "
"like size, flavor, and decoration in a custom order form."
msgstr ""
"<strong>Đặt hàng theo yêu cầu</strong>: Cho phép khách hàng đặt bánh theo "
"yêu cầu cho những dịp đặc biệt thông qua cửa hàng online của bạn, bằng cách "
"để họ chọn các chi tiết như kích thước, hương vị và đồ trang trí trong biểu "
"mẫu đặt hàng tuỳ chỉnh."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.ir_ui_view_1538
msgid "<strong>Made with love</strong>"
msgstr "<strong>Tạo ra từ trái tim</strong>"

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Marketing automation</strong>: Manage all communication channels "
"(email, social media, SMS) in one place."
msgstr ""
"<strong>Tự động hóa marketing</strong>: Quản lý tất cả kênh liên lạc (email, "
"mạng xã hội, SMS) trên một nền tảng duy nhất."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Online orders, In-shop pickup</strong>: Allow customers to order "
"online, pay in-store, and pick up at the shop."
msgstr ""
"<strong>Đặt hàng online, nhận tại cửa hàng</strong>: Cho phép khách hàng đặt "
"hàng online, thanh toán tại cửa hàng và đến nhận trực tiếp."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>Take orders in Point of Sales</strong>: Process in-store cake and "
"pastry orders quickly using the Point of Sales system."
msgstr ""
"<strong>Nhận đơn hàng tại POS</strong>: Xử lý nhanh chóng các đơn đặt bánh "
"và bánh ngọt tại cửa hàng bằng hệ thống POS."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.welcome_article_body
msgid ""
"<strong>You didn't import demo data?</strong> You can still do it. Go to "
"<strong>Apps &gt; Industries &gt; Upgrade your Cake Shop Package</strong> "
"and check the related box."
msgstr ""
"<strong>Bạn chưa nhập dữ liệu demo?</strong> Đừng lo! Bạn vẫn có thể làm "
"được bằng cách đi đến <strong>Ứng dụng &gt; Ngành &gt; Nâng cấp gói Tiệm "
"bánh của bạn</strong> và đánh dấu vào ô liên quan."

#. module: cake_shop
#: model_terms:ir.ui.view,arch_db:cake_shop.ir_ui_view_1538
msgid "Baked with Love, Just for you"
msgstr "Nướng bằng cả yêu thương, dành riêng cho bạn."

