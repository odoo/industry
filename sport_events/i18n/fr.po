#. module: sport_events
#: model_terms:ir.ui.view,arch_db:sport_events.welcome_article_body
msgid ""
"<strong>Categorize expenses</strong> (Logistics, Accommodation, Meals, "
"Travel) for clear reporting."
msgstr ""
"<strong>Catégorisez les notes de frais</strong> (logistique, hébergement, "
"repas, déplacements) pour un reporting clair."

#. module: sport_events
#: model_terms:ir.ui.view,arch_db:sport_events.welcome_article_body
msgid ""
"<strong>Categorize products</strong> into groups like Apparel, First Aid, "
"Technical Equipment, and Merchandise."
msgstr ""
"<strong>Catégorisez les produits</strong> dans des groupes tels que "
"vêtements, premiers secours, équipement technique et produits dérivés."

#. module: sport_events
#: model_terms:ir.ui.view,arch_db:sport_events.welcome_article_body
msgid "<strong>Communicate Efficiently</strong>"
msgstr "<strong>Communiquez efficacement</strong>"

#. module: sport_events
#: model_terms:ir.ui.view,arch_db:sport_events.welcome_article_body
msgid ""
"<strong>Create a purchase order</strong> in <em>Purchase</em> when you need "
"ravitaillement supplies, race bibs, signage, timing systems, volunteer "
"uniforms, or safety equipment."
msgstr ""
"<strong>Créez un bon de commande</strong> dans <em>Achats</em> lorsque vous "
"avez besoin de fournitures de ravitaillement, de dossards, de signalétique, "
"de systèmes de chronométrage, d'uniformes pour les bénévoles ou d'équipement "
"de sécurité."

#. module: sport_events
#: model_terms:ir.ui.view,arch_db:sport_events.welcome_article_body
msgid ""
"<strong>Create engaging announcements </strong>and highlight reels to "
"promote upcoming events."
msgstr ""
"<strong>Créez des annonces attrayantes </strong>et des vidéos best of pour "
"promouvoir les événements à venir."

#. module: sport_events
#: model_terms:ir.ui.view,arch_db:sport_events.welcome_article_body
