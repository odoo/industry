#. module: sport_events
#: model_terms:ir.ui.view,arch_db:sport_events.welcome_article_body
msgid ""
"<strong><font class=\"text-o-color-1\">CRM</font></strong>: Manage "
"relationships with sponsors, partners, and key contacts."
msgstr ""
"<strong><font class=\"text-o-color-1\">CRM</font></strong>: Håndtér "
"relationer med sponsorer, partnere og nøglekontakter."

#. module: sport_events
#: model_terms:ir.ui.view,arch_db:sport_events.welcome_article_body
msgid ""
"<strong><font class=\"text-o-color-1\">Documents</font></strong>: Centralize "
"spreadsheets and materials checklists."
msgstr ""
"<strong><font class=\"text-o-color-1\">Dokumenter</font></strong>: Saml "
"regneark og materialelister ét sted."

#. module: sport_events
#: model_terms:ir.ui.view,arch_db:sport_events.welcome_article_body
msgid ""
"<strong><font class=\"text-o-color-1\">Events</font></strong>: Plan and "
"manage sport competitions, races, or tournaments."
msgstr ""
"<strong><font class=\"text-o-color-1\">Arrangementer</font></strong>: "
"Planlæg og administrér sportskonkurrencer, løb eller turneringer."

#. module: sport_events
#: model_terms:ir.ui.view,arch_db:sport_events.welcome_article_body
msgid ""
"<strong><font class=\"text-o-color-1\">Inventory</font></strong>: Track "
"sports gear, event equipment, merchandise, and manage stock of all materials."
msgstr ""
"<strong><font class=\"text-o-color-1\">Lager</font></strong>: Spor "
"sportsudstyr, eventudstyr og merchandise, og administrér lagerbeholdningen "
"af alle materialer."

#. module: sport_events
#: model_terms:ir.ui.view,arch_db:sport_events.welcome_article_body
msgid ""
"<strong><font class=\"text-o-color-1\">Planning</font></strong>: Create "
"staff schedules, assign roles, and manage shifts."
msgstr ""
"<strong><font class=\"text-o-color-1\">Planlægning</font></strong>: Opret "
"personaleplaner, tildel roller, og administrér vagter."

#. module: sport_events
#: model_terms:ir.ui.view,arch_db:sport_events.welcome_article_body
msgid ""
"<strong><font class=\"text-o-color-1\">Project</font></strong>: Organize "
"event planning, deadlines, and task responsibilities."
msgstr ""
"<strong><font class=\"text-o-color-1\">Projekt</font></strong>: Organisér "
"planlægning af arrangementer, deadlines og ansvarsfordeling for opgaver."

#. module: sport_events
#: model_terms:ir.ui.view,arch_db:sport_events.welcome_article_body
msgid ""
"<strong><font class=\"text-o-color-1\">Purchase</font>: </strong>Order "
"ravitaillement supplies, gear, equipment, and other essentials for sport "
"events.<strong/><br/>"
msgstr ""
"<strong><font class=\"text-o-color-1\">Indkøb</font>: </strong>Bestil "
"forsyninger, udstyr og andre nødvendigheder til sportsbegivenheder.<strong/>"
"<br/>"

#. module: sport_events
#: model_terms:ir.ui.view,arch_db:sport_events.welcome_article_body
msgid ""
"<strong><font class=\"text-o-color-1\">Sign</font></strong>: Digitally sign "
"sponsorship agreements or volunteer forms."
msgstr ""
"<strong><font class=\"text-o-color-1\">e-Signatur</font></strong>: "
"Underskriv sponsorataftaler eller frivilligformularer digitalt."

#. module: sport_events
#: model_terms:ir.ui.view,arch_db:sport_events.welcome_article_body
msgid ""
"<strong><font class=\"text-o-color-1\">Survey</font></strong>: Gather "
"feedback from participants, staff, and sponsors."
msgstr ""
"<strong><font class=\"text-o-color-1\">Spørgeundersøgelser</font></strong>: "
"Indsaml feedback fra deltagere, personale og sponsorer."

#. module: sport_events
#: model_terms:ir.ui.view,arch_db:sport_events.welcome_article_body
msgid ""
"<strong><font class=\"text-o-color-1\">Website</font></strong>: Promote "
"events, sell tickets, and gather sponsorships online."
msgstr ""
"<strong><font class=\"text-o-color-1\">Hjemmeside</font></strong>: Promovér "
"arrangementer, sælg billetter, og skaf sponsorer online."

#. module: sport_events
#: model_terms:event.event,description:sport_events.event_event_2
msgid "<strong>A Day of Competition, Energy &amp; Team Spirit</strong>"
msgstr "<strong>En dag med konkurrence, energi og holdånd</strong>"

#. module: sport_events
#: model_terms:ir.ui.view,arch_db:sport_events.welcome_article_body
msgid ""
"<strong>Add contact forms </strong>for participants to send questions, "
"feedback, or requests."
msgstr ""
"<strong>Tilføj kontaktformularer </strong>, så deltagerne kan sende "
"spørgsmål, feedback eller anmodninger."

#. module: sport_events
#: model_terms:ir.ui.view,arch_db:sport_events.welcome_article_body
msgid ""
"<strong>Add your event details</strong> in the <em>Events</em> app, "
"including dates, locations, ticket types, and capacity."
msgstr ""
"<strong>Tilføj dine begivenhedsoplysninger</strong> i appen <em>"
"Arrangementer</em>, herunder datoer, steder, billettyper og kapacitet."

#. module: sport_events
#: model_terms:event.event,description:sport_events.event_event_3
