<?xml version='1.0' encoding='UTF-8'?>
<odoo noupdate="1">
  <!--Update sale order stages-->
  <function model="sale.order" name="action_confirm" eval="[[ref('sale_order_2'),ref('sale_order_5'),ref('sale_order_4')]]"/>

  <function name="button_validate" model="stock.picking" context="{'skip_sms': True}">
      <value model="stock.picking" eval="[ref('stock_picking_1')]"/>
  </function>

  <!-- Confirming MO'S -->
  <function name="action_confirm" model="mrp.production">
      <value eval="[ref('mrp_production_1'), ref('mrp_production_6'), ref('mrp_production_7'), ref('mrp_production_9')]" />
  </function>

  <function name="button_plan" model="mrp.production">
    <value eval="[ref('mrp_production_6'), ref('mrp_production_7'), ref('mrp_production_9')]"/>
  </function>

  <function name="action_start" model="mrp.production">
    <value eval="[ref('mrp_production_7')]"/>
  </function>

  <function name="button_mark_done" model="mrp.production">
      <value eval="[ref('mrp_production_1'), ref('mrp_production_8')]"/>
  </function>

  <function name="write" model="mrp.workorder">
      <function model="mrp.workorder" name="search" eval="[[('production_id', '=', ref('mrp_production_7'))]]"/>
      <value eval="{'state': 'progress', 'duration': 0.25}"/>
  </function>

  <function name="write" model="mrp.production">
    <function model="mrp.production" name="search" eval="[[('id', '=', ref('mrp_production_6'))]]"/>
    <value model="knowledge.article" eval="{'note': ('&lt;div&gt;' + '&lt;a href=&quot;/odoo/knowledge/' + str(obj().env.ref('textile_manufacturing.knowledge_article_44').id) + '&quot;&gt;S00001&lt;/a&gt;' + '&lt;/div&gt;')}"/>
  </function>

  <function name="write" model="mrp.production">
    <function model="mrp.production" name="search" eval="[[('id', '=', ref('mrp_production_7'))]]"/>
    <value model="knowledge.article" eval="{'note': ('&lt;div&gt;' + '&lt;a href=&quot;/odoo/knowledge/' + str(obj().env.ref('textile_manufacturing.knowledge_article_38').id) + '&quot;&gt;SO/00005 - MO/00005&lt;/a&gt;' + '&lt;/div&gt;')}"/>
  </function>
</odoo>
