#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid "<b><u>Using Multiple BOMs</u></b>"
msgstr "<b><u>ການນຳໃຊ້ BOM ຫຼາຍລາຍການ</u></b>"

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<b>A key tip:</b> Don't create a new product for each order. Instead, use a "
"generic product and differentiate it using the <b>lot number</b>. You can "
"then link the correct production order to the right delivery."
msgstr ""
"<b>ເຄັດລັບທີ່ສຳຄັນ:</b> ບໍ່ຄວນສ້າງສິນຄ້າໃໝ່ສຳລັບທຸກໆຄຳສັ່ງຊື້. ແຕ່ໃຫ້ໃຊ້ສິນຄ້າທົ່ວໄປ ແລະ ແຍກຄວາມແຕກຕ່າ"
"ງໂດຍໃຊ້ <b>ເລກລັອດ (lot number)</b>. ຈາກນັ້ນທ່ານສາມາດເຊື່ອມໂຍງໃບສັ່ງຜະລິດທີ່ຖືກຕ້ອງເຂົ້າກັບການ"
"ຈັດສົ່ງທີ່ເໝາະສົມ."

#. module: textile_manufacturing
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_12
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_13
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_14
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_15
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_3
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_4
msgid ""
"<b>Athletic Fit:</b> Designed to fit close to the body, often with raglan "
"sleeves, to allow for movement"
msgstr ""
"<b>ຊົງກິລາ (Athletic Fit):</b> ອອກແບບມາໃຫ້ເຂົ້າຮູບພໍດີກັບຮ່າງກາຍ, ມັກຈະມີແຂນແບບ raglan ເພື່"
"ອໃຫ້ເຄື່ອນໄຫວໄດ້ສະດວກ"

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<b>Automatically</b> if the available stock falls below the minimum level "
"set in the <b>Reordering Rule</b>."
msgstr ""
"<b>ໂດຍອັດຕະໂນມັດ</b> ຫາກເຄື່ອງໃນສາງທີ່ມີຢູ່ຫຼຸດລົງຕໍ່າກວ່າລະດັບຕ່ຳສຸດທີ່ຕັ້ງໄວ້ໃນ <b>ກົດເກນການສັ່ງຊື້ຄືນ</"
"b>."

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<b>BOM 1: Full Fabrication</b> This BOM would include all raw materials, "
"like the fabric and thread, to make the T-shirt from scratch."
msgstr ""
"<b>BOM 1: ການຜະລິດແບບເຕັມຮູບແບບ</b> BOM ນີ້ຈະລວມເອົາວັດຖຸດິບທັງໝົດ ເຊັ່ນ: ຜ້າ ແລະ ເສັ້ນດ້າຍ ເພື່"
"ອຜະລິດເສື້ອຢືດຕັ້ງແຕ່ເລີ່ມຕົ້ນ."

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<b>BOM 2: Reusing Stock</b> This BOM would be used if you already have plain"
" T-shirts in stock. It would only include the components needed to add the "
"logo."
msgstr ""
"<b>BOM 2: ການນຳໃຊ້ເຄື່ອງໃນສາງຄືນ</b> BOM ນີ້ຈະຖືກນໍາໃຊ້ຖ້າທ່ານມີເສື້ອຢືດເປົ່າຢູ່ໃນສາງແລ້ວ. ມັນຈະລວ"
"ມເອົາສະເພາະສ່ວນປະກອບທີ່ຈຳເປັນໃນການເພີ່ມໂລໂກ້ເທົ່ານັ້ນ."

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid "<b>Blue Cotton</b>: Only applies to the \"Blue\" T-shirt variant."
msgstr "<b>Blue Cotton</b>: ໃຊ້ກັບເສື້ອຢືດລຸ້ນສີ \"ຟ້າ\" ເທົ່ານັ້ນ."

#. module: textile_manufacturing
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_12
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_13
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_14
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_15
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_3
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_4
msgid ""
"<b>Boat Neck:</b> A wide, straight neckline that runs horizontally across "
"the collarbone."
msgstr ""
"<b>ຄໍເຮືອ (Boat Neck):</b> ຄໍເສື້ອທີ່ກວ້າງ ແລະ ຊື່ ວາງຕາມແນວນອນຜ່ານກະດູກໄຫປາຣ້າ."

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<b>By-products:</b> Manage leftovers from production and track them as "
"valuable inventory."
msgstr ""
"<b>ຜະລິດຕະພັນພລອຍໄດ້ (By-products):</b> ຈັດການສິ່ງເສດເຫຼືອຈາກການຜະລິດ ແລະ ຕິດຕາມພວກມັນເປັ"
"ນສິນຄ້າທີ່ມີມູນຄ່າໃນສາງ."

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<b>Clothing Label</b>: Applies to both variants (when setting is empty)"
msgstr ""
"<b>ປ້າຍເສື້ອ (Clothing Label)</b>: ໃຊ້ກັບທັງສອງລຸ້ນ (ເມື່ອການຕັ້ງຄ່າຫວ່າງເປົ່າ)"

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid "<b>Component List</b>:"
msgstr "<b>ລາຍການສ່ວນປະກອບ</b>:"

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid "<b>Connected Printers:</b> Set up automated label printing."
msgstr "<b>ເຄື່ອງພິມທີ່ເຊື່ອມຕໍ່:</b> ຕັ້ງຄ່າການພິມປ້າຍແບບອັດຕະໂນມັດ."

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<b>Create BOMs for a single unit:</b> It's often easier to define your Bill "
"of Materials for just one unit."
msgstr ""
"<b>ສ້າງ BOM ສຳລັບໜ່ວຍດຽວ:</b> ມັນມັກຈະງ່າຍກວ່າໃນການກຳນົດລາຍການວັດສະດຸ (BOM) ສຳລັບສິນຄ້າພຽງ"
"ໜຶ່ງໜ່ວຍ."

#. module: textile_manufacturing
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_12
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_13
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_14
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_15
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_3
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_4
msgid "<b>Crew Neck (Round Neck):</b> The most classic and popular style."
msgstr "<b>ຄໍມົນ (Crew Neck):</b> ຮູບແບບທີ່ຄລາດສິກ ແລະ ເປັນທີ່ນິຍົມທີ່ສຸດ."

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<b>Destination Location:</b> If you have more than 1 internal location set "
"up on your inventory, you can choose the destination location as well."
msgstr ""
"<b>ສະຖານທີ່ປາຍທາງ:</b> ຖ້າທ່ານມີການຕັ້ງຄ່າສະຖານທີ່ພາຍໃນຫຼາຍກວ່າ 1 ແຫ່ງໃນສາງຂອງທ່ານ, ທ່ານສາມາ"
"ດເລືອກສະຖານທີ່ປາຍທາງໄດ້ເຊັ່ນກັນ."

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<b>Detailed Logging:</b> A record of the conversion is automatically posted "
"to the <b>Chatter</b> of both the Transfer and the Manufacturing Order."
msgstr ""
"<b>ການບັນທຶກລາຍລະອຽດ:</b> ບັນທຶກການແປງສະພາບຈະຖືກສະແດງໂດຍອັດຕະໂນມັດໃນ <b>Chatter</b> "
"ຂອງທັງການໂອນສາງ ແລະ ໃບສັ່ງຜະລິດ."

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<b>Direct Integration: </b> Add all the details directly to the "
"manufacturing operations."
msgstr ""
"<b>ການເຊື່ອມໂຍງໂດຍກົງ: </b> ເພີ່ມລາຍລະອຽດທັງໝົດເຂົ້າໃນການດຳເນີນງານການຜະລິດໂດຍກົງ."

#. module: textile_manufacturing
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_12
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_13
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_14
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_15
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_3
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_4
msgid ""
"<b>Dolman/Batwing Sleeve:</b> A very loose sleeve that gets narrower at the "
"wrist."
msgstr ""
"<b>ແຂນເສື້ອແບບປີກເຈຍ (Dolman/Batwing Sleeve):</b> ແຂນເສື້ອທີ່ວ່າງຫຼາຍ ແລະ ແຄບລົງຢູ່ບໍລິເວນຂໍ້"
"ມື."

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<b>Dropshipping route:</b> Enable this for products that are shipped "
"directly from a supplier's location to another destination without ever "
"entering your warehouse."
msgstr ""
"<b>ເສັ້ນທາງ Dropshipping:</b> ເປີດໃຊ້ງານສຳລັບສິນຄ້າທີ່ຖືກຈັດສົ່ງໂດຍກົງຈາກສະຖານທີ່ຂອງຜູ້ສະໜອງໄປຫ"
"າປາຍທາງອື່ນ ໂດຍທີ່ບໍ່ໄດ້ຜ່ານສາງຂອງທ່ານ."

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<b>Error Prevention:</b> This guardrail ensures users only convert products "
"into eligible alternatives, preventing manual data entry errors."
msgstr ""
"<b>ການປ້ອງກັນຂໍ້ຜິດພາດ:</b> ລະບົບປ້ອງກັນນີ້ຊ່ວຍໃຫ້ແນ່ໃຈວ່າຜູ້ໃຊ້ຈະແປງສະພາບສິນຄ້າເປັນທາງເລືອກທີ່ເໝາະສົ"
"ມເທົ່ານັ້ນ, ເພື່ອປ້ອງກັນຂໍ້ຜິດພາດຈາກການປ້ອນຂໍ້ມູນດ້ວຍຕົນເອງ."

#. module: textile_manufacturing
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_12
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_13
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_14
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_15
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_3
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_4
msgid "<b>Fit:</b>"
msgstr "<b>ຊົງ:</b>"

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<b>For Engineer-to-Order (ETO):</b> From the CRM, create a new project by "
"clicking the <b>⚙️ icon</b> and selecting a template. This project will "
"allow you to manage all the pre-sales steps, such as:"
msgstr ""
"<b>ສຳລັບການຜະລິດອອກແບບຕາມສັ່ງ (ETO):</b> ຈາກ CRM, ສ້າງໂຄງການໃໝ່ໂດຍການຄລິກທີ່ <b>ໄອຄອນ "
"⚙️</b> ແລະ ເລືອກແມ່ແບບ. ໂຄງການນີ້ຈະຊ່ວຍໃຫ້ທ່ານຈັດການຂັ້ນຕອນກ່ອນການຂາຍທັງໝົດ ເຊັ່ນ:"

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<b>For Make-to-Stock (MTS) or Make-to-Order (MTO) Products:</b> Simply create a quote with the correct product. When the customer confirms it, Odoo will automatically create a delivery order. Whether a production order is also\n"
"                    created depends on your settings, which are detailed in the <b>Manufacturing Order Creation</b> section."
msgstr ""
"<b>ສຳລັບສິນຄ້າແບບຜະລິດເພື່ອສາງ (MTS) ຫຼື ຜະລິດເມື່ອມີຄຳສັ່ງ (MTO):</b> ພຽງແຕ່ສ້າງໃບສະເໜີລາຄາດ້ວ"
"ຍສິນຄ້າທີ່ຖືກຕ້ອງ. ເມື່ອລູກຄ້າຢືນຢັນ, Odoo ຈະສ້າງໃບຈັດສົ່ງໂດຍອັດຕະໂນມັດ. ສ່ວນວ່າໃບສັ່ງຜະລິດຈະຖືກສ້າງຂຶ້ນ"
"ນຳຫຼືບໍ່ນັ້ນ ແມ່ນຂຶ້ນກັບການຕັ້ງຄ່າຂອງທ່ານ ເຊິ່ງມີລາຍລະອຽດຢູ່ໃນພາກ <b>ການສ້າງໃບສັ່ງຜະລິດ</b>."

#. module: textile_manufacturing
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_12
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_13
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_14
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_15
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_3
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_4
msgid ""
"<b>Henley:</b> A crew neck with a placket of a few buttons, often without a "
"collar."
msgstr ""
"<b>ເຮັນເລ (Henley):</b> ເສື້ອຄໍມົນທີ່ມີແຖບປຸ່ມກົດດ້ານໜ້າເລັກນ້ອຍ, ມັກຈະບໍ່ມີຄໍເສື້ອ."

#. module: textile_manufacturing
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_12
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_13
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_14
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_15
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_3
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_4
msgid ""
"<b>High Quality Cotton T-shirt available in the following variants:</b>"
msgstr "<b>ເສື້ອຢືດຜ້າຝ້າຍຄຸນນະພາບສູງ ມີໃຫ້ເລືອກໃນລຸ້ນຕ່າງໆດັ່ງນີ້:</b>"

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<b>History Preservation:</b> By using a background MO, the <b>Traceability "
"Report</b> remains unbroken. You can view the entire history of the new "
"product, including its previous form."
msgstr ""
"<b>ການຮັກສາປະຫວັດ:</b> ໂດຍການນຳໃຊ້ໃບສັ່ງຜະລິດ (MO) ໃນເບື້ອງຫຼັງ, <b>ລາຍງານການຕິດຕາມ "
"(Traceability Report)</b> ຈະບໍ່ຂາດຕອນ. ທ່ານສາມາດເບິ່ງປະຫວັດທັງໝົດຂອງສິນຄ້າໃໝ່ ລວມທັງຮູບແບບ"
"ກ່ອນໜ້ານີ້ຂອງມັນ."

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<b>Inventory Presence:</b> The transfer must not be a Receipt or Dropship. "
"(Products must be physically in stock before they can be converted)."
msgstr ""
"<b>ການມີຢູ່ໃນສາງ:</b> ການໂອນຍ້າຍຕ້ອງບໍ່ແມ່ນການຮັບສິນຄ້າ ຫຼື Dropship. (ສິນຄ້າຕ້ອງມີຢູ່ໃນສາງແທ້ໆ ກ່"
"ອນທີ່ຈະສາມາດແປງສະພາບໄດ້)."

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<b>Keep Lot/SN:</b> If checked, the new product inherits the existing "
"Lot/Serial Number (e.g., new \"T-shirt (Quality Refurbished, Yellow)\" "
"retains the original \"LOT1\")."
msgstr ""
"<b>ຮັກສາ Lot/SN:</b> ຖ້າໝາຍເລືອກ, ສິນຄ້າໃໝ່ຈະໄດ້ຮັບເລກລັອດ/ຊີຣຽວທີ່ມີຢູ່ແລ້ວ (ຕົວຢ່າງ: \"ເສື້ອຢືດ "
"(ປັບປຸງຄຸນນະພາບ, ສີເຫຼືອງ)\" ໃໝ່ ຈະຍັງຄົງຮັກສາ \"LOT1\" ເດີມໄວ້)."

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<b>Link to a Knowledge Page:</b> Gather all the information in a separate knowledge page and then link that page to the manufacturing instructions. This keeps the operations clean while providing all the\n"
"                                    necessary details."
msgstr ""
"<b>ເຊື່ອມໂຍງຫາໜ້າຄວາມຮູ້:</b> ຮວບຮວມຂໍ້ມູນທັງໝົດໄວ້ໃນໜ້າຄວາມຮູ້ແຍກຕ່າງຫາກ ແລ້ວເຊື່ອມໂຍງໜ້ານັ້ນເຂົ້າກັ"
"ບຄຳແນະນຳການຜະລິດ. ສິ່ງນີ້ຊ່ວຍໃຫ້ການດຳເນີນງານເປັນລະບຽບ ໃນຂະນະທີ່ຍັງມີລາຍລະອຽດທີ່ຈຳເປັນຄົບຖ້ວນ."

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<b>Location Accuracy:</b> The MO pulls from the exact \"Pick From\" location"
" to ensure inventory balance."
msgstr ""
"<b>ຄວາມຖືກຕ້ອງຂອງສະຖານທີ່:</b> ໃບສັ່ງຜະລິດ (MO) ຈະດຶງຂໍ້ມູນຈາກສະຖານທີ່ \"ເກັບຈາກ\" ທີ່ແນ່ນອນ ເ"
"ພື່ອຮັບປະກັນຄວາມສົມດຸນຂອງສາງ."

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<b>Make to Order (MTO):</b> Enable this if you want replenishment to be "
"automatically triggered whenever a sales order or production order is "
"validated."
msgstr ""
"<b>ຜະລິດເມື່ອມີຄຳສັ່ງ (MTO):</b> ເປີດໃຊ້ງານຫາກທ່ານຕ້ອງການໃຫ້ມີການເຕີມສິນຄ້າໂດຍອັດຕະໂນມັດ ທຸກຄັ້ງທີ່"
"ໃບສັ່ງຂາຍ ຫຼື ໃບສັ່ງຜະລິດຖືກຢືນຢັນ."

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<b>Manually</b> if the product doesn't have a Reordering Rule and there is "
"no stock available."
msgstr ""
"<b>ດ້ວຍຕົນເອງ</b> ຫາກສິນຄ້າບໍ່ມີກົດເກນການສັ່ງຊື້ຄືນ ແລະ ບໍ່ມີເຄື່ອງໃນສາງ."

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<b>Manufacturing 2 steps:</b> Your current \"Manufacturing 1 step\" workflow takes components directly from stock. By switching to a 2-step process, you'll add a picking operation between your warehouse and production\n"
"                                area. This is ideal for transferring entire packages, like a full bobbin of thread, rather than just a small portion."
msgstr ""
"<b>ການຜະລິດ 2 ຂັ້ນຕອນ:</b> ຂັ້ນຕອນການເຮັດວຽກ \"ການຜະລິດ 1 ຂັ້ນຕອນ\" ຂອງທ່ານໃນປະຈຸບັນຈະດຶງສ່"
"ວນປະກອບໂດຍກົງຈາກສາງ. ໂດຍການປ່ຽນເປັນຂະບວນການ 2 ຂັ້ນຕອນ, ທ່ານຈະເພີ່ມການດຳເນີນງານການເກັບເຄື່"
"ອງລະຫວ່າງສາງ ແລະ ເຂດການຜະລິດ. ສິ່ງນີ້ເໝາະສຳລັບການໂອນຍ້າຍທັງຫີບຫໍ່ ເຊັ່ນ: ກົງດ້າຍທັງກົງ, ແທນທີ່ຈະເ"
"ປັນພຽງສ່ວນນ້ອຍໆ."

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<b>Manufacturing 3 steps:</b> If you need a dedicated storage step for finished products, change your warehouse settings to a 3-step workflow. This adds a final transfer step, moving completed items from the\n"
"                                production area to their final storage location."
msgstr ""
"<b>ການຜະລິດ 3 ຂັ້ນຕອນ:</b> ຖ້າທ່ານຕ້ອງການຂັ້ນຕອນການຈັດເກັບສະເພາະສຳລັບສິນຄ້າສຳເລັດຮູບ, ໃຫ້ປ່ຽນກ"
"ານຕັ້ງຄ່າສາງເປັນ 3 ຂັ້ນຕອນ. ສິ່ງນີ້ຈະເພີ່ມຂັ້ນຕອນການໂອນຍ້າຍຂັ້ນສຸດທ້າຍ, ເປັນການຍ້າຍສິນຄ້າທີ່ຜະລິດສຳເລັດແ"
"ລ້ວຈາກເຂດການຜະລິດໄປຫາສະຖານທີ່ຈັດເກັບສຸດທ້າຍ."

#. module: textile_manufacturing
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_12
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_13
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_14
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_15
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_3
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_4
msgid ""
"<b>Material:</b> Crafted from 100% Ring-Spun Combed Cotton for superior "
"softness and durability. Our t-shirts are pre-shrunk to ensure a consistent "
"fit."
msgstr ""
"<b>ວັດສະດຸ:</b> ຜະລິດຈາກຜ້າຝ້າຍ Ring-Spun Combed 100% ເພື່ອຄວາມນຸ່ມນວນ ແລະ ທົນທານທີ່ເໜືອກວ່"
"າ. ເສື້ອຢືດຂອງພວກເຮົາຜ່ານຂະບວນການປ້ອງກັນການຫົດຕົວ ເພື່ອໃຫ້ແນ່ໃຈວ່າຊົງເສື້ອຈະຄົງທີ່."

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<b>Multi-Step Operations:</b> Choose a 1, 2, or 3-step process for receiving"
" and shipping goods in your <b>Warehouse Settings</b>."
msgstr ""
"<b>ການດຳເນີນງານຫຼາຍຂັ້ນຕອນ:</b> ເລືອກຂະບວນການ 1, 2 ຫຼື 3 ຂັ້ນຕອນສຳລັບການຮັບ ແລະ ການສົ່ງສິນຄ້"
"າໃນ <b>ການຕັ້ງຄ່າສາງ</b> ຂອງທ່ານ."

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<b>New Lot/SN:</b> If \"Keep\" is unchecked, users can manually assign a new"
" Lot/Serial Number."
msgstr ""
"<b>Lot/SN ໃໝ່:</b> ຖ້າບໍ່ໄດ້ໝາຍເລືອກ \"ຮັກສາ\", ຜູ້ໃຊ້ສາມາດກຳນົດເລກລັອດ/ຊີຣຽວໃໝ່ດ້ວຍຕົນເອງໄດ້."

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<b>Note:</b> If you validate a transfer for a partial quantity, the system "
"will automatically create a <b>backorder</b> for the rest of the items."
msgstr ""
"<b>ໝາຍເຫດ:</b> ຖ້າທ່ານຢືນຢັນການໂອນຍ້າຍສຳລັບຈຳນວນບາງສ່ວນ, ລະບົບຈະສ້າງ <b>ໃບສັ່ງຄ້າງສົ່ງ "
"(backorder)</b> ສຳລັບລາຍການທີ່ເຫຼືອໂດຍອັດຕະໂນມັດ."

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<b>Operational Status:</b> The transfer must be in a state other than "
"\"Draft\" or \"Done.\""
msgstr ""
"<b>ສະຖານະການດຳເນີນງານ:</b> ການໂອນຍ້າຍຕ້ອງຢູ່ໃນສະຖານະອື່ນທີ່ບໍ່ແມ່ນ \"ຮ່າງ\" ຫຼື \"ສຳເລັດແລ້ວ\""

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid "<b>Package Types:</b> Track specific types of packages."
msgstr "<b>ປະເພດຫີບຫໍ່:</b> ຕິດຕາມປະເພດຫີບຫໍ່ທີ່ສະເພາະເຈາະຈົງ."

#. module: textile_manufacturing
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_12
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_13
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_14
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_15
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_3
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_4
msgid "<b>Polo Collar:</b> A two-button placket and a soft, folded collar."
msgstr "<b>ຄໍໂປໂລ (Polo Collar):</b> ມີແຖບປຸ່ມສອງປຸ່ມ ແລະ ຄໍເສື້ອແບບພັບທີ່ນຸ່ມ."

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<b>Pro-Tip:</b> You can print and use barcode commands with a scanner to "
"automate and streamline your workflow."
msgstr ""
"<b>ເຄັດລັບ:</b> ທ່ານສາມາດພິມ ແລະ ນຳໃຊ້ຄຳສັ່ງບາໂຄດດ້ວຍເຄື່ອງສະແກນ ເພື່ອເຮັດໃຫ້ຂັ້ນຕອນການເຮັດວຽກ"
"ເປັນອັດຕະໂນມັດ ແລະ ຄ່ອງຕົວຂຶ້ນ."

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<b>Quantity Validation:</b> The system prevents converting more than the "
"maximum available stock for that specific Quant."
msgstr ""
"<b>ການກວດສອບຈຳນວນ:</b> ລະບົບຈະປ້ອງກັນບໍ່ໃຫ້ແປງສະພາບເກີນກວ່າຈຳນວນສິນຄ້າສູງສຸດທີ່ມີຢູ່ໃນ Quant ນັ້"
"ນ."

#. module: textile_manufacturing
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_12
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_13
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_14
