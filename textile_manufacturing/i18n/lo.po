msgstr "ປ້າຍເສື້ອຜ້າ (ຊຸດຊັ້ນໃນ)"

#. module: textile_manufacturing
#: model:product.public.category,name:textile_manufacturing.product_public_category_5
msgid "Collections"
msgstr "ຄໍເລັກຊັນ"

#. module: textile_manufacturing
#: model_terms:product.public.category,website_description:textile_manufacturing.product_public_category_3
msgid "Complete your look with our trendy and functional accessories."
msgstr "ເຕີມເຕັມລຸກຂອງທ່ານດ້ວຍອຸປະກອນເສີມທີ່ທັນສະໄໝ ແລະ ໃຊ້ງານໄດ້ດີ."

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.contactus
