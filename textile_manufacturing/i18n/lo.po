#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_3
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_4
msgid "<b>Regular/Classic Fit:</b> A standard, comfortable, and timeless fit."
msgstr "<b>ຊົງທຳມະດາ/ຄລາດສິກ:</b> ຊົງມາດຕະຖານ, ໃສ່ສະບາຍ ແລະ ບໍ່ຕົກຍຸກ."

#. module: textile_manufacturing
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_12
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_13
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_14
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_15
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_3
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_4
msgid ""
"<b>Relaxed/Oversized Fit:</b> A looser, more casual fit that is currently "
"popular in streetwear."
msgstr ""
"<b>ຊົງຫຼົມ/Oversized:</b> ຊົງທີ່ຫຼົມກວ່າ, ເບິ່ງສະບາຍໆ ເຊິ່ງກຳລັງເປັນທີ່ນິຍົມໃນແຟຊັນ streetwear."

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<b>Restricted Mapping:</b> If a product uses an attribute marked \"Convert "
"Attribute,\" the user is limited to selecting variants within that specific "
"attribute group."
msgstr ""
"<b>ການຈຳກັດການຈັບຄູ່:</b> ຫາກສິນຄ້າໃຊ້ຄຸນລັກສະນະທີ່ໝາຍວ່າ \"Convert Attribute\", ຜູ້ໃຊ້ຈະຖືກຈ"
"ຳກັດໃຫ້ເລືອກໄດ້ສະເພາະລຸ້ນຍ່ອຍພາຍໃນກຸ່ມຄຸນລັກສະນະນັ້ນເທົ່ານັ້ນ."

#. module: textile_manufacturing
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_12
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_13
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_14
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_15
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_3
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_4
msgid ""
"<b>Scoop Neck:</b> A wider, U-shaped neckline, more common in women's "
"styles."
msgstr ""
"<b>ຄໍກວ້າງຮູບຕົວ U (Scoop Neck):</b> ຄໍເສື້ອທີ່ກວ້າງເປັນຮູບຕົວ U, ມັກພົບເຫັນໃນເສື້ອຜ້າຜູ້ຍິງ."

#. module: textile_manufacturing
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_12
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_13
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_14
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_15
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_3
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_4
msgid ""
"<b>Set-in Sleeve:</b> The standard sleeve that is sewn into the armhole "
"seam."
msgstr "<b>ແຂນແບບ Set-in:</b> ແຂນເສື້ອມາດຕະຖານທີ່ຖືກຫຍິບເຂົ້າກັບຮູວົງແຂນ."

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid "<b>Shipping Connectors:</b> Integrate directly with shipping carriers."
msgstr "<b>ຕົວເຊື່ອມຕໍ່ການຂົນສົ່ງ:</b> ເຊື່ອມຕໍ່ໂດຍກົງກັບຜູ້ໃຫ້ບໍລິການຂົນສົ່ງ."

#. module: textile_manufacturing
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_12
