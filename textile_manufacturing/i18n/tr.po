#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.homepage
msgid ""
"<span class=\"h6-fs\">Collaborate with our team to create a custom line that "
"perfectly represents your brand</span>"
msgstr ""
"<span class=\"h6-fs\">Markanızı mükemmel bir şekilde temsil eden özel bir "
"çizgi oluşturmak için ekibimizle işbirliği yapın</span>"

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<span class=\"h6-fs\">Create all products—whether they are <b>finished "
"goods</b>, <b>semi-finished products</b>, or <b>raw materials</b>—and fill "
"in all the required information.</span><br/>"
msgstr ""
"<span class=\"h6-fs\">Tüm ürünleri—ister <b>bitmiş ürün</b>, <b>yarı mamul</"
"b> ister <b>ham madde</b> olsun—oluşturun ve gerekli tüm bilgileri doldurun."
"</span><br/>"

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<span class=\"h6-fs\">From the Inventory app, create your existing products. "
"To automate your workflows, make sure each product is configured correctly.</"
"span>"
msgstr ""
"<span class=\"h6-fs\">Envanter uygulamasından mevcut ürünlerinizi oluşturun. "
"İş akışlarınızı otomatikleştirmek için her ürünün doğru yapılandırıldığından "
"emin olun.</span>"

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid "<span class=\"h6-fs\">In the Manufacturing App</span>"
msgstr "<span class=\"h6-fs\">Üretim Uygulamasında</span>"

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<span class=\"h6-fs\">Textile manufacturing uses a variety of production "
"methods. This package focuses on three primary models</span><br/>"
msgstr ""
"<span class=\"h6-fs\">Tekstil üretiminde çeşitli üretim yöntemleri "
"kullanılmaktadır. Bu paket üç ana modele odaklanmaktadır</span><br/>"

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<span class=\"h6-fs\">To manage your production workflow, go to the "
"<b>Manufacturing</b> application. From there, you can create your <b>work "
"centers</b>, <b>operations</b>, and <b>bills of materials</b>..</span>"
msgstr ""
"<span class=\"h6-fs\">Üretim iş akışınızı yönetmek için <b>Üretim</b> "
"uygulamasına gidin. Buradan <b>iş merkezlerinizi</b>, <b>operasyonlarınızı</"
"b> ve <b>ürün reçetelerinizi</b> oluşturabilirsiniz.</span>"

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<span class=\"h6-fs\">Use the <b>Document</b> app to manage all your "
"internal and external documents and use the Sign App for automated customer "
"signatures</span>"
msgstr ""
"<span class=\"h6-fs\">Tüm dahili ve harici belgelerinizi yönetmek için "
"<b>Document</b> uygulamasını kullanın ve otomatik müşteri imzaları için İmza "
"Uygulamasını kullanın</span>"

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<span class=\"h6-fs\">Use the <b>E-commerce</b> app to sell products online."
"</span>"
msgstr ""
"<span class=\"h6-fs\">Çevrimiçi ürün satmak için <b>E-ticaret</b> "
"uygulamasını kullanın.</span>"

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<span class=\"h6-fs\">Use the Maintenance app to plan and monitor the upkeep "
"of your production line.<b/></span><br/>"
msgstr ""
"<span class=\"h6-fs\">Üretim hattınızın bakımını planlamak ve izlemek için "
"Bakım uygulamasını kullanın.<b/></span><br/>"

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<span class=\"h6-fs\">Use the Quality app to implement specific quality "
"control checks throughout your production or supply chain process.<b/></"
"span><br/>"
msgstr ""
"<span class=\"h6-fs\">Üretim veya tedarik zinciri süreciniz boyunca belirli "
"kalite kontrol kontrollerini uygulamak için Kalite uygulamasını kullanın.<b/"
"></span><br/>"

