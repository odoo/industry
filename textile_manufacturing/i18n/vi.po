#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<span class=\"h6-fs\">Textile manufacturing uses a variety of production "
"methods. This package focuses on three primary models</span><br/>"
msgstr ""
"<span class=\"h6-fs\">Ngành sản xuất hàng dệt may sử dụng nhiều phương pháp "
"sản xuất khác nhau. Gói này tập trung vào ba mô hình chính</span><br/>"

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<span class=\"h6-fs\">To manage your production workflow, go to the "
"<b>Manufacturing</b> application. From there, you can create your <b>work "
"centers</b>, <b>operations</b>, and <b>bills of materials</b>..</span>"
msgstr ""
"<span class=\"h6-fs\">Để quản lý quy trình sản xuất của bạn, hãy vào ứng "
"dụng <b>Sản xuất</b>. Từ đó, bạn có thể tạo <b>khu vực sản xuất</b>, <b>hoạt "
"động sản xuất</b> và <b>danh mục vật tư</b>.</span>"

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<span class=\"h6-fs\">Use the <b>Document</b> app to manage all your "
"internal and external documents and use the Sign App for automated customer "
"signatures</span>"
msgstr ""
"<span class=\"h6-fs\">Sử dụng ứng dụng <b>Tài liệu</b> để quản lý tất cả tài "
"liệu nội bộ và bên ngoài của bạn, đồng thời dùng ứng dụng Ký tên để tự động "
"hóa chữ ký của khách hàng.</span>"

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<span class=\"h6-fs\">Use the <b>E-commerce</b> app to sell products online."
"</span>"
msgstr ""
"<span class=\"h6-fs\">Sử dụng ứng dụng <b>Thương mại điện tử</b> để bán sản "
"phẩm online.</span>"

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<span class=\"h6-fs\">Use the Maintenance app to plan and monitor the upkeep "
"of your production line.<b/></span><br/>"
msgstr ""
"<span class=\"h6-fs\">Sử dụng ứng dụng Bảo trì để lập kế hoạch và giám sát "
"việc bảo dưỡng dây chuyền sản xuất của bạn.<b/></span><br/>"

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<span class=\"h6-fs\">Use the Quality app to implement specific quality "
"control checks throughout your production or supply chain process.<b/></"
"span><br/>"
msgstr ""
"<span class=\"h6-fs\">Sử dụng ứng dụng Chất lượng để triển khai các bước "
"kiểm tra chất lượng cụ thể trong suốt quy trình sản xuất hoặc chuỗi cung ứng "
"của bạn.<b/></span><br/>"

