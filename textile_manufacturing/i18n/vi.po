#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_14
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_15
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_3
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_4
msgid ""
"<b>Raglan Sleeve:</b> Extends in one piece to the collar, creating a "
"diagonal seam."
msgstr ""
"<b>Tay áo Raglan:</b> Được may liền một mảnh kéo dài đến cổ áo, tạo thành "
"một đường may chéo."

#. module: textile_manufacturing
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_12
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_13
#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_14
