msgstr ""
"<b>Công suất khu vực sản xuất:</b> Tối ưu hóa lịch sản xuất của bạn bằng "
"cách khai thác công suất của các khu vực sản xuất."

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid "<b>Yellow Cotton</b>: Only applies to the \"Yellow\" T-shirt variant."
msgstr ""
"<b>Vải cotton vàng:</b> Chỉ áp dụng cho biến thể áo phông màu \"Vàng\"."

