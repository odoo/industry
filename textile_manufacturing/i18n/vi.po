#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<span class=\"h6-fs\">\n"
"                This module is designed to streamline your daily production, "
"from start to finish. It helps you manage customer relationships, prepare "
"for production, purchase raw materials, and handle deliveries. With this "
"complete solution, you\n"
"                can boost efficiency and improve customer satisfaction "
"across all your production services.\n"
"            </span>"
msgstr ""
"<span class=\"h6-fs\">\n"
"              Phân hệ này được thiết kế để tối ưu hóa quy trình sản xuất "
"hàng ngày của bạn từ đầu đến cuối. Nó giúp bạn quản lý mối quan hệ với khách "
"hàng, chuẩn bị cho quá trình sản xuất, mua nguyên liệu thô và xử lý giao "
"hàng. Với giải pháp toàn diện này, bạn\n"
"              có thể nâng cao hiệu quả và cải thiện sự hài lòng của khách "
"hàng trong tất cả dịch vụ sản xuất của mình.\n"
"</span>"

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<span class=\"h6-fs\">\n"
"                Welcome to the <strong><font style=\"color: rgb(113, 75, "
"103);\">Odoo Textile Manufacturing</font></strong>!\n"
"            </span>\n"
"            <br/>"
msgstr ""

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<span class=\"h6-fs\">\n"
"                When a purchase order for a subcontracted product is "
"created, the system handles the entire process. As long as your Bill of "
"Materials (BOM) is accurate, the purchase order will automatically trigger a "
"receipt for the final product\n"
"                and a replenishment order for all necessary components.\n"
"            </span>\n"
"            <span class=\"h2-fs\"><span class=\"h2-fs\"/></span><br/>"
msgstr ""
"<span class=\"h6-fs\">\n"
"              Khi tạo đơn mua hàng cho sản phẩm gia công, hệ thống sẽ tự "
"động xử lý toàn bộ quy trình. Miễn là Danh mục vật tư (BOM) của bạn chính "
"xác, đơn mua hàng sẽ tự động kích hoạt phiếu nhập kho cho sản phẩm cuối "
"cùng\n"
"              và đơn bổ sung hàng cho tất cả các thành phần cần thiết.\n"
"</span>\n"
"          <span class=\"h2-fs\"><span class=\"h2-fs\"/></span><br/>"

