#: model_terms:product.template,description_ecommerce:textile_manufacturing.product_template_4
msgid ""
"<b>Set-in Sleeve:</b> The standard sleeve that is sewn into the armhole seam."
msgstr "<b>Tay áo ráp:</b> Kiểu tay áo tiêu chuẩn được may vào đường ráp nách."

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid "<b>Shipping Connectors:</b> Integrate directly with shipping carriers."
msgstr ""
"<b>Đơn vị vận chuyển:</b> Tích hợp trực tiếp với các nhà cung cấp dịch vụ "
"vận chuyển."

