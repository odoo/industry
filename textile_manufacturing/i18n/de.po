msgstr "<b>Variantenkontrolle &amp; Fehlervermeidung</b>"

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<b>Work Center Capacity:</b> Optimize your production schedule by exploring "
"the capacity of your work centers."
msgstr ""
"<b>Kapazität des Arbeitsplatzes:</b> Optimieren Sie Ihren Produktionsplan, "
"indem Sie die Kapazität Ihrer Arbeitsplätze erkunden."

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid "<b>Yellow Cotton</b>: Only applies to the \"Yellow\" T-shirt variant."
msgstr "<b>Gelbe Baumwolle</b>: Gilt nur für die T-Shirt-Variante „Gelb“."

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.homepage
msgid ""
"<br/>Our vibrant color palette is ready to brighten your wardrobe this "
"upcoming summer.<br/>"
msgstr ""
"<br/>Unsere lebendige Farbpalette ist bereit, Ihre Garderobe im kommenden "
"Sommer aufzufrischen.<br/>"

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>CRM App</b> &amp; <b>Sales App</b></font>: "
"Manage client relationships and opportunities, creating stunning quotations "
"for new collections or bulk orders."
msgstr ""
"<font class=\"text-o-color-1\"><b>CRM-App</b> &amp; <b> Verkaufsapp</b></"
"font>: Verwalten Sie Kundenbeziehungen und Verkaufschancen und erstellen Sie "
"beeindruckende Angebote für neue Kollektionen oder Großaufträge."

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>Inventory App</b>:</font> Fasten your "
"purchasing cycles and track raw materials across your warehouse and "
"subcontractor locations."
msgstr ""
"<font class=\"text-o-color-1\"><b>Lagerapp</b>:</font> Beschleunigen Sie "
"Ihre Einkaufszyklen und verfolgen Sie Rohstoffe in Ihrem Lager sowie bei "
"Ihren Subunternehmern."

#. module: textile_manufacturing
#: model_terms:ir.ui.view,arch_db:textile_manufacturing.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>Invoicing App</b>:</font> Streamline your "
"cash flow by invoicing clients at the right time, whether upon order "
"confirmation or delivery."
msgstr ""
"<font class=\"text-o-color-1\"><b>Rechnungsstellungsapp</b>:</font> "
