msgstr "ອາສາມະຊັກ"

#. module: non_profit_organization
#: model_terms:ir.ui.view,arch_db:non_profit_organization.welcome_article_body
msgid ""
"Volunteer shifts and roles are scheduled and tracked through <strong>\n"
"                    <font class=\"text-o-color-1\">Planning</font>\n"
