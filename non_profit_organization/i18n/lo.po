"{{ object.company_id.name }} {{ object.state in ('draft', 'sent') and "
"(ctx.get('proforma') and 'Proforma' or 'Quotation') or 'Order' }} (Ref {{ "
"object.name or 'n/a' }})"
msgstr ""
"{{ object.company_id.name }} {{ object.state in ('draft', 'sent') and "
"(ctx.get('proforma') and 'ໃບແຈ້ງໜີ້ຊົ່ວຄາວ' or 'ໃບສະເໜີລາຄາ') or 'ໃບສັ່ງຂາຍ' }} (ອ້າງອີ"
"ງ {{ object.name or 'n/a' }})"
