#. module: non_profit_organization
#: model:mail.template,body_html:non_profit_organization.mail_template_50
msgid ""
"<div data-oe-version=\"2.0\">Dear <t "
"t-out=\"object.partner_id.name\"/>,</div><br/><div>Thank you for your "
"continued support in <t t-out=\"object.invoice_date.year if "
"object.invoice_date else ''\"/>.</div><br/><div>Please find attached your "
"fiscal attestation for this year. </div><br/><div>If you have any questions,"
" feel free to contact us at <t "
"t-out=\"object.company_id.email\"/>.</div><br/><div>Warm regards, "
"</div><div>The <t t-out=\"object.company_id.name\"/> team </div><div><t "
"t-out=\"object.company_id.email\"/> | <t "
"t-out=\"object.company_id.phone\"/></div>\n"
msgstr ""
"<div data-oe-version=\"2.0\">ຮຽນ <t t-out=\"object.partner_id.name\"/>,</div>"
"<br/><div>ຂໍຂອບໃຈສຳລັບການສະໜັບສະໜູນຢ່າງຕໍ່ເນື່ອງຂອງທ່ານໃນປີ <t t-"
"out=\"object.invoice_date.year if object.invoice_date else ''\"/>.</div><br/>"
"<div>ກະລຸນາເບິ່ງໃບຢັ້ງຢືນການເສຍພາສີຂອງທ່ານສຳລັບປີນີ້ໃນເອກະສານຄັດຕິດ. </div><br/><div>ຫາກທ່ານ"
"ມີຄຳຖາມໃດໆ, ສາມາດຕິດຕໍ່ພວກເຮົາໄດ້ທີ່ <t t-out=\"object.company_id.email\"/>.</div>"
"<br/><div>ດ້ວຍຄວາມນັບຖື, </div><div>ທີມງານ <t t-out=\"object.company_id.name\"/> "
"</div><div><t t-out=\"object.company_id.email\"/> | <t t-"
"out=\"object.company_id.phone\"/></div>\n"

#. module: non_profit_organization
#: model:mail.template,body_html:non_profit_organization.mail_template_51
msgid ""
"<div data-oe-version=\"2.0\">Dear Sir or "
"Madam,</div><div><br/></div><div>Please find attached the CSV file "
"containing all fiscal attestations for the year <t "
"t-out=\"object.invoice_date.year if object.invoice_date else "
"''\"/>.</div><br/><div>If you require any additional information, feel free "
"to reach out to us at <t "
"t-out=\"object.company_id.email\"/>.</div><br/><div>Best regards, "
"</div><div><t t-out=\"object.user_id.name\"/> </div><div><t "
"t-out=\"object.company_id.name\"/> </div><div><t "
"t-out=\"object.user_id.email\"/> | <t "
"t-out=\"object.company_id.phone\"/></div>\n"
msgstr ""
"<div data-oe-version=\"2.0\">ຮຽນ ທ່ານ ທີ່ນັບຖື,</div><div><br/></div><div>ກະລຸນາເບິ່ງ"
"ໄຟລ໌ CSV ທີ່ຄັດຕິດມານີ້ ເຊິ່ງລວມມີໃບຢັ້ງຢືນການເສຍພາສີທັງໝົດສຳລັບປີ <t t-"
"out=\"object.invoice_date.year if object.invoice_date else ''\"/>.</div><br/>"
"<div>ຫາກທ່ານຕ້ອງການຂໍ້ມູນເພີ່ມເຕີມ, ສາມາດຕິດຕໍ່ພວກເຮົາໄດ້ທີ່ <t t-"
"out=\"object.company_id.email\"/>.</div><br/><div>ດ້ວຍຄວາມນັບຖື, </div><div><t "
"t-out=\"object.user_id.name\"/> </div><div><t t-"
"out=\"object.company_id.name\"/> </div><div><t t-"
"out=\"object.user_id.email\"/> | <t t-out=\"object.company_id.phone\"/></div>"
"\n"

