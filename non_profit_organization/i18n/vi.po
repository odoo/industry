#: model:mail.template,body_html:non_profit_organization.mail_template_50
msgid ""
"<div data-oe-version=\"2.0\">Dear <t t-out=\"object.partner_id.name\">,</t></"
"div><br/><div>Thank you for your continued support in <t t-"
"out=\"object.invoice_date.year\">.</t></div><br/><div>Please find attached "
"your fiscal attestation for this year. </div><br/><div>If you have any "
"questions, feel free to contact us at <t t-out=\"object.company_id.email\">."
"</t></div><br/><div>Warm regards, </div><div>The <t t-"
"out=\"object.company_id.name\"> team </t></div><div><t t-"
"out=\"object.company_id.email\"> | <t t-out=\"object.company_id.phone\"/></"
"t></div>\n"
msgstr ""
"<div data-oe-version=\"2.0\">Kính gửi <t t-out=\"object.partner_id.name\">,</"
"t></div><br/><div>Cảm ơn bạn đã luôn đồng hành và ủng hộ trong năm <t t-"
"out=\"object.invoice_date.year\">.</t></div><br/><div>Vui lòng xem chứng từ "
"thuế của bạn cho năm nay trong tệp đính kèm. </div><br/><div>Nếu bạn có bất "
"kỳ câu hỏi nào, hãy liên hệ với chúng tôi qua <t t-"
"out=\"object.company_id.email\">.</t></div><br/><div>Trân trọng, </"
"div><div><t t-out=\"object.company_id.name\"> Đội ngũ</t></div><div><t t-"
"out=\"object.company_id.email\"> | <t t-out=\"object.company_id.phone\"/></"
"t></div>\n"

#. module: non_profit_organization
#: model:mail.template,body_html:non_profit_organization.mail_template_51
msgid ""
"<div data-oe-version=\"2.0\">Dear Sir or Madam,</div><div><br/></"
"div><div>Please find attached the CSV file containing all fiscal "
"attestations for the year <t t-out=\"object.invoice_date.year\">.</t></"
"div><br/><div>If you require any additional information, feel free to reach "
"out to us at <t t-out=\"object.company_id.email\">.</t></div><br/><div>Best "
"regards, </div><div><t t-out=\"object.user_id.name\"> </t></div><div><t t-"
"out=\"object.company_id.name\"> </t></div><div><t t-"
"out=\"object.user_id.email\"> | <t t-out=\"object.company_id.phone\"/></t></"
"div>\n"
msgstr ""
"<div data-oe-version=\"2.0\">Kính gửi Quý ông/bà,</div><div><br/></"
"div><div>Vui lòng xem tệp CSV đính kèm, trong đó chứa toàn bộ chứng từ thuế "
"cho năm <t t-out=\"object.invoice_date.year\">.</t></div><br/><div>Nếu ông/"
"bà cần thêm thông tin, xin vui lòng liên hệ với chúng tôi qua địa chỉ <t t-"
"out=\"object.company_id.email\">.</t></div><br/><div>Trân trọng, </"
"div><div><t t-out=\"object.user_id.name\"> </t></div><div><t t-"
"out=\"object.company_id.name\"> </t></div><div><t t-"
"out=\"object.user_id.email\"> | <t t-out=\"object.company_id.phone\"/></t></"
"div>\n"

