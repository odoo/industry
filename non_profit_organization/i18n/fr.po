#. module: non_profit_organization
#: model_terms:ir.ui.view,arch_db:non_profit_organization.welcome_article_body
msgid ""
"3. <strong>Organize Awareness Events</strong>: Schedule events like "
"<em>Community\n"
"                Talks</em> or <em>Film Screenings</em> using Events."
msgstr ""
"3. <strong>Organisez des événements de sensibilisation</strong> : planifiez "
"des événements tels que des <em>conférences communautaires</em> ou des <em>"
"projections de films</em> à l’aide de l’application Événements."

#. module: non_profit_organization
#: model_terms:ir.ui.view,arch_db:non_profit_organization.report_fiscal_attestation_document
msgid "3.00"
