msgstr "Osallistuisitko toiseen vastaavaan tapahtumaan tulevaisuudessa?"

#. module: non_profit_organization
#: model_terms:ir.ui.view,arch_db:non_profit_organization.welcome_article_body
msgid "Would you like to discuss your Odoo setup with us or go even further?"
msgstr ""
"Haluatko keskustella kanssamme Odoon käyttöönotosta tai jatkaa sitäkin "
"pidemmälle?"

#. module: non_profit_organization
#: model:survey.question,title:non_profit_organization.survey_question_13
