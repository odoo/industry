#. module: non_profit_organization
#: model:mail.template,body_html:non_profit_organization.mail_template_50
msgid ""
"<div data-oe-version=\"2.0\">Dear <t t-out=\"object.partner_id.name\"/>,</"
"div><br/><div>Thank you for your continued support in <t t-"
"out=\"object.invoice_date.year if object.invoice_date else ''\"/>.</div><br/"
"><div>Please find attached your fiscal attestation for this year. </div><br/"
"><div>If you have any questions, feel free to contact us at <t t-"
"out=\"object.company_id.email\"/>.</div><br/><div>Warm regards, </"
"div><div>The <t t-out=\"object.company_id.name\"/> team </div><div><t t-"
"out=\"object.company_id.email\"/> | <t t-out=\"object.company_id.phone\"/></"
"div>\n"
msgstr ""
"<div data-oe-version=\"2.0\">Estimado/a <t t-out=\"object.partner_id.name\"/"
">:</div><br/><div>Gracias por su continuo apoyo en <t t-"
"out=\"object.invoice_date.year if object.invoice_date else ''\"/>.</div><br/"
"><div>Adjuntamos su certificado fiscal correspondiente a este año. </div><br/"
"><div>Si tiene alguna pregunta, no dude en contactar con nosotros a través "
"de <t t-out=\"object.company_id.email\"/>.</div><br/><div>Reciba un cordial "
"saludo, </div><div>El equipo de <t t-out=\"object.company_id.name\"/> </"
"div><div><t t-out=\"object.company_id.email\"/> | <t t-"
"out=\"object.company_id.phone\"/></div>\n"

#. module: non_profit_organization
#: model:mail.template,body_html:non_profit_organization.mail_template_51
msgid ""
"<div data-oe-version=\"2.0\">Dear Sir or Madam,</div><div><br/></"
"div><div>Please find attached the CSV file containing all fiscal "
"attestations for the year <t t-out=\"object.invoice_date.year if "
"object.invoice_date else ''\"/>.</div><br/><div>If you require any "
"additional information, feel free to reach out to us at <t t-"
"out=\"object.company_id.email\"/>.</div><br/><div>Best regards, </"
"div><div><t t-out=\"object.user_id.name\"/> </div><div><t t-"
"out=\"object.company_id.name\"/> </div><div><t t-"
"out=\"object.user_id.email\"/> | <t t-out=\"object.company_id.phone\"/></"
"div>\n"
msgstr ""
"<div data-oe-version=\"2.0\">Estimado/a:</div><div><br/></"
"div><div>Adjuntamos el archivo CSV que contiene todas las certificaciones "
"fiscales correspondientes al año <t t-out=\"object.invoice_date.year if "
"object.invoice_date else ''\"/>.</div><br/><div>Si necesita información "
"adicional, no dude en ponerse en contacto con nosotros a través de <t t-"
"out=\"object.company_id.email\"/>.</div><br/><div>Saludos cordiales, </"
"div><div><t t-out=\"object.user_id.name\"/> </div><div><t t-"
"out=\"object.company_id.name\"/> </div><div><t t-"
"out=\"object.user_id.email\"/> | <t t-out=\"object.company_id.phone\"/></"
"div>\n"

