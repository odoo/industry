<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="action_report_donation_receipt" model="ir.actions.report">
        <field name="name">Donation Receipt</field>
        <field name="model">x_donation_receipt</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">non_profit_organization.report_donation_receipt_document</field>
        <field name="binding_model_id" ref="x_donation_receipt_model"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'Donation Receipt - %s' % (object.x_donation_receipt_no or '')</field>
    </record>
    <record id="action_report_donation_summary" model="ir.actions.report">
        <field name="name">Donation Receipt Summary</field>
        <field name="model">x_donation_receipt</field>
        <field name="report_type">qweb-pdf</field>
        <field name="binding_model_id" ref="x_donation_receipt_model"/>
        <field name="binding_type">report</field>
        <field name="report_name">non_profit_organization.report_donation_summary</field>
        <field name="print_report_name">'Donation Summary - %s' % (object.id)</field>
        <field name="multi">True</field>
    </record>
</odoo>
