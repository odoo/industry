<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <!-- Donation Receipt -->

    <template id="report_donation_receipt_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="d-flex justify-content-end mb-4">
                            <div class="text-end col-6">
                                <div t-field="o.x_donor"
                                    t-options="{'widget': 'contact', 'fields': ['name','address'], 'no_marker': True}"/>
                                <div t-if="o.x_donor.x_citizen_id_number" class="text-muted">
                                    <span t-field="o.x_donor.x_citizen_id_number"/>
                                </div>
                            </div>
                        </div>

                        <h2 class="mt-4">Donation Receipt</h2>
                        <p class="text-muted" t-field="o.x_donation_receipt_no"/>
                        <p class="text-muted">
                            Period: <span t-field="o.x_donation_period.date_from" t-options="{'widget':'date'}"/>
                            - <span t-field="o.x_donation_period.date_to" t-options="{'widget':'date'}"/>
                        </p>

                        <table class="table table-sm">
                            <thead>
                                <tr class="fw-bold border-bottom border-dark">
                                    <td>Date</td>
                                    <td>Reference</td>
                                    <td class="text-end">Amount</td>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="donation_lines" t-value="o.env['account.move.line'].search([
                                    ('move_id.partner_id', '=', o.x_donor.id),
                                    ('move_id.move_type', '=', 'out_invoice'),
                                    ('move_id.state', '=', 'posted'),
                                    ('product_id.categ_id.x_product_category_is_donation', '=', True),
                                    ('move_id.invoice_date', '&gt;=', o.x_donation_period.date_from),
                                    ('move_id.invoice_date', '&lt;=', o.x_donation_period.date_to),
                                ])"/>
                                <t t-set="total" t-value="sum(donation_lines.mapped('price_total'))"/>

                                <t t-foreach="donation_lines" t-as="line">
                                    <tr>
                                        <td>
                                            <span t-field="line.move_id.invoice_date"/>
                                        </td>
                                        <td>
                                            <span t-field="line.move_id.payment_reference"/>
                                        </td>
                                        <td class="text-end">
                                            <span t-field="line.price_total" t-options="{'widget':'monetary','display_currency':line.currency_id}"/>
                                        </td>
                                    </tr>
                                </t>

                                <tr>
                                    <td><strong>Total</strong></td>
                                    <td/>
                                    <td class="text-end">
                                        <strong t-out="total" t-options="{'widget':'monetary','display_currency':res_company.currency_id}"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                        <p class="mt-2"><b>No goods or services were provided in exchange for this contribution.</b></p>
                        <p class="mt-2">
                            Delivered in <span t-field="res_company.partner_id.city"/>,
                            on <span t-field="o.create_date" t-options="{'widget':'date'}"/>.
                        </p>
                        <div class="mt-2 me-2">
                            <p>
                                <span t-field="o.create_uid.name"/><br/>
                                <img t-if="o.create_uid.x_report_signature"
                                    t-att-src="image_data_uri(o.create_uid.x_report_signature)"
                                    style="max-height:80px;"/>
                            </p>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
    <template id="report_donation_summary">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
            <div class="page">
                <h2 class="mb-3">Donation Receipt Summary</h2>
                <!-- Period -->
                <t t-set="period_start" t-value="min(docs.mapped('x_donation_period.date_from'))"/>
                <t t-set="period_end" t-value="max(docs.mapped('x_donation_period.date_to'))"/>
                <p class="text-muted">
                Period:
                <t t-out="period_start" t-options="{'widget': 'date'}"/>
                -
                <t t-out="period_end" t-options="{'widget': 'date'}"/>
                </p>
                <table class="table table-bordered table-sm align-middle">
                <thead class="table-light">
                    <tr class="fw-bold">
                    <th>Donor</th>
                    <th>Citizen ID</th>
                    <th class="text-end">Total Amount</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-set="donors" t-value="docs.mapped('x_donor')"/>
                    <t t-foreach="donors" t-as="donor">
                    <t t-set="donation_lines"
                        t-value="docs.env['account.move.line'].search([
                        ('move_id.partner_id','=',donor.id),
                        ('move_id.move_type','=','out_invoice'),
                        ('move_id.state','=','posted'),
                        ('product_id.categ_id.x_product_category_is_donation','=',True),
                        ('move_id.invoice_date','&gt;=',period_start),
                        ('move_id.invoice_date','&lt;=',period_end),
                        ])"/>
                    <t t-set="donor_total" t-value="sum(donation_lines.mapped('price_total'))"/>

                    <tr>
                        <td t-out="donor.name"/>
                        <td t-out="donor.x_citizen_id_number or '-'"/>
                        <td class="text-end">
                        <t t-out="donor_total"
                            t-options="{'widget':'monetary','display_currency':res_company.currency_id}"/>
                        </td>
                    </tr>
                    </t>
                </tbody>
                </table>
                <div class="mt-4">
                <p>
                    Delivered in <t t-out="res_company.partner_id.city"/> on
                    <t t-out="docs[0].create_date" t-options="{'widget':'date'}"/>.
                </p>
                <div class="d-flex align-items-center mt-3">
                    <span t-field="user.name"/><br/>
                    <img t-if="user.x_report_signature"
                        t-att-src="image_data_uri(user.x_report_signature)"
                        style="max-height:80px;"/>
                </div>
                </div>
            </div>
            </t>
        </t>
    </template>

    <!-- Website Views -->

    <record id="website_checkout_extra_info" model="ir.ui.view">
        <field name="arch" type="xml">
        <t name="Checkout Extra Info" active="False" t-name="website_sale.extra_info">
            <t t-set="oe_structure"><div class="oe_structure" id="oe_structure_website_sale_extra_info_1"/></t>
            <t t-call="website_sale.checkout_layout"
                show_navigation_button="False"
                redirect.f="/shop/extra_info"
                oe_structure="oe_structure">
            <h3 class="mb-4">Extra info</h3>
            <section class="s_website_form o_colored_level" data-vcss="001" data-snippet="s_website_form">
                <div class="container">
                <form action="/website/form/" method="post" enctype="multipart/form-data" class="o_mark_required s_website_form_no_recaptcha" data-mark="*" data-force_action="shop.sale.order" data-model_name="sale.order" data-success-mode="redirect" data-success-page="/shop/payment" hide-change-model="true">
                    <div class="s_website_form_rows s_col_no_bgcolor row">
                    <div class="s_website_form_field col-12 pb-2 mb-0" data-type="char" data-name="Field">
                        <div class="row s_col_no_resize s_col_no_bgcolor">
                            <label class="s_website_form_label col-form-label col-sm-auto" style="width: 200px" for="citizen_id_number1">
                                <span class="s_website_form_label_content">Citizen ID Number</span>
                            </label>
                            <div class="col-sm">
                                <input id="citizen_id_number1" type="text" class="s_website_form_input form-control" name="x_related_citizen_id_number"/>
                            </div>
                        </div>
                    </div>
                    <div class="s_website_form_submit s_website_form_no_submit_option d-flex flex-column flex-lg-row align-items-lg-center pt-4">
                        <a role="button" name="website_sale_main_button" class="s_website_form_send btn btn-primary order-lg-3 w-100 w-lg-auto ms-lg-auto" href="/shop/confirm_order">
                                        Continue checkout
                                        <i class="fa fa-angle-right ms-2 fw-light"/>
                                    </a>
                        <div class="position-relative d-flex d-lg-none w-100 justify-content-center align-items-center my-2 opacity-75">
                        <hr class="w-100"/>
                        <span class="px-3">or</span>
                        <hr class="w-100"/>
                        </div>
                        <a href="/shop/checkout" class="text-center"><i class="fa fa-angle-left me-2 fw-light"/>
                                        Return to shipping
                                    </a>
                        <span id="s_website_form_result"/>
                    </div>
                    </div>
                </form>
                </div>
            </section>
            </t>
        </t>
        </field>
        <field name="key">non_profit_organization.extra_info</field>
        <field name="name">Checkout Extra Info</field>
        <field name="type">qweb</field>
        <field name="active" eval="True"/>
        <field name="website_id" ref="base.default_website"/>
    </record>
    <function model="ir.ui.view" name="write">
        <value model="ir.ui.view" eval="obj().env['website'].with_context(website_id=obj().env.ref('base.default_website').id).viewref('website_sale.extra_info').id"/>
        <value model="ir.ui.view" eval="{'arch': obj().env.ref('non_profit_organization.website_checkout_extra_info').arch}"/>
    </function>
    <function model="ir.model.fields" name="formbuilder_whitelist">
        <value eval="'sale.order'"/>
        <value eval="['x_related_citizen_id_number']"/>
    </function>
</odoo>
