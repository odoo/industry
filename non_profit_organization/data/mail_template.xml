<?xml version='1.0' encoding='UTF-8'?>
<odoo noupdate="1">
    <record id="mail_template_51" model="mail.template">
        <field name="body_html"><![CDATA[
<div data-oe-version="2.0">Dear Sir or Madam,</div><div><br/></div><div>Please find attached the CSV file containing all fiscal attestations for the year <t t-out="object.invoice_date.year if object.invoice_date else ''"/>.</div><br/><div>If you require any additional information, feel free to reach out to us at <t t-out="object.company_id.email"/>.</div><br/><div>Best regards, </div><div><t t-out="object.user_id.name"/> </div><div><t t-out="object.company_id.name"/> </div><div><t t-out="object.user_id.email"/> | <t t-out="object.company_id.phone"/></div>
]]></field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="name">Fiscal Attestation Authorities</field>
        <field name="subject">Fiscal Attestations for {{ object.partner_id.name }}</field>
    </record>
     <record id="email_template_donation_receipt" model="mail.template">
        <field name="name">Donation Receipt</field>
        <field name="model_id" ref="x_donation_receipt_model"/>
        <field name="partner_to">{{ object.x_donor.id }}</field>
        <field name="report_template_ids" eval="[(6, 0, [ref('action_report_donation_receipt')])]"/>
        <field name="subject">{{ user.company_id.name }} Donation Receipt - {{ object.x_donation_receipt_no }}</field>
        <field name="body_html" type="html">
            <div style="margin: 0px; padding: 0px;">
                <p style="margin: 0px; padding: 0px;">
                    Dear <t t-out="object.x_donor.name or 'Donor'"/>,
                    <br/>
                    Thank you for your generous donation. Please find below the details
                    of your donation receipt for the period
                    <t t-out="object.x_donation_period.date_from or ''"/> to <t t-out="object.x_donation_period.date_to or ''"/>.
                    <br/>
                    <br/>
                    Receipt No: <t t-out="object.x_donation_receipt_no or ''"/>
                    <br/>
                    <br/>
                    We deeply appreciate your support in helping us continue our mission.
                    <br/>
                    Do not hesitate to contact us if you have any questions.
                    <br/>
                    Sincerely,
                    <br/>
                    <t t-out="user.name"/>
                </p>
            </div>
        </field>
    </record>
</odoo>
