<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="action_server_donation_receipt_no" model="ir.actions.server" >
        <field name="name">Donation Receipt Sequence server action</field>
        <field name="model_id" ref="x_donation_receipt_model"/>
        <field name="update_path">x_donation_receipt_no</field>
        <field name="update_field_id" ref="x_donation_receipt_no_field_x_donation_receipt"/>
        <field name="evaluation_type">equation</field>
        <field name="state">object_write</field>
        <field name="value"><![CDATA["Receipt/" + record.env['ir.sequence'].next_by_code('x_donation_receipt')]]></field>
    </record>
    <record id="ir_actions_server_update_journal_entry" model="ir.actions.server">
        <field name="name">Update Journal Entry</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="update_path">journal_id</field>
        <field name="state">object_write</field>
        <field name="crud_model_id" ref="account.model_account_move"/>
        <field name="update_field_id" ref="account.field_account_move__journal_id"/>
        <field name="usage">base_automation</field>
        <field name="value" ref="account_journal_donations"/>
    </record>
</odoo>
