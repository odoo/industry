<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="base_automation_to_generate_receipt_no" model="base.automation">
        <field name="name">Generate Receipt No</field>
        <field name="model_id" ref="x_donation_receipt_model"/>
        <field name="trigger">on_create</field>
        <field name="action_server_ids" eval="[(6, 0, [ref('action_server_donation_receipt_no')])]"/>
    </record>
    <record id="base_automation_for_invoice_creation" model="base.automation">
        <field name="name">Invoice creation from donation category product</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="trigger">on_create</field>
        <field name="action_server_ids" eval="[(6, 0, [ref('ir_actions_server_update_journal_entry')])]"/>
        <field name="filter_domain" eval="[('invoice_line_ids.product_id.categ_id', 'in', [ref('website_sale.product_category_donations')])]"/>
    </record>
</odoo>
