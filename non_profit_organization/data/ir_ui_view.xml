<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="product_category_form_view" model="ir.ui.view">
        <field name="name">product.category.form.view.inherited.non_profit_organization</field>
        <field name="model">product.category</field>
        <field name="inherit_id" ref="product.product_category_form_view"/>
        <field name="active" eval="True"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='parent_id']" position="before">
                <field name="x_product_category_is_donation"/>
            </xpath>
        </field>
    </record>

    <record id="res_partner_form_view" model="ir.ui.view">
        <field name="name">res.partner.form.view.inherited.non_profit_organization</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field eval="17" name="priority"/>
        <field name="active" eval="True"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('o_address_format')]" position="after">
                <field name="x_citizen_id_number" placeholder="e.g. 123455 555 6"/>
            </xpath>
        </field>
    </record>

    <record id="sale_order_tree_customization" model="ir.ui.view">
        <field name="name">sale.order.tree.customization</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_quotation_tree"/>
        <field name="mode">extension</field>
        <field name="active" eval="True"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="x_related_address"/>
                <field name="x_related_citizen_id_number" placeholder="e.g. 123455 555 6"/>
            </xpath>
        </field>
    </record>
    <record id="sale_order_form_customization" model="ir.ui.view">
        <field name="name">sale.order.form.customization</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="mode">extension</field>
        <field name="active" eval="True"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_shipping_id']" position="after">
                <field name="x_related_citizen_id_number" placeholder="e.g. 123455 555 6"/>
            </xpath>
        </field>
    </record>
    <record id="sale_order_graph_customization" model="ir.ui.view">
        <field name="name">sale.order.graph.customization</field>
        <field name="model">sale.order</field>
        <field name="mode">primary</field>
        <field name="active" eval="True"/>
        <field name="arch" type="xml">
            <graph>
                <field name="date_order" interval="month"/>
            </graph>
        </field>
    </record>
    <record id="x_donation_receipt_form_view" model="ir.ui.view">
        <field name="name">x_donation_receipt.form.view</field>
        <field name="model">x_donation_receipt</field>
        <field name="active" eval="True"/>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="x_donation_receipt_no"/>
                        <field name="x_donor"/>
                        <field name="x_donation_period"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="x_donation_receipt_list_view" model="ir.ui.view">
        <field name="name">x_donation_receipt.list.view</field>
        <field name="model">x_donation_receipt</field>
        <field name="active" eval="True"/>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list>
                <field name="x_donation_receipt_no"/>
                <field name="x_donor"/>
                <field name="x_donation_period"/>
            </list>
        </field>
    </record>
    <record id="res_users_view_form_custom" model="ir.ui.view">
        <field name="name">res.users.form.view.non_profit_organization</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="model">res.users</field>
        <field name="mode">extension</field>
        <field name="active" eval="True"/>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='signature']" position="after">
                <field name="x_report_signature" widget="signature"/>
            </xpath>
        </field>
    </record>
    <record id="action_window_donations" model="ir.actions.act_window">
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('sale_order_tree_customization')}),
            (0, 0, {'view_mode': 'graph', 'view_id': ref('sale_order_graph_customization')}),
        ]"/>
    </record>
</odoo>
