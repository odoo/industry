<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <!-- product_category fields -->
     <record id="x_product_category_is_donation_field_product_category" model="ir.model.fields">
        <field name="ttype">boolean</field>
        <field name="copied" eval="True"/>
        <field name="field_description">Is donation</field>
        <field name="model_id" ref="product.model_product_category"/>
        <field name="name">x_product_category_is_donation</field>
    </record>

    <!-- res_partner fields -->
    <record id="x_citizen_id_number_field_res_partner" model="ir.model.fields">
        <field name="ttype">char</field>
        <field name="copied" eval="True"/>
        <field name="field_description">Citizen ID Number</field>
        <field name="model_id" ref="base.model_res_partner"/>
        <field name="name">x_citizen_id_number</field>
    </record>

    <!-- sale_order fields -->
    <record id="x_related_citizen_id_number_field_account_journal" model="ir.model.fields">
        <field name="ttype">char</field>
        <field name="related">partner_id.x_citizen_id_number</field>
        <field name="copied" eval="True"/>
        <field name="field_description">Citizen ID Number</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="name">x_related_citizen_id_number</field>
    </record>
    <record id="x_related_address_field_account_journal" model="ir.model.fields">
        <field name="ttype">char</field>
        <field name="related">partner_id.contact_address_complete</field>
        <field name="copied" eval="True"/>
        <field name="field_description">Address</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="name">x_related_address</field>
    </record>

    <!-- Donation receipt fields -->
    <record id="x_donation_receipt_model_x_donor_field" model="ir.model.fields">
        <field name="name">x_donor</field>
        <field name="field_description">Donor</field>
        <field name="model_id" ref="x_donation_receipt_model"/>
        <field name="ttype">many2one</field>
        <field name="required" eval="True"/>
        <field name="relation">res.partner</field>
    </record>
    <record id="x_donation_receipt_no_field_x_donation_receipt" model="ir.model.fields">
        <field name="name">x_donation_receipt_no</field>
        <field name="field_description">Receipt No</field>
        <field name="model_id" ref="x_donation_receipt_model"/>
        <field name="ttype">char</field>
        <field name="readonly" eval="True"/>
    </record>
    <record id="x_donation_period_field" model="ir.model.fields">
        <field name="name">x_donation_period</field>
        <field name="ttype">many2one</field>
        <field name="field_description">Period</field>
        <field name="model_id" ref="x_donation_receipt_model"/>
        <field name="relation">account.fiscal.year</field>
    </record>
    <record id="x_report_signature_field_res_users" model="ir.model.fields">
        <field name="name">x_report_signature</field>
        <field name="field_description">Report Signature</field>
        <field name="model_id" ref="base.model_res_users"/>
        <field name="ttype">binary</field>
    </record>
</odoo>
