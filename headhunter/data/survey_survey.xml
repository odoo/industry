<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="survey_survey_1" model="survey.survey">
        <field name="title">Feedback Form</field>
        <field name="scoring_type">no_scoring</field>
        <field name="progression_mode">number</field>
        <field name="survey_type">survey</field>
        <field name="description">
            <![CDATA[ 
                Please complete this very short survey to let us know how satisfied your are with our products.<br />
                Your responses will help us improve our product range to serve you even better.
            ]]>
        </field>
        <field name="description_done">
            <![CDATA[ 
                <p>Thank you very much for your feedback. We highly value your opinion!</p>
            ]]>
        </field>
    </record>
    <record id="survey_survey_2" model="survey.survey">
        <field name="title">test</field>
        <field name="scoring_type">no_scoring</field>
    </record>
</odoo>

