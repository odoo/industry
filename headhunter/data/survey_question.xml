<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="survey_question_1" model="survey.question">
        <field name="title">How frequently do you use our products?</field>
        <field name="survey_id" ref="survey_survey_1"/>
        <field name="question_type">simple_choice</field>
        <field name="constr_mandatory" eval="True"/>
    </record>
    <record id="survey_question_2" model="survey.question">
        <field name="title">How many orders did you pass during the last 6 months?</field>
        <field name="survey_id" ref="survey_survey_1"/>
        <field name="question_type">numerical_box</field>
    </record>
    <record id="survey_question_3" model="survey.question">
        <field name="title">How likely are you to recommend the following products to a friend?</field>
        <field name="survey_id" ref="survey_survey_1"/>
        <field name="question_type">matrix</field>
    </record>
</odoo>
