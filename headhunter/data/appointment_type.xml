<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="appointment_type_1" model="appointment.type">
        <field name="name">First Interview</field>
        <field name="avatars_display">hide</field>
        <field name="appointment_duration_formatted">1 hour</field>
        <field name="staff_user_count">1</field>
        <field name="appointment_tz" model="res.users" eval="obj().env.ref('base.user_admin').tz or 'UTC'"/>
        <field name="reminder_ids" eval="[(6, 0, [ref('calendar.alarm_notif_1'), ref('calendar.alarm_mail_1'), ref('appointment_sms.calendar_alarm_data_1h_sms')])]"/>
        <field name="assign_method">time_auto_assign</field>
        <field name="staff_user_ids" eval="[(6, 0, [ref('base.user_admin')])]"/>
        <field name="website_url">/appointment/1</field>
        <field name="can_publish" eval="True"/>
        <field name="has_message" eval="True"/>
    </record>
</odoo>
