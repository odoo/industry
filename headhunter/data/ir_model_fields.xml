<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="field_x_name" model="ir.model.fields">
        <field name="name">x_name</field>
        <field name="field_description">Description</field>
        <field name="model_id" ref="project_task_line"/>
        <field name="required" eval="True"/>
        <field name="translate" eval="True"/>
        <field name="ttype">char</field>
    </record>
    <record id="field_x_opportunities" model="ir.model.fields">
        <field name="name">x_opportunities</field>
        <field name="field_description">Opportunities</field>
        <field name="model_id" ref="hr_recruitment.model_hr_applicant"/>
        <field name="relation">crm.lead</field>
        <field name="relation_table">x_crm_lead_hr_applicant_rel</field>
        <field name="ttype">many2many</field>
    </record>
    <record id="field_x_opportunities_count" model="ir.model.fields">
        <field name="compute"><![CDATA[for record in self: record['x_opportunities_count'] = self.env['hr.applicant'].search_count([('x_opportunities', '=', record.id)])]]></field>
        <field name="field_description">Opportunities count</field>
        <field name="name">x_opportunities_count</field>
        <field name="model_id" ref="crm.model_crm_lead"/>
        <field name="selectable" eval="False"/>
        <field name="store" eval="False"/>
        <field name="ttype">integer</field>
    </record>
    <record id="field_x_sequence" model="ir.model.fields">
        <field name="name">x_sequence</field>
        <field name="field_description">Sequence</field>
        <field name="model_id" ref="project_task_line"/>
        <field name="ttype">integer</field>
    </record>
</odoo>
