<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="agreement_signature" model="ir.actions.server">
        <field name="name">Agreement Signature</field>
        <field name="model_id" ref="crm.model_crm_lead"/>
        <field name="base_automation_id" ref="agreement_signature_automation"/>
        <field name="state">mail_post</field>
        <field name="mail_post_method">comment</field>
        <field name="template_id" ref="crm_signature_agreem"/>
    </record>
    <record id="contact_activity" model="ir.actions.server">
        <field name="name">Contact activity</field>
        <field name="model_id" ref="crm.model_crm_lead"/>
        <field name="base_automation_id" ref="contact_activity_automation"/>
        <field name="state">next_activity</field>
        <field name="activity_type_id" ref="mail.mail_activity_data_call"/>
        <field name="activity_date_deadline_range">3</field>
        <field name="activity_summary">First Contact</field>
        <field name="activity_user_type">specific</field>
        <field name="activity_user_id" ref="base.user_admin"/>
    </record>
    <record id="contact_applicant" model="ir.actions.server">
        <field name="name">Contact Applicant</field>
        <field name="model_id" ref="hr_recruitment.model_hr_applicant"/>
        <field name="base_automation_id" ref="contact_applicant_automation"/>
        <field name="state">next_activity</field>
        <field name="activity_type_id" ref="mail.mail_activity_data_call"/>
        <field name="activity_date_deadline_range">2</field>
        <field name="activity_summary">Contact new applicant</field>
        <field name="activity_user_type">generic</field>
        <field name="activity_user_field_name">user_id</field>
    </record>
</odoo>
