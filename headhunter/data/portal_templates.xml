<?xml version="1.0" encoding="UTF-8"?>
<odoo noupdate="1">
    <record id="portal_my_home_cv_sent_applicants" model="portal.entry">
        <field name="name">Applicants</field>
        <field name="description">Follow CVs and availability from applicants for each job position</field>
        <field name="url">/website/action/cv_sent_applicants</field>
        <field name="image" type="base64" file="headhunter/static/src/binary/ir_attachment/icon.png"/>
        <field name="is_config_card" eval="True"/>
    </record>
    <template id="portal_cv_sent_applicants" name="CV Sent Applicants">
        <t t-call="portal.portal_layout">
            <t t-set="logged_user" t-value="request.env.user"/>
            <t t-set="partner_ids" t-value="[logged_user.partner_id.id, logged_user.partner_id.parent_id.id]"/>
            <t t-set="user_applicants" t-value="
                request.env['x_cv_sent_application'].sudo().search([
                    ('x_is_published', '=', True),
                    ('x_job_id.x_customer_id', 'in', partner_ids)
                ])
            "/>

            <t t-call="portal.portal_searchbar">
                <t t-set="title">Applicants</t>
            </t>

            <div t-if="not user_applicants" class="alert alert-info">
                There are currently no published applicants for your account.
            </div>

            <t t-else="">
                <t t-call="portal.portal_table">
                    <thead>
                        <tr>
                            <th>Applicant</th>
                            <th>Job Position</th>
                            <th>Available</th>
                            <th>Availability</th>
                            <th>CV</th>
                            <th>CV Sent Date</th>
                        </tr>
                    </thead>
                    <t t-foreach="user_applicants" t-as="app">
                        <tr>
                            <td><t t-out="app.x_applicant_id.partner_name"/></td>
                            <td><t t-out="app.x_job_id.name"/></td>
                            <td>
                                <t t-if="app.x_available">
                                    <span class="btn btn-outline-success btn-sm">Yes</span>
                                </t>
                                <t t-else="">
                                    <span class="btn btn-outline-danger btn-sm">No</span>
                                </t>
                            </td>
                            <td><t t-out="app.x_availability"/></td>
                            <td>
                                <t t-if="app.x_cv_ids">
                                    <t t-foreach="app.x_cv_ids" t-as="cv">
                                        <div>
                                            <a t-att-href="'/web/content/%s?filename=%s&amp;download=false' % (cv.id, cv.name)" target="_blank">
                                                <i class="fa fa-file-pdf-o me-1"/>
                                                <t t-out="cv.name or 'View CV'"/>
                                            </a>
                                        </div>
                                    </t>
                                </t>
                            </td>
                            <td><t t-out="app.x_cv_sent_date"/></td>
                        </tr>
                    </t>
                </t>
            </t>
        </t>
    </template>
</odoo>
