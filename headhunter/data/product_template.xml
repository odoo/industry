<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="product_template_1" model="product.template" context="{'create_product_product': False}">
        <field name="name">Job Onboarding</field>
        <field name="purchase_ok" eval="False"/>
        <field name="default_code">ONBOARDING</field>
        <field name="detailed_type">service</field>
        <field name="categ_id" ref="product.product_category_all"/>
        <field name="list_price">400.0</field>
        <field name="description">
            <![CDATA[ 
                <p>
                Create a new job position on the career webpage for the customer <br />
                <br />
                This includes 1 applicant proposal.
                </p>
            ]]>
        </field>
    </record>
    <record id="product_template_2" model="product.template" context="{'create_product_product': False}">
        <field name="name">Candidates Proposal</field>
        <field name="purchase_ok" eval="False"/>
        <field name="default_code">PROPOSAL</field>
        <field name="detailed_type">service</field>
        <field name="categ_id" ref="product.product_category_all"/>
        <field name="list_price">100.0</field>
    </record>
    <record id="product_template_3" model="product.template" context="{'create_product_product': False}">
        <field name="name">[To delete]</field>
        <field name="purchase_ok" eval="False"/>
        <field name="default_code">to delete</field>
        <field name="detailed_type">service</field>
        <field name="categ_id" ref="product.product_category_all"/>
        <field name="description">
            <![CDATA[ 
                <p>Content of the package :</p>
                <p>Onboarding : Contact with the customer, creation of the job position.</p>
                <p>Follow-up : Gather information and manage applicants info.</p>
                <p>Proposals : Send the 5 bests applicants to the customer.</p>
            ]]>
        </field>
    </record>
    <record id="product_template_6" model="product.template" context="{'create_product_product': False}">
        <field name="name">Company Analysis</field>
        <field name="purchase_ok" eval="False"/>
        <field name="default_code">ANALYSIS_COMPANY</field>
        <field name="detailed_type">service</field>
        <field name="categ_id" ref="product.product_category_all"/>
        <field name="list_price">3000.0</field>
    </record>
    <record id="product_template_7" model="product.template" context="{'create_product_product': False}">
        <field name="name">Market deep dive</field>
        <field name="purchase_ok" eval="False"/>
        <field name="default_code">ANALYSIS_MARKET</field>
        <field name="detailed_type">service</field>
        <field name="categ_id" ref="product.product_category_all"/>
        <field name="list_price">2500.0</field>
    </record>
    <record id="product_template_8" model="product.template" context="{'create_product_product': False}">
        <field name="name">Hired Candidate Plan</field>
        <field name="purchase_ok" eval="False"/>
        <field name="default_code">HIRED</field>
        <field name="detailed_type">service</field>
        <field name="categ_id" ref="product.product_category_all"/>
    </record>
</odoo>
