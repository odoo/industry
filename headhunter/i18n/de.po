#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid "<b>1. Creation &amp; Initial Contact</b>"
msgstr "<b>1. Erstellung &amp; Erstkontakt</b>"

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid "<b>2. Screening &amp; Data Enrichment</b>"
msgstr "<b>2. Screening &amp; Datenanreicherung</b>"

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid "<b>3. Interview Scheduling</b>"
msgstr "<b>3. Terminvereinbarung für Vorstellungsgespräche</b>"

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">CRM</font>:</b> Streamlines daily "
"discussions with potential clients."
msgstr ""
"<b><font class=\"text-o-color-1\">CRM-</font>:</b> Optimiert die täglichen "
"Gespräche mit potenziellen Kunden."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Recruitment App:</font></b> Tracks all "
"talent and their applications within a clear pipeline"
msgstr ""
"<b><font class=\"text-o-color-1\">Personalbeschaffungsapp:</font></b> "
"Verfolgt alle Talente und ihre Bewerbungen in einer übersichtlichen Pipeline"

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Sales &amp; Invoicing App</font>:</b> "
"Maintains a clear, automated record of all\n"
"                financial transactions."
msgstr ""
"<b><font class=\"text-o-color-1\">Verkaufs- &amp; Rechnungsstellungsapp</"
"font>:</b> Führt eine übersichtliche, automatisierte Aufzeichnung aller\n"
"                Finanztransaktionen."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Website App:</font></b> Drives visibility "
"about open positions"
msgstr ""
"<b><font class=\"text-o-color-1\">Website-App:</font></b> Steigert die "
"Sichtbarkeit offener Stellen"

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Activate:</b> After the quotation is signed, update the Job Position "
"status to <b>Open</b>."
msgstr ""
"<b>Aktivieren:</b> Nachdem das Angebot unterzeichnet wurde, aktualisieren "
"Sie den Status der Auftragsposition auf <b>Offen.</b>."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Activation:</b> Once the Sales Order is validated by the client, manually "
"update the status to\n"
"                    <b>\"Open\"</b> to begin active sourcing."
msgstr ""
"<b>Aktivierung:</b> Sobald der Verkaufsauftrag vom Kunden validiert wurde, "
"aktualisieren Sie den Status manuell auf\n"
"                   <b>Offen</b>, um mit der aktiven Beschaffung zu beginnen."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Add to Pool:</b> Select the application and click the <b>Add to Pool</b> "
"button."
msgstr ""
"<b>Zum Pool hinzufügen:</b> Wählen Sie die App aus und klicken Sie auf die "
"Schaltfläche <b>Zum Pool hinzufügen</b>."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Applicants:</b> Track active candidates through the recruitment pipeline "
"for each job position."
msgstr ""
"<b>Bewerber:</b> Verfolgen Sie aktive Kandidaten durch den "
"Rekrutierungsprozess für jede Stellenposition."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Automatic Tracking:</b> This action automatically creates a line for this "
"candidate into the\n"
"                    <b>\"Reporting / Cv sent Report.\"</b>"
msgstr ""
"<b>Automatische Nachverfolgung:</b> Diese Aktion erstellt automatisch eine "
"Zeile für diesen Kandidaten unter\n"
"                   <b>Berichtswesen/Bericht über gesendete Lebensläufe.</b>"

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Automation:</b> Each pipeline stage can be configured to send automated "
"emails to maintain consistent\n"
"                    communication with candidates."
msgstr ""
"<b>Automatisierung:</b> Jede Pipeline-Phase kann so konfiguriert werden, "
"dass automatisierte E-Mails versendet werden, um eine konsistente\n"
"                    Kommunikation mit den Bewerbern aufrechtzuerhalten."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Availability Tracking:</b> For every applicant, you can toggle their "
"status (Available/Unavailable) or\n"
"                    set a specific \"Available From\" date."
msgstr ""
"<b>Verfügbarkeitsverfolgung:</b> Für jeden Bewerber können Sie den Status "
"(Verfügbar/Nicht verfügbar) umschalten oder\n"
"                    ein bestimmtes „Verfügbar ab“-Datum festlegen."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Bill:</b> Once the successful candidates are hired, proceed to "
"<b>invoice</b> the Sales Order."
msgstr ""
"<b>Rechnung:</b> Sobald die erfolgreichen Kandidaten eingestellt sind, "
"stellen Sie den Verkaufsauftrag in <b>Rechnung</b>."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Configure</b> client details and grant portal access to the hiring team."
msgstr ""
"<b>Konfigurieren</b> Sie die Kundendaten und gewähren Sie dem "
"Einstellungsteam den Zugriff auf das Portal."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Convert to Talent:</b> The candidate is now a \"Talent.\" From their "
"profile, you can now instantly apply\n"
"                    them to any other open positions."
msgstr ""
"<b>In Talent umwandeln:</b> Der Kandidat ist nun ein „Talent“. Über sein "
"Profil können Sie ihn nun sofort\n"
"                    auf alle anderen offenen Stellen bewerben."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid "<b>Create</b> a new job position"
msgstr "<b>Erstellen</b> Sie eine neue Stelle"

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Define Requirements:</b> Input essential details such as target profile, "
"salary range, and job description."
msgstr ""
"<b>Anforderungen definieren:</b> Geben Sie wesentliche Details wie "
"Zielprofil, Gehaltsspanne und Stellenbeschreibung ein."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid "<b>Define</b> key skills required for the job"
msgstr ""
"<b>Definieren</b> Sie die für die Stelle erforderlichen Kernkompetenzen"

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid "<b>Document Management:</b>"
msgstr "<b>Dokumentenverwaltung:</b>"

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Done:</b> Fulfilled or inactive job position; these are hidden from the "
"website and automatically\n"
"                            filtered out of your main view."
msgstr ""
"<b>Erledigt:</b> Besetzte oder inaktive Stellen; diese werden auf der "
"Website ausgeblendet und automatisch\n"
"                            aus Ihrer Hauptansicht herausgefiltert."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Draft Sales Order:</b> Once the details are finalized, generate a "
"<b>Quotation</b> from either\n"
"                            the Job Position or the Opportunity; both "
"methods will link the records correctly."
msgstr ""
"<b>Verkaufsauftrag im Entwurf:</b> Sobald die Details feststehen, generieren "
"Sie ein <b>Angebot</b> entweder\n"
"                            aus der Auftragsposition oder aus der "
"Verkaufschance; beide Methoden verknüpfen die Datensätze korrekt."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Draft:</b> Used for job position awaiting final client approval. You "
"cannot publish these or add\n"
"                            applicants yet."
msgstr ""
"<b>Entwurf:</b> Wird für Stellenangebote verwendet, die auf die endgültige "
"Freigabe durch den Kunden warten. Sie können diese noch nicht "
"veröffentlichen oder\n"
"                            Bewerber hinzufügen."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>External Settings:</b> For client-based job positions, you can designate "
"the Customer and the\n"
"                    <b>Hiring Team Contact</b>. Members of the Hiring Team "
"Contact will receive emails whenever new CVs are\n"
"                    submitted."
msgstr ""
"<b>Externe Einstellungen:</b> Für kundenbasierte Stellen können Sie den "
"Kunden und den\n"
"                   <b>Ansprechpartner des Einstellungsteams</b> angeben. Die "
"Mitglieder des Einstellungsteams erhalten E-Mails, sobald neue Lebensläufe\n"
"                    eingereicht werden."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Flexible Billing:</b> Customize payment terms within the Sales Order "
"based on the specific contract type."
msgstr ""
"<b>Flexible Rechnungsstellung:</b> Passen Sie die Zahlungsbedingungen im "
"Verkaufsauftrag entsprechend der jeweiligen Vertragsart an."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Generate Job:</b> From the Opportunity, select <b>Create New Job</b>."
msgstr ""
"<b>Stelle erstellen:</b> Wählen Sie die Verkaufschance aus und wählen Sie "
"<b>Neue Stelle erstellen</b> aus."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid "<b>Go Live</b> by switching the status to \"Open.\""
msgstr ""
"<b>Veröffentlichen</b> Sie sie, indem Sie den Status auf „Offen“ setzen."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Independent Pipelines:</b> While core information is linked, each "
"application follows its own unique\n"
"                    recruitment journey, allowing you to track progress for "
"different roles simultaneously."
msgstr ""
"<b>Unabhängige Pipelines:</b> Während Kerninformationen verknüpft sind, "
"folgt jede App ihrem eigenen, einzigartigen\n"
"                    Rekrutierungsprozess, sodass Sie den Fortschritt für "
"verschiedene Rollen gleichzeitig verfolgen können."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Initiate:</b> Open the CRM app and create a new <b>Opportunity</b> for "
"your client."
msgstr ""
"<b>Loslegen:</b> Öffnen Sie die CRM-App und erstellen Sie eine neue "
"<b>Verkaufschance</b> für Ihren Kunden."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Internal Files:</b> Documents attached to the <b>Chatter</b> are private "
"and for internal use\n"
"                            only."
msgstr ""
"<b>Interne Dateien:</b> Dokumente, die im <b>Chatter</b> angehängt sind, "
"sind privat und nur für den internen Gebrauch bestimmt\n"
"                            ."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Invoicing:</b> Once the Sales Order is signed, you can proceed to "
"generate the invoice according to the agreed-upon terms."
msgstr ""
"<b>Rechnungsstellung:</b> Sobald der Verkaufsauftrag unterzeichnet ist, "
"können Sie die Rechnung gemäß den vereinbarten Bedingungen erstellen."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Job Positions:</b> Define your requirements, website listings, and "
"necessary skills."
msgstr ""
"<b>Stellen:</b> Definieren Sie Ihre Anforderungen, Website-Anzeigen und "
"erforderlichen Kompetenzen."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid "<b>Key Configuration Rules</b>"
msgstr "<b>Wichtige Konfigurationsregeln</b>"

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Locate the Candidate:</b> Find the new application within that Job "
"Position in the back-end."
msgstr ""
"<b>Kandidaten suchen:</b> Suchen Sie die neue Bewerbung innerhalb dieser "
"Stelle im Backend."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid "<b>Login:</b> john.smith@fifth.example.com <b>Password:</b> john"
msgstr "<b>Benutzer:</b> john.smith@fünftes.beispiel.com <b>Passwort:</b> john"

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Manual Entry:</b> Creating a record directly within the specific Job "
"Position pipeline."
msgstr ""
"<b>Manuelle Eingabe:</b> Erstellen eines Datensatzes direkt innerhalb der "
"spezifischen Pipeline für Stellenangebote."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid "<b>Open:</b> Active roles that are ready for publication."
msgstr "<b>Offen:</b> Aktive Rollen, die zur Veröffentlichung bereit sind."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid "<b>Opportunity Creation → Quotation/Sales Order → Invoicing.</b>"
msgstr ""
"<b>Erstellung der Verkaufschance → Angebot/Verkaufsauftrag → "
"Rechnungsstellung.</b>"

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid "<b>Publish</b> and customize the job description on the website"
msgstr ""
"<b>Veröffentlichen</b> und passen Sie die Stellenbeschreibung auf der "
"Website an"

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Real-Time Synchronization:</b> This centralized view ensures that if you "
"update a candidate’s\n"
"                    availability (e.g., they are hired elsewhere), that "
"status updates instantly across all client portals where\n"
"                    that CV was shared."
msgstr ""
"<b>Echtzeit-Synchronisation:</b> Diese zentralisierte Ansicht stellt sicher, "
"dass bei einer Aktualisierung der Verfügbarkeit eines Bewerbers\n"
"                    (z. B. wenn er anderweitig eingestellt wurde) dieser "
"Status sofort in allen Kundenportalen aktualisiert wird, in denen\n"
"                    dieser Lebenslauf geteilt wurde."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid "<b>Recruit:</b> Your recruitment team can now begin their search."
msgstr ""
"<b>Einstellen:</b> Ihr Personalbeschaffungsteam kann nun mit der Suche "
"beginnen."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Recruitment Type:</b> Distinguish between <b>Internal</b> (hiring for "
"your own firm) and\n"
"                    <b>External</b> (hiring on behalf of a client)."
msgstr ""
"<b>Art der Personalbeschaffung:</b> Unterscheiden Sie zwischen <b>Intern</b> "
"(Einstellung für das eigene Unternehmen) und\n"
"                   <b> Extern</b> (Einstellung im Auftrag eines Kunden)."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Scheduling:</b> Ensure your Appointment app is synced to allow candidates "
"to book meetings based on your\n"
"                    real-time availability."
msgstr ""
"<b>Terminplanung:</b> Stellen Sie sicher, dass Ihre Termine-App "
"synchronisiert ist, damit Kandidaten Termine basierend auf Ihrer\n"
"                    Echtzeit-Verfügbarkeit buchen können."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Seamless Application: </b>When a Talent is moved to a job position, the "
"system creates a linked duplicate\n"
"                    for that specific role, ensuring organized record-"
"keeping."
msgstr ""
"<b>Nahtlose App: </b>Wenn ein Talent auf eine Stelle versetzt wird, erstellt "
"das System ein verknüpftes Duplikat\n"
"                    für diese spezifische Rolle, wodurch eine organisierte "
"Datenerfassung gewährleistet wird."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid "<b>See It In Action!</b>"
msgstr "<b>Sehen Sie es in Aktion!</b>"

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Shared Files:</b> Documents uploaded to the <b>Shared CV</b> field are "
"customer-facing. These are\n"
"                            the files sent via email to clients and "
"published on the Customer Portal."
msgstr ""
"<b>Geteilte Dateien:</b> Dokumente, die in das Feld <b>Geteilter Lebenslauf</"
"b> hochgeladen werden, sind für Kunden bestimmt. Dies sind\n"
"                            die Dateien, die per E-Mail an Kunden gesendet "
"und im Kundenportal veröffentlicht werden."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Smart Syncing:</b> Most data is shared between the Talent profile and "
"their specific job applications.\n"
"                    For example, updating a candidate's <b>availability</b> "
"in the Talent Pool automatically updates it across\n"
"                    all their active applications."
msgstr ""
"<b>Intelligente Synchronisierung:</b> Die meisten Daten werden zwischen dem "
"Talentprofil und den jeweiligen Bewerbungen geteilt.\n"
"                    Wenn Sie beispielsweise die <b>Verfügbarkeit</b> eines "
"Bewerbers im Talentpool aktualisieren, wird diese automatisch in\n"
"                    allen seinen aktiven Bewerbungen aktualisiert."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Source</b> the perfect candidate from your existing talent pool or new "
"applicants."
msgstr ""
"<b>Finden</b> Sie den perfekten Kandidaten aus Ihrem bestehenden Talentpool "
"oder unter neuen Bewerbern."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid "<b>Status Indicators:</b>"
msgstr "<b>Statusanzeigen:</b>"

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Status Management:</b> New positions are created in <b>Draft</b> mode by "
"default, preventing premature\n"
"                    publication or applications."
msgstr ""
"<b>Statusverwaltung:</b> Neue Stellen werden standardmäßig im "
"<b>Entwurfsmodus</b> erstellt, um eine vorzeitige\n"
"                    Veröffentlichung oder Bewerbungen zu verhindern."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid "<b>Step-by-Step Recruitment Process</b>"
msgstr "<b>Schritt-für-Schritt-Einstellungsprozess</b>"

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
