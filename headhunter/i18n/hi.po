#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid "<b>See It In Action!</b>"
msgstr ""

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Shared Files:</b> Documents uploaded to the <b>Shared CV</b> field are "
"customer-facing. These are\n"
"                            the files sent via email to clients and "
"published on the Customer Portal."
msgstr ""

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Smart Syncing:</b> Most data is shared between the Talent profile and "
"their specific job applications.\n"
"                    For example, updating a candidate's <b>availability</b> "
"in the Talent Pool automatically updates it across\n"
"                    all their active applications."
msgstr ""

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Source</b> the perfect candidate from your existing talent pool or new "
"applicants."
msgstr ""

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid "<b>Status Indicators:</b>"
msgstr ""

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Status Management:</b> New positions are created in <b>Draft</b> mode by "
"default, preventing premature\n"
"                    publication or applications."
msgstr ""

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid "<b>Step-by-Step Recruitment Process</b>"
msgstr ""

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Submit an Entry:</b> Go to the website and apply for the <b>Open "
"Application</b> job."
msgstr ""

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Talent Pool:</b> Promoting an existing talent record using the \"Apply "
"Job\" button."
msgstr ""

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Talent Pools:</b> Maintain a database of qualified candidates ready for "
