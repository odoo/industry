msgstr ""

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>The Customer Portal:</b> Clients can log into their Odoo portal to view "
"their Sales Orders, Invoices, and\n"
"                    the <b>Applications</b> you have shared from the "
"previous report."
msgstr ""

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Website Integration:</b> Direct applications from your website’s job "
"board."
msgstr ""

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Website Integration:</b> Once a position is set to \"Open,\" ensure the "
"public listing is formatted\n"
"                    correctly for your website."
msgstr ""

