#. module: headhunter
#: model_terms:hr.job,website_description:headhunter.hr_job_6
msgid ""
"<strong style=\"font-weight: 600; color: var(--tw-prose-bold);\">Coding:</"
"strong> Collaborate with senior developers to write clean, maintainable, and "
"efficient code for software applications and features."
msgstr ""
"<strong style=\"font-weight: 600; color: var(--tw-prose-bold);\">Código:</"
"strong> Colaborar con desarrolladores más experimentados para escribir "
"código limpio, mantenible y eficiente para aplicaciones de software y sus "
"funciones."

#. module: headhunter
#: model_terms:hr.job,website_description:headhunter.hr_job_7
msgid ""
"<strong style=\"font-weight: 600; color: var(--tw-prose-bold);"
"\">Collaboration:</strong> Work closely with cross-functional teams, "
"including business analysts, engineers, and decision-makers, to understand "
"data\n"
"                            requirements and deliver actionable insights."
msgstr ""
"<strong style=\"font-weight: 600; color: var(--tw-prose-bold);"
"\">Colaboración:</strong> Trabajar en equipos multifuncionales compuestos "
"por consultores, ingenieros y personas responsables de la toma de decisiones "
"para entender los requisitos\n"
"                             de datos y ofrecer información útil."

#. module: headhunter
#: model_terms:hr.job,website_description:headhunter.hr_job_6
msgid ""
"<strong style=\"font-weight: 600; color: var(--tw-prose-bold);"
"\">Collaboration:</strong> Work closely with cross-functional teams, "
"including designers, product managers, and quality assurance, to ensure "
"project\n"
"                                        success."
msgstr ""
"<strong style=\"font-weight: 600; color: var(--tw-prose-bold);"
"\">Colaboración:</strong> Trabajar en equipos multifuncionales compuestos "
"por diseñadores, gerentes de producto y personas responsables del "
"aseguramiento de calidad para que los proyectos\n"
"                             sean exitosos."

#. module: headhunter
#: model_terms:hr.job,website_description:headhunter.hr_job_7
msgid ""
"<strong style=\"font-weight: 600; color: var(--tw-prose-bold);\">Data "
"Analysis:</strong> Utilize statistical analysis and data visualization "
"techniques to identify trends, patterns, and insights within datasets."
msgstr ""
"<strong style=\"font-weight: 600; color: var(--tw-prose-bold);\">Análisis de "
"datos:</strong> Utilizar técnicas de análisis estadístico y visualización de "
"datos para identificar tendencias, patrones e información dentro de los "
"conjuntos de datos."

#. module: headhunter
#: model_terms:hr.job,website_description:headhunter.hr_job_7
msgid ""
"<strong style=\"font-weight: 600; color: var(--tw-prose-bold);\">Data "
"Collection:</strong> Gather and organize data from various sources, ensuring "
"data accuracy and completeness."
msgstr ""
"<strong style=\"font-weight: 600; color: var(--tw-prose-bold);"
"\">Recopilación de datos:</strong> Recopilar y organizar datos de distintas "
"fuentes, además de garantizar su exactitud e integridad."

#. module: headhunter
#: model_terms:hr.job,website_description:headhunter.hr_job_7
msgid ""
"<strong style=\"font-weight: 600; color: var(--tw-prose-bold);\">Data "
"Quality Assurance:</strong> Develop and implement data quality checks and "
"processes to maintain data integrity."
msgstr ""
"<strong style=\"font-weight: 600; color: var(--tw-prose-bold);"
"\">Aseguramiento de la calidad de los datos:</strong> Desarrollar e "
"implementar controles y procesos de calidad de los datos para mantener su "
"integridad de los mismos."

#. module: headhunter
#: model_terms:hr.job,website_description:headhunter.hr_job_6
msgid ""
"<strong style=\"font-weight: 600; color: var(--tw-prose-bold);"
"\">Documentation:</strong> Create and maintain technical documentation, "
"including code comments and user guides."
msgstr ""
"<strong style=\"font-weight: 600; color: var(--tw-prose-bold);"
"\">Documentación:</strong> Crear y mantener documentación técnica, "
"incluyendo los comentarios en el código y las guías de usuario."

#. module: headhunter
#: model_terms:hr.job,website_description:headhunter.hr_job_6
#: model_terms:hr.job,website_description:headhunter.hr_job_7
