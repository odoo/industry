#. module: headhunter
#: model_terms:hr.job,website_description:headhunter.hr_job_4
msgid "12 days / year, including <br>6 of your choice."
msgstr "12 días al año,<br>con 6 de tu elección."

#. module: headhunter
#: model_terms:hr.job,job_details:headhunter.hr_job_10
