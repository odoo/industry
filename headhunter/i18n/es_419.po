#. module: headhunter
#: model_terms:hr.job,website_description:headhunter.hr_job_4
msgid ""
"<a href=\"/\" class=\"btn btn-primary o_translate_inline\" "
"target=\"_blank\"><small><b>READ</b></small></a>"
msgstr ""
"<a href=\"/\" class=\"btn btn-primary o_translate_inline\" "
"target=\"_blank\"><small><b>MÁS INFORMACIÓN</b></small></a>"

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid "<b>1. Creation &amp; Initial Contact</b>"
msgstr "<b>1. Creación y contacto inicial</b>"

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid "<b>2. Screening &amp; Data Enrichment</b>"
msgstr "<b>2. Evaluación y enriquecimiento de datos</b>"

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid "<b>3. Interview Scheduling</b>"
msgstr "<b>3. Programación de entrevistas</b>"

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">CRM</font>:</b> Streamlines daily "
"discussions with potential clients."
msgstr ""
"<b><font class=\"text-o-color-1\">CRM</font>:</b> Optimiza las "
"conversaciones diarias con tus clientes potenciales."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Recruitment App:</font></b> Tracks all "
"talent and their applications within a clear pipeline"
msgstr ""
"<b><font class=\"text-o-color-1\">Reclutamiento:</font></b> Lleva "
"seguimiento de todo el talento y sus postulaciones en un flujo claro"

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Sales &amp; Invoicing App</font>:</b> "
"Maintains a clear, automated record of all\n"
"                financial transactions."
msgstr ""
"<b><font class=\"text-o-color-1\">Ventas y Facturación</font>:</b> Mantiene "
"un registro claro y automatizado de todas\n"
"            las transacciones financieras."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Website App:</font></b> Drives visibility "
"about open positions"
msgstr ""
"<b><font class=\"text-o-color-1\">Sitio web:</font></b> Aumenta la "
"visibilidad de las vacantes abiertas"

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Activate:</b> After the quotation is signed, update the Job Position "
"status to <b>Open</b>."
msgstr ""
"<b>Activar:</b> Después de firmar la cotización, actualiza el estado del "
"puesto de trabajo a <b>Abierto</b>."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Activation:</b> Once the Sales Order is validated by the client, manually "
"update the status to\n"
"                    <b>\"Open\"</b> to begin active sourcing."
msgstr ""
"<b>Activación:</b> Una vez que el cliente valide la orden de venta, "
"actualiza el estado de forma manual a\n"
"                    <b>\"Abierto\"</b> para iniciar la búsqueda activa."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Add to Pool:</b> Select the application and click the <b>Add to Pool</b> "
"button."
msgstr ""
"<b>Agregar a la base de talentos:</b> Selecciona la postulación y haz clic "
"en el botón \"<b>Agregar a la base de talentos</b>\"."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Applicants:</b> Track active candidates through the recruitment pipeline "
"for each job position."
msgstr ""
"<b>Postulantes:</b> Lleva seguimiento de los candidatos activos a través del "
"flujo de reclutamiento para cada puesto de trabajo."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Automatic Tracking:</b> This action automatically creates a line for this "
"candidate into the\n"
"                    <b>\"Reporting / Cv sent Report.\"</b>"
msgstr ""
"<b>Seguimiento automático:</b> Esta acción crea una línea para este "
"candidato de forma automática en\n"
"                   <b>\"Reportes / Reporte de CV enviados\".</b>"

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Automation:</b> Each pipeline stage can be configured to send automated "
"emails to maintain consistent\n"
"                    communication with candidates."
msgstr ""
"<b>Automatización:</b> Puedes configurar cada etapa del proceso para enviar "
"correos automatizados y mantener una comunicación \n"
"                    constante con los candidatos."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Availability Tracking:</b> For every applicant, you can toggle their "
"status (Available/Unavailable) or\n"
"                    set a specific \"Available From\" date."
msgstr ""
"<b>Seguimiento de la disponibilidad:</b> Para cada postulante, puedes "
"cambiar su estado (Disponible/No disponible) o\n"
"                    definir una fecha específica en \"Disponible desde\"."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Bill:</b> Once the successful candidates are hired, proceed to "
"<b>invoice</b> the Sales Order."
msgstr ""
"<b>Facturar:</b> Una vez que contrates a los postulantes seleccionados, "
"continúa con la <b>facturación</b> de la orden de venta."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Configure</b> client details and grant portal access to the hiring team."
msgstr ""
"<b>Configura</b> los detalles del cliente y dale acceso al portal al equipo "
"de contratación."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Convert to Talent:</b> The candidate is now a \"Talent.\" From their "
"profile, you can now instantly apply\n"
"                    them to any other open positions."
msgstr ""
"<b>Convertir en talento:</b> El candidato ahora es \"Talento\". Desde su "
"perfil, puedes postularlo\n"
"                    al instante a cualquier otra vacante abierta."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid "<b>Create</b> a new job position"
msgstr "<b>Crea</b> un nuevo puesto de trabajo"

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Define Requirements:</b> Input essential details such as target profile, "
"salary range, and job description."
msgstr ""
"<b>Define los requisitos:</b> Ingresa detalles importantes como el perfil "
"objetivo, el rango salarial y la descripción del puesto."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid "<b>Define</b> key skills required for the job"
msgstr "<b>Define</b> las habilidades clave necesarias para el puesto"

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid "<b>Document Management:</b>"
msgstr "<b>Gestión de documentos:</b>"

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Done:</b> Fulfilled or inactive job position; these are hidden from the "
"website and automatically\n"
"                            filtered out of your main view."
msgstr ""
"<b>Hecho:</b> Puesto de trabajo cubierto o inactivo. Estos se ocultan del "
"sitio web y se excluyen\n"
"                            de tu vista principal de forma automática."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Draft Sales Order:</b> Once the details are finalized, generate a "
"<b>Quotation</b> from either\n"
"                            the Job Position or the Opportunity; both "
"methods will link the records correctly."
msgstr ""
"<b>Borrador de la orden de venta:</b> Cuando completes los detalles, crea "
"una <b>cotización</b> desde el\n"
"                            puesto o la oportunidad. Ambos métodos "
"vincularán los registros de forma correcta."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Draft:</b> Used for job position awaiting final client approval. You "
"cannot publish these or add\n"
"                            applicants yet."
msgstr ""
"<b>Borrador:</b> Se usa para puestos que están a la espera de la aprobación "
"final del cliente. Aún no puedes publicarlos\n"
"                            ni agregar postulantes."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>External Settings:</b> For client-based job positions, you can designate "
"the Customer and the\n"
"                    <b>Hiring Team Contact</b>. Members of the Hiring Team "
"Contact will receive emails whenever new CVs are\n"
"                    submitted."
msgstr ""
"<b>Ajustes externos:</b> Para puestos basados en clientes, puedes definir el "
"cliente y el\n"
"                <b>contacto del equipo de contratación</b>. Los miembros de "
"este contacto recibirán correos cada vez que haya\n"
"                nuevos CV."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Flexible Billing:</b> Customize payment terms within the Sales Order "
"based on the specific contract type."
msgstr ""
"<b>Facturación flexible:</b> Personaliza los términos de pago dentro de la "
"orden de venta según el tipo de contrato."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Generate Job:</b> From the Opportunity, select <b>Create New Job</b>."
msgstr ""
"<b>Generar puesto:</b> Desde la oportunidad, selecciona <b>Crear nuevo "
"puesto</b>."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid "<b>Go Live</b> by switching the status to \"Open.\""
msgstr "<b>Publica</b> al cambiar el estado a \"Abierto\"."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Independent Pipelines:</b> While core information is linked, each "
"application follows its own unique\n"
"                    recruitment journey, allowing you to track progress for "
"different roles simultaneously."
msgstr ""
"<b>Canales independientes:</b> Aunque la información principal está "
"vinculada, cada postulación sigue su propio\n"
"                    proceso de reclutamiento, lo que te permite seguir el "
"progreso de distintos puestos al mismo tiempo."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Initiate:</b> Open the CRM app and create a new <b>Opportunity</b> for "
"your client."
msgstr ""
"<b>Inicia:</b> Abre la aplicación CRM y crea una nueva <b>oportunidad</b> "
"para tu cliente."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Internal Files:</b> Documents attached to the <b>Chatter</b> are private "
"and for internal use\n"
"                            only."
msgstr ""
"<b>Archivos internos:</b> Los documentos adjuntos al <b>chatter</b> son "
"privados y solo para \n"
"                            uso interno."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Invoicing:</b> Once the Sales Order is signed, you can proceed to "
"generate the invoice according to the agreed-upon terms."
msgstr ""
"<b>Facturación:</b> Una vez la orden de venta esté firmada podrás generar la "
"factura según los términos acordados."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Job Positions:</b> Define your requirements, website listings, and "
"necessary skills."
msgstr ""
"<b>Puestos:</b> Define tus requisitos, anuncios en el sitio web y "
"habilidades necesarias."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid "<b>Key Configuration Rules</b>"
msgstr "<b>Reglas clave de configuración</b>"

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Locate the Candidate:</b> Find the new application within that Job "
"Position in the back-end."
msgstr ""
"<b>Ubica al postulante:</b> Busca la nueva postulación dentro de ese puesto "
"desde el backend."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid "<b>Login:</b> john.smith@fifth.example.com <b>Password:</b> john"
msgstr "<b>Usuario:</b> john.smith@fifth.ejemplo.com <b>Contraseña:</b> john"

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Manual Entry:</b> Creating a record directly within the specific Job "
"Position pipeline."
msgstr ""
"<b>Entrada manual:</b> Crea un registro directo en el flujo del puesto."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid "<b>Open:</b> Active roles that are ready for publication."
msgstr "<b>Abierto:</b> Puestos activos listos para publicar."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid "<b>Opportunity Creation → Quotation/Sales Order → Invoicing.</b>"
msgstr ""
"<b>Creación de oportunidad → Cotización/orden de venta → Facturación.</b>"

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid "<b>Publish</b> and customize the job description on the website"
msgstr "<b>Publica</b> y personaliza la descripción del puesto en el sitio web"

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Real-Time Synchronization:</b> This centralized view ensures that if you "
"update a candidate’s\n"
"                    availability (e.g., they are hired elsewhere), that "
"status updates instantly across all client portals where\n"
"                    that CV was shared."
msgstr ""
"<b>Sincronización en tiempo real:</b> Esta vista centralizada garantiza que, "
"si actualizas la disponibilidad de un\n"
"                    candidato (por ejemplo, si otra empresa lo contrata), "
"ese estado se actualice al instante en todos los portales de clientes\n"
"                    donde compartiste ese CV."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid "<b>Recruit:</b> Your recruitment team can now begin their search."
msgstr ""
"<b> Reclutar:</b> Tu equipo de reclutamiento ya puede iniciar su búsqueda."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Recruitment Type:</b> Distinguish between <b>Internal</b> (hiring for "
"your own firm) and\n"
"                    <b>External</b> (hiring on behalf of a client)."
msgstr ""
"<b>Tipo de reclutamiento:</b> Distingue entre <b>interno</b> (contratación "
"para tu propia empresa) y\n"
"                    <b>externo</b> (contratación en nombre de un cliente)."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Scheduling:</b> Ensure your Appointment app is synced to allow candidates "
"to book meetings based on your\n"
"                    real-time availability."
msgstr ""
"<b>Programación:</b> Asegúrate de sincronizar tu aplicación Citas para que "
"los postulantes puedan agendar sus reuniones según \n"
"                    tu disponibilidad en tiempo real."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Seamless Application: </b>When a Talent is moved to a job position, the "
"system creates a linked duplicate\n"
"                    for that specific role, ensuring organized record-"
"keeping."
msgstr ""
"<b>Postulación organizada:</b> Cuando mueves un talento a un puesto, el "
"sistema crea un duplicado vinculado\n"
"                    para ese puesto en específico y garantiza un registro "
"organizado."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid "<b>See It In Action!</b>"
msgstr "<b>¡Míralo en acción!</b>"

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Shared Files:</b> Documents uploaded to the <b>Shared CV</b> field are "
"customer-facing. These are\n"
"                            the files sent via email to clients and "
"published on the Customer Portal."
msgstr ""
"<b>Archivos compartidos:</b> Los documentos subidos al campo <b>CV "
"compartido</b> están destinados al cliente. Estos son\n"
"                            los archivos enviados por correo electrónico a "
"los clientes y publicados en el portal del cliente."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Smart Syncing:</b> Most data is shared between the Talent profile and "
"their specific job applications.\n"
"                    For example, updating a candidate's <b>availability</b> "
"in the Talent Pool automatically updates it across\n"
"                    all their active applications."
msgstr ""
"<b>Sincronización inteligente:</b> La mayoría de los datos se comparten "
"entre el perfil del talento y sus postulaciones a puestos específicos.\n"
"                Por ejemplo, si actualizas la <b>disponibilidad</b> de un "
"postulante en la base de talentos, ese cambio se refleja de forma "
"automática\n"
"                en todas sus postulaciones activas."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Source</b> the perfect candidate from your existing talent pool or new "
"applicants."
msgstr ""
"<b>Busca</b> al postulante ideal en tu base de talentos actual o entre "
"nuevos postulantes."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid "<b>Status Indicators:</b>"
msgstr "<b>Indicadores de estado:</b>"

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Status Management:</b> New positions are created in <b>Draft</b> mode by "
"default, preventing premature\n"
"                    publication or applications."
msgstr ""
"<b>Gestión del estado:</b> Los nuevos puestos se crean en modo de "
"<b>borrador</b> de forma predeterminada, lo que evita \n"
"                    publicaciones o postulaciones antes de tiempo."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid "<b>Step-by-Step Recruitment Process</b>"
msgstr "<b>Proceso de reclutamiento paso a paso</b>"

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Submit an Entry:</b> Go to the website and apply for the <b>Open "
"Application</b> job."
msgstr ""
"<b>Envía una solicitud:</b> Ve al sitio web y postúlate al puesto "
"<b>Postulación abierta</b>."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Talent Pool:</b> Promoting an existing talent record using the \"Apply "
"Job\" button."
msgstr ""
"<b>Base de talentos:</b> Promociona un registro de talento existente con el "
"botón \"Postular\"."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Talent Pools:</b> Maintain a database of qualified candidates ready for "
"future roles."
msgstr ""
"<b>Bases de talento:</b> Mantén una base de datos de postulantes calificados "
"listos para los próximos puestos."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>The Customer Portal:</b> Clients can log into their Odoo portal to view "
"their Sales Orders, Invoices, and\n"
"                    the <b>Applications</b> you have shared from the "
"previous report."
msgstr ""
"<b>El portal del cliente:</b> Los clientes pueden iniciar sesión en su "
"portal de Odoo para ver sus órdenes de venta, facturas\n"
"                    y las <b>postulaciones</b> que compartiste desde el "
"reporte anterior."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Website Integration:</b> Direct applications from your website’s job "
"board."
msgstr ""
"<b>Integración con el sitio web:</b> Postulaciones directas desde la bolsa "
"de trabajo de tu sitio web."

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
