#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Manual Entry:</b> Creating a record directly within the specific Job "
"Position pipeline."
msgstr ""

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid "<b>Open:</b> Active roles that are ready for publication."
msgstr ""

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid "<b>Opportunity Creation → Quotation/Sales Order → Invoicing.</b>"
msgstr ""

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid "<b>Publish</b> and customize the job description on the website"
msgstr ""

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Real-Time Synchronization:</b> This centralized view ensures that if you "
"update a candidate’s\n"
"                    availability (e.g., they are hired elsewhere), that "
"status updates instantly across all client portals where\n"
"                    that CV was shared."
msgstr ""

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid "<b>Recruit:</b> Your recruitment team can now begin their search."
msgstr ""

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Recruitment Type:</b> Distinguish between <b>Internal</b> (hiring for "
"your own firm) and\n"
"                    <b>External</b> (hiring on behalf of a client)."
msgstr ""

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
msgid ""
"<b>Scheduling:</b> Ensure your Appointment app is synced to allow candidates "
"to book meetings based on your\n"
"                    real-time availability."
msgstr ""

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.welcome_article_body
