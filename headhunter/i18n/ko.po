"<span style=\"font-size: 16px; font-style: normal; font-weight: 400;\" "
"class=\"bg-o-color-2 text-o-color-3\">당사의 재무 전문가가 최고의 재무 및 회"
"계 전문가를 찾을 수 있도록 도와드립니다.</span>\n"
"                                            <br/>"

#. module: headhunter
#: model_terms:ir.ui.view,arch_db:headhunter.homepage
msgid ""
"<span style=\"font-size: 16px; font-style: normal; font-weight: 400;\" "
"class=\"text-o-color-1 bg-o-color-1\">\n"
