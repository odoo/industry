<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <function model="sale.order" name="action_confirm">
        <value eval="[ref('sale_order_11'), ref('sale_order_12'), ref('sale_order_13')]"/>
    </function>

    <!-- Create invoice -->
    <record id="sale_advance_payment_inv_1" model="sale.advance.payment.inv">
        <field name="advance_payment_method" >delivered</field>
        <field name="sale_order_ids" eval="[Command.set([ref('sale_order_11')])]"/>
    </record>
    <function model="sale.advance.payment.inv" name="create_invoices"
            eval="[ref('sale_advance_payment_inv_1')]"/>

    <record id="sale_advance_payment_inv_2" model="sale.advance.payment.inv">
        <field name="advance_payment_method" >delivered</field>
        <field name="sale_order_ids" eval="[Command.set([ref('sale_order_12')])]"/>
    </record>
    <function model="sale.advance.payment.inv" name="create_invoices"
            eval="[ref('sale_advance_payment_inv_2')]"/>

    <record id="sale_advance_payment_inv_3" model="sale.advance.payment.inv">
        <field name="advance_payment_method" >delivered</field>
        <field name="sale_order_ids" eval="[Command.set([ref('sale_order_13')])]"/>
    </record>
    <function model="sale.advance.payment.inv" name="create_invoices"
            eval="[ref('sale_advance_payment_inv_3')]"/>    
            
    <!-- Confirm invoice -->
    <function model="account.move" name="action_post">
        <value model="account.move" eval="(
            obj().env.ref('headhunter.sale_order_11').invoice_ids
            | obj().env.ref('headhunter.sale_order_12').invoice_ids
            | obj().env.ref('headhunter.sale_order_13').invoice_ids
        ).ids"/>
    </function>
</odoo>
