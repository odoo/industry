<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <function name="button_immediate_uninstall" model="ir.module.module" eval="[(
        ref('base.module_crm_iap_enrich', raise_if_not_found=False),
        ref('base.module_crm_iap_mine', raise_if_not_found=False)
    )]"/>
    <record model="res.config.settings" id="res_config_settings">
        <field name="account_price_include">tax_included</field>
        <field name="module_partnership" eval="1"/>
        <field name="module_crm_iap_enrich" eval="0"/>
        <field name="module_crm_iap_mine" eval="0"/>
        <field name="group_discount_per_so_line" eval="1"/>
        <field name="group_product_pricelist" eval="1"/>
        <field name="module_loyalty" eval="1"/>
        <field name="module_event_sale" eval="1"/>
        <field name="module_pos_event" eval="1"/>
    </record>

    <function model="res.config.settings" name="execute" eval="[ref('res_config_settings')]"/>
</odoo>
