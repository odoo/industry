<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="new_decimal_purchase_x_tolerance" model="ir.model.fields">
        <field name="name">x_tolerance</field>
        <field name="model_id" ref="purchase.model_purchase_order_line"/>
        <field name="ttype">float</field>
        <field name="field_description">Tolerance</field>
    </record>

    <record id="new_decimal_stock_x_po_tolerance" model="ir.model.fields">
        <field name="name">x_po_tolerance</field>
        <field name="model_id" ref="stock.model_stock_move"/>
        <field name="ttype">float</field>
        <field name="field_description">PO Tolerance</field>
    </record>

    <record id="new_decimal_stock_x_allowed_quantity" model="ir.model.fields">
        <field name="name">x_allowed_quantity</field>
        <field name="model_id" ref="stock.model_stock_move"/>
        <field name="ttype">float</field>
        <field name="field_description">Allowed Quantity</field>
    </record>

    <record id="new_related_field_st_x_po_tolerance_1" model="ir.model.fields">
        <field name="name">x_po_tolerance_1</field>
        <field name="model_id" ref="stock.model_stock_move"/>
        <field name="ttype">float</field>
        <field name="field_description">Po Tolerance</field>
        <field name="related">purchase_line_id.x_tolerance</field>
    </record>

    <record id="new_text_transfer_x_vehicle_no" model="ir.model.fields">
        <field name="name">x_vehicle_no</field>
        <field name="model_id" ref="stock.model_stock_picking"/>
        <field name="ttype">char</field>
        <field name="field_description">Vehicle No</field>
    </record>
</odoo>
