    <record id="x_quality_check_worksheet_template_1_ir_ui_view_1" model="ir.ui.view">
        <field name="name">template_view_Coal_Quality_Analysis</field>
        <field name="model">x_quality_check_worksheet_template_1_studio</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form create="false" js_class="worksheet_validation">
                <sheet>
                    <h1 invisible="context.get('studio') or context.get('default_x_quality_check_id')">
                        <field name="x_quality_check_id" domain="[('test_type', '=', 'worksheet')]"/>
                    </h1>
                    <group>
                        <group>
                            <field name="x_comments" invisible="1"/>
                            <field name="x_test_type_1"/>
                            <field name="x_passed" invisible="1"/>
                            <field name="x_net_calorific_value" string="Net calorific value"/>
                            <field name="x_ash_content" string="Ash Content"/>
                            <field name="x_moisture_content" string="Moisture Content"/>
                        </group>
                        <group>
                            <field name="x_test_type" string="Total Moisture"/>
                            <field name="x_total_sulphur" string="Total Sulphur"/>
                            <field name="x_flying_substance" string="Flying Substance"/>
                            <field name="x_hardgrave_grindability_index" string="Hardgrave Grindability Index"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="odoo_studio_purchase_7c6ddd47-d639-4df3-9e8f-991e7fe65484" model="ir.ui.view">
        <field name="name">Odoo Studio: purchase.order.form customization</field>
        <field name="model">purchase.order</field>
        <field name="type">form</field>
        <field name="mode">extension</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="priority">160</field>
        <field name="arch" type="xml">
            <data>
                <xpath expr="//form[1]/sheet[1]/notebook[1]/page[@name='products']/field[@name='order_line']/tree[1]/button[@name='action_product_forecast_report']"
                       position="after">
                    <field optional="show" name="x_tolerance" string="Tolerance"/>
                </xpath>
            </data>
        </field>
    </record>

    <record id="odoo_studio_stock_pi_113560f5-7f1d-4502-9002-25d54cd5ddcd" model="ir.ui.view">
        <field name="name">Odoo Studio: stock.picking.form customization</field>
        <field name="model">stock.picking</field>
        <field name="type">form</field>
        <field name="mode">extension</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="priority">160</field>
        <field name="arch" type="xml">
            <data>
                <xpath expr="//field[@name='origin']" position="after">
                    <field name="x_vehicle_no" string="Vehicle No" required="picking_type_code != 'internal'"/>
                </xpath>
                <xpath expr="//form[1]/sheet[1]/notebook[1]/page[@name='operations']/field[@name='move_ids_without_package']/tree[1]/button[@name='action_product_forecast_report']"
                       position="after">
                    <field optional="show" name="x_po_tolerance_1" string="Po Tolerance"/>
                    <field optional="show" name="x_allowed_quantity" string="Allowed Quantity "/>
                </xpath>
            </data>
        </field>
    </record>

    <record id="x_quality_check_worksheet_template_2_ir_ui_view_1" model="ir.ui.view">
        <field name="name">template_view_Gas_Quality_Analysis</field>
        <field name="model">x_quality_check_worksheet_template_2_studio</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form create="false" js_class="worksheet_validation">
                <sheet>
                    <h1 invisible="context.get('studio') or context.get('default_x_quality_check_id')">
                        <field name="x_quality_check_id" domain="[('test_type', '=', 'worksheet')]"/>
                    </h1>
                    <group>
                        <group>
                            <field name="x_comments" invisible="1"/>
                            <field name="x_passed" invisible="1"/>
                            <field name="x_mon" string="AKI"/>
                            <field name="x_ron" string="RON"/>
                            <field name="x_aki"/>
                        </group>
                        <group>
                            <field name="x_aromatic_content" string="Aromatic content"/>
                            <field name="x_density" string="Density"/>
                            <field name="x_lead_content" string="Lead Content "/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="x_quality_check_worksheet_template_1_ir_ui_view_2" model="ir.ui.view">
        <field name="name">tree_view_Coal_Quality_Analysis</field>
        <field name="model">x_quality_check_worksheet_template_1_studio</field>
        <field name="type">tree</field>
        <field name="arch" type="xml">
            <tree>
                <field name="create_date" widget="date"/>
                <field name="x_name"/>
            </tree>
        </field>
    </record>

    <record id="x_quality_check_worksheet_template_1_ir_ui_view_3" model="ir.ui.view">
        <field name="name">search_view_Coal_Quality_Analysis</field>
        <field name="model">x_quality_check_worksheet_template_1_studio</field>
        <field name="type">search</field>
        <field name="arch" type="xml">
            <search>
                <field name="x_name"/>
                <filter string="Created on" date="create_date" name="create_date"/>
                <filter name="group_by_month" string="Created on" context="{'group_by': 'create_date:month'}"/>
            </search>
        </field>
    </record>

    <record id="x_quality_check_worksheet_template_2_ir_ui_view_2" model="ir.ui.view">
        <field name="name">tree_view_Gas_Quality_Analysis</field>
        <field name="model">x_quality_check_worksheet_template_2_studio</field>
        <field name="type">tree</field>
        <field name="arch" type="xml">
            <tree>
                <field name="create_date" widget="date"/>
                <field name="x_name"/>
            </tree>
        </field>
    </record>

    <record id="x_quality_check_worksheet_template_2_ir_ui_view_3" model="ir.ui.view">
        <field name="name">search_view_Gas_Quality_Analysis</field>
        <field name="model">x_quality_check_worksheet_template_2_studio</field>
        <field name="type">search</field>
        <field name="arch" type="xml">
            <search>
                <field name="x_name"/>
                <filter string="Created on" date="create_date" name="create_date"/>
                <filter name="group_by_month" string="Created on" context="{'group_by': 'create_date:month'}"/>
            </search>
        </field>
    </record>
</odoo>
