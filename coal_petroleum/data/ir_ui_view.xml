<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="report_custom_x_quality_check_worksheet_template_1" model="ir.ui.view">
        <field name="name">x_quality_check_worksheet_template_1_studio</field>
        <field name="type">qweb</field>
        <field name="key">gen_key.1d38a6</field>
        <field name="arch" type="xml">
            <t t-name="x_quality_check_worksheet_template_1">
                <div>
                    <div class="row" style="page-break-inside: avoid">
                        <div class="col-6" style="page-break-inside: avoid">
                            <div class="row mb-3" style="page-break-inside: avoid">
                                <div t-att-class="('col-5' if report_type == 'pdf' else 'col-lg-5 col-12') + ' font-weight-bold'">
                                    Ash Content</div>
                                <div string="Ash Content"
                                     t-att-class="'col-7' if report_type == 'pdf' else 'col-lg-7 col-12'"
                                     t-field="worksheet.x_ash_content"/>
                            </div>
                            <div class="row mb-3" style="page-break-inside: avoid">
                                <div t-att-class="('col-5' if report_type == 'pdf' else 'col-lg-5 col-12') + ' font-weight-bold'">
                                    Net calorific value</div>
                                <div string="Net calorific value"
                                     t-att-class="'col-7' if report_type == 'pdf' else 'col-lg-7 col-12'"
                                     t-field="worksheet.x_net_calorific_value"/>
                            </div>
                            <div class="row mb-3" style="page-break-inside: avoid">
                                <div t-att-class="('col-5' if report_type == 'pdf' else 'col-lg-5 col-12') + ' font-weight-bold'">
                                    Moisture Content</div>
                                <div string="Moisture Content"
                                     t-att-class="'col-7' if report_type == 'pdf' else 'col-lg-7 col-12'"
                                     t-field="worksheet.x_moisture_content"/>
                            </div>
                            <div class="row mb-3" style="page-break-inside: avoid">
                                <div t-att-class="('col-5' if report_type == 'pdf' else 'col-lg-5 col-12') + ' font-weight-bold'">
                                    Test Type</div>
                                <div t-att-class="'col-7' if report_type == 'pdf' else 'col-lg-7 col-12'"
                                     t-field="worksheet.x_test_type_1"/>
                            </div>
                        </div>
                        <div class="col-6" style="page-break-inside: avoid">
                            <div class="row mb-3" style="page-break-inside: avoid">
                                <div t-att-class="('col-5' if report_type == 'pdf' else 'col-lg-5 col-12') + ' font-weight-bold'">
                                    Total Moisture</div>
                                <div string="Total Moisture"
                                     t-att-class="'col-7' if report_type == 'pdf' else 'col-lg-7 col-12'"
                                     t-field="worksheet.x_test_type"/>
                            </div>
                            <div class="row mb-3" style="page-break-inside: avoid">
                                <div t-att-class="('col-5' if report_type == 'pdf' else 'col-lg-5 col-12') + ' font-weight-bold'">
                                    Total Sulphur</div>
                                <div string="Total Sulphur"
                                     t-att-class="'col-7' if report_type == 'pdf' else 'col-lg-7 col-12'"
                                     t-field="worksheet.x_total_sulphur"/>
                            </div>
                            <div class="row mb-3" style="page-break-inside: avoid">
                                <div t-att-class="('col-5' if report_type == 'pdf' else 'col-lg-5 col-12') + ' font-weight-bold'">
                                    Flying Substance</div>
                                <div string="Flying Substance"
                                     t-att-class="'col-7' if report_type == 'pdf' else 'col-lg-7 col-12'"
                                     t-field="worksheet.x_flying_substance"/>
                            </div>
                            <div class="row mb-3" style="page-break-inside: avoid">
                                <div t-att-class="('col-5' if report_type == 'pdf' else 'col-lg-5 col-12') + ' font-weight-bold'">
                                    Hardgrave Grindability Index</div>
                                <div string="Hardgrave Grindability Index"
                                     t-att-class="'col-7' if report_type == 'pdf' else 'col-lg-7 col-12'"
                                     t-field="worksheet.x_hardgrave_grindability_index"/>
                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </field>
    </record>

