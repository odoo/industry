#: model:mail.template,body_html:corporate_gifts.mail_template_43
msgid ""
"<p style=\"margin: 0px 0 16px 0; box-sizing: border-box;\">Hello,</p>\n"
"            <p style=\"margin: 0px 0 16px 0; box-sizing: border-box;\">\n"
"                Following your order with our company,<br/>\n"
"                can you send us your logo in vectorial format: .SVG or .PDF?\n"
"            </p>\n"
"            <p style=\"margin: 0px 0 16px 0; box-sizing: border-box;\">Thanks,</p>\n"
"        \n"
"        "
msgstr ""
"<p style=\"margin: 0px 0 16px 0; box-sizing: border-box;\">ສະບາຍດີ,</p>\n"
"            <p style=\"margin: 0px 0 16px 0; box-sizing: border-box;\">\n"
"                ອີງຕາມການສັ່ງຊື້ຂອງທ່ານກັບບໍລິສັດພວກເຮົາ,<br/>\n"
"                ທ່ານສາມາດສົ່ງໂລໂກ້ຂອງທ່ານໃນຮູບແບບ vectorial: .SVG ຫຼື .PDF ໃຫ້ພວກເຮົາໄດ້"
"ບໍ່?\n"
"            </p>\n"
"            <p style=\"margin: 0px 0 16px 0; box-sizing: border-box;\">ຂອບໃ"
"ຈ,</p>\n"
"        \n"
"        "

