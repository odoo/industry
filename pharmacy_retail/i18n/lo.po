#. module: pharmacy_retail
#: model_terms:ir.ui.view,arch_db:pharmacy_retail.welcome_article_body
msgid ""
"<font style=\"color: rgb(255, 156, 0);\"><strong>Company</strong></font>: two fields have been created in company form: \"<font class=\"text-o-color-1\">Drug License Numbe</font>r \" and \"\n"
"                <font class=\"text-o-color-1\">Drug License Date</font>\". They will be used for every outgoing document."
msgstr ""
"<font style=\"color: rgb(255, 156, 0);\"><strong>ບໍລິສັດ</strong></font>: ສອງຟິວໄ"
"ດ້ຖືກສ້າງຂຶ້ນໃນຟອມບໍລິສັດ: \"<font class=\"text-o-color-1\">ເລກໃບອະນຸຍາດຂາຍຢາ</font> "
"\" ແລະ \"\n"
"                <font class=\"text-o-color-1\">ວັນທີໃບອະນຸຍາດຂາຍຢາ</font>\". ພວກ"
"ມັນຈະຖືກນໍາໃຊ້ສໍາລັບທຸກໆເອກະສານຂາອອກ."

#. module: pharmacy_retail
#: model_terms:ir.ui.view,arch_db:pharmacy_retail.welcome_article_body
msgid ""
"<font style=\"color: rgb(255, 156, 0);\"><strong>Customer (B2B) / Vendor</strong></font> : \"<font class=\"text-o-color-1\">Drug License Number</font>\" and \"<font class=\"text-o-color-1\">Drug License Date</font>\" fields have been created\n"
"                in contact form. This will ensure that the necessary information is collected from Customers/Vendors."
msgstr ""
"<font style=\"color: rgb(255, 156, 0);\"><strong>ລູກຄ້າ (B2B) / ຜູ້ສະໜອງ</strong>"
"</font> : ຟິວ \"<font class=\"text-o-color-1\">ເລກໃບອະນຸຍາດຂາຍຢາ</font>\" ແລະ "
"\"<font class=\"text-o-color-1\">ວັນທີໃບອະນຸຍາດຂາຍຢາ</font>\" ໄດ້ຖືກສ້າງຂຶ້ນ\n"
"                ໃນຟອມຜູ້ຕິດຕໍ່. ນີ້ຈະເຮັດໃຫ້ໝັ້ນໃຈໄດ້ວ່າຂໍ້ມູນທີ່ຈໍາເປັນຖືກເກັບກໍາຈາກ ລູກຄ້າ/ຜູ້ສະໜອງ."

#. module: pharmacy_retail
#: model_terms:ir.ui.view,arch_db:pharmacy_retail.welcome_article_body
msgid ""
"<font style=\"color: rgb(255, 156, 0);\"><strong>Doctor</strong></font>: new menu has been created \"<font class=\"text-o-color-1\">Doctors</font>\" on <font class=\"text-o-color-1\">Contacts</font>. This model will\n"
"                include a \"<font class=\"text-o-color-1\">Registration Number</font>\", which is specific to doctors. This will help you keep track of doctor-related information in your system."
msgstr ""
"<font style=\"color: rgb(255, 156, 0);\"><strong>ທ່ານໝໍ</strong></font>: ເມນູໃໝ່ໄ"
"ດ້ຖືກສ້າງຂຶ້ນ \"<font class=\"text-o-color-1\">ທ່ານໝໍ</font>\" ໃນ <font "
"class=\"text-o-color-1\">ຜູ້ຕິດຕໍ່</font>. ໂມເດວນີ້ຈະ\n"
"                ລວມມີ \"<font class=\"text-o-color-1\">ເລກທະບຽນ</font>\", ເຊິ່ງເ"
"ປັນຂໍ້ມູນສະເພາະຂອງໝໍ. ນີ້ຈະຊ່ວຍໃຫ້ທ່ານຕິດຕາມຂໍ້ມູນທີ່ກ່ຽວຂ້ອງກັບທ່ານໝໍໃນລະບົບຂອງທ່ານ."

#. module: pharmacy_retail
#: model_terms:ir.ui.view,arch_db:pharmacy_retail.welcome_article_body
msgid ""
"<font style=\"color: rgb(255, 156, 0);\"><strong>Manufacturer Name </strong>(OEM)</font>: new menu has been created \"<font class=\"text-o-color-1\">Manufacturers</font>\" on <font class=\"text-o-color-1\">Contacts</font> to\n"
"                <font>handle Manufacturer specific information.</font>"
msgstr ""
"<font style=\"color: rgb(255, 156, 0);\"><strong>ຊື່ຜູ້ຜະລິດ </strong>(OEM)</font>"
": ເມນູໃໝ່ໄດ້ຖືກສ້າງຂຶ້ນ \"<font class=\"text-o-color-1\">ຜູ້ຜະລິດ</font>\" ໃນ <font "
"class=\"text-o-color-1\">ຜູ້ຕິດຕໍ່</font> ເພື່ອ\n"
"                <font>ຈັດການຂໍ້ມູນສະເພາະຂອງຜູ້ຜະລິດ.</font>"

#. module: pharmacy_retail
#: model_terms:ir.ui.view,arch_db:pharmacy_retail.welcome_article_body
msgid ""
"<font style=\"color: rgb(255, 156, 0);\"><strong>Medical Type, and Therapeutic Classification</strong></font>: Medical Type and Therapeutic Classification will be managed via Product Attribute. This will provide a way to categorize\n"
"                and classify pharmaceutical products."
msgstr ""
"<font style=\"color: rgb(255, 156, 0);\"><strong>ປະເພດທາງການແພດ, ແລະ ການຈັດປະເ"
"ພດການປິ່ນປົວ</strong></font>: ປະເພດທາງການແພດ ແລະ ການຈັດປະເພດການປິ່ນປົວ ຈະຖືກຈັດການຜ່ານ "
"ຄຸນລັກສະນະສິນຄ້າ. ນີ້ຈະເປັນວິທີໃນການແບ່ງໝວດໝູ່\n"
"                ແລະ ຈັດປະເພດຜະລິດຕະພັນຢາ."

#. module: pharmacy_retail
#: model_terms:ir.ui.view,arch_db:pharmacy_retail.welcome_article_body
msgid ""
"<font style=\"color: rgb(255, 156, 0);\"><strong>Product "
"Tags</strong></font>: Generic Names (ingredient) will be managed via Tags. "
"This will allow easier categorization and searching."
msgstr ""
"<font style=\"color: rgb(255, 156, 0);\"><strong>ແທັກສິນຄ້າ</strong></font>: ຊື່ສາ"
"ມັນ (ສ່ວນປະກອບ) ຈະຖືກຈັດການຜ່ານ ແທັກ. ນີ້ຈະຊ່ວຍໃຫ້ການແບ່ງໝວດໝູ່ ແລະ ການຄົ້ນຫາເຮັດໄດ້ງ່າຍຂຶ້ນ."

