#. module: pharmacy_retail
#: model_terms:ir.ui.view,arch_db:pharmacy_retail.welcome_article_body
msgid ""
"<font style=\"color: rgb(255, 156, 0);\"><strong>Company</strong></font>: "
"two fields have been created in company form: \"<font class=\"text-o-"
"color-1\">Drug License Numbe</font>r \" and \"\n"
"                <font class=\"text-o-color-1\">Drug License Date</font>\". "
"They will be used for every outgoing document."
msgstr ""
"<font style=\"color: rgb(255, 156, 0);\"><strong>Virksomhed</strong></font>: "
"Der er oprettet to felter i virksomhedsformularen: \"<font class=\"text-o-"
"color-1\">Lægemiddelregistreringsnummer</font>\" og \"\n"
"               <font class=\"text-o-color-1\"> Dato for lægemidlets "
"godkendelse</font>\". De vil blive brugt til alle udgående dokumenter."

#. module: pharmacy_retail
#: model_terms:ir.ui.view,arch_db:pharmacy_retail.welcome_article_body
msgid ""
"<font style=\"color: rgb(255, 156, 0);\"><strong>Customer (B2B) / Vendor</"
"strong></font> : \"<font class=\"text-o-color-1\">Drug License Number</"
"font>\" and \"<font class=\"text-o-color-1\">Drug License Date</font>\" "
"fields have been created\n"
"                in contact form. This will ensure that the necessary "
"information is collected from Customers/Vendors."
msgstr ""
"<font style=\"color: rgb(255, 156, 0);\"><strong>Kunde (B2B)/leverandør</"
"strong></font>: \"<font class=\"text-o-color-1\">"
"Lægemiddelregistreringsnummer</font>\" og \"<font class=\"text-o-color-1\">"
"Dato for lægemidlets godkendelse</font>\" felter er blevet oprettet\n"
"                i kontaktformularen. Dette vil sikre, at de nødvendige "
"oplysninger indsamles fra kunder/leverandører."

#. module: pharmacy_retail
#: model_terms:ir.ui.view,arch_db:pharmacy_retail.welcome_article_body
msgid ""
"<font style=\"color: rgb(255, 156, 0);\"><strong>Doctor</strong></font>: new "
"menu has been created \"<font class=\"text-o-color-1\">Doctors</font>\" on "
"<font class=\"text-o-color-1\">Contacts</font>. This model will\n"
"                include a \"<font class=\"text-o-color-1\">Registration "
"Number</font>\", which is specific to doctors. This will help you keep track "
"of doctor-related information in your system."
msgstr ""
"<font style=\"color: rgb(255, 156, 0);\"><strong>Læge</strong></font>: Der "
"er oprettet et nyt menu \"<font class=\"text-o-color-1\">Læger</font>\" på "
"<font class=\"text-o-color-1\">Kontakter</font>. Denne model vil\n"
"                indeholde et \"<font class=\"text-o-color-1\">"
"Registreringsnummer</font>\", som er specifikt for læger. Dette vil hjælpe "
"dig med at holde styr på lægerelaterede oplysninger i dit system."

#. module: pharmacy_retail
#: model_terms:ir.ui.view,arch_db:pharmacy_retail.welcome_article_body
msgid ""
"<font style=\"color: rgb(255, 156, 0);\"><strong>Manufacturer Name </"
"strong>(OEM)</font>: new menu has been created \"<font class=\"text-o-"
"color-1\">Manufacturers</font>\" on <font class=\"text-o-color-1\">Contacts</"
"font> to\n"
"                <font>handle Manufacturer specific information.</font>"
msgstr ""
"<font style=\"color: rgb(255, 156, 0);\"><strong>Producentnavn </strong>(OEM)"
"</font>: Der er oprettet en ny menu \"<font class=\"text-o-color-1\">"
"Producenter</font>\" på <font class=\"text-o-color-1\">Kontakter</font> til\n"
"               <font> håndterer producent-specifikke oplysninger.</font>"

#. module: pharmacy_retail
#: model_terms:ir.ui.view,arch_db:pharmacy_retail.welcome_article_body
msgid ""
"<font style=\"color: rgb(255, 156, 0);\"><strong>Medical Type, and "
"Therapeutic Classification</strong></font>: Medical Type and Therapeutic "
"Classification will be managed via Product Attribute. This will provide a "
"way to categorize\n"
"                and classify pharmaceutical products."
msgstr ""
"<font style=\"color: rgb(255, 156, 0);\"><strong>Medicinsk type og "
"terapeutisk klassificering</strong></font>: Medicinsk type og terapeutisk "
"klassificering vil blive administreret via produktattribut. Dette vil give "
"mulighed for at kategorisere\n"
"                og klassificere farmaceutiske produkter."

#. module: pharmacy_retail
#: model_terms:ir.ui.view,arch_db:pharmacy_retail.welcome_article_body
msgid ""
"<font style=\"color: rgb(255, 156, 0);\"><strong>Product Tags</strong></"
"font>: Generic Names (ingredient) will be managed via Tags. This will allow "
"easier categorization and searching."
msgstr ""
"<font style=\"color: rgb(255, 156, 0);\"><strong>Produkt-tags</strong></font>"
": Generiske navne (ingredienser) administreres via mærker. Dette vil gøre "
"kategorisering og søgning nemmere."

