"System already has a Promotion program with the name \"<font class=\"text-o-"
"color-1\">Buy 2 Get 1</font>\".<br/>\n"
"                <br/>"
msgstr ""
"Systemet har allerede et kampagneprogram med navnet \"<font class=\"text-o-"
"color-1\">Køb 2, få 1 gratis</font>\".<br/>\n"
"                <br/>"

#. module: pharmacy_retail
#: model_terms:ir.ui.view,arch_db:pharmacy_retail.welcome_article_body
