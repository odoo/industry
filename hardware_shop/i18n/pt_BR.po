#. module: hardware_shop
#: model_terms:ir.ui.view,arch_db:hardware_shop.welcome_article_body
msgid "Use Case"
msgstr "Caso de uso"

#. module: hardware_shop
#: model_terms:ir.ui.view,arch_db:hardware_shop.welcome_article_body
msgid ""
"Use the <strong><span style=\"color: #875A7B;\">Barcode App</span></strong> "
"to scan your products and create new entries directly from this App to "
"encode new products faster than ever."
msgstr ""
"Use o <strong><span style=\"color: #875A7B;\">app Código de Barras</span></"
"strong> para digitalizar seus produtos e criar novas entradas direto no "
"aplicativo para codificar novos produtos mais rápido do que nunca."

#. module: hardware_shop
#: model_terms:ir.ui.view,arch_db:hardware_shop.welcome_article_body
msgid ""
"Use the <strong><span style=\"color: #875A7B;\">Inventory App</span></"
"strong> to manage your orders receive and deliver your products."
msgstr ""
"Use o <strong><span style=\"color: #875A7B;\">app Inventário</span></strong> "
"para gerenciar seus pedidos, receber e entregar seus produtos."

#. module: hardware_shop
#: model_terms:ir.ui.view,arch_db:hardware_shop.welcome_article_body
msgid ""
"Use the <strong><span style=\"color: #875A7B;\">Point of Sale</span></"
"strong> for your sales at the desk. You can directly order new products for "
"your customers and manage their accounts and advantages. You will also have "
"the possibility to sale in your shop and choose to ship later the order."
msgstr ""
"Use o <strong><span style=\"color: #875A7B;\">Ponto de Vendas</span></"
"strong> para suas vendas no escritório. É possível encomendar novos produtos "
"para seus clientes e gerenciar suas contas e vantagens. Você também terá a "
"possibilidade de vender em sua loja e optar por enviar o pedido "
"posteriormente."

#. module: hardware_shop
