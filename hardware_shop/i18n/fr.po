#. module: hardware_shop
#: model_terms:ir.ui.view,arch_db:hardware_shop.welcome_article_body
msgid "Use Case"
msgstr "Cas d'utilisation"

#. module: hardware_shop
#: model_terms:ir.ui.view,arch_db:hardware_shop.welcome_article_body
msgid ""
"Use the <strong><span style=\"color: #875A7B;\">Barcode App</span></strong> "
"to scan your products and create new entries directly from this App to "
"encode new products faster than ever."
msgstr ""
"Utilisez l'application <strong><span style=\"color: #875A7B;\">Code-barres</"
"span></strong> pour scanner vos produits et créer de nouvelles entrées "
"directement depuis l'application. Encodez de nouveaux produits plus "
"rapidement que jamais."

#. module: hardware_shop
#: model_terms:ir.ui.view,arch_db:hardware_shop.welcome_article_body
msgid ""
"Use the <strong><span style=\"color: #875A7B;\">Inventory App</span></"
"strong> to manage your orders receive and deliver your products."
msgstr ""
"Utilisez l'application <strong><span style=\"color: #875A7B;\">Inventaire</"
"span></strong> pour gérer vos commandes, recevoir et livrer vos produits."

#. module: hardware_shop
#: model_terms:ir.ui.view,arch_db:hardware_shop.welcome_article_body
msgid ""
"Use the <strong><span style=\"color: #875A7B;\">Point of Sale</span></"
"strong> for your sales at the desk. You can directly order new products for "
"your customers and manage their accounts and advantages. You will also have "
"the possibility to sale in your shop and choose to ship later the order."
msgstr ""
"Utilisez le <strong><span style=\"color: #875A7B;\">Point de Vente</span></"
"strong> pour vos ventes au comptoir. Vous pouvez directement commander de "
"nouveaux produits pour vos clients et gérer leurs comptes et avantages. Vous "
"avez également la possibilité d'effectuer des ventes dans votre boutique et "
"d'expédier la commande ultérieurement."

#. module: hardware_shop
#: model_terms:ir.ui.view,arch_db:hardware_shop.welcome_article_body
