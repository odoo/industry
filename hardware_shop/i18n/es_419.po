#. module: hardware_shop
#: model_terms:ir.ui.view,arch_db:hardware_shop.welcome_article_body
msgid ""
"Use the <strong><span style=\"color: #875A7B;\">Barcode App</span></strong> "
"to scan your products and create new entries directly from this App to "
"encode new products faster than ever."
msgstr ""
"Usa <strong><span style=\"color: #875A7B;\">Código de barras</span></strong> "
"para escanear tus productos y crear nuevas entradas desde esta aplicación. "
"Agrega los productos más rápido que nunca."

#. module: hardware_shop
#: model_terms:ir.ui.view,arch_db:hardware_shop.welcome_article_body
msgid ""
"Use the <strong><span style=\"color: #875A7B;\">Inventory App</span></"
"strong> to manage your orders receive and deliver your products."
msgstr ""
"Usa <strong><span style=\"color: #875A7B;\">Inventario</span></strong> para "
"gestionar tus órdenes y para recibir y enviar tus productos."

#. module: hardware_shop
