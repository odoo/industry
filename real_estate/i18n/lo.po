#. module: real_estate
#: model_terms:ir.ui.view,arch_db:real_estate.welcome_article_body
msgid ""
"<strong><b>Appointments App</b>:</strong> Allow clients to book property "
"visits and consultations directly with agents, synchronizing calendars "
"automatically.<br/>"
msgstr ""
"<strong><b>ແອັບການນັດໝາຍ</b>:</strong> ອະນຸຍາດໃຫ້ລູກຄ້າຈອງການເຂົ້າຊົມຊັບສິນ ແລະ "
"ປຶກສາກັບຕົວແທນໂດຍກົງ, ພ້ອມທັງຊິງຄ໌ປະຕິທິນໂດຍອັດຕະໂນມັດ.<br/>"

#. module: real_estate
#: model_terms:ir.ui.view,arch_db:real_estate.welcome_article_body
msgid ""
"<strong><b>Properties App</b>:</strong> Organize your portfolio with a "
"dedicated app to manage property listings, details, and availability status."
"<br/>"
msgstr ""
"<strong><b>ແອັບອະສັງຫາລິມະຊັບ</b>:</strong> "
"ຈັດລະບຽບລາຍການຊັບສິນຂອງທ່ານດ້ວຍແອັບສະເພາະເພື່ອຈັດການລາຍການ, ລາຍລະອຽດ ແລະ ສະຖານະການວ່າງ."
"<br/>"

#. module: real_estate
#: model_terms:ir.ui.view,arch_db:real_estate.welcome_article_body
msgid ""
"<strong><b>Sales App</b>:</strong> Handle offers, negotiations, and closing "
"deals with professional quotations and digital signatures.<br/>"
msgstr ""
"<strong><b>ແອັບການຂາຍ</b>:</strong> ຈັດການຂໍ້ສະເໜີ, ການເຈລະຈາ ແລະ "
"ການປິດການຂາຍດ້ວຍໃບສະເໜີລາຄາທີ່ເປັນມືອາຊີບ ແລະ ການເຊັນຊື່ດິຈິຕອນ.<br/>"

#. module: real_estate
#: model_terms:ir.ui.view,arch_db:real_estate.welcome_article_body
msgid "<strong><span class=\"h2-fs\">Tips for Success</span></strong>"
msgstr "<strong><span class=\"h2-fs\">ເຄັດລັບສູ່ຄວາມສຳເລັດ</span></strong>"

#. module: real_estate
#: model_terms:ir.ui.view,arch_db:real_estate.welcome_article_body
msgid ""
"<strong>Automate your alerts:</strong> Matchmaking turns passive leads into "
"active buyers"
msgstr ""
"<strong>ຕັ້ງການແຈ້ງເຕືອນອັດຕະໂນມັດ:</strong> ການຈັບຄູ່ຈະປ່ຽນຜູ້ທີ່ສົນໃຈທົ່ວໄປໃຫ້ກາຍເປັນຜູ້ຊື້ຕົວຈິງ"

#. module: real_estate
#: model_terms:ir.ui.view,arch_db:real_estate.welcome_article_body
msgid ""
"<strong>Centralize documents:</strong> Use the Documents or Sign apps for "
"contracts and plans"
msgstr ""
"<strong>ລວມເອກະສານໄວ້ບ່ອນດຽວ:</strong> ໃຊ້ແອັບເອກະສານ ຫຼື ການເຊັນຊື່ ເພື່ອຈັດການສັນຍາ ແລະ "
"ແຜນຜັງຕ່າງໆ"

#. module: real_estate
#: model_terms:ir.ui.view,arch_db:real_estate.welcome_article_body
msgid ""
"<strong>Commissions are managed in</strong> <em>Sales &gt; Commissions</em>. "
"You can add a commission plan and compute commissions for both the "
"<strong>Salesperson</strong> (the person who closed the deal) and the\n"
"                    <strong>Seller</strong> of the property."
msgstr ""
"<strong>ຄ່ານາຍໜ້າແມ່ນຈັດການຢູ່ທີ່</strong> <em>ການຂາຍ &gt; ຄ່ານາຍໜ້າ</em>. "
"ທ່ານສາມາດເພີ່ມແຜນຄ່ານາຍໜ້າ ແລະ ຄຳນວນຄ່ານາຍໜ້າໃຫ້ທັງ <strong>ພະນັກງານຂາຍ</strong> "
"(ຜູ້ທີ່ປິດການຂາຍ) ແລະ <strong>ຜູ້ຂາຍ</strong> ຊັບສິນ."

#. module: real_estate
#: model_terms:ir.ui.view,arch_db:real_estate.homepage
msgid "<strong>Delivered to you!</strong>"
msgstr "<strong>ສົ່ງຕົງເຖິງທ່ານ!</strong>"

#. module: real_estate
#: model_terms:ir.ui.view,arch_db:real_estate.welcome_article_body
msgid ""
"<strong>Encourage online bookings:</strong> Let clients book visits on their "
"own time"
msgstr ""
"<strong>ສົ່ງເສີມການຈອງອອນລາຍ:</strong> ໃຫ້ລູກຄ້າຈອງການເຂົ້າຊົມໃນເວລາທີ່ເຂົາເຈົ້າສະດວກ"

#. module: real_estate
#: model_terms:ir.ui.view,arch_db:real_estate.welcome_article_body
