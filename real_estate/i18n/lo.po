#. module: real_estate
#: model_terms:ir.ui.view,arch_db:real_estate.homepage
msgid "24/7 Property Search Assistance"
msgstr "ການຊ່ວຍເຫຼືອຄົ້ນຫາອະສັງຫາລິມະຊັບ 24/7"

#. module: real_estate
#: model_terms:ir.ui.view,arch_db:real_estate.welcome_article_body
msgid ""
"<b>CRM App</b>: Manage your leads efficiently, tracking ongoing buying and "
"selling opportunities in a visual pipeline."
msgstr ""
"<b>ແອັບ CRM</b>: ຈັດການຜູ້ທີ່ສົນໃຈຂອງທ່ານຢ່າງມີປະສິດທິພາບ, ຕິດຕາມໂອກາດການຊື້ ແລະ "
"ການຂາຍທີ່ກຳລັງດຳເນີນຢູ່ພາຍໃນຂັ້ນຕອນການຂາຍທີ່ເບິ່ງເຫັນໄດ້ງ່າຍ."

#. module: real_estate
#: model_terms:ir.ui.view,arch_db:real_estate.ir_ui_view_3154
msgid "<b>Designed</b> for companies"
msgstr "<b>ອອກແບບ</b> ເພື່ອບໍລິສັດ"

#. module: real_estate
#: model_terms:ir.ui.view,arch_db:real_estate.ir_ui_view_3154
msgid ""
"<b>My Company</b><br/>250 Executive Park Blvd, Suite 3400 <br/> San "
"Francisco CA 94134 <br/>United States"
msgstr ""
"<b>ບໍລິສັດຂອງຂ້ອຍ</b><br/>250 Executive Park Blvd, Suite 3400 <br/> San "
"Francisco CA 94134 <br/>United States"

#. module: real_estate
#: model_terms:ir.ui.view,arch_db:real_estate.welcome_article_body
msgid ""
"<b>Website App</b>: Drive qualified traffic by promoting your listings on a "
"beautiful, mobile-responsive real estate portal."
msgstr ""
"<b>ແອັບເວັບໄຊ</b>: ເພີ່ມຈຳນວນຜູ້ເຂົ້າຊົມທີ່ມີຄຸນນະພາບ "
"ດ້ວຍການໂປຣໂມດລາຍການຊັບສິນຂອງທ່ານໃນເວັບໄຊອະສັງຫາລິມະຊັບທີ່ສວຍງາມ ແລະ "
"ຮອງຮັບການສະແດງຜົນເທິງມືຖື."

