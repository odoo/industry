<?xml version='1.0' encoding='UTF-8'?>
<odoo>
  <record id="contacts.action_contacts" model="ir.actions.act_window" forcecreate="1">
    <field name="name">Contacts</field>
    <field name="res_model">res.partner</field>
    <field name="context">{'default_is_company': True}</field>
    <field name="domain">[("x_studio_technical_partner", "!=", True)]</field>
    <field name="help"><![CDATA[<p class="o_view_nocontent_smiling_face">
            Create a Contact in your address book
          </p><p>
            Odoo helps you track all activities related to your contacts.
          </p>
        ]]></field>
    <field name="search_view_id" ref="base.view_res_partner_filter"/>
    <field name="view_mode">kanban,list,form,activity</field>
  </record>
  <record id="owners_90091a6a-8637-4e51-9c6e-1a3a3295f012" model="ir.actions.act_window">
    <field name="name">Owners</field>
    <field name="res_model">crm.lead</field>
    <field name="domain">[("team_id.x_studio_is_sellers_team", "=", True)]</field>
    <field name="help"><![CDATA[<p class="o_view_nocontent_smiling_face">
                    This is your new action.
                </p>
                <p>By default, it contains a list and a form view and possibly
                    other view types depending on the options you chose for your model.
                </p>
                <p>
                    You can start customizing these screens by clicking on the Studio icon on the
                    top right corner (you can also customize this help message there).
                </p>
            ]]></field>
    <field name="view_mode">kanban,list,form,calendar,map,pivot,graph,activity,cohort</field>
  </record>
  <record id="sale.product_template_action" model="ir.actions.act_window" forcecreate="1">
    <field name="name">Products</field>
    <field name="context">{"search_default_filter_to_sell":1, "sale_multi_pricelist_product_template": 1}</field>
    <field name="domain">["&amp;", ("sale_ok", "=", True), ("x_studio_is_properties", "=", False)]</field>
    <field name="help"><![CDATA[<p class="o_view_nocontent_smiling_face">
                Create a new product
            </p><p>
                You must define a product for everything you sell or purchase,
                whether it's a storable product, a consumable or a service.
            </p>
        ]]></field>
    <field name="res_model">product.template</field>
    <field name="search_view_id" ref="product.product_template_search_view"/>
  </record>
