<?xml version='1.0' encoding='UTF-8'?>
<odoo noupdate="1">
    <record id="book_your_visit_mail_template" model="mail.template">
        <field name="name">Industry: Book your visit</field>
        <field name="model_id" ref="crm.model_crm_lead"/>
        <field name="subject">Book your visit to {{ object.x_interested_in_id.name }}</field>
        <field name="body_html"><![CDATA[
        <div>
          <h1 style="font-size: 28px; color: #111827; font-family: 'Trebuchet MS', sans-serif;">Book your visit!</h1>
          <div style="font-family: 'Trebuchet MS', sans-serif;">
            Feel free to book a visit in our calendar. If you need a specific time, let us know!
          </div>
          <br/>
      
          <t t-foreach="object.x_interested_in_id" t-as="line">
            <t t-set="appointment" t-value="env['appointment.type'].search([('x_property_id', '=', line.id)], limit=1)"/>
            <table width="100%" style="border-collapse: collapse; margin-bottom: 16px;">
              <tr>
                <td style="padding: 10px; border: 1px solid #ccc;">
                  <img t-attf-src="/web/image/product.template/{{ line.id }}/image_512"
                       alt="Property Image"
                       style="max-width: 100%; height: auto; object-fit: cover; margin-bottom: 10px;" />
                  <div style="font-family: 'Trebuchet MS', sans-serif; font-weight: bold; font-size: 18px;">
                    <t t-out="line.name or 'Your dream house'"/>
                  </div>
                  <br/>
                  <t t-if="appointment.short_code">
                    <a t-att-href="'/book/%s' % appointment.short_code"
                       class="btn btn-fill-primary"
                       style="color: #ffffff; background-color: #714b67; padding: 8px 16px; border-radius: 4px; text-decoration: none; font-family: 'Trebuchet MS', sans-serif;">
                      Book your visit
                    </a>
                  </t>
                </td>
              </tr>
            </table>
          </t>
      
          <p style="font-family: 'Trebuchet MS', sans-serif; font-weight: bold;">
            We look forward to visiting this property together.<br/>
            Your Real Estate Company's Team
          </p>
        </div>
        ]]></field>
    </record>      
