  <record id="new_many2many_contac_d385b9fd-40b5-4889-ae1a-9148d3f19eb1" model="ir.model.fields">
    <field name="compute"><![CDATA[properties = self.env['product.template'].search([])
for record in self:
    matching_properties = []
    if record.x_categories or record.x_region or record.x_type or record.x_condition or record.x_min_price != 0 or record.x_max_price != 0: # At least 1 criteria
        for property in properties:
            if property.categ_id.x_is_properties_category and not property.website_ribbon_id.x_is_closed_ribbon : # Properties only && Not closed ribbons only
                matching_property = True
                # Categories
                if record.x_categories:
                    matched = False
                    for interest in record.x_categories:
                        if interest in property.public_categ_ids: matched = True
                    if not matched: matching_property = False
                # Region
                if record.x_region:
                    matched = False
                    for interest in record.x_region:
                        for attribute_line in property.attribute_line_ids:
                            if interest in attribute_line.value_ids: matched = True
                    if not matched: matching_property = False
                # Construction type
                if record.x_type:
                    matched = False
                    for interest in record.x_type:
                        for attribute_line in property.attribute_line_ids:
                            if interest in attribute_line.value_ids: matched = True
                    if not matched: matching_property = False
                # Condition
                if record.x_condition:
                    matched = False
                    for interest in record.x_condition:
                        for attribute_line in property.attribute_line_ids:
                            if interest in attribute_line.value_ids: matched = True
                    if not matched: matching_property = False
                # Price
                if record.x_min_price != 0 or record.x_max_price != 0:
                    matched = True
                    if record.x_min_price != 0 and record.x_min_price > property.list_price: matched = False
                    if record.x_max_price != 0 and property.list_price > record.x_max_price: matched = False
                    if not matched: matching_property = False
                # Outcome
                if matching_property: matching_properties.append(property.id)
    record['x_properties_from_contacts'] = matching_properties]]></field>
    <field name="ttype">many2many</field>
    <field name="depends">x_categories, x_region, x_type, x_condition, x_min_price, x_max_price</field>
    <field name="field_description">Properties from Contacts</field>
    <field name="model_id" ref="base.model_res_partner"/>
    <field name="name">x_properties_from_contacts</field>
    <field name="readonly" eval="True"/>
    <field name="relation">product.template</field>
    <field name="selectable" eval="False"/>
    <field name="store" eval="False"/>
  </record>
