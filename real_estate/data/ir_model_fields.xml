  <record id="new_many2many_contac_0ee2f752-5f50-439b-8429-dffd44e1da8e" model="ir.model.fields">
    <field name="compute"><![CDATA[for record in self:
    notification_properties = []
    for property in record.x_property_matches_contacts:
        if property.x_last_notification_update != False:
            if record.x_last_notification == False: notification_properties.append(property.id)
            else: 
                if record.x_last_notification < property.x_last_notification_update: notification_properties.append(property.id)
        else:
            notification_properties.append(property.id)
    record['x_to_notify_properties'] = [(6, 0, notification_properties)]]]></field>
    <field name="ttype">many2many</field>
    <field name="depends">x_property_matches_contacts, x_last_notification</field>
    <field name="field_description">To notify properties</field>
    <field name="model_id" ref="base.model_res_partner"/>
    <field name="name">x_to_notify_properties</field>
    <field name="readonly" eval="True"/>
    <field name="relation">product.template</field>
    <field name="relation_table">x_product_template_res_partner_rel_to_notify</field>
  </record>
