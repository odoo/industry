            <field widget="statinfo" name="x_x_studio_property_calendar_event_count" string="Visits"/>
          </button>
          <button class="oe_stat_button" icon="fa-heart" type="action" name="%(matches_2271ffa5-4f55-4268-a247-ce5a08b2b5a2)d" invisible="not x_studio_is_properties" context="{'property_id': id}">
            <field widget="statinfo" name="x_x_studio_property_matches_contacts_res_partner_count" string="Matches" invisible="False"/>
          </button>
        </xpath>
        <xpath expr="//field[@name='invoice_policy']" position="after">
          <field name="website_url" invisible="True"/>
        </xpath>
        <xpath expr="//field[@name='categ_id']" position="after">
          <field name="x_studio_is_properties" invisible="True"/>
        </xpath>
        <xpath expr="//field[@name='default_code']" position="after">
