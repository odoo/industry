          <header>
            <button string="Create Visit Link" name="%(industry_create_appo_39885800-fc45-44d6-ad5a-d10d1d357034)d" type="action" invisible="x_studio_appointments or x_studio_is_closed == True"/>
          </header>
        </xpath> -->
        <xpath expr="//button[@name='action_view_sales']" position="after">
          <button class="oe_stat_button" icon="fa-star" type="action" name="%(buyers_7da4651a-dd29-4e4d-9147-c4b2282225c7)d" invisible="not x_studio_is_properties">
            <field widget="statinfo" name="x_x_studio_interested_in_crm_lead_count" string="Buyers"/>
