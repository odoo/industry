#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid "<strong>Basics</strong>"
msgstr "<strong>ພື້ນຖານ</strong>"

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid "<strong>Company specific offers</strong>"
msgstr "<strong>ຂໍ້ສະເໜີສະເພາະຂອງແຕ່ລະບໍລິສັດ</strong>"

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid "<strong>Do you want to go further?</strong>"
msgstr "<strong>ທ່ານຕ້ອງການໄປຕໍ່ໃຫ້ໄກກວ່ານີ້ບໍ່?</strong>"

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid "<strong>Final word</strong>"
msgstr "<strong>ບົດສະຫຼຸບ</strong>"

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid ""
"<strong>In such situation, feel free to experiment with this database and "
"then\n"
"                        to create a new one for your own usage.</strong>"
msgstr ""
"<strong>ໃນສະຖານະການດັ່ງກ່າວ, ທ່ານສາມາດທົດລອງໃຊ້ຖານຂໍ້ມູນນີ້ໄດ້ຢ່າງເຕັມທີ່ ແລະ ຈາກນັ້ນ\n"
"                        ຈຶ່ງສ້າງຖານຂໍ້ມູນໃໝ່ເພື່ອການນຳໃຊ້ຕົວຈິງຂອງທ່ານ.</strong>"

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid "<strong>Multiple resource blocking / period closure</strong>"
msgstr "<strong>ການປິດກັ້ນຫຼາຍຊັບພະຍາກອນ / ການປິດຊົ່ວຄາວ</strong>"

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid "<strong>Shared offers</strong>"
msgstr "<strong>ຂໍ້ສະເໜີທີ່ໃຊ້ຮ່ວມກັນ</strong>"

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid "<strong>Single resource blocking</strong>"
msgstr "<strong>ການປິດກັ້ນຊັບພະຍາກອນດຽວ</strong>"

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid "<strong>Use case</strong>"
msgstr "<strong>ກໍລະນີຕົວຢ່າງການນຳໃຊ້</strong>"

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.homepage
msgid ""
"A cozy retreat in the heart of the country side, offering a warm atmosphere "
"and personalized service for every guest."
msgstr ""
"ສະຖານທີ່ພັກຜ່ອນທີ່ແສນສະບາຍຢູ່ໃຈກາງຊົນນະບົດ, ໃຫ້ບັນຍາກາດທີ່ອົບອຸ່ນ ແລະ "
"ການບໍລິການທີ່ເປັນກັນເອງສຳລັບແຂກທຸກທ່ານ."

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid "Access to more details clicking the slot."
msgstr "ເຂົ້າເບິ່ງລາຍລະອຽດເພີ່ມເຕີມໂດຍການຄລິກໃສ່ຊ່ອງຂໍ້ມູນ."

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid ""
"Add a line with Dinner Plate and update the counts as per guest request."
msgstr "ເພີ່ມລາຍການອາຫານຄໍ່າ ແລະ ອັບເດດຈຳນວນຕາມຄວາມຕ້ອງການຂອງແຂກ."

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid "Add here as many of them as needed."
msgstr "ເພີ່ມລາຍການຢູ່ບ່ອນນີ້ໄດ້ຫຼາຍເທົ່າທີ່ຕ້ອງການ."

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid "Adjust the number of stars, leave a comment and send it!"
msgstr "ປັບຈຳນວນດາວ, ຂຽນຄວາມຄິດເຫັນ ແລະ ກົດສົ່ງ!"

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid ""
"Adjust the rental dates, click the book button and then proceed to checkout."
msgstr "ປັບປ່ຽນວັນທີເຊົ່າ, ຄລິກປຸ່ມຈອງ ແລະ ດຳເນີນການຊຳລະເງິນ."

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid "Adjusting your offers in consequence"
msgstr "ປັບປ່ຽນຂໍ້ສະເໜີຂອງທ່ານໃຫ້ສອດຄ່ອງ"

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid ""
"Again, the <strong>Guest House App </strong>helps you manage the end of the "
"stay!"
msgstr ""
"ອີກຄັ້ງໜຶ່ງ, <strong>ແອັບເຮືອນພັກ (Guest House App)</strong> "
"ຈະຊ່ວຍທ່ານຈັດການໃນຊ່ວງທ້າຍຂອງການເຂົ້າພັກ!"

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid ""
"Alternatively to individual resource blocking slots described earlier, you "
"can select a resource this leave applies to."
msgstr ""
"ນອກຈາກການປິດກັ້ນແຕ່ລະຊັບພະຍາກອນຕາມທີ່ໄດ້ອະທິບາຍກ່ອນໜ້ານີ້, "
"ທ່ານຍັງສາມາດເລືອກຊັບພະຍາກອນທີ່ຈະນຳໃຊ້ການລານີ້ໄດ້."

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid ""
"Alternatively, switch to the list view, and then change the resource.<br/"
">Be\n"
"                    careful not to double book a resource with such change!"
msgstr ""
"ຫຼື ປ່ຽນໄປໃຊ້ຮູບແບບລາຍການ (List view), ແລ້ວຈຶ່ງປ່ຽນຊັບພະຍາກອນ.<br/>ຕ້ອງ\n"
"                    ລະມັດລະວັງບໍ່ໃຫ້ມີການຈອງຊັບພະຍາກອນຊໍ້າຊ້ອນໃນການປ່ຽນແປງດັ່ງກ່າວ!"

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid ""
"Alternatively, switch to the list view, which is more suitable if the "
"booking is\n"
"                    not during the visualized date range and update the "
"booking date range."
msgstr ""
"ຫຼື ປ່ຽນໄປໃຊ້ຮູບແບບລາຍການ (List view), ເຊິ່ງຈະເໝາະສົມກວ່າ ຖ້າການຈອງນັ້ນ\n"
"                    ບໍ່ໄດ້ຢູ່ໃນຊ່ວງວັນທີທີ່ສະແດງຢູ່ ແລະ ອັບເດດຊ່ວງວັນທີຂອງການຈອງ."

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid ""
"Alternatively, type in the search bar and select the appropriate filter."
msgstr "ຫຼື ພິມລົງໃນແຖບຄົ້ນຫາ ແລະ ເລືອກຕົວຕອງທີ່ເໝາະສົມ."

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid ""
"Alternatively, you can create a slot as placeholder from the planning "
"directly:"
msgstr "ຫຼື ທ່ານສາມາດສ້າງຊ່ອງຂໍ້ມູນເພື່ອສຳຮອງໄວ້ ຈາກລະບົບການວາງແຜນໄດ້ໂດຍກົງ:"

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid "An automation is setup for an email to be sent automatically for you."
msgstr "ມີການຕັ້ງຄ່າລະບົບອັດຕະໂນມັດເພື່ອສົ່ງອີເມລໃຫ້ທ່ານໂດຍອັດຕະໂນມັດ."

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid ""
"Any time you create a new survey and save it with the setting \"is customer "
"satisfaction survey\", previous ones\n"
"                    will be archived so that it becomes your new default "
"survey."
msgstr ""
"ທຸກໆຄັ້ງທີ່ທ່ານສ້າງແບບສຳຫຼວດໃໝ່ ແລະ ບັນທຶກດ້ວຍການຕັ້ງຄ່າ \"ແມ່ນແບບສຳຫຼວດຄວາມພຶງພໍໃຈຂອງລູກຄ້າ\", "
"ແບບສຳຫຼວດກ່ອນໜ້ານີ້\n"
"                    ຈະຖືກເກັບໄວ້ໃນບ່ອນເກັບມ້ຽນ (archived) "
"ເພື່ອໃຫ້ມັນກາຍເປັນແບບສຳຫຼວດເລີ່ມຕົ້ນໃໝ່ຂອງທ່ານ."

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid ""
"Anyone can create a portal account on your database.<br/>Open your website "
"home page\n"
"                in a private tab to do so."
msgstr ""
"ທຸກຄົນສາມາດສ້າງບັນຊີ Portal ໃນຖານຂໍ້ມູນຂອງທ່ານໄດ້.<br/>ເປີດໜ້າທຳອິດຂອງເວັບໄຊທ໌ຂອງທ່ານ\n"
"                ໃນແຖບສ່ວນຕົວ (private tab) ເພື່ອດຳເນີນການ."

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid "Assign them a resource, which helps you keeping track."
msgstr "ມອບໝາຍຊັບພະຍາກອນໃຫ້ພວກເຂົາ, ເຊິ່ງຈະຊ່ວຍໃຫ້ທ່ານສາມາດຕິດຕາມໄດ້."

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid ""
"At any time during their stay, open their rental order from the Guest House "
"App."
msgstr "ໃນລະຫວ່າງການເຂົ້າພັກ, ທ່ານສາມາດເປີດລາຍການເຊົ່າຂອງພວກເຂົາໄດ້ທຸກເວລາ ຈາກແອັບເຮືອນພັກ."

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid ""
"At any time from the guest order, use the Send message capability in the "
"chatter\n"
"                    to exchange with your guest."
msgstr ""
"ທ່ານສາມາດໃຊ້ລະບົບສົ່ງຂໍ້ຄວາມໃນຊ່ອງສົນທະນາ (chatter) ຈາກລາຍການຂອງແຂກ\n"
"                    ເພື່ອຕິດຕໍ່ສື່ສານກັບແຂກຂອງທ່ານໄດ້ທຸກເວລາ."

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid ""
"At any time you can adjust the city tax count delivered by re-opening the "
"city tax widget clicking the City Tax button on the guest order."
msgstr ""
"ທ່ານສາມາດປັບປ່ຽນຈຳນວນຄ່າທໍານຽມເມືອງໄດ້ທຸກເວລາ ໂດຍການເປີດ widget ຄ່າທໍານຽມເມືອງຄືນໃໝ່ "
"ຜ່ານການຄລິກປຸ່ມ City Tax ໃນລາຍການຂອງແຂກ."

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid "At the end of their stay, they'll be able to pay for all those extras."
msgstr "ເມື່ອສິ້ນສຸດການເຂົ້າພັກ, ພວກເຂົາຈະສາມາດຊຳລະຄ່າບໍລິການເພີ່ມເຕີມທັງໝົດໄດ້."

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid ""
"Beyond daily operations, the Steering menu serves as the \"Captain’s "
"Bridge\" of your guest house. It provides a 500-day horizon to anticipate "
"market trends, manage risks, and optimize your revenue."
msgstr ""
"ນອກຈາກການດຳເນີນງານປະຈຳວັນແລ້ວ, ເມນູ Steering ຍັງປຽບເໝືອນ \"ຫ້ອງຄວບຄຸມ\" "
"ຂອງເຮືອນພັກຂອງທ່ານ. ມັນໃຫ້ຂໍ້ມູນຄາດການລ່ວງໜ້າ 500 ວັນ ເພື່ອວິເຄາະແນວໂນ້ມຕະຫຼາດ, ຈັດການຄວາມສ່ຽງ "
"ແລະ ເພີ່ມລາຍຮັບຂອງທ່ານ."

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid "Blocking resources"
msgstr "ການປິດກັ້ນຊັບພະຍາກອນ"

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid "Booking a room"
msgstr "ການຈອງຫ້ອງພັກ"

#. module: guest_house
#: model:product.template,name:guest_house.product_template_12
msgid "Breakfast (1 guest)"
msgstr "ອາຫານເຊົ້າ (ສຳລັບ 1 ທ່ານ)"

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid ""
"By uploading this module's demo data, your database has been filled with a "
"few products,\n"
"            sale orders and more."
msgstr ""
"ໂດຍການອັບໂຫລດຂໍ້ມູນຕົວຢ່າງຂອງໂມດູນນີ້, ຖານຂໍ້ມູນຂອງທ່ານຈະຖືກເຕີມເຕັມດ້ວຍສິນຄ້າ,\n"
"            ລາຍການຂາຍ ແລະ ຂໍ້ມູນອື່ນໆ ຈຳນວນໜຶ່ງ."

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid "Charge your customer for the resulting amount and you're all set!"
msgstr "ເກັບເງິນລູກຄ້າຕາມຈຳນວນທີ່ສະຫຼຸບໄດ້ ແລະ ທຸກຢ່າງກໍຮຽບຮ້ອຍ!"

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid "Charge your guests"
msgstr "ເກັບຄ່າບໍລິການຈາກແຂກຂອງທ່ານ"

#. module: guest_house
#: model_terms:product.template,description_ecommerce:guest_house.product_template_14
msgid "Charming double room with a fireplace and scenic views."
msgstr "ຫ້ອງນອນຄູ່ທີ່ມີສະເໜ່ ພ້ອມເຕົາຜີງ ແລະ ວິວທີ່ສວຍງາມ."

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid ""
"Check and adjust if needed the number of guests who stayed in each room. "
"Then confirm the number of city taxes to be charged, which updates the "
"delivered city tax count."
msgstr ""
"ກວດເບິ່ງ ແລະ ປັບປ່ຽນຈຳນວນແຂກທີ່ພັກໃນແຕ່ລະຫ້ອງຖ້າຈຳເປັນ. "
"ຈາກນັ້ນຢືນຢັນຈຳນວນຄ່າທໍານຽມເມືອງທີ່ຈະເກັບ, ເຊິ່ງຈະເປັນການອັບເດດຈຳນວນຄ່າທໍານຽມເມືອງຕົວຈິງ."

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid "Check guests in"
msgstr "ຮັບແຂກເຂົ້າພັກ"

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid "Check guests out"
msgstr "ແຈ້ງແຂກອອກ"

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid "Check information and then confirm the booking."
msgstr "ກວດສອບຂໍ້ມູນ ແລະ ຈາກນັ້ນຢືນຢັນການຈອງ."

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid "Check the invoice data and confirm it."
msgstr "ກວດສອບຂໍ້ມູນໃບແຈ້ງໜີ້ ແລະ ຢືນຢັນ."

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid ""
"City Taxes are to be billed to spent nights in practice and not in theory "
"and are counted as the sum of nights each guest stayed."
msgstr ""
"ຄ່າທໍານຽມເມືອງຈະຖືກເກັບຕາມຈຳນວນຄືນທີ່ພັກຕົວຈິງ ບໍ່ແມ່ນຕາມທິດສະດີ ແລະ "
"ຈະຖືກນັບເປັນຜົນລວມຂອງຄືນທີ່ແຂກແຕ່ລະຄົນໄດ້ພັກ."

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid "Click one of the room to book."
msgstr "ຄລິກທີ່ຫ້ອງໃດໜຶ່ງເພື່ອດຳເນີນການຈອງ."

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid ""
"Click the Check in button to confirm they are now staying at your place!"
msgstr "ຄລິກປຸ່ມ Check in (ແຈ້ງເຂົ້າ) ເພື່ອຢືນຢັນວ່າພວກເຂົາໄດ້ເຂົ້າພັກແລ້ວ!"

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid "Click the Check out button to capture they return you the keys."
msgstr "ຄລິກປຸ່ມ Check out (ແຈ້ງອອກ) ເພື່ອບັນທຶກການຄືນກະແຈ."

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid "Click the Create Order to open the order form."
msgstr "ຄລິກ ສ້າງລາຍການ (Create Order) ເພື່ອເປີດແບບຟອມການສັ່ງຊື້."

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid "Click the Invoice button with a full invoice."
msgstr "ຄລິກປຸ່ມ Invoice ເພື່ອສ້າງໃບແຈ້ງໜີ້ເຕັມຮູບແບບ."

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid ""
"Click the Pay with demo button, and then Pay button to mimic the payment."
msgstr "ຄລິກປຸ່ມ ຊຳລະດ້ວຍຕົວຢ່າງ (Pay with demo), ແລ້ວຄລິກປຸ່ມ Pay ເພື່ອທົດລອງການຊຳລະເງິນ."

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid ""
"Click the tail of the corresponding booking and drag it to the requested "
"date."
msgstr "ຄລິກທີ່ສ່ວນທ້າຍຂອງການຈອງນັ້ນ ແລ້ວລາກໄປຫາວັນທີທີ່ຕ້ອງການ."

#. module: guest_house
#: model:product.template,name:guest_house.product_template_17
msgid "Comfy Room (2 guests)"
msgstr "ຫ້ອງພັກທີ່ແສນສະບາຍ (ສຳລັບ 2 ທ່ານ)"

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid ""
"Configure the email delay as you wish the email to be sent after the guest "
"checkout."
msgstr "ຕັ້ງຄ່າໄລຍະເວລາການສົ່ງອີເມລຕາມທີ່ທ່ານຕ້ອງການ ຫຼັງຈາກທີ່ແຂກແຈ້ງອອກແລ້ວ."

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid ""
"Create a new leave selecting the appropriate working schedule, the one from "
"your stay resources."
msgstr ""
"ສ້າງການລາໃໝ່ໂດຍເລືອກຕາຕະລາງການເຮັດວຽກທີ່ເໝາະສົມ, ເຊິ່ງແມ່ນອັນທີ່ມາຈາກຊັບພະຍາກອນບ່ອນພັກຂອງທ່ານ."

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid ""
"Create a new leave the same way as previously, but this time specify the "
"resource this applies to."
msgstr "ສ້າງການລາໃໝ່ໃນຮູບແບບດຽວກັນກັບຄັ້ງກ່ອນ, ແຕ່ຄັ້ງນີ້ໃຫ້ລະບຸຊັບພະຍາກອນທີ່ຈະນຳໃຊ້ການລານີ້."

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid ""
"Created offers are assigned no company nor branch (default behavior).<br/>As "
"a result, they are available from all companies and branches, as well as all "
"websites from those."
msgstr ""
"ຂໍ້ສະເໜີທີ່ສ້າງຂຶ້ນຈະບໍ່ຖືກກຳນົດໃຫ້ບໍລິສັດ ຫຼື ສາຂາໃດໜຶ່ງ (ເປັນຄ່າເລີ່ມຕົ້ນ).<br/>ດັ່ງນັ້ນ, "
"ພວກມັນຈຶ່ງສາມາດໃຊ້ໄດ້ໃນທຸກບໍລິສັດ ແລະ ສາຂາ, ລວມທັງເວັບໄຊທ໌ທັງໝົດຂອງພວກເຂົາ."

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid "Define start and end date time and save your leave."
msgstr "ກຳນົດວັນທີ ແລະ ເວລາ ເລີ່ມຕົ້ນ-ສິ້ນສຸດ ແລ້ວບັນທຶກການລາຂອງທ່ານ."

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid "Deliver extra services"
msgstr "ມອບການບໍລິການເພີ່ມເຕີມ"

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.homepage
msgid "Different atmospheres for you to find the one you need"
msgstr "ບັນຍາກາດທີ່ຫຼາກຫຼາຍ ເພື່ອໃຫ້ທ່ານຄົ້ນພົບສິ່ງທີ່ທ່ານຕ້ອງການ"

#. module: guest_house
#: model:product.template,name:guest_house.product_template_20
msgid "Dinner Plate (1 guest)"
msgstr "ອາຫານຄໍ່າ (ສຳລັບ 1 ທ່ານ)"

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid "Discover more about Odoo by diving into our"
msgstr "ຄົ້ນຫາເພີ່ມເຕີມກ່ຽວກັບ Odoo ໂດຍການສຶກສາ"

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid ""
"Discover the basics of this package and explore all the possibilities Odoo "
"offers to\n"
"            improve your experience."
msgstr ""
"ຄົ້ນຫາພື້ນຖານຂອງແພັກເກັດນີ້ ແລະ ສຳຫຼວດຄວາມເປັນໄປໄດ້ທັງໝົດທີ່ Odoo ມອບໃຫ້ ເພື່ອ\n"
"            ພັດທະນາປະສົບການຂອງທ່ານ."

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid ""
"During an available period, click, drag and drop on a room line to create a "
"slot."
msgstr "ໃນຊ່ວງເວລາທີ່ຫວ່າງ, ໃຫ້ຄລິກ, ລາກ ແລະ ວາງໃສ່ແຖວຂອງຫ້ອງ ເພື່ອສ້າງຊ່ອງການຈອງ."

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid "Each company can have its own website!"
msgstr "ແຕ່ລະບໍລິສັດສາມາດມີເວັບໄຊທ໌ເປັນຂອງຕົນເອງໄດ້!"

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid "Employee assignations"
msgstr "ການມອບໝາຍພະນັກງານ"

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid ""
"Employee would open the tasks from their hand and update the status until "
"Clean."
msgstr "ພະນັກງານຈະເປີດວຽກຈາກອຸປະກອນຂອງພວກເຂົາ ແລະ ອັບເດດສະຖານະຈົນກວ່າຈະ \"ສະອາດ\"."

#. module: guest_house
#: model_terms:product.template,description_ecommerce:guest_house.product_template_20
msgid ""
"Enjoy a beautifully arranged board featuring a curated selection of local "
"cheeses, premium cured meats, fresh bread, and seasonal accompaniments."
msgstr ""
"ເພີດເພີນກັບຖາດອາຫານທີ່ຈັດແຕ່ງຢ່າງສວຍງາມ ເຊິ່ງປະກອບດ້ວຍເນີຍແຂງທ້ອງຖິ່ນທີ່ຄັດສັນມາຢ່າງດີ, "
"ຊີ້ນແຫ້ງຄຸນນະພາບຢ້ຽມ, ເຂົ້າຈີ່ສົດ ແລະ ເຄື່ອງຄຽງຕາມລະດູການ."

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.welcome_article_body
msgid ""
"Example: A room for 2 is booked for 4 nights, two guests were here for the "
"first three nights but only one stayed the last night. Then the guests x "
"nights is 2x3+1x1=7."
msgstr ""
"ຕົວຢ່າງ: ຫ້ອງສຳລັບ 2 ທ່ານ ຖືກຈອງ 4 ຄືນ, ແຂກສອງທ່ານພັກໃນສາມຄືນທຳອິດ "
"ແຕ່ມີພຽງທ່ານດຽວທີ່ພັກໃນຄືນສຸດທ້າຍ. ດັ່ງນັ້ນ ຈຳນວນແຂກ x ຄືນ ແມ່ນ 2x3+1x1=7."

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.homepage
msgid "Experience the Comfort of <br/>Our Guest House"
msgstr "ສຳຜັດກັບຄວາມສະບາຍຂອງ <br/>ເຮືອນພັກພວກເຮົາ"

#. module: guest_house
#: model_terms:ir.ui.view,arch_db:guest_house.homepage
msgid ""
"Experience the warmth and comfort of our guest house, where every stay feels "
"like a home away from home. Our dedicated staff ensures that your visit is "
"relaxing and memorable."
msgstr ""
"ສຳຜັດກັບຄວາມອົບອຸ່ນ ແລະ ຄວາມສະບາຍຂອງເຮືອນພັກພວກເຮົາ, "
"ບ່ອນທີ່ການເຂົ້າພັກທຸກຄັ້ງໃຫ້ຄວາມຮູ້ສຶກຄືກັບຢູ່ບ້ານ. "
"ພະນັກງານທີ່ຕັ້ງໃຈຂອງພວກເຮົາຈະເຮັດໃຫ້ການມາຢ້ຽມຢາມຂອງທ່ານເປັນການພັກຜ່ອນທີ່ໜ້າຈົດຈຳ."

#. module: guest_house
#: model:product.template,name:guest_house.product_template_14
