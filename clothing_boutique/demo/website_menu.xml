<?xml version='1.0' encoding='UTF-8'?>
<odoo noupdate="1">
    <function model="website.menu" name="unlink">
        <value model="website.menu" eval="obj().search([('website_id', '=', ref('website.default_website')), ('url', '=', '#')]).ids" />
    </function>
    <record id="website_menu_3" model="website.menu">
        <field name="name">Top Menu for Website</field>
        <field name="sequence" eval="False"/>
        <field name="website_id" ref="website.default_website"/>
    </record>
    <record id="website_menu_4" model="website.menu">
        <field name="name">HOME</field>
        <field name="url">/</field>
        <field name="website_id" ref="website.default_website"/>
        <field name="parent_id" ref="website_menu_3"/>
    </record>
    <record id="website_menu_12" model="website.menu">
        <field name="name">SHOP</field>
        <field name="website_id" ref="website.default_website"/>
        <field name="parent_id" ref="website_menu_3"/>
        <field name="is_mega_menu" eval="1"/>
        <field name="mega_menu_content"><![CDATA[
        <section class="s_mega_menu_odoo_menu pt16 o_colored_level o_cc o_cc1">
            <div class="container">
                <div class="row">
                    <!-- FOR HER -->
                    <div class="col-12 pt16 pb24 col-lg-3 o_colored_level">
                        <h4 class="text-uppercase h5 fw-bold mt-0">
                            <a class="nav-link p-0 text-black" href="/shop">
                                For Her
                            </a>
                        </h4>
                        <div class="s_hr pt4 pb16 o_colored_level">
                            <hr class="w-100 mx-auto"
                                style="border-top-width: 2px; border-top-color: var(--primary);" />
                        </div>
                        <nav class="nav flex-column">
                            <a class="nav-link px-0" href="#">Best Sellers</a>
                            <a class="nav-link px-0" href="#">Dresses</a>
                            <a class="nav-link px-0" href="#">Tops</a>
                            <a class="nav-link px-0" href="#">Jeans</a>
                            <a class="nav-link px-0" href="#">Essentials</a>
                            <a class="nav-link px-0 fw-bold mt-2"
                            style="color: rgb(248, 106, 22);"
                            href="/shop">
                                → See All
                            </a>
                        </nav>
                    </div>

                    <!-- FOR HIM -->
                    <div class="col-12 pt16 pb24 col-lg-3 o_colored_level">
                        <h4 class="text-uppercase h5 fw-bold mt-0">
                            <a class="nav-link p-0 text-black" href="/shop">
                                For Him
                            </a>
                        </h4>
                        <div class="s_hr pt4 pb16 o_colored_level">
                            <hr class="w-100 mx-auto"
                                style="border-top-width: 2px; border-top-color: var(--secondary);" />
                        </div>
                        <nav class="nav flex-column">
                            <a class="nav-link px-0" href="#">Best Sellers</a>
                            <a class="nav-link px-0" href="#">T-Shirts</a>
                            <a class="nav-link px-0" href="#">Polos</a>
                            <a class="nav-link px-0" href="#">Trousers</a>
                            <a class="nav-link px-0" href="#">Coats</a>
                            <a class="nav-link px-0 fw-bold mt-2"
                            style="color: rgb(248, 106, 22);"
                            href="/shop">
                                → See All
                            </a>
                        </nav>
                    </div>

                    <!-- ACCESSORIES -->
                    <div class="col-12 pt16 pb24 col-lg-3 o_colored_level">
                        <h4 class="text-uppercase h5 fw-bold mt-0">
                            <a class="nav-link p-0 text-black" href="/shop">
                                Accessories
                            </a>
                        </h4>
                        <div class="s_hr pt4 pb16 o_colored_level">
                            <hr class="w-100 mx-auto"
                                style="border-top-width: 2px; border-top-color: var(--primary);" />
                        </div>
                        <nav class="nav flex-column">
                            <a class="nav-link px-0" href="#">Shoes</a>
                            <a class="nav-link px-0" href="#">Headwear</a>
                            <a class="nav-link px-0" href="#">Sunglasses</a>
                            <a class="nav-link px-0" href="#">Other</a>
                        </nav>
                    </div>

                    <!-- OUTLET -->
                    <div class="col-12 pt16 pb24 col-lg-3 o_colored_level">
                        <h4 class="text-uppercase h5 fw-bold mt-0">
                            <a class="nav-link p-0 text-black" href="/shop">
                                Outlet
                            </a>
                        </h4>
                        <div class="s_hr pt4 pb16 o_colored_level">
                            <hr class="w-100 mx-auto"
                                style="border-top-width: 2px; border-top-color: var(--secondary);" />
                        </div>
                        <nav class="nav flex-column">
                            <a class="nav-link px-0" href="#">In Promotion</a>
                            <a class="nav-link px-0" href="#">Pre-Owned</a>
                        </nav>
                    </div>
                </div>
            </div>
        </section>
        ]]></field>
        <field name="mega_menu_classes">border-top-0</field>
    </record>
    <record id="website_menu_7" model="website.menu">
        <field name="name">WINTER COLLECTION</field>
        <field name="url" eval="'/shop/category/%s' % ref('clothing_boutique.product_public_category_11')"/>
        <field name="website_id" ref="website.default_website"/>
        <field name="parent_id" ref="website_menu_3"/>
    </record>
    <record id="website_menu_9" model="website.menu">
        <field name="name">SUMMER COLLECTION</field>
        <field name="url" eval="'/shop/category/%s' % ref('clothing_boutique.product_public_category_9')"/>
        <field name="website_id" ref="website.default_website"/>
        <field name="parent_id" ref="website_menu_3"/>
    </record>
    <record id="website_menu_11" model="website.menu">
        <field name="name">FIND US</field>
        <field name="page_id" ref="website_page_8"/>
        <field name="url">/find-us</field>
        <field name="website_id" ref="website.default_website"/>
        <field name="parent_id" ref="website_menu_3"/>
    </record>
</odoo>
