<?xml version='1.0' encoding='UTF-8'?>
<odoo>
  <!-- about us -->
  <record id="ir_ui_view_3658" model="ir.ui.view">
    <field name="arch" type="xml">
      <t name="About Us" t-name="website.about-us">
        <t t-call="website.layout">
          <div id="wrap">
            <div class="oe_structure">
              <section class="s_title parallax s_parallax_is_fixed bg-black-50 pt24 pb24" data-vcss="001" data-snippet="s_title" data-scroll-background-ratio="1">
                <span class="s_parallax_bg_wrap">
                  <span class="s_parallax_bg oe_img_bg" style="background-image: url('/web/image/clothing_boutique.ir_attachment_14'); background-position: 50% 0;"/>
                </span>
                <div class="o_we_bg_filter bg-black-50"/>
                <div class="container">
                  <h1>About us</h1>
                </div>
              </section>
            </div>
            <div class="oe_structure">
              <section class="s_text_image pt80 pb80" data-snippet="s_text_image">
                <div class="container">
                  <div class="row align-items-center">
                    <div class="col-lg-5 pt16 pb16">
                      <h2>Fashion is our passion!</h2>
                      <p>
                      </p>
                      <p><br/>Clear, consistent communication enhances your shopping experience. We prioritize open dialogue, ensuring alignment with your style preferences and seamless service throughout your visit.</p>
                      <p>Start with the customer – find out what they want and give it to them.</p>
                      <p/>
                    </div>
                    <div class="col-lg-6 offset-lg-1 pt16 pb16">
                      <img src="/clothing_boutique/static/src/img/s_text_image.svg" class="img img-fluid mx-auto rounded" alt="" loading="lazy"/>
                    </div>
                  </div>
                </div>
              </section>
              <section class="s_text_image pt80 pb80" data-snippet="s_image_text">
                <div class="container">
                  <div class="row align-items-center">
                    <div class="col-lg-6 pt16 pb16">
                      <img src="/clothing_boutique/static/src/img/s_image_text.svg" class="img img-fluid mx-auto rounded" alt="" loading="lazy"/>
                    </div>
                    <div class="col-lg-5 offset-lg-1 pt16 pb16">
                      <h2>Top quality apparel</h2>
                      <p></p>
                      <p><br/>Our apparel is crafted for comfort, durability, and style. With meticulous attention to detail, we create fashionable pieces that elevate your wardrobe.</p>
                      <p>Start with the customer – find out what they want and give it to them.</p>
                      <p/>
                    </div>
                  </div>
                </div>
              </section>
              <section class="s_title pt96 pb80" data-vcss="001" data-snippet="s_title">
                <div class="container s_allow_columns">
                  <h2 class="display-3-fs" style="text-align: center;">
                      Exceptional shopping experiences.
                  </h2>
                </div>
              </section>
              <section class="s_company_team pt48 pb48" data-snippet="s_company_team">
                <div class="container">
                  <h2 class="h3-fs">Explore our collection</h2>
                  <p class="lead">Find your perfect fit with our dedicated team</p>
                  <div class="row">
                    <div class="col-lg-6 pt32 pb32" data-name="Team Member">
                      <div class="row s_col_no_resize s_col_no_bgcolor">
                        <div class="col-lg-3 pb24 o_not_editable" contenteditable="false">
                          <img alt="" src="/web/image/website.s_company_team_image_1" class="img-fluid rounded-circle o_editable_media w-lg-100 mx-lg-auto" loading="lazy"/>
                        </div>
                        <div class="col-lg-9">
                          <h3 class="h5-fs">Tony Fred</h3>
                          <p class="text-muted mb-3">Women's Clothing</p>
                          <p>
                            Meet our founder and fashion visionary, Tony. He is dedicated to providing the best shopping experience for our customers and is involved in all aspects of the business.
                          </p>
                        </div>
                      </div>
                    </div>
                    <div class="col-lg-6 pt32 pb32" data-name="Team Member">
                      <div class="row s_col_no_resize s_col_no_bgcolor">
                        <div class="col-lg-3 pb24 o_not_editable" contenteditable="false">
                          <img alt="" src="/web/image/website.s_company_team_image_2" class="img-fluid rounded-circle o_editable_media w-lg-100 mx-lg-auto" loading="lazy"/>
                        </div>
                        <div class="col-lg-9">
                          <h3 class="h5-fs">Mich Stark</h3>
                          <p class="text-muted mb-3">Men's Clothing</p>
                          <p>Mich is our operations director and ensures that our store runs smoothly. With years of experience in the fashion industry, Mich is one of the best in the business.</p>
                        </div>
                      </div>
                    </div>
                    <div class="col-lg-6 pt32 pb32" data-name="Team Member">
                      <div class="row s_col_no_resize s_col_no_bgcolor">
                        <div class="col-lg-3 pb24 o_not_editable" contenteditable="false">
                          <img alt="" src="/web/image/website.s_company_team_image_3" class="img-fluid rounded-circle o_editable_media w-lg-100 mx-lg-auto" loading="lazy"/>
                        </div>
                        <div class="col-lg-9">
                          <h3 class="h5-fs">Aline Turner</h3>
                          <p class="text-muted mb-3">Kid's Clothing</p>
                          <p>Aline is our fashion expert and leads our team of stylists. She has a passion for fashion and ensures that our store offers the latest and greatest styles.</p>
                        </div>
                      </div>
                    </div>
                    <div class="col-lg-6 pt32 pb32" data-name="Team Member">
                      <div class="row s_col_no_resize s_col_no_bgcolor">
                        <div class="col-lg-3 pb24 o_not_editable" contenteditable="false">
                          <img alt="" src="/web/image/website.s_company_team_image_4" class="img-fluid rounded-circle o_editable_media w-lg-100 mx-lg-auto" loading="lazy"/>
                        </div>
                        <div class="col-lg-9">
                          <h3 class="h5-fs">Iris Joe</h3>
                          <p class="text-muted mb-3">Accessories</p>
                          <p>Iris brings her financial expertise to our team and helps us make informed business decisions. She is committed to driving our success.</p>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </section>
            </div>
          </div>
        </t>
      </t>
    </field>
    <field name="key">clothing_boutique.about-us</field>
    <field name="name">About Us</field>
    <field name="type">qweb</field>
    <field name="website_id" ref="website.default_website"/>
  </record>

  <!-- find us -->
  <record id="ir_ui_view_3792" model="ir.ui.view">
    <field name="arch" type="xml">
      <t t-name="website.find-us">
        <t t-call="website.layout">
          <div id="wrap" class="oe_structure oe_empty">
            <section class="s_text_block pt40 pb0 o_colored_level" data-snippet="s_text_block">
              <div class="container s_allow_columns">
                <h1 style="text-align: center;">Find us</h1>
              </div>
            </section>
            <section class="s_text_block pt40 pb40 o_colored_level" data-snippet="s_text_block">
              <div class="container s_allow_columns">
                <p>Great stories have a <b>personality</b>. Consider telling a great story that provides personality. Writing a story with personality for potential clients will assist with making a relationship connection. This shows up in small quirks like word choices or phrases. Write from your point of view, not from someone else's experience.</p>
                <p>Great stories are <b>for everyone</b> even when only written <b>for just one person</b>. If you try to write with a wide, general audience in mind, your story will sound fake and lack emotion. No one will be interested. Write for one person. If it’s genuine for the one, it’s genuine for the rest.</p>
              </div>
            </section>
            <section class="s_map pb56 pt56 rounded-3 o_not_editable o_half_screen_height" data-map-type="m" data-map-zoom="12" data-vxml="001" data-snippet="s_map" data-map-address="Belgium">
              <div class="map_container">
                <div class="css_non_editable_mode_hidden">
                  <div class="missing_option_warning alert alert-info rounded-0 fade show d-none d-print-none">
                    An address must be specified for a map to be embedded
                  </div>
                </div>
                <iframe class="s_map_embedded o_not_editable" src="https://maps.google.com/maps?q=250%20Executive%20Park%20Blvd%2C%20Suite%203400%20San%20Francisco%20California%20(US)%20United%20States&amp;t=m&amp;z=12&amp;ie=UTF8&amp;iwloc=&amp;output=embed" width="100%" height="100%" frameborder="0" scrolling="no" marginheight="0" marginwidth="0" aria-label="Map"/>
                <div class="s_map_color_filter"/>
              </div>
            </section>
            <section class="s_image_gallery o_spc-small o_masonry pt24 pb24 o_image_popup o_colored_level" data-vcss="002" data-columns="3" style="overflow: hidden;" data-snippet="s_images_wall">
              <div class="container">
                <div class="row s_nb_column_fixed">
                  <div class="o_masonry_col o_snippet_not_selectable col-lg-4">
                    <img class="img img-fluid d-block rounded" src="/web/image/clothing_boutique.ir_attachment_13" data-index="0" data-name="Image" alt="" loading="lazy"/>
                    <img class="img img-fluid d-block rounded" src="/web/image/clothing_boutique.ir_attachment_12" data-index="3" data-name="Image" alt="" loading="lazy"/>
                  </div>
                  <div class="o_masonry_col o_snippet_not_selectable col-lg-4">
                    <img class="img img-fluid d-block rounded" src="/web/image/clothing_boutique.ir_attachment_14" data-index="1" data-name="Image" alt="" loading="lazy"/>
                    <img class="img img-fluid d-block rounded" src="/web/image/clothing_boutique.ir_attachment_10" data-index="4" data-name="Image" alt="" loading="lazy"/>
                  </div>
                  <div class="o_masonry_col o_snippet_not_selectable col-lg-4">
                    <img class="img img-fluid d-block rounded" src="/web/image/clothing_boutique.ir_attachment_9" data-index="2" data-name="Image" alt="" loading="lazy"/>
                    <img class="img img-fluid d-block rounded" src="/web/image/clothing_boutique.ir_attachment_8" data-index="5" data-name="Image" alt="" loading="lazy"/>
                  </div>
                </div>
              </div>
            </section>
          </div>
        </t>
      </t>
    </field>
    <field name="key">clothing_boutique.find-us</field>
    <field name="name">FIND US</field>
    <field name="type">qweb</field>
    <field name="website_id" ref="website.default_website"/>
  </record>
  <record id="homepage" model="ir.ui.view">
    <field name="arch" type="xml">
      <t name="Homepage" t-name="website.homepage">
        <t t-call="website.layout" pageName.f="homepage">
          <div id="wrap" class="oe_structure">
            <section class="s_banner_connected o_cc o_cc5 o_colored_level oe_img_bg o_bg_img_center o_bg_img_origin_border_box pt256 pb256 o_full_screen_height" data-oe-shape-data="{'shape':'html_builder/Connections/13','colors':{'c5':'rgb(255, 255, 255)'},'showOnMobile':true}" data-scroll-background-ratio="0" data-snippet="s_banner_connected" data-name="Banner connected" style="background-image: url(/web/image/clothing_boutique.ir_attachment_5);" data-format-mimetype="image/webp" data-original-src="/web/image/clothing_boutiqueir_attachment_1" data-mimetype-before-conversion="image/jpeg" data-resize-width="1800" data-mimetype="image/webp">
              <div class="o_we_bg_filter bg-black-25"/>
              <div class="o_we_shape o_html_builder_Connections_13 o_shape_show_mobile" style="background-image: url('/html_editor/shape/html_builder/Connections/13.svg?c5=rgb%28255%2C255%2C255%29');"/>
              <div class="container">
                <div class="row o_grid_mode" data-row-count="5">
                  <div class="o_colored_level o_grid_item g-col-lg-5 g-height-5 col-lg-5" data-scroll-background-ratio="0" style="z-index: 1; grid-area: 1 / 1 / 6 / 6;">
                    <h1>MY.CLOTHING</h1>
                    <p class="lead">Innovation transforms possibilities into reality.</p>
                    <p>
                      <a class="o_translate_inline btn-lg btn btn-secondary" href="/shop">SHOP NOW</a>
                    </p>
                  </div>
                </div>
              </div>
            </section>
            <section class="s_floating_blocks pt32 pb32 o_cc o_colored_level o_cc1" data-snippet="s_floating_blocks" data-name="Floating Cards">
              <div class="container-fluid">
                <div class="d-flex flex-column gap-5">
                  <div class="s_floating_blocks_wrapper s_floating_blocks_wrapper_shadow d-contents rounded-4">
                    <section data-name="Card" class="s_floating_blocks_block s_col_no_resize position-sticky py-5 py-lg-0 d-flex o_cc o_cc5 o_colored_level oe_img_bg o_bg_img_center o_bg_img_origin_border_box" style="background-image: url(/web/image/clothing_boutique.ir_attachment_1);" data-scroll-background-ratio="0" data-format-mimetype="image/webp" data-original-id="1093" data-original-src="/web/image/clothing_boutiqueir_attachment_1" data-mimetype-before-conversion="image/jpeg" data-resize-width="1290" data-mimetype="image/webp">
                      <div class="o_we_bg_filter bg-black-15"/>
                      <div class="container-fluid align-self-end align-self-lg-center">
                        <div class="s_floating_blocks_block_grid oe_unremovable row mx-0 o_grid_mode" data-row-count="8">
                          <div class="o_grid_item g-col-lg-8 col-lg-8 order-lg-0 o_colored_level g-height-4" style="z-index: 1; grid-area: 1 / 1 / 5 / 9;" data-scroll-background-ratio="0">
                            <p class="lead">Get Stylish for Your Holidays</p>
                            <h1>SUMMER&amp; </h1>
                            <h1>COLLECTION&amp; <br/></h1>
                          </div>
                          <div class="o_grid_item g-height-2 g-col-lg-4 o_colored_level col-lg-4" style="z-index: 2; --grid-item-padding-y: 0px; --grid-item-padding-x: 0px; grid-area: 7 / 1 / 9 / 5;" data-scroll-background-ratio="0">
                            <a title="" role="button" class="btn-lg btn btn-secondary" href="/shop/category/%s' % ref('clothing_boutique.product_public_category_9')">Shop Collection</a>
                          </div>
                        </div>
                      </div>
                    </section>
                    <section data-name="Card" class="s_floating_blocks_block s_col_no_resize position-sticky py-5 py-lg-0 d-flex o_cc o_cc5 o_colored_level oe_img_bg o_bg_img_center o_bg_img_origin_border_box" data-scroll-background-ratio="0" style="background-image: url(/web/image/clothing_boutique.ir_attachment_3);" data-format-mimetype="image/webp" data-original-id="1099" data-original-src="/web/image/clothing_boutiqueir_attachment_1" data-mimetype-before-conversion="image/jpeg" data-resize-width="1290" data-mimetype="image/webp">
                      <div class="container-fluid align-self-start align-self-lg-center">
                        <div class="s_floating_blocks_block_grid oe_unremovable row mx-0 o_grid_mode" data-row-count="8">
                          <div class="o_grid_item g-height-4 g-col-lg-8 col-lg-8 order-lg-0 o_colored_level" style="z-index: 1; grid-area: 1 / 1 / 5 / 9;">
                            <p class="lead">Warm Winters.</p>
                            <h2 class="display-4-fs">WINTER<br/>COLLECTION</h2>
                          </div>
                          <div class="o_grid_item g-height-2 g-col-lg-4 col-lg-4 o_colored_level" style="z-index: 2; --grid-item-padding-y: 0px; --grid-item-padding-x: 0px; grid-area: 7 / 1 / 9 / 5;">
                            <a title="" role="button" class="btn-lg btn btn-secondary" href="/shop/category/%s' % ref('clothing_boutique.product_public_category_11')">Shop Collection</a>
                          </div>
                        </div>
                      </div>
                    </section>
                  </div>
                </div>
              </div>
            </section>
            <section class="s_references o_cc o_cc1 o_colored_level" data-snippet="s_references">
              <div class="container">
                <h1 style="text-align: center;">As seen in</h1>
                <div class="row">
                  <div class="col-6 col-lg-2 pt16 pb16 o_colored_level">
                    <img src="/web/image/website.s_reference_demo_image_1" class="img img-fluid mx-auto" alt="" loading="lazy"/>
                  </div>
                  <div class="col-6 col-lg-2 pt16 pb16 o_colored_level">
                    <img src="/web/image/website.s_reference_demo_image_2" class="img img-fluid mx-auto" alt="" loading="lazy"/>
                  </div>
                  <div class="col-6 col-lg-2 pt16 pb16 o_colored_level">
                    <img src="/web/image/website.s_reference_demo_image_3" class="img img-fluid mx-auto" alt="" loading="lazy"/>
                  </div>
                  <div class="col-6 col-lg-2 pt16 pb16 o_colored_level">
                    <img src="/web/image/website.s_reference_demo_image_4" class="img img-fluid mx-auto" alt="" loading="lazy"/>
                  </div>
                  <div class="col-6 col-lg-2 pt16 pb16 o_colored_level">
                    <img src="/web/image/website.s_reference_demo_image_5" class="img img-fluid mx-auto" alt="" loading="lazy"/>
                  </div>
                  <div class="col-6 col-lg-2 pt16 pb16 o_colored_level">
                    <img src="/web/image/website.s_reference_default_image_6" class="img img-fluid mx-auto" alt="" loading="lazy"/>
                  </div>
                </div>
              </div>
            </section>
            <section class="s_cta_box pt80 pb80 o_colored_level" data-snippet="s_cta_box">
              <div class="container">
                <div class="s_card o_card_img_horizontal card o_cc o_cc4 flex-lg-row o_colored_level" data-snippet="s_card" data-vxml="001" data-name="Card" style="--card-spacer-x: 64px;--card-spacer-y: 64px;border-width: 0px !important;border-radius: 24px !important;-card-img-size-h: 33.33333%">
                  <figure class="o_card_img_wrapper mb-0">
                    <img class="o_card_img rounded-end o_editable_media" src="/clothing_boutique/static/src/img/s_cta_box.svg" alt="" style="padding: 40px;" loading="lazy"/>
                  </figure>
                  <div class="card-body">
                    <h2 class="card-title">
                      Join our fashion team for creativity and growth!
                    </h2>
                    <p class="card-text">
                      Join our dynamic fashion team focused on creativity and growth.<br/><br/>
                    </p>
                    <a class="btn btn-lg btn-secondary" href="/contactus">Get in touch with us</a>
                  </div>
                </div>
              </div>
            </section>
          </div>
        </t>
      </t>
    </field>
    <field name="key">clothing_boutique.homepage</field>
    <field name="name">Home</field>
    <field name="type">qweb</field>
    <field name="website_id" ref="website.default_website"/>
  </record>
  <record id="ir_ui_view_3681" model="ir.ui.view">
    <field name="arch" type="xml">
      <data name="eCommerce Footer Categories">
        <xpath expr="//section[hasclass('s_text_block')]//div[hasclass('container') and hasclass('s_allow_columns')]" position="attributes">
          <attribute name="class" remove="container" add="container-fluid" separator=" "/>
        </xpath>
        <xpath expr="//ul[hasclass('list-unstyled')]/t" position="replace">
          <t t-set="ecommerce_categories" t-value="[
            {'name': 'Accessories', 'id': request.env.ref('clothing_boutique.product_public_category_6').id},
            {'name': 'Activewear', 'id': request.env.ref('clothing_boutique.product_public_category_8').id},
            {'name': 'Essentials', 'id': request.env.ref('clothing_boutique.product_public_category_1').id},
            {'name': 'Footwear', 'id': request.env.ref('clothing_boutique.product_public_category_12').id},
            {'name': 'Loungewear', 'id': request.env.ref('clothing_boutique.product_public_category_13').id},
            {'name': 'Outerwear','id': request.env.ref('clothing_boutique.product_public_category_4').id},
          ]"/>
        </xpath>
      </data>
    </field>
    <field name="inherit_id" ref="website_sale.template_footer_website_sale"/>
    <field name="key">clothing_boutique.template_footer_website_sale</field>
    <field name="mode">extension</field>
    <field name="name">E-Commerce Footer</field>
    <field name="type">qweb</field>
    <field name="website_id" ref="website.default_website"/>
  </record>
</odoo>
