<?xml version='1.0' encoding='UTF-8'?>
<odoo noupdate="1">
  <record id="pos_config_1" model="pos.config">
    <field name="name">Online Orders</field>
    <field name="tip_product_id" eval="False"/>
    <field name="use_presets" eval="True"/>
    <field name="default_preset_id" ref="pos_restaurant.pos_delivery_preset"/>
    <field name="available_preset_ids" eval="[(6, 0, [ref('pos_restaurant.pos_takeout_preset'), ref('pos_restaurant.pos_delivery_preset')])]"/>
    <field name="module_pos_restaurant" eval="True"/>
    <field name="payment_method_ids" eval="[(6, 0, [ref('pos_payment_method_2'), ref('pos_payment_method_3'), ref('pos_payment_method_1')])]"/>
    <field name="show_product_images" eval="False"/>
    <field name="show_category_images" eval="False"/>
    <field name="iface_printbill" eval="True"/>
    <field name="floor_ids" eval="[(6, 0, [ref('restaurant_floor_1')])]"/>
    <field name="default_screen">register</field>
    <field name="self_ordering_mode">mobile</field>
    <field name="self_ordering_available_language_ids" eval="[(6, 0, [ref('base.lang_en')])]"/>
    <field name="self_ordering_pay_after">each</field>
  </record>
  <record id="pos_config_2" model="pos.config">
    <field name="name">Restaurant</field>
    <field name="tip_product_id" eval="False"/>
    <field name="module_pos_restaurant" eval="True"/>
    <field name="iface_splitbill" eval="True"/>
    <field name="self_ordering_available_language_ids" eval="[(6, 0, [ref('base.lang_en')])]"/>
    <field name="self_ordering_pay_after">each</field>
  </record>
</odoo>
