#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid ""
"Complicated customer requests? No problem - serve any item in any order, "
"take notes, and more."
msgstr ""
"Yêu cầu phức tạp từ khách hàng? Không vấn đề gì - phục vụ món ăn theo từng "
"đơn hàng, ghi chú và nhiều hơn nữa."

#. module: takeaway_restaurant
#: model_terms:product.template,description:takeaway_restaurant.product_template_pesto_chicken_pizza
msgid "Creamy pesto sauce base with grilled chicken and sun-dried tomatoes."
msgstr "Nước sốt pesto kem mịn kết hợp với gà nướng và cà chua khô."

#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid ""
"Create &amp; manage your products in Odoo - from single dishes, to combo "
"meals, and more."
msgstr ""
"Tạo &amp; quản lý sản phẩm của bạn trong Odoo - từ các món ăn đơn lẻ, đến "
"các combo bữa ăn và hơn thế nữa."

#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid "Create a beautiful <strong>floor plan, add tables &amp; seats</strong>"
msgstr "Tạo <strong>sơ đồ tầng đẹp mắt, thêm bàn &amp; và ghế</strong>"

#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid "Create dishes, sides, drinks, and <strong>combo products</strong><br/>"
msgstr ""
"Tạo các món ăn, món phụ, đồ uống và <strong>các sản phẩm combo</strong><br/>"

#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid "Create one-off or recurring <strong>RFQs</strong> to vendors"
msgstr "Tạo<strong>RFQ</strong> một lần hoặc định kỳ gửi đến các nhà cung cấp"

#. module: takeaway_restaurant
#: model_terms:product.template,description:takeaway_restaurant.product_template_garlic_bread
