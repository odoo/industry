#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid "<span class=\"h1-fs\">Basics</span>"
msgstr "<span class=\"h1-fs\">Cơ bản</span>"

#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid ""
"<strong><b>Inventory App</b>:</strong> Track ingredient usage in real-time "
"to prevent stockouts and minimize food waste."
msgstr ""
"<strong><b>Ứng dụng Tồn kho</b>:</strong> Theo dõi việc sử dụng nguyên liệu "
"theo thời gian thực để ngăn chặn tình trạng hết hàng và giảm thiểu lãng phí "
"thực phẩm."

#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid ""
"<strong><b>Invoicing App</b>:</strong> Simplify your financial management by "
"automatically tracking revenue from all sales channels.<br/>"
msgstr ""
"<strong><b>Ứng dụng Hóa đơn</b>:</strong> Đơn giản hóa việc quản lý tài "
"chính của bạn bằng cách tự động theo dõi doanh thu từ tất cả các kênh bán "
"hàng.<br/>"

#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid ""
"<strong><b>POS Preparation Display</b>:</strong> Replace paper tickets with "
"a digital Kitchen Display System to manage order flow and preparation times "
"efficiently.<br/>"
msgstr ""
"<strong><b>Màn hình khâu chuẩn bị POS</b>:</strong> Thay thế phiếu giấy bằng "
"Hệ thống hiển thị nhà bếp kỹ thuật số để quản lý luồng đơn hàng và thời gian "
"chuẩn bị một cách hiệu quả.<br/>"

#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid ""
"<strong><b>Point of Sale App</b>:</strong> Register in-store orders quickly, "
"processing payments and sending tickets directly to the kitchen.<br/>"
msgstr ""
"<strong><b>Ứng dụng POS</b>:</strong> Đăng ký đơn bán hàng tại cửa hàng "
"nhanh chóng, xử lý thanh toán và gửi phiếu trực tiếp đến bếp.<br/>"

#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid ""
"<strong><b>Purchase App</b>:</strong> Manage supplier relationships and "
"automate reordering for essential ingredients and packaging."
msgstr ""
"<strong><b>Ứng dụng Mua hàng</b>:</strong> Quản lý mối quan hệ với nhà cung "
"cấp và tự động hóa việc đặt hàng lại các nguyên liệu thiết yếu và bao bì."

#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid ""
"<strong><b>Website App</b>:</strong> Build an appetizing digital menu and "
"enable customers to place orders online for pickup or delivery.<br/>"
msgstr ""
"<strong><b>Ứng dụng Trang web</b>:</strong> Tạo một thực đơn số hấp dẫn và "
"cho phép khách hàng đặt hàng online để nhận tại cửa hàng hoặc giao hàng tận "
"nơi.<br/>"

#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid "<strong><span class=\"h2-fs\">Tips for Success</span></strong>"
msgstr "<strong><span class=\"h2-fs\">Mẹo thành công</span></strong>"

#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid ""
"<strong>Accounting</strong>: Handle daily revenue tracking, taxes, and end-"
"of-month reports"
msgstr ""
"<strong>Kế toán</strong>: Quản lý theo dõi doanh thu hàng ngày, thuế và báo "
"cáo cuối tháng"

#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid ""
"<strong>Experiment ! </strong>Did you know you can create a copy of your "
"database to try things out ? Simply go to"
msgstr ""
"<strong>Thử nghiệm! </strong>Bạn có biết rằng bạn có thể tạo một bản sao của "
"cơ sở dữ liệu để thử nghiệm các tính năng mới không? Chỉ cần truy cập"

#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid "<strong>Inventory</strong>"
msgstr "<strong>Tồn kho</strong>"

#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid "<strong>Keep your pantry stocked and your costs under control.</strong>"
msgstr ""
"<strong>Giữ cho tủ bếp của bạn luôn đầy đủ và kiểm soát chi phí.</strong>"

#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid "<strong>Kitchen display</strong>"
msgstr "<strong>Màn hình nhà bếp</strong>"

#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid ""
"<strong>Loyalty Programs in the Point of Sale</strong>: Reward repeat "
"customers with discounts, points, or free items"
msgstr ""
"<strong>Chương trình khách hàng thân thiết tại POS (Point of Sale)</strong>: "
"Tặng thưởng cho khách hàng thường xuyên bằng cách giảm giá, tích điểm hoặc "
"tặng quà miễn phí"

#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid ""
"<strong>Marketing</strong>: Send newsletters or discount codes to customers "
"who've opted in<br/>\n"
"                    <br/>"
msgstr ""
"<strong>Marketing</strong>: Gửi bản tin hoặc mã giảm giá cho khách hàng đã "
"đăng ký nhận thông tin<br/>\n"
"                    <br/>"

#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid ""
"<strong>Odoo ensures every order is registered, traceable, and ready to "
"prepare or deliver without delay.</strong>"
msgstr ""
"<strong>Odoo đảm bảo rằng mọi đơn hàng đều được ghi nhận, có thể theo dõi và "
"sẵn sàng để chuẩn bị hoặc giao hàng mà không bị chậm trễ.</strong>"

#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid "<strong>Point of Sale</strong>"
msgstr "<strong>POS</strong>"

#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid "<strong>Purchase</strong>"
msgstr "<strong>Mua hàng</strong>"

#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid ""
"<strong>Start small, iterate.</strong> Configure your website and products "
