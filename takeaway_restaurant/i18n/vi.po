#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid "Assign orders to tables in just a tap"
msgstr "Gán đơn hàng cho bàn chỉ với một lần chạm"

#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid ""
"Assign orders to tables, follow-up on customer requests, and always deliver "
