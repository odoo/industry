#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid "<span class=\"h1-fs\">Basics</span>"
msgstr "<span class=\"h1-fs\">Основы</span>"

#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid ""
"<strong><b>Inventory App</b>:</strong> Track ingredient usage in real-time "
"to prevent stockouts and minimize food waste."
msgstr ""
"<strong><b>Модуль Склад</b>:</strong> Отслеживайте расход ингредиентов в "
"реальном времени, чтобы предотвратить дефицит и минимизировать пищевые "
"отходы."

#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid ""
"<strong><b>Invoicing App</b>:</strong> Simplify your financial management by "
"automatically tracking revenue from all sales channels.<br/>"
msgstr ""
"<strong><b>Модуль Выставление счетов</b>:</strong> Упростите финансовое "
"управление, автоматически отслеживая выручку со всех каналов продаж.<br/>"

#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid ""
"<strong><b>POS Preparation Display</b>:</strong> Replace paper tickets with "
"a digital Kitchen Display System to manage order flow and preparation times "
"efficiently.<br/>"
msgstr ""
"<strong><b>Кухонный дисплей POS</b>:</strong> Замените бумажные чеки "
"цифровой системой кухонных экранов для эффективного управления потоком "
"заказов и временем приготовления.<br/>"

#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid ""
"<strong><b>Point of Sale App</b>:</strong> Register in-store orders quickly, "
"processing payments and sending tickets directly to the kitchen.<br/>"
msgstr ""
"<strong><b>Модуль POS</b>:</strong> Быстро регистрируйте заказы в заведении, "
"принимая оплату и отправляя чеки напрямую на кухню.<br/>"

#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid ""
"<strong><b>Purchase App</b>:</strong> Manage supplier relationships and "
"automate reordering for essential ingredients and packaging."
msgstr ""
"<strong><b>Модуль Закупки</b>:</strong> Управляйте отношениями с "
"поставщиками и автоматизируйте правила повторного заказа необходимых "
"ингредиентов и упаковки."

#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid ""
"<strong><b>Website App</b>:</strong> Build an appetizing digital menu and "
"enable customers to place orders online for pickup or delivery.<br/>"
msgstr ""
"<strong><b>Модуль Вебсайт</b>:</strong> Создайте аппетитное онлайн-меню и "
"позвольте клиентам оформлять онлайн-заказы на самовывоз или доставку.<br/>"

#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid "<strong><span class=\"h2-fs\">Tips for Success</span></strong>"
msgstr ""
"<strong><span class=\"h2-fs\">Советы для достижения успеха</span></strong>"

#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid ""
"<strong>Accounting</strong>: Handle daily revenue tracking, taxes, and end-"
"of-month reports"
msgstr ""
"<strong>Бухгалтерия</strong>: Ведите ежедневный учет выручки, налогов и "
"формируйте ежемесячные отчеты"

#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid ""
"<strong>Experiment ! </strong>Did you know you can create a copy of your "
"database to try things out ? Simply go to"
msgstr ""
"<strong>Экспериментируйте! </strong>Знаете ли вы, что можете создать копию "
"своей базы данных для тестов? Просто перейдите в"

