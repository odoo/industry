msgid "<span class=\"h1-fs\">Basics</span>"
msgstr "<span class=\"h1-fs\">Les bases</span>"

#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid ""
"<strong><b>Inventory App</b>:</strong> Track ingredient usage in real-time "
"to prevent stockouts and minimize food waste."
msgstr ""
"<strong><b>Application Inventaire</b> :</strong> suivez l'utilisation des "
"ingrédients en temps réel afin d'éviter les ruptures de stock et de "
"minimiser le gaspillage alimentaire."

#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid ""
"<strong><b>Invoicing App</b>:</strong> Simplify your financial management by "
"automatically tracking revenue from all sales channels.<br/>"
msgstr ""
"<strong><b>Application Facturation</b> :</strong> simplifiez votre gestion "
"financière en suivant automatiquement les revenus de tous les canaux de "
"vente.<br/>"

#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid ""
"<strong><b>POS Preparation Display</b>:</strong> Replace paper tickets with "
"a digital Kitchen Display System to manage order flow and preparation times "
"efficiently.<br/>"
msgstr ""
"<strong><b>Écran de préparation du point de vente</b> :</strong> remplacez "
"les tickets papier par un écran de cuisine numérique afin de gérer "
"efficacement le flux des commandes et les temps de préparation.<br/>"

#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid ""
"<strong><b>Point of Sale App</b>:</strong> Register in-store orders quickly, "
"processing payments and sending tickets directly to the kitchen.<br/>"
msgstr ""
"<strong><b>Application Point de Vente</b> :</strong> enregistrez rapidement "
"les commandes en magasin, traitez les paiements et envoyez les tickets "
"directement en cuisine.<br/>"

#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid ""
"<strong><b>Purchase App</b>:</strong> Manage supplier relationships and "
"automate reordering for essential ingredients and packaging."
msgstr ""
"<strong><b>Application Achats</b> :</strong> gérez les relations "
"fournisseurs et automatisez le réapprovisionnement des ingrédients et "
"emballages essentiels."

#. module: takeaway_restaurant
#: model_terms:ir.ui.view,arch_db:takeaway_restaurant.welcome_article_body
msgid ""
"<strong><b>Website App</b>:</strong> Build an appetizing digital menu and "
"enable customers to place orders online for pickup or delivery.<br/>"
msgstr ""
"<strong><b>Application Site Web</b> :</strong> créez un menu numérique "
"attrayant et offrez aux clients la possibilité de passer des commandes en "
"ligne pour le retrait ou la livraison.<br/>"

