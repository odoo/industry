<?xml version='1.0' encoding='UTF-8'?>
<odoo>

    <!-- shopping list -->
    <record id="field_x_work_item_line_x_demand" model="ir.model.fields">
        <field name="name">x_demand</field>
        <field name="ttype">float</field>
        <field name="depends">x_quantity,x_work_item_id,x_work_item_id.x_sale_order_line_id,x_work_item_id.x_sale_order_line_id.product_uom_qty</field>
        <field name="field_description">Needed</field>
        <field name="model_id" ref="x_work_item_line_model"/>
        <field name="readonly" eval="True"/>
        <field name="compute"><![CDATA[
for r in self: r['x_demand'] = (r.x_quantity * (line.product_uom_qty if (line := r.x_work_item_id.x_sale_order_line_id) else 1))
]]></field>
    </record>
    <record id="field_x_work_item_line_x_consumed" model="ir.model.fields">
        <field name="name">x_consumed</field>
        <field name="ttype">float</field>
        <field name="field_description">Consumed</field>
        <field name="model_id" ref="x_work_item_line_model"/>
        <field name="readonly" eval="True"/>
        <field name="store" eval="False"/>
        <field name="depends">x_demand,x_work_item_id,x_work_item_id.x_sale_order_line_id,x_work_item_id.x_sale_order_line_id.x_cost_nature,x_work_item_id.x_sale_order_line_id.x_delivered_progress</field>
        <field name="compute"><![CDATA[
for r in self: r['x_consumed'] = r.x_demand if (r.x_work_item_id.x_sale_order_line_id.x_cost_nature == 'material' and r.x_work_item_id.x_sale_order_line_id.x_delivered_progress == 100) else 0
]]></field>
    </record>
    <record id="field_x_work_item_line_x_line_reference" model="ir.model.fields">
        <field name="ttype">char</field>
        <field name="related">x_work_item_id.x_sale_order_line_id.x_reference</field>
        <field name="field_description">Line Reference</field>
        <field name="model_id" ref="x_work_item_line_model"/>
        <field name="name">x_line_reference</field>
        <field name="readonly" eval="True"/>
        <field name="store" eval="False"/>
    </record>
    <record id="field_x_work_item_line_x_sale_order_id" model="ir.model.fields">
        <field name="ttype">many2one</field>
        <field name="related">x_work_item_id.x_sale_order_line_id.order_id</field>
        <field name="relation">sale.order</field>
        <field name="field_description">Sale Order</field>
        <field name="model_id" ref="x_work_item_line_model"/>
        <field name="name">x_sale_order_id</field>
        <field name="readonly" eval="True"/>
        <field name="store" eval="False"/>
    </record>



    <record id="action_project_x_work_item_line_view_from_project" model="ir.actions.act_window">
        <field name="name">Procurement</field>
        <field name="res_model">x_work_item_line</field>
        <field name="domain">[('x_sale_order_id.project_id', '=', active_id), ('x_cost_nature', '=', 'material')]</field>
        <field name="view_mode">list</field>
    </record>
    <record id="action_project_x_work_item_line_view_from_so" model="ir.actions.act_window">
        <field name="name">Procurement</field>
        <field name="res_model">x_work_item_line</field>
        <field name="domain">[('x_sale_order_id', '=', active_id), ('x_cost_nature', '=', 'material')]</field>
        <field name="view_mode">list</field>
        <field name="context">{'search_default_group_by_product': True}</field>
    </record>
    <record id="action_project_x_work_item_line_view_from_menu" model="ir.actions.act_window">
        <field name="name">Procurement</field>
        <field name="res_model">x_work_item_line</field>
        <field name="domain">[('x_work_item_id.x_is_template', '=', False), ('x_cost_nature', '=', 'material')]</field>
        <field name="view_mode">list</field>
        <field name="context">{'search_default_group_by_product': True}</field>
    </record>



    <record id="project_embedded_action_x_work_item_lines" model="ir.embedded.actions">
        <field name="parent_res_model">project.project</field>
        <field name="name">Procurement</field>
        <field name="sequence">104</field>
        <field name="parent_action_id" ref="project.act_project_project_2_project_task_all"/>
        <field name="action_id" eval="ref('construction_developer.action_project_x_work_item_line_view_from_project')"/>
    </record>
    <record id="project_embedded_action_x_work_item_lines_dashboard" model="ir.embedded.actions">
        <field name="parent_res_model">project.project</field>
        <field name="name">Procurement</field>
        <field name="sequence">104</field>
        <field name="parent_action_id" ref="project.project_update_all_action"/>
        <field name="action_id" eval="ref('construction_developer.action_project_x_work_item_line_view_from_project')"/>
    </record>


    <record id="x_work_item_line_list_view" model="ir.ui.view">
        <field name="model">x_work_item_line</field>
        <field name="name">x_work_item_line.view.list</field>
        <field name="type">list</field>
        <field name="active" eval="True"/>
        <field name="arch" type="xml">
            <list open_form_view="false" create="0">
                <field name="x_sale_order_id" widget="many2one" optional="show"/>
                <field name="x_line_reference" optional="show"/>
                <field name="x_product_id" widget="many2one" optional="show"/>
                <field name="x_work_item_id" widget="many2one" optional="show"/>
                <field name="x_unit_id" widget="many2one" optional="show"/>
                <field name="x_demand" optional="show"/>
                <field name="x_consumed" optional="show"/>
            </list>
        </field>
    </record>

    <record id="menu_reordering_rules_replenish" model="ir.ui.menu">
        <field name="action" ref="action_project_x_work_item_line_view_from_menu"/>
        <field name="name">Procurement</field> 
        <field name="parent_id" ref="stock.menu_stock_procurement"/>
        <field name="sequence">0</field>
    </record>
</odoo>
