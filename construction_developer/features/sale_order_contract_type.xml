<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="default_sale_order_line_sol_contract_type" model="ir.default">
        <field name="field_id" ref="field_sale_order_line_sol_contract_type"/>
        <field name="json_value">"fixed_price"</field>
    </record>


    <record id="field_sale_order_so_contract_type" model="ir.model.fields">
        <field name="name">x_so_contract_type</field>
        <field name="field_description">Contract Type</field>
        <field name="ttype">selection</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="help"><![CDATA[Precise on the quotation document the contract type:
- Unspecified: No specific billing terms will be displayed on this document.
- Fixed Price: A mention is displayed precising the contract type is fixed price.
- Open Book: A mention is displayed precising the contract type is open book.
- Per Line: Mixed billing logic where you define individually for each line item.]]></field>
    </record>
    <record id="field_sale_order_so_contract_type_selection_unspecified" model="ir.model.fields.selection">
        <field name="name">Unspecified</field>
        <field name="field_id" ref="field_sale_order_so_contract_type"/>
        <field name="value">unspecified</field>
    </record>
    <record id="field_sale_order_so_contract_type_selection_fixed_price" model="ir.model.fields.selection">
        <field name="name">Fixed Price</field>
        <field name="field_id" ref="field_sale_order_so_contract_type"/>
        <field name="value">fixed_price</field>
    </record>
    <record id="field_sale_order_so_contract_type_selection_open_book" model="ir.model.fields.selection">
        <field name="name">Open Book</field>
        <field name="field_id" ref="field_sale_order_so_contract_type"/>
        <field name="value">open_book</field>
    </record>
    <record id="field_sale_order_so_contract_type_selection_per_line" model="ir.model.fields.selection">
        <field name="name">Per Line</field>
        <field name="field_id" ref="field_sale_order_so_contract_type"/>
        <field name="value">per_line</field>
    </record>
    <record id="field_sale_order_line_sol_contract_type" model="ir.model.fields">
        <field name="name">x_sol_contract_type</field>
        <field name="field_description">Contract Type</field>
        <field name="ttype">selection</field>
        <field name="model_id" ref="sale.model_sale_order_line"/>
    </record>
    <record id="field_sale_order_line_sol_contract_type_selection_fixed_price" model="ir.model.fields.selection">
        <field name="name">Fixed Price</field>
        <field name="field_id" ref="field_sale_order_line_sol_contract_type"/>
        <field name="value">fixed_price</field>
    </record>
    <record id="field_sale_order_line_sol_contract_type_selection_open_book" model="ir.model.fields.selection">
        <field name="name">Open Book</field>
        <field name="field_id" ref="field_sale_order_line_sol_contract_type"/>
        <field name="value">open_book</field>
    </record>
</odoo>
