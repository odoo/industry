<!-- product.template -->
    <record id="field_product_template_x_uom_matches_category" model="ir.model.fields">
        <field name="name">x_uom_matches_category</field>
        <field name="field_description">UOM Matches Category</field>
        <field name="ttype">boolean</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="store" eval="False"/>
        <field name="copied" eval="False"/>
        <field name="readonly" eval="True"/>
        <field name="depends">categ_id,uom_id</field>
        <field name="compute"><![CDATA[
for record in self:
    record['x_uom_matches_category'] = record.categ_id.x_cost_nature not in ['equipment', 'labour'] or (record.uom_id and record.uom_id._has_common_reference(self.env.ref('uom.product_uom_hour')))
]]></field>
    </record>
