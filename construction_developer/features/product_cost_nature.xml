        <field name="model_id" ref="product.model_product_category"/>
        <field name="action_server_ids" eval="[(6, 0, [ref('server_action_update_x_cost_nature')])]"/>
        <field name="filter_domain">[('parent_id', '!=', False)]</field>
        <field name="trigger">on_create_or_write</field>
        <field name="trigger_field_ids" eval="[(6, 0, [ref('product.field_product_category__parent_id')])]"/>
    </record>


    <record id="server_action_update_x_cost_nature" model="ir.actions.server">
        <field name="name">Construction Developer: Update Product Category Cost Nature</field>
        <field name="model_id" ref="product.model_product_category"/>
        <field name="state">code</field>
        <field name="code"><![CDATA[
# Simple, 1 level check to facilitate creating new subcategories. We don't support more complex operations
for record in records: record['x_cost_nature'] = record.x_cost_nature or record.parent_id.x_cost_nature
]]></field>
    </record>


    <record id="action_compute_cost_nature_analysis_report" model="ir.actions.server">
        <field name="model_id" ref="product.model_product_product"/>
        <field name="state">code</field>
        <field name="name">Construction Developer: Compute Cost Nature Analysis</field>
        <field name="code"><![CDATA[
# NB: apparently SQL queries are not counted as maintenance lines

# Since a simple server action executed only once in e.g. ir_model_post.xml to 
# drop the db after model creation (and not check its type every time this server action runs)
# does not work on the runbot for some reason, do the following instead
# Ask Postgres what the type of 'x_cost_nature_analysis_report' currently is
env.cr.execute('''
    SELECT relkind 
    FROM pg_class 
    WHERE relname = 'x_cost_nature_analysis_report'
''')
result = env.cr.fetchone()  # fetch the result of the query that was just executed

# Drop the physical TABLE Odoo auto-created (no _auto = False in XML model) when creating the model
# We need this code to create this model as a VIEW and not a TABLE (auto-created)
# 'r': ordinary TABLE, i.e. not a VIEW ('v')
if result and result[0] == 'r': env.cr.execute('DROP TABLE x_cost_nature_analysis_report CASCADE')

# action called from a project: fetch the records from the project
# action called from a sale order: passed in the context as active_ids 
so_ids = (env.context.get('active_ids') if not (project_id := env.context.get('project_id')) else env['sale.order'].search([('project_id', '=', project_id)]).ids) or [0]

action = { 'name': "Cost Nature Analysis", 'view_mode': 'list', 'res_model': 'x_cost_nature_analysis_report', 'type': 'ir.actions.act_window',
           'context': {'view_id': 'view_x_margin_report_analysis_list', 'search_default_group_by_cost_nature': True, 'search_default_group_by_category': True, 'search_default_group_by_product': True }}

# skip the query if there are no sale orders
if so_ids != [0]:
    # Format the Python list into a valid SQL tuple string
    # e.g., [1, 2] becomes "(1, 2)" and [1] becomes "(1)"
    so_ids_sql = tuple(so_ids) if len(so_ids) > 1 else f"({so_ids[0]})"

    # Actual logic
    env.cr.execute(f'''
    CREATE OR REPLACE VIEW x_cost_nature_analysis_report AS (
        WITH raw_data AS (
            SELECT sol.order_id AS x_so_id,
                wil.x_work_item_id AS x_work_item_id,

                COALESCE(wil.x_quantity * sol.product_uom_qty, sol.product_uom_qty) AS x_quantity, -- COALESCE looks at WIL first; if it's NULL (no work item), it uses SOL.
                COALESCE(wil.x_product_id, sol.product_id) AS x_product_id,
                COALESCE(wil.x_cost_nature, sol.x_cost_nature) AS x_cost_nature,
                COALESCE(wil.x_category_id, sol.x_category_id) AS x_category_id,
                COALESCE(wil.x_unit_price * wil.x_quantity * sol.product_uom_qty, sol.price_unit * sol.product_uom_qty) AS x_total_price,
                COALESCE(wil.x_unit_cost * wil.x_quantity * sol.product_uom_qty, sol.purchase_price * sol.product_uom_qty) AS x_total_cost,

                COALESCE(wil.x_quantity * (wil.x_unit_price - wil.x_unit_cost) * sol.product_uom_qty, 
                            sol.product_uom_qty * (sol.price_unit - sol.purchase_price)) AS x_margin,

                CASE WHEN wil.x_work_item_id IS NOT NULL
                        THEN (wil.x_unit_price - wil.x_unit_cost) / NULLIF(wil.x_unit_price, 0)
                        ELSE (sol.price_unit - sol.purchase_price) / NULLIF(sol.price_unit, 0) 
                END AS x_margin_percent
            FROM sale_order_line sol LEFT JOIN x_work_item_line wil 
            ON sol.x_line_work_item_id = wil.x_work_item_id
            WHERE sol.display_type IS NULL AND sol.product_id IS NOT NULL
            AND sol.order_id IN {so_ids_sql}
        )
        SELECT 
            ROW_NUMBER() OVER () AS id,
            *, -- take everything from the previous table

            -- Individual Margin / Total Margin of all rows
            x_margin / NULLIF(SUM(x_margin) OVER (), 0) AS x_margin_share,
            
            -- Individual Cost / Total Cost of all rows
            x_total_cost / NULLIF(SUM(x_total_cost) OVER (), 0) AS x_cost_share

        FROM raw_data)''')

    # add active_ids to the context of the action
    action['context']['active_ids'] = so_ids
]]></field>
    </record>


<!-- Cost Nature Analysis views -->
     <record id="view_x_cost_nature_analysis_report_search" model="ir.ui.view">
        <field name="name">construction_developer.x_cost_nature_analysis_report.view.search</field>
        <field name="model">x_cost_nature_analysis_report</field>
        <field name="type">search</field>
        <field name="active" eval="True"/>
        <field name="arch" type="xml">
            <search>
                <field name="x_so_id" string="Sale Order" filter_domain="[('x_so_id.name', 'ilike', self)]"/>
                <field name="x_work_item_id" string="Work Item" filter_domain="[('x_work_item_id.x_name', 'ilike', self)]"/>
                <field name="x_product_id" string="Product" filter_domain="[('x_product_id.name', 'ilike', self)]"/>
                <field name="x_category_id" string="Category" filter_domain="[('x_category_id.name', 'ilike', self)]"/>
                <field name="x_cost_nature" string="Cost Nature" filter_domain="[('x_cost_nature', 'ilike', self)]"/>
                <separator/>
                <filter string="Material" name="material" domain="[('x_cost_nature', '=', 'material')]"/>
                <filter string="Equipment" name="equipment" domain="[('x_cost_nature', '=', 'equipment')]"/>
                <filter string="Labour" name="labour" domain="[('x_cost_nature', '=', 'labour')]"/>
                <separator/>
                <filter string="Positive Margin" name="positive_margin" domain="[('x_margin', '>', 0)]"/>
                <filter string="Negative Margin" name="negative_margin" domain="[('x_margin', '&lt;', 0)]"/>
                <separator/>
                <group>
                    <filter string="Cost Nature" name="group_by_cost_nature" context="{'group_by': 'x_cost_nature'}"/>
                    <filter string="Category" name="group_by_category" context="{'group_by': 'x_category_id'}"/>
                    <filter string="Sale Order" name="group_by_sale_order" context="{'group_by': 'x_so_id'}"/>
                    <filter string="Product" name="group_by_product" context="{'group_by': 'x_product_id'}"/>
                    <filter string="Work Item" name="group_by_work_item" context="{'group_by': 'x_work_item_id'}"/>
                </group>
            </search>
        </field>
    </record>
    <record id="view_x_margin_report_analysis_list" model="ir.ui.view">
        <field name="name">x_cost_nature_analysis_report.view.list</field>
        <field name="model">x_cost_nature_analysis_report</field>
        <field name="active" eval="True"/>
        <field name="arch" type="xml">
            <list string="Cost Nature Analysis" default_order="x_margin DESC, x_total_cost DESC">
                <field name="x_cost_nature" optional="hide"/>
                <field name="x_category_id" widget="many2one" optional="hide"/>
                <field name="x_so_id" widget="many2one" optional="hide"/>
                <field name="x_product_id" widget="many2one" optional="show"/>
                <field name="x_work_item_id" widget="many2one" optional="show"/>
                <field name="x_quantity" optional="hide"/>
                <field name="x_total_price" sum="Sum of Prices" optional="show"/>
                <field name="x_total_cost" sum="Sum of Costs" optional="show"/>
                <field name="x_cost_share" widget="percentage" sum="Sum of Cost Shares" optional="show"/>
                <field name="x_margin" sum="Sum of Margins" optional="show"/>
                <field name="x_margin_percent" widget="percentage" avg="Average Margin" optional="show"/>
                <field name="x_margin_share" widget="percentage" sum="Sum of Margin Shares" optional="show"/>
            </list>
        </field>
    </record>
</odoo>
