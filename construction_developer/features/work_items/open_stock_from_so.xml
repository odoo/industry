<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <!-- make a new action to remove hardcoded location in the context to be able to pass it ourselves -->
    <record model="ir.actions.act_window" id="action_ws_product_location_open">
        <field name="name">Worksite Stock</field>
        <field name="res_model">product.product</field>
        <field name="search_view_id" ref="stock.stock_product_search_form_view"/>
        <field name="context">{'search_default_real_stock_available': 1, 'search_default_virtual_stock_available': 1,
                    'search_default_virtual_stock_negative': 1, 'search_default_real_stock_negative': 1, 'create': False}</field>
    </record>
</odoo>
