<?xml version='1.0' encoding='UTF-8'?>
<odoo>
<!-- product.category -->
     <record id="field_product_category_x_cost_nature" model="ir.model.fields">
        <field name="name">x_cost_nature</field>
        <field name="field_description">Cost Nature</field>
        <field name="ttype">selection</field>
        <field name="model_id" ref="product.model_product_category"/>
    </record>
    <record id="selection_field_product_category_x_cost_nature_labour" model="ir.model.fields.selection">
        <field name="name">Labour</field>
        <field name="field_id" ref="field_product_category_x_cost_nature"/>
        <field name="value">labour</field>
    </record>
    <record id="selection_field_product_category_x_cost_nature_material" model="ir.model.fields.selection">
        <field name="name">Material</field>
        <field name="field_id" ref="field_product_category_x_cost_nature"/>
        <field name="value">material</field>
    </record>
    <record id="selection_field_product_category_x_cost_nature_equipment" model="ir.model.fields.selection">
        <field name="name">Equipment</field>
        <field name="field_id" ref="field_product_category_x_cost_nature"/>
        <field name="value">equipment</field>
    </record>
<!-- product.template -->
    <record id="field_product_template_x_uom_matches_category" model="ir.model.fields">
        <field name="name">x_uom_matches_category</field>
        <field name="field_description">UOM Matches Category</field>
        <field name="ttype">boolean</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="store" eval="False"/>
        <field name="copied" eval="False"/>
        <field name="readonly" eval="True"/>
        <field name="depends">categ_id,uom_id</field>
        <field name="compute"><![CDATA[
for record in self:
    record['x_uom_matches_category'] = record.categ_id.x_cost_nature not in ['equipment', 'labour'] or (record.uom_id and record.uom_id._has_common_reference(self.env.ref('uom.product_uom_hour')))
]]></field>
    </record>
<!-- x_cost_nature_analysis_report -->
    <record id="field_x_cost_nature_analysis_report_x_category_id" model="ir.model.fields">
        <field name="model_id" ref="model_x_cost_nature_analysis_report"/>
