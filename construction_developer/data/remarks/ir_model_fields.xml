<?xml version='1.0' encoding='UTF-8'?>
<odoo>
<!-- Remark Stage -->
    <record id="field_x_remark_stage_x_name" model="ir.model.fields">
        <field name="model_id" ref="model_x_remark_stage"/>
        <field name="ttype">char</field>
        <field name="name">x_name</field>
        <field name="field_description">Name</field>
        <field name="required" eval="True"/>
    </record>
    <record id="field_x_remark_stage_x_sequence" model="ir.model.fields">
        <field name="model_id" ref="model_x_remark_stage"/>
        <field name="ttype">integer</field>
        <field name="name">x_sequence</field>
        <field name="field_description">Sequence</field>
    </record>
    <record id="field_x_remark_stage_x_project_ids" model="ir.model.fields">
        <field name="model_id" ref="model_x_remark_stage"/>
        <field name="ttype">many2many</field>
        <field name="name">x_project_ids</field>
        <field name="field_description">Projects</field>
        <field name="relation">project.project</field>
        <field name="relation_field">x_remark_stage_ids</field>
    </record>

<!-- Remark Category -->
    <record id="field_x_remark_category_x_name" model="ir.model.fields">
        <field name="model_id" ref="model_x_remark_category"/>
        <field name="ttype">char</field>
        <field name="name">x_name</field>
        <field name="field_description">Name</field>
        <field name="required" eval="True"/>
    </record>
    <record id="field_x_remark_category_x_color" model="ir.model.fields">
        <field name="model_id" ref="model_x_remark_category"/>
        <field name="ttype">integer</field>
        <field name="name">x_color</field>
        <field name="field_description">Color</field>
    </record>

<!-- Remark -->
    <record id="field_x_remark_x_name" model="ir.model.fields">
        <field name="model_id" ref="model_x_remark"/>
        <field name="ttype">char</field>
        <field name="name">x_name</field>
        <field name="field_description">Name</field>
    </record>
    <record id="field_x_remark_x_priority" model="ir.model.fields">
        <field name="model_id" ref="model_x_remark"/>
        <field name="ttype">selection</field>
        <field name="name">x_priority</field>
        <field name="field_description">Priority</field>
    </record>
     <record id="field_x_remark_x_priority_selection_0" model="ir.model.fields.selection">
        <field name="name">Low Priority</field>
        <field name="field_id" ref="field_x_remark_x_priority"/>
        <field name="value">0</field>
    </record>
    <record id="field_x_remark_x_priority_selection_1" model="ir.model.fields.selection">
        <field name="name">Medium Priority</field>
        <field name="field_id" ref="field_x_remark_x_priority"/>
        <field name="value">1</field>
    </record>
    <record id="field_x_remark_x_priority_selection_2" model="ir.model.fields.selection">
        <field name="name">High Priority</field>
        <field name="field_id" ref="field_x_remark_x_priority"/>
        <field name="value">2</field>
    </record>
    <record id="field_x_remark_x_priority_selection_3" model="ir.model.fields.selection">
        <field name="name">Urgent</field>
        <field name="field_id" ref="field_x_remark_x_priority"/>
        <field name="value">3</field>
    </record>

    <record id="field_x_remark_x_state" model="ir.model.fields">
        <field name="model_id" ref="model_x_remark"/>
        <field name="ttype">selection</field>
        <field name="name">x_state</field>
        <field name="field_description">State</field>
    </record>
     <record id="field_x_remark_x_state_selection_in_progress" model="ir.model.fields.selection">
        <field name="name">In Progress</field>
        <field name="field_id" ref="field_x_remark_x_state"/>
        <field name="value">01_in_progress</field>
    </record>
    <record id="field_x_remark_x_state_selection_changes_requested" model="ir.model.fields.selection">
        <field name="name">Changes Requested</field>
        <field name="field_id" ref="field_x_remark_x_state"/>
        <field name="value">02_changes_requested</field>
    </record>
    <record id="field_x_remark_x_state_selection_approved" model="ir.model.fields.selection">
        <field name="name">Approved</field>
        <field name="field_id" ref="field_x_remark_x_state"/>
        <field name="value">03_approved</field>
    </record>
    <record id="field_x_remark_x_state_selection_done" model="ir.model.fields.selection">
        <field name="name">Done</field>
        <field name="field_id" ref="field_x_remark_x_state"/>
        <field name="value">1_done</field>
    </record>
    <record id="field_x_remark_x_state_selection_canceled" model="ir.model.fields.selection">
        <field name="name">Canceled</field>
        <field name="field_id" ref="field_x_remark_x_state"/>
        <field name="value">1_canceled</field>
    </record>

    <record id="field_x_remark_x_project_id" model="ir.model.fields">
        <field name="model_id" ref="model_x_remark"/>
        <field name="ttype">many2one</field>
        <field name="relation">project.project</field>
        <field name="name">x_project_id</field>
        <field name="field_description">Project</field>
    </record>
    <record id="field_x_remark_x_description" model="ir.model.fields">
        <field name="model_id" ref="model_x_remark"/>
        <field name="ttype">html</field>
        <field name="name">x_description</field>
        <field name="field_description">Description</field>
    </record>
    <record id="field_x_remark_x_date_deadline" model="ir.model.fields">
        <field name="model_id" ref="model_x_remark"/>
        <field name="ttype">date</field>
        <field name="name">x_date_deadline</field>
        <field name="field_description">Deadline</field>
    </record>
    <record id="field_x_remark_x_date" model="ir.model.fields">
        <field name="model_id" ref="model_x_remark"/>
        <field name="ttype">date</field>
        <field name="name">x_date</field>
        <field name="field_description">Date</field>
        <field name="compute"><![CDATA[
for record in self: record['x_date'] = record['x_date'] or datetime.datetime.today().date()
]]></field>
    </record>
    <record id="field_x_remark_x_reference" model="ir.model.fields">
        <field name="model_id" ref="model_x_remark"/>
        <field name="ttype">char</field>
        <field name="name">x_reference</field>
        <field name="field_description">Reference</field>
        <field name="readonly" eval="True"/>
    </record>
    <record id="field_x_remark_x_location" model="ir.model.fields">
        <field name="model_id" ref="model_x_remark"/>
        <field name="ttype">char</field>
        <field name="name">x_location</field>
        <field name="field_description">Location</field>
    </record>
    <record id="field_x_remark_x_category" model="ir.model.fields">
        <field name="model_id" ref="model_x_remark"/>
        <field name="ttype">many2many</field>
        <field name="relation">x_remark_category</field>
        <field name="name">x_remark_category_ids</field>
        <field name="field_description">Category</field>
    </record>
    <record id="field_x_remark_x_event_id" model="ir.model.fields">
        <field name="model_id" ref="model_x_remark"/>
        <field name="ttype">many2one</field>
        <field name="relation">calendar.event</field>
        <field name="name">x_event_id</field>
        <field name="field_description">Event</field>
        <field name="readonly" eval="True"/>
    </record>
    <record id="field_x_remark_x_project_update_id" model="ir.model.fields">
        <field name="model_id" ref="model_x_remark"/>
        <field name="ttype">many2one</field>
        <field name="relation">project.update</field>
        <field name="name">x_update_id</field>
        <field name="field_description">Project Update</field>
        <field name="readonly" eval="True"/>
    </record>
    <record id="field_x_remark_x_partner_id" model="ir.model.fields">
        <field name="model_id" ref="model_x_remark"/>
        <field name="ttype">many2one</field>
        <field name="relation">res.partner</field>
        <field name="name">x_partner_id</field>
        <field name="field_description">Owner</field>
    </record>
    <record id="field_x_remark_x_stage_id" model="ir.model.fields">
        <field name="model_id" ref="model_x_remark"/>
        <field name="ttype">many2one</field>
        <field name="relation">x_remark_stage</field>
        <field name="name">x_stage_id</field>
        <field name="field_description">Remark Stage</field>
        <field name="group_expand" eval="True"/>
    </record>


<!-- 
    Remarks: External Models
-->
<!-- calendar.event -->
    <record id="field_event_x_project_id" model="ir.model.fields">
        <field name="model_id" ref="calendar.model_calendar_event"/>
        <field name="ttype">many2one</field>
        <field name="relation">project.project</field>
        <field name="name">x_project_id</field>
        <field name="field_description">Project</field>
    </record>
    <record id="field_event_x_remark_ids" model="ir.model.fields">
        <field name="model_id" ref="calendar.model_calendar_event"/>
        <field name="ttype">one2many</field>
        <field name="relation">x_remark</field>
        <field name="relation_field">x_event_id</field>
        <field name="name">x_remark_ids</field>
        <field name="field_description">Remarks</field>
    </record>
<!-- project.project -->
    <record id="field_project_x_remark_stage_ids" model="ir.model.fields">
        <field name="model_id" ref="project.model_project_project"/>
        <field name="ttype">many2many</field>
        <field name="name">x_remark_stage_ids</field>
        <field name="field_description">Remark Stages</field>
        <field name="relation">x_remark_stage</field>
        <field name="relation_field">x_project_ids</field>
    </record>
<!-- project.update -->
    <record id="field_project_update_x_remark_ids" model="ir.model.fields">
        <field name="model_id" ref="project.model_project_update"/>
        <field name="ttype">one2many</field>
        <field name="relation">x_remark</field>
        <field name="relation_field">x_update_id</field>
        <field name="name">x_remark_ids</field>
        <field name="field_description">Remarks</field>
    </record>
</odoo>
