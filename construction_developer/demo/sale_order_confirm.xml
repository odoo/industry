<?xml version='1.0' encoding='UTF-8'?>
<odoo noupdate="1" context="{'mail_auto_subscribe_no_notify': True}">

    <!-- Confirm sale orders and assign XML IDs to their created projects -->
    <!-- S00003 -->
    <function name="action_confirm" model="sale.order" eval="[[ref('sale_order_41')]]"/>
    <function model="ir.model.data" name="_update_xmlids">
        <value model="project.project" eval="[{'xml_id': 'construction_developer.project_project_16', 'record': obj().search([('sale_order_id', '=', ref('construction_developer.sale_order_41'))])}]"/>
    </function>

    <record id="sale_advance_payment_inv_1" model="sale.advance.payment.inv">
        <field name="advance_payment_method">delivered</field>
        <field name="sale_order_ids" eval="[Command.set([ref('sale_order_41')])]"/>
    </record>

    <function name="create_invoices" model="sale.advance.payment.inv" eval="[ref('sale_advance_payment_inv_1')]"/>
    <function name="action_post" model="account.move" eval="[obj().search([('line_ids.sale_line_ids.order_id', 'in', ref('sale_order_41'))]).ids]"/>
</odoo>
