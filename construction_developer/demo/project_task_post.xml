<?xml version='1.0' encoding='UTF-8'?>
<odoo noupdate="1">
<!-- 
    These tasks were created by the creation of the WBS.
    Assigns them an ID to be used in other files.
-->

    <!-- S00003: Ground (section) -->
    <function name="write" model="project.task">
        <value model="project.task" eval="obj().search([
            ('sale_line_id', '=', ref('construction_developer.sale_order_line_325'))
        ], limit=1).id"/>
        <value eval="{
            'stage_id': ref('construction.planning_project_stage_3'),
            'state': '1_done',
        }"/>
    </function>

    <!-- S00003: Ground Preparation -->
    <function model="ir.model.data" name="_update_xmlids">
        <value model="project.task" eval="[{
            'xml_id': 'construction_developer.project_task_319', 
            'record': obj().search([('sale_line_id', '=', ref('construction_developer.sale_order_line_319'))], limit=1)}]"/>
    </function>
    <record id="project_task_319" model="project.task">
        <field name="stage_id" ref="construction.planning_project_stage_3" />
        <field name="state">1_done</field>
        <field name="planned_date_start" eval="datetime.today().date() - relativedelta(days=3)"/>
        <field name="date_deadline" eval="datetime.today().date() - relativedelta(days=3)"/>
    </record>

