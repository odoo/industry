<?xml version='1.0' encoding='UTF-8'?>
<odoo noupdate="1" context="{'mail_auto_subscribe_no_notify': True}">
  <record id="sale_order_41" model="sale.order">
    <field name="partner_id" ref="res_partner_30"/>
    <field name="sale_order_template_id" ref="sale_order_template_2"/>
    <field name="prepayment_percent">1.0</field>
    <field name="user_id" ref="base.user_admin"/>
    <field name="x_so_contract_type">fixed_price</field>
  </record>
  <!-- trigger the addition of all the quotation template lines to the SO -->
  <function name="_onchange_sale_order_template_id" model="sale.order" eval="[[ref('sale_order_41')]]"/>


  <record id="construction.sale_order_1" model="sale.order" forcecreate="0">
    <field name="x_so_contract_type">per_line</field>
    <field name="user_id" ref="base.user_admin"/>
  </record>
  <record id="construction.sale_order_6" model="sale.order" forcecreate="0">
    <field name="x_so_contract_type">per_line</field>
    <field name="user_id" ref="base.user_admin"/>
  </record>
</odoo>
