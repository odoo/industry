<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="mail.Chatter" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('o-mail-AttachmentBox')]" position="attributes">
            <attribute
                name="t-if"
                separator=" or "
                add="this.env.searchModel.context.force_open_attachments"/>
        </xpath>
    </t>
</templates>
