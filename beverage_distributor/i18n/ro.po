msgid ""
"85% of our clients have trusted us for their beverage distribution needs for "
"over five years."
msgstr ""
"85% dintre clienții noștri ne-au încredințat nevoile de distribuție a "
"băuturilor de peste cinci ani."

#. module: beverage_distributor
#: model_terms:ir.ui.view,arch_db:beverage_distributor.welcome_article_body
msgid ""
"<b>Barcode App</b>: Accelerate picking and packing processes with mobile "
"scanners, ensuring accurate\n"
"                            inventory counts and faster loading."
msgstr ""
"<b>Aplicația cu coduri de bare</b>: Accelerează procesele de picking și "
"ambalare cu scanere mobile, asigurând numărătoarea\n"
"                            precisă a inventarului și încărcarea mai rapidă."

#. module: beverage_distributor
#: model_terms:ir.ui.view,arch_db:beverage_distributor.welcome_article_body
msgid ""
"<b>Inventory App</b>: Serve as the central hub for stock, managing "
"consignments, batch tracking, and\n"
"                            warehouse operations with precision."
msgstr ""
"<b>Aplicația de inventar</b>: Funcționează ca centrul de control pentru "
"stoc, gestionând consignațiile, urmărirea loturilor și\n"
"                            operațiunile de depozit cu precizie."

#. module: beverage_distributor
#: model_terms:ir.ui.view,arch_db:beverage_distributor.welcome_article_body
msgid ""
"<b>Manufacturing App</b>: Manage the repackaging of bulk items into smaller "
"saleable units automatically."
msgstr ""
"<b>Aplicația de producție</b>: Gestionează reambalarea articolelor în vrac "
"în unități mai mici de vânzare automat."

#. module: beverage_distributor
#: model_terms:ir.ui.view,arch_db:beverage_distributor.welcome_article_body
msgid ""
"<b>Point of Sale App</b>: process B2C sales efficiently at your distribution "
"center's front counter or\n"
"                            cash-and-carry section."
msgstr ""
"<b>Aplicația punct de vânzare</b>: procesează eficient vânzările B2C la "
"ghișeul din față al centrului de distribuție sau\n"
"                            secțiunea cash-and-carry."

#. module: beverage_distributor
#: model_terms:ir.ui.view,arch_db:beverage_distributor.welcome_article_body
msgid ""
"<b>Purchase App</b>: Automate replenishment from suppliers, ensuring you "
"have the right mix of beverages to\n"
"                            meet seasonal demand."
msgstr ""
"<b>Aplicația de achiziții</b>: Automatizează reaprovizionarea de la "
"furnizori, asigurându-te că ai mixul corect de băuturi pentru\n"
"                            a satisface cererea sezonieră."

#. module: beverage_distributor
#: model_terms:ir.ui.view,arch_db:beverage_distributor.welcome_article_body
msgid ""
"<b>Sales App</b>: Handle high-volume client orders and manage complex "
"product catalogs with varying units of\n"
"                            measure (e.g., crate vs. bottle)."
msgstr ""
"<b>Aplicația de vânzări</b>: Gestionează comenzile clienților cu volum mare "
"și administrează cataloguri complexe de produse cu unități de\n"
"                            măsură variabile (de ex., ladă vs. sticlă)."

#. module: beverage_distributor
#: model_terms:ir.ui.view,arch_db:beverage_distributor.welcome_article_body
msgid ""
"<b>eCommerce App</b>: Expand your reach with a B2B portal that allows "
"restaurants and retailers to place\n"
"                            restocking orders online 24/7."
msgstr ""
"<b>Aplicația eCommerce</b>: Extinde-ți raza de acțiune cu un portal B2B care "
"permite restaurantelor și retailerilor să plaseze\n"
"                            comenzi de reaprovizionare online 24/7."

