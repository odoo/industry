#: model_terms:ir.ui.view,arch_db:candy_shop.welcome_article_body
msgid ""
"<strong>Inventory</strong>: Track stock levels, manage reorders, and prevent "
"shortages."
msgstr ""
"<strong>Inventário</strong>: Monitore os níveis de estoque, gerencie novos "
"pedidos e evite a falta de produtos."

#. module: candy_shop
#: model_terms:ir.ui.view,arch_db:candy_shop.welcome_article_body
msgid ""
"<strong>Loyalty Programs</strong>: Reward repeat customers with loyalty "
"points and discounts."
msgstr ""
"<strong>Programas de fidelidade</strong>: Recompense os clientes fiéis com "
"pontos de fidelidade e descontos."

#. module: candy_shop
#: model_terms:ir.ui.view,arch_db:candy_shop.welcome_article_body
msgid "<strong>Managing Stock Automatically</strong>:"
msgstr "<strong>Gerenciamento automático de estoque</strong>:"

#. module: candy_shop
#: model_terms:ir.ui.view,arch_db:candy_shop.welcome_article_body
msgid ""
"<strong>Marketing Automation</strong>: Set up email campaigns to promote new "
"products and special offers."
msgstr ""
"<strong>Automação de marketing</strong>: Configure campanhas por e-mail para "
"promover novos produtos e ofertas especiais."

