#. module: candy_shop
#: model_terms:ir.ui.view,arch_db:candy_shop.welcome_article_body
msgid ""
"<strong>Email Marketing</strong>: Send newsletters to keep customers updated "
"on promotions, seasonal products, and new arrivals."
