#: model_terms:ir.ui.view,arch_db:candy_shop.welcome_article_body
msgid "<strong>Handling Online Orders</strong>:"
msgstr "<strong>Gestión de órdenes en línea</strong>:"

#. module: candy_shop
#: model_terms:ir.ui.view,arch_db:candy_shop.welcome_article_body
msgid ""
"<strong>Inventory</strong>: Track stock levels, manage reorders, and prevent "
"shortages."
msgstr ""
"<strong>Inventario</strong>: Rastrea los niveles de stock, gestiona "
"reabastecimientos y evita que te quedes sin existencias."

#. module: candy_shop
#: model_terms:ir.ui.view,arch_db:candy_shop.welcome_article_body
msgid ""
"<strong>Loyalty Programs</strong>: Reward repeat customers with loyalty "
"points and discounts."
msgstr ""
"<strong>Programas de lealtad</strong>: Premia a los clientes frecuentes con "
"puntos de lealtad y descuentos."

#. module: candy_shop
#: model_terms:ir.ui.view,arch_db:candy_shop.welcome_article_body
msgid "<strong>Managing Stock Automatically</strong>:"
msgstr "<strong>Gestión automática de existencias</strong>:"

#. module: candy_shop
#: model_terms:ir.ui.view,arch_db:candy_shop.welcome_article_body
msgid ""
"<strong>Marketing Automation</strong>: Set up email campaigns to promote new "
"products and special offers."
msgstr ""
"<strong>Automatización de marketing</strong>: Configura campañas de correo "
"para promocionar productos nuevos y ofertas especiales."

