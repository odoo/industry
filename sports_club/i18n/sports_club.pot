#: model_terms:ir.ui.view,arch_db:sports_club.welcome_article_body
msgid ""
"<strong>Instant Member Scanning:</strong> Link unique barcodes to your\n"
"                            members' profiles. Staff can simply scan a physical or digital\n"
"                            membership card at the bar to instantly apply their preferential\n"
"                            discounts or tab the drinks to their account."
msgstr ""

#. module: sports_club
#: model_terms:ir.ui.view,arch_db:sports_club.welcome_article_body
