        <field name="group_stock_lot_print_gs1" eval="1"/>
        <field name="enabled_extra_checkout_step" eval="1"/>
        <field name="group_cash_rounding" eval="1"/>
        <field name="group_stock_multi_locations" eval="1"/>
        <field name="group_stock_adv_location" eval="1"/>
