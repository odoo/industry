<?xml version='1.0' encoding='UTF-8'?>
<odoo noupdate="1">

    <record id="production_schedule_1" model="mrp.production.schedule">
        <field name="product_id" ref="product_product_3"/>
        <field name="replenish_trigger">manual</field>
        <field name="enable_batch_size" eval="True"/>
        <field name="batch_size">200.0</field>
    </record>
    <record id="production_schedule_2" model="mrp.production.schedule">
        <field name="product_id" ref="product_product_12"/>
        <field name="replenish_trigger">manual</field>
        <field name="bom_id" ref="mrp_bom_2"/>
        <field name="forecast_target_qty">220.0</field>
    </record>
    <record id="production_schedule_3" model="mrp.production.schedule">
        <field name="product_id" ref="product_product_13"/>
        <field name="replenish_trigger">manual</field>
        <field name="bom_id" ref="mrp_bom_3"/>
        <field name="forecast_target_qty">330.0</field>
    </record>

    <record id="forecast_1" model="mrp.product.forecast">
        <field name="production_schedule_id" ref="production_schedule_2"/>
        <field name="date" eval="DateTime.today()"/>
        <field name="replenish_qty">220</field>
        <field name="replenish_qty_updated" eval="True"/>
    </record>
    <record id="forecast_2" model="mrp.product.forecast">
        <field name="production_schedule_id" ref="production_schedule_2"/>
        <field name="date" eval="DateTime.today() + relativedelta(months=1)"/>
        <field name="replenish_qty">240</field>
        <field name="replenish_qty_updated" eval="True"/>
    </record>
    <record id="forecast_3" model="mrp.product.forecast">
        <field name="production_schedule_id" ref="production_schedule_2"/>
        <field name="date" eval="DateTime.today() + relativedelta(months=2)"/>
        <field name="replenish_qty">250</field>
        <field name="replenish_qty_updated" eval="True"/>
    </record>
    <record id="forecast_4" model="mrp.product.forecast">
        <field name="production_schedule_id" ref="production_schedule_2"/>
        <field name="date" eval="DateTime.today() + relativedelta(months=3)"/>
        <field name="replenish_qty">260</field>
        <field name="replenish_qty_updated" eval="True"/>
    </record>
    <record id="forecast_5" model="mrp.product.forecast">
        <field name="production_schedule_id" ref="production_schedule_3"/>
        <field name="date" eval="DateTime.today()"/>
        <field name="replenish_qty">330</field>
        <field name="replenish_qty_updated" eval="True"/>
    </record>
    <record id="forecast_6" model="mrp.product.forecast">
        <field name="production_schedule_id" ref="production_schedule_3"/>
        <field name="date" eval="DateTime.today() + relativedelta(months=1)"/>
        <field name="replenish_qty">360</field>
        <field name="replenish_qty_updated" eval="True"/>
    </record>
    <record id="forecast_7" model="mrp.product.forecast">
        <field name="production_schedule_id" ref="production_schedule_3"/>
        <field name="date" eval="DateTime.today() + relativedelta(months=2)"/>
        <field name="replenish_qty">380</field>
        <field name="replenish_qty_updated" eval="True"/>
    </record>
    <record id="forecast_8" model="mrp.product.forecast">
        <field name="production_schedule_id" ref="production_schedule_3"/>
        <field name="date" eval="DateTime.today() + relativedelta(months=3)"/>
        <field name="replenish_qty">400</field>
        <field name="replenish_qty_updated" eval="True"/>
    </record>
    

    <function name="action_replenish" model="mrp.production.schedule">
        <value eval="[
            ref('production_schedule_1'),
            ref('production_schedule_2'),
            ref('production_schedule_3'),
        ]"/>
    </function>
</odoo>
