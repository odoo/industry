<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="x_setting_field_approvers" model="ir.model.fields">
        <field name="ttype">boolean</field>
        <field name="field_description">Approvers</field>
        <field name="model_id" ref="base_setup.model_res_config_settings"/>
        <field name="name">x_setting_approvers</field>
        <field name="store" eval="True"/>
        <field name="compute"><![CDATA[
self['x_setting_approvers'] = self.env['ir.config_parameter'].get_param('house_keeping.x_approvers_setting', '0') == '1'
]]></field>
    </record>
    <record id="x_setting_field_approver_users_ids" model="ir.model.fields">
        <field name="ttype">many2many</field>
        <field name="relation">res.users</field>
        <field name="field_description">Users</field>
        <field name="model_id" ref="base_setup.model_res_config_settings"/>
        <field name="name">x_setting_approver_users_ids</field>
        <field name="store" eval="True"/>
        <field name="compute"><![CDATA[
param = self.env['ir.config_parameter'].get_param('house_keeping.x_approver_users_ids_setting', 'a')
self['x_setting_approver_users_ids'] = [(6, 0, [int(u) for u in param.split(',')])] if param != 'a' else [(5, 0)]
]]></field>
    </record>
    <record id="res_config_settings_form_view_inherited" model="ir.ui.view">
        <field name="name">res.config.settings.form.view.inherited.house.keeping</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="40"/>
        <field name="active" eval="True"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Accomodation" name="accomodation">
                    <block title="House Keeping" name="house_keeping_config_block">
                        <setting id="approvers_setting_house_keeping" help="Approval process to accept house keeping tasks.">
                            <field name="x_setting_approvers"/>
                            <div class="mt16" invisible="not x_setting_approvers">
                                <label for="x_setting_approver_users_ids" class="o_light_label mr8"/>
                                <field name="x_setting_approver_users_ids" class="oe_inline" widget="many2many_tags"/>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
    <record id="server_action_set_x_setting_approvers" model="ir.actions.server">
        <field name="name">HouseKeeping: Set approvers setting</field>
        <field name="code"><![CDATA[
env['ir.config_parameter'].set_param('house_keeping.x_approvers_setting', ('1' if record.x_setting_approvers else '0'))
]]></field>
        <field name="model_id" ref="base_setup.model_res_config_settings"/>
        <field name="state">code</field>
    </record>
    <record id="server_action_set_x_setting_approver_users_ids" model="ir.actions.server">
        <field name="name">HouseKeeping: Set approver users setting</field>
        <field name="code"><![CDATA[
approvers_ids_formated = ','.join(str(u.id) for u in record.x_setting_approver_users_ids) if (record.x_setting_approver_users_ids and record.x_setting_approvers) else 'a'
env['ir.config_parameter'].set_param('house_keeping.x_approver_users_ids_setting', approvers_ids_formated)
]]></field>
        <field name="model_id" ref="base_setup.model_res_config_settings"/>
        <field name="state">code</field>
    </record>
    <record id="automation_on_x_setting_approvers_set" model="base.automation">
        <field name="name">HouseKeeping: On approvers setting set</field>
        <field name="model_id" ref="base_setup.model_res_config_settings"/>
        <field name="action_server_ids" eval="[(6, 0, [ref('server_action_set_x_setting_approvers')])]"/>
        <field name="trigger">on_create_or_write</field>
        <field name="trigger_field_ids" eval="[(6, 0, [ref('x_setting_field_approvers')])]"/>
    </record>
    <record id="automation_on_x_setting_approver_users_ids_set" model="base.automation">
        <field name="name">HouseKeeping: On approver users setting set</field>
        <field name="model_id" ref="base_setup.model_res_config_settings"/>
        <field name="action_server_ids" eval="[(6, 0, [ref('server_action_set_x_setting_approver_users_ids')])]"/>
        <field name="trigger">on_create_or_write</field>
        <field name="trigger_field_ids" eval="[(6, 0, [ref('x_setting_field_approver_users_ids')])]"/>
    </record>
</odoo>
