<?xml version='1.0' encoding='UTF-8'?>
<odoo auto_sequence="1">
  <data noupdate="1">
    <function model="website.menu" name="write">
      <value model="website.menu"
      eval="obj().search([('website_id', '=', ref('base.default_website')), ('url', '=', '/shop')], limit=1).id" />
      <value eval="{'name': 'Stay Offers'}"/>
    </function>
  </data>
  <template id="custom_product_name" inherit_id="website_sale.products">
    <xpath expr="//h1[hasclass('h4-fs')]" position="replace">
      <h1 class="h4-fs">All Stay Offers</h1>
    </xpath>
  </template>
</odoo>
