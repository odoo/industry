msgid ""
"🎓\n"
"                Companies"
msgstr ""
"🎓\n"
"                Unternehmen"

#. module: campsite
#: model_terms:ir.ui.view,arch_db:campsite.welcome_article_body
msgid ""
"🎓\n"
"                Contacts"
msgstr ""
"🎓\n"
"            Kontakte"

#. module: campsite
