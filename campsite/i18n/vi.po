#. module: campsite
#: model_terms:ir.ui.view,arch_db:campsite.welcome_article_body
msgid "Charge your guests"
msgstr "Tính phí cho khách"

#. module: campsite
#: model_terms:product.template,description_ecommerce:campsite.product_template_6
msgid ""
"Charming and compact, these A-frame cabins blend rustic style with modern "
"convenience. A snug retreat for couples or solo travelers looking for a "
"warm, sheltered stay in nature."
msgstr ""
"Nhỏ nhắn và duyên dáng, những cabin hình chữ A này kết hợp phong cách mộc "
"mạc với tiện nghi hiện đại. Một nơi nghỉ dưỡng ấm áp, lý tưởng cho các cặp "
"đôi hoặc du khách một mình muốn tận hưởng không gian thiên nhiên có mái che."

#. module: campsite
#: model_terms:ir.ui.view,arch_db:campsite.homepage
msgid "Check Out Out Stay Offers"
msgstr "Khám phá các lựa chọn lưu trú của chúng tôi"

#. module: campsite
#: model_terms:ir.ui.view,arch_db:campsite.welcome_article_body
msgid "Check guests in"
msgstr "Check-in cho khách"

#. module: campsite
#: model_terms:ir.ui.view,arch_db:campsite.welcome_article_body
msgid "Check guests out"
msgstr "Check-out cho khách"

#. module: campsite
#: model_terms:ir.ui.view,arch_db:campsite.welcome_article_body
msgid "Check information and then confirm the booking."
msgstr "Kiểm tra thông tin và sau đó xác nhận đặt chỗ."

#. module: campsite
#: model_terms:ir.ui.view,arch_db:campsite.welcome_article_body
msgid "Click one of the offers to book."
msgstr "Nhấp vào một trong các lựa chọn để đặt chỗ."

#. module: campsite
#: model_terms:ir.ui.view,arch_db:campsite.welcome_article_body
msgid ""
"Click the Check in button to confirm they are now staying at your place!"
msgstr ""
"Nhấp vào nút check in để xác nhận rằng họ hiện đang lưu trú tại cơ sở của "
"bạn!"

#. module: campsite
#: model_terms:ir.ui.view,arch_db:campsite.welcome_article_body
msgid "Click the Check out button to capture they left their spot ."
msgstr "Nhấp vào nút Check out để ghi nhận rằng họ đã rời vị trí cắm trại."

#. module: campsite
#: model_terms:ir.ui.view,arch_db:campsite.welcome_article_body
msgid "Click the Create Order to open the order form."
msgstr "Nhấp vào Tạo đơn hàng để mở biểu mẫu đặt hàng."

#. module: campsite
#: model_terms:ir.ui.view,arch_db:campsite.welcome_article_body
msgid ""
