"المتكاملة تمامًا في<font class=\"text-o-color-5\">في </font><strong>\n"
"                    <font class=\"text-o-color-5\">اتطبيق المحاسبة</font>\n"
"                </strong><font class=\"text-o-color-5\">.</font>"

#. module: campsite
#: model_terms:ir.ui.view,arch_db:campsite.welcome_article_body
