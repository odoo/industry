<?xml version='1.0' encoding='UTF-8'?>
<odoo noupdate="1">
    <function name="action_confirm" model="sale.order">
        <value eval="[
            ref('sale_order_1'),
            ref('sale_order_2'),
            ref('sale_order_3'),
        ]"/>
    </function>

    <record id="x_guests_line_1" model="x_guests_line">
        <field name="x_sale_order_id" ref="sale_order_1"/>
        <field name="x_guest_partner_id" ref="base_industry_data.res_partner_20"/>
        <field name="x_room_resource_id" model="resource.resource" eval="obj().env.ref('campsite.sale_order_1').order_line[:1].x_resource_id.id"/>
    </record>
    <record id="x_guests_line_2" model="x_guests_line">
        <field name="x_sale_order_id" ref="sale_order_2"/>
        <field name="x_guest_partner_id" ref="base_industry_data.res_partner_21"/>
        <field name="x_room_resource_id" model="resource.resource" eval="obj().env.ref('campsite.sale_order_2').order_line[:1].x_resource_id.id"/>
    </record>
    <record id="x_guests_line_3" model="x_guests_line">
