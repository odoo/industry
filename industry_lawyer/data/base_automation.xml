<?xml version='1.0' encoding='UTF-8'?>
<odoo>
  <record id="automation_update_additional_contacts_of_mail_compose" model="base.automation">
    <field name="model_id" ref="mail.model_mail_compose_message"/>
    <field name="trigger">on_change</field>
    <field name="name">Update Partners In Mail</field>
    <field name="action_server_ids" eval="[(6, 0, [ref('action_update_additional_contacts')])]"/>
    <field name="on_change_field_ids" eval="[(6, 0, [ref('mail.field_mail_compose_message__author_id')])]"/>
  </record>
  <record id="automation_update_additional_contacts_of_account_move_send" model="base.automation">
    <field name="model_id" ref="account.model_account_move_send_wizard"/>
    <field name="trigger">on_change</field>
    <field name="name">Update Additional Contacts in Account Move Send</field>
    <field name="action_server_ids" eval="[(6, 0, [ref('action_update_additional_contacts_in_account_move_send')])]"/>
    <field name="on_change_field_ids" eval="[(6, 0, [ref('account.field_account_move_send_wizard__move_id')])]"/>
  </record>
  <record id="automation_for_devide_share" model="base.automation">
    <field name="model_id" ref="model_claimants_line"/>
    <field name="trigger">on_create</field>
    <field name="action_server_ids" eval="[(6, 0, [ref('action_devide_share_equally')])]"/>
    <field name="name">create</field>
  </record>
