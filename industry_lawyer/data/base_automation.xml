<?xml version='1.0' encoding='UTF-8'?>
<odoo>
  <record id="automation_update_additional_contacts_of_mail_compose" model="base.automation">
    <field name="model_id" ref="mail.model_mail_compose_message"/>
    <field name="trigger">on_change</field>
    <field name="name">Update Partners Of Mail Composition</field>
    <field name="action_server_ids" eval="[(6, 0, [ref('action_update_additional_contacts_of_mail_composition')])]"/>
    <field name="on_change_field_ids" eval="[(6, 0, [ref('mail.field_mail_compose_message__author_id')])]"/>
  </record>
  <record id="automation_update_additional_contacts_of_account_move_send" model="base.automation">
    <field name="model_id" ref="account.model_account_move_send_wizard"/>
    <field name="trigger">on_change</field>
    <field name="name">Update Additional Contacts Of Account Move Send</field>
    <field name="action_server_ids" eval="[(6, 0, [ref('action_update_additional_contacts_of_account_move_send')])]"/>
    <field name="on_change_field_ids" eval="[(6, 0, [ref('account.field_account_move_send_wizard__move_id')])]"/>
  </record>


  <record id="automation_rebalance_claimant_share" model="base.automation">
    <field name="model_id" ref="model_claimants_line"/>
    <field name="trigger">on_create_or_write</field>
    <field name="action_server_ids" eval="[(6, 0, [ref('action_rebalance_claimant_share')])]"/>
    <field name="name">create</field>
    <field name="trigger_field_ids" eval="[(6, 0, [ref('field_x_share'), ref('field_x_claimant_parent_id')])]"/>
  </record>
  <record id="automation_devide_claimant_share_on_craete_and_unlink" model="base.automation">
    <field name="model_id" ref="base.model_res_partner"/>
    <field name="action_server_ids" eval="[(6, 0, [ref('action_devide_claimant_share_on_craete_and_unlink')])]"/>
    <field name="trigger">on_create_or_write</field>
    <field name="name">Calculate Claimant Share on Create and Deletion Claimant line</field>
    <field name="trigger_field_ids" eval="[(6, 0, [ref('x_claimants_line_ids')])]"/>
  </record>
  <record id="automation_link_attachment_to_project_documents" model="base.automation">
    <field name="model_id" ref="base.model_ir_attachment"/>
    <field name="trigger">on_create_or_write</field>
    <field name="name">Industry Lawyer: Link Attachments to Project Documents</field>
    <field name="action_server_ids" eval="[(6, 0, [ref('action_link_attachment_to_project_documents')])]"/>
    <field name="trigger_field_ids" eval="[(6, 0, [ref('base.field_ir_attachment__res_model'), ref('base.field_ir_attachment__res_id')])]"/>
  </record>
</odoo>
