<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="field_x_claimant_group" model="ir.model.fields">
        <field name="name">x_claimant_group</field>
        <field name="ttype">boolean</field>
        <field name="field_description">Claimant Group</field>
