        <field name="field_description">Suggest Approver</field>
        <field name="model_id" ref="base.model_res_users"/>
        <field name="name">x_suggest_approver_group_id</field>
        <field name="relation">res.groups</field>
    </record>
    <record id="field_x_mail_author_id" model="ir.model.fields">
        <field name="ttype">many2one</field>
