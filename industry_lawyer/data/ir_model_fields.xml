<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="x_is_group_of_people_field" model="ir.model.fields">
        <field name="name">x_is_group_of_people</field>
        <field name="ttype">boolean</field>
        <field name="field_description">Is Group Of People</field>
        <field name="model_id" ref="base.model_res_partner"/>
    </record>
    <record id="field_claimants_id" model="ir.model.fields">
        <field name="name">x_claimants_id</field>
        <field name="ttype">many2one</field>
        <field name="field_description">Claimant relation field</field>
        <field name="model_id" ref="model_claimants_line"/>
        <field name="relation">res.partner</field>
    </record>
    <record id="x_claimants_line_ids" model="ir.model.fields">
        <field name="name">x_claimants_line_ids</field>
        <field name="ttype">one2many</field>
        <field name="relation">x_claimants_line</field>
        <field name="relation_field">x_claimants_id</field>
        <field name="field_description">Claimants Line</field>
        <field name="model_id" ref="base.model_res_partner"/>
    </record>
    <record id="field_x_share" model="ir.model.fields">
        <field name="name">x_share</field>
        <field name="ttype">float</field>
        <field name="field_description">% Share</field>
        <field name="model_id" ref="model_claimants_line"/>
    </record>
    <record id="field_x_claimants" model="ir.model.fields">
        <field name="name">x_claimants</field>
        <field name="ttype">many2one</field>
        <field name="field_description">Claimant</field>
        <field name="model_id" ref="model_claimants_line"/>
        <field name="on_delete" eval="False"/>
        <field name="relation">res.partner</field>
    </record>
    <record id="field_x_approval" model="ir.model.fields">
        <field name="ttype">many2one</field>
        <field name="copied" eval="True"/>
        <field name="field_description">Approval</field>
        <field name="model_id" ref="mail.model_mail_compose_message"/>
        <field name="name">x_approval</field>
        <field name="relation">res.partner</field>
    </record>
    <record id="field_x_approval_required" model="ir.model.fields">
        <field name="name">x_approval_required</field>
        <field name="ttype">selection</field>
        <field name="field_description">Approval Required</field>
        <field name="model_id" ref="base.model_res_config_settings"/>
    </record>
    <record id="x_approval_required_field_selection_mendatory" model="ir.model.fields.selection">
        <field name="name">Mendatory</field>
        <field name="field_id" ref="field_x_approval_required" />
        <field name="value">mendatory</field>
    </record>
    <record id="x_approval_required_field_selection_optional" model="ir.model.fields.selection">
        <field name="name">Optional</field>
        <field name="field_id" ref="field_x_approval_required" />
        <field name="value">optional</field>
    </record>
    <record id="field_x_approval_status" model="ir.model.fields">
        <field name="name">x_approval_status</field>
        <field name="ttype">selection</field>
        <field name="field_description">Approval Status</field>
        <field name="model_id" ref="mail.model_mail_mail"/>
    </record>
    <record id="x_approval_status_field_selection_pending" model="ir.model.fields.selection">
        <field name="name">Pending</field>
        <field name="field_id" ref="field_x_approval_status" />
        <field name="value">pending</field>
    </record>
    <record id="x_approval_status_field_selection_sent" model="ir.model.fields.selection">
        <field name="name">Sent</field>
        <field name="field_id" ref="field_x_approval_status" />
        <field name="value">sent</field>
    </record>
    <record id="x_approval_status_field_selection_cancelled" model="ir.model.fields.selection">
        <field name="name">Cancelled</field>
        <field name="field_id" ref="field_x_approval_status" />
        <field name="value">cancelled</field>
    </record>
    <record id="field_x_approval_state" model="ir.model.fields">
        <field name="name">x_approval_state</field>
        <field name="ttype">selection</field>
        <field name="field_description">Approval State</field>
        <field name="model_id" ref="mail.model_mail_mail"/>
    </record>
    <record id="x_approval_state_field_selection_01_in_progress" model="ir.model.fields.selection">
        <field name="name">In Progress</field>
        <field name="field_id" ref="field_x_approval_state" />
        <field name="value">01_in_progress</field>
    </record>
    <record id="x_approval_state_field_selection_02_changes_requested" model="ir.model.fields.selection">
        <field name="name">Changes Requested</field>
        <field name="field_id" ref="field_x_approval_state" />
        <field name="value">02_changes_requested</field>
    </record>
    <record id="x_approval_state_field_selection_03_approved" model="ir.model.fields.selection">
        <field name="name">Approved</field>
        <field name="field_id" ref="field_x_approval_state" />
        <field name="value">03_approved</field>
    </record>
    <record id="x_approval_state_field_selection_1_done" model="ir.model.fields.selection">
        <field name="name">Done</field>
        <field name="field_id" ref="field_x_approval_state" />
        <field name="value">1_done</field>
    </record>
    <record id="x_approval_state_field_selection_1_canceled" model="ir.model.fields.selection">
        <field name="name">Cancelled</field>
        <field name="field_id" ref="field_x_approval_state" />
        <field name="value">1_canceled</field>
    </record>
    <record id="field_x_approval_group" model="ir.model.fields">
        <field name="ttype">boolean</field>
        <field name="copied" eval="True"/>
        <field name="field_description">Approval Group</field>
        <field name="model">res.groups</field>
        <field name="model_id" ref="base.model_res_groups"/>
        <field name="name">x_approval_group</field>
    </record>
</odoo>
