        <field name="field_description">Approved By</field>
        <field name="on_delete" eval="False"/>
        <field name="model_id" ref="model_x_approval_mail"/>
        <field name="name">x_approved_by_groups_id</field>
        <field name="relation">res.groups</field>
    </record>
    <record id="field_x_related_document_model" model="ir.model.fields">
        <field name="ttype">char</field>
        <field name="field_description">Related Document Model</field>
        <field name="model_id" ref="model_x_approval_mail"/>
        <field name="name">x_res_model</field>
    </record>
    <record id="field_x_related_document_id" model="ir.model.fields">
        <field name="ttype">integer</field>
        <field name="field_description">Related Document Id</field>
        <field name="model_id" ref="model_x_approval_mail"/>
        <field name="name">x_res_id</field>
    </record>
    <record id="field_x_selected_claimant_ids" model="ir.model.fields">
        <field name="ttype">many2many</field>
        <field name="field_description">Selected Claimant</field>
        <field name="compute"><![CDATA[
for record in self: record['x_selected_claimant_ids'] = [(6, 0, [line.x_claimant_id.id for line in record.x_claimants_line_ids])]
]]></field>
        <field name="depends">x_claimants_line_ids</field>
        <field name="model_id" ref="base.model_res_partner"/>
        <field name="name">x_selected_claimant_ids</field>
        <field name="relation">res.partner</field>
        <field name="relation_table">x_res_partner_res_partner_rel</field>
    </record>
    <record id="field_x_selected_claimant_ids_in_so" model="ir.model.fields">
        <field name="ttype">many2many</field>
        <field name="field_description">Claimants</field>
        <field name="related">partner_id.x_selected_claimant_ids</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="name">x_claimant_ids</field>
        <field name="relation">res.partner</field>
        <field name="relation_table">x_res_partner_sale_order_rel</field>
    </record>
    <record id="field_x_access_by_users_ids" model="ir.model.fields">
        <field name="ttype">many2many</field>
        <field name="field_description">Access By Users</field>
        <field name="model_id" ref="model_x_approval_mail"/>
        <field name="name">x_access_by_users_ids</field>
        <field name="relation">res.users</field>
        <field name="relation_table">x_res_users_x_approval_mail_rel</field>
    </record>
</odoo>
