    <record id="field_sale_order_x_show_split_invoice" model="ir.model.fields">
        <field name="name">x_show_split_invoice</field>
        <field name="compute"><![CDATA[
for record in self: record['x_show_split_invoice'] = len(record.x_claimant_ids) > 1
]]></field>
        <field name="ttype">boolean</field>
        <field name="field_description">Show Split Invoice</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="store" eval="False"/>
    </record>
    <record id="field_account_move_x_show_split_invoice" model="ir.model.fields">
        <field name="compute"><![CDATA[
for record in self: record['x_show_split_invoice'] = len(record.partner_id.x_claimants_line_ids) > 1
]]></field>
        <field name="name">x_show_split_invoice</field>
        <field name="ttype">boolean</field>
        <field name="field_description">Show Split Invoice</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="store" eval="False"/>
    </record>
    <record id="field_x_approver_group_id" model="ir.model.fields">
        <field name="ttype">many2one</field>
