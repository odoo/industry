    <record id="field_x_share" model="ir.model.fields">
        <field name="name">x_share</field>
        <field name="ttype">float</field>
        <field name="field_description">% Share</field>
        <field name="model_id" ref="model_claimants_line"/>
    </record>
    <record id="field_x_share_is_manual" model="ir.model.fields">
        <field name="name">x_share_is_manual</field>
        <field name="ttype">boolean</field>
