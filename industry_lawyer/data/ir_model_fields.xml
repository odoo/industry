    <record id="field_x_approval_groups" model="ir.model.fields">
        <field name="ttype">boolean</field>
        <field name="field_description">Approval Group</field>
        <field name="model_id" ref="base.model_res_groups"/>
        <field name="name">x_approval_groups</field>
    </record>
    <record id="field_x_suggest_approver_group_id" model="ir.model.fields">
