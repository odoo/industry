<?xml version='1.0' encoding='UTF-8'?>
<odoo noupdate="1">
  <record id="group_low" model="res.groups">
    <field name="name">Low</field>
    <field name="x_approval_groups" eval="True"/>
  </record>
  <record id="group_medium" model="res.groups">
    <field name="implied_ids" eval="[(6, 0, [ref('group_low')])]"/>
    <field name="name">Medium</field>
    <field name="x_approval_groups" eval="True"/>
  </record>
  <record id="group_high" model="res.groups">
    <field name="implied_ids" eval="[(6, 0, [ref('group_low'), ref('group_medium')])]"/>
    <field name="name">High</field>
    <field name="x_approval_groups" eval="True"/>
  </record>
</odoo>
