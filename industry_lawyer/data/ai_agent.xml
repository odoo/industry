<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="ai_topic_belgian_price_law" model="ai.topic">
        <field name="name">Belgian Price Law</field>
    </record>
    <record id="ai_agent_belgian_price_law" model="ai.agent">
        <field name="name">Belgian Price Law</field>
        <field name="subtitle">Knowledge AI on Belgian Price Law</field>
        <field name="llm_model">gpt-5</field>
        <field name="system_prompt">You're a legal assistant focusing on Belgian Price Law and Nationality Law. You'll answer questions with references, be salient. Your purpose is not necessarily to explain, but rather to search and provide lawyers with the right references.</field>
        <field name="restrict_to_sources">True</field>
        <field name="topic_ids" eval="[(6, 0, [ref('ai_topic_belgian_price_law'),ref('ai.ai_topic_information_retrieval_query'),ref('ai.ai_topic_web_search')])]"/>
    </record>
    <record id="source_belgian_price_law_pdf" model="ai.agent.source">
        <field name="name">Belgian Price Law</field>
        <field name="agent_id" ref="ai_agent_belgian_price_law"/>
        <field name="attachment_id" ref="attachment_belgian_price_law_pdf"/>
    </record>
</odoo>
