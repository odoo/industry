<?xml version='1.0' encoding='UTF-8'?>
<odoo noupdate="1">
    <record id="project_project_3" model="project.project" context="{'mail_auto_subscribe_no_notify': True}">
        <field name="name">Case Template</field>
        <field name="allow_billable" eval="True"/>
        <field name="allocated_hours">10.0</field>
        <field name="type_ids" eval="[(6, 0, [ref('project_task_type_1'), ref('project_task_type_2'), ref('project_task_type_3')])]"/>
        <field name="billing_type">manually</field>
        <field name="user_id" ref="base.user_admin"/>
        <field name="stage_id" ref="project_project_stage_5"/>
        <field name="allow_recurring_tasks" eval="True"/>
        <field name="allow_milestones" eval="True"/>
    </record>
    <record id="project_project_5" model="project.project" context="{'mail_auto_subscribe_no_notify': True}">
        <field name="name">Procedural Request - Drafting and Filing </field>
        <field name="allow_billable" eval="True"/>
        <field name="type_ids" eval="[(6, 0, [ref('project_task_type_1'), ref('project_task_type_2'), ref('project_task_type_3')])]"/>
        <field name="stage_id" ref="project_project_stage_5"/>
        <field name="user_id" ref="base.user_admin"/>
        <field name="allow_recurring_tasks" eval="True"/>
        <field name="allow_milestones" eval="True"/>
    </record>
    <record id="project_project_3_top_bar" model="res.users.settings.embedded.action">
        <field name="user_setting_id" model="res.users.settings" search="[('user_id', '=', ref('base.user_admin'))]"/>
        <field name="action_id" ref="project.act_project_project_2_project_task_all"/>
        <field name="res_model">project.project</field>
        <field name="res_id" ref="project_project_3"/>
        <field name="embedded_actions_order"
            eval="','.join([
                'false',
                str(ref('hr_timesheet.project_embedded_action_timesheets')),
                str(ref('documents_project.project_embedded_action_documents')),
                str(ref('project_hr_expense.project_embedded_action_hr_expenses')),
                str(ref('sale_project.project_embedded_action_invoices')),
            ])"
        />
        <field name="embedded_actions_visibility"
            eval="','.join([
                'false',
                str(ref('hr_timesheet.project_embedded_action_timesheets')),
                str(ref('documents_project.project_embedded_action_documents')),
                str(ref('project_hr_expense.project_embedded_action_hr_expenses')),
                str(ref('sale_project.project_embedded_action_invoices')),
            ])"
        />
        <field name="embedded_visibility">True</field>
  </record>
</odoo>
