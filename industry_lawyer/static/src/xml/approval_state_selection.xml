<?xml version="1.0" encoding="UTF-8"?>
<templates>
    <t t-name="industry_lawyer.ApprovalStateSelection"
       t-inherit="project.ProjectTaskStateSelection"
       t-inherit-mode="primary">
        <xpath expr="//t[@t-elif=&quot;isToggleMode and currentValue == '01_in_progress'&quot;]//span[@class='o_status_label']" position="replace">
            <span class="o_status_label">
                <t t-out="label"/>
            </span>
        </xpath>
    </t>
</templates>
