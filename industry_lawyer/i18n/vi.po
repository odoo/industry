#. module: industry_lawyer
#: model_terms:ir.ui.view,arch_db:industry_lawyer.welcome_article_body
msgid ""
"<strong>Invoice the client</strong>: Compile logged hours, document "
"preparation costs, and travel expenses into the invoice."
msgstr ""
"<strong>Lập hóa đơn cho khách hàng</strong>: Tổng hợp thời gian đã ghi nhận, "
"phí chuẩn bị tài liệu và chi phí đi lại vào hóa đơn."

#. module: industry_lawyer
#: model_terms:ir.ui.view,arch_db:industry_lawyer.welcome_article_body
msgid ""
"<strong>Log your time</strong> directly in the 'Timesheet' tab of a specific "
"task, or use the timer to track the time spent on that task."
msgstr ""
"<strong>Ghi lại thời gian làm việc</strong> ngay trong tab 'Bảng chấm công' "
"của một nhiệm vụ cụ thể, hoặc sử dụng đồng hồ tính giờ để theo dõi thời gian "
"bạn đã dành cho công việc đó."

#. module: industry_lawyer
#: model_terms:ir.ui.view,arch_db:industry_lawyer.welcome_article_body
msgid ""
"<strong>Log your time</strong>: Track hours spent on each task in the "
"Timesheet tab."
msgstr ""
"<strong>Ghi lại thời gian của bạn</strong>: Theo dõi số giờ đã dành cho mỗi "
"nhiệm vụ trong tab Bảng chấm công."

#. module: industry_lawyer
#: model_terms:ir.ui.view,arch_db:industry_lawyer.welcome_article_body
