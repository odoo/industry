msgstr "支持公益項目：捐款資助與公益事業相關的展覽。"

#. module: museum
#: model_terms:ir.ui.view,arch_db:museum.ir_ui_view_4974
msgid "Support us"
msgstr "支持我們"

#. module: museum
#: model:product.pricelist,name:museum.product_pricelist_3
#: model:res.partner.grade,name:museum.res_partner_grade_supporter
