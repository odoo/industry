#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid "<span class=\"h1-fs\">Basics</span>"
msgstr "<span class=\"h1-fs\">Básicos</span>"

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<strong><b>Accounting App</b>: </strong>Automate your financial reporting, "
"tracking revenue from ticket sales\n"
"                    and concessions in real-time."
msgstr ""
"<strong><b>Aplicación Contabilidad</b>: </strong>automatiza tus informes "
"financieros y realiza un seguimiento de los ingresos por venta de entradas\n"
"                    y concesiones en tiempo real."

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<strong><b>CRM App</b>: </strong>Manage your passholders and sponsors "
"onboarding and follow up processes."
msgstr ""
"<strong><b>Aplicación CRM</b>: </strong>gestiona los procesos de alta y "
"seguimiento de abonados y patrocinadores."

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<strong><b>Contacts App</b>: </strong>Build a database of patrons, members, "
"and press contacts to nurture\n"
"                    relationships and loyalty."
msgstr ""
"<strong><b>Aplicación Contactos</b>: </strong>crea una base de datos de "
"patrocinadores, miembros y contactos de prensa para fortalecer\n"
"                    las relaciones duraderas y la fidelización."

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<strong><b>Email Marketing App</b>: </strong>Keep your audience engaged by "
"sending newsletters about upcoming\n"
"                    premieres, cast announcements, and special offers."
msgstr ""
"<strong><b>Aplicación Marketing por correo electrónico</b>: </strong>mantén "
"a tu público interesado mediante el envío de boletines informativos sobre "
"próximos\n"
"estrenos, anuncios del reparto y ofertas especiales."

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<strong><b>Events App</b>: </strong>Create and manage your show calendar, "
"selling tickets online with support\n"
"                    for different seating categories and pricing.<br/>"
msgstr ""
"<strong><b>Aplicación Eventos</b>: </strong>crea y gestiona tu calendario de "
"espectáculos, vende entradas en línea con diferentes\n"
"                    opciones y categorías de asientos y precios.<br/>"

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<strong><b>Point of Sale App</b>: </strong>Manage your concession stand or "
"bar efficiently, handling fast-paced\n"
"                    sales of drinks and snacks during intermission.<br/>"
msgstr ""
"<strong><b>Aplicación Punto de venta</b>: </strong>gestiona tu puesto de "
"comida o bar de forma eficiente, así como la venta rápida\n"
"                    de bebidas y aperitivos durante el descanso.<br/>"

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<strong><b>Website App</b>: </strong>Showcase your season program with a "
"beautiful, mobile-responsive online\n"
"                    agenda that drives ticket sales."
msgstr ""
"<strong><b>Aplicación Sitio web</b>: </strong>presenta el programa de "
"temporada con una agenda en línea llamativa y adaptada para dispositivos "
"móviles\n"
"                    que impulsa la venta de entradas."

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid "<strong><span class=\"h2-fs\">Tips for Success</span></strong>"
msgstr "<strong><span class=\"h2-fs\">Consejos para el éxito</span></strong>"

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
