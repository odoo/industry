#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid "<span class=\"display-4-fs\"><strong>Odoo for Theater</strong></span><br/>"
msgstr ""
"<span class=\"display-4-fs\"><strong>Odoo ສຳລັບໂຮງລະຄອນ</strong></span><br/>"

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid "<span class=\"h1-fs\">Basics</span>"
msgstr "<span class=\"h1-fs\">ພື້ນຖານ</span>"

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<strong><b>Accounting App</b>: </strong>Automate your financial reporting, tracking revenue from ticket sales\n"
"                    and concessions in real-time."
msgstr ""
"<strong><b>ແອັບການບັນຊີ</b>: </strong>ເຮັດໃຫ້ການລາຍງານທາງດ້ານການເງິນຂອງທ່ານເປັນລະບົບອັດຕ"
"ະໂນມັດ, ຕິດຕາມລາຍຮັບຈາກການຂາຍປີ້ ແລະ ການຂາຍອາຫານເຄື່ອງດື່ມແບບສົດໆ (real-time)."

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<strong><b>CRM App</b>: </strong>Manage your passholders and sponsors "
"onboarding and follow up processes."
msgstr ""
"<strong><b>ແອັບ CRM</b>: </strong>ຈັດການຂະບວນການຮັບສະມາຊິກຜູ້ຖືບັດຜ່ານ ແລະ ຜູ້ອຸປະຖຳ ລວມທັ"
"ງຂະບວນການຕິດຕາມຕ່າງໆ."

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<strong><b>Contacts App</b>: </strong>Build a database of patrons, members, and press contacts to nurture\n"
"                    relationships and loyalty."
msgstr ""
"<strong><b>ແອັບຜູ້ຕິດຕໍ່</b>: </strong>ສ້າງຖານຂໍ້ມູນຂອງຜູ້ນິຍົມຊົມຊອບ, ສະມາຊິກ, ແລະ ຜູ້ຕິດຕໍ່ຈາກສື່ມ"
"ວນຊົນ ເພື່ອເສີມສ້າງສາຍສຳພັນ ແລະ ຄວາມຈົງຮັກພັກດີ."

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<strong><b>Email Marketing App</b>: </strong>Keep your audience engaged by sending newsletters about upcoming\n"
"                    premieres, cast announcements, and special offers."
msgstr ""
"<strong><b>ແອັບການຕະຫຼາດຜ່ານອີເມລ</b>: </strong>ສ້າງການມີສ່ວນຮ່ວມກັບຜູ້ຊົມຂອງທ່ານໂດຍການສົ່ງຈົ"
"ດໝາຍຂ່າວກ່ຽວກັບຮອບປະຖົມມະທັດທີ່ຈະມາເຖິງ, ການປະກາດລາຍຊື່ນັກສະແດງ, ແລະ ຂໍ້ສະເໜີພິເສດຕ່າງໆ."

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<strong><b>Events App</b>: </strong>Create and manage your show calendar, selling tickets online with support\n"
"                    for different seating categories and pricing.<br/>"
msgstr ""
"<strong><b>ແອັບກິດຈະກຳ</b>: </strong>ສ້າງ ແລະ ຈັດການປະຕິທິນການສະແດງຂອງທ່ານ, ຂາຍປີ້ທາງອ"
"ອນລາຍ ພ້ອມຮອງຮັບການແບ່ງປະເພດບ່ອນນັ່ງ ແລະ ລາຄາທີ່ແຕກຕ່າງກັນ.<br/>"

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<strong><b>Point of Sale App</b>: </strong>Manage your concession stand or bar efficiently, handling fast-paced\n"
"                    sales of drinks and snacks during intermission.<br/>"
msgstr ""
"<strong><b>ແອັບຈຸດຂາຍ (PoS)</b>: </strong>ຈັດການຮ້ານຂາຍອາຫານ ຫຼື ບາຂອງທ່ານຢ່າງມີປະສິດທິພ"
"າບ, ຮອງຮັບການຂາຍເຄື່ອງດື່ມ ແລະ ອາຫານວ່າງຢ່າງວ່ອງໄວໃນຊ່ວງເວລາພັກການສະແດງ.<br/>"

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<strong><b>Website App</b>: </strong>Showcase your season program with a beautiful, mobile-responsive online\n"
"                    agenda that drives ticket sales."
msgstr ""
"<strong><b>ແອັບເວັບໄຊ</b>: </strong>ສະແດງໂຄງການລະດູການຂອງທ່ານດ້ວຍກຳນົດການອອນລາຍທີ່ສວຍ"
"ງາມ, ຮອງຮັບການເບິ່ງຜ່ານມືຖື ເພື່ອຊ່ວຍຊຸກຍູ້ການຂາຍປີ້."

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid "<strong><span class=\"h2-fs\">Tips for Success</span></strong>"
msgstr "<strong><span class=\"h2-fs\">ເຄັດລັບສູ່ຄວາມສຳເລັດ</span></strong>"

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<strong>Accounting</strong>: Handle donations, bar revenue, ticket sales, "
"and grant reporting."
msgstr ""
"<strong>ການບັນຊີ</strong>: ຈັດການເງິນບໍລິຈາກ, ລາຍຮັບຈາກບາ, ການຂາຍປີ້, ແລະ ການລາຍງານເງິນ"
"ທຶນຊ່ວຍເຫຼືອ."

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<strong>Add QR codes</strong> to printed flyers or posters to link directly "
"to online ticketing pages."
msgstr ""
"<strong>ເພີ່ມລະຫັດ QR</strong> ໃສ່ໃນໃບປິວ ຫຼື ໂປສເຕີ ເພື່ອເຊື່ອມຕໍ່ໂດຍກົງໄປຫາໜ້າຂາຍປີ້ອອນລາຍ."

