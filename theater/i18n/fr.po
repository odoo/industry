#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<strong><b>Accounting App</b>: </strong>Automate your financial reporting, "
"tracking revenue from ticket sales\n"
"                    and concessions in real-time."
msgstr ""
"<strong><b>Application Comptabilité</b> :</strong> automatisez vos rapports "
"financiers en suivant en temps réel les revenus issus de la vente de billets "
"et des concessions."

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<strong><b>CRM App</b>: </strong>Manage your passholders and sponsors "
"onboarding and follow up processes."
msgstr ""
"<strong><b>Application CRM</b> :</strong> gérez les processus d’intégration "
"et de suivi de vos abonnés et sponsors."

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<strong><b>Contacts App</b>: </strong>Build a database of patrons, members, "
"and press contacts to nurture\n"
"                    relationships and loyalty."
msgstr ""
"<strong><b>Application Contacts</b> :</strong> constituez une base de "
"données de spectateurs, de membres et de contacts presse afin de développer "
"les relations et la fidélité."

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<strong><b>Email Marketing App</b>: </strong>Keep your audience engaged by "
"sending newsletters about upcoming\n"
"                    premieres, cast announcements, and special offers."
msgstr ""
"<strong><b>Application E-mail Marketing</b> :</strong> maintenez "
"l’engagement de votre public en envoyant des newsletters sur les prochaines "
"premières, les annonces de distribution et les offres spéciales."

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<strong><b>Events App</b>: </strong>Create and manage your show calendar, "
"selling tickets online with support\n"
"                    for different seating categories and pricing.<br/>"
msgstr ""
"<strong><b>Application Événements</b> :</strong> créez et gérez le "
"calendrier de vos spectacles, vendez des billets en ligne avec la prise en "
"charge de différentes catégories de places et de tarifs.<br/>"

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<strong><b>Point of Sale App</b>: </strong>Manage your concession stand or "
"bar efficiently, handling fast-paced\n"
"                    sales of drinks and snacks during intermission.<br/>"
msgstr ""
"<strong><b>Application Point de Vente</b> :</strong> gérez efficacement "
"votre buvette ou votre bar, traitez des ventes rapides de boissons et de "
"snacks pendant l’entracte.<br/>"

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<strong><b>Website App</b>: </strong>Showcase your season program with a "
"beautiful, mobile-responsive online\n"
"                    agenda that drives ticket sales."
msgstr ""
"<strong><b>Application Site Web</b> :</strong> présentez la programmation de "
"votre saison grâce à un agenda en ligne esthétique, adapté à tous les écrans "
"et conçu pour stimuler les ventes de billets."

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid "<strong><span class=\"h2-fs\">Tips for Success</span></strong>"
msgstr ""
"<strong><span class=\"h2-fs\">Des conseils pour réussir</span></strong>"

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<strong>Accounting</strong>: Handle donations, bar revenue, ticket sales, "
"and grant reporting."
msgstr ""
"<strong>Comptabilité</strong> : Assurez la gestion des dons, des revenus du "
"bar, des ventes de billets et du suivi des subventions."

