#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<span class=\"display-4-fs\"><strong>Odoo for Theater</strong></span><br/>"
msgstr ""
"<span class=\"display-4-fs\"><strong>Odoo для театра</strong></span><br/>"

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid "<span class=\"h1-fs\">Basics</span>"
msgstr "<span class=\"h1-fs\">Основы</span>"

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<strong><b>Accounting App</b>: </strong>Automate your financial reporting, "
"tracking revenue from ticket sales\n"
"                    and concessions in real-time."
msgstr ""
"<strong><b>Модуль Бухгалтерия</b>: </strong>Автоматизируйте финансовую "
"отчетность, отслеживая доходы от продажи билетов\n"
"                    и услуг буфета в реальном времени."

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<strong><b>CRM App</b>: </strong>Manage your passholders and sponsors "
"onboarding and follow up processes."
msgstr ""
"<strong><b>Модуль CRM</b>: </strong>Управляйте процессами регистрации "
"владельцев абонементов и спонсоров, а также последующим взаимодействием с "
"ними."

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<strong><b>Contacts App</b>: </strong>Build a database of patrons, members, "
"and press contacts to nurture\n"
"                    relationships and loyalty."
msgstr ""
"<strong><b>Модуль Контакты</b>: </strong>Создайте базу меценатов, участников "
"и контактов прессы для развития\n"
"                    лояльности и долгосрочных отношений."

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<strong><b>Email Marketing App</b>: </strong>Keep your audience engaged by "
"sending newsletters about upcoming\n"
"                    premieres, cast announcements, and special offers."
msgstr ""
"<strong><b>Модуль E-mail рассылки</b>: </strong>Поддерживайте интерес "
"аудитории, отправляя рассылки о предстоящих\n"
"                    премьерах, анонсах состава актеров и специальных "
"предложениях."

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<strong><b>Events App</b>: </strong>Create and manage your show calendar, "
"selling tickets online with support\n"
"                    for different seating categories and pricing.<br/>"
msgstr ""
"<strong><b>Модуль Мероприятия</b>: </strong>Создавайте и ведите календарь "
"шоу, продавая билеты онлайн с поддержкой\n"
"                    различных категорий мест и цен.<br/>"

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<strong><b>Point of Sale App</b>: </strong>Manage your concession stand or "
"bar efficiently, handling fast-paced\n"
"                    sales of drinks and snacks during intermission.<br/>"
msgstr ""
"<strong><b>Модуль POS</b>: </strong>Эффективно управляйте буфетом или баром, "
"обеспечивая быстрые\n"
"                    продажи напитков и закусок во время антракта.<br/>"

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<strong><b>Website App</b>: </strong>Showcase your season program with a "
"beautiful, mobile-responsive online\n"
"                    agenda that drives ticket sales."
msgstr ""
"<strong><b>Модуль Вебсайт</b>: </strong>Представьте программу сезона в "
"красивой адаптивной онлайн-афише,\n"
"                    которая стимулирует продажи билетов."

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid "<strong><span class=\"h2-fs\">Tips for Success</span></strong>"
msgstr ""
"<strong><span class=\"h2-fs\">Советы для достижения успеха</span></strong>"

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<strong>Accounting</strong>: Handle donations, bar revenue, ticket sales, "
"and grant reporting."
msgstr ""
"<strong>Бухгалтерия</strong>: Управляйте пожертвованиями, доходами бара, "
"продажами билетов и отчетностью по грантам."

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<strong>Add QR codes</strong> to printed flyers or posters to link directly "
"to online ticketing pages."
msgstr ""
"<strong>Добавьте QR-коды</strong> на печатные листовки или плакаты, чтобы "
"обеспечить прямую ссылку на страницы онлайн-продажи билетов."

