msgstr "<span class=\"h1-fs\">Concetti di base</span>"

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<strong><b>Accounting App</b>: </strong>Automate your financial reporting, "
"tracking revenue from ticket sales\n"
"                    and concessions in real-time."
msgstr ""
"<strong><b>Contabilità</b>: </strong>automatizza la reportistica finanziaria "
"monitorando le entrate derivanti dalla vendita dei biglietti e dalle "
"concessioni in tempo reale."

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<strong><b>CRM App</b>: </strong>Manage your passholders and sponsors "
"onboarding and follow up processes."
msgstr ""
"<strong><b>CRM</b>: </strong>gestisci i tuoi abbonati e sponsor, "
"dall'inserimento al follow-up."

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<strong><b>Contacts App</b>: </strong>Build a database of patrons, members, "
"and press contacts to nurture\n"
"                    relationships and loyalty."
msgstr ""
"<strong><b>Contatti</b>: </strong>crea un database con clienti, membri e "
"contatti stampa per coltivare le relazioni e la fiducia."

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<strong><b>Email Marketing App</b>: </strong>Keep your audience engaged by "
"sending newsletters about upcoming\n"
"                    premieres, cast announcements, and special offers."
msgstr ""
"<strong><b>E-mail marketing</b>: </strong>coinvolgi il pubblico inviando "
"newsletter sulle prime in arrivo, sui cast e su offerte speciali."

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<strong><b>Events App</b>: </strong>Create and manage your show calendar, "
"selling tickets online with support\n"
"                    for different seating categories and pricing.<br/>"
msgstr ""
"<strong><b>Eventi</b>: </strong>crea e gestisci il calendario degli "
"spettacoli, vendi i biglietti online con prezzi e categorie distinti.<br/>"

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<strong><b>Point of Sale App</b>: </strong>Manage your concession stand or "
"bar efficiently, handling fast-paced\n"
"                    sales of drinks and snacks during intermission.<br/>"
msgstr ""
"<strong><b>Punto vendita</b>: </strong>gestisci in modo efficiente il tuo "
"chiosco o bar, gestendo le vendite frenetiche di bevande e snack durante "
"l'intervallo.<br/>"

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid ""
"<strong><b>Website App</b>: </strong>Showcase your season program with a "
"beautiful, mobile-responsive online\n"
"                    agenda that drives ticket sales."
msgstr ""
"<strong><b>Sito web</b>: </strong>illustra il programma stagionale grazie a "
"un bellissimo calendario online adatto ai dispositivi mobili che permette di "
"vendere biglietti."

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
msgid "<strong><span class=\"h2-fs\">Tips for Success</span></strong>"
msgstr "<strong><span class=\"h2-fs\">Consigli utili</span></strong>"

#. module: theater
#: model_terms:ir.ui.view,arch_db:theater.welcome_article_body
