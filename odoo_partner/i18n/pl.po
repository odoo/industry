#. module: odoo_partner
#: model_terms:ir.ui.view,arch_db:odoo_partner.welcome_article_body
msgid ""
"<b>CRM App</b>: Manage your leads and opportunities in a dedicated pipeline, "
"tracking stages from \"New Lead\"\n"
"                    to \"Won\" efficiently."
msgstr ""
"<b>Aplikacja CRM</b>: Zarządzaj potencjalnymi klientami i możliwościami w "
"dedykowanym systemie, skutecznie śledząc etapy od „nowego leada”\n"
"do „wygranej”."

#. module: odoo_partner
#: model_terms:ir.ui.view,arch_db:odoo_partner.welcome_article_body
msgid ""
"<b>Documents App</b>: Store and organize crucial client documents, "
"contracts, and technical specifications\n"
"                    in a secure, central repository."
msgstr ""
"<b>Aplikacja Dokumenty</b>: przechowuj i porządkuj ważne dokumenty klientów, "
"umowy i specyfikacje techniczne w bezpiecznym, centralnym repozytorium."

#. module: odoo_partner
#: model_terms:ir.ui.view,arch_db:odoo_partner.welcome_article_body
msgid ""
"<b>Helpdesk App</b>: Handle client support requests and tickets "
"systematically, ensuring timely resolution and\n"
"                high service levels."
msgstr ""
"<b>Aplikacja Helpdesk</b>: Systematyczne obsługiwanie zgłoszeń klientów, "
"zapewniające terminowe rozwiązywanie problemów i wysoki poziom usług."

#. module: odoo_partner
#: model_terms:ir.ui.view,arch_db:odoo_partner.welcome_article_body
msgid ""
"<b>Planning App</b>: Schedule your consultants' and developers' workload to "
"optimize resource allocation and\n"
"                    prevent bottlenecks."
msgstr ""
"<b>Aplikacja Planowanie</b>: Planuj obciążenie pracą konsultantów i "
"programistów, aby zoptymalizować alokację zasobów i\n"
"                    zapobiegać powstawaniu wąskich gardeł."

#. module: odoo_partner
#: model_terms:ir.ui.view,arch_db:odoo_partner.welcome_article_body
msgid ""
"<b>Project App</b>: Manage Success Packs and large implementations with task "
"management, milestones, and\n"
"                    shared customer views."
msgstr ""
"<b>Aplikacja Projekt</b>: Zarządzaj pakietami wdrożeniowymi i dużymi "
"implementacjami za pomocą zarządzania zadaniami, kamieniami milowymi i "
"wspólnymi widokami klientów."

#. module: odoo_partner
#: model_terms:ir.ui.view,arch_db:odoo_partner.welcome_article_body
msgid ""
"<b>Sales App</b>: Create professional proposals using an advanced Quote "
"Calculator and PDF Quote Builder to\n"
"                    impress prospective clients."
msgstr ""
"<b>Aplikacja Sprzedaż</b>: Twórz profesjonalne oferty przy użyciu "
"zaawansowanego kalkulatora ofert i narzędzia do tworzenia ofert w formacie "
"PDF, aby zrobić wrażenie na potencjalnych klientach."

#. module: odoo_partner
#: model_terms:ir.ui.view,arch_db:odoo_partner.welcome_article_body
msgid ""
"<b>Sign App</b>: Send contracts and engagement letters for fast, legally "
"binding digital signatures.<br/>"
msgstr ""
"<b>Aplikacja Podpisy</b>: Wysyłaj umowy i pisma dotyczące współpracy, aby "
"uzyskać szybkie, prawnie wiążące podpisy cyfrowe.<br/>"

#. module: odoo_partner
#: model_terms:ir.ui.view,arch_db:odoo_partner.welcome_article_body
msgid ""
"<b>Timesheets App</b>: Track billable hours spent on client projects to "
"ensure accurate invoicing and\n"
"                    profitability analysis."
msgstr ""
"<b>Aplikacja Ewidencja czasu pracy</b>: Śledź godziny pracy nad projektami "
"klientów, aby zapewnić dokładne fakturowanie i analizę rentowności."

