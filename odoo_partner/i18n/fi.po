#. module: odoo_partner
#: model_terms:ir.ui.view,arch_db:odoo_partner.welcome_article_body
msgid ""
"<b>CRM App</b>: Manage your leads and opportunities in a dedicated pipeline, "
"tracking stages from \"New Lead\"\n"
"                    to \"Won\" efficiently."
msgstr ""
"<b>CRM-sovellus</b>: Hallitse liidejäsi ja mahdollisuuksiasi niille "
"omistetussa myyntiputkessa, jossa voit seurata vaiheita uusista liideistä\n"
"                    aina voitettuihin asti."

#. module: odoo_partner
#: model_terms:ir.ui.view,arch_db:odoo_partner.welcome_article_body
msgid ""
"<b>Documents App</b>: Store and organize crucial client documents, "
"contracts, and technical specifications\n"
"                    in a secure, central repository."
msgstr ""
"<b>Asiakirjat-sovellus</b>: Tallenna ja järjestä tärkeät asiakasasiakirjat, "
"sopimukset ja tekniset määrittelyt\n"
"turvalliseen ja keskitettyyn tallennuspaikkaan."

#. module: odoo_partner
#: model_terms:ir.ui.view,arch_db:odoo_partner.welcome_article_body
msgid ""
"<b>Helpdesk App</b>: Handle client support requests and tickets "
"systematically, ensuring timely resolution and\n"
"                high service levels."
msgstr ""
"<b>Asiakaspalvelu-sovellus</b>: Käsittele asiakastukipyynnöt "
"järjestelmällisesti varmistaen oikea-aikaisen ratkaisun ja\n"
"                korkean palvelutason."

#. module: odoo_partner
#: model_terms:ir.ui.view,arch_db:odoo_partner.welcome_article_body
msgid ""
"<b>Planning App</b>: Schedule your consultants' and developers' workload to "
"optimize resource allocation and\n"
"                    prevent bottlenecks."
msgstr ""
"<b>Suunnittelu-sovellus</b>: Aikatauluta konsulttiesi ja kehittäjiesi "
"työmäärä resurssien optimoimiseksi sekä\n"
"                    pullonkaulojen ehkäisemiseksi."

#. module: odoo_partner
#: model_terms:ir.ui.view,arch_db:odoo_partner.welcome_article_body
msgid ""
"<b>Project App</b>: Manage Success Packs and large implementations with task "
"management, milestones, and\n"
"                    shared customer views."
msgstr ""
"<b>Projekti-sovellus</b>: Hallitse Menestyspaketteja sekä suuria toteutuksia "
"tehtävienhallinnan, välitavoitteiden ja\n"
"                    jaettujen asiakasnäkymien avulla."

#. module: odoo_partner
#: model_terms:ir.ui.view,arch_db:odoo_partner.welcome_article_body
msgid ""
"<b>Sales App</b>: Create professional proposals using an advanced Quote "
"Calculator and PDF Quote Builder to\n"
"                    impress prospective clients."
msgstr ""
"<b>Myynti-sovellus</b>: Luo ammattimaisia tarjouksia edistyksellisen "
"tarjouslaskurin sekä PDF-tarjousrakentajan avulla\n"
"                    tehdäksesi vaikutuksen potentiaalisiin asiakkaisiin."

#. module: odoo_partner
#: model_terms:ir.ui.view,arch_db:odoo_partner.welcome_article_body
msgid ""
"<b>Sign App</b>: Send contracts and engagement letters for fast, legally "
"binding digital signatures.<br/>"
msgstr ""
"<b>Allekirjoita-sovellus</b>: Lähetä sopimukset sekä toimeksiantokirjeet "
"nopeaa ja laillisesti sitovaa digitaalista allekirjoitusta varten.<br/>"

#. module: odoo_partner
#: model_terms:ir.ui.view,arch_db:odoo_partner.welcome_article_body
msgid ""
"<b>Timesheets App</b>: Track billable hours spent on client projects to "
"ensure accurate invoicing and\n"
"                    profitability analysis."
msgstr ""
"<b>Työaikakirjaukset-sovellus</b>: Seuraa asiakasprojekteihin käytettyjä "
"tunteja varmistaaksesi tarkan laskuttamisen sekä\n"
"                    kannattavuusanalyysin."

