#. module: odoo_partner
#: model_terms:ir.ui.view,arch_db:odoo_partner.welcome_article_body
msgid ""
"<b>CRM App</b>: Manage your leads and opportunities in a dedicated pipeline, "
"tracking stages from \"New Lead\"\n"
"                    to \"Won\" efficiently."
msgstr ""
"<b>Aplikace CRM</b>: Spravujte své potenciální zákazníky a příležitosti ve "
"specializovaném pipeline a efektivně sledujte fáze od „Nový“\n"
"                    až po „Získáno“."

#. module: odoo_partner
#: model_terms:ir.ui.view,arch_db:odoo_partner.welcome_article_body
msgid ""
"<b>Documents App</b>: Store and organize crucial client documents, "
"contracts, and technical specifications\n"
"                    in a secure, central repository."
msgstr ""
"<b>Aplikace Dokumenty</b>: Ukládejte a organizujte důležité technické "
"specifikace, smlouvy a dokumenty klientů v bezpečném centrálním úložišti."

#. module: odoo_partner
#: model_terms:ir.ui.view,arch_db:odoo_partner.welcome_article_body
msgid ""
"<b>Helpdesk App</b>: Handle client support requests and tickets "
"systematically, ensuring timely resolution and\n"
"                high service levels."
msgstr ""
"<b>Aplikace Helpdesk</b>: Systematicky zpracovávejte požadavky a tikety "
"zákaznické podpory a zajistěte včasné řešení a vysokou úroveň služeb."

#. module: odoo_partner
#: model_terms:ir.ui.view,arch_db:odoo_partner.welcome_article_body
msgid ""
"<b>Planning App</b>: Schedule your consultants' and developers' workload to "
"optimize resource allocation and\n"
"                    prevent bottlenecks."
msgstr ""
"<b>Aplikace Plánování</b>: Naplánujte pracovní vytížení svých konzultantů a "
"vývojářů a optimalizujte přidělování zdrojů a předcházejte vzniku úzkých "
"míst."

#. module: odoo_partner
#: model_terms:ir.ui.view,arch_db:odoo_partner.welcome_article_body
msgid ""
"<b>Project App</b>: Manage Success Packs and large implementations with task "
"management, milestones, and\n"
"                    shared customer views."
msgstr ""
"<b>Aplikace Projekt</b>: Spravujte implementační balíčky a rozsáhlé "
"implementace pomocí správy úkolů, milníků a sdílených pohledů zákazníků."

#. module: odoo_partner
#: model_terms:ir.ui.view,arch_db:odoo_partner.welcome_article_body
msgid ""
"<b>Sales App</b>: Create professional proposals using an advanced Quote "
"Calculator and PDF Quote Builder to\n"
"                    impress prospective clients."
msgstr ""
"<b>Aplikace Prodej</b>: Vytvářejte profesionální nabídky pomocí pokročilé "
"kalkulačky nabídek a nástroje vytváření nabídek PDF, abyste\n"
"                    zapůsobili na potenciální klienty."

#. module: odoo_partner
#: model_terms:ir.ui.view,arch_db:odoo_partner.welcome_article_body
msgid ""
"<b>Sign App</b>: Send contracts and engagement letters for fast, legally "
"binding digital signatures.<br/>"
msgstr ""
"<b>Aplikace podpisy</b>: Posílejte smlouvy a smluvní nabídky k rychlému a "
"právně závaznému digitálnímu podpisu.<br/>"

#. module: odoo_partner
#: model_terms:ir.ui.view,arch_db:odoo_partner.welcome_article_body
msgid ""
"<b>Timesheets App</b>: Track billable hours spent on client projects to "
"ensure accurate invoicing and\n"
"                    profitability analysis."
msgstr ""
"<b>Aplikace Časové výkazy</b>: Sledujte fakturovatelné hodiny strávené na "
"projektech klientů pro zajištění přesné fakturace a\n"
"                    analýzu zisku."

