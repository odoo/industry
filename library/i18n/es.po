#. module: library
#: model:mail.template,body_html:library.mail_template_1
msgid ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            Dear <t t-out=\"object.partner_id.name or '''Customer'''\"/>,\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            This email is a friendly reminder regarding the\n"
"            <t t-out=\"object.product_id.name or '''Product'''\"/> that was "
"due for return.\n"
"            Our records indicate that the product has not yet been "
"returned.\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            As per our rental/return policy, a daily late fee will be "
"applied for each day the product is overdue.\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            To avoid any additional charges, please return the product as "
"soon as possible.\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            If you have already returned the product, please disregard this "
"email.\n"
"            However, if you believe there has been an error, or if you "
"require an extension,\n"
"            please contact us immediately so we can assist you.\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            We appreciate your prompt attention to this matter.\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            Sincerely,\n"
"        </p>\n"
"    \n"
"    "
msgstr ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            Estimado/a <t t-out=\"object.partner_id.name or '''cliente'''\"/"
">:\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            Este correo electrónico es un recordatorio de que\n"
"            <t t-out=\"object.product_id.name or '''el producto'''\"/> debe "
"ser devuelto.\n"
"            Según nuestros registros, el producto aún no ha sido devuelto.\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            De acuerdo con nuestras condiciones de alquiler y devolución, se "
"aplicará una tarifa diaria por demora por cada día de retraso en la "
"devolución del producto.\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            Para evitar cargos adicionales, le rogamos que devuelva el "
"producto lo antes posible.\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            Si ya ha devuelto el producto, puede ignorar este mensaje.\n"
"            Sin embargo, si cree que esto es un error o si requiere más "
"tiempo.\n"
"            póngase en contacto con nosotros lo antes posible para poder "
"asistirle.\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            Agradecemos su pronta atención a este asunto.\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            Saludos cordiales,\n"
"        </p>\n"
"    \n"
"    "

