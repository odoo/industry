#. module: library
#: model:mail.template,body_html:library.mail_template_1
msgid ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            Dear <t t-out=\"object.partner_id.name or '''Customer'''\"/>,\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            This email is a friendly reminder regarding the\n"
"            <t t-out=\"object.product_id.name or '''Product'''\"/> that was due for return.\n"
"            Our records indicate that the product has not yet been returned.\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            As per our rental/return policy, a daily late fee will be applied for each day the product is overdue.\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            To avoid any additional charges, please return the product as soon as possible.\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            If you have already returned the product, please disregard this email.\n"
"            However, if you believe there has been an error, or if you require an extension,\n"
"            please contact us immediately so we can assist you.\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            We appreciate your prompt attention to this matter.\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            Sincerely,\n"
"        </p>\n"
"    \n"
"    "
msgstr ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            ຮຽນ <t t-out=\"object.partner_id.name or '''ລູກຄ້າ'''\"/>,\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            ອີເມວສະບັບນີ້ເປັນການແຈ້ງເຕືອນດ້ວຍຄວາມຫວັງດີກ່ຽວກັບ\n"
"            <t t-out=\"object.product_id.name or '''ສິນຄ້າ'''\"/> ທີ່ຮອດກຳນົດຕ້ອງສົ່ງ"
"ຄືນ.\n"
"            ຕາມບັນທຶກຂອງພວກເຮົາ ສິນຄ້າດັ່ງກ່າວຍັງບໍ່ທັນໄດ້ຮັບການສົ່ງຄືນເທື່ອ.\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            ອີງຕາມນະໂຍບາຍການເຊົ່າ/ສົ່ງຄືນ, ຄ່າທໍານຽມການສົ່ງຄືນຊ້າຈະຖືກຄິດໄລ່ເປັນລາຍວັນສຳລັບແຕ່ລະ"
"ມື້ທີ່ກາຍກຳນົດ.\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            ເພື່ອຫຼີກເວັ້ນຄ່າໃຊ້ຈ່າຍເພີ່ມເຕີມ, ກະລຸນາສົ່ງຄືນສິນຄ້າໂດຍໄວທີ່ສຸດ.\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            ຖ້າທ່ານໄດ້ສົ່ງຄືນສິນຄ້າແລ້ວ, ກະລຸນາມອງຂ້າມອີເມວສະບັບນີ້.\n"
"            ແນວໃດກໍຕາມ, ຖ້າທ່ານຄິດວ່າມີຂໍ້ຜິດພາດ ຫຼື ຕ້ອງການຕໍ່ເວລາ,\n"
"            ກະລຸນາຕິດຕໍ່ພວກເຮົາທັນທີເພື່ອໃຫ້ພວກເຮົາສາມາດຊ່ວຍເຫຼືອທ່ານໄດ້.\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            ພວກເຮົາຂໍຂອບໃຈທີ່ທ່ານໃຫ້ຄວາມສົນໃຈຕໍ່ເລື່ອງນີ້ໂດຍໄວ.\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            ດ້ວຍຄວາມນັບຖື,\n"
"        </p>\n"
"    \n"
"    "

#. module: library
