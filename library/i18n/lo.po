#. module: library
#: model_terms:ir.ui.view,arch_db:library.welcome_article_body
msgid ""
"<b>Confirm Access:</b> In the pop-up window, click \"<b>Grant Access</b>.\""
msgstr ""
"<b>ຢືນຢັນການເຂົ້າເຖິງ:</b> ໃນໜ້າຕ່າງທີ່ປາກົດຂຶ້ນມາ, ໃຫ້ຄລິກ \"<b>ອະນຸຍາດການເຂົ້າເຖິງ</b>.\""

#. module: library
#: model_terms:ir.ui.view,arch_db:library.welcome_article_body
msgid ""
"<b>Confirm all products at once</b> by clicking the <b>Validate</b> button."
msgstr "<b>ຢືນຢັນສິນຄ້າທັງໝົດໃນຄັ້ງດຽວ</b> ໂດຍການຄລິກປຸ່ມ <b>ກວດສອບຢືນຢັນ</b>."

#. module: library
#: model_terms:ir.ui.view,arch_db:library.welcome_article_body
msgid "<b>Confirm</b> the subscription."
msgstr "<b>ຢືນຢັນ</b> ການສະໝັກສະມາຊິກ."

#. module: library
#: model_terms:ir.ui.view,arch_db:library.welcome_article_body
msgid "<b>Create the invoice</b>."
msgstr "<b>ສ້າງໃບແຈ້ງໜີ້</b>."

#. module: library
#: model_terms:ir.ui.view,arch_db:library.ir_ui_view_3888
msgid "<b>Designed</b><br/>for Companies"
msgstr "<b>ອອກແບບມາ</b><br/>ສຳລັບບໍລິສັດ"

#. module: library
#: model_terms:ir.ui.view,arch_db:library.welcome_article_body
msgid "<b>Go to Website Settings.</b>"
msgstr "<b>ໄປທີ່ການຕັ້ງຄ່າເວັບໄຊ.</b>"

#. module: library
#: model_terms:ir.ui.view,arch_db:library.welcome_article_body
msgid ""
"<b>Grant Portal Access:</b> At the top of the page, click the <b>gear icon "
"⚙️</b> and choose \"<b>Grant portal access</b>.\""
msgstr ""
"<b>ອະນຸຍາດການເຂົ້າເຖິງພໍທໍ (Portal):</b> ຢູ່ທາງເທິງຂອງໜ້າ, ໃຫ້ຄລິກ <b>ໄອຄອນເຟືອງ ⚙️</b> ແລ"
"ະ ເລືອກ \"<b>ອະນຸຍາດການເຂົ້າເຖິງພໍທໍ</b>.\""

#. module: library
#: model_terms:ir.ui.view,arch_db:library.welcome_article_body
msgid "<b>Open POS Session:</b> Start your Point of Sale (POS) session."
msgstr "<b>ເປີດຮອບການຂາຍ POS:</b> ເລີ່ມຮອບການຂາຍ (POS) ຂອງທ່ານ."

#. module: library
#: model_terms:ir.ui.view,arch_db:library.welcome_article_body
msgid ""
"<b>Process as Usual:</b> Complete the transaction just like a regular rental"
" order."
msgstr ""
"<b>ດຳເນີນການຕາມປົກກະຕິ:</b> ເຮັດທຸລະກຳໃຫ້ສຳເລັດ ຄືກັນກັບຄຳສັ່ງເຊົ່າປົກກະຕິ."

#. module: library
#: model_terms:ir.ui.view,arch_db:library.welcome_article_body
msgid ""
"<b>Select the Customer:</b> In the <b>Contact app</b>, find and select the "
"customer you want to give website access to."
msgstr ""
"<b>ເລືອກລູກຄ້າ:</b> ໃນ <b>ແອັບລາຍຊື່ຜູ້ຕິດຕໍ່</b>, ຊອກຫາ ແລະ ເລືອກລູກຄ້າທີ່ທ່ານຕ້ອງການ ອະນຸຍາດໃຫ້"
"ເຂົ້າເຖິງເວັບໄຊ."

#. module: library
#: model_terms:ir.ui.view,arch_db:library.welcome_article_body
msgid ""
"<b>Settle the Order:</b> Click the <b>three dots</b> (...), select "
"\"<b>Quotation/order</b>,\" then find the correct order and choose "
"\"<b>Settle the order</b>.\""
msgstr ""
"<b>ຈັດການຄຳສັ່ງ:</b> ຄລິກທີ່ <b>ສາມຈຸດ</b> (...), ເລືອກ \"<b>ໃບສະເໜີລາຄາ/ຄຳສັ່ງຊື້</b>,\" "
"ຈາກນັ້ນຊອກຫາຄຳສັ່ງທີ່ຖືກຕ້ອງ ແລະ ເລືອກ \"<b>ຈັດການຄຳສັ່ງ</b>.\""

#. module: library
#: model_terms:ir.ui.view,arch_db:library.welcome_article_body
msgid "<b>Validate!</b>"
msgstr "<b>ກວດສອບຢືນຢັນ!</b>"

#. module: library
#: model_terms:ir.ui.view,arch_db:library.welcome_article_body
msgid ""
"<b>Verify Pricelist:</b> Make sure their <b>Sales parameters</b> show the "
"correct pricelist."
msgstr ""
"<b>ກວດສອບລາຍການລາຄາ:</b> ກວດເບິ່ງໃຫ້ແນ່ໃຈວ່າ <b>ພະລາມິເຕີການຂາຍ</b> ສະແດງລາຍການລາຄາທີ່"
"ຖືກຕ້ອງ."

#. module: library
#: model_terms:ir.ui.view,arch_db:library.welcome_article_body
msgid ""
"<em><em/></em> database, the system will automatically populate relevant "
