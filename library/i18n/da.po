#. module: library
#: model:mail.template,body_html:library.mail_template_1
msgid ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            Dear <t t-out=\"object.partner_id.name or '''Customer'''\"/>,\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            This email is a friendly reminder regarding the\n"
"            <t t-out=\"object.product_id.name or '''Product'''\"/> that was "
"due for return.\n"
"            Our records indicate that the product has not yet been "
"returned.\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            As per our rental/return policy, a daily late fee will be "
"applied for each day the product is overdue.\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            To avoid any additional charges, please return the product as "
"soon as possible.\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            If you have already returned the product, please disregard this "
"email.\n"
"            However, if you believe there has been an error, or if you "
"require an extension,\n"
"            please contact us immediately so we can assist you.\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            We appreciate your prompt attention to this matter.\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            Sincerely,\n"
"        </p>\n"
"    \n"
"    "
msgstr ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            Hej <t t-out=\"object.partner_id.name or '''Customer'''\"/>\n"
"       </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\"> \n"
"            Denne e-mail er en venlig påmindelse vedrørende\n"
"           <t t-out=\"object.product_id.name or '''Product'''\"/>, som "
"skulle have været returneret.\n"
"            Vores optegnelser viser, at produktet endnu ikke er returneret.\n"
"       </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\"> \n"
"            I henhold til vores udlejnings- og returpolitik vil der blive "
"pålagt et dagligt gebyr for hver dag, produktet returneres for sent.\n"
"       </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\"> \n"
"            For at undgå yderligere gebyrer bedes du returnere produktet så "
"hurtigt som muligt.\n"
"       </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\"> \n"
"            Hvis du allerede har returneret produktet, kan du se bort fra "
"denne e-mail.\n"
"            Hvis du mener, der er sket en fejl, eller hvis du har brug for "
"en forlængelse,\n"
"            bedes du straks kontakte os, så vi kan hjælpe dig.\n"
"       </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\"> \n"
"            Tak for din hurtige håndtering af denne sag.\n"
"       </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\"> \n"
"            Med venlig hilsen\n"
"       </p> \n"
"    \n"
"    "

