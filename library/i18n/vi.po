#. module: library
#: model:mail.template,body_html:library.mail_template_1
msgid ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            Dear <t t-out=\"object.partner_id.name or '''Customer'''\"/>,\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            This email is a friendly reminder regarding the\n"
"            <t t-out=\"object.product_id.name or '''Product'''\"/> that was "
"due for return.\n"
"            Our records indicate that the product has not yet been "
"returned.\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            As per our rental/return policy, a daily late fee will be "
"applied for each day the product is overdue.\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            To avoid any additional charges, please return the product as "
"soon as possible.\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            If you have already returned the product, please disregard this "
"email.\n"
"            However, if you believe there has been an error, or if you "
"require an extension,\n"
"            please contact us immediately so we can assist you.\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            We appreciate your prompt attention to this matter.\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            Sincerely,\n"
"        </p>\n"
"    \n"
"    "
msgstr ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"    Kính gửi <t t-out=\"object.partner_id.name or '''Quý khách hàng'''\"/>,\n"
"</p>\n"
"\n"
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"    Đây là email nhắc nhở thân thiện liên quan đến \n"
"    <t t-out=\"object.product_id.name or '''Sản phẩm'''\"/> đã đến hạn hoàn "
"trả. \n"
"    Theo ghi nhận của chúng tôi, sản phẩm vẫn chưa được trả lại.\n"
"</p>\n"
"\n"
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"    Theo chính sách thuê/trả của chúng tôi, phí trễ hạn sẽ được áp dụng cho "
"mỗi ngày quá hạn.\n"
"</p>\n"
"\n"
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"    Để tránh phát sinh thêm chi phí, vui lòng hoàn trả sản phẩm trong thời "
"gian sớm nhất.\n"
"</p>\n"
"\n"
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"    Nếu quý khách đã trả sản phẩm, xin vui lòng bỏ qua email này. \n"
"    Tuy nhiên, nếu có nhầm lẫn hoặc quý khách cần gia hạn, \n"
"    vui lòng liên hệ ngay với chúng tôi để được hỗ trợ.\n"
"</p>\n"
"\n"
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"    Chúng tôi trân trọng cảm ơn sự hợp tác kịp thời của quý khách.\n"
"</p>\n"
"\n"
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"    Trân trọng,\n"
"</p>\n"
"    \n"
"    "

