#. module: library
#: model:mail.template,body_html:library.mail_template_1
msgid ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            Dear <t t-out=\"object.partner_id.name or '''Customer'''\"/>,\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            This email is a friendly reminder regarding the\n"
"            <t t-out=\"object.product_id.name or '''Product'''\"/> that was "
"due for return.\n"
"            Our records indicate that the product has not yet been "
"returned.\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            As per our rental/return policy, a daily late fee will be "
"applied for each day the product is overdue.\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            To avoid any additional charges, please return the product as "
"soon as possible.\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            If you have already returned the product, please disregard this "
"email.\n"
"            However, if you believe there has been an error, or if you "
"require an extension,\n"
"            please contact us immediately so we can assist you.\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            We appreciate your prompt attention to this matter.\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            Sincerely,\n"
"        </p>\n"
"    \n"
"    "
msgstr ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            Cher(e) <t t-out=\"object.partner_id.name or '''Customer'''\"/"
">,\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            Cet e-mail est un rappel concernant le produit\n"
"            <t t-out=\"object.product_id.name or '''Product'''\"/> qui "
"aurait dû être restitué.\n"
"            Nos registres indiquent que ce produit n’a pas encore été "
"restitué.\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            Conformément à notre politique de location et de retour, des "
"frais de retard journaliers seront appliqués pour chaque jour de "
"dépassement.\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            Afin d’éviter tout frais supplémentaire, nous vous invitons à "
"retourner le produit dans les plus brefs délais.\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            Si vous avez déjà procédé au retour, veuillez ignorer ce "
"message.\n"
"            Dans le cas contraire, si vous pensez qu’il s’agit d’une erreur "
"ou si vous souhaitez demander une prolongation,\n"
"            merci de nous contacter immédiatement afin que nous puissions "
"vous assister.\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            Nous vous remercions de l’attention portée à ce rappel.\n"
"        </p>\n"
"\n"
"        <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"            Cordialement,\n"
"        </p>\n"
"    \n"
"    "

