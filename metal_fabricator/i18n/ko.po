#. module: metal_fabricator
#: model_terms:ir.ui.view,arch_db:metal_fabricator.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>Project App</b>:</font> Manage complex "
"fabrication projects that involve multiple production stages and "
"installation phases efficiently."
msgstr ""

#. module: metal_fabricator
#: model_terms:ir.ui.view,arch_db:metal_fabricator.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>Purchase App</b>:</font> Ensure accurate "
"inventory replenishment for raw materials and track <b>subcontracting "
"services</b> for specialized treatments like galvanizing."
msgstr ""

#. module: metal_fabricator
#: model_terms:ir.ui.view,arch_db:metal_fabricator.welcome_article_body
