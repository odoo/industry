#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>Appointments App</b>: </strong>Organize and book winery tours and "
"tastings, enhancing the visitor\n"
"                    experience."
msgstr ""
"<strong><b>Aplicativo Compromissos</b>: </strong>Organize e reserve visitas "
"a vinícolas e degustações, melhorando a experiência do visitante.\n"
"                    ."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>CRM App</b>: </strong>Cultivate relationships with distributors "
"and private clients, tracking leads\n"
"                    to close more deals effectively.<br/>"
msgstr ""
"<strong><b>Aplicativo CRM</b>: </strong>Cultive relacionamentos com "
"distribuidores e clientes particulares, acompanhando leads\n"
"para fechar mais negócios com eficácia.<br/>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>Field Service App</b>: </strong>Coordinate vineyard operations, "
"assigning tasks to teams for pruning,\n"
"                    spraying, and harvesting.<br/>"
msgstr ""
"<strong><b>App Serviços de Campo</b>: </strong>Coordenar as operações da "
"vinícola, atribuindo tarefas às equipes para poda,\n"
"pulverização e colheita.<br/>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>Manufacturing App</b>: </strong>Manage the art of winemaking by "
"overseeing pressing, fermentation,\n"
"                    and blending processes with precision.<br/>"
msgstr ""
"<strong><b>Aplicativo Fabricação</b>: </strong>Gerencie a arte da produção "
"de vinho supervisionando os processos de prensagem, fermentação\n"
"e mistura com precisão.<br/>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>PLM App</b>: </strong>Innovate your wine portfolio by iterating "
"on blend recipes and managing product\n"
"                    lifecycle changes.<br/>"
msgstr ""
"<strong><b>App PLM</b>: </strong>Inove seu portfólio de vinhos iterando "
"receitas de misturas e gerenciando mudanças no ciclo de vida do produto.\n"
"                    .<br/>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>Point of Sale App</b>: </strong>Manage direct sales at the cellar "
"door with an easy-to-use interface\n"
"                    for visitors and tourists.<br/>"
msgstr ""
"<strong><b>Aplicativo Ponto de Venda</b>: </strong>Gerencie as vendas "
"diretas na adega com uma interface fácil de usar\n"
"para visitantes e turistas.<br/>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>Quality App</b>: </strong>Ensure every bottle meets your "
"standards by tracking quality control points\n"
"                    throughout production.<br/>"
msgstr ""
"<strong><b>Aplicativo Qualidade</b>: </strong>Assegure que cada garrafa "
"esteja nos padrões monitorando pontos de controle de qualidade\n"
"                    ao longo da produção.<br/>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>Website App</b>: </strong>Sell your wines globally with a fully "
"integrated eCommerce platform that\n"
"                    manages inventory in real-time.<br/>"
msgstr ""
"<strong><b>Aplicativo Site</b>: </strong>Venda seus vinhos globalmente com "
"uma plataforma de comércio eletrônico totalmente integrada que\n"
"gerencia o inventário em tempo real.<br/>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
