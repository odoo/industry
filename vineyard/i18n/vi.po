msgstr ""
"<strong>Tích hợp các ứng dụng</strong> của bạn để dữ liệu về bán hàng, sản "
"xuất và chất lượng được luân chuyển liền mạch."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.ir_ui_view_4048
msgid "<strong>Languages:</strong> EN / CH / FR"
msgstr "<strong>Ngôn ngữ:</strong> EN/CH/FR"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Log grape harvests</strong> in Inventory."
