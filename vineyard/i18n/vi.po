#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>Appointments App</b>: </strong>Organize and book winery tours and "
"tastings, enhancing the visitor\n"
"                    experience."
msgstr ""

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>CRM App</b>: </strong>Cultivate relationships with distributors "
"and private clients, tracking leads\n"
"                    to close more deals effectively.<br/>"
msgstr ""

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>Field Service App</b>: </strong>Coordinate vineyard operations, "
"assigning tasks to teams for pruning,\n"
"                    spraying, and harvesting.<br/>"
msgstr ""

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>Manufacturing App</b>: </strong>Manage the art of winemaking by "
"overseeing pressing, fermentation,\n"
"                    and blending processes with precision.<br/>"
msgstr ""

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>PLM App</b>: </strong>Innovate your wine portfolio by iterating "
"on blend recipes and managing product\n"
"                    lifecycle changes.<br/>"
msgstr ""

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>Point of Sale App</b>: </strong>Manage direct sales at the cellar "
"door with an easy-to-use interface\n"
"                    for visitors and tourists.<br/>"
msgstr ""

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>Quality App</b>: </strong>Ensure every bottle meets your "
"standards by tracking quality control points\n"
"                    throughout production.<br/>"
msgstr ""

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>Website App</b>: </strong>Sell your wines globally with a fully "
"integrated eCommerce platform that\n"
"                    manages inventory in real-time.<br/>"
msgstr ""

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Accept multiple payment methods</strong> (cash, card)."
msgstr ""
"<strong>Chấp nhận nhiều phương thức thanh toán</strong> (tiền mặt, thẻ)."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong>Accounting</strong> – Manage finances, track profitability by "
"product line, and automate reporting."
msgstr ""
"<strong>Kế toán</strong> – Quản lý tài chính, theo dõi lợi nhuận theo dòng "
"sản phẩm và tự động hóa báo cáo."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Add products</strong> to POS catalog."
msgstr "<strong>Thêm sản phẩm</strong> vào danh mục sản phẩm của POS."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Analyze trends</strong> for planning through reporting."
msgstr "<strong>Phân tích xu hướng</strong> để lập kế hoạch thông qua báo cáo."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Apply taxes</strong> automatically on invoices."
msgstr "<strong>Áp dụng thuế</strong> tự động trên hóa đơn."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Appointments 📅</strong>"
msgstr "<strong>Lịch hẹn 📅</strong>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Approve only if tests pass</strong>."
msgstr "<strong>Chỉ phê duyệt nếu các cuộc thử nghiệm thành công</strong>."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Assign checks</strong> to manufacturing steps."
msgstr "<strong>Gán các kiểm tra</strong> cho các bước sản xuất."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Assign lot numbers</strong> to batches."
msgstr "<strong>Gán số lô</strong> cho các lô hàng."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Assign to workers</strong> or external partners."
msgstr "<strong>Giao cho nhân viên</strong> hoặc đối tác bên ngoài."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Attach related quality points</strong> to ECO."
msgstr "<strong>Gắn các điểm chất lượng liên quan</strong> vào ECO."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Basics</strong>"
msgstr "<strong>Cơ sở</strong>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>CRM 🎯</strong>"
msgstr "<strong>CRM 🎯</strong>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Capture leads</strong> from website forms or direct outreach."
msgstr ""
"<strong>Thu thập thông tin lead</strong> từ các biểu mẫu trên trang web hoặc "
"qua các hoạt động tiếp cận trực tiếp."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong>Collaborate internally</strong> through chatter notes and file "
"attachments."
msgstr ""
"<strong>Hợp tác nội bộ</strong> thông qua các ghi chú cửa sổ trò chuyện và "
"tệp đính kèm."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Compare scrap over time</strong> to measure progress."
msgstr "<strong>So sánh phế phẩm theo thời gian</strong> để đo lường tiến độ."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Compare yield ratios</strong> to expectations."
msgstr "<strong>So sánh tỷ lệ sản lượng</strong> với kỳ vọng."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Configure excise rates</strong> in products."
msgstr ""
"<strong>Cấu hình thuế suất thuế tiêu thụ đặc biệt</strong> cho các sản phẩm."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong>Create appointment types</strong> (e.g., tour &amp; tasting, private "
"tour)."
msgstr ""
"<strong>Tạo các loại lịch hẹn</strong> (VD: tour &amp; thử rượu, tour riêng)."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Create engineering change orders</strong> in PLM."
msgstr "<strong>Tạo lệnh thay đổi kỹ thuật</strong> trong PLM."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong>Create manufacturing orders</strong> for specific grapes, musts and "
"assemblages."
msgstr ""
"<strong>Tạo đơn lệnh sản xuất</strong> cho các loại nho, nước nho và hỗn hợp "
"nho cụ thể."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong>Create product pages</strong> with tasting notes and vintage details."
msgstr ""
"<strong>Tạo trang sản phẩm</strong> với ghi chú hương vị và thông tin niên "
"vụ."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Create tasks</strong> with location, date, and description."
msgstr "<strong>Tạo nhiệm vụ</strong> với vị trí, ngày tháng và mô tả."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong>Define bills of materials</strong> with grape types and quantities."
msgstr ""
"<strong>Xác định danh mục vật tư</strong> cho các loại nho và số lượng tương "
"ứng."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong>Define quality control points</strong> (acidity, sugar content, "
"clarity)."
msgstr ""
"<strong>Xác định các điểm kiểm soát chất lượng</strong> (độ axit, hàm lượng "
"đường, độ trong)."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Detailed usage:</strong>"
msgstr ""

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
#, fuzzy
msgid "<strong>Do You Want to Go Further?</strong>"
msgstr "<strong>Bạn có muốn tiến xa hơn không?</strong>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Enable online payments</strong> and automated invoicing."
msgstr "<strong>Bật thanh toán online</strong> và hóa đơn tự động."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong>Events</strong> – Organize wine festivals, promotional events, or "
"launch parties."
msgstr ""
"<strong>Sự kiện</strong> – Tổ chức lễ hội rượu, các sự kiện khuyến mại hoặc "
"tiệc ra mắt sản phẩm."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Excise Management 💰</strong>"
msgstr "<strong>Quản lý thuế tiêu thụ đặc biệt 💰</strong>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Field Service 🚜</strong>"
msgstr "<strong>Dịch vụ hiện trường 🚜</strong>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Follow up </strong>your plan from the planning"
msgstr "<strong>Theo dõi </strong>kế hoạch của bạn từ giai đoạn lập kế hoạch"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Generate excise reports</strong> for submission."
msgstr "<strong>Tạo báo cáo thuế tiêu thụ đặc biệt</strong> để nộp."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Generate lot numbers</strong> for traceability."
msgstr "<strong>Tạo số lô</strong> để theo dõi nguồn gốc."

#. module: vineyard
#: model_terms:product.template,description:vineyard.product_product_16_product_template
#: model_terms:product.template,description:vineyard.product_product_25_product_template
#: model_terms:product.template,description:vineyard.product_product_26_product_template
#: model_terms:product.template,description:vineyard.product_product_27_product_template
msgid ""
"<strong>Goal</strong>: Aromatic complexity, age-worthiness, firm tannins"
msgstr ""
"<strong>Mục tiêu</strong>: Hương thơm phức hợp, có khả năng lưu trữ lâu, "
"tannin chắc chắn"

#. module: vineyard
#: model_terms:product.template,description:vineyard.product_product_17_product_template
msgid "<strong>Goal</strong>: Deep color, spice, aging potential"
msgstr ""
"<strong>Mục tiêu</strong>: Màu sắc đậm, hương gia vị, khả năng lưu trữ lâu "
"dài"

#. module: vineyard
#: model_terms:product.template,description:vineyard.product_product_15_product_template
msgid "<strong>Goal</strong>: Round mouthfeel, fruit-forward, soft tannins"
msgstr ""
"<strong>Mục tiêu</strong>: Vị tròn trịa, hương trái cây nổi bật, tannin mềm "
"mại"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Harvest Management 🌾</strong>"
msgstr "<strong>Quản lý thu hoạch 🌾</strong>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.ir_ui_view_4048
msgid ""
"<strong>Includes:</strong> Vineyard walk, cellar visit, guided tasting of 3 "
"wines"
msgstr ""
"<strong>Bao gồm:</strong> Đi dạo vườn nho, tham quan hầm rượu, thưởng thức "
"có hướng dẫn 3 loại rượu"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong>Integrate your apps</strong> so sales, production, and quality data "
