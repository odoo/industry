#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Log results</strong> for each lot."
msgstr "<strong>Ghi lại kết quả</strong> cho từng lô."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Log time and materials</strong> used."
msgstr "<strong>Ghi lại thời gian và vật liệu</strong> đã sử dụng."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Manufacturing 🛠</strong>"
msgstr "<strong>Sản xuất 🛠</strong>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Mark complete</strong> once the work is done."
msgstr "<strong>Đánh dấu hoàn thành</strong> sau khi công việc hoàn tất."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Monitor yields</strong> and scrap quantities."
msgstr "<strong>Theo dõi sản lượng</strong> và lượng phế phẩm."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong>Move opportunities</strong> across pipeline stages until closing."
msgstr ""
"<strong>Di chuyển cơ hội</strong> qua các giai đoạn của quy trình bán hàng "
"cho đến khi hoàn tất."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>PLM 🧪</strong>"
msgstr "<strong>PLM 🧪</strong>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Point of Sale 🏷</strong>"
msgstr "<strong>POS 🏷</strong>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Prepare guest experiences</strong> based on booking notes."
msgstr ""
"<strong>Chuẩn bị trải nghiệm cho khách</strong> dựa trên ghi chú đặt lịch."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Print or email receipts</strong>."
msgstr "<strong>In hoặc gửi email biên lai</strong>."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Promote offers</strong> through banners and newsletters."
msgstr ""
"<strong>Quảng bá các ưu đãi</strong> thông qua banner và bản tin email."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Publish booking links</strong> on your website."
msgstr "<strong>Đăng các liên kết đặt lịch</strong> trên trang web của bạn."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong>Qualify prospects</strong> by checking interest level, wine "
"preferences, and budget."
msgstr ""
"<strong>Đánh giá khách hàng tiềm năng</strong> bằng cách kiểm tra mức độ "
"quan tâm, sở thích về rượu và ngân sách."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Quality ✅</strong>"
msgstr "<strong>Chất lượng ✅</strong>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Receive notifications</strong> for new bookings."
msgstr "<strong>Nhận thông báo</strong> cho các đặt lịch mới."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong>Record production steps</strong> such as fermentation and blending."
msgstr ""
"<strong>Ghi lại các bước sản xuất</strong> như quá trình lên men và phối "
"trộn."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong>Regularly review recipes</strong> and production methods in PLM for "
"ongoing improvement."
msgstr ""
"<strong>Thường xuyên xem xét công thức</strong> và phương pháp sản xuất "
"trong PLM để cải tiến liên tục."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Review dashboard metrics</strong> per year."
msgstr "<strong>Xem lại các chỉ số trên bảng điều khiển</strong> hàng năm."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Review history</strong> for audits."
msgstr "<strong>Xem lại lịch sử</strong> để phục vụ kiểm toán."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Review history</strong> for traceability."
msgstr ""
"<strong>Xem lại lịch sử</strong> để đảm bảo khả năng truy xuất nguồn gốc."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Run tests</strong> before approving ECO."
msgstr "<strong>Tiến hành thử nghiệm</strong> trước khi phê duyệt ECO."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong>Schedule activities</strong> such as follow-up calls or tastings."
msgstr ""
"<strong>Lên lịch hoạt động</strong> như các cuộc gọi follow-up hoặc các buổi "
"thử rượu."

