#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>Appointments App</b>: </strong>Organize and book winery tours and tastings, enhancing the visitor\n"
"                    experience."
msgstr ""
"<strong><b>ແອັບການນັດໝາຍ</b>: </strong>ຈັດການ ແລະ ຈອງທົວຊົມໂຮງບົ່ມ ແລະ ຊິມເຫຼົ້າອະງຸ່ນ, ເພື່"
"ອສ້າງປະສົບການທີ່ດີ\n"
"                    ໃຫ້ແກ່ຜູ້ມາຢ້ຽມຊົມ."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>CRM App</b>: </strong>Cultivate relationships with distributors and private clients, tracking leads\n"
"                    to close more deals effectively.<br/>"
msgstr ""
"<strong><b>ແອັບ CRM</b>: </strong>ສ້າງສາຍສຳພັນກັບຕົວແທນຈຳໜ່າຍ ແລະ ລູກຄ້າສ່ວນຕົວ, ຕິດຕາມຜູ້"
"ມີໂອກາດເປັນລູກຄ້າ\n"
"                    ເພື່ອປິດການຂາຍໄດ້ຢ່າງມີປະສິດທິພາບ.<br/>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>Field Service App</b>: </strong>Coordinate vineyard operations, assigning tasks to teams for pruning,\n"
"                    spraying, and harvesting.<br/>"
msgstr ""
"<strong><b>ແອັບບໍລິການພາກສະໜາມ</b>: </strong>ປະສານງານການເຮັດວຽກໃນສວນອະງຸ່ນ, ມອບໝາຍວ"
"ຽກໃຫ້ທີມງານໃນການຕັດແຕ່ງກິ່ງ,\n"
"                    ການສີດຢາ, ແລະ ການເກັບກ່ຽວ.<br/>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>Manufacturing App</b>: </strong>Manage the art of winemaking by overseeing pressing, fermentation,\n"
"                    and blending processes with precision.<br/>"
msgstr ""
"<strong><b>ແອັບການຜະລິດ</b>: </strong>ຈັດການສິລະປະການເຮັດເຫຼົ້າອະງຸ່ນ ໂດຍການຄວບຄຸມການບີບນ້"
"ຳ, ການໝັກ,\n"
"                    ແລະ ຂະບວນການປະສົມໃຫ້ມີຄວາມຊັດເຈນ.<br/>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>PLM App</b>: </strong>Innovate your wine portfolio by iterating on blend recipes and managing product\n"
"                    lifecycle changes.<br/>"
msgstr ""
"<strong><b>ແອັບ PLM</b>: </strong>ພັດທະນາຜະລິດຕະພັນເຫຼົ້າອະງຸ່ນຂອງທ່ານ ໂດຍການທົດລອງສູດປະສົ"
"ມໃໝ່ໆ ແລະ ຈັດການ\n"
"                    ການປ່ຽນແປງຕະຫຼອດວົງຈອນຊີວິດຂອງຜະລິດຕະພັນ.<br/>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>Point of Sale App</b>: </strong>Manage direct sales at the cellar door with an easy-to-use interface\n"
"                    for visitors and tourists.<br/>"
msgstr ""
"<strong><b>ແອັບຈຸດຂາຍ (POS)</b>: </strong>ຈັດການການຂາຍໂດຍກົງຢູ່ໜ້າຮ້ານ ຫຼື ໂຮງບົ່ມ ດ້ວຍລະບົ"
"ບທີ່ໃຊ້ງານງ່າຍ\n"
"                    ສຳລັບຜູ້ມາຢ້ຽມຊົມ ແລະ ນັກທ່ອງທ່ຽວ.<br/>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>Quality App</b>: </strong>Ensure every bottle meets your standards by tracking quality control points\n"
"                    throughout production.<br/>"
msgstr ""
"<strong><b>ແອັບຄຸນນະພາບ</b>: </strong>ຮັບປະກັນໃຫ້ທຸກຕຸກໄດ້ມາດຕະຖານຂອງທ່ານ ໂດຍການຕິດຕາມຈຸ"
"ດຄວບຄຸມຄຸນນະພາບ\n"
"                    ຕະຫຼອດຂະບວນການຜະລິດ.<br/>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>Website App</b>: </strong>Sell your wines globally with a fully integrated eCommerce platform that\n"
"                    manages inventory in real-time.<br/>"
msgstr ""
"<strong><b>ແອັບເວັບໄຊ</b>: </strong>ຂາຍເຫຼົ້າອະງຸ່ນຂອງທ່ານໄປທົ່ວໂລກ ດ້ວຍລະບົບ eCommerce ທີ່"
"ເຊື່ອມຕໍ່ກັນຢ່າງສົມບູນ\n"
"                    ເຊິ່ງຊ່ວຍຈັດການສາງສິນຄ້າແບບເວລາຈິງ (Real-time).<br/>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Accept multiple payment methods</strong> (cash, card)."
msgstr "<strong>ຮອງຮັບການຊຳລະເງິນຫຼາຍຮູບແບບ</strong> (ເງິນສົດ, ບັດ)."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong>Accounting</strong> – Manage finances, track profitability by "
"product line, and automate reporting."
msgstr ""
"<strong>ການບັນຊີ</strong> – ຈັດການດ້ານການເງິນ, ຕິດຕາມກຳໄລຕາມສາຍຜະລິດຕະພັນ, ແລະ ສ້າງລາຍ"
"ງານອັດຕະໂນມັດ."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Add products</strong> to POS catalog."
msgstr "<strong>ເພີ່ມສິນຄ້າ</strong> ເຂົ້າໃນລາຍການຂອງ POS."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Analyze trends</strong> for planning through reporting."
msgstr "<strong>ວິເຄາະທ່າອ່ຽງ</strong> ເພື່ອວາງແຜນຜ່ານການອອກລາຍງານ."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Apply taxes</strong> automatically on invoices."
msgstr "<strong>ນຳໃຊ້ພາສີ</strong> ໂດຍອັດຕະໂນມັດໃນໃບບິນ."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Appointments 📅</strong>"
msgstr "<strong>ການນັດໝາຍ 📅</strong>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Approve only if tests pass</strong>."
msgstr "<strong>ອະນຸມັດສະເພາະເມື່ອຜ່ານການທົດສອບເທົ່ານັ້ນ</strong>."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Assign checks</strong> to manufacturing steps."
msgstr "<strong>ມອບໝາຍການກວດສອບ</strong> ໃຫ້ກັບຂັ້ນຕອນການຜະລິດ."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Assign lot numbers</strong> to batches."
msgstr "<strong>ກຳນົດເລກລັອດ (Lot numbers)</strong> ໃຫ້ກັບແຕ່ລະຊຸດການຜະລິດ."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Assign to workers</strong> or external partners."
msgstr "<strong>ມອບໝາຍໃຫ້ພະນັກງານ</strong> ຫຼື ຄູ່ຮ່ວມງານພາຍນອກ."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Attach related quality points</strong> to ECO."
msgstr "<strong>ຄັດຕິດຈຸດຄຸນນະພາບທີ່ກ່ຽວຂ້ອງ</strong> ໃສ່ໃນ ECO."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Basics</strong>"
msgstr "<strong>ພື້ນຖານ</strong>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>CRM 🎯</strong>"
msgstr "<strong>CRM 🎯</strong>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Capture leads</strong> from website forms or direct outreach."
msgstr ""
"<strong>ເກັບກຳຂໍ້ມູນຜູ້ມີໂອກາດເປັນລູກຄ້າ</strong> ຈາກແບບຟອມເວັບໄຊ ຫຼື ການຕິດຕໍ່ໂດຍກົງ."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong>Collaborate internally</strong> through chatter notes and file "
"attachments."
msgstr ""
"<strong>ຮ່ວມມືກັນພາຍໃນ</strong> ຜ່ານລະບົບການບັນທຶກຂໍ້ຄວາມ (Chatter) ແລະ ການຄັດຕິດໄຟລ໌."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Compare scrap over time</strong> to measure progress."
msgstr "<strong>ປຽບທຽບສິນຄ້າເສຍຕາມໄລຍະເວລາ</strong> ເພື່ອວັດແທກຄວາມຄືບໜ້າ."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Compare yield ratios</strong> to expectations."
msgstr "<strong>ປຽບທຽບອັດຕາສ່ວນຜົນຜະລິດ</strong> ກັບສິ່ງທີ່ຄາດຫວັງໄວ້."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Configure excise rates</strong> in products."
msgstr "<strong>ຕັ້ງຄ່າອັດຕາພາສີຊົມໃຊ້</strong> ໃນຜະລິດຕະພັນ."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong>Create appointment types</strong> (e.g., tour &amp; tasting, private"
" tour)."
msgstr ""
"<strong>ສ້າງປະເພດການນັດໝາຍ</strong> (ເຊັ່ນ: ການຊົມສວນ ແລະ ຊິມເຫຼົ້າ, ທົວສ່ວນຕົວ)."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Create engineering change orders</strong> in PLM."
msgstr "<strong>ສ້າງຄຳສັ່ງປ່ຽນແປງທາງວິສະວະກຳ (ECO)</strong> ໃນ PLM."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong>Create manufacturing orders</strong> for specific grapes, musts and "
"assemblages."
msgstr ""
"<strong>ສ້າງໃບສັ່ງຜະລິດ</strong> ສຳລັບໝາກອະງຸ່ນ, ນ້ຳໝາກອະງຸ່ນ ແລະ ການປະສົມສະເພາະຢ່າງ."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong>Create product pages</strong> with tasting notes and vintage "
"details."
msgstr ""
"<strong>ສ້າງໜ້າຜະລິດຕະພັນ</strong> ພ້ອມກັບລາຍລະອຽດການຊິມ ແລະ ຂໍ້ມູນປີທີ່ຜະລິດ."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Create tasks</strong> with location, date, and description."
msgstr "<strong>ສ້າງວຽກ</strong> ໂດຍລະບຸສະຖານທີ່, ວັນທີ, ແລະ ຄຳອະທິບາຍ."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong>Define bills of materials</strong> with grape types and quantities."
msgstr "<strong>ກຳນົດລາຍການວັດສະດຸ (BOM)</strong> ດ້ວຍປະເພດໝາກອະງຸ່ນ ແລະ ຈຳນວນ."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong>Define quality control points</strong> (acidity, sugar content, "
"clarity)."
msgstr ""
"<strong>ກຳນົດຈຸດຄວບຄຸມຄຸນນະພາບ</strong> (ຄວາມສົ້ມ, ປະລິມານນ້ຳຕານ, ຄວາມໃສ)."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Detailed usage:</strong>"
msgstr "<strong>ການນຳໃຊ້ຢ່າງລະອຽດ:</strong>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Do You Want to Go Further?</strong>"
msgstr "<strong>ທ່ານຕ້ອງການໄປຕໍ່ໃຫ້ໄກກວ່ານີ້ບໍ?</strong>"

