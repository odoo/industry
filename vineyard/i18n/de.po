#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<span class=\"display-4-fs\"><strong>Vineyard</strong></span>"
msgstr "<span class=\"display-4-fs\"><strong>Weingut</strong></span>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>Appointments App</b>: </strong>Organize and book winery tours and "
"tastings, enhancing the visitor\n"
"                    experience."
msgstr ""
"<strong><b>Termine-App</b>: </strong>Organisieren und buchen Sie "
"Weingutbesichtigungen und Verkostungen, um das Besuchererlebnis\n"
"                   zu verbessern."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>CRM App</b>: </strong>Cultivate relationships with distributors "
"and private clients, tracking leads\n"
"                    to close more deals effectively.<br/>"
msgstr ""
"<strong><b>CRM-App</b>: </strong>Pflegen Sie Beziehungen zu Händlern und "
"Privatkunden und verfolgen Sie Leads,\n"
"um mehr Geschäfte effektiv abzuschließen.<br/>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>Field Service App</b>: </strong>Coordinate vineyard operations, "
"assigning tasks to teams for pruning,\n"
"                    spraying, and harvesting.<br/>"
msgstr ""
"<strong><b>Außendienst-App</b>: </strong>Koordinieren Sie das Weingut und "
"weisen Sie den Teams Aufgaben wie Rebschnitt,\n"
"Sprühung und Ernte zu.<br/>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>Manufacturing App</b>: </strong>Manage the art of winemaking by "
"overseeing pressing, fermentation,\n"
"                    and blending processes with precision.<br/>"
msgstr ""
"<strong><b>Fertigungsapp</b>: </strong>Verwalten Sie die Kunst der "
"Weinherstellung, indem Sie die Prozesse des Pressens,\n"
"der Gärung und der Mischung präzise überwachen.<br/>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>PLM App</b>: </strong>Innovate your wine portfolio by iterating "
"on blend recipes and managing product\n"
"                    lifecycle changes.<br/>"
msgstr ""
"<strong><b>PLM-App</b>: </strong>Innovieren Sie Ihr Weinportfolio, indem Sie "
"Mischungsrezepte optimieren und Änderungen im Produktlebenszyklus\n"
"                    verwalten.<br/>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>Point of Sale App</b>: </strong>Manage direct sales at the cellar "
"door with an easy-to-use interface\n"
"                    for visitors and tourists.<br/>"
msgstr ""
"<strong><b>Kassensystemapp</b>: </strong>Verwalten Sie den Direktverkauf im "
"Weinkeller mit einer benutzerfreundlichen Oberfläche\n"
"für Besucher und Touristen.<br/>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>Quality App</b>: </strong>Ensure every bottle meets your "
"standards by tracking quality control points\n"
"                    throughout production.<br/>"
msgstr ""
"<strong><b>Qualitätsapp </b>: </strong>Stellen Sie sicher, dass jede Flasche "
"Ihren Standards entspricht, indem Sie die Qualitätskontrollpunkte\n"
"während der gesamten Produktion verfolgen.<br/>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>Website App</b>: </strong>Sell your wines globally with a fully "
"integrated eCommerce platform that\n"
"                    manages inventory in real-time.<br/>"
msgstr ""
"<strong><b>Website-App</b>: </strong>Verkaufen Sie Ihre Weine weltweit mit "
"einer vollständig integrierten E-Commerce-Plattform, die\n"
"                    das Lager in Echtzeit verwaltet.<br/>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Accept multiple payment methods</strong> (cash, card)."
msgstr ""
"<strong>Akzeptieren Sie mehrere Zahlungsmethoden</strong> (Bargeld, Karte)."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong>Accounting</strong> – Manage finances, track profitability by "
"product line, and automate reporting."
msgstr ""
"<strong>Buchhaltung</strong>: Verwalten Sie Finanzen, verfolgen Sie die "
"Rentabilität nach Produktlinien und automatisieren Sie die Berichterstellung."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Add products</strong> to POS catalog."
msgstr ""
"<strong>Fügen Sie Produkte</strong> zum Katalog des Kassensystems hinzu."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Analyze trends</strong> for planning through reporting."
msgstr ""
