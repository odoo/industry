#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>Appointments App</b>: </strong>Organize and book winery tours and "
"tastings, enhancing the visitor\n"
"                    experience."
msgstr ""
"<strong><b>Rendez-vous</b> : </strong>organisez et réservez des visites de "
"domaines viticoles et des dégustations pour améliorer l’expérience des "
"visiteurs."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>CRM App</b>: </strong>Cultivate relationships with distributors "
"and private clients, tracking leads\n"
"                    to close more deals effectively.<br/>"
msgstr ""
"<strong><b>CRM</b> : </strong>entretenez les relations avec les "
"distributeurs et les clients particuliers, et suivez les pistes afin de "
"conclure plus d’affaires efficacement.<br/>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>Field Service App</b>: </strong>Coordinate vineyard operations, "
"assigning tasks to teams for pruning,\n"
"                    spraying, and harvesting.<br/>"
msgstr ""
"<strong><b>Services sur Site</b> : </strong>coordonnez les opérations dans "
"le vignoble en attribuant des tâches aux équipes pour la taille, le "
"traitement et la récolte.<br/>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>Manufacturing App</b>: </strong>Manage the art of winemaking by "
"overseeing pressing, fermentation,\n"
"                    and blending processes with precision.<br/>"
msgstr ""
"<strong><b>Fabrication</b> : </strong>gérez l’art de la vinification en "
"supervisant avec précision les processus de pressurage, de fermentation et "
"d’assemblage.<br/>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>PLM App</b>: </strong>Innovate your wine portfolio by iterating "
"on blend recipes and managing product\n"
"                    lifecycle changes.<br/>"
msgstr ""
"<strong><b>PLM</b> : </strong>innovez votre gamme de vins en itérant sur les "
"recettes d’assemblage et en gérant les changements du cycle de vie des "
"produits.<br/>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>Point of Sale App</b>: </strong>Manage direct sales at the cellar "
"door with an easy-to-use interface\n"
"                    for visitors and tourists.<br/>"
msgstr ""
"<strong><b>Point de Vente</b> : </strong>gérez les ventes directes à la cave "
"grâce à une interface simple d’utilisation pour les visiteurs et les "
"touristes.<br/>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>Quality App</b>: </strong>Ensure every bottle meets your "
"standards by tracking quality control points\n"
"                    throughout production.<br/>"
msgstr ""
"<strong><b>Qualité</b> : </strong>assurez-vous que chaque bouteille respecte "
"vos normes en suivant les points de contrôle qualité tout au long de la "
"production.<br/>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>Website App</b>: </strong>Sell your wines globally with a fully "
"integrated eCommerce platform that\n"
"                    manages inventory in real-time.<br/>"
msgstr ""
"<strong><b>Site Web</b> : </strong>vendez vos vins à l’échelle mondiale "
"grâce à une plateforme eCommerce entièrement intégrée qui gère l’inventaire "
"en temps réel.<br/>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Accept multiple payment methods</strong> (cash, card)."
msgstr "<strong>Acceptez plusieurs modes de paiement</strong> (espèces, carte)."

