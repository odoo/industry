<?xml version='1.0' encoding='UTF-8'?>
<odoo noupdate="1">
    <record id="calendar_event_1" model="calendar.event">
        <field name="name">Jean Elie - 3 hours Intervention Booking</field>
        <field name="description"><![CDATA[<span><strong>Contact Details</strong><br>Jean Elie<br><a href="mailto:jean@elie.com">jean@elie.com</a><br><a href="tel:+32464646464">+32464646464</a><br><br><strong>Questions &amp; Answers</strong><br><span>Phone number - +32464646464</span></span>]]></field>
        <field name="appointment_type_id" ref="appointment_type_3"/>
        <field name="duration">3.0</field>
        <field name="partner_ids" eval="[(4, ref('res_partner_36'))]"/>
        <field name="location">Rue des Bourlottes 9, 1367 Ramillies, Belgium</field>
        <field name="appointment_status">booked</field>
        <field name="resource_ids" eval="[(6, 0, [ref('appointment_resource_1')])]"/>
        <field name="start" model="appointment.type" eval="(DateTime.today().date() - relativedelta(days=7, hour=9)).replace(tzinfo=pytz.timezone(obj().env.ref('garage_auto_repair.appointment_type_3').appointment_tz)).astimezone(pytz.UTC).replace(tzinfo=None)"/>
        <field name="stop" model="appointment.type" eval="(DateTime.today().date() - relativedelta(days=7, hour=12)).replace(tzinfo=pytz.timezone(obj().env.ref('garage_auto_repair.appointment_type_3').appointment_tz)).astimezone(pytz.UTC).replace(tzinfo=None)"/>
    </record>
