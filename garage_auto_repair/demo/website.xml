<?xml version='1.0' encoding='UTF-8'?>
<odoo noupdate="1">
    <record id="website.default_website" model="website" forcecreate="1">
        <field name="name">Garage &amp; Auto Repair</field>
        <field name="theme_id" search="[('id', '=', ref('base.module_theme_notes', raise_if_not_found=False))]"/>
        <field name="logo" type="bytes" file="garage_auto_repair/static/description/icon.png"/>
        <field name="favicon" type="bytes" file="garage_auto_repair/static/description/icon.png"/>
        <field name="configurator_done" eval="True"/>
        <field name="user_id" ref="base.public_user"/>
    </record>
</odoo>
