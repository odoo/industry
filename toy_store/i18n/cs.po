#~ "                &lt;a href=\"https://www.odoo.com/slides/slide/5316?"
#~ "fullscreen=1\" class=\"btn btn-secondary\"&gt;🎓 Tutoriál&lt;/"
#~ "a&gt;&amp;nbsp;\n"
