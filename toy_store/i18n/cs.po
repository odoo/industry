#~ "Doplňování&lt;/em&gt;\n"
#~ "                                &lt;/em&gt;\n"
#~ "                                &lt;/em&gt;\n"
#~ "                                .\n"
#~ "                        &lt;/li&gt;\n"
#~ "                        &lt;li&gt;;Zkontrolujte pravidlo pro doplňování "
#~ "pro &lt;em&gt;Pandemic&lt;/em&gt;&amp;nbsp; změňte "
#~ "&lt;em&gt;Maximální&lt;/em&gt;&amp;nbsp;množství na 15.&lt;/li&gt;\n"
#~ "                        &lt;li&gt;Klikněte na&amp;nbsp;&lt;span "
#~ "class=\"fa fa-refresh\"&gt;&lt;/"
#~ "span&gt;&lt;em&gt;&amp;nbsp;Automatizovat&lt;/em&gt;.&lt;/li&gt;\n"
#~ "                        &lt;li&gt;Prohlédněte si nový návrh "
#~ "objednávky.&lt;/li&gt;\n"
#~ "                        &lt;/ul&gt;\n"
#~ "                &lt;/div&gt;\n"
#~ "                &lt;/div&gt;\n"
#~ "                &lt;p&gt;&lt;br /&gt;&lt;/p&gt;\n"
#~ "                &lt;h3&gt;🚚&lt;span style=\"width: 17px;\" class=\"oe-"
