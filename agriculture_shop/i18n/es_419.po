#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>\n"
"                    SEO features</b>"
msgstr ""
"<b>\n"
"                    Funciones de SEO</b>"

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Inventory App:</font></b> Keep precise "
"track of stock levels for diverse products\n"
"                like pesticides and equipment."
msgstr ""
"<b><font class=\"text-o-color-1\">Inventario:</font></b> Lleva un control "
"preciso de los niveles de existencias de diversos productos\n"
"            como pesticidas y equipos."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Point of Sale App:</font></b> Manage in-"
"store transactions efficiently, handling sales of seeds, tools, and supplies "
"with ease."
msgstr ""
"<b><font class=\"text-o-color-1\">Punto de venta:</font></b> Gestiona tus "
"transacciones en tienda con eficiencia y encárgate de la ventas de semillas, "
"herramientas e insumos con facilidad."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Purchase App:</font></b> Streamline the "
"procurement of farming products from suppliers, managing costs and lead "
"times."
msgstr ""
"<b><font class=\"text-o-color-1\">Compras:</font></b> Optimiza el "
"aprovisionamiento de productos agrícolas de proveedores y gestiona los "
"costos y los plazos de entrega."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Sales App:</font></b> Handle B2B orders "
"and contracts for large farming clients, ensuring accurate pricing."
msgstr ""
"<b><font class=\"text-o-color-1\">Ventas:</font></b> Gestiona las órdenes "
"B2B y los contratos para grandes clientes agrícolas y asegúrate de que los "
"precios sean precisos."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Website App:</font></b><font class=\"text-"
"o-color-3\"> Build a professional online presence to showcase your catalog "
"and attract new customers.</font>"
msgstr ""
"<b><font class=\"text-o-color-1\">Sitio web:</font></b><font class=\"text-o-"
"color-3\"> Crea una presencia en línea profesional para mostrar tu catálogo "
"y atraer a nuevos clientes.</font>"

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">eCommerce App:</font></b> Expand your "
"reach by selling products online, offering convenience to modern farmers."
msgstr ""
"<b><font class=\"text-o-color-1\">Comercio electrónico:</font></b> Amplía tu "
"alcance al vender productos en línea y ofrece comodidad a agricultores "
"modernos."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Accounting:</b> Automatically log payments, close sessions, and generate "
"tax\n"
"                    reports."
msgstr ""
"<b>Contabilidad:</b> Registra los pagos de forma automática, cierra las "
"sesiones y genera reportes\n"
"                    fiscales."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Automated Trigger</b> will instantly create a\n"
"                    purchase order."
msgstr ""
"El <b>activador automatizado</b> creará una orden de compra\n"
"                    al instante."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Automatic Delivery:</b> Once the quote is\n"
"                    accepted, the system automatically creates a linked "
"<b>Delivery Order</b>, just\n"
"                    as it does for a regular e-commerce order."
msgstr ""
"<b>Entrega automática:</b> Al aceptar la\n"
"                    cotización, el sistema crea una <b>orden de entrega</b> "
"vinculada de forma automática, igual\n"
"                    que con las órdenes regulares de comercio electrónico."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Capture Requests:</b> Any submission via the <b>\"Contact\n"
"                    Us\"</b> page instantly generates a new <b>CRM "
"opportunity</b>."
msgstr ""
"<b>Recibe solicitudes:</b> Cada vez que alguien se comunique mediante la "
"página <b>\"Contáctanos\"\n"
"                    </b>, el sistema genera una nueva <b>oportunidad en CRM</"
"b> de inmediato."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Crucial Review:</b> You must review all\n"
"                    e-commerce settings to ensure they align with your "
"internal business policies\n"
"                    (e.g., when invoices are generated, whether a mandatory "
"customer check-in is\n"
"                    required for ordering, etc.)."
msgstr ""
"<b>Revisiones importantes:</b> Revisa todos los ajustes\n"
"                    de Comercio electrónico para asegurarte de que se "
"adapten a tus políticas internas\n"
"                    (por ejemplo, cuándo se generan las facturas, si es "
"necesario que el cliente se registre\n"
"                    para ordenar, entre otras cosas)."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Define B2B Pricing:</b> Create and assign a <b>dedicated\n"
"                    pricelist</b> to each B2B contact. Ensure this pricelist "
"is active on your\n"
"                    website so the customer sees their agreed-upon prices "
"upon login."
msgstr ""
"<b>Define precios B2B:</b> Crea y asigna una <b>lista de precios\n"
"                    específica</b> para cada contacto B2B. Asegúrate de que "
"esta lista esté activa en tu\n"
"                    sitio web para que el cliente vea los precios correctos "
"al iniciar sesión."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Delivery Methods:</b> Go to <b>Website &gt;\n"
"                    Configuration &gt; Delivery Methods</b> to define all "
"available options and\n"
"                    their costs."
msgstr ""
"<b>Métodos de entrega:</b> Ve a <b>Sitio web &gt;\n"
"                    Configuración &gt; Métodos de entrega</b> para definir "
"todas las opciones disponibles\n"
"                    y sus costos."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>E-commerce Category:</b> For easier product\n"
"                    retrieval by customers on your online store."
msgstr ""
"<b>Categoría de comercio electrónico:</b> Facilita que los clientes "
"encuentren \n"
"                    productos en tu tienda en línea."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>External Providers:</b> Check if a\n"
"                            predefined Odoo connection exists if you work "
"with specific shipping\n"
"                            carriers."
msgstr ""
"<b>Proveedores externos:</b> Verifica si\n"
"                            existe una conexión predefinida de Odoo\n"
"                            si trabajas con transportistas específicos."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Field Service:</b> Implement this module if you <b>offer on-site repair "
"or\n"
"                maintenance services</b>."
msgstr ""
"<b>Servicio externo:</b> Implementa este módulo si <b>ofreces servicios de "
"reparación o\n"
"                mantenimiento en sitio</b>."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>In-Store Pickup (Click &amp; Collect):</b>\n"
"                            If you wish to offer this, you must <b>activate "
"the setting</b> within\n"
"                            the <b>Website Settings</b> first."
msgstr ""
"<b>Recolección en tienda (Haz clic y recoge):</b> \n"
"                            Si deseas ofrecer esta opción, primero debes "
"<b>activar la función</b> \n"
"                            en los <b>ajustes de Sitio web</b>."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid "<b>Key Product Settings:</b>"
msgstr "<b>Ajustes clave para los productos:</b>"

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Layout Settings:</b> Adjust the visual\n"
"                    presentation and layout of products using the <b>website "
"editor</b>."
msgstr ""
"<b>Ajustes de diseño:</b> Ajusta la presentación\n"
"                    visual y el diseño de los productos con el <b>editor del "
"sitio web</b>."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Loyalty Programs:</b> Implement <b>loyalty cards</b> as a core\n"
"                            strategy to <b>activate customer retention</b> "
"and increase lifetime\n"
"                            value."
msgstr ""
"<b>Programas de lealtad:</b> Implementa <b>tarjetas de lealtad</b> como "
"estrategia\n"
"                            clave para <b>incentivar la retención de "
"clientes</b> y aumentar su valor\n"
"                            a largo plazo."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Manual Trigger</b> will display the demand in the\n"
"                    Inventory <b>Replenishment view </b>for you to confirm. "
"<i>(Note:\n"
"                    Reordering rules work in conjunction with defined lead "
"times.)</i>"
msgstr ""
"El <b>activador manual</b> muestra la demanda en la\n"
"                    <b>vista de reabastecimiento</b> del inventario para que "
"la confirmes. <i>(Nota:\n"
"                    Las reglas de reabastecimiento funcionan junto con los "
"plazos de entrega definidos).</i>"

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Optimal stock management</b> is achieved by <b>combining both the "
"Reordering Rules and\n"
"            Suggested Replenishment</b> to ensure a comprehensive, forecast-"
"aware stock follow-up."
msgstr ""
"<b>La gestión óptima del inventario</b> se logra al <b>combinar las reglas "
"de reabastecimiento y\n"
"            el reabastecimiento sugerido</b> para garantizar un seguimiento "
"completo de las existencias basado en pronósticos."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Payment Providers &amp; Methods:</b> Go to <b>Website\n"
"                    &gt; Configuration &gt; Payment Providers</b> and "
"install <b>all</b> the payment\n"
"                    methods and providers you plan to offer (e.g., credit "
"card processors, PayPal,\n"
"                    etc.)."
msgstr ""
"<b>Proveedores y métodos de pago:</b> Ve a <b>Sitio web\n"
"                    &gt; Configuración &gt; Proveedores de pago</b> e "
"instala <b>todos</b> los métodos\n"
"                    y proveedores de pago que planeas ofrecer (por ejemplo, "
"procesadores de tarjetas de crédito, PayPal,\n"
"                    etc.)."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Payroll:</b> Use this feature to handle <b>employee salaries and manage "
"holiday\n"
"                requests</b>."
msgstr ""
"<b>Nómina:</b> Usa esta función para gestionar <b>los sueldos de los "
"empleados y las solicitudes de \n"
"                vacaciones</b>."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Point of Sale Category:</b> For organizing\n"
"                    transactions within your shop system."
msgstr ""
"<b>Categoría de Punto de venta:</b> Organiza las transacciones\n"
"                    del sistema de tu tienda."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Pricelist Segmentation:</b> Define multiple pricing structures for the\n"
"                            same product, supporting different business "
"models (e.g., B2B vs. B2C)\n"
"                            and enabling <b>client-specific pricing "
"contracts</b>."
msgstr ""
"<b>Segmentación de listas de precios:</b> Define varias estructuras de "
"precios para\n"
"                            el mismo producto, así podrás gestionarlos para "
"distintos modelos de negocio (por ejemplo, B2B y B2C)\n"
"                            y ofrecer <b>contratos de precios específicos "
"para cada cliente</b>."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Product Category:</b> For internal tracking and\n"
"                    reporting."
msgstr ""
"<b>Categoría de producto:</b> Úsala para el seguimiento interno y para "
"elaborar\n"
"                    los reportes."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Product-Level Settings:</b> Define core product\n"
"                    settings directly on the <b>product form</b>."
msgstr ""
"<b>Ajustes a nivel de producto:</b> Define los ajustes principales "
"directamente \n"
"                    en el <b>formulario del producto</b>."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Promotional Agility:</b> Use <b>discounts and promotions</b> to\n"
"                            quickly adjust pricing for sales events or to "
"give targeted, <b>manual\n"
"                            reductions</b> at the point of sale."
msgstr ""
"<b>Agilidad promocional:</b> Usa <b>descuentos y promociones</b> para\n"
"                            ajustar los precios en eventos de venta con "
"rapidez o aplicar <b>reducciones\n"
"                            manuales</b> específicas en el punto de venta."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Publishing:</b> Each product can be <b>published\n"
"                    independently</b> on your online store."
msgstr ""
"<b>Publicación:</b> Publica <b>cada producto \n"
"                    por separado</b> en tu tienda en línea."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Qualify Leads:</b> Engage with the client through\n"
"                    the CRM opportunity to fully understand their request—"
"whether it's a need for a\n"
"                    specific product, a supplier inquiry, or general "
"information."
msgstr ""
"<b>Califica leads:</b> Interactúa con el cliente desde\n"
"                    la oportunidad en el CRM para comprender su solicitud, "
"ya sea una necesidad\n"
"                    de producto, una consulta de proveedor o información "
"general."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Quote and Confirm:</b> If a specific demand\n"
"                    requires pricing, generate a <b>quotation directly from "
"the opportunity</b>. The\n"
"                    client can then <b>confirm and sign it online</b>."
msgstr ""
"<b>Cotiza y confirma:</b> Si una solicitud específica\n"
"                    requiere un precio, genera una <b>cotización "
"directamente desde la oportunidad</b>. El\n"
"                    cliente puede <b>confirmarla y firmarla en línea</b>."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid "<b>Use the</b>"
msgstr "<b>Usa</b>"

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<font color=\"#343541\">Welcome to the <strong>\n"
"                    <font class=\"text-o-color-1\">Odoo Agricultural Store "
"package.</font>\n"
"                </strong></font>"
msgstr ""
"<font color=\"#343541\">Te damos la bienvenida al <strong>\n"
"                    <font class=\"text-o-color-1\">paquete para tiendas "
"agrícolas de Odoo.</font>\n"
"                </strong></font>"

