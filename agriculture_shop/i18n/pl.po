#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>\n"
"                    SEO features</b>"
msgstr ""
"<b>\n"
"                    Funkcje SEO</b>"

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Inventory App:</font></b> Keep precise "
"track of stock levels for diverse products\n"
"                like pesticides and equipment."
msgstr ""
"<b><font class=\"text-o-color-1\">Aplikacja Magazyn:</font></b> Precyzyjnie "
"śledź poziomy zapasów różnych produktów,\n"
"                takich jak pestycydy i sprzęt."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Point of Sale App:</font></b> Manage in-"
"store transactions efficiently, handling sales of seeds, tools, and supplies "
"with ease."
msgstr ""
"<b><font class=\"text-o-color-1\">Aplikacja Punkt Sprzedaży:</font></b> "
"Efektywnie zarządzaj transakcjami w sklepie, z łatwością obsługując sprzedaż "
"nasion, narzędzi i materiałów eksploatacyjnych."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Purchase App:</font></b> Streamline the "
"procurement of farming products from suppliers, managing costs and lead "
"times."
msgstr ""
"<b><font class=\"text-o-color-1\">Aplikacja Zakupy:</font></b> Usprawnij "
"proces zaopatrzenia produktów rolnych od dostawców, zarządzając kosztami i "
"terminami realizacji."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Sales App:</font></b> Handle B2B orders "
"and contracts for large farming clients, ensuring accurate pricing."
msgstr ""
"<b><font class=\"text-o-color-1\">Aplikacja Sprzedaż:</font></b> Obsługa "
"zamówień i umów B2B dla dużych klientów rolniczych, zapewniająca dokładne "
"wyceny."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Website App:</font></b><font class=\"text-"
"o-color-3\"> Build a professional online presence to showcase your catalog "
"and attract new customers.</font>"
msgstr ""
"<b><font class=\"text-o-color-1\">Aplikacja Strony internetowe:</font></"
"b><font class=\"text-o-color-3\"> Stwórz profesjonalną stronę internetową, "
"aby zaprezentować swój katalog i przyciągnąć nowych klientów.</font>"

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">eCommerce App:</font></b> Expand your "
"reach by selling products online, offering convenience to modern farmers."
msgstr ""
"<b><font class=\"text-o-color-1\">Aplikacja eCommerce:</font></b> Zwiększ "
"swój zasięg, sprzedając produkty online i oferując wygodę współczesnym "
"rolnikom."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Accounting:</b> Automatically log payments, close sessions, and generate "
"tax\n"
"                    reports."
msgstr ""
"<b>Księgowość:</b> Automatycznie rejestruj płatności, zamykaj sesje i "
"generuj raporty podatkowe.\n"
"                    ."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Automated Trigger</b> will instantly create a\n"
"                    purchase order."
msgstr ""
"<b>Automatyczny wyzwalacz</b> natychmiast utworzy\n"
"                    zamówienie zakupu."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Automatic Delivery:</b> Once the quote is\n"
"                    accepted, the system automatically creates a linked "
"<b>Delivery Order</b>, just\n"
"                    as it does for a regular e-commerce order."
msgstr ""
"<b>Automatyczna dostawa:</b> Po zaakceptowaniu oferty\n"
"system automatycznie tworzy powiązane zamówienie dostawy <b></b> , tak\n"
" samo jak w przypadku zwykłego zamówienia e-commerce."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Capture Requests:</b> Any submission via the <b>\"Contact\n"
"                    Us\"</b> page instantly generates a new <b>CRM "
"opportunity</b>."
msgstr ""
"<b>Przechwytuj zapytania:</b> Każde zgłoszenie przesłane za pośrednictwem "
"strony <b>\"Kontakt\"</b> natychmiast generuje nową <b>okazję w CRM</b>."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Crucial Review:</b> You must review all\n"
"                    e-commerce settings to ensure they align with your "
"internal business policies\n"
"                    (e.g., when invoices are generated, whether a mandatory "
"customer check-in is\n"
"                    required for ordering, etc.)."
msgstr ""
"<b>Kluczowa rewizja:</b> Należy sprawdzić wszystkie\n"
"                    ustawienia e-commerce, aby upewnić się, że są one zgodne "
"z wewnętrznymi zasadami firmy\n"
"                    (np. kiedy generowane są faktury, czy do złożenia "
"zamówienia wymagana jest obowiązkowa rejestracja klienta\n"
"                    itp.)."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Define B2B Pricing:</b> Create and assign a <b>dedicated\n"
"                    pricelist</b> to each B2B contact. Ensure this pricelist "
"is active on your\n"
"                    website so the customer sees their agreed-upon prices "
"upon login."
msgstr ""
"<b>Zdefiniuj ceny B2B:</b> Utwórz i przypisz <b>dedykowany cennik</b>\n"
"                    do każdego kontaktu B2B. Upewnij się, że ten cennik jest "
"aktywny na Twojej\n"
"                    stronie internetowej, aby klient widział uzgodnione ceny "
"po zalogowaniu."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Delivery Methods:</b> Go to <b>Website &gt;\n"
"                    Configuration &gt; Delivery Methods</b> to define all "
"available options and\n"
"                    their costs."
msgstr ""
"<b>Metody dostawy:</b> Przejdź do <b>strony internetowej &gt; \n"
"                    Konfiguracja &gt; Metody dostawy</b>, aby określić "
"wszystkie dostępne opcje i\n"
"                    ich koszty."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>E-commerce Category:</b> For easier product\n"
"                    retrieval by customers on your online store."
msgstr ""
"<b>Kategoria e-commerce:</b> Ułatwia klientom wyszukiwanie produktów\n"
"                    w Twoim sklepie internetowym."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>External Providers:</b> Check if a\n"
"                            predefined Odoo connection exists if you work "
"with specific shipping\n"
"                            carriers."
msgstr ""
"<b>Dostawcy zewnętrzni:</b> Sprawdź, czy istnieje\n"
"                            wstępnie zdefiniowane połączenie Odoo, jeśli "
"współpracujesz z konkretnymi przewoźnikami\n"
"                            ."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Field Service:</b> Implement this module if you <b>offer on-site repair "
"or\n"
"                maintenance services</b>."
msgstr ""
"<b>Usługi terenowe:</b> Zaimplementuj ten moduł, jeśli <b>oferujesz naprawy "
"lub\n"
"                usługi konserwacyjne na miejscu</b>."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>In-Store Pickup (Click &amp; Collect):</b>\n"
"                            If you wish to offer this, you must <b>activate "
"the setting</b> within\n"
"                            the <b>Website Settings</b> first."
msgstr ""
"<b> &amp; Odbiór w sklepie (opcja „Kliknij i odbierz”):</b>\n"
"                            Jeśli chcesz zaoferować tę opcję, musisz "
"najpierw <b>aktywować ustawienie</b> w\n"
"                            ustawieniach <b>strony internetowej</b> ."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid "<b>Key Product Settings:</b>"
msgstr "<b>Najważniejsze ustawienia produktu:</b>"

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Layout Settings:</b> Adjust the visual\n"
"                    presentation and layout of products using the <b>website "
"editor</b>."
msgstr ""
"<b>Ustawienia układu:</b> Dostosuj wygląd\n"
"                    i układ produktów za pomocą <b>edytora strony "
"internetowej</b> ."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Loyalty Programs:</b> Implement <b>loyalty cards</b> as a core\n"
"                            strategy to <b>activate customer retention</b> "
"and increase lifetime\n"
"                            value."
msgstr ""
"<b>Programy lojalnościowe:</b> Wdrażaj <b>karty lojalnościowe</b> jako "
"podstawową\n"
"                            strategię mającą na celu <b>utrzymanie klientów</"
"b> i zwiększenie wartości w całym okresie użytkowania\n"
"                            produktu."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Manual Trigger</b> will display the demand in the\n"
"                    Inventory <b>Replenishment view </b>for you to confirm. "
"<i>(Note:\n"
"                    Reordering rules work in conjunction with defined lead "
"times.)</i>"
msgstr ""
"<b>Ręczne uruchomienie </b> spowoduje wyświetlenie zapotrzebowania w\n"
"                    <b>widoku uzupełniania</b>w Magazynie do potwierdzenia. "
"<i>(Uwaga:\n"
"                    zasady ponownego zamawiania działają w połączeniu z "
"określonymi czasami realizacji).</i>"

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Optimal stock management</b> is achieved by <b>combining both the "
"Reordering Rules and\n"
"            Suggested Replenishment</b> to ensure a comprehensive, forecast-"
"aware stock follow-up."
msgstr ""
"<b>Optymalne zarządzanie zapasami</b> osiąga się poprzez <b>połączenie zasad "
"zamawiania i\n"
"            sugerowanego uzupełniania zapasów</b> w celu zapewnienia "
"kompleksowej, uwzględniającej prognozy kontroli zapasów."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Payment Providers &amp; Methods:</b> Go to <b>Website\n"
"                    &gt; Configuration &gt; Payment Providers</b> and "
"install <b>all</b> the payment\n"
"                    methods and providers you plan to offer (e.g., credit "
"card processors, PayPal,\n"
"                    etc.)."
msgstr ""
"<b>Operatorzy płatności &amp; Metody:</b> Przejdź do <b>Strony internetowej\n"
"                    &gt; Konfiguracja &gt; Operatorzy płatności</b> i "
"zainstaluj <b>wszystkie</b> metody\n"
"                    płatności i operatorów, których planujesz oferować (np., "
"operatorzy kart kredytowych, PayPal,\n"
"                    itp.)."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Payroll:</b> Use this feature to handle <b>employee salaries and manage "
"holiday\n"
"                requests</b>."
msgstr ""
"<b>Wynagrodzenie:</b> Użyj tej funkcji, aby obsługiwać wynagrodzenia "
"pracowników <b>i zarządzać wnioskami urlopowymi\n"
"               </b> ."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Point of Sale Category:</b> For organizing\n"
"                    transactions within your shop system."
msgstr ""
"<b>Kategoria Punktu Sprzedaży:</b> Do organizowania\n"
"                    transakcji w systemie sklepu."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Pricelist Segmentation:</b> Define multiple pricing structures for the\n"
"                            same product, supporting different business "
"models (e.g., B2B vs. B2C)\n"
"                            and enabling <b>client-specific pricing "
"contracts</b>."
msgstr ""
"<b>Segmentacja cennika:</b> Zdefiniuj wiele struktur cenowych dla\n"
"                            tego samego produktu, obsługujących różne modele "
"biznesowe (np. B2B vs. B2C)\n"
"                            i umożliwiających <b>umowy cenowe dostosowane do "
"potrzeb klienta</b>."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Product Category:</b> For internal tracking and\n"
"                    reporting."
msgstr ""
"<b>Kategoria produktu:</b> Do wewnętrznego śledzenia i\n"
"                    raportowania."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Product-Level Settings:</b> Define core product\n"
"                    settings directly on the <b>product form</b>."
msgstr ""
"<b>Ustawienia na poziomie produktu:</b> Zdefiniuj podstawowe ustawienia "
"produktu\n"
"bezpośrednio w formularzu produktu <b></b> ."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Promotional Agility:</b> Use <b>discounts and promotions</b> to\n"
"                            quickly adjust pricing for sales events or to "
"give targeted, <b>manual\n"
"                            reductions</b> at the point of sale."
msgstr ""
"<b>Elastyczność promocji:</b> Skorzystaj z <b>rabatów i promocji</b> , aby\n"
"                            szybko dostosować ceny podczas wydarzeń "
"sprzedażowych lub oferować ukierunkowane, <b>manualne obniżki\n"
"                            </b> w punkcie sprzedaży."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Publishing:</b> Each product can be <b>published\n"
"                    independently</b> on your online store."
msgstr ""
"<b>Publikowanie:</b> Każdy produkt może być <b>opublikowany\n"
"                    niezależnie</b> w Twoim sklepie internetowym."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Qualify Leads:</b> Engage with the client through\n"
"                    the CRM opportunity to fully understand their request—"
"whether it's a need for a\n"
"                    specific product, a supplier inquiry, or general "
"information."
msgstr ""
"<b>Kwalifikowanie leadów:</b> Nawiązuj kontakt z klientem za pośrednictwem\n"
"                    systemu CRM, aby w pełni zrozumieć jego potrzeby — "
"niezależnie od tego, czy chodzi o zapotrzebowanie na\n"
"                    konkretny produkt, zapytanie dotyczące dostawcy, czy "
"ogólne informacje."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Quote and Confirm:</b> If a specific demand\n"
"                    requires pricing, generate a <b>quotation directly from "
"the opportunity</b>. The\n"
"                    client can then <b>confirm and sign it online</b>."
msgstr ""
"<b>Wycena i potwierdzenie:</b> Jeśli konkretne zapotrzebowanie\n"
"                    wymaga wyceny, należy wygenerować ofertę <b>bezpośrednio "
"z okazji</b>. Klient\n"
"                    może następnie <b>potwierdzić ją i podpisać online</b>."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid "<b>Use the</b>"
msgstr "<b>Użyj</b>"

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<font color=\"#343541\">Welcome to the <strong>\n"
"                    <font class=\"text-o-color-1\">Odoo Agricultural Store "
"package.</font>\n"
"                </strong></font>"
msgstr ""
"<font color=\"#343541\">Witamy w pakiecie <strong>\n"
"                    <font class=\"text-o-color-1\">Sklepu Rolniczego Odoo.</"
"font>\n"
"                </strong></font>"

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.contactus
msgid ""
"<i class=\"fa fa-1x fa-fw fa-envelope me-2\"/>\n"
"                                                <span>info@yourcompany."
"example.com</span>"
msgstr ""
"<i class=\"fa fa-1x fa-fw fa-envelope me-2\"/>\n"
"                                                <span>info@yourcompany."
