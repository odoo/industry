#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>\n"
"                    SEO features</b>"
msgstr ""
"<b>\n"
"                    ຄຸນສົມບັດ SEO</b>"

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Inventory App:</font></b> Keep precise track of stock levels for diverse products\n"
"                like pesticides and equipment."
msgstr ""
"<b><font class=\"text-o-color-1\">App ຄັງສິນຄ້າ:</font></b> ຕິດຕາມລະດັບສິນຄ້າໃນສາງໃຫ້"
"ຊັດເຈນສຳລັບສິນຄ້າທີ່ຫຼາກຫຼາຍ\n"
"                ເຊັ່ນ: ຢາປາບສັດຕູພືດ ແລະ ອຸປະກອນ."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Point of Sale App:</font></b> Manage in-"
"store transactions efficiently, handling sales of seeds, tools, and supplies"
" with ease."
msgstr ""
"<b><font class=\"text-o-color-1\">App ຈຸດຂາຍ (POS):</font></b> ຈັດການທຸລະກຳພາຍໃນ"
"ຮ້ານຢ່າງມີປະສິດທິພາບ, ຈັດການການຂາຍແກ່ນພັນ, ເຄື່ອງມື ແລະ ອຸປະກອນຕ່າງໆໄດ້ຢ່າງງ່າຍດາຍ."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Purchase App:</font></b> Streamline the "
"procurement of farming products from suppliers, managing costs and lead "
"times."
msgstr ""
"<b><font class=\"text-o-color-1\">App ການຈັດຊື້:</font></b> ປັບປຸງຂະບວນການຈັດຊື້ຜະລິດຕ"
"ະພັນກະສິກຳຈາກຜູ້ສະໜອງ, ຈັດການຕົ້ນທຶນ ແລະ ໄລຍະເວລາການຈັດສົ່ງ."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Sales App:</font></b> Handle B2B orders "
"and contracts for large farming clients, ensuring accurate pricing."
msgstr ""
"<b><font class=\"text-o-color-1\">App ການຂາຍ:</font></b> ຈັດການຄຳສັ່ງຊື້ B2B ແລະ ສັ"
"ນຍາສຳລັບລູກຄ້າກະສິກຳລາຍໃຫຍ່, ຮັບປະກັນການກຳນົດລາຄາທີ່ຖືກຕ້ອງ."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Website App:</font></b><font class=\"text-"
"o-color-3\"> Build a professional online presence to showcase your catalog "
"and attract new customers.</font>"
msgstr ""
"<b><font class=\"text-o-color-1\">App ເວັບໄຊ:</font></b><font class=\"text-o-"
"color-3\"> ສ້າງຕົວຕົນອອນລາຍແບບມືອາຊີບເພື່ອສະແດງລາຍການສິນຄ້າ ແລະ ດຶງດູດລູກຄ້າໃໝ່.</font>"

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">eCommerce App:</font></b> Expand your "
"reach by selling products online, offering convenience to modern farmers."
msgstr ""
"<b><font class=\"text-o-color-1\">App ອີຄອມເມີຊ:</font></b> ຂະຫຍາຍການເຂົ້າເຖິງໂດຍກ"
"ານຂາຍສິນຄ້າອອນລາຍ, ເພີ່ມຄວາມສະດວກສະບາຍໃຫ້ແກ່ຊາວກະສິກອນຍຸກໃໝ່."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Accounting:</b> Automatically log payments, close sessions, and generate tax\n"
"                    reports."
msgstr ""
"<b>ການບັນຊີ:</b> ບັນທຶກການຊຳລະເງິນໂດຍອັດຕະໂນມັດ, ປິດຮອບການຂາຍ ແລະ ສ້າງລາຍງານ\n"
"                    ພາສີ."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Automated Trigger</b> will instantly create a\n"
"                    purchase order."
msgstr ""
"<b>ການກະຕຸ້ນອັດຕະໂນມັດ</b> ຈະສ້າງໃບສັ່ງຊື້\n"
"                    ໂດຍທັນທີ."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Automatic Delivery:</b> Once the quote is\n"
"                    accepted, the system automatically creates a linked <b>Delivery Order</b>, just\n"
"                    as it does for a regular e-commerce order."
msgstr ""
"<b>ການຈັດສົ່ງອັດຕະໂນມັດ:</b> ເມື່ອໃບສະເໜີລາຄາຖືກ\n"
"                    ຕອບຮັບ, ລະບົບຈະສ້າງ <b>ໃບຈັດສົ່ງສິນຄ້າ</b> ທີ່ເຊື່ອມໂຍງກັນໂດຍອັດຕະໂນມັ"
"ດ, ຄືກັນກັບ\n"
"                    ການສັ່ງຊື້ອີຄອມເມີຊທົ່ວໄປ."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Capture Requests:</b> Any submission via the <b>\"Contact\n"
"                    Us\"</b> page instantly generates a new <b>CRM opportunity</b>."
msgstr ""
"<b>ບັນທຶກການຮ້ອງຂໍ:</b> ທຸກໆການສົ່ງຂໍ້ມູນຜ່ານໜ້າ <b>\"ຕິດຕໍ່\n"
"                    ພວກເຮົາ\"</b> ຈະສ້າງ <b>ໂອກາດທາງ CRM</b> ໃໝ່ໂດຍທັນທີ."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Crucial Review:</b> You must review all\n"
"                    e-commerce settings to ensure they align with your internal business policies\n"
"                    (e.g., when invoices are generated, whether a mandatory customer check-in is\n"
"                    required for ordering, etc.)."
msgstr ""
"<b>ການກວດສອບທີ່ສຳຄັນ:</b> ທ່ານຕ້ອງກວດສອບການຕັ້ງຄ່າ\n"
"                    ອີຄອມເມີຊທັງໝົດເພື່ອໃຫ້ແນ່ໃຈວ່າມັນສອດຄ່ອງກັບນະໂຍບາຍທຸລະກິດພາຍໃນຂອງທ່ານ\n"
"                    (ເຊັ່ນ: ເວລາໃດທີ່ໃບເກັບເງິນຖືກສ້າງ, ຕ້ອງໃຫ້ລູກຄ້າລົງທະບຽນກ່ອນສັ່ງຊື້ຫຼືບໍ່, ແລະ"
"ອື່ນໆ)."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Define B2B Pricing:</b> Create and assign a <b>dedicated\n"
"                    pricelist</b> to each B2B contact. Ensure this pricelist is active on your\n"
"                    website so the customer sees their agreed-upon prices upon login."
msgstr ""
"<b>ກຳນົດລາຄາ B2B:</b> ສ້າງ ແລະ ກຳນົດ <b>ລາຍການລາຄາສະເພາະ</b> \n"
"                    ໃຫ້ແກ່ແຕ່ລະຜູ້ຕິດຕໍ່ B2B. ຮັບປະກັນວ່າລາຍການລາຄານີ້ຖືກເປີດໃຊ້ງານໃນ\n"
"                    ເວັບໄຊຂອງທ່ານ ເພື່ອໃຫ້ລູກຄ້າເຫັນລາຄາທີ່ຕົກລົງກັນໄວ້ເມື່ອເຂົ້າສູ່ລະບົບ."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Delivery Methods:</b> Go to <b>Website &gt;\n"
"                    Configuration &gt; Delivery Methods</b> to define all available options and\n"
"                    their costs."
msgstr ""
"<b>ວິທີການຈັດສົ່ງ:</b> ໄປທີ່ <b>ເວັບໄຊ &gt;\n"
"                    ການຕັ້ງຄ່າ &gt; ວິທີການຈັດສົ່ງ</b> ເພື່ອກຳນົດຕົວເລືອກທີ່ມີທັງໝົດ ແລະ\n"
"                    ຕົ້ນທຶນຂອງພວກມັນ."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>E-commerce Category:</b> For easier product\n"
"                    retrieval by customers on your online store."
msgstr ""
"<b>ໝວດໝູ່ອີຄອມເມີຊ:</b> ເພື່ອໃຫ້ລູກຄ້າຄົ້ນຫາສິນຄ້າ\n"
"                    ໃນຮ້ານຄ້າອອນລາຍຂອງທ່ານໄດ້ງ່າຍຂຶ້ນ."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>External Providers:</b> Check if a\n"
"                            predefined Odoo connection exists if you work with specific shipping\n"
"                            carriers."
msgstr ""
"<b>ຜູ້ໃຫ້ບໍລິການພາຍນອກ:</b> ກວດສອບເບິ່ງວ່າມີ\n"
"                            ການເຊື່ອມຕໍ່ Odoo ທີ່ກຳນົດໄວ້ລ່ວງໜ້າຫຼືບໍ່ ຖ້າທ່ານເຮັດວຽກກັບຜູ້ໃຫ້ບໍລິກາ"
"ນ\n"
"                            ຂົນສົ່ງສະເພາະ."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Field Service:</b> Implement this module if you <b>offer on-site repair or\n"
"                maintenance services</b>."
msgstr ""
"<b>ການບໍລິການນອກສະຖານທີ່:</b> ຕິດຕັ້ງໂມດູນນີ້ຖ້າທ່ານ <b>ມີບໍລິການສ້ອມແປງ ຫຼື\n"
"                ບຳລຸງຮັກສານອກສະຖານທີ່</b>."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>In-Store Pickup (Click &amp; Collect):</b>\n"
"                            If you wish to offer this, you must <b>activate the setting</b> within\n"
"                            the <b>Website Settings</b> first."
msgstr ""
"<b>ຮັບເຄື່ອງຢູ່ຮ້ານ (Click &amp; Collect):</b>\n"
"                            ຖ້າທ່ານຕ້ອງການໃຫ້ບໍລິການນີ້, ທ່ານຕ້ອງ <b>ເປີດໃຊ້ການຕັ້ງຄ່າ</b> ໃ"
"ນ\n"
"                            <b>ການຕັ້ງຄ່າເວັບໄຊ</b> ກ່ອນ."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid "<b>Key Product Settings:</b>"
msgstr "<b>ການຕັ້ງຄ່າສິນຄ້າທີ່ສຳຄັນ:</b>"

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Layout Settings:</b> Adjust the visual\n"
"                    presentation and layout of products using the <b>website editor</b>."
msgstr ""
"<b>ການຕັ້ງຄ່າຮູບແບບ:</b> ປັບແຕ່ງການສະແດງຜົນ\n"
"                    ແລະ ຮູບແບບຂອງສິນຄ້າໂດຍໃຊ້ <b>ເຄື່ອງມືແກ້ໄຂເວັບໄຊ</b>."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Loyalty Programs:</b> Implement <b>loyalty cards</b> as a core\n"
"                            strategy to <b>activate customer retention</b> and increase lifetime\n"
"                            value."
msgstr ""
"<b>ໂປຣແກຣມສະມາຊິກ:</b> ໃຊ້ <b>ບັດສະສົມຄະແນນ</b> ເປັນກົນລະຍຸດ\n"
"                            ຫຼັກເພື່ອ <b>ຮັກສາຖານລູກຄ້າ</b> ແລະ ເພີ່ມມູນຄ່າ\n"
"                            ໃນໄລຍະຍາວ."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Manual Trigger</b> will display the demand in the\n"
"                    Inventory <b>Replenishment view </b>for you to confirm. <i>(Note:\n"
"                    Reordering rules work in conjunction with defined lead times.)</i>"
msgstr ""
"<b>ການກະຕຸ້ນດ້ວຍມື</b> ຈະສະແດງຄວາມຕ້ອງການໃນ\n"
"                    ໜ້າ <b>ການເຕີມສິນຄ້າ</b> ຂອງຄັງສິນຄ້າເພື່ອໃຫ້ທ່ານຢືນຢັນ. <i>(ໝາຍເຫດ:\n"
"                    ກົດເກນການສັ່ງຊື້ຄືນເຮັດວຽກຮ່ວມກັບໄລຍະເວລາການຈັດສົ່ງທີ່ກຳນົດໄວ້.)</i>"

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Optimal stock management</b> is achieved by <b>combining both the Reordering Rules and\n"
"            Suggested Replenishment</b> to ensure a comprehensive, forecast-aware stock follow-up."
msgstr ""
"<b>ການຈັດການສິນຄ້າຄົງຄັງທີ່ດີທີ່ສຸດ</b> ແມ່ນເກີດຈາກ <b>ການຮ່ວມມືກັນລະຫວ່າງ ກົດເກນການສັ່ງຊື້ຄືນ ແລະ\n"
"            ການແນະນຳການເຕີມສິນຄ້າ</b> ເພື່ອຮັບປະກັນການຕິດຕາມສິນຄ້າທີ່ຄອບຄຸມ ແລະ ຮູ້ເທົ່າທັນການຄ"
"າດຄະເນ."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Payment Providers &amp; Methods:</b> Go to <b>Website\n"
"                    &gt; Configuration &gt; Payment Providers</b> and install <b>all</b> the payment\n"
"                    methods and providers you plan to offer (e.g., credit card processors, PayPal,\n"
"                    etc.)."
msgstr ""
"<b>ຜູ້ໃຫ້ບໍລິການ ແລະ ວິທີການຊຳລະເງິນ:</b> ໄປທີ່ <b>ເວັບໄຊ\n"
"                    &gt; ການຕັ້ງຄ່າ &gt; ຜູ້ໃຫ້ບໍລິການຊຳລະເງິນ</b> ແລະ ຕິດຕັ້ງ <b>ທັງໝົດ</"
"b> \n"
"                    ວິທີການ ແລະ ຜູ້ໃຫ້ບໍລິການທີ່ທ່ານວາງແຜນຈະໃຊ້ (ເຊັ່ນ: ບັດເຄຣດິດ, PayPal,\n"
"                    ແລະອື່ນໆ)."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Payroll:</b> Use this feature to handle <b>employee salaries and manage holiday\n"
"                requests</b>."
msgstr ""
"<b>ບັນຊີເງິນເດືອນ:</b> ໃຊ້ຄຸນສົມບັດນີ້ເພື່ອຈັດການ <b>ເງິນເດືອນພະນັກງານ ແລະ ການຂໍ\n"
"                ພັກຜ່ອນ</b>."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Point of Sale Category:</b> For organizing\n"
"                    transactions within your shop system."
msgstr ""
"<b>ໝວດໝູ່ຈຸດຂາຍ:</b> ເພື່ອຈັດລະບຽບ\n"
"                    ການເຮັດທຸລະກຳພາຍໃນລະບົບຮ້ານຄ້າຂອງທ່ານ."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Pricelist Segmentation:</b> Define multiple pricing structures for the\n"
"                            same product, supporting different business models (e.g., B2B vs. B2C)\n"
"                            and enabling <b>client-specific pricing contracts</b>."
msgstr ""
"<b>ການແບ່ງກຸ່ມລາຍການລາຄາ:</b> ກຳນົດໂຄງສ້າງລາຄາທີ່ຫຼາກຫຼາຍສຳລັບ\n"
"                            ສິນຄ້າດຽວກັນ, ເພື່ອຮອງຮັບຮູບແບບທຸລະກິດທີ່ຕ່າງກັນ (ເຊັ່ນ: B2B ທຽບ"
"ກັບ B2C)\n"
"                            ແລະ ເປີດໃຊ້ <b>ສັນຍາລາຄາສະເພາະລູກຄ້າ</b>."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Product Category:</b> For internal tracking and\n"
"                    reporting."
msgstr ""
"<b>ໝວດໝູ່ສິນຄ້າ:</b> ສຳລັບການຕິດຕາມພາຍໃນ ແລະ\n"
"                    ການລາຍງານ."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Product-Level Settings:</b> Define core product\n"
"                    settings directly on the <b>product form</b>."
msgstr ""
"<b>ການຕັ້ງຄ່າລະດັບສິນຄ້າ:</b> ກຳນົດການຕັ້ງຄ່າ\n"
"                    ສິນຄ້າຫຼັກໂດຍກົງໃນ <b>ຟອມສິນຄ້າ</b>."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Promotional Agility:</b> Use <b>discounts and promotions</b> to\n"
"                            quickly adjust pricing for sales events or to give targeted, <b>manual\n"
"                            reductions</b> at the point of sale."
msgstr ""
"<b>ຄວາມຄ່ອງຕົວໃນການສົ່ງເສີມການຂາຍ:</b> ໃຊ້ <b>ສ່ວນຫຼຸດ ແລະ ໂປຣໂມຊັນ</b> ເພື່ອ\n"
"                            ປັບລາຄາຢ່າງໄວວາສຳລັບກິດຈະກຳການຂາຍ ຫຼື ເພື່ອໃຫ້ <b>ສ່ວນຫຼຸດ\n"
"                            ດ້ວຍມື</b> ທີ່ຈຸດຂາຍ."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Publishing:</b> Each product can be <b>published\n"
"                    independently</b> on your online store."
msgstr ""
"<b>ການເຜີຍແຜ່:</b> ສິນຄ້າແຕ່ລະຢ່າງສາມາດຖືກ <b>ເຜີຍແຜ່\n"
"                    ແຍກກັນ</b> ໃນຮ້ານຄ້າອອນລາຍຂອງທ່ານ."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Qualify Leads:</b> Engage with the client through\n"
"                    the CRM opportunity to fully understand their request—whether it's a need for a\n"
"                    specific product, a supplier inquiry, or general information."
msgstr ""
"<b>ຄັດກອງລູກຄ້າເປົ້າໝາຍ:</b> ສື່ສານກັບລູກຄ້າຜ່ານ\n"
"                    ໂອກາດ CRM ເພື່ອເຂົ້າໃຈຄວາມຕ້ອງການຂອງພວກເຂົາຢ່າງຄົບຖ້ວນ—ບໍ່ວ່າຈະເປັນຄວາ"
"ມຕ້ອງການ\n"
"                    ສິນຄ້າສະເພາະ, ການສອບຖາມຜູ້ສະໜອງ ຫຼື ຂໍ້ມູນທົ່ວໄປ."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Quote and Confirm:</b> If a specific demand\n"
"                    requires pricing, generate a <b>quotation directly from the opportunity</b>. The\n"
"                    client can then <b>confirm and sign it online</b>."
msgstr ""
"<b>ສະເໜີລາຄາ ແລະ ຢືນຢັນ:</b> ຖ້າຄວາມຕ້ອງການສະເພາະໃດໜຶ່ງ\n"
"                    ຕ້ອງມີການກຳນົດລາຄາ, ໃຫ້ສ້າງ <b>ໃບສະເໜີລາຄາໂດຍກົງຈາກໂອກາດ</b>. \n"
"                    ລູກຄ້າສາມາດ <b>ຢືນຢັນ ແລະ ເຊັນຊື່ທາງອອນລາຍ</b> ໄດ້."

