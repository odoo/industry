#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>\n"
"                    SEO features</b>"
msgstr ""
"<b>\n"
"                    SEO özellikleri</b>"

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Inventory App:</font></b> Keep precise "
"track of stock levels for diverse products\n"
"                like pesticides and equipment."
msgstr ""

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Point of Sale App:</font></b> Manage in-"
"store transactions efficiently, handling sales of seeds, tools, and supplies "
"with ease."
msgstr ""

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Purchase App:</font></b> Streamline the "
"procurement of farming products from suppliers, managing costs and lead "
"times."
msgstr ""

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Sales App:</font></b> Handle B2B orders "
"and contracts for large farming clients, ensuring accurate pricing."
msgstr ""

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Website App:</font></b><font class=\"text-"
"o-color-3\"> Build a professional online presence to showcase your catalog "
"and attract new customers.</font>"
msgstr ""

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">eCommerce App:</font></b> Expand your "
"reach by selling products online, offering convenience to modern farmers."
msgstr ""

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Accounting:</b> Automatically log payments, close sessions, and generate "
"tax\n"
"                    reports."
msgstr ""
"<b>Muhasebe:</b> Ödemeleri otomatik olarak kaydedin, oturumları kapatın ve "
"vergi oluşturun\n"
"                    raporlar."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Automated Trigger</b> will instantly create a\n"
"                    purchase order."
msgstr ""
"<b>Otomatik Tetikleyici</b> anında bir\n"
"                    Satın alma emri."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Automatic Delivery:</b> Once the quote is\n"
"                    accepted, the system automatically creates a linked "
"<b>Delivery Order</b>, just\n"
"                    as it does for a regular e-commerce order."
msgstr ""
"<b>Otomatik Teslimat:</b> Alıntı yapıldıktan sonra\n"
"                    kabul edildiğinde, sistem otomatik olarak bağlantılı bir "
"<b>Teslimat Siparişi</b> oluşturur, sadece\n"
"                    normal bir e-ticaret siparişinde olduğu gibi."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Capture Requests:</b> Any submission via the <b>\"Contact\n"
"                    Us\"</b> page instantly generates a new <b>CRM "
"opportunity</b>."
msgstr ""
"<b>Yakalama Talepleri:</b> <b> \"İletişim\" adresi üzerinden yapılan tüm "
"başvurular\n"
"                    Biz\"</b> sayfası anında yeni bir <b>CRM fırsatı</b> "
"oluşturur."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Crucial Review:</b> You must review all\n"
"                    e-commerce settings to ensure they align with your "
"internal business policies\n"
"                    (e.g., when invoices are generated, whether a mandatory "
"customer check-in is\n"
"                    required for ordering, etc.)."
msgstr ""
"<b>Önemli İnceleme:</b> Tümünü gözden geçirmelisiniz\n"
"                    e-ticaret ayarlarının dahili iş politikalarınızla uyumlu "
"olduğundan emin olmak için\n"
"                    (örneğin, faturaların ne zaman oluşturulduğu, zorunlu "
"müşteri check-in işleminin yapılıp yapılmadığı\n"
"                    sipariş için gerekli, vb.)."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Define B2B Pricing:</b> Create and assign a <b>dedicated\n"
"                    pricelist</b> to each B2B contact. Ensure this pricelist "
"is active on your\n"
"                    website so the customer sees their agreed-upon prices "
"upon login."
msgstr ""
"<b>B2B Fiyatlandırmasını Tanımlayın:</b> Özel bir <b>oluşturun ve atayın\n"
"                    fiyat listesi</b> her B2B irtibat kişisine. Bu fiyat "
"listesinin aktif olduğundan emin olun.\n"
"                    Böylece müşteri giriş yaptığında üzerinde anlaşılan "
"fiyatları görür."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Delivery Methods:</b> Go to <b>Website &gt;\n"
"                    Configuration &gt; Delivery Methods</b> to define all "
"available options and\n"
"                    their costs."
msgstr ""
"<b>Teslimat Yöntemleri:</b> <b> Web Sitesine Git &gt;\n"
"                    Yapılandırma &gt; Teslimat Yöntemleri</b> mevcut tüm "
"seçenekleri tanımlamak ve\n"
"                    maliyetleri."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>E-commerce Category:</b> For easier product\n"
"                    retrieval by customers on your online store."
msgstr ""
"<b>E-ticaret Kategorisi:</b> Daha kolay ürün için\n"
"                    çevrimiçi mağazanızdaki müşteriler tarafından alınabilir."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>External Providers:</b> Check if a\n"
"                            predefined Odoo connection exists if you work "
"with specific shipping\n"
"                            carriers."
msgstr ""
"<b>Harici Sağlayıcılar:</b> Kontrol edin eğer bir\n"
"                            Belirli bir kargo ile çalışıyorsanız önceden "
"tanımlanmış Odoo bağlantısı mevcuttur\n"
"                            Taşıyıcılar."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Field Service:</b> Implement this module if you <b>offer on-site repair "
"or\n"
"                maintenance services</b>."
msgstr ""
"<b>Saha Hizmetleri:</b> Bu modülü <b>yerinde onarım hizmeti sunuyorsanız "
"veya\n"
"                Bakım hizmetleri</b>."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>In-Store Pickup (Click &amp; Collect):</b>\n"
"                            If you wish to offer this, you must <b>activate "
"the setting</b> within\n"
"                            the <b>Website Settings</b> first."
msgstr ""
"<b>Mağaza İçi Teslim Alma ( &amp; Collect'e tıklayın):</b>\n"
"                            Bunu sunmak istiyorsanız, <b>içinde</b> ayarını "
"etkinleştirmeniz gerekir.\n"
"                            önce <b>Web Sitesi Ayarları</b> adresini ziyaret "
"edin."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid "<b>Key Product Settings:</b>"
msgstr "<b>Anahtar Ürün Ayarları:</b>"

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Layout Settings:</b> Adjust the visual\n"
"                    presentation and layout of products using the <b>website "
"editor</b>."
msgstr ""
"<b>Düzen Ayarları:</b> Görselliği ayarlayın\n"
"                    <b> web sitesi editörü</b> kullanılarak ürünlerin sunumu "
"ve düzeni."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Loyalty Programs:</b> Implement <b>loyalty cards</b> as a core\n"
"                            strategy to <b>activate customer retention</b> "
"and increase lifetime\n"
"                            value."
msgstr ""
"<b>Sadakat Programları:</b> <b> sadakat kartlarını</b> çekirdek olarak "
"uygulayın\n"
"                            strateji <b>müşteriyi elde tutmayı "
"etkinleştirmek</b> ve yaşam süresini artırmak\n"
"                            değer."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Manual Trigger</b> will display the demand in the\n"
"                    Inventory <b>Replenishment view </b>for you to confirm. "
"<i>(Note:\n"
"                    Reordering rules work in conjunction with defined lead "
"times.)</i>"
msgstr ""
"<b>Manuel Tetik</b> adresinde talebi görüntüleyecektir.\n"
"                    Envanter <b>Yenileme görünümü </b>onaylamanız için. "
"<i>(Not:\n"
"                    Yeniden sipariş kuralları tanımlanmış teslim süreleri "
"ile birlikte çalışır).</i>"

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Optimal stock management</b> is achieved by <b>combining both the "
"Reordering Rules and\n"
"            Suggested Replenishment</b> to ensure a comprehensive, forecast-"
"aware stock follow-up."
msgstr ""
"<b>Optimum stok yönetimi</b> <b> tarafından hem Yeniden Sıralama Kuralları "
"hem de\n"
"            Kapsamlı, öngörüye dayalı bir stok takibi sağlamak için Önerilen "
"Yenileme</b>."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Payment Providers &amp; Methods:</b> Go to <b>Website\n"
"                    &gt; Configuration &gt; Payment Providers</b> and "
"install <b>all</b> the payment\n"
"                    methods and providers you plan to offer (e.g., credit "
"card processors, PayPal,\n"
"                    etc.)."
msgstr ""
"<b>Ödeme Sağlayıcıları &amp; Yöntemleri:</b> <b> Web Sitesine Git\n"
"                    &gt; Yapılandırma &gt; Ödeme Sağlayıcıları</b> ve "
"yükleme <b>tüm</b> ödeme\n"
"                    sunmayı planladığınız yöntemler ve sağlayıcılar (örn. "
"alacak işlemcileri, PayPal,\n"
"                    vb.)."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Payroll:</b> Use this feature to handle <b>employee salaries and manage "
"holiday\n"
"                requests</b>."
msgstr ""
"<b>Bordro:</b> <b> çalışan maaşlarını işlemek ve tatil taleolerini yönetmek "
"için bu özelliği\n"
"                kullanın</b>."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Point of Sale Category:</b> For organizing\n"
"                    transactions within your shop system."
msgstr ""
"<b>Satış Noktası Kategorisi:</b> Organize etmek için\n"
"                    mağaza sisteminizdeki işlemleri."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Pricelist Segmentation:</b> Define multiple pricing structures for the\n"
"                            same product, supporting different business "
"models (e.g., B2B vs. B2C)\n"
"                            and enabling <b>client-specific pricing "
"contracts</b>."
msgstr ""
"<b>Fiyat Listesi Segmentasyonu:</b> için çoklu fiyatlandırma yapıları "
"tanımlayın.\n"
"                            farklı iş modellerini destekleyen aynı ürün (ör. "
"B2B ve B2C)\n"
"                            ve <b>müşteriye özel fiyatlandırma "
"sözleşmelerinin etkinleştirilmesi</b>."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Product Category:</b> For internal tracking and\n"
"                    reporting."
msgstr ""
"<b>Ürün Kategorisi:</b> Dahili takip için ve\n"
"                    Raporlama."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Product-Level Settings:</b> Define core product\n"
"                    settings directly on the <b>product form</b>."
msgstr ""
"<b>Ürün Seviyesi Ayarları:</b> Temel ürünü tanımlayın\n"
"                    ayarları doğrudan <b>ürün formunda</b>."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Promotional Agility:</b> Use <b>discounts and promotions</b> to\n"
"                            quickly adjust pricing for sales events or to "
"give targeted, <b>manual\n"
"                            reductions</b> at the point of sale."
msgstr ""
"<b>Promosyon Çevikliği:</b> <b> indirim ve promosyonlarını</b> için "
"kullanın\n"
"                            satış etkinlikleri için fiyatlandırmayı hızlı "
"bir şekilde ayarlamak veya hedeflenen, <b>kılavuzu vermek için\n"
"                            indirimler</b> satış noktasında."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Publishing:</b> Each product can be <b>published\n"
"                    independently</b> on your online store."
msgstr ""
"<b>Yayınlama:</b> Her ürün <b>yayınlanabilir\n"
"                    çevrimiçi mağazanızda bağımsız olarak</b>."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Qualify Leads:</b> Engage with the client through\n"
"                    the CRM opportunity to fully understand their request—"
"whether it's a need for a\n"
"                    specific product, a supplier inquiry, or general "
"information."
msgstr ""
"<b>Müşteri Adaylarını Nitelendirin:</b> Müşteri ile şu yollarla etkileşim "
"kurun\n"
"                    taleplerini tam olarak anlamak için CRM fırsatı - ister "
"bir ihtiyaç olsun\n"
"                    belirli bir ürün, tedarikçi sorgusu veya genel bilgi."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Quote and Confirm:</b> If a specific demand\n"
"                    requires pricing, generate a <b>quotation directly from "
"the opportunity</b>. The\n"
"                    client can then <b>confirm and sign it online</b>."
msgstr ""
"<b>Teklif Verin ve Onaylayın:</b> Belirli bir talep varsa\n"
"                    fiyatlandırma gerektiriyorsa, doğrudan</b> fırsatından "
"bir <b>fiyat teklifi oluşturun. Fiyatlandırma\n"
"                    müşteri daha sonra <b>onaylayabilir ve çevrimiçi olarak</"
"b> imzalayabilir."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid "<b>Use the</b>"
msgstr "<b>Kullanın</b>"

