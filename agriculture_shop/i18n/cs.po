#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>\n"
"                    SEO features</b>"
msgstr ""
"<b>\n"
"                    Funkce SEO</b>"

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Inventory App:</font></b> Keep precise "
"track of stock levels for diverse products\n"
"                like pesticides and equipment."
msgstr ""

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Point of Sale App:</font></b> Manage in-"
"store transactions efficiently, handling sales of seeds, tools, and supplies "
"with ease."
msgstr ""

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Purchase App:</font></b> Streamline the "
"procurement of farming products from suppliers, managing costs and lead "
"times."
msgstr ""

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Sales App:</font></b> Handle B2B orders "
"and contracts for large farming clients, ensuring accurate pricing."
msgstr ""

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Website App:</font></b><font class=\"text-"
"o-color-3\"> Build a professional online presence to showcase your catalog "
"and attract new customers.</font>"
msgstr ""

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">eCommerce App:</font></b> Expand your "
"reach by selling products online, offering convenience to modern farmers."
msgstr ""

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Accounting:</b> Automatically log payments, close sessions, and generate "
"tax\n"
"                    reports."
msgstr ""
"<b>Účetnictví:</b> Automaticky zaznamenávejte platby, uzavírejte relace a "
"generujte daňové\n"
"                    hlášení."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Automated Trigger</b> will instantly create a\n"
"                    purchase order."
msgstr ""
"<b>Automatická spouštěcí funkce</b> okamžitě vytvoří\n"
"                    objednávku."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Automatic Delivery:</b> Once the quote is\n"
"                    accepted, the system automatically creates a linked "
"<b>Delivery Order</b>, just\n"
"                    as it does for a regular e-commerce order."
msgstr ""
"<b>Automatické doručení:</b> Jakmile je nabídka\n"
"                    přijata, systém automaticky vytvoří propojenou <b>dodací "
"objednávku</b>, stejně\n"
"                    jako u běžné e-commerce objednávky."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Capture Requests:</b> Any submission via the <b>\"Contact\n"
"                    Us\"</b> page instantly generates a new <b>CRM "
"opportunity</b>."
msgstr ""
"<b>Zachycování žádosti:</b> Jakékoli podání prostřednictvím stránky "
"<b>„Kontaktujte\n"
" nás“</b> na webu okamžitě generuje novou <b>příležitost CRM</b> ."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Crucial Review:</b> You must review all\n"
"                    e-commerce settings to ensure they align with your "
"internal business policies\n"
"                    (e.g., when invoices are generated, whether a mandatory "
"customer check-in is\n"
"                    required for ordering, etc.)."
msgstr ""
"<b>Klíčová recenze:</b> Musíte zkontrolovat všechna\n"
"                    nastavení elektronického obchodu, abyste se ujistili, že "
"jsou v souladu s vašimi interními obchodními zásadami\n"
"                    (např. kdy se generují faktury, zda je pro objednávku "
"vyžadována povinná registrace zákazníka\n"
"                    atd.)."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Define B2B Pricing:</b> Create and assign a <b>dedicated\n"
"                    pricelist</b> to each B2B contact. Ensure this pricelist "
"is active on your\n"
"                    website so the customer sees their agreed-upon prices "
"upon login."
msgstr ""
"<b>Definujte ceny B2B:</b> Vytvořte a přiřaďte každému kontaktu B2B "
"<b>speciální ceník</b> . Ujistěte se, že je tento ceník aktivní na vašem\n"
"                    webu, aby zákazník po přihlášení viděl dohodnuté ceny."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Delivery Methods:</b> Go to <b>Website &gt;\n"
"                    Configuration &gt; Delivery Methods</b> to define all "
"available options and\n"
"                    their costs."
msgstr ""
"<b>Způsoby doručení:</b> Přejděte na <b>Webové stránky&gt; \n"
"                    Konfigurace &gt; Způsoby doručení</b>, kde jsou uvedeny "
"všechny dostupné možnosti a\n"
"                    jejich ceny."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>E-commerce Category:</b> For easier product\n"
"                    retrieval by customers on your online store."
msgstr ""
"<b>Kategorie e-Shopu:</b> Pro snazší vyhledávání produktů\n"
"                    zákazníky ve vašem internetovém obchodě."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>External Providers:</b> Check if a\n"
"                            predefined Odoo connection exists if you work "
"with specific shipping\n"
"                            carriers."
msgstr ""
"<b>Externí poskytovatelé:</b> Zkontrolujte, zda existuje\n"
"                            předdefinované připojení Odoo, pokud pracujete s "
"konkrétními přepravci."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Field Service:</b> Implement this module if you <b>offer on-site repair "
"or\n"
"                maintenance services</b>."
msgstr ""
"<b>Terénní služby:</b> Tento modul implementujte, pokud <b>nabízíte opravy "
"nebo\n"
"                údržbu na místě</b>."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>In-Store Pickup (Click &amp; Collect):</b>\n"
"                            If you wish to offer this, you must <b>activate "
"the setting</b> within\n"
"                            the <b>Website Settings</b> first."
msgstr ""
"<b> Osobní odběr v obchodě (Click &amp; Collect):</b>\n"
"                            Pokud chcete tuto službu nabízet, musíte nejprve "
"<b>aktivovat nastavení</b> v\n"
"                            <b>nastavení webových stránek</b> ."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid "<b>Key Product Settings:</b>"
msgstr "<b>Klíčová nastavení produktu:</b>"

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Layout Settings:</b> Adjust the visual\n"
"                    presentation and layout of products using the <b>website "
"editor</b>."
msgstr ""
"<b>Nastavení rozvržení:</b> Upravte vizuální\n"
"                    prezentaci a rozvržení produktů pomocí <b>editoru "
"webových stránek</b> ."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Loyalty Programs:</b> Implement <b>loyalty cards</b> as a core\n"
"                            strategy to <b>activate customer retention</b> "
"and increase lifetime\n"
"                            value."
msgstr ""
"<b>Věrnostní programy:</b> Zaveďte <b>věrnostní karty</b> jako základní\n"
"                            strategii pro <b>aktivování udržení zákazníků</"
"b> a zvýšení celoživotní\n"
"                            hodnoty."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Manual Trigger</b> will display the demand in the\n"
"                    Inventory <b>Replenishment view </b>for you to confirm. "
"<i>(Note:\n"
"                    Reordering rules work in conjunction with defined lead "
"times.)</i>"
msgstr ""
"<b>Ruční spouštěč</b> zobrazí poptávku v\n"
"                    pohledu <b>doplňování skladových zásob</b>, kde ji "
"můžete potvrdit. <i>(Poznámka:\n"
"                    Pravidla pro objednávání fungují ve spojení s "
"definovanými dodacími lhůtami.)</i>"

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Optimal stock management</b> is achieved by <b>combining both the "
"Reordering Rules and\n"
"            Suggested Replenishment</b> to ensure a comprehensive, forecast-"
"aware stock follow-up."
msgstr ""
"<b>Optimální řízení zásob</b> je dosaženo <b>kombinací pravidel pro "
"objednávky a\n"
"            navrhovaného doplňování zásob</b>, které zajišťují komplexní "
"sledování zásob s ohledem na prognózy."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Payment Providers &amp; Methods:</b> Go to <b>Website\n"
"                    &gt; Configuration &gt; Payment Providers</b> and "
"install <b>all</b> the payment\n"
"                    methods and providers you plan to offer (e.g., credit "
"card processors, PayPal,\n"
"                    etc.)."
msgstr ""
"<b>Poskytovatelé platebních služeb a metod:</b> Přejděte na <b>webovou "
"stránku &gt; Konfigurace &gt; Poskytovatelé platebních služeb</b> a "
"nainstalujte <b>všechny</b> platební\n"
"                    metody a poskytovatele, které plánujete nabízet (např. "
"zpracovatelé plateb kreditními kartami, PayPal,\n"
"                    atd.)."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Payroll:</b> Use this feature to handle <b>employee salaries and manage "
"holiday\n"
"                requests</b>."
msgstr ""
"<b>Mzdy:</b> Tuto funkci použijte ke zpracování mezd zaměstnanců <b>a správě "
"žádostí o dovolenou\n"
"               </b> ."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Point of Sale Category:</b> For organizing\n"
"                    transactions within your shop system."
msgstr ""
"<b>Kategorie prodejních míst:</b> Pro organizaci\n"
"                    transakcí v rámci vašeho obchodního systému."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Pricelist Segmentation:</b> Define multiple pricing structures for the\n"
"                            same product, supporting different business "
"models (e.g., B2B vs. B2C)\n"
"                            and enabling <b>client-specific pricing "
"contracts</b>."
msgstr ""
"<b>Segmentace ceníku:</b> Definujte více cenových struktur pro\n"
"                            stejný produkt, podporujte různé obchodní modely "
"(např. B2B vs. B2C)\n"
"                            a umožněte <b>uzavírání cenových smluv "
"specifických pro jednotlivé klienty</b>."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Product Category:</b> For internal tracking and\n"
"                    reporting."
msgstr ""
"<b>Kategorie produktu:</b> Pro interní sledování a\n"
"                    reporting."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Product-Level Settings:</b> Define core product\n"
"                    settings directly on the <b>product form</b>."
msgstr ""
"<b>Nastavení na úrovni produktu:</b> Definujte základní nastavení produktu\n"
"přímo ve <b>formuláři produktu</b>."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Promotional Agility:</b> Use <b>discounts and promotions</b> to\n"
"                            quickly adjust pricing for sales events or to "
"give targeted, <b>manual\n"
"                            reductions</b> at the point of sale."
msgstr ""
"<b>Propagační flexibilita:</b> Využijte <b>slevy a propagační akce </b> k\n"
"                            rychlé úpravě cen pro prodejní akce nebo k "
"poskytnutí cílených, <b>manuálních\n"
"                            slev</b> na prodejních místech."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Publishing:</b> Each product can be <b>published\n"
"                    independently</b> on your online store."
msgstr ""
"<b>Publikování:</b> Každý produkt lze <b>publikovat\n"
"                    nezávisle</b> ve vašem internetovém obchodě."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Qualify Leads:</b> Engage with the client through\n"
"                    the CRM opportunity to fully understand their request—"
"whether it's a need for a\n"
"                    specific product, a supplier inquiry, or general "
"information."
msgstr ""
"<b>Kvalifikujte potenciální zákazníky:</b> Komunikujte s klientem "
"prostřednictvím\n"
"                    příležitosti CRM, abyste plně porozuměli jeho požadavku "
"– ať už se jedná o potřebu\n"
"                    konkrétního produktu, dotaz na dodavatele nebo obecné "
"informace."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Quote and Confirm:</b> If a specific demand\n"
"                    requires pricing, generate a <b>quotation directly from "
"the opportunity</b>. The\n"
"                    client can then <b>confirm and sign it online</b>."
msgstr ""
"<b>Cenová nabídka a potvrzení:</b> Pokud konkrétní poptávka\n"
"                    vyžaduje stanovení ceny, vygenerujte cenovou nabídku "
"<b>přímo z příležitosti</b>.\n"
"                    Klient ji pak může <b>potvrdit a podepsat online</b>."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid "<b>Use the</b>"
msgstr "<b>Použijte</b>"

