"                                                <span "
"class=\"o_force_ltr\">+1 (650) 555-0111</span>"
msgstr ""
"<i class=\"fa fa-phone fa-fw me-2\"/>\n"
"                                                <span "
"class=\"o_force_ltr\">+1 (650) 555-0111</span>"

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<i class=\"o_editor_banner_icon mb-3 fst-normal\" data-oe-aria-"
"label=\"Banner Info\">💡</i>"
msgstr ""
"<i class=\"o_editor_banner_icon mb-3 fst-normal\" data-oe-aria-"
