#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>\n"
"                    SEO features</b>"
msgstr ""
"<b>\n"
"                    Recursos de SEO</b>"

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Inventory App:</font></b> Keep precise "
"track of stock levels for diverse products\n"
"                like pesticides and equipment."
msgstr ""
"<b><font class=\"text-o-color-1\">App Inventário:</font></b> Acompanhe com "
"precisão os níveis de estoque de diversos produtos,\n"
"como pesticidas e equipamentos."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Point of Sale App:</font></b> Manage in-"
"store transactions efficiently, handling sales of seeds, tools, and supplies "
"with ease."
msgstr ""
"<b><font class=\"text-o-color-1\">App Ponto de Venda:</font></b> Gerencie as "
"transações na loja com eficiência, lidando com facilidade com as vendas de "
"sementes, ferramentas e suprimentos."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Purchase App:</font></b> Streamline the "
"procurement of farming products from suppliers, managing costs and lead "
"times."
msgstr ""
"<b><font class=\"text-o-color-1\">App Compras:</font></b> Simplifique a "
"aquisição de produtos agrícolas de fornecedores, gerenciando custos e prazos "
"de entrega."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Sales App:</font></b> Handle B2B orders "
"and contracts for large farming clients, ensuring accurate pricing."
msgstr ""
"<b><font class=\"text-o-color-1\">App Vendas:</font></b> Gerencie pedidos e "
"contratos B2B para grandes clientes agrícolas, garantindo preços precisos."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Website App:</font></b><font class=\"text-"
"o-color-3\"> Build a professional online presence to showcase your catalog "
"and attract new customers.</font>"
msgstr ""
"<b><font class=\"text-o-color-1\">App Site:</font></b><font class=\"text-o-"
"color-3\"> Crie uma presença online profissional para mostrar seu catálogo e "
"atrair novos clientes.</font>"

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">eCommerce App:</font></b> Expand your "
"reach by selling products online, offering convenience to modern farmers."
msgstr ""
"<b><font class=\"text-o-color-1\">App e-Commerce:</font></b> Expanda seu "
"alcance vendendo produtos online, oferecendo conveniência aos agricultores "
"modernos."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Accounting:</b> Automatically log payments, close sessions, and generate "
"tax\n"
"                    reports."
msgstr ""
"<b>Contabilidade:</b> Registre automaticamente os pagamentos, encerre as "
"sessões e gere relatórios fiscais.\n"
"                    relatórios fiscais."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Automated Trigger</b> will instantly create a\n"
"                    purchase order."
msgstr ""
"<b>O acionador automático</b> criará um\n"
"                    pedido de compra instantaneamente."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Automatic Delivery:</b> Once the quote is\n"
"                    accepted, the system automatically creates a linked "
"<b>Delivery Order</b>, just\n"
"                    as it does for a regular e-commerce order."
msgstr ""
"<b>Entrega automática:</b> Quando a cotação é\n"
"                    aceita, o sistema cria automaticamente um pedido de "
"entrega vinculado <b></b> , da mesma forma\n"
"                    como em um pedido de e-Commerce normal."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Capture Requests:</b> Any submission via the <b>\"Contact\n"
"                    Us\"</b> page instantly generates a new <b>CRM "
"opportunity</b>."
msgstr ""
"<b>Capturar solicitações:</b> Envios feitos pela página <b>\"Entre em\n"
"contato\"</b> instantaneamente criam uma nova oportunidade no CRM <b></b> ."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Crucial Review:</b> You must review all\n"
"                    e-commerce settings to ensure they align with your "
"internal business policies\n"
"                    (e.g., when invoices are generated, whether a mandatory "
"customer check-in is\n"
"                    required for ordering, etc.)."
msgstr ""
"<b>Revisão crucial:</b> Você deve revisar todas as\n"
"                    configurações de e-Commerce para garantir que estejam "
"alinhadas com suas políticas comerciais internas\n"
"                    (ex.: quando as faturas são geradas, se é\n"
"                    obrigatório que o cliente faça checkin para fazer "
"pedidos, etc.)."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Define B2B Pricing:</b> Create and assign a <b>dedicated\n"
"                    pricelist</b> to each B2B contact. Ensure this pricelist "
"is active on your\n"
"                    website so the customer sees their agreed-upon prices "
"upon login."
msgstr ""
"<b>Defina preços B2B:</b> Crie e atribua uma <b>\n"
"                    lista de preços dedicada</b>para cada contato B2B. "
"Certifique-se de que essa lista de preços esteja ativa no\n"
"site para que o cliente veja os preços acordados ao fazer login."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Delivery Methods:</b> Go to <b>Website &gt;\n"
"                    Configuration &gt; Delivery Methods</b> to define all "
"available options and\n"
"                    their costs."
msgstr ""
"<b>Métodos de entrega:</b> Acesse <b>Site &gt;\n"
"                    Configuração &gt; Métodos de entrega</b> para definir as "
"opções disponíveis e\n"
"                    seus custos."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>E-commerce Category:</b> For easier product\n"
"                    retrieval by customers on your online store."
msgstr ""
"<b>Categoria do e-Commerce:</b> Para facilitar a\n"
"                    a recuperação de produtos pelos clientes em sua loja on-"
"line."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>External Providers:</b> Check if a\n"
"                            predefined Odoo connection exists if you work "
"with specific shipping\n"
"                            carriers."
msgstr ""
"<b>Provedores externos:</b> Verifique se existe uma conexão\n"
"                            conexão predefinida do Odoo, se você trabalha "
"com transportadoras específicas\n"
"                            transportadoras específicas."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Field Service:</b> Implement this module if you <b>offer on-site repair "
"or\n"
"                maintenance services</b>."
msgstr ""
"<b>Serviços de Campo:</b> Implemente este módulo se você <b>oferecer "
"serviços de reparo ou manutenção no local\n"
"                ou serviços de manutenção no local</b>."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>In-Store Pickup (Click &amp; Collect):</b>\n"
"                            If you wish to offer this, you must <b>activate "
"the setting</b> within\n"
"                            the <b>Website Settings</b> first."
msgstr ""
"<b>Retirada na loja (clique em &amp; Collect):</b>\n"
"                            Se quiser oferecer essa opção, você deverá "
"<b>ativar a configuração</b> em\n"
"                            nas configurações do site <b></b> primeiro."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid "<b>Key Product Settings:</b>"
msgstr "<b>Principais definições de produtos:</b>"

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Layout Settings:</b> Adjust the visual\n"
"                    presentation and layout of products using the <b>website "
"editor</b>."
msgstr ""
"<b>Definições de layout:</b> Ajuste a apresentação visual\n"
"e o layout dos produtos usando o editor do site <b></b> ."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Loyalty Programs:</b> Implement <b>loyalty cards</b> as a core\n"
"                            strategy to <b>activate customer retention</b> "
"and increase lifetime\n"
"                            value."
msgstr ""
"<b>Programas de fidelidade:</b> Implemente <b>cartões de fidelidade</b> como "
"estratégia\n"
"central para <b>ativar a retenção</b> de clientes e aumentar\n"
"o valor ao longo do tempo."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Manual Trigger</b> will display the demand in the\n"
"                    Inventory <b>Replenishment view </b>for you to confirm. "
"<i>(Note:\n"
"                    Reordering rules work in conjunction with defined lead "
"times.)</i>"
msgstr ""
"<b>O acionamento manual</b> exibirá a demanda na visualização de reposição "
"do Inventário <b> </b> para que você confirme. <i>(Observação:\n"
"                    as regras de reposição funcionam em conjunto com os "
"prazos de entrega definidos.)</i>"

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Optimal stock management</b> is achieved by <b>combining both the "
"Reordering Rules and\n"
"            Suggested Replenishment</b> to ensure a comprehensive, forecast-"
"aware stock follow-up."
msgstr ""
"Alcance <b>a gestão ideal de estoque</b> com a <b>combinação de Regras de "
"Reposição e\n"
"            Sugestão de Reposição</b>, garantindo um acompanhamento "
"abrangente e consciente das previsões de estoque."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Payment Providers &amp; Methods:</b> Go to <b>Website\n"
"                    &gt; Configuration &gt; Payment Providers</b> and "
"install <b>all</b> the payment\n"
"                    methods and providers you plan to offer (e.g., credit "
"card processors, PayPal,\n"
"                    etc.)."
msgstr ""
"<b>Provedores e Métodos de pagamento:</b> Acesse o app <b> Site\n"
" &gt; Configuração &gt; Provedores de pagamento</b> e instale <b>todos</b> "
"os métodos\n"
"e provedores de pagamento que pretende oferecer (ex.: processadores de "
"crédito, PayPal\n"
"etc.)."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Payroll:</b> Use this feature to handle <b>employee salaries and manage "
"holiday\n"
"                requests</b>."
msgstr ""
"<b>Folha de pagamento:</b> Use este recurso para lidar com <b>salários dos "
"funcionários e gerenciar solicitações de\n"
"férias</b>."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Point of Sale Category:</b> For organizing\n"
"                    transactions within your shop system."
msgstr ""
"<b>Categoria de ponto de venda:</b> Para organizar\n"
"transações dentro do sistema da sua loja."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Pricelist Segmentation:</b> Define multiple pricing structures for the\n"
"                            same product, supporting different business "
"models (e.g., B2B vs. B2C)\n"
"                            and enabling <b>client-specific pricing "
"contracts</b>."
msgstr ""
"<b>Segmentação de listas de preços:</b> Defina várias estruturas de preços "
"para o\n"
"mesmo produto, oferecendo suporte a diferentes modelos de negócios (ex.: B2B "
"vs. B2C)\n"
"e permitindo contratos de preços específicos para cada cliente <b>.</b>."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Product Category:</b> For internal tracking and\n"
"                    reporting."
msgstr ""
"<b>Categoria do produto:</b> Para rastreamento interno e\n"
"                    relatórios."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Product-Level Settings:</b> Define core product\n"
"                    settings directly on the <b>product form</b>."
msgstr ""
"<b>Configurações no nível do produto:</b> Defina as configurações principais "
"do produto\n"
"diretamente no <b> formulário do produto</b> ."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Promotional Agility:</b> Use <b>discounts and promotions</b> to\n"
"                            quickly adjust pricing for sales events or to "
"give targeted, <b>manual\n"
"                            reductions</b> at the point of sale."
msgstr ""
"<b>Agilidade promocional:</b> Use descontos e promoções <b></b> para\n"
"                            ajustar rapidamente os preços para eventos de "
"vendas ou para oferecer reduções manuais direcionadas e "
"<b>                           </b> no ponto de venda."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Publishing:</b> Each product can be <b>published\n"
"                    independently</b> on your online store."
msgstr ""
"<b>Publicação:</b> Cada produto pode ser publicado de forma independente "
"<b>                    em sua loja online</b>."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Qualify Leads:</b> Engage with the client through\n"
"                    the CRM opportunity to fully understand their request—"
"whether it's a need for a\n"
"                    specific product, a supplier inquiry, or general "
"information."
msgstr ""
"<b>Qualifique os leads:</b> Interaja com o cliente pela\n"
"oportunidade no CRM para entender bem a solicitação dele — seja uma "
"necessidade de um\n"
"produto específico, uma consulta sobre fornecedores ou informações gerais."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Quote and Confirm:</b> If a specific demand\n"
"                    requires pricing, generate a <b>quotation directly from "
"the opportunity</b>. The\n"
"                    client can then <b>confirm and sign it online</b>."
msgstr ""
"<b>Cotação e confirmação:</b> Se uma demanda específica\n"
"                    exigir uma cotação, gere uma cotação <b>diretamente da "
"oportunidade</b>. O\n"
"                    cliente pode então <b>confirmá-la e assiná-la online</b>."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid "<b>Use the</b>"
msgstr "<b>Usar</b>"

