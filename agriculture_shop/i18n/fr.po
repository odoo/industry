#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>\n"
"                    SEO features</b>"
msgstr ""
"<b>\n"
"                    Fonctionnalités SEO</b>"

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Inventory App:</font></b> Keep precise "
"track of stock levels for diverse products\n"
"                like pesticides and equipment."
msgstr ""
"<b><font class=\"text-o-color-1\">Application Inventaire :</font></b> Suivez "
"précisément les niveaux de stock de produits variés, comme les pesticides et "
"le matériel."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Point of Sale App:</font></b> Manage in-"
"store transactions efficiently, handling sales of seeds, tools, and supplies "
"with ease."
msgstr ""
"<b><font class=\"text-o-color-1\">Application Point de Vente :</font></b> "
"Gérez efficacement les transactions en magasin, de la vente de semences, d’"
"outils et de fournitures, en toute simplicité."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Purchase App:</font></b> Streamline the "
"procurement of farming products from suppliers, managing costs and lead "
"times."
msgstr ""
"<b><font class=\"text-o-color-1\">Application Achats :</font></b> Optimisez "
"l’approvisionnement en produits agricoles auprès des fournisseurs, tout en "
"maîtrisant les coûts et les délais."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Sales App:</font></b> Handle B2B orders "
"and contracts for large farming clients, ensuring accurate pricing."
msgstr ""
"<b><font class=\"text-o-color-1\">Application Ventes :</font></b> Gérez les "
"commandes et les contrats B2B pour les grands clients agricoles, en "
"garantissant une tarification précise."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Website App:</font></b><font class=\"text-"
"o-color-3\"> Build a professional online presence to showcase your catalog "
"and attract new customers.</font>"
msgstr ""
"<b><font class=\"text-o-color-1\">Application Site web :</font></b><font "
"class=\"text-o-color-3\"> Créez une présence en ligne professionnelle afin "
"de présenter votre catalogue et d’attirer de nouveaux clients.</font>"

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">eCommerce App:</font></b> Expand your "
"reach by selling products online, offering convenience to modern farmers."
msgstr ""
"<b><font class=\"text-o-color-1\">Application eCommerce :</font></b> "
"Élargissez votre portée en vendant vos produits en ligne et offrez davantage "
"de praticité aux agriculteurs modernes."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Accounting:</b> Automatically log payments, close sessions, and generate "
"tax\n"
"                    reports."
msgstr ""
"<b>Comptabilité :</b> Enregistrez automatiquement les paiements, clôturez "
"les sessions et générez des rapports fiscaux."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Automated Trigger</b> will instantly create a\n"
"                    purchase order."
msgstr ""
"<b>Déclencheur automatique</b> créera instantanément un\n"
"                bon de commande."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Automatic Delivery:</b> Once the quote is\n"
"                    accepted, the system automatically creates a linked "
"<b>Delivery Order</b>, just\n"
"                    as it does for a regular e-commerce order."
msgstr ""
"<b>Livraison automatique :</b> Une fois le devis\n"
"                accepté, le système crée automatiquement un <b>bon de "
"livraison</b> lié, tout\n"
"                comme pour une commande e-commerce classique."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Capture Requests:</b> Any submission via the <b>\"Contact\n"
"                    Us\"</b> page instantly generates a new <b>CRM "
"opportunity</b>."
msgstr ""
"<b>Enregistrer les demandes :</b> Toute soumission via la page <b"
">\"Contactez-nous\"</b> \n"
"génère instantanément une nouvelle <b>opportunité CRM</b>."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Crucial Review:</b> You must review all\n"
"                    e-commerce settings to ensure they align with your "
"internal business policies\n"
"                    (e.g., when invoices are generated, whether a mandatory "
"customer check-in is\n"
"                    required for ordering, etc.)."
msgstr ""
"<b>Vérification essentielle :</b> Vous devez vérifier tous les paramètres \n"
"e-commerce afin de vous assurer qu’ils correspondent à vos politiques "
"internes \n"
"(par ex. quand les factures sont générées, si une connexion client "
"obligatoire est \n"
"requise pour commander, etc.)."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Define B2B Pricing:</b> Create and assign a <b>dedicated\n"
"                    pricelist</b> to each B2B contact. Ensure this pricelist "
"is active on your\n"
"                    website so the customer sees their agreed-upon prices "
"upon login."
msgstr ""
"<b>Définir les prix B2B :</b> Créez et attribuez une <b>liste de prix \n"
"dédiée</b> à chaque contact B2B. Assurez-vous que cette liste de prix est "
"active sur votre \n"
"site web afin que le client voie ses prix convenus lors de la connexion."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Delivery Methods:</b> Go to <b>Website &gt;\n"
"                    Configuration &gt; Delivery Methods</b> to define all "
"available options and\n"
"                    their costs."
msgstr ""
"<b>Modes de livraison :</b> Allez dans <b>Site Web &gt;\n"
"Configuration &gt; Modes de livraison</b> pour définir toutes les options "
"disponibles et\n"
"leurs coûts."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>E-commerce Category:</b> For easier product\n"
"                    retrieval by customers on your online store."
msgstr ""
"<b>Catégorie e-commerce :</b> Pour faciliter la recherche de produits \n"
"par les clients sur votre boutique en ligne."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>External Providers:</b> Check if a\n"
"                            predefined Odoo connection exists if you work "
"with specific shipping\n"
"                            carriers."
msgstr ""
"<b>Fournisseurs externes :</b> Vérifiez si une \n"
"connexion Odoo prédéfinie existe si vous travaillez avec des transporteurs \n"
"spécifiques."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Field Service:</b> Implement this module if you <b>offer on-site repair "
"or\n"
"                maintenance services</b>."
msgstr ""
"<b>Service sur site :</b> Implémentez ce module si vous <b>proposez des "
"services de réparation ou \n"
"de maintenance sur site</b>."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>In-Store Pickup (Click &amp; Collect):</b>\n"
"                            If you wish to offer this, you must <b>activate "
"the setting</b> within\n"
"                            the <b>Website Settings</b> first."
msgstr ""
"<b>Retrait en magasin (Click &amp; Collect) :</b>\n"
"Si vous souhaitez proposer cela, vous devez d’abord <b>activer le paramètre</"
"b> dans \n"
"les <b>paramètres du site web</b>."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid "<b>Key Product Settings:</b>"
msgstr "<b>Paramètres clés du produit :</b>"

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Layout Settings:</b> Adjust the visual\n"
"                    presentation and layout of products using the <b>website "
"editor</b>."
msgstr ""
"<b>Paramètres de mise en page :</b> Ajustez la présentation visuelle et la "
"mise en page des produits à l’aide de <b>l’éditeur de site web</b>."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Loyalty Programs:</b> Implement <b>loyalty cards</b> as a core\n"
"                            strategy to <b>activate customer retention</b> "
"and increase lifetime\n"
"                            value."
msgstr ""
"<b>Programmes de fidélité :</b> Implémentez des <b>cartes de fidélité</b> "
"comme stratégie principale pour <b>activer la fidélisation des clients</b> "
"et augmenter la valeur à long terme."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Manual Trigger</b> will display the demand in the\n"
"                    Inventory <b>Replenishment view </b>for you to confirm. "
"<i>(Note:\n"
"                    Reordering rules work in conjunction with defined lead "
"times.)</i>"
msgstr ""
"<b>Déclenchement manuel</b> affichera la demande dans la vue de "
"<b>réapprovisionnement</b> de l’inventaire afin que vous puissiez la "
"confirmer. \n"
"<i>(Remarque : les règles de réapprovisionnement fonctionnent conjointement "
"avec les délais définis.)</i>"

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Optimal stock management</b> is achieved by <b>combining both the "
"Reordering Rules and\n"
"            Suggested Replenishment</b> to ensure a comprehensive, forecast-"
"aware stock follow-up."
msgstr ""
"<b>Une gestion optimale des stocks</b> est assurée en <b>combinant les "
"règles de réapprovisionnement et le réapprovisionnement suggéré</b> afin de "
"garantir un suivi complet des stocks, intégrant les prévisions."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Payment Providers &amp; Methods:</b> Go to <b>Website\n"
"                    &gt; Configuration &gt; Payment Providers</b> and "
"install <b>all</b> the payment\n"
"                    methods and providers you plan to offer (e.g., credit "
"card processors, PayPal,\n"
"                    etc.)."
msgstr ""
"<b>Fournisseurs et méthodes de paiement :</b> Accédez à <b>Site Web\n"
"&gt; Configuration &gt; Fournisseurs de paiement</b> et installez <b>tous</"
"b> les modes\n"
"et fournisseurs de paiement que vous prévoyez de proposer "
"(par ex. prestataires de cartes bancaires, PayPal, etc.)."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Payroll:</b> Use this feature to handle <b>employee salaries and manage "
"holiday\n"
"                requests</b>."
msgstr ""
"<b>Paie :</b> utilisez cette fonctionnalité pour gérer <b>les salaires des "
"employés et les demandes de congé</b>."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Point of Sale Category:</b> For organizing\n"
"                    transactions within your shop system."
msgstr ""
"<b>Catégorie point de vente :</b> pour organiser les transactions dans votre "
"système de caisse."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Pricelist Segmentation:</b> Define multiple pricing structures for the\n"
"                            same product, supporting different business "
"models (e.g., B2B vs. B2C)\n"
"                            and enabling <b>client-specific pricing "
"contracts</b>."
msgstr ""
"<b>Segmentation des listes de prix :</b> définissez plusieurs structures "
"tarifaires pour le\n"
"même produit, adaptées à différents modèles économiques (par ex. B2B vs B2C),"
"\n"
"et permettant des <b>contrats tarifaires spécifiques à chaque client</b>."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Product Category:</b> For internal tracking and\n"
"                    reporting."
msgstr "<b>Catégorie produit :</b> pour le suivi interne et le reporting."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Product-Level Settings:</b> Define core product\n"
"                    settings directly on the <b>product form</b>."
msgstr ""
"<b>Paramètres au niveau du produit :</b> définissez les principaux "
"paramètres du produit directement sur le <b>formulaire produit</b>."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Promotional Agility:</b> Use <b>discounts and promotions</b> to\n"
"                            quickly adjust pricing for sales events or to "
"give targeted, <b>manual\n"
"                            reductions</b> at the point of sale."
msgstr ""
"<b>Flexibilité promotionnelle :</b> utilisez <b>des remises et des "
"promotions</b> pour\n"
"ajuster rapidement les prix lors d’opérations commerciales ou pour appliquer "
"des <b>réductions manuelles</b> au point de vente."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Publishing:</b> Each product can be <b>published\n"
"                    independently</b> on your online store."
msgstr ""
"<b>Publication :</b> chaque produit peut être <b>publié indépendamment</b> "
"sur votre boutique en ligne."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Qualify Leads:</b> Engage with the client through\n"
"                    the CRM opportunity to fully understand their request—"
"whether it's a need for a\n"
"                    specific product, a supplier inquiry, or general "
"information."
msgstr ""
"<b>Qualifier les leads :</b> échangez avec le client via l’opportunité CRM "
"afin de bien comprendre sa demande — qu’il s’agisse d’un besoin pour un "
"produit spécifique, d’une question sur un fournisseur ou d’informations "
"générales."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid ""
"<b>Quote and Confirm:</b> If a specific demand\n"
"                    requires pricing, generate a <b>quotation directly from "
"the opportunity</b>. The\n"
"                    client can then <b>confirm and sign it online</b>."
msgstr ""
"<b>Devis et confirmation :</b> si une demande spécifique nécessite un devis,"
"\n"
"générez un <b>devis directement depuis l’opportunité</b>. Le client peut "
"ensuite\n"
"<b>le confirmer et le signer en ligne</b>."

#. module: agriculture_shop
#: model_terms:ir.ui.view,arch_db:agriculture_shop.welcome_article_body
msgid "<b>Use the</b>"
msgstr "<b>Utilisez le</b>"

