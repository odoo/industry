<?xml version='1.0' encoding='UTF-8'?>
<odoo noupdate="1">
  <record id="appointment.appointment_question_phone" model="appointment.question" forcecreate="1">
    <field name="is_default" eval="True"/>
    <field name="name">Phone number</field>
    <field name="placeholder">e.g. +1 555-555-5555</field>
    <field name="question_required" eval="True"/>
    <field name="question_type">phone</field>
  </record>
  <record id="appointment_question_1" model="appointment.question">
    <field name="name">Property Type</field>
    <field name="question_required" eval="True"/>
    <field name="question_type">radio</field>
    <field name="answer_ids" eval="[
      (0, 0, {'name': 'Residential'}),
      (0, 0, {'name': 'Commercial'}),
    ]"/>
  </record>
  <record id="appointment_question_2" model="appointment.question">
    <field name="name">Company Name</field>
    <field name="placeholder">If Commercial Property</field>
  </record>
  <record id="appointment_question_3" model="appointment.question">
    <field name="name">Address</field>
    <field name="question_required" eval="True"/>
    <field name="question_type">text</field>
  </record>
  <record id="appointment_question_4" model="appointment.question">
    <field name="name">PIN Code</field>
    <field name="question_required" eval="True"/>
    <field name="question_type">phone</field>
  </record>
  <record id="appointment_question_5" model="appointment.question">
    <field name="name">City</field>
    <field name="question_required" eval="True"/>
  </record>
  <record id="appointment_question_6" model="appointment.question">
    <field name="name">State</field>
    <field name="question_required" eval="True"/>
  </record>
</odoo>
