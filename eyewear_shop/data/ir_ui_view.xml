<?xml version='1.0' encoding='UTF-8'?>
<odoo>
  <record id="res_partner_form_customization" model="ir.ui.view">
    <field name="name">res.partner.form customization</field>
    <field name="inherit_id" ref="base.view_partner_form"/>
    <field name="mode">extension</field>
    <field name="model">res.partner</field>
    <field name="active" eval="True"/>
    <field name="priority">360</field>
    <field name="type">form</field>
    <field name="arch" type="xml">
      <data>
        <xpath expr="//div[@name='warning_tax']" position="before">
          <header/>
        </xpath>
        <xpath expr="//form[1]/sheet[1]/group[1]" position="after">
          <group name="studio_group_654_1im2a6k14" string="Consultations">
            <field name="x_visits_1">
              <list delete="false">
                <field name="x_sequence" widget="handle"/>
                <field name="id" optional="show"/>
                <field name="create_date" optional="show" string="Consultation date"/>
                <field name="create_uid" optional="show"/>
                <field name="x_remarks" optional="show"/>
              </list>
            </field>
          </group>
        </xpath>
      </data>
    </field>
  </record>
  <record id="studio_report_docume_11a9312f-4f14-4b17-a9eb-14e3eaea3d20" model="ir.ui.view">
    <field name="name">eyewear_shop.studio_report_docume_11a9312f-4f14-4b17-a9eb-14e3eaea3d20_document</field>
    <field name="key">eyewear_shop.studio_report_docume_11a9312f-4f14-4b17-a9eb-14e3eaea3d20_document</field>
    <field name="type">qweb</field>
    <field name="active" eval="True"/>
    <field name="arch" type="xml">
      <t t-name="studio_report_document">
        <t t-call="web.external_layout">
          <div class="page">
            <div class="oe_structure"/>
          </div>
        </t>
      </t>
    </field>
  </record>
  <record id="studio_main_report_c8cda4f6-341a-4b90-b41c-821712e0e147" model="ir.ui.view">
    <field name="name">eyewear_shop.studio_report_docume_11a9312f-4f14-4b17-a9eb-14e3eaea3d20</field>
    <field name="key">eyewear_shop.studio_report_docume_11a9312f-4f14-4b17-a9eb-14e3eaea3d20</field>
    <field name="type">qweb</field>
    <field name="active" eval="True"/>
    <field name="arch" type="xml">
      <t t-name="studio_main_report">
        <t t-call="web.html_container">
          <t t-foreach="docs" t-as="doc">
            <t t-call="eyewear_shop.studio_report_docume_11a9312f-4f14-4b17-a9eb-14e3eaea3d20_document"/>
          </t>
        </t>
      </t>
    </field>
  </record>
  <record id="web_studio_report_ed_9f0e3709-c6af-49ff-86ab-648b4c1a25b0" model="ir.ui.view">
    <field name="name">eyewear_shop.studio_report_docume_11a9312f-4f14-4b17-a9eb-14e3eaea3d20_document</field>
    <field name="inherit_id" ref="studio_report_docume_11a9312f-4f14-4b17-a9eb-14e3eaea3d20"/>
    <field name="key">eyewear_shop.studio_report_docume_11a9312f-4f14-4b17-a9eb-14e3eaea3d20_document</field>
    <field name="mode">extension</field>
    <field name="priority">9999999</field>
    <field name="active" eval="True"/>
    <field name="type">qweb</field>
    <field name="arch" type="xml">
      <data>
        <data>
          <xpath position="replace" expr="/t[@t-name='studio_report_document']//t[@t-call='web.external_layout']/div/div" meta-class="oe_structure"/>
          <xpath position="inside" expr="/t[@t-name='studio_report_document']//t[@t-call='web.external_layout']/div" meta-class="page">
            <h3 class="oe_structure">Patient Details</h3>
            <p>
              <span t-field="doc.complete_name"/>
              <br/>
              <span t-field="doc.contact_address_complete"/>
              <br/>
              <span t-field="doc.email"/>
              <br/>
              <span t-field="doc.phone"/>
              <br/>
            </p>
            <h3>Eye Test</h3>
            <h4>Base results</h4>
            <table class="table o_table table-borderless" style="width: 100%; padding:5px;">
              <tbody>
                <tr>
                  <td style="width: 20%; color: rgb(17, 24, 39);" class="bg-o-color-2">
                    <div>
                      <strong> Eye</strong>
                    </div>
                  </td>
                  <td style="width: 20%; color: rgb(17, 24, 39);" class="bg-o-color-2">
                    <div>
                      <strong>Sphere</strong>
                    </div>
                  </td>
                  <td style="width: 20%; color: rgb(17, 24, 39);" class="bg-o-color-2">
                    <div>
                      <strong>
                Cylinder &amp; Axis</strong>
                    </div>
                  </td>
                  <td style="width: 20%; color: rgb(17, 24, 39);" class="bg-o-color-2">
                    <div>
                      <strong>Addition</strong>
                    </div>
                  </td>
                  <td style="width: 20%; color: rgb(17, 24, 39);" class="bg-o-color-2">
                    <div>
                      <strong>
                Base</strong>
                    </div>
                  </td>
                </tr>
                <tr>
                  <td style="width: 119.734px;">
                    <strong> Right Eye</strong>
                  </td>
                  <td style="width: 105.328px;">
                    <span t-field="doc.x_sphere_diopters_right">/</span>
                    <br/>
                  </td>
                  <td style="width: 200.219px;">
                    <p><strong>
                  </strong>Cylinder<strong>: </strong><span t-field="doc.x_cylinder_diopters_right">/</span><strong><br/></strong>Axis: <span t-field="doc.x_axis_degrees_right">/</span>
              </p>
                  </td>
                  <td style="width: 124.844px;">
                    <p>
                      <strong>
                        <span t-field="doc.x_addition_add_right">/</span>
                        <br/>
                      </strong>
                    </p>
                  </td>
                  <td style="width: 160.75px;">
                    <p>
                      <strong>
                        <span t-field="doc.x_base_curve_mm_right">/</span>
                        <br/>
                      </strong>
                    </p>
                  </td>
                </tr>
                <tr>
                  <td style="width: 119.734px;">
                    <p>
                      <strong> Left Eye</strong>
                    </p>
                  </td>
                  <td style="width: 105.328px;">
                    <p>
                      <strong>
                        <span t-field="doc.x_sphere_diopters_left">/</span>
                        <br/>
                      </strong>
                    </p>
                  </td>
                  <td style="width: 200.219px;">
                    <p>
                Cylinder : <span t-field="doc.x_cylinder_diopters_left">/</span>
                <br/>Axis : <span t-field="doc.x_axis_degrees_left">/</span>
              </p>
                  </td>
                  <td style="width: 124.844px;">
                    <p>
                      <span t-field="doc.x_addition_add_left">/</span>
                    </p>
                  </td>
                  <td style="width: 160.75px;">
                    <p>
                      <strong>
                        <span t-field="doc.x_base_curve_mm_left">/</span>
                        <br/>
                      </strong>
                    </p>
                  </td>
                </tr>
              </tbody>
            </table>
            <h4>Other</h4>
            <table class="table o_table table-borderless" style="padding:5px;">
              <tbody>
                <tr>
                  <td class="bg-o-color-1" style="color: rgb(17, 24, 39);">
                    <p>
                      <strong> Pupillary Distance</strong>
                    </p>
                  </td>
                  <td class="bg-o-color-1" style="color: rgb(17, 24, 39);">
                    <p>
                      <strong>Near Pupillary Distance</strong>
                    </p>
                  </td>
                  <td class="bg-o-color-1" style="color: rgb(17, 24, 39);">
                    <p>
                      <strong>Vertex Distance</strong>
                    </p>
                  </td>
                  <td class="bg-o-color-1" style="color: rgb(17, 24, 39);">
                    <p>
                      <strong>Ocular Dominance</strong>
                    </p>
                  </td>
                  <td class="bg-o-color-1" style="color: rgb(17, 24, 39);">
                    <p>
                      <strong>Segment Height </strong>
                      <br/>
                      <strong>(multifocal)</strong>
                    </p>
                  </td>
                </tr>
                <tr>
                  <td>
                    <p>
                      <span t-field="doc.x_pupillary_distance_pd">/</span>
                    </p>
                  </td>
                  <td>
                    <p>
                      <span t-field="doc.x_near_pd_for_reading">/</span>
                    </p>
                  </td>
                  <td>
                    <p>
                      <span t-field="doc.x_vertex_distance">/</span>
                    </p>
                  </td>
                  <td>
                    <p>Right: <span t-field="doc.x_ocular_dominance_right">/</span>
                <br/>Left : <span t-field="doc.x_ocular_dominance_left">/</span>
              </p>
                  </td>
                  <td>
                    <p>
                      <span t-field="doc.x_segment_height_for_multifocals">/</span>
                    </p>
                  </td>
                </tr>
              </tbody>
            </table>
            <h4>
        Remarks</h4>
            <p>
              <span t-field="doc.x_studio_remarks_for_patient">No remarks</span>
              <br/>
            </p>
          </xpath>
        </data>
      </data>
    </field>
  </record>
  <record id="default_list_view_for_x_consultations" model="ir.ui.view">
    <field name="name">Default list view for x_consultations</field>
    <field name="model">x_consultations</field>
    <field name="type">list</field>
    <field name="active" eval="True"/>
    <field name="arch" type="xml">
      <list>
        <field name="x_sequence" widget="handle"/>
        <field name="x_name"/>
        <field name="x_user_id" widget="many2one_avatar_user"/>
      </list>
    </field>
  </record>
  <record id="default_form_view_for_x_consultations" model="ir.ui.view">
    <field name="name">Default form view for x_consultations</field>
    <field name="model">x_consultations</field>
    <field name="type">form</field>
    <field name="active" eval="True"/>
    <field name="arch" type="xml">
      <form>
        <header/>
        <sheet string="Consultations">
          <widget name="web_ribbon" text="Archived" bg_color="text-bg-danger" invisible="x_active"/>
          <field name="x_active" invisible="1"/>
          <div class="oe_title">
            <h1>
              <field name="x_name" required="1" placeholder="Name..."/>
            </h1>
          </div>
          <group name="studio_group_92fee4">
            <group name="studio_group_92fee4_left">
              <field name="x_user_id" widget="many2one_avatar_user"/>
            </group>
            <group name="studio_group_92fee4_right"/>
          </group>
        </sheet>
        <chatter/>
      </form>
    </field>
  </record>
  <record id="default_search_view_for_x_consultations" model="ir.ui.view">
    <field name="name">Default search view for x_consultations</field>
    <field name="model">x_consultations</field>
    <field name="type">search</field>
    <field name="active" eval="True"/>
    <field name="arch" type="xml">
      <search>
        <field name="x_name"/>
        <field name="x_user_id"/>
        <filter string="My Consultations" name="my_x_consultations" domain="[['x_user_id', '=', uid]]"/>
        <separator/>
        <filter string="Archived" name="archived_x_consultations" domain="[['x_active', '=', False]]"/>
        <separator/>
        <filter name="groupby_x_user" string="Responsible" context="{'group_by': 'x_user_id'}" domain="[]"/>
      </search>
    </field>
  </record>
  <record id="x_consultations_default_form_view_extension" model="ir.ui.view">
    <field name="name">Default form view for x_consultations customization</field>
    <field name="inherit_id" ref="default_form_view_for_x_consultations"/>
    <field name="mode">extension</field>
    <field name="model">x_consultations</field>
    <field name="priority">99</field>
    <field name="type">form</field>
    <field name="active" eval="True"/>
    <field name="arch" type="xml">
      <data>
        <xpath expr="//field[@name='x_user_id']" position="replace"/>
        <xpath expr="//field[@name='x_name']" position="replace"/>
        <xpath expr="//field[@name='x_active']" position="replace"/>
      </data>
    </field>
  </record>
  <record id="x_res_partner_line_0ace2_default_list_view" model="ir.ui.view">
    <field name="name">Default list view for x_res_partner_line_0ace2</field>
    <field name="model">x_res_partner_line_0ace2</field>
    <field name="type">list</field>
    <field name="active" eval="True"/>
    <field name="arch" type="xml">
      <list>
        <field name="x_sequence" widget="handle"/>
        <field name="x_name"/>
      </list>
    </field>
  </record>
  <record id="x_res_partner_line_0ace2_default_form_view" model="ir.ui.view">
    <field name="name">Default form view for x_res_partner_line_0ace2</field>
    <field name="model">x_res_partner_line_0ace2</field>
    <field name="type">form</field>
    <field name="active" eval="True"/>
    <field name="arch" type="xml">
      <form>
        <header/>
        <sheet string="res_partner_line">
          <div class="oe_title">
            <h1>
              <field name="x_name" required="1" placeholder="Name..."/>
            </h1>
          </div>
          <group name="studio_group_8d2edb">
            <group name="studio_group_8d2edb_left"/>
            <group name="studio_group_8d2edb_right"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>
  <record id="x_res_partner_line_0ace2_default_search_view" model="ir.ui.view">
    <field name="name">Default search view for x_res_partner_line_0ace2</field>
    <field name="model">x_res_partner_line_0ace2</field>
    <field name="type">search</field>
    <field name="active" eval="True"/>
    <field name="arch" type="xml">
      <search>
        <field name="x_name"/>
      </search>
    </field>
  </record>
  <record id="x_res_partner_line_0ace2_default_form_view_extension" model="ir.ui.view">
    <field name="name">Default form view for x_res_partner_line_0ace2 customization</field>
    <field name="model">x_res_partner_line_0ace2</field>
    <field name="inherit_id" ref="x_res_partner_line_0ace2_default_form_view"/>
    <field name="mode">extension</field>
    <field name="priority">99</field>
    <field name="type">form</field>
    <field name="active" eval="True"/>
    <field name="arch" type="xml">
      <data>
        <xpath expr="//form[1]/header[1]" position="inside">
          <button string="Print results" name="%(partner_line_eye_test_result_report)d" type="action"/>
        </xpath>
        <xpath expr="//field[@name='x_name']" position="attributes">
          <attribute name="force_save">1</attribute>
          <attribute name="placeholder">New</attribute>
          <attribute name="readonly">True</attribute>
        </xpath>
        <xpath expr="//group[@name='studio_group_8d2edb_left']" position="inside">
          <field name="create_uid"/>
          <field name="x_res_partner_id" string="Client"/>
        </xpath>
        <xpath expr="//group[@name='studio_group_8d2edb_right']" position="inside">
          <field name="create_date" string="Consultation Date" readonly="False"/>
          <field name="x_remarks"/>
        </xpath>
        <xpath expr="//group[@name='studio_group_8d2edb']" position="after">
          <notebook name="studio_notebook_743_1im7k3pvo">
            <page string="Eyesight" name="studio_page_743">
              <group name="studio_group_743">
                <group name="studio_group_743_left" string="Right Eye">
                  <field name="x_visual_acuity_distance_right"/>
                  <field name="x_visual_acuity_near_right"/>
                  <field name="x_sphere_diopters_right"/>
                  <field name="x_cylinder_diopters_right"/>
                  <field name="x_axis_degrees_right"/>
                  <field name="x_addition_add_right"/>
                  <field name="x_keratometry_k1_k2_right"/>
                  <field name="x_corneal_diameter_white_to_white_right"/>
                </group>
                <group name="studio_group_743_right" string="Left Eye">
                  <field name="x_visual_acuity_distance_left"/>
                  <field name="x_visual_acuity_near_left"/>
                  <field name="x_sphere_diopters_left"/>
                  <field name="x_cylinder_diopters_left"/>
                  <field name="x_axis_degrees_left"/>
                  <field name="x_addition_add_left"/>
                  <field name="x_keratometry_k1_k2_left"/>
                  <field name="x_corneal_diameter_white_to_white_left"/>
                </group>
              </group>
            </page>
            <page string="Binocular Measurements" name="studio_page_88s_1im7kcoc7">
              <group name="studio_group_88s">
                <group name="studio_group_88s_left">
                  <field name="x_pupillary_distance_pd"/>
                  <field name="x_near_pd_for_reading"/>
                  <field name="x_segment_height_for_multifocals"/>
                  <field name="x_vertex_distance"/>
                </group>
                <group name="studio_group_88s_right">
                  <field name="x_ocular_dominance_right"/>
                  <field name="x_ocular_dominance_left"/>
                </group>
              </group>
            </page>
            <page string="Contact Lenses" name="studio_page_9d8_1im7kgfnc">
              <group name="studio_group_9d8">
                <group name="studio_group_9d8_left" string="Right Eye">
                  <field name="x_base_curve_mm_right"/>
                  <field name="x_diameter_mm_right"/>
                </group>
                <group name="studio_group_9d8_right" string="Left Eye">
                  <field name="x_base_curve_mm_left"/>
                  <field name="x_diameter_mm_left"/>
                </group>
              </group>
            </page>
          </notebook>
        </xpath>
        <xpath expr="//form[1]/sheet[1]" position="after">
          <chatter/>
        </xpath>
      </data>
    </field>
  </record>
</odoo>
