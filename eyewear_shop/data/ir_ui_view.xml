<?xml version='1.0' encoding='UTF-8'?>
<odoo>
  <record id="res_partner_form_customization" model="ir.ui.view">
    <field name="name">res.partner.form customization</field>
    <field name="inherit_id" ref="base.view_partner_form"/>
    <field name="mode">extension</field>
    <field name="model">res.partner</field>
    <field name="active" eval="True"/>
    <field name="priority">360</field>
    <field name="type">form</field>
    <field name="arch" type="xml">
      <data>
        <xpath expr="//form[1]/sheet[1]/group[1]" position="after">
          <group name="studio_group_654_1im2a6k14" string="Consultations">
            <field name="x_visits_1">
              <list delete="false">
                <field name="x_sequence" widget="handle"/>
                <field name="id" optional="show"/>
                <field name="create_date" optional="show" string="Consultation date"/>
                <field name="create_uid" optional="show"/>
                <field name="x_remarks" optional="show"/>
              </list>
            </field>
          </group>
        </xpath>
      </data>
    </field>
  </record>
  <record id="x_res_partner_line_default_list_view" model="ir.ui.view">
    <field name="name">Default list view for x_res_partner_line</field>
    <field name="model">x_res_partner_line</field>
    <field name="type">list</field>
    <field name="active" eval="True"/>
    <field name="arch" type="xml">
      <list>
        <field name="x_sequence" widget="handle"/>
        <field name="x_name"/>
      </list>
    </field>
  </record>
  <record id="x_res_partner_line_default_form_view" model="ir.ui.view">
    <field name="name">Default form view for x_res_partner_line</field>
    <field name="model">x_res_partner_line</field>
    <field name="type">form</field>
    <field name="active" eval="True"/>
    <field name="arch" type="xml">
      <form>
        <header/>
        <sheet string="res_partner_line">
          <div class="oe_title">
            <h1>
              <field name="x_name" required="1" placeholder="Name..."/>
            </h1>
          </div>
          <group name="studio_group_8d2edb">
            <group name="studio_group_8d2edb_left"/>
            <group name="studio_group_8d2edb_right"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>
  <record id="x_res_partner_line_default_search_view" model="ir.ui.view">
    <field name="name">Default search view for x_res_partner_line</field>
    <field name="model">x_res_partner_line</field>
    <field name="type">search</field>
    <field name="active" eval="True"/>
    <field name="arch" type="xml">
      <search>
        <field name="x_name"/>
      </search>
    </field>
  </record>
  <record id="x_res_partner_line_default_form_view_extension" model="ir.ui.view">
    <field name="name">Default form view for x_res_partner_line customization</field>
    <field name="model">x_res_partner_line</field>
    <field name="inherit_id" ref="x_res_partner_line_default_form_view"/>
    <field name="mode">extension</field>
    <field name="priority">99</field>
    <field name="type">form</field>
    <field name="active" eval="True"/>
    <field name="arch" type="xml">
      <data>
        <xpath expr="//form[1]/header[1]" position="inside">
          <button string="Print results" name="%(partner_line_eye_test_result_report)d" type="action"/>
        </xpath>
        <xpath expr="//field[@name='x_name']" position="attributes">
          <attribute name="force_save">1</attribute>
          <attribute name="placeholder">New</attribute>
          <attribute name="readonly">True</attribute>
        </xpath>
        <xpath expr="//group[@name='studio_group_8d2edb_left']" position="inside">
          <field name="create_uid"/>
          <field name="x_res_partner_id" string="Client"/>
        </xpath>
        <xpath expr="//group[@name='studio_group_8d2edb_right']" position="inside">
          <field name="create_date" string="Consultation Date" readonly="False"/>
          <field name="x_remarks"/>
        </xpath>
        <xpath expr="//group[@name='studio_group_8d2edb']" position="after">
          <notebook name="studio_notebook_743_1im7k3pvo">
            <page string="Eyesight" name="studio_page_743">
              <group name="studio_group_743">
                <group name="studio_group_743_left" string="Right Eye">
                  <field name="x_visual_acuity_distance_right"/>
                  <field name="x_visual_acuity_near_right"/>
                  <field name="x_sphere_diopters_right"/>
                  <field name="x_cylinder_diopters_right"/>
                  <field name="x_axis_degrees_right"/>
                  <field name="x_addition_add_right"/>
                  <field name="x_keratometry_k1_k2_right"/>
                  <field name="x_corneal_diameter_white_to_white_right"/>
                </group>
                <group name="studio_group_743_right" string="Left Eye">
                  <field name="x_visual_acuity_distance_left"/>
                  <field name="x_visual_acuity_near_left"/>
                  <field name="x_sphere_diopters_left"/>
                  <field name="x_cylinder_diopters_left"/>
                  <field name="x_axis_degrees_left"/>
                  <field name="x_addition_add_left"/>
                  <field name="x_keratometry_k1_k2_left"/>
                  <field name="x_corneal_diameter_white_to_white_left"/>
                </group>
              </group>
            </page>
            <page string="Binocular Measurements" name="studio_page_88s_1im7kcoc7">
              <group name="studio_group_88s">
                <group name="studio_group_88s_left">
                  <field name="x_pupillary_distance_pd"/>
                  <field name="x_near_pd_for_reading"/>
                  <field name="x_segment_height_for_multifocals"/>
                  <field name="x_vertex_distance"/>
                </group>
                <group name="studio_group_88s_right">
                  <field name="x_ocular_dominance_right"/>
                  <field name="x_ocular_dominance_left"/>
                </group>
              </group>
            </page>
            <page string="Contact Lenses" name="studio_page_9d8_1im7kgfnc">
              <group name="studio_group_9d8">
                <group name="studio_group_9d8_left" string="Right Eye">
                  <field name="x_base_curve_mm_right"/>
                  <field name="x_diameter_mm_right"/>
                </group>
                <group name="studio_group_9d8_right" string="Left Eye">
                  <field name="x_base_curve_mm_left"/>
                  <field name="x_diameter_mm_left"/>
                </group>
              </group>
            </page>
          </notebook>
        </xpath>
        <xpath expr="//form[1]/sheet[1]" position="after">
          <chatter/>
        </xpath>
      </data>
    </field>
  </record>
  <record id="view_calendar_event_form_inherit" model="ir.ui.view">
    <field name="name">calendar.event.form.inherit.opportunity.partner</field>
    <field name="inherit_id" ref="calendar.view_calendar_event_form"/>
    <field name="model">calendar.event</field>
    <field name="mode">extension</field>
    <field name="active" eval="True"/>
    <field name="type">form</field>
    <field name="arch" type="xml">
        <xpath expr="//field[@name='alarm_ids']" position="after">
            <field name="x_calendar_opportunity"/>
        </xpath>
    </field>
</record>
</odoo>
