<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="appointment_type_1" model="appointment.type">
        <field name="name">Eye Test (NY)</field>
        <field name="reminder_ids" eval="[(6, 0, [ref('calendar.alarm_notif_1'), ref('calendar.alarm_mail_1'), ref('appointment_sms.calendar_alarm_data_1h_sms')])]"/>
        <field name="website_published" eval="True"/>
        <field name="is_published" eval="True"/>
        <field name="lead_create" eval="True"/>
        <field name="location_id" ref="base.main_partner"/>
        <field name="message_intro">&lt;p&gt;Hello. If You're from NY, book your appointments for eye test here.&lt;br&gt;&lt;/p&gt;</field>
        <field name="resource_ids" eval="[(6, 0, [ref('appointment_resource_1')])]"/>
        <field name="appointment_tz" model="res.users" eval="obj().env.ref('base.user_admin').tz or 'UTC'"/>
    </record>
    <record id="appointment_type_2" model="appointment.type">
        <field name="name">Eye Test (Texas)</field>
        <field name="reminder_ids" eval="[(6, 0, [ref('calendar.alarm_notif_1'), ref('calendar.alarm_mail_1'), ref('appointment_sms.calendar_alarm_data_1h_sms')])]"/>
        <field name="website_published" eval="True"/>
        <field name="is_published" eval="True"/>
        <field name="lead_create" eval="True"/>
        <field name="website_url">/appointment/2</field>
        <field name="message_intro">&lt;p&gt;Hey. If you're from Texas, book your appointments here.&lt;br&gt;&lt;br&gt;&lt;/p&gt;</field>
        <field name="resource_ids" eval="[(6, 0, [ref('appointment_resource_2')])]"/>
        <field name="appointment_tz" model="res.users" eval="obj().env.ref('base.user_admin').tz or 'UTC'"/>
    </record>
</odoo>
