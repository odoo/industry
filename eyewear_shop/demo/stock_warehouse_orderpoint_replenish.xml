<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <function model="stock.warehouse.orderpoint" name="write">
        <value eval="[ref('orderpoint_1')]"/>
        <value eval="{'qty_to_order': 20.0}"/>
    </function>
    <function model="stock.warehouse.orderpoint" name="write">
        <value eval="[ref('orderpoint_2')]"/>
        <value eval="{'qty_to_order': 13.0}"/>
    </function>

    <function model="stock.warehouse.orderpoint" name="action_replenish">
        <value eval="[
            ref('orderpoint_1'),ref('orderpoint_2')]"
        />
    </function>
</odoo>
