  <record id="web_studio_report_ed_0a0f291c-0b17-4d1e-8813-b63a0518701c" model="ir.ui.view">
    <field name="name">eyewear.studio_report_docume_912bd635-16ab-499e-841c-bf4c99bfd54d_document</field>
    <field name="inherit_id" ref="studio_report_docume_912bd635-16ab-499e-841c-bf4c99bfd54d"/>
    <field name="key">eyewear.studio_report_docume_912bd635-16ab-499e-841c-bf4c99bfd54d_document</field>
    <field name="mode">extension</field>
    <field name="active" eval="True"/>
    <field name="priority">9999999</field>
    <field name="type">qweb</field>
    <field name="arch" type="xml">
      <data>
        <data>
          <xpath position="replace" expr="/t[@t-name='studio_report_document']//t[@t-call='web.external_layout']/div/div" meta-class="oe_structure"/>
          <xpath position="inside" expr="/t[@t-name='studio_report_document']//t[@t-call='web.external_layout']/div" meta-class="page">
            <h3 class="oe_structure">Contact details</h3>
            <p class="oe_structure">Name : <span t-field="doc.x_res_partner_id.complete_name"/>
        <br/>Address : <span t-field="doc.x_res_partner_id.contact_address_complete">/</span>
        <br/>Email : <span t-field="doc.x_res_partner_id.email">/</span>
        <br/>Phone : <span t-field="doc.x_res_partner_id.phone_mobile_search">/</span>
      </p>
            <h3 class="oe_structure">Eye examination</h3>
            <table class="table o_table table-borderless">
              <tbody>
                <tr>
                  <td style="background-color: rgb(58, 175, 169); color: rgb(17, 24, 39);">
                    <p>
                      <font class="text-o-color-4">
                        <span style="font-size: 14px;">
                          <strong> Eye</strong>
                        </span>
                      </font>
                    </p>
                  </td>
                  <td style="background-color: rgb(58, 175, 169); color: rgb(17, 24, 39);">
                    <p>
                      <font class="text-o-color-4">
                        <span style="font-size: 14px;">
                          <strong>Sphere</strong>
                        </span>
                      </font>
                    </p>
                  </td>
                  <td style="background-color: rgb(58, 175, 169); color: rgb(17, 24, 39);">
                    <p>
                      <font class="text-o-color-4">
                        <span style="font-size: 14px;">
                          <strong>Cylinder</strong>
                        </span>
                      </font>
                    </p>
                  </td>
                  <td style="background-color: rgb(58, 175, 169); color: rgb(17, 24, 39);">
                    <p>
                      <font class="text-o-color-4">
                        <span style="font-size: 14px;">
                          <strong>Axis</strong>
                        </span>
                      </font>
                    </p>
                  </td>
                  <td style="background-color: rgb(58, 175, 169); color: rgb(17, 24, 39);">
                    <p>
                      <font class="text-o-color-4">
                        <span style="font-size: 14px;">
                          <strong>Addition</strong>
                        </span>
                      </font>
                    </p>
                  </td>
                  <td style="background-color: rgb(58, 175, 169); color: rgb(17, 24, 39);">
                    <p>
                      <font class="text-o-color-4">
                        <span style="font-size: 14px;">
                          <strong>Base</strong>
                        </span>
                      </font>
                    </p>
                  </td>
                </tr>
                <tr>
                  <td>
                    <p>
                      <strong> Right Eye</strong>
                    </p>
                  </td>
                  <td>
                    <p>
                      <span t-field="doc.x_sphere_diopters_right">/</span>
                    </p>
                  </td>
                  <td>
                    <p>
                      <span t-field="doc.x_cylinder_diopters_right">/</span>
                    </p>
                  </td>
                  <td>
                    <p>
                      <span t-field="doc.x_axis_degrees_right">/</span>
                    </p>
                  </td>
                  <td>
                    <p>
                      <span t-field="doc.x_addition_add_right">/</span>
                    </p>
                  </td>
                  <td>
                    <p>
                      <span t-field="doc.x_base_curve_mm_right">/</span>
                    </p>
                  </td>
                </tr>
                <tr>
                  <td>
                    <p>
                      <strong> Left Eye</strong>
                    </p>
                  </td>
                  <td>
                    <p>
                      <span t-field="doc.x_sphere_diopters_left">/</span>
                    </p>
                  </td>
                  <td>
                    <p>
                      <span t-field="doc.x_cylinder_diopters_left">/</span>
                    </p>
                  </td>
                  <td>
                    <p>
                      <span t-field="doc.x_axis_degrees_left">/</span>
                    </p>
                  </td>
                  <td>
                    <p>
                      <span t-field="doc.x_addition_add_left">/</span>
                    </p>
                  </td>
                  <td>
                    <p>
                      <span t-field="doc.x_base_curve_mm_left">/</span>
                    </p>
                  </td>
                </tr>
              </tbody>
            </table>
            <p class="oe_structure">
              <br/>
            </p>
            <table class="table o_table table-borderless">
              <tbody>
                <tr>
                  <td style="background-color: rgb(58, 175, 169); color: rgb(17, 24, 39);">
                    <p>
                      <font class="text-o-color-4">
                        <strong> Pupillary Distance</strong>
                      </font>
                    </p>
                  </td>
                  <td style="background-color: rgb(58, 175, 169); color: rgb(17, 24, 39);">
                    <p>
                      <font class="text-o-color-4">
                        <strong>Near Pupillary Distance</strong>
                      </font>
                    </p>
                  </td>
                  <td style="background-color: rgb(58, 175, 169); color: rgb(17, 24, 39);">
                    <p>
                      <font class="text-o-color-4">
                        <strong>Vertex distance</strong>
                      </font>
                    </p>
                  </td>
                  <td style="background-color: rgb(58, 175, 169); color: rgb(17, 24, 39);">
                    <p>
                      <font class="text-o-color-4">
                        <strong>Ocular Dominance</strong>
                      </font>
                    </p>
                  </td>
                  <td style="background-color: rgb(58, 175, 169); color: rgb(17, 24, 39);">
                    <p>
                      <font class="text-o-color-4">
                        <strong>Segment height (M.F.)</strong>
                      </font>
                    </p>
                  </td>
                </tr>
                <tr>
                  <td>
                    <p>
                      <span t-field="doc.x_pupillary_distance_pd">/</span>
                    </p>
                  </td>
                  <td>
                    <p>
                      <span t-field="doc.x_near_pd_for_reading">/</span>
                    </p>
                  </td>
                  <td>
                    <p>
                      <span t-field="doc.x_vertex_distance">/</span>
                    </p>
                  </td>
                  <td>
                    <p>Right: <span t-field="doc.x_ocular_dominance_right">/</span>
                <br/>Left: <span t-field="doc.x_ocular_dominance_left">/</span>
              </p>
                  </td>
                  <td>
                    <p>
                      <span t-field="doc.x_segment_height_for_multifocals">/</span>
                    </p>
                  </td>
                </tr>
              </tbody>
            </table>
            <h3 class="oe_structure">
        Remarks</h3>
            <p>
              <span t-field="doc.x_remarks">None</span>
            </p>
          </xpath>
        </data>
      </data>
    </field>
