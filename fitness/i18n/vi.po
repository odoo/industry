#. module: fitness
#: model_terms:ir.ui.view,arch_db:fitness.welcome_article_body
msgid "<strong>Appointment booking <strong>🗓️</strong></strong>"
msgstr "<strong>Đặt lịch hẹn <strong>🗓️</strong></strong>"

#. module: fitness
#: model_terms:ir.ui.view,arch_db:fitness.welcome_article_body
msgid ""
"<strong>Assign Personnel</strong>: Assign maintenance tasks to specific "
"employees or teams, ensuring that the right person is handling the repair."
msgstr ""
"<strong>Phân công nhân sự</strong>: Phân công nhiệm vụ bảo dưỡng cho các "
"nhân viên hoặc bộ phận cụ thể, đảm bảo phân công đúng người xử lý việc sửa "
"chữa."

#. module: fitness
#: model_terms:ir.ui.view,arch_db:fitness.welcome_article_body
msgid "<strong>Automate Your Reordering Process 🚀</strong>"
msgstr "<strong>Tự động hóa quy trình tái đặt hàng của bạn 🚀</strong>"

#. module: fitness
#: model_terms:ir.ui.view,arch_db:fitness.welcome_article_body
msgid "<strong>Check Stock Levels</strong>:"
msgstr "<strong>Kiểm tra mức tồn kho</strong>:"

#. module: fitness
#: model_terms:ir.ui.view,arch_db:fitness.welcome_article_body
msgid ""
"<strong>Choose Your Vendors</strong>: Select the vendors you want to reorder "
"from. You can also add bulk pricing options to save time and money."
msgstr ""
"<strong>Chọn nhà cung cấp của bạn</strong>: Chọn nhà cung cấp mà bạn muốn "
"đặt hàng lại. Bạn cũng có thể thêm tùy chọn giá bán buôn để tiết kiệm thời "
"gian và tiền bạc."

#. module: fitness
#: model_terms:ir.ui.view,arch_db:fitness.welcome_article_body
msgid ""
"<strong>Confirm Orders</strong>: When an order is confirmed, a delivery is "
"automatically created in the Inventory app. This allows you to keep track of "
"stock levels and ensure you have enough inventory for your daily\n"
"                        operations."
msgstr ""
"<strong>Xác nhận đơn hàng</strong>: Khi đơn hàng được xác nhận, một lệnh "
"giao hàng sẽ tự động được tạo trong ứng dụng Tồn kho. Điều này cho phép bạn "
"theo dõi mức tồn kho và đảm bảo bạn có đủ hàng tồn kho cho hoạt động hàng "
"ngày\n"
"của mình."

#. module: fitness
#: model_terms:ir.ui.view,arch_db:fitness.welcome_article_body
msgid ""
"<strong>Create Maintenance Requests</strong>: Easily generate maintenance "
"requests when equipment needs repair or servicing. These requests can be "
"categorized and prioritized based on urgency."
msgstr ""
"<strong>Tạo yêu cầu bảo dưỡng</strong>: Dễ dàng tạo yêu cầu bảo dưỡng khi "
"thiết bị cần sửa chữa hoặc bảo dưỡng. Những yêu cầu này có thể được phân "
"loại và ưu tiên dựa trên mức độ khẩn cấp."

#. module: fitness
#: model_terms:ir.ui.view,arch_db:fitness.welcome_article_body
msgid ""
"<strong>Create Reordering Rules</strong>: Click on the Products menu and "
"select Reordering Rules. Here, you can set minimum and maximum quantities "
"for each product to trigger automatic reordering."
msgstr ""
"<strong>Tạo Quy tắc tái đặt hàng</strong>: Nhấp vào menu Sản phẩm và chọn "
"Quy tắc tái đặt hàng. Tại đây, bạn có thể đặt số lượng tối thiểu và tối đa "
"cho mỗi sản phẩm để kích hoạt tái đặt hàng tự động."

#. module: fitness
#: model_terms:ir.ui.view,arch_db:fitness.welcome_article_body
msgid ""
"<strong>Create Tailor-Made Subscriptions and Sell Products Effortlessly 🛒</"
"strong>"
msgstr "<strong>Tạo đăng ký theo yêu cầu và bán sản phẩm dễ dàng 🛒</strong>"

#. module: fitness
#: model_terms:ir.ui.view,arch_db:fitness.welcome_article_body
msgid ""
"<strong>Define Equipment</strong>: Create detailed profiles for each piece "
"of equipment, including specifications, usage history,emplacement,  and "
"maintenance requirements."
msgstr ""
"<strong>Xác định thiết bị</strong>: Tạo hồ sơ chi tiết cho từng thiết bị, "
"bao gồm thông số kỹ thuật, lịch sử sử dụng, vị trí lắp đặt và yêu cầu bảo "
"dưỡng."

#. module: fitness
#: model_terms:ir.ui.view,arch_db:fitness.welcome_article_body
msgid "<strong>Effortlessly manage your Point of Sale 💵</strong>"
msgstr "<strong>Quản lý POS dễ dàng 💵</strong>"

#. module: fitness
#: model_terms:ir.ui.view,arch_db:fitness.welcome_article_body
msgid "<strong>Effortlessly manage your eCommerce 💵</strong>"
msgstr "<strong>Quản lý thương mại điện tử dễ dàng 💵</strong>"

#. module: fitness
#: model_terms:ir.ui.view,arch_db:fitness.welcome_article_body
msgid "<strong>Equipment Definition and Maintenance Requests</strong> 🛠️🔧"
msgstr "<strong>Xác định thiết bị và yêu cầu bảo dưỡng</strong> 🛠️🔧"

#. module: fitness
#: model_terms:ir.ui.view,arch_db:fitness.welcome_article_body
msgid ""
"<strong>If you want to execute a practical guided tour of this module, you "
"should Import demo data and try the features described in this article.</"
"strong>"
msgstr ""
"<strong>Nếu bạn muốn dùng thử tour được hướng dẫn thực tế về phân hệ này, "
"bạn nên nhập dữ liệu demo và thử các tính năng được trình bày trong bài viết "
"này.</strong>"

#. module: fitness
#: model_terms:ir.ui.view,arch_db:fitness.welcome_article_body
msgid ""
"<strong>Integration with Employee Management</strong>: Link maintenance "
"tasks to employee schedules, ensuring efficient allocation of resources."
msgstr ""
"<strong>Tích hợp với Quản lý nhân viên</strong>: Liên kết các nhiệm vụ bảo "
"dưỡng với lịch trình của nhân viên, đảm bảo phân bổ tài nguyên hiệu quả."

#. module: fitness
#: model_terms:ir.ui.view,arch_db:fitness.welcome_article_body
msgid ""
"<strong>Navigate to the Inventory App</strong>: Go to the Inventory app in "
"Odoo."
msgstr ""
"<strong>Điều hướng đến Ứng dụng Tồn kho</strong>: Đi tới ứng dụng Tồn kho "
"trong Odoo."

#. module: fitness
#: model_terms:ir.ui.view,arch_db:fitness.welcome_article_body
msgid ""
"<strong>Resupply as Needed</strong>: If stock levels are low, create a "
"purchase order from the Purchase app. Link it to the right vendor to ensure "
"timely replenishment."
msgstr ""
"<strong>Tái cung ứng khi cần thiết</strong>: Nếu mức tồn kho thấp, tạo đơn "
"mua hàng từ ứng dụng Mua hàng. Liên kết đơn mua hàng này với đúng nhà cung "
"cấp để đảm bảo bổ sung hàng kịp thời."

#. module: fitness
#: model_terms:ir.ui.view,arch_db:fitness.welcome_article_body
msgid "<strong>Scheduling and Resource Allocation 🏋️‍♂️</strong>"
msgstr "<strong>Lên lịch và phân bổ tài nguyên 🏋️‍♂️</strong>"

#. module: fitness
#: model_terms:ir.ui.view,arch_db:fitness.welcome_article_body
msgid "<strong>Set Up Automatic Reordering</strong>:"
msgstr "<strong>Thiết lập tái đặt hàng tự động</strong>:"

#. module: fitness
#: model_terms:ir.ui.view,arch_db:fitness.welcome_article_body
msgid ""
"<strong>Thanks</strong> to the invoicing policy that you can modify, the "
"generated invoice is always the reflect of the reality on the field and it "
"is fair for the customer."
msgstr ""
"<strong>Nhờ</strong> chính sách lập hóa đơn mà bạn có thể điều chỉnh, hóa "
"đơn lập ra luôn phản ánh đúng thực tế tại địa điểm và công bằng với khách "
"hàng."

#. module: fitness
#: model_terms:ir.ui.view,arch_db:fitness.welcome_article_body
msgid ""
"<strong>Track Progress</strong>: Monitor the status of maintenance requests "
"in real-time, from creation to completion, ensuring nothing falls through "
"the cracks."
msgstr ""
"<strong>Theo dõi tiến độ</strong>: Giám sát trạng thái yêu cầu bảo dưỡng "
"theo thời gian thực, từ khi tạo đến khi hoàn thành, đảm bảo không có yêu cầu "
"nào bị bỏ sót."

#. module: fitness
#: model_terms:ir.ui.view,arch_db:fitness.welcome_article_body
msgid ""
"A free, personalized, integrated <strong><font class=\"text-o-"
"color-1\">Website</font></strong> in a few clicks. Start receiving orders "
"directly in Odoo and go live with your \n"
"                <strong><font class=\"text-o-color-1\">E-shop</font></"
"strong> in a few minutes."
msgstr ""
"Một <strong><font class=\"text-o-color-1\">Trang web</font></strong> miễn "
"phí, được cá nhân hóa, tích hợp chỉ với vài cú nhấp chuột. Bắt đầu nhận đơn "
"hàng trực tiếp trong Odoo và đưa <strong><font class=\"text-o-color-1\">Cửa "
"hàng online</font></strong> của bạn đi vào hoạt động chỉ trong vài phút."

