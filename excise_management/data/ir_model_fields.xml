<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="name_excise_category" model="ir.model.fields">
        <field name="ttype">char</field>
        <field name="copied" eval="True"/>
        <field name="field_description">Name</field>
        <field name="model_id" ref="excise_category"/>
        <field name="name">x_name</field>
        <field name="required" eval="True"/>
        <field name="tracking">1</field>
        <field name="translate" eval="True"/>
    </record>
    <record id="active_excise_category" model="ir.model.fields">
        <field name="ttype">boolean</field>
        <field name="copied" eval="True"/>
        <field name="field_description">Active</field>
        <field name="model_id" ref="excise_category"/>
        <field name="name">x_active</field>
        <field name="tracking">1</field>
    </record>
    <record id="sequence_excise_category" model="ir.model.fields">
        <field name="ttype">integer</field>
        <field name="copied" eval="True"/>
        <field name="field_description">Sequence</field>
        <field name="model_id" ref="excise_category"/>
        <field name="name">x_sequence</field>
    </record>
    <record id="description_excise_category" model="ir.model.fields">
        <field name="ttype">text</field>
        <field name="copied" eval="True"/>
        <field name="field_description">Description</field>
        <field name="model_id" ref="excise_category"/>
        <field name="name">x_description</field>
    </record>
    <record id="sequence_excise_category_line" model="ir.model.fields">
        <field name="ttype">integer</field>
        <field name="copied" eval="True"/>
        <field name="field_description">Sequence</field>
        <field name="model_id" ref="excise_category_line"/>
        <field name="name">x_sequence</field>
    </record>
    <record id="name_excise_category_line" model="ir.model.fields">
        <field name="ttype">char</field>
        <field name="copied" eval="True"/>
        <field name="field_description">Name</field>
        <field name="model_id" ref="excise_category_line"/>
        <field name="name">x_name</field>
        <field name="required" eval="True"/>
        <field name="translate" eval="True"/>
    </record>
    <record id="excise_category_line_excise_category" model="ir.model.fields">
        <field name="ttype">many2one</field>
        <field name="copied" eval="True"/>
        <field name="field_description">Excise Category</field>
        <field name="model_id" ref="excise_category_line"/>
        <field name="name">x_excise_category_id</field>
        <field name="relation">x_excise_category</field>
        <field name="required" eval="True"/>
        <field name="on_delete">cascade</field>
    </record>
    <record id="excise_category_excise_category_line" model="ir.model.fields">
        <field name="ttype">one2many</field>
        <field name="field_description">Excises</field>
        <field name="model_id" ref="excise_category"/>
        <field name="name">x_excises</field>
        <field name="relation">x_excise_category_line</field>
        <field name="relation_field">x_excise_category_id</field>
    </record>
    <record id="excise_category_line_currency" model="ir.model.fields">
        <field name="ttype">many2one</field>
        <field name="copied" eval="True"/>
        <field name="field_description">Currency</field>
        <field name="model_id" ref="excise_category_line"/>
        <field name="name">x_currency_id</field>
        <field name="relation">res.currency</field>
        <field name="required" eval="True"/>
        <field name="on_delete">restrict</field>
    </record>
    <record id="excise_category_line_amount" model="ir.model.fields">
        <field name="ttype">float</field>
        <field name="copied" eval="True"/>
        <field name="field_description">Amount</field>
        <field name="model_id" ref="excise_category_line"/>
        <field name="name">x_amount</field>
        <!-- <field name="currency_field">x_currency_id</field> -->
        <field name="required" eval="True"/>
    </record>
    <record id="excise_category_line_unit" model="ir.model.fields">
        <field name="ttype">many2one</field>
        <field name="copied" eval="True"/>
        <field name="field_description">Unit</field>
        <field name="model_id" ref="excise_category_line"/>
        <field name="name">x_unit</field>
        <field name="relation">uom.uom</field>
        <field name="required" eval="True"/>
        <field name="on_delete">restrict</field>
    </record>
    <record id="excise_category_line_unit_correction" model="ir.model.fields">
        <field name="ttype">selection</field>
        <field name="copied" eval="True"/>
        <field name="field_description">Unit correction</field>
        <field name="model_id" ref="excise_category_line"/>
        <field name="name">x_unit_correction</field>
        <field name="selection">[('none', 'None'), ('plato', 'Plato degree'), ('alcohol', 'Neat alcohol')]</field>
        <field name="required" eval="True"/>
    </record>
    <record id="product_template_excise_category" model="ir.model.fields">
        <field name="ttype">many2one</field>
        <field name="copied" eval="True"/>
        <field name="field_description">Excise category</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="name">x_excise_category</field>
        <field name="relation">x_excise_category</field>
    </record>
    <record id="product_template_alcohol_degree" model="ir.model.fields">
        <field name="ttype">float</field>
        <field name="copied" eval="True"/>
        <field name="field_description">Alcohol degree</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="name">x_alcohol_degree</field>
    </record>
    <record id="product_template_alcohol_plato_degree" model="ir.model.fields">
        <field name="compute"><![CDATA[for record in self:
    record['x_alcohol_plato_degree'] = int((258.6*(record.x_alcohol_degree))/(0.12+0.88*(1+record.x_alcohol_degree))) + ((258.6*(record.x_alcohol_degree)) % (0.12+0.88*(1+record.x_alcohol_degree)) > 0) ]]></field>
        <field name="ttype">float</field>
        <field name="depends">x_alcohol_degree</field>
        <field name="field_description">Alcohol Plato degree</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="name">x_alcohol_plato_degree</field>
        <field name="readonly" eval="True"/>
    </record>
    <record id="product_template_excise_amount" model="ir.model.fields">
        <field name="compute"><![CDATA[for record in self:
    if record.x_excise_category:
        computed_excises = 0
        product_volume = self.env.ref('excise_management.convert_to_base_unit_server_action').with_context(active_model='uom.uom', active_id=record.uom_id.id).run()
        for excise in record.x_excise_category.x_excises:
            excise_volume = self.env.ref('excise_management.convert_to_base_unit_server_action').with_context(active_model='uom.uom', active_id=excise.x_unit.id).run()
            volume_correction = 1
            match excise.x_unit_correction:
                case "none":
                    volume_correction = 1
                case "plato":
                    volume_correction = record.x_alcohol_plato_degree
                case "alcohol":
                    volume_correction = record.x_alcohol_degree
            computed_excises += excise.x_currency_id._convert(excise.x_amount, record.currency_id) * product_volume * volume_correction / excise_volume
        record["x_excise_amount"] = computed_excises
    else:
        record["x_excise_amount"] = 0]]></field>
        <field name="ttype">monetary</field>
        <field name="depends">x_excise_category, x_excise_category.x_excises, uom_id, x_alcohol_plato_degree, x_alcohol_degree</field>
        <field name="field_description">Excise amount</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="name">x_excise_amount</field>
        <field name="readonly" eval="True"/>
        <field name="selectable" eval="False"/>
        <field name="currency_field">currency_id</field>
    </record>
    <record id="product_template_excise_volume" model="ir.model.fields">
        <field name="compute"><![CDATA[excise_uom = self.env["uom.uom"].search([('x_excise_reporting_unit', '=', True)], limit=1)
convert = self.env.ref('excise_management.convert_to_base_unit_server_action').with_context(active_model='uom.uom')
for record in self:
    record["x_excise_volume"] = convert.with_context(active_id=record.uom_id.id).run() / convert.with_context(active_id=excise_uom.id).run() if (record.x_excise_category and excise_uom) else 0
]]></field>
        <field name="ttype">float</field>
        <field name="depends">x_excise_category, uom_id</field>
        <field name="field_description">Excise volume</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="name">x_excise_volume</field>
        <field name="readonly" eval="True"/>
        <field name="selectable" eval="False"/>
        <field name="store" eval="False"/>
    </record>
    <record id="product_template_excise_description" model="ir.model.fields">
        <field name="ttype">text</field>
        <field name="related">x_excise_category.x_description</field>
        <field name="field_description">Excise description</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="name">x_excise_description</field>
        <field name="readonly" eval="True"/>
        <field name="store" eval="False"/>
    </record>
    <record id="excise_category_product_template_ids" model="ir.model.fields">
        <field name="ttype">one2many</field>
        <field name="field_description">Products</field>
        <field name="model_id" ref="excise_category"/>
        <field name="name">x_product_template_ids</field>
        <field name="relation">product.template</field>
        <field name="relation_field">x_excise_category</field>
    </record>
