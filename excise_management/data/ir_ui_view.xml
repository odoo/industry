    <record id="x_excise_category_line_view_form" model="ir.ui.view">
        <field name="name">x_excise_category_line.view.form</field>
        <field name="model">x_excise_category_line</field>
        <field name="type">form</field>
        <field name="active" eval="True"/>
        <field name="arch" type="xml">
        <form>
            <header/>
            <sheet string="excise_category_line">
            <div class="oe_title">
                <h1>
                <field name="x_name" required="1" placeholder="Name..."/>
                </h1>
            </div>
            <group>
                <group>
                    <field name="x_amount"/>
                    <field name="x_currency_id"/>
                </group>
                <group name="studio_group_9b192d_right">
                    <field name="x_unit"/>
                    <field name="x_unit_correction"/>
                </group>
            </group>
            </sheet>
        </form>
        </field>
    </record>
