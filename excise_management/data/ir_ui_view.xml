<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="x_excise_category_view_list" model="ir.ui.view">
        <field name="name">x_excise_category.view.list</field>
        <field name="model">x_excise_category</field>
        <field name="type">list</field>
        <field name="active" eval="True"/>
        <field name="arch" type="xml">
        <list>
            <field name="x_sequence" widget="handle"/>
            <field name="x_name"/>
            <field name="x_description" optional="show"/>
        </list>
        </field>
    </record>
    <record id="x_excise_category_view_form" model="ir.ui.view">
        <field name="name">x_excise_category.view.form</field>
        <field name="model">x_excise_category</field>
        <field name="type">form</field>
        <field name="active" eval="True"/>
        <field name="arch" type="xml">
            <form>
                <header/>
                <sheet string="Excise Category">
                    <widget name="web_ribbon" text="Archived" bg_color="text-bg-danger" invisible="x_active"/>
                    <div class="oe_title">
                        <h1>
                            <field name="x_name" required="1" placeholder="Name..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="x_description"/>
                        </group>
                    </group>
                    <field name="x_excises">
                        <list editable="bottom">
                            <field name="x_sequence" widget="handle"/>
                            <field name="x_name" string="Name"/>
                            <field name="x_amount" optional="show"/>
                            <field name="x_currency_id" optional="show"/>
                            <field name="x_unit" optional="show"/>
                            <field name="x_unit_correction" optional="show"/>
                        </list>
                    </field>
                    <field name="x_product_template_ids" force_save="1" readonly="True" string="Products">
                        <list string="Product" multi_edit="1" sample="1">
                            <field name="is_favorite" widget="boolean_favorite" optional="show" nolabel="1"/>
                            <field name="name" string="Product Name"/>
                            <field name="responsible_id" widget="many2one_avatar_user" optional="hide" groups="stock.group_stock_user"/>
                            <field name="product_tag_ids" widget="many2many_tags" optional="hide"/>
                            <field name="barcode" optional="hide" readonly="product_variant_count != 1"/>
                            <field name="company_id" options="{'no_create': True}" groups="base.group_multi_company" optional="hide"/>
                            <field name="categ_id" optional="hide"/>
                            <field name="type" optional="hide" readonly="1"/>
                            <field name="x_alcohol_degree" optional="show" widget="percentage"/>
                            <field name="x_alcohol_plato_degree" optional="show" options="{'human_readable':true}"/>
                            <field name="x_excise_volume" optional="show" options="{'digits':[8,4]}"/>
                            <field name="x_excise_amount" optional="show" options="{'no_symbol':false}"/>
                        </list>
                    </field>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
