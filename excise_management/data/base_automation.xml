<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="add_excise" model="base.automation">
        <field name="model_id" ref="product.model_product_template"/>
        <field name="action_server_ids" eval="[(6, 0, [ref('add_excise_server_action')])]"/>
        <field name="trigger">on_create_or_write</field>
        <field name="filter_pre_domain">[('x_excise_category', '=', False)]</field>
        <field name="filter_domain">[('x_excise_category', '!=', False)]</field>
        <field name="name">Add Excise Taxes</field>
        <field name="trigger_field_ids" eval="[(6, 0, [ref('product_template_excise_category')])]"/>
    </record>
    <record id="remove_excise" model="base.automation">
        <field name="model_id" ref="product.model_product_template"/>
        <field name="action_server_ids" eval="[(6, 0, [ref('remove_excise_server_action')])]"/>
        <field name="trigger">on_create_or_write</field>
        <field name="filter_pre_domain">[('x_excise_category', '!=', False)]</field>
        <field name="filter_domain">[('x_excise_category', '=', False)]</field>
        <field name="name">Remove Excise Taxes</field>
        <field name="trigger_field_ids" eval="[(6, 0, [ref('product_template_excise_category')])]"/>
    </record>
</odoo>
