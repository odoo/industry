<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="active_excise_category_default" model="ir.default">
        <field name="field_id" ref="active_excise_category"/>
        <field name="json_value">true</field>
    </record>
    <record id="sequence_excise_category_default" model="ir.default">
        <field name="field_id" ref="sequence_excise_category"/>
        <field name="json_value">10</field>
    </record>
    <!-- <record id="sequence_excise_category_default" model="ir.default">
        <field name="field_id" ref="x_unit_correction"/>
        <field name="json_value">none</field>
    </record> -->
    <function model="ir.default" name="set" eval="('x_excise_category_line', 'x_unit_correction', 'none')"/>
    <function model="ir.default" name="set" eval="('x_excise_category_line', 'x_currency_id', obj().env.company.id)"/>
    <function model="ir.default" name="set" eval="('x_excise_category_line', 'x_unit', obj().env['uom.uom'].search([('x_excise_reporting_unit', '=', True)], limit=1).id)"/>
</odoo>
