<?xml version='1.0' encoding='UTF-8'?>
<odoo noupdate="1">
    <record id="account_tax_excises" model="account.tax">
        <field name="name">Excises</field>
        <field name="type_tax_use">none</field>
        <field name="amount_type">code</field>
        <field name="amount">0.1</field>
        <field name="description">Excises (Merchandise)</field>
        <field name="price_include_override">tax_included</field>
        <field name="include_base_amount" eval="True"/>
        <field name="tax_group_id" ref="excises_tax_group"/>
        <field name="formula"><![CDATA[quantity * product.x_excise_amount]]></field>
        <field name="x_is_excise" eval="True"/>
    </record>
</odoo>
