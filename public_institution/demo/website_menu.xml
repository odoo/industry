<?xml version='1.0' encoding='UTF-8'?>
<odoo noupdate="1">
  <function model="website.menu" name="write">
    <value model="website.menu" eval="obj().search([('website_id', '=', ref('website.default_website')), ('url', '=', '/shop')], limit=1).id" />
    <value eval="{'name': 'Rentals', 'sequence': 40}"/>
  </function>
  <function model="website.menu" name="write">
    <value model="website.menu" eval="obj().search([('website_id', '=', ref('website.default_website')), ('url', '=', '/blog')], limit=1).id" />
    <value eval="{'name': 'News', 'sequence': 20}"/>
  </function>
  <function model="website.menu" name="write">
    <value model="website.menu" eval="obj().search([('website_id', '=', ref('website.default_website')), ('url', '=', '/helpdesk')], limit=1).id" />
    <value eval="{'name': 'Support'}"/>
  </function>
  <function model="website.menu" name="unlink">
    <value model="website.menu" eval="obj().search([('website_id', '=', ref('website.default_website')), ('url', '=', '/appointment')]).ids"/>
  </function>
</odoo>
