#: model_terms:ir.ui.view,arch_db:carpenter.welcome_article_body
msgid "<strong><span class=\"display-4-fs\">Carpenter</span></strong><br/>"
msgstr "<strong><span class=\"display-4-fs\">大工業</span></strong><br/>"

#. module: carpenter
#: model_terms:ir.ui.view,arch_db:carpenter.welcome_article_body
msgid "<strong>Accounting made easy 🧮</strong>"
msgstr "<strong>会計管理を簡単に 🧮</strong>"

#. module: carpenter
#: model_terms:ir.ui.view,arch_db:carpenter.welcome_article_body
msgid "<strong>Create an attractive website 🌐</strong>"
