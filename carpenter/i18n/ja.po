#. module: carpenter
#: model_terms:ir.ui.view,arch_db:carpenter.welcome_article_body
msgid ""
"<span class=\"h6-fs\">This module is designed to simplify daily project "
"management, helping you effortlessly handle customer relationships, prepare "
"construction sites, manage material purchases, and organize your project "
"calendar. The result is improved efficiency and happier customers across all "
"your production services.</span>"
msgstr ""
"<span class=\"h6-fs\">このモジュールは、日々のプロジェクト管理を簡素化するよ"
"うに設計されており、顧客との関係、建設現場の準備、資材購入の管理、プロジェク"
"トカレンダの整理などを簡単に行うことができます。効率性を向上させることで、す"
"べての製品やサービスにおいて顧客の満足度を高めます。</span>"

#. module: carpenter
#: model_terms:ir.ui.view,arch_db:carpenter.welcome_article_body
msgid ""
"<span class=\"h6-fs\">Welcome to the <strong><font style=\"color: rgb(113, "
"75, 103);\">Odoo Carpenter package</font></strong>!</span><br/>"
msgstr ""
"<span class=\"h6-fs\"><strong><font style=\"color: rgb(113, 75, 103);\">Odoo"
"大工業パッケージ</font></strong>へようこそ!</span><br/>"

#. module: carpenter
#: model_terms:ir.ui.view,arch_db:carpenter.welcome_article_body
msgid "<span class=\"h6-fs\">Within the Manufacturing App</span>"
msgstr "<span class=\"h6-fs\">製造アプリ内</span>"

#. module: carpenter
#: model_terms:ir.ui.view,arch_db:carpenter.welcome_article_body
