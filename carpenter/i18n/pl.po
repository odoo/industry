#. module: carpenter
#: model_terms:ir.ui.view,arch_db:carpenter.welcome_article_body
msgid ""
"<span class=\"h6-fs\">This module is designed to simplify daily project "
"management, helping you effortlessly handle customer relationships, prepare "
"construction sites, manage material purchases, and organize your project "
"calendar. The result is improved efficiency and happier customers across all "
"your production services.</span>"
msgstr ""
"<span class=\"h6-fs\">Ten moduł został zaprojektowany w celu uproszczenia "
"codziennego zarządzania projektami, pomagając w łatwym zarządzaniu relacjami "
"z klientami, przygotowywaniu placów budowy, zarządzaniu zakupami materiałów "
"i organizowaniu kalendarza projektów. Efektem jest poprawa wydajności i "
"większa satysfakcja klientów we wszystkich usługach produkcyjnych.</span>"

#. module: carpenter
#: model_terms:ir.ui.view,arch_db:carpenter.welcome_article_body
msgid ""
"<span class=\"h6-fs\">Welcome to the <strong><font style=\"color: rgb(113, "
"75, 103);\">Odoo Carpenter package</font></strong>!</span><br/>"
msgstr ""
"<span class=\"h6-fs\">Witamy w pakiecie <strong><font style=\"color: "
"rgb(113, 75, 103);\"> Odoo Stolarz</font></strong>!</span><br/>"

