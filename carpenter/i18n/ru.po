#. module: carpenter
#: model_terms:ir.ui.view,arch_db:carpenter.welcome_article_body
msgid ""
"<span class=\"h6-fs\">This module is designed to simplify daily project "
"management, helping you effortlessly handle customer relationships, prepare "
"construction sites, manage material purchases, and organize your project "
"calendar. The result is improved efficiency and happier customers across all "
"your production services.</span>"
msgstr ""
"<span class=\"h6-fs\">Этот модуль разработан для упрощения ежедневного "
"управления проектами. Он поможет вам легко выстраивать отношения с "
"клиентами, подготавливать строительные площадки, управлять закупками "
"материалов и организовывать календарь проекта. Итог – рост эффективности и "
"удовлетворенности клиентов по всем вашим производственным услугам.</span>"

#. module: carpenter
#: model_terms:ir.ui.view,arch_db:carpenter.welcome_article_body
msgid ""
"<span class=\"h6-fs\">Welcome to the <strong><font style=\"color: rgb(113, "
"75, 103);\">Odoo Carpenter package</font></strong>!</span><br/>"
msgstr ""
"<span class=\"h6-fs\">Добро пожаловать в решение для <strong><font style="
"\"color: rgb(113, 75, 103);\">плотников от Odoo</font></strong>!</span><br/>"

#. module: carpenter
#: model_terms:ir.ui.view,arch_db:carpenter.welcome_article_body
