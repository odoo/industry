#. module: cleaning_services
#: model_terms:ir.ui.view,arch_db:cleaning_services.welcome_article_body
msgid "<span class=\"h1-fs\">Basics</span>"
msgstr "<span class=\"h1-fs\">Grundlagen</span>"

#. module: cleaning_services
#: model_terms:ir.ui.view,arch_db:cleaning_services.welcome_article_body
msgid ""
"<strong>Activities</strong>: Schedule activities directly within the CRM to "
"ensure timely follow-ups. Activities are actions users take on a document, "
"like making a call or organizing a meeting. Pending activities are visible "
"above\n"
"                the message history in the chatter widget."
msgstr ""
"<strong>Aktivitäten</strong>: Planen Sie Aktivitäten direkt im CRM, um eine "
"zeitnahe Durchführung zu gewährleisten. Aktivitäten sind Aktionen, die "
"Benutzer in einem Datensatz vornehmen, wie z. B. einen Anruf tätigen oder "
"ein Meeting organisieren. Ausstehende Aktivitäten werden über\n"
"                dem Nachrichtenverlauf im Chatter-Widget angezeigt."

#. module: cleaning_services
#: model_terms:ir.ui.view,arch_db:cleaning_services.welcome_article_body
msgid "<strong>CRM for Opportunity Management</strong>"
msgstr "<strong>CRM zur Verwaltung von Verkaufschancen</strong>"

#. module: cleaning_services
#: model_terms:ir.ui.view,arch_db:cleaning_services.welcome_article_body
msgid ""
"<strong>CRM</strong>: Manages customer inquiries and tracks leads with "
"efficient follow-ups."
msgstr ""
"<strong>CRM</strong>: Verwaltet Kundenanfragen und verfolgt Leads mit "
"effizienten Bearbeitungsmaßnahmen."

#. module: cleaning_services
#: model_terms:ir.ui.view,arch_db:cleaning_services.welcome_article_body
msgid ""
"<strong>Chatter</strong>: Use the chatter to communicate with team members, "
"log notes, and keep a record of all updates related to the opportunity. Tag "
"colleagues by typing @ followed by their name to send notifications."
msgstr ""
"<strong>Chatter</strong>: Verwenden Sie den Chatter, um mit Teammitgliedern "
"zu kommunizieren, Notizen zu protokollieren und alle Aktualisierungen im "
"Zusammenhang mit der Verkaufschance zu dokumentieren. Markieren Sie "
"Kollegen, indem Sie @ gefolgt von ihrem Namen eingeben, um ihnen "
"Benachrichtigungen zu senden."

#. module: cleaning_services
#: model_terms:ir.ui.view,arch_db:cleaning_services.welcome_article_body
msgid ""
"<strong>Field Service Tasks</strong>: Dispatches on-site cleaning tasks "
"promptly upon order confirmation."
msgstr ""
"<strong>Außendienstaufgaben</strong>: Entsenden Sie Reinigungskräfte vor Ort "
"umgehend nach Auftragsbestätigung."

