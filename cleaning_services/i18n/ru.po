#. module: cleaning_services
#: model_terms:ir.ui.view,arch_db:cleaning_services.welcome_article_body
msgid "<span class=\"h1-fs\">Basics</span>"
msgstr "<span class=\"h1-fs\">Основы</span>"

#. module: cleaning_services
#: model_terms:ir.ui.view,arch_db:cleaning_services.welcome_article_body
msgid ""
"<strong>Activities</strong>: Schedule activities directly within the CRM to "
"ensure timely follow-ups. Activities are actions users take on a document, "
"like making a call or organizing a meeting. Pending activities are visible "
"above\n"
"                the message history in the chatter widget."
msgstr ""
"<strong>Задачи</strong>: Планируйте задачи непосредственно в CRM, чтобы "
"обеспечить своевременное выполнение. Задачи — это действия, которые "
"пользователи выполняют с документом, например, звонок или организация "
"встречи. Ожидающие задачи отображаются над\n"
"                  историей сообщений в виджете чата."

#. module: cleaning_services
#: model_terms:ir.ui.view,arch_db:cleaning_services.welcome_article_body
msgid "<strong>CRM for Opportunity Management</strong>"
msgstr "<strong>CRM для управления возможностями</strong>"

#. module: cleaning_services
#: model_terms:ir.ui.view,arch_db:cleaning_services.welcome_article_body
msgid ""
"<strong>CRM</strong>: Manages customer inquiries and tracks leads with "
"efficient follow-ups."
msgstr ""
"<strong>CRM</strong>: Управляет запросами клиентов и отслеживает "
"потенциальных клиентов с эффективным последующим сопровождением."

#. module: cleaning_services
#: model_terms:ir.ui.view,arch_db:cleaning_services.welcome_article_body
msgid ""
"<strong>Chatter</strong>: Use the chatter to communicate with team members, "
"log notes, and keep a record of all updates related to the opportunity. Tag "
"colleagues by typing @ followed by their name to send notifications."
msgstr ""
"<strong>Чаттер</strong>: Используйте чаттер для общения с членами команды, "
"ведения заметок и хранения записей обо всех обновлениях, связанных с "
"возможностью. Отмечайте коллег, вводя @ и их имя, чтобы отправлять "
"уведомления."

#. module: cleaning_services
#: model_terms:ir.ui.view,arch_db:cleaning_services.welcome_article_body
msgid ""
"<strong>Field Service Tasks</strong>: Dispatches on-site cleaning tasks "
"promptly upon order confirmation."
msgstr ""
"<strong>Задачи выездного обслуживания</strong>: Быстро отправляет задачи по "
"уборке на место после подтверждения заказа."

#. module: cleaning_services
#: model_terms:ir.ui.view,arch_db:cleaning_services.welcome_article_body
msgid "<strong>Field Service 🌱️</strong>"
msgstr "<strong>Выездное обслуживание 🌱️</strong>"

#. module: cleaning_services
#: model_terms:ir.ui.view,arch_db:cleaning_services.welcome_article_body
