#. module: fast_food
#: model_terms:ir.ui.view,arch_db:fast_food.welcome_article_body
msgid "<span class=\"display-4-fs\"><strong>Fast Food Restaurant</strong></span>"
msgstr ""
"<span class=\"display-4-fs\"><strong>ຮ້ານອາຫານຟາດຟູດ (Fast Food Restaurant)</"
"strong></span>"

#. module: fast_food
#: model_terms:ir.ui.view,arch_db:fast_food.welcome_article_body
msgid "<span class=\"h1-fs\"><strong>Do you want to go further?</strong></span>"
msgstr ""
"<span class=\"h1-fs\"><strong>ທ່ານຕ້ອງການສຶກສາເພີ່ມເຕີມບໍ່?</strong></span>"

#. module: fast_food
#: model_terms:ir.ui.view,arch_db:fast_food.welcome_article_body
msgid ""
"<strong>1. Flow 1:</strong> Most products need a human assessment as the "
"remaining quantity cannot be automatically computed. For those: Go to your "
"Purchase App to easily create Requests for Proposal or Purchase Orders."
msgstr ""
"<strong>1. ຂັ້ນຕອນທີ 1:</strong> ສິນຄ້າສ່ວນໃຫຍ່ຕ້ອງມີການປະເມີນໂດຍຄົນ ເພາະຈຳນວນທີ່ເຫຼືອບໍ່ສາມາດ"
"ຄິດໄລ່ໂດຍອັດຕະໂນມັດໄດ້. ສຳລັບສິນຄ້າເຫຼົ່ານັ້ນ: ໃຫ້ໄປທີ່ແອັບການຈັດຊື້ (Purchase App) ເພື່ອສ້າງການຂໍໃບສ"
"ະເໜີລາຄາ ຫຼື ໃບສັ່ງຊື້ໄດ້ຢ່າງງ່າຍດາຍ."

#. module: fast_food
#: model_terms:ir.ui.view,arch_db:fast_food.welcome_article_body
msgid ""
"<strong>2. Flow 2:</strong> For products that can be tracked, such as "
"bottled beers and sodas, you can use automated purchases. To try it, "
"navigate to your Point of Sale and sell a Blond Beer to a customer."
msgstr ""
"<strong>2. ຂັ້ນຕອນທີ 2:</strong> ສຳລັບສິນຄ້າທີ່ສາມາດຕິດຕາມໄດ້ ເຊັ່ນ: ເບຍຂວດ ແລະ ນ້ຳອັດລົມ, ທ່"
"ານສາມາດໃຊ້ການຈັດຊື້ອັດຕະໂນມັດ. ເພື່ອທົດລອງ, ໃຫ້ໄປທີ່ຈຸດຂາຍ (Point of Sale) ແລະ ຂາຍເບຍ "
"Blond Beer ໃຫ້ລູກຄ້າ."

#. module: fast_food
#: model_terms:ir.ui.view,arch_db:fast_food.welcome_article_body
msgid "<strong><span class=\"h1-fs\">Use case:</span></strong>"
msgstr "<strong><span class=\"h1-fs\">ກໍລະນີຕົວຢ່າງ:</span></strong>"

#. module: fast_food
#: model_terms:ir.ui.view,arch_db:fast_food.welcome_article_body
msgid "<strong>Basics:</strong>"
msgstr "<strong>ພື້ນຖານ:</strong>"

#. module: fast_food
#: model_terms:ir.ui.view,arch_db:fast_food.welcome_article_body
msgid "<strong>Kiosks</strong>"
msgstr "<strong>ຕູ້ສັ່ງອາຫານ (Kiosks)</strong>"

#. module: fast_food
#: model_terms:ir.ui.view,arch_db:fast_food.welcome_article_body
msgid "<strong>Self-ordering</strong>"
msgstr "<strong>ການສັ່ງດ້ວຍຕົນເອງ</strong>"

#. module: fast_food
#: model_terms:ir.ui.view,arch_db:fast_food.welcome_article_body
msgid ""
"At the end of your service, remember to close your register. To do so, in "
"the Point of Sale App, select \"Close Register\" in the top-right menu. You "
"can then precise your cash amount and validate the closing."
msgstr ""
"ເມື່ອຈົບການບໍລິການ, ຢ່າລືມປິດຮອບການຂາຍ. ເພື່ອດຳເນີນການ, ໃນແອັບຈຸດຂາຍ (POS), ເລືອກ \"ປິດຮອບກາ"
"ນຂາຍ (Close Register)\" ໃນເມນູຂວາມືດ້ານເທິງ. ຈາກນັ້ນທ່ານສາມາດກວດສອບຈຳນວນເງິນສົດ ແລະ ຢືນ"
"ຢັນການປິດ."

#. module: fast_food
#: model:pos.payment.method,name:fast_food.pos_payment_method_3
msgid "Bank"
msgstr "ທະນາຄານ"

#. module: fast_food
#: model:planning.role,name:fast_food.planning_role_2
msgid "Bar"
msgstr "ບາ (Bar)"

#. module: fast_food
#: model_terms:ir.ui.view,arch_db:fast_food.welcome_article_body
msgid "Basics:"
msgstr "ພື້ນຖານ:"

#. module: fast_food
#: model:product.template,name:fast_food.product_product_54_product_template
msgid "Beef 1kg"
msgstr "ຊີ້ນງົວ 1 ກິໂລ"

#. module: fast_food
#: model:product.template,name:fast_food.product_product_59_product_template
msgid "Blond Beer"
msgstr "ເບຍບລອນ (Blond Beer)"

#. module: fast_food
#: model:product.template,name:fast_food.product_product_55_product_template
msgid "Butter"
msgstr "ເນີຍ (Butter)"

#. module: fast_food
#: model_terms:ir.ui.view,arch_db:fast_food.welcome_article_body
msgid "By doing so, you have only 23 beers left in your stock."
msgstr "ດ້ວຍການເຮັດແບບນັ້ນ, ທ່ານຈະເຫຼືອເບຍພຽງ 23 ຂວດໃນສາງ."

#. module: fast_food
#: model_terms:ir.ui.view,arch_db:fast_food.welcome_article_body
msgid ""
"By uploading this module's demo data, your database has been filled with a "
"few products, a point of sale configuration and a sample planning."
msgstr ""
"ໂດຍການອັບໂຫຼດຂໍ້ມູນຕົວຢ່າງຂອງໂມດູນນີ້, ຖານຂໍ້ມູນຂອງທ່ານໄດ້ຖືກເພີ່ມສິນຄ້າບາງຢ່າງ, ການຕັ້ງຄ່າຈຸດຂາຍ ແລະ "
"ຕົວຢ່າງການວາງແຜນ."

#. module: fast_food
#: model:pos.payment.method,name:fast_food.pos_payment_method_4
msgid "Cash (Restaurant)"
msgstr "ເງິນສົດ (ຮ້ານອາຫານ)"

#. module: fast_food
#: model:product.template,name:fast_food.product_product_56_product_template
msgid "Cheese 250gr"
msgstr "ຊີສ 250 ກຣາມ"

#. module: fast_food
#: model_terms:ir.ui.view,arch_db:fast_food.welcome_article_body
msgid ""
"Create a stunning <strong><font class=\"text-o-"
"color-1\">website</font></strong> and start receiving orders directly in "
"Odoo. Go live with your <strong><font class=\"text-o-"
"color-1\">E-shop</font></strong> in a few minutes."
msgstr ""
"ສ້າງ <strong><font class=\"text-o-color-1\">ເວັບໄຊ</font></strong> ທີ່ສວຍງາມ ແລະ "
"ເລີ່ມຮັບລາຍການສັ່ງຊື້ໂດຍກົງໃນ Odoo. ເປີດໃຊ້ <strong><font class=\"text-o-color-1\">ຮ້ານຄ້"
"າອອນລາຍ (E-shop)</font></strong> ຂອງທ່ານໃນບໍ່ກີ່ນາທີ."

#. module: fast_food
#: model_terms:ir.ui.view,arch_db:fast_food.welcome_article_body
msgid "Discover more about Odoo by diving into our"
msgstr "ຄົ້ນຫາເພີ່ມເຕີມກ່ຽວກັບ Odoo ໂດຍການເຂົ້າໄປເບິ່ງ"

#. module: fast_food
#: model_terms:ir.ui.view,arch_db:fast_food.welcome_article_body
msgid ""
"Discover the basics of this package and explore all the possibilities Odoo "
"offers to improve your experience."
msgstr ""
"ຄົ້ນຫາພື້ນຖານຂອງແພັກເກັດນີ້ ແລະ ສຳຫຼວດຄວາມເປັນໄປໄດ້ທັງໝົດທີ່ Odoo ມອບໃຫ້ເພື່ອປັບປຸງປະສົບການຂອງທ່ານ."

#. module: fast_food
#: model_terms:ir.ui.view,arch_db:fast_food.welcome_article_body
msgid "Do you want to go further?"
msgstr "ທ່ານຕ້ອງການສຶກສາເພີ່ມເຕີມບໍ່?"

#. module: fast_food
#: model_terms:ir.ui.view,arch_db:fast_food.welcome_article_body
msgid ""
"Don't forget to hit the \"Order\" button each time you change an order. This"
" will forward the order to the Kitchen Display."
msgstr ""
"ຢ່າລືມກົດປຸ່ມ \"Order\" ທຸກຄັ້ງທີ່ທ່ານປ່ຽນແປງລາຍການສັ່ງຊື້. ນີ້ຈະສົ່ງລາຍການໄປຍັງໜ້າຈໍສະແດງຜົນໃນເຮືອນຄົ"
"ວ."

#. module: fast_food
#: model_terms:ir.ui.view,arch_db:fast_food.welcome_article_body
msgid ""
"Each order will be sent to your preparation displays and if you don't "
"configure a payment terminal for each, they can pay directly online."
msgstr ""
"ແຕ່ລະລາຍການສັ່ງຊື້ຈະຖືກສົ່ງໄປຍັງໜ້າຈໍການກຽມອາຫານ ແລະ ຖ້າທ່ານບໍ່ໄດ້ຕັ້ງຄ່າເຄື່ອງຮູດບັດ, ພວກເຂົາສາມາດຊຳ"
"ລະເງິນທາງອອນລາຍໄດ້ໂດຍກົງ."

#. module: fast_food
#: model:loyalty.program,name:fast_food.loyalty_program_2
msgid "Foodie Card"
msgstr "ບັດນັກກິນ (Foodie Card)"

#. module: fast_food
#: model:loyalty.reward,description:fast_food.loyalty_reward_1
msgid "Free Product - Cheese Burger"
msgstr "ສິນຄ້າຟຣີ - ຊີສເບີເກີ (Cheese Burger)"

#. module: fast_food
#: model_terms:ir.ui.view,arch_db:fast_food.welcome_article_body
msgid "From the Point of Sale, open your register on the main dashboard."
msgstr "ຈາກຈຸດຂາຍ (POS), ໃຫ້ເປີດຮອບການຂາຍຂອງທ່ານໃນໜ້າຈໍຫຼັກ."

#. module: fast_food
#: model_terms:ir.ui.view,arch_db:fast_food.welcome_article_body
msgid "Hello there!"
msgstr "ສະບາຍດີ!"

#. module: fast_food
#: model_terms:ir.ui.view,arch_db:fast_food.welcome_article_body
msgid ""
"If you navigate to your Purchase App, you can see a new Purchase Order that "
"is ready to be sent. You can choose a packaging if your product has an "
"existing one."
msgstr ""
"ຖ້າທ່ານໄປທີ່ແອັບການຈັດຊື້ (Purchase App), ທ່ານຈະເຫັນໃບສັ່ງຊື້ໃໝ່ທີ່ພ້ອມຈະສົ່ງ. ທ່ານສາມາດເລືອກບັນຈຸພັນໄ"
"ດ້ຫາກສິນຄ້ານັ້ນມີການຕັ້ງຄ່າໄວ້."

#. module: fast_food
#: model_terms:ir.ui.view,arch_db:fast_food.welcome_article_body
msgid ""
"If you want to assign them an Odoo user account, you can select a related "
"user in the \"HR Settings\" tab."
msgstr ""
"ຖ້າທ່ານຕ້ອງການມອບໝາຍບັນຊີຜູ້ໃຊ້ Odoo ໃຫ້ພວກເຂົາ, ທ່ານສາມາດເລືອກຜູ້ໃຊ້ທີ່ກ່ຽວຂ້ອງໃນແຖບ \"ການຕັ້ງຄ່າ "
"HR\"."

#. module: fast_food
#: model_terms:ir.ui.view,arch_db:fast_food.welcome_article_body
msgid ""
"If you want to execute a practical guided tour of this module, you should "
"Import demo data and try the Demo - Use Case. (In the next Knowledge "
"Article)"
msgstr ""
"ຖ້າທ່ານຕ້ອງການລອງໃຊ້ງານຕາມຄູ່ມືຕົວຈິງຂອງໂມດູນນີ້, ທ່ານຄວນນຳເຂົ້າຂໍ້ມູນຕົວຢ່າງ ແລະ ທົດລອງ Demo - "
"Use Case. (ໃນບົດຄວາມຄວາມຮູ້ຖັດໄປ)"

#. module: fast_food
#: model:product.template,name:fast_food.product_product_57_product_template
