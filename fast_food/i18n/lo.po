#. module: fast_food
#: model_terms:ir.ui.view,arch_db:fast_food.welcome_article_body
msgid "<span class=\"display-4-fs\"><strong>Fast Food Restaurant</strong></span>"
msgstr ""
"<span class=\"display-4-fs\"><strong>ຮ້ານອາຫານຟາສຟູ້ດ (Fast Food)</strong></"
"span>"

#. module: fast_food
#: model_terms:ir.ui.view,arch_db:fast_food.welcome_article_body
msgid "<span class=\"h1-fs\"><strong>Do you want to go further?</strong></span>"
msgstr ""
"<span class=\"h1-fs\"><strong>ທ່ານຕ້ອງການສຶກສາເພີ່ມເຕີມບໍ່?</strong></span>"

#. module: fast_food
#: model_terms:ir.ui.view,arch_db:fast_food.welcome_article_body
msgid ""
"<strong>1. Flow 1:</strong> Most products need a human assessment as the "
"remaining quantity cannot be automatically computed. For those: Go to your "
"Purchase App to easily create Requests for Proposal or Purchase Orders."
msgstr ""
"<strong>1. ຂັ້ນຕອນທີ 1:</strong> ສິນຄ້າສ່ວນໃຫຍ່ຕ້ອງການການກວດສອບໂດຍບຸກຄົນ ເນື່ອງຈາກຈຳນວນທີ່ເ"
"ຫຼືອບໍ່ສາມາດຄິດໄລ່ໄດ້ໂດຍອັດຕະໂນມັດ. ສຳລັບສິນຄ້າເຫຼົ່ານັ້ນ: ໃຫ້ໄປທີ່ແອັບການຈັດຊື້ຂອງທ່ານເພື່ອສ້າງໃບສະເໜີລາຄ"
"າ ຫຼື ໃບສັ່ງຊື້ໄດ້ຢ່າງງ່າຍດາຍ."

#. module: fast_food
#: model_terms:ir.ui.view,arch_db:fast_food.welcome_article_body
msgid ""
"<strong>2. Flow 2:</strong> For products that can be tracked, such as "
"bottled beers and sodas, you can use automated purchases. To try it, "
"navigate to your Point of Sale and sell a Blond Beer to a customer."
msgstr ""
"<strong>2. ຂັ້ນຕອນທີ 2:</strong> ສຳລັບສິນຄ້າທີ່ສາມາດຕິດຕາມໄດ້ ເຊັ່ນ: ເບຍຂວດ ແລະ ນ້ຳອັດລົມ, ທ່"
"ານສາມາດໃຊ້ການຈັດຊື້ອັດຕະໂນມັດໄດ້. ເພື່ອທົດລອງໃຊ້, ໃຫ້ໄປທີ່ຈຸດຂາຍຂອງທ່ານ ແລະ ຂາຍ Blond Beer ໃຫ້"
"ລູກຄ້າ."

#. module: fast_food
#: model_terms:ir.ui.view,arch_db:fast_food.welcome_article_body
msgid "<strong><span class=\"h1-fs\">Use case:</span></strong>"
msgstr "<strong><span class=\"h1-fs\">ກໍລະນີຕົວຢ່າງ:</span></strong>"

#. module: fast_food
#: model_terms:ir.ui.view,arch_db:fast_food.welcome_article_body
msgid "<strong>Basics:</strong>"
msgstr "<strong>ພື້ນຖານ:</strong>"

#. module: fast_food
#: model_terms:ir.ui.view,arch_db:fast_food.welcome_article_body
msgid "<strong>Kiosks</strong>"
msgstr "<strong>ຕູ້ສັ່ງອາຫານ</strong>"

#. module: fast_food
#: model_terms:ir.ui.view,arch_db:fast_food.welcome_article_body
msgid "<strong>Self-ordering</strong>"
msgstr "<strong>ການສັ່ງອາຫານດ້ວຍຕົນເອງ</strong>"

#. module: fast_food
#: model_terms:ir.ui.view,arch_db:fast_food.welcome_article_body
msgid ""
"At the end of your service, remember to close your register. To do so, in "
"the Point of Sale App, select \"Close Register\" in the top-right menu. You "
"can then precise your cash amount and validate the closing."
msgstr ""
"ເມື່ອສິ້ນສຸດການບໍລິການຂອງທ່ານ, ຢ່າລືມປິດຮອບການຂາຍ. ເພື່ອດຳເນີນການ, ໃນແອັບຈຸດຂາຍ (POS), ໃຫ້ເລືອ"
"ກ \"ປິດຮອບການຂາຍ\" ຢູ່ໃນເມນູມຸມຂວາເທິງ. ຈາກນັ້ນທ່ານສາມາດລະບຸຈຳນວນເງິນສົດ ແລະ ຢືນຢັນການປິດ."

#. module: fast_food
#: model:pos.payment.method,name:fast_food.pos_payment_method_3
msgid "Bank"
msgstr "ທະນາຄານ"

#. module: fast_food
#: model:planning.role,name:fast_food.planning_role_2
msgid "Bar"
msgstr "ບາ"

#. module: fast_food
#: model:product.template,name:fast_food.product_product_54_product_template
msgid "Beef 1kg"
msgstr "ຊີ້ນງົວ 1 ກິໂລ"

#. module: fast_food
#: model:uom.uom,name:fast_food.uom_uom_1
msgid "Bin"
msgstr "ຖັງ"

#. module: fast_food
#: model:product.template,name:fast_food.product_product_59_product_template
msgid "Blond Beer"
msgstr "ເບຍ (Blond Beer)"

#. module: fast_food
#: model:product.template,name:fast_food.product_product_55_product_template
msgid "Butter"
msgstr "ເບີ"

#. module: fast_food
