<?xml version='1.0' encoding='UTF-8'?>
<odoo noupdate="1">
    <record id="pos_payment_method_2" model="pos.payment.method">
        <field name="name">Online Payment</field>
        <field name="is_online_payment" eval="1"/>
        <field name="online_payment_provider_ids" eval="[(6, 0, [ref('payment.payment_provider_demo')])]"/>
    </record>
    <function model="pos.config" name="write">
        <value model="pos.config" eval="obj().search([('self_ordering_mode', '=', 'kiosk')]).ids"/>
        <value model="pos.payment.method" eval="{ 'payment_method_ids': [Command.link(ref('fast_food.pos_payment_method_2'))]}"/>
    </function>
</odoo>
