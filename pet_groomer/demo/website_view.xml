                <div class="row">
                  <div class="col-lg-6 pt32 pb32 o_colored_level" data-name="Box">
                    <h1 class="display-3">
        A little place <br/>of pampering
    </h1>
                    <p class="lead">
        This is a simple hero unit, a simple jumbotron-style component for calling extra attention to our grooming services and special offers.
    </p>
                    <p class="mb-0">
                      <a class="o_translate_inline btn btn-primary" href="/appointment">Book your appointment&amp;nbsp;<span class="fa fa-angle-right ms-2"/></a>
                    </p>
                  </div>
                </div>
              </div>
            </section>
            <section class="s_text_image o_cc o_cc2 pb64 pt64 o_colored_level" data-oe-shape-data="{&quot;shape&quot;:&quot;web_editor/Floats/13&quot;,&quot;flip&quot;:[&quot;x&quot;],&quot;showOnMobile&quot;:false,&quot;shapeAnimationSpeed&quot;:&quot;0&quot;}" data-snippet="s_image_text">
              <div class="o_we_shape o_web_editor_Floats_13" style="background-image: url(&quot;/web_editor/shape/web_editor%2FFloats%2F13.svg?c1=%23F6A4A2&amp;c2=%23FED9B7&amp;c5=%2315616D&amp;flip=x&quot;); background-position: 50% 50%;"/>
              <div class="container">
                <div class="row align-items-center">
                  <div class="col-lg-6 pt16 pb16 o_colored_level">
                    <img src="/web_editor/image_shape/pet_groomer.ir_attachment_4/web_editor/geometric_round/geo_round_square_2.svg" class="img img-fluid mx-auto rounded" alt="" data-shape="web_editor/geometric_round/geo_round_square_2" data-file-name="s_image_text.svg" data-shape-colors=";;;;" loading="lazy" data-format-mimetype="image/jpeg"/>
                  </div>
                  <div class="col-lg-5 offset-lg-1 pt16 pb16 o_colored_level">
                    <h2 class="h3-fs">
        Grooming Services
    </h2>
                    <div class="s_hr pb32 pt8" data-snippet="s_hr" data-name="Separator">
                      <hr class="w-50 me-auto" style="border-top: 4px dotted var(--o-color-2) !important;"/>
                    </div>
                    <p>
        Our team is composed of experienced pet groomers.
    </p>
                    <p>
        We will provide your pets with grooming activities that are fun, safe, and suited to their breed and personality.
    </p>
                    <p>
                      <br/>
                    </p>
                    <p>
                      <a href="#" class="btn btn-secondary o_translate_inline">Learn more</a>
                    </p>
                  </div>
                </div>
              </div>
            </section>
            <section class="s_three_columns o_cc o_colored_level o_cc1 pt112 pb0" data-vxml="001" data-vcss="001" data-oe-shape-data="{'shape':'web_editor/Connections/06','colors':{'c5':'o-color-3'},'flip':['y'],'showOnMobile':true,'shapeAnimationSpeed':'0'}" data-snippet="s_three_columns">
              <div class="o_we_shape o_web_editor_Connections_06 o_shape_show_mobile" style="background-image: url(&quot;/web_editor/shape/web_editor/Connections/06.svg?c5=o-color-3&amp;flip=y&quot;); background-position: 50% 0%;"/>
              <div class="container">
                <div class="row d-flex align-items-stretch">
                  <div data-name="Card" class="col-lg-4 pt16 pb16">
                    <div class="s_card o_card_img_top card h-100 o_cc o_cc1 my-0 o_colored_level" data-vxml="001" data-snippet="s_card" data-name="Card" style="border-width: 0px !important;">
                      <figure class="o_card_img_wrapper ratio mb-0 ratio-1x1">
                        <img class="o_card_img card-img-top" src="/web_editor/image_shape/pet_groomer.ir_attachment_3/web_editor/solid/solid_blob_1.svg?c2=o-color-1" alt="" data-shape="web_editor/solid/solid_blob_1" data-file-name="s_three_columns_default_image_1.svg" data-shape-colors=";o-color-1;;;" loading="lazy" data-format-mimetype="image/jpeg"/>
                      </figure>
                      <div class="card-body">
                        <h5 class="card-title" style="text-align: center;"><br/> Our mission
    </h5>
                        <div class="s_hr pb32 pt8" data-snippet="s_hr" data-name="Separator">
                          <hr class="w-25 mx-auto" style="border-top: 5px dotted var(--o-color-2) !important;"/>
                        </div>
                        <p class="card-text" style="text-align: center;">
        Our aim is to make your pet's grooming experience as enjoyable, stress-free, and positive as possible.
    </p>
                      </div>
                    </div>
                  </div>
                  <div data-name="Card" class="col-lg-4 pt16 pb16">
                    <div class="s_card o_card_img_top card h-100 o_cc o_cc1 my-0 o_colored_level" data-vxml="001" data-snippet="s_card" data-name="Card" style="border-width: 0px !important;">
                      <figure class="o_card_img_wrapper ratio mb-0 ratio-1x1">
                        <img class="o_card_img card-img-top" src="/web_editor/image_shape/pet_groomer.ir_attachment_2/web_editor/composition/composition_organic_line.svg?c2=o-color-3" alt="" data-shape="web_editor/composition/composition_organic_line" data-file-name="s_three_columns_default_image_2.svg" data-shape-colors=";o-color-3;;;" loading="lazy" data-format-mimetype="image/jpeg"/>
                      </figure>
                      <div class="card-body">
                        <h5 class="card-title" style="text-align: center;"><br/> For every pet
    </h5>
                        <div class="s_hr pb32 pt8" data-snippet="s_hr" data-name="Separator">
                          <hr class="w-25 mx-auto" style="border-top: 5px dotted var(--o-color-1) !important;"/>
                        </div>
                        <p class="card-text" style="text-align: center;">
        All grooming services are tailored to meet each pet’s individual needs. This approach will help your pet look and feel their best.
    </p>
                      </div>
                    </div>
                  </div>
                  <div data-name="Card" class="col-lg-4 pt16 pb16">
                    <div class="s_card o_card_img_top card h-100 o_cc o_cc1 my-0 o_colored_level" data-vxml="001" data-snippet="s_card" data-name="Card" style="border-width: 0px !important;">
                      <figure class="o_card_img_wrapper ratio mb-0 ratio-1x1">
                        <img class="o_card_img card-img-top" src="/web_editor/image_shape/pet_groomer.ir_attachment_1/web_editor/solid/solid_blob_3.svg?c5=o-color-2" alt="" data-shape="web_editor/solid/solid_blob_3" data-file-name="s_three_columns_default_image_3.svg" data-shape-colors=";;;;o-color-2" loading="lazy" data-format-mimetype="image/jpeg"/>
                      </figure>
                      <div class="card-body">
                        <h5 class="card-title" style="text-align: center;"><br/> Open-door policy
    </h5>
                        <div class="s_hr pb32 pt8" data-snippet="s_hr" data-name="Separator">
                          <hr class="w-25 mx-auto" style="border-top: 5px dotted var(--o-color-2) !important;"/>
                        </div>
                        <p class="card-text" style="text-align: center;">
        You are welcome to come and see our grooming salon and meet the team at any time convenient to you.
    </p>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </section>
            <section class="s_call_to_action o_cc o_cc2 pt152 pb152 o_colored_level" data-oe-shape-data="{&quot;shape&quot;:&quot;web_editor/Floats/14&quot;}" data-snippet="s_call_to_action">
              <div class="o_we_shape o_web_editor_Floats_14 o_footer_extra_shape_mapping"/>
              <div class="container">
                <div class="row">
                  <div class="col-lg-10 offset-lg-1 pt48 pb24 o_colored_level">
                    <h3 style="text-align: center;">2,000 pet owners<br/> trust us with their furry friends.</h3>
                    <p style="text-align: center;">Entrust us with your pets and go to work with peace of mind</p>
                    <p>
                      <br/>
                    </p>
                    <p style="text-align: center;">
                      <a class="btn btn-primary btn-lg o_translate_inline" href="/appointment">Schedule an appointment</a>
                    </p>
                  </div>
                </div>
              </div>
            </section>
          </div>
        </t>
      </t>
    </field>
    <field name="key">pet_groomer.homepage</field>
    <field name="name">Home</field>
    <field name="type">qweb</field>
    <field name="website_id" ref="website.default_website"/>
  </record>
