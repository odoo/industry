msgid "<strong>Appointments 📅</strong>"
msgstr "<strong>Ajanvaraukset 📅</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Appointments</strong> – Let customers book grooming services online with predefined services and\n"
"                availability."
msgstr ""
"<strong>Ajanvaraukset</strong> – Anna asiakkaiden varata trimmaus verkossa "
"ennalta määriteltyjen palveluiden ja\n"
"                saatavuuden perusteella."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_grooming_service
msgid ""
"<strong>Bath &amp; Dry</strong> – wash with pet-safe shampoos, conditioners,"
" blow-dry."
msgstr ""
"<strong>Kylpy &amp; Kuivaus</strong> – pesu lemmikille sopivilla shampoilla "
"ja hoitoaineilla, kuivaus."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_grooming_service
msgid ""
"<strong>Brushing &amp; De-shedding</strong> – remove loose fur, undercoat, "
"reduce shedding."
msgstr ""
"<strong>Harjaus &amp; pohjavillan poisto</strong> – poista irto- ja "
"aluskarvat, vähennä karvanlähtöä."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Calendar 🗓️</strong>"
msgstr "<strong>Kalenteri 🗓️</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Calendar</strong> – Visualize and manage grooming sessions, staff schedules, and availability in one\n"
"                place."
msgstr ""
"<strong>Kalenteri</strong> – Visualisoi ja hallinnoi trimmauskäyntejä, "
"henkilökunnan työvuoroja sekä saatavuutta yhdessä\n"
"                paikassa."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_animal_wellness
msgid ""
"<strong>Coat Conditioning Treatments</strong> – special shampoos, oils, or "
"masks."
msgstr "<strong>Turkin hoidot</strong> – erityiset shampoot, öljyt tai naamiot."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_animal_wellness
msgid ""
"<strong>Creative Grooming</strong> – coat dyeing, fur sculpting, accessories"
" (bows, bandanas)."
msgstr ""
"<strong>Luova trimmaus</strong> – turkin värjäys ja muotoilu, asusteet "
"(rusetit, bandanat)."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_animal_wellness
msgid ""
"<strong>De-matting</strong> – untangling severe knots in long-haired breeds."
msgstr ""
"<strong>Takkujen poisto</strong> – pitkäkarvaisten rotujen vaikeiden "
"takkujen selvittäminen."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>HR Apps </strong>- Manage employees, recruitment, and time off using"
" Odoo’s HR suite."
msgstr ""
"<strong>HR-sovellukset </strong>- Hallinnoi työntekijöitä, rekrytointia ja "
"vapaita Odoon HR-sovelluspaketin avulla."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_grooming_service
msgid ""
"<strong>Haircuts &amp; Styling</strong> – breed-standard trims (poodles, "
"terriers) or custom owner requests."
msgstr ""
"<strong>Turkin leikkuu &amp; muotoilu</strong> – rodun standardien mukaiset "
"trimmaukset (puudelit, terrierit) tai omistajan toiveiden mukaiset "
"leikkaukset."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>How it’s used in a grooming business:</strong>"
msgstr "<strong>Käyttöesimerkki trimmausalalla:</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Inventory</strong> – Track grooming products, retail items, and "
"stock levels in real time."
msgstr ""
"<strong>Varastointi</strong> – Seuraa trimmaus- ja jälleenmyyntituotteita "
"sekä varastotasoja reaaliajassa."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Odoo for Pet Groomers</strong>"
msgstr "<strong>Odoo lemmikkien trimmaajille</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Pets 🐾</strong>"
msgstr "<strong>Lemmikit 🐾</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Pets</strong> – Store detailed profiles for each pet, including breed, size, notes, and grooming\n"
"                history."
msgstr ""
"<strong>Lemmikit</strong> – Luo kullekin lemmikille yksityiskohtaiset "
"profiilit. Kirjaa rotu, koko, muistiinpanot ja\n"
"                hoitohistoria."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Planning</strong> – Organize employee shifts, workload distribution,"
" and time-off."
msgstr ""
"<strong>Suunnittelu</strong> – Järjestä työntekijöiden vuorot, työmäärän "
"jakautuminen sekä vapaat."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Point of Sale 🧾</strong>"
msgstr "<strong>Kassajärjestelmä 🧾</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Point of Sale</strong> – Quickly charge grooming services and retail"
" products at the counter."
msgstr ""
"<strong>Kassajärjestelmä</strong> – Laskuta trimmauspalveluista ja "
"jälleenmyyntituotteista nopeasti kassalla."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_grooming_service
msgid ""
"<strong>Puppy’s First Groom</strong> – gentle introduction session for young"
" dogs."
msgstr ""
"<strong>Pennun ensimmäinen trimmaus</strong> – lempeä tutustumiskäynti "
"nuorille koirille."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Purchase &amp; Inventory 📦</strong>"
msgstr "<strong>Ostot &amp; Varastointi 📦</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Sales 💼</strong>"
msgstr "<strong>Myynti 💼</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Sales</strong> – Create service orders, manage pricing, and prepare "
"transactions before payment."
msgstr ""
"<strong>Myynti</strong> – Luo palvelutilauksia, hallinnoi hinnoittelua ja "
"valmistele tapahtumia ennen maksua."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_animal_wellness
msgid ""
"<strong>Seasonal Packages</strong> – “Summer cut” or “Winter coat "
"maintenance.”"
msgstr "<strong>Kausipaketit</strong> – ”Kesätrimmaus” tai ”Talviturkin hoito.”"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Sign</strong> – Digitally manage consent forms, liability waivers, "
"and service approvals."
msgstr ""
"<strong>Allekirjoita</strong> – Käsittele suostumuslomakkeet, "
"vastuuvapauslausekkeet ja palveluiden hyväksynnät digitaalisesti."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Survey</strong> - Track client satisfaction &amp; feedback using "
