#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Appointments 📅</strong>"
msgstr "<strong>Randevular 📅</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Appointments</strong> – Let customers book grooming services online with predefined services and\n"
"                availability."
msgstr ""
"<strong>Randevular</strong> – Müşterilerin önceden tanımlanmış hizmetler ve\n"
"                uygunluk durumuna göre bakım hizmetlerini çevrimiçi olarak "
"rezerve etmelerini sağlayın."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_grooming_service
msgid ""
"<strong>Bath &amp; Dry</strong> – wash with pet-safe shampoos, conditioners,"
" blow-dry."
msgstr ""
"<strong>Banyo &amp; Kurutma</strong> – evcil hayvanlar için güvenli şampuan "
"ve saç kremleriyle yıkayın, fön ile kurutun."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_grooming_service
msgid ""
"<strong>Brushing &amp; De-shedding</strong> – remove loose fur, undercoat, "
"reduce shedding."
msgstr ""
"<strong> &amp; Fırçalama – gevşek tüyleri ve alt tüyleri temizleyin, tüy "
"dökülmesini azaltın.</strong> "

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Calendar 🗓️</strong>"
msgstr "<strong>Takvim 🗓️</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Calendar</strong> – Visualize and manage grooming sessions, staff schedules, and availability in one\n"
"                place."
msgstr ""
"<strong>Takvim</strong> – Bakım seanslarını, personel programlarını ve "
"müsaitlik durumlarını tek bir\n"
"                yerden görüntüleyin ve yönetin."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_animal_wellness
msgid ""
"<strong>Coat Conditioning Treatments</strong> – special shampoos, oils, or "
"masks."
msgstr ""
"<strong>Ceket Bakım Tedavileri</strong> – özel şampuanlar, yağlar veya "
"maskeler."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_animal_wellness
msgid ""
"<strong>Creative Grooming</strong> – coat dyeing, fur sculpting, accessories"
" (bows, bandanas)."
msgstr ""
"<strong>Yaratıcı Bakım</strong> – tüy boyama, kürk şekillendirme, "
"aksesuarlar (fiyonklar, bandanalar)."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_animal_wellness
msgid ""
"<strong>De-matting</strong> – untangling severe knots in long-haired breeds."
msgstr ""
"<strong></strong> Tüylerini açma – uzun tüylü ırklarda ciddi düğümleri çözme."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>HR Apps </strong>- Manage employees, recruitment, and time off using"
" Odoo’s HR suite."
msgstr ""
"<strong>HR Uygulamaları </strong>- Odoo’nun İK paketini kullanarak "
"çalışanları, işe alımları ve izinleri yönetin."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_grooming_service
msgid ""
"<strong>Haircuts &amp; Styling</strong> – breed-standard trims (poodles, "
"terriers) or custom owner requests."
msgstr ""
"<strong>Saç Kesimi &amp; Şekillendirme</strong> – cins standartlarına uygun "
"kesimler (poodle, terrier) veya sahibinin özel istekleri."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>How it’s used in a grooming business:</strong>"
msgstr "<strong>Bir bakım işletmesinde nasıl kullanılır:</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Inventory</strong> – Track grooming products, retail items, and "
"stock levels in real time."
msgstr ""
"<strong></strong> Stok – Kişisel bakım ürünlerini, perakende ürünleri ve "
"stok seviyelerini gerçek zamanlı olarak takip edin."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Odoo for Pet Groomers</strong>"
msgstr "<strong>Evcil Hayvan Bakım Uzmanları için Odoo</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Pets 🐾</strong>"
msgstr "<strong>Evcil Hayvanlar 🐾</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Pets</strong> – Store detailed profiles for each pet, including breed, size, notes, and grooming\n"
"                history."
msgstr ""
"<strong>Evcil Hayvanlar</strong> – Her evcil hayvan için cins, boyut, notlar "
"ve bakım\n"
"                geçmişi dahil olmak üzere ayrıntılı profiller saklayın."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Planning</strong> – Organize employee shifts, workload distribution,"
" and time-off."
msgstr ""
"<strong></strong> Planlama – Çalışanların vardiyalarını, iş yükü dağılımını "
"ve izinlerini düzenleyin."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Point of Sale 🧾</strong>"
msgstr "<strong>Satış Noktası</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Point of Sale</strong> – Quickly charge grooming services and retail"
" products at the counter."
msgstr ""
"<strong>Satış Noktası</strong> – Güzellik hizmetlerinin ve perakende "
"ürünlerin ücretlerini kasada hızlı bir şekilde tahsil edin."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_grooming_service
msgid ""
"<strong>Puppy’s First Groom</strong> – gentle introduction session for young"
" dogs."
msgstr ""
"<strong>Puppy’s First Groom</strong> – genç köpekler için nazik bir tanışma "
"seansı."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
