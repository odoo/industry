#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Appointments 📅</strong>"
msgstr "<strong>Afspraken 📅</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Appointments</strong> – Let customers book grooming services online with predefined services and\n"
"                availability."
msgstr ""
"<strong>Afspraken</strong> – Laat klanten online verzorgingsdiensten boeken "
"met diensten en je beschikbaarheid die je vooraf instelt."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_grooming_service
msgid ""
"<strong>Bath &amp; Dry</strong> – wash with pet-safe shampoos, conditioners,"
" blow-dry."
msgstr ""
"<strong>Wassen &amp; Drogen</strong> – wassen met huisdiervriendelijke "
"shampoos en conditioners, föhnen."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_grooming_service
msgid ""
"<strong>Brushing &amp; De-shedding</strong> – remove loose fur, undercoat, "
"reduce shedding."
msgstr ""
"<strong>Borstelen &amp; Anti-verharing</strong> – losse haren en ondervacht "
"verwijderen, verharen verminderen."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Calendar 🗓️</strong>"
msgstr "<strong>Agenda 🗓️</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Calendar</strong> – Visualize and manage grooming sessions, staff schedules, and availability in one\n"
"                place."
msgstr ""
"<strong>Agenda</strong> – Visualiseer en beheer verzorgings-sessies, "
"personeelsroosters en beschikbaarheid op één plek."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_animal_wellness
msgid ""
"<strong>Coat Conditioning Treatments</strong> – special shampoos, oils, or "
"masks."
msgstr "<strong>Vachtverzorging</strong> – speciale shampoos, oliën of maskers."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_animal_wellness
msgid ""
"<strong>Creative Grooming</strong> – coat dyeing, fur sculpting, accessories"
" (bows, bandanas)."
msgstr ""
"<strong>Creatieve knipbeurt</strong> – vachtverven, vachtmodelleren, "
"accessoires (strikken, bandana's)."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_animal_wellness
msgid ""
"<strong>De-matting</strong> – untangling severe knots in long-haired breeds."
msgstr ""
"<strong>Ontklitten</strong> – het ontwarren van ernstige klitten bij "
"langharige rassen."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>HR Apps </strong>- Manage employees, recruitment, and time off using"
" Odoo’s HR suite."
msgstr ""
"<strong>HR-apps </strong>- Beheer werknemers, werving en verlof met behulp "
"van de HR-suite van Odoo."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_grooming_service
msgid ""
"<strong>Haircuts &amp; Styling</strong> – breed-standard trims (poodles, "
"terriers) or custom owner requests."
msgstr ""
"<strong>Kapsels &amp; Styling</strong> – rasstandaardkapsels (poedels, "
"terriërs) of aangepaste verzoeken van eigenaren."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>How it’s used in a grooming business:</strong>"
msgstr "<strong>Hoe dit wordt gebruikt in een trimsalon:</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Inventory</strong> – Track grooming products, retail items, and "
"stock levels in real time."
msgstr ""
"<strong>Voorraad</strong> – Volg verzorgingsproducten, winkelartikelen en "
"voorraadniveaus realtime op."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Odoo for Pet Groomers</strong>"
msgstr "<strong>Odoo voor dierentrimmers</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Pets 🐾</strong>"
msgstr "<strong>Huisdieren 🐾</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Pets</strong> – Store detailed profiles for each pet, including breed, size, notes, and grooming\n"
"                history."
msgstr ""
"<strong>Huisdieren</strong> – Sla gedetailleerde profielen op voor elk "
"huisdier, inclusief ras, grootte, notities en verzorgingsgeschiedenis."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Planning</strong> – Organize employee shifts, workload distribution,"
" and time-off."
msgstr ""
"<strong>Planning</strong> – Organiseer dienstroosters, verdeling van "
"werklast en verlof voor werknemers."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Point of Sale 🧾</strong>"
msgstr "<strong>Kassa 🧾</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Point of Sale</strong> – Quickly charge grooming services and retail"
" products at the counter."
msgstr ""
"<strong>Kassa</strong> – Reken snel verzorgingsdiensten en winkelproducten "
"af aan de kassa."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_grooming_service
msgid ""
"<strong>Puppy’s First Groom</strong> – gentle introduction session for young"
" dogs."
msgstr ""
"<strong>Puppy’s eerste verzorging</strong> – rustige kennismakingssessie "
"voor jonge honden."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Purchase &amp; Inventory 📦</strong>"
msgstr "<strong>Inkoop &amp; Voorraad 📦</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Sales 💼</strong>"
msgstr "<strong>Verkoop 💼</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Sales</strong> – Create service orders, manage pricing, and prepare "
"transactions before payment."
msgstr ""
"<strong>Verkoop</strong> – Maak verkooporders aan, beheer prijzen en bereid "
"transacties voor vóór betaling."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_animal_wellness
msgid ""
"<strong>Seasonal Packages</strong> – “Summer cut” or “Winter coat "
"maintenance.”"
msgstr ""
"<strong>Seizoenspakketten</strong> – “Zomerkapsel” of “Wintervachtonderhoud.”"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Sign</strong> – Digitally manage consent forms, liability waivers, "
"and service approvals."
msgstr ""
"<strong>Ondertekenen</strong> – Beheer toestemmingsformulieren, "
"afstandsverklaringen en goedkeuringen voor diensten digitaal."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Survey</strong> - Track client satisfaction &amp; feedback using "
