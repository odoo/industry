#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Appointments</strong> – Let customers book grooming services online with predefined services and\n"
"                availability."
msgstr ""
"<strong>Termine</strong> – Ermöglichen Sie Kunden, Pflegebehandlungen online "
"mit vordefinierten Leistungen und\n"
"                Verfügbarkeiten zu buchen."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_grooming_service
msgid ""
"<strong>Bath &amp; Dry</strong> – wash with pet-safe shampoos, conditioners,"
" blow-dry."
msgstr ""
"<strong>Baden &amp; Trocknen</strong> – Waschen mit tierfreundlichen "
"Shampoos und Conditionern, Föhnen."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_grooming_service
msgid ""
"<strong>Brushing &amp; De-shedding</strong> – remove loose fur, undercoat, "
"reduce shedding."
msgstr ""
"<strong>Bürsten &amp; Enthaaren</strong> – lose Haare und Unterwolle "
"entfernen, Haarausfall reduzieren."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Calendar 🗓️</strong>"
msgstr "<strong>Kalender 🗓️</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Calendar</strong> – Visualize and manage grooming sessions, staff schedules, and availability in one\n"
"                place."
msgstr ""
"<strong>Kalender-</strong> – Visualisieren und verwalten Sie Körperpflege-"
"Sitzungen, Mitarbeiterpläne und Verfügbarkeiten an einem\n"
"                Ort."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_animal_wellness
msgid ""
"<strong>Coat Conditioning Treatments</strong> – special shampoos, oils, or "
"masks."
msgstr ""
"<strong>Pflegebehandlungen für das Fell</strong> – spezielle Shampoos, Öle "
"oder Masken."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_animal_wellness
msgid ""
"<strong>Creative Grooming</strong> – coat dyeing, fur sculpting, accessories"
" (bows, bandanas)."
msgstr ""
"<strong>Kreative Fellpflege</strong> – Fellfärben, Fellmodellierung, "
"Accessoires (Schleifen, Bandanas)."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_animal_wellness
msgid ""
"<strong>De-matting</strong> – untangling severe knots in long-haired breeds."
msgstr ""
"<strong>Entfilzung</strong> – das Entwirren schwerer Verfilzungen bei "
"langhaarigen Rassen."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>HR Apps </strong>- Manage employees, recruitment, and time off using"
" Odoo’s HR suite."
msgstr ""
"<strong>Personalverwaltungsapps- </strong> – Verwalten Sie Mitarbeiter, "
"Personalbeschaffung und Urlaubstage mit den Personalverwaltungsapps von Odoo."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_grooming_service
msgid ""
"<strong>Haircuts &amp; Styling</strong> – breed-standard trims (poodles, "
"terriers) or custom owner requests."
msgstr ""
"<strong>Haarschnitte &amp; Styling</strong> – rassestandardmäßige Schnitte "
"(Pudel, Terrier) oder individuelle Wünsche der Besitzer."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>How it’s used in a grooming business:</strong>"
msgstr "<strong>So wird es in einem Hundesalon verwendet:</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Inventory</strong> – Track grooming products, retail items, and "
"stock levels in real time."
msgstr ""
"<strong>Lager</strong> – Verfolgen Sie Pflegeprodukte, Einzelhandelsartikel "
"und Lagerbestände in Echtzeit."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Odoo for Pet Groomers</strong>"
msgstr "<strong>Odoo für Tierpfleger</strong>"

