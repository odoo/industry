#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Appointments 📅</strong>"
msgstr "<strong>Citas 📅</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Appointments</strong> – Let customers book grooming services online with predefined services and\n"
"                availability."
msgstr ""
"<strong>Citas</strong>: Permite que tus clientes agenden servicios de "
"peluquería en línea con servicios y\n"
"            disponibilidad predefinidos."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_grooming_service
msgid ""
"<strong>Bath &amp; Dry</strong> – wash with pet-safe shampoos, conditioners,"
" blow-dry."
msgstr ""
"<strong>Baño y secado</strong>: Lavado con champús seguros para mascotas, "
"acondicionadores y secado con secadora."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_grooming_service
msgid ""
"<strong>Brushing &amp; De-shedding</strong> – remove loose fur, undercoat, "
"reduce shedding."
msgstr ""
"<strong>Cepillado y eliminación de pelo muerto</strong>: Elimina pelo suelto "
"y manto inferior, y reduce la caída."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Calendar 🗓️</strong>"
msgstr "<strong>Calendario 🗓️</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Calendar</strong> – Visualize and manage grooming sessions, staff schedules, and availability in one\n"
"                place."
msgstr ""
"<strong>Calendario</strong>: Visualiza y gestiona sesiones de peluquería, "
"los horarios del personal y la disponibilidad desde un solo\n"
"            lugar."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_animal_wellness
msgid ""
"<strong>Coat Conditioning Treatments</strong> – special shampoos, oils, or "
"masks."
msgstr ""
"<strong>Tratamientos de acondicionamiento del pelaje</strong>: Champús "
"especiales, aceites o mascarillas."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_animal_wellness
msgid ""
"<strong>Creative Grooming</strong> – coat dyeing, fur sculpting, accessories"
" (bows, bandanas)."
msgstr ""
"<strong>Peluquería creativa</strong>: Teñido de pelaje, esculpido de pelaje "
"y accesorios (moños, pañuelos)."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_animal_wellness
msgid ""
"<strong>De-matting</strong> – untangling severe knots in long-haired breeds."
msgstr ""
"<strong>Desenredado</strong>: Elimina nudos extremos en razas de pelo largo."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>HR Apps </strong>- Manage employees, recruitment, and time off using"
" Odoo’s HR suite."
msgstr ""
"<strong>Aplicaciones de RR. HH.</strong>: Gestiona a tus empleados, el "
"reclutamiento y los permisos y ausencias con el paquete para RR. HH. de Odoo."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_grooming_service
msgid ""
"<strong>Haircuts &amp; Styling</strong> – breed-standard trims (poodles, "
"terriers) or custom owner requests."
msgstr ""
"<strong>Cortes de pelo y estilizado</strong>: Cortes estándar por raza "
"(caniches, terriers) o según las solicitudes personalizadas del dueño."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>How it’s used in a grooming business:</strong>"
msgstr "<strong>Cómo se usa en un negocio de peluquería:</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Inventory</strong> – Track grooming products, retail items, and "
"stock levels in real time."
msgstr ""
"<strong>Inventario</strong>: Lleva seguimiento en tiempo real de los "
"productos de peluquería, los artículos de venta y los niveles de existencias."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Odoo for Pet Groomers</strong>"
msgstr "<strong>Odoo para estéticas de mascotas</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Pets 🐾</strong>"
msgstr "<strong>Mascotas 🐾</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Pets</strong> – Store detailed profiles for each pet, including breed, size, notes, and grooming\n"
"                history."
msgstr ""
"<strong>Mascotas</strong>: Guarda perfiles detallados de cada mascota, "
"incluida su raza, tamaño, notas e historial de \n"
"                peluquería."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Planning</strong> – Organize employee shifts, workload distribution,"
" and time-off."
msgstr ""
"<strong>Planeación</strong>: Organiza los turnos de tus empleados, la "
"distribución de la carga de trabajo y los días libres."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Point of Sale 🧾</strong>"
msgstr "<strong>Punto de venta 🧾</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Point of Sale</strong> – Quickly charge grooming services and retail"
" products at the counter."
msgstr ""
"<strong>Punto de venta</strong>: Cobra los servicios de peluquería y "
"productos de venta en el mostrador con rapidez."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_grooming_service
msgid ""
"<strong>Puppy’s First Groom</strong> – gentle introduction session for young"
" dogs."
msgstr ""
"<strong>Primer visita para cachorros</strong>: Una sesión delicada de "
"introducción para perros jóvenes."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Purchase &amp; Inventory 📦</strong>"
msgstr "<strong>Compras e Inventario 📦</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Sales 💼</strong>"
msgstr "<strong>Ventas 💼</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Sales</strong> – Create service orders, manage pricing, and prepare "
"transactions before payment."
msgstr ""
"<strong>Ventas</strong>: Crea órdenes de venta, gestiona los precios y "
"prepara las transacciones antes del pago."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_animal_wellness
msgid ""
"<strong>Seasonal Packages</strong> – “Summer cut” or “Winter coat "
"maintenance.”"
msgstr ""
"<strong>Paquetes de temporada</strong>: \"Corte de verano\" o "
"\"Mantenimiento de pelaje de invierno\"."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Sign</strong> – Digitally manage consent forms, liability waivers, "
"and service approvals."
msgstr ""
"<strong>Firma electrónica</strong>: Gestiona formularios de consentimiento, "
"exenciones de responsabilidad y aprobaciones de servicio de forma digital."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Survey</strong> - Track client satisfaction &amp; feedback using "
"Odoo Survey"
msgstr ""
"<strong>Encuestas</strong>: Lleva seguimiento de la satisfacción y los "
"comentarios de los clientes con la aplicación Encuestas de Odoo."

