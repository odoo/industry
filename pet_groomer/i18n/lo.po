#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Appointments 📅</strong>"
msgstr "<strong>ການນັດໝາຍ 📅</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Appointments</strong> – Let customers book grooming services online with predefined services and\n"
"                availability."
msgstr ""
"<strong>ການນັດໝາຍ</strong> – ໃຫ້ລູກຄ້າຈອງບໍລິການເສີມສວຍທາງອອນລາຍ ດ້ວຍການກຳນົດບໍລິການ ແລ"
"ະ\n"
"                ເວລາທີ່ວ່າງໄວ້ລ່ວງໜ້າ."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_grooming_service
msgid ""
"<strong>Bath &amp; Dry</strong> – wash with pet-safe shampoos, conditioners,"
" blow-dry."
msgstr ""
"<strong>ອາບນ້ຳ &amp; ເປົ່າແຫ້ງ</strong> – ອາບນ້ຳດ້ວຍແຊມພູ ແລະ ຄີມນວດທີ່ປອດໄພສຳລັບສັດ, ພ້ອມ"
"ເປົ່າຂົນໃຫ້ແຫ້ງ."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_grooming_service
msgid ""
"<strong>Brushing &amp; De-shedding</strong> – remove loose fur, undercoat, "
"reduce shedding."
msgstr ""
"<strong>ຫວີຂົນ &amp; ກຳຈັດຂົນລົ່ນ</strong> – ເອົາຂົນທີ່ຫຼຸດລອກ ແລະ ຂົນຊັ້ນໃນອອກ, ຊ່ວຍຫຼຸດຜ່ອນການ"
"ລົ່ນຂອງຂົນ."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Calendar 🗓️</strong>"
msgstr "<strong>ປະຕິທິນ 🗓️</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Calendar</strong> – Visualize and manage grooming sessions, staff schedules, and availability in one\n"
"                place."
msgstr ""
"<strong>ປະຕິທິນ</strong> – ສະແດງ ແລະ ຈັດການຮອບບໍລິການ, ຕາຕະລາງພະນັກງານ ແລະ ເວລາທີ່ວ່າງ"
"ໄດ້ໃນ\n"
"                ບ່ອນດຽວ."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_animal_wellness
msgid ""
"<strong>Coat Conditioning Treatments</strong> – special shampoos, oils, or "
"masks."
msgstr ""
"<strong>ການບຳລຸງເສັ້ນຂົນ</strong> – ໃຊ້ແຊມພູສູດພິເສດ, ນ້ຳມັນບຳລຸງ ຫຼື ມາກຂົນ."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_animal_wellness
msgid ""
"<strong>Creative Grooming</strong> – coat dyeing, fur sculpting, accessories"
" (bows, bandanas)."
msgstr ""
"<strong>ການເສີມສວຍແບບສ້າງສັນ</strong> – ການຍ້ອມສີຂົນ, ຕັດແຕ່ງຊົງຂົນ, ເພີ່ມເຄື່ອງປະດັບ (ໂບ, ຜ້"
"າພັນຄໍ)."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_animal_wellness
msgid ""
"<strong>De-matting</strong> – untangling severe knots in long-haired breeds."
msgstr ""
"<strong>ກຳຈັດຂົນພັນກັນ</strong> – ແກ້ຂົນທີ່ກອດກັນເປັນກ້ອນສຳລັບສັດພັນຂົນຍາວ."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>HR Apps </strong>- Manage employees, recruitment, and time off using"
" Odoo’s HR suite."
msgstr ""
"<strong>ແອັບ HR </strong>- ຈັດການພະນັກງານ, ການຮັບສະໝັກ ແລະ ການລາພັກ ໂດຍໃຊ້ຊຸດເຄື່ອງມື "
"HR ຂອງ Odoo."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_grooming_service
msgid ""
"<strong>Haircuts &amp; Styling</strong> – breed-standard trims (poodles, "
"terriers) or custom owner requests."
msgstr ""
"<strong>ຕັດຂົນ &amp; ອອກແບບຊົງ</strong> – ຕັດແຕ່ງຕາມມາດຕະຖານສາຍພັນ (ພຸດເດິ້ນ, ເທີເຣຍ) "
"ຫຼື ຕາມຄວາມຕ້ອງການຂອງເຈົ້າຂອງ."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>How it’s used in a grooming business:</strong>"
msgstr "<strong>ວິທີການນຳໃຊ້ໃນທຸລະກິດເສີມສວຍສັດລ້ຽງ:</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Inventory</strong> – Track grooming products, retail items, and "
"stock levels in real time."
msgstr ""
"<strong>ສາງສິນຄ້າ</strong> – ຕິດຕາມຜະລິດຕະພັນເສີມສວຍ, ສິນຄ້າຂາຍຍ່ອຍ ແລະ ຈຳນວນສິນຄ້າໃນສາງ"
"ແບບຕາມເວລາຈິງ."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Odoo for Pet Groomers</strong>"
msgstr "<strong>Odoo ສຳລັບຮ້ານເສີມສວຍສັດລ້ຽງ</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Pets 🐾</strong>"
msgstr "<strong>ສັດລ້ຽງ 🐾</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Pets</strong> – Store detailed profiles for each pet, including breed, size, notes, and grooming\n"
"                history."
msgstr ""
"<strong>ສັດລ້ຽງ</strong> – ເກັບກຳຂໍ້ມູນລະອຽດຂອງສັດລ້ຽງແຕ່ລະໂຕ, ລວມທັງສາຍພັນ, ຂະໜາດ, ໝາຍເ"
"ຫດ ແລະ ປະຫວັດ\n"
"                ການເສີມສວຍ."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Planning</strong> – Organize employee shifts, workload distribution,"
" and time-off."
msgstr ""
"<strong>ການວາງແຜນ</strong> – ຈັດຕາຕະລາງການເຮັດວຽກຂອງພະນັກງານ, ການແບ່ງງານ ແລະ ການລ"
"າພັກ."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Point of Sale 🧾</strong>"
msgstr "<strong>ຈຸດຂາຍສິນຄ້າ (POS) 🧾</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Point of Sale</strong> – Quickly charge grooming services and retail"
" products at the counter."
msgstr ""
"<strong>ຈຸດຂາຍສິນຄ້າ</strong> – ຄິດໄລ່ເງິນຄ່າບໍລິການເສີມສວຍ ແລະ ສິນຄ້າຂາຍຍ່ອຍໄດ້ຢ່າງວ່ອງໄວຢູ່ໜ້າ"
"ເຄົາເຕີ."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_grooming_service
msgid ""
"<strong>Puppy’s First Groom</strong> – gentle introduction session for young"
" dogs."
msgstr ""
"<strong>ການເສີມສວຍຄັ້ງທຳອິດຂອງລູກໝາ</strong> – ຮອບບໍລິການແບບອ່ອນໂຍນເພື່ອໃຫ້ໝານ້ອຍຄຸ້ນເຄີຍ."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Purchase &amp; Inventory 📦</strong>"
msgstr "<strong>ການຈັດຊື້ &amp; ສາງສິນຄ້າ 📦</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Sales 💼</strong>"
msgstr "<strong>ການຂາຍ 💼</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Sales</strong> – Create service orders, manage pricing, and prepare "
"transactions before payment."
msgstr ""
"<strong>ການຂາຍ</strong> – ສ້າງໃບສັ່ງບໍລິການ, ຈັດການລາຄາ ແລະ ກຽມທຸລະກຳກ່ອນການຊຳລະເງິນ."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_animal_wellness
msgid ""
"<strong>Seasonal Packages</strong> – “Summer cut” or “Winter coat "
"maintenance.”"
msgstr ""
"<strong>ແພັກເກັດຕາມລະດູການ</strong> – “ຕັດຊົງລະດູຮ້ອນ” ຫຼື “ການບຳລຸງຂົນໃນລະດູໜາວ.”"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Sign</strong> – Digitally manage consent forms, liability waivers, "
"and service approvals."
