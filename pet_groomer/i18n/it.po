#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Appointments 📅</strong>"
msgstr "<strong>Appuntamenti 📅</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Appointments</strong> – Let customers book grooming services online with predefined services and\n"
"                availability."
msgstr ""
"<strong>Appuntamenti</strong> – Consenti ai clienti di prenotare online "
"servizi di toelettatura con servizi predefiniti e\n"
"                disponibilità."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_grooming_service
msgid ""
"<strong>Bath &amp; Dry</strong> – wash with pet-safe shampoos, conditioners,"
" blow-dry."
msgstr ""
"<strong>Bagno e sciugatura</strong> – Lavaggio con shampoo e balsami adatti "
"agli animali domestici, asciugatura con il phon."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_grooming_service
msgid ""
"<strong>Brushing &amp; De-shedding</strong> – remove loose fur, undercoat, "
"reduce shedding."
msgstr ""
"<strong>Spazzolatura e rimozione del sottopelo</strong> – Rimozione del pelo "
"morto, del sottopelo, riduzione della perdita di pelo."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Calendar 🗓️</strong>"
msgstr "<strong>Calendario 🗓️</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Calendar</strong> – Visualize and manage grooming sessions, staff schedules, and availability in one\n"
"                place."
msgstr ""
"<strong>Calendario</strong> – Visualizza e gestisci le sessioni di grooming, "
"gli orari del personale e la disponibilità in un'unica\n"
"                piattaforma."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_animal_wellness
msgid ""
"<strong>Coat Conditioning Treatments</strong> – special shampoos, oils, or "
"masks."
msgstr ""
"<strong>Trattamenti condizionanti del mantello</strong> – Shampoo, oli o "
"maschere speciali."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_animal_wellness
msgid ""
"<strong>Creative Grooming</strong> – coat dyeing, fur sculpting, accessories"
" (bows, bandanas)."
msgstr ""
"<strong>Toelettatura creativa</strong> – Tintura del mantello, modellatura "
"del pelo, accessori (fiocchi, bandane)."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_animal_wellness
msgid ""
"<strong>De-matting</strong> – untangling severe knots in long-haired breeds."
msgstr ""
"<strong>Districamento dei nodi</strong> - Eliminazione di nodi difficili "
"nelle razze a pelo lungo."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>HR Apps </strong>- Manage employees, recruitment, and time off using"
" Odoo’s HR suite."
msgstr ""
"<strong>App HR </strong>- Gestisci i dipendenti, le assunzioni e le ferie "
"utilizzando la suite HR di Odoo."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_grooming_service
msgid ""
"<strong>Haircuts &amp; Styling</strong> – breed-standard trims (poodles, "
"terriers) or custom owner requests."
msgstr ""
"<strong>Tagli e styling</strong> - Tagli standard di razza (barboncini, "
"terrier) o richieste personalizzate del proprietario."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>How it’s used in a grooming business:</strong>"
msgstr "<strong>Come viene utilizzato in un'azienda di toelettatura:</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Inventory</strong> – Track grooming products, retail items, and "
"stock levels in real time."
msgstr ""
"<strong>Magazzino</strong> – Tieni traccia dei prodotti per la cura "
"personale, degli articoli al dettaglio e dei livelli delle scorte in tempo "
"reale."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Odoo for Pet Groomers</strong>"
msgstr "<strong>Odoo per toelettatori di animali domestici</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Pets 🐾</strong>"
msgstr "<strong>Animali domestici 🐾</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Pets</strong> – Store detailed profiles for each pet, including breed, size, notes, and grooming\n"
"                history."
msgstr ""
"<strong>Animali domestici</strong> – Memorizza profili dettagliati per ogni "
"animale domestico, inclusi razza, taglia, note e\n"
"                cronologia delle toelettature."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Planning</strong> – Organize employee shifts, workload distribution,"
" and time-off."
msgstr ""
"<strong>Pianificazione</strong> – Organizza i turni dei dipendenti, la "
"distribuzione del carico di lavoro e le ferie."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Point of Sale 🧾</strong>"
msgstr "<strong>Punto vendita 🧾</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Point of Sale</strong> – Quickly charge grooming services and retail"
" products at the counter."
msgstr ""
"<strong>Punto vendita</strong> – Fattura rapidamente i servizi di "
"toelettatura e i prodotti al dettaglio alla cassa."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_grooming_service
msgid ""
"<strong>Puppy’s First Groom</strong> – gentle introduction session for young"
" dogs."
msgstr ""
"<strong>Prima toelettatura</strong> – Sessione di introduzione delicata per "
"cuccioli."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Purchase &amp; Inventory 📦</strong>"
msgstr "<strong>Acquisti e magazzino 📦</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid "<strong>Sales 💼</strong>"
msgstr "<strong>Vendite 💼</strong>"

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Sales</strong> – Create service orders, manage pricing, and prepare "
"transactions before payment."
msgstr ""
"<strong>Vendite</strong> – Crea ordini di servizio, gestisci i prezzi e "
"prepara le transazioni prima del pagamento."

#. module: pet_groomer
#: model_terms:appointment.type,message_intro:pet_groomer.appointment_type_animal_wellness
msgid ""
"<strong>Seasonal Packages</strong> – “Summer cut” or “Winter coat "
"maintenance.”"
msgstr ""
"<strong>Pacchetti stagionali</strong> – “Taglio estivo” o “Manutenzione del "
"pelo invernale”."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Sign</strong> – Digitally manage consent forms, liability waivers, "
"and service approvals."
msgstr ""
"<strong>Firma</strong> – Gestisci digitalmente i moduli di consenso, le "
"liberatorie e le approvazioni dei servizi."

#. module: pet_groomer
#: model_terms:ir.ui.view,arch_db:pet_groomer.welcome_article_body
msgid ""
"<strong>Survey</strong> - Track client satisfaction &amp; feedback using "
