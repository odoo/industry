<?xml version='1.0' encoding='UTF-8'?>
<odoo>
  <record id="pets_window_action" model="ir.actions.act_window">
    <field name="name">Pets</field>
    <field name="res_model">x_pets</field>
    <field name="view_mode">list,form,kanban</field>
  </record>
  <record id="medical_issues_window_action" model="ir.actions.act_window">
    <field name="name">Medical Issues</field>
    <field name="res_model">x_medical_issues</field>
  </record>
  <record id="treatments_window_action" model="ir.actions.act_window">
    <field name="name">Treatments</field>
    <field name="res_model">x_treatments</field>
  </record>
  <record id="allergies_window_action" model="ir.actions.act_window">
    <field name="name">Allergies</field>
    <field name="res_model">x_allergies</field>
  </record>
  <record id="species_window_action" model="ir.actions.act_window">
    <field name="name">Species</field>
    <field name="res_model">x_species</field>
  </record>
  <record id="action_window_sale_order" model="ir.actions.act_window">
    <field name="context">{'search_default_x_pets': active_id,'default_x_pets': [active_id]}</field>
    <field name="domain">[('x_pet_ids', '=', active_id)]</field>
    <field name="name">Sales Order</field>
    <field name="res_model">sale.order</field>
  </record>
</odoo>
