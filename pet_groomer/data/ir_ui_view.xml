<?xml version='1.0' encoding='UTF-8'?>
<odoo>
  <record id="x_pets_list_view" model="ir.ui.view">
    <field name="name">x_pets.list.view</field>
    <field name="model">x_pets</field>
    <field name="active" eval="True"/>
    <field name="type">list</field>
    <field name="arch" type="xml">
      <list>
        <field name="x_sequence" widget="handle"/>
        <field name="x_name"/>
        <field name="x_species_id" optional="show"/>
        <field name="x_breed_id" optional="show"/>
        <field name="x_gender" optional="show"/>
        <field name="x_standard_package_ids" optional="show" widget="many2many_tags"/>
        <field name="x_user_id" widget="many2one_avatar_user"/>
      </list>
    </field>
  </record>
  <record id="x_pets_form_view" model="ir.ui.view">
    <field name="name">x_pets.form.view</field>
    <field name="model">x_pets</field>
    <field name="active" eval="True"/>
    <field name="type">form</field>
    <field name="arch" type="xml">
      <form>
        <header>
          <button name="%(ir_actions_server_create_sale_order_from_pets)d" string="Create Order" type="action" class="btn-primary"/>
        </header>
        <sheet string="Pets">
          <widget name="web_ribbon" text="Archived" bg_color="text-bg-danger" invisible="x_active"/>
          <div name="button_box" class="oe_button_box">
            <button name="%(action_window_sale_order)d" class="oe_stat_button" icon="fa-shopping-cart" type="action" invisible="not x_pets_sale_order_count">
              <field widget="statinfo" name="x_pets_sale_order_count" string="Sales Order"/>
            </button>
          </div>
          <field name="x_active" invisible="1"/>
          <field name="x_avatar_image" widget="image" class="oe_avatar" options="{'size':[0,180]}"/>
          <div class="oe_title">
            <h1>
              <field name="x_name" required="1" placeholder="Name..."/>
            </h1>
          </div>
          <group name="main_group">
            <group name="left_group" string="Main">
              <field name="x_owner_ids" widget="many2many_tags"/>
              <field name="x_user_id" widget="many2one_avatar_user"/>
            </group>
            <group name="right_group" string="Grooming">
              <field name="x_standard_package_ids" widget="many2many_tags"/>
              <field name="x_preferred_haircut_style"/>
              <field name="x_bathing_preferences"/>
            </group>
          </group>
          <notebook name="notebook">
            <page string="Details" name="details_page">
              <group name="main_group_details">
                <group name="general_group" string="General">
                  <field name="x_species_id" options="{'create_name_field': 'x_name'}"/>
                  <field name="x_breed_id" options="{'create_name_field': 'x_name'}"/>
                  <field name="x_size_class"/>
                  <field name="x_weight"/>
                  <field name="x_date_of_birth"/>
                  <field name="x_gender"/>
                  <field name="x_coat_type"/>
                  <field name="x_coat_condition"/>
                </group>
                <group name="safety_medical_group" string="Safety &amp; Medical">
                  <field name="x_behavior" widget="selection_badge" string="Temperament"/>
                  <field name="x_owner_presence_required"/>
                  <field name="x_escape_risk"/>
                  <field name="x_neutered_spayed"/>
                  <field name="x_muzzle_required"/>
                  <field name="x_can_share_room_with_other_pets"/>
                  <field name="x_treatment_ids" widget="many2many_tags"/>
                  <field name="x_medical_issue_ids" widget="many2many_tags"/>
                  <field name="x_allergies_ids" widget="many2many_tags"/>
                </group>
              </group>
            </page>
            <page string="Notes" name="notes_page">
              <field name="x_notes" string="Notes" placeholder="Enter your notes"/>
            </page>
          </notebook>
        </sheet>
        <chatter/>
      </form>
    </field>
  </record>
  <record id="x_pets_search_view" model="ir.ui.view">
    <field name="name">x_pets.search.view</field>
    <field name="model">x_pets</field>
    <field name="active" eval="True"/>
    <field name="type">search</field>
    <field name="arch" type="xml">
      <search>
        <field name="x_name"/>
        <field name="x_user_id"/>
        <filter string="My Pets" name="my_x_pets" domain="[['x_user_id', '=', uid]]"/>
        <separator/>
        <filter string="Archived" name="archived_x_pets" domain="[['x_active', '=', False]]"/>
        <separator/>
        <filter name="groupby_x_user" string="Responsible" context="{'group_by': 'x_user_id'}" domain="[]"/>
      </search>
    </field>
  </record>
  <record id="x_medical_issues_list_view" model="ir.ui.view">
    <field name="name">x_medical_issues.list.view</field>
    <field name="model">x_medical_issues</field>
