  <record id="x_pets_kanban_view" model="ir.ui.view">
    <field name="name">x_pets.kanban.view</field>
    <field name="model">x_pets</field>
    <field name="active" eval="True"/>
    <field name="priority">99</field>
    <field name="type">kanban</field>
    <field name="arch" type="xml">
      <kanban>
        <templates>
          <t t-name="card">
            <field name="x_avatar_image" display="full" widget="contact_image" options="{'zoom':false,'size':[0,90]}"/>
            <field name="x_name" class="fw-bold"/>
            <field name="x_species_id" class="fw-bold"/>
            <field name="x_breed_id" widget="badge"/>
            <field name="x_behavior" widget="badge"/>
            <field name="x_standard_package_ids"/>
          </t>
        </templates>
      </kanban>
    </field>
  </record>
