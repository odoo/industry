      </list>
    </field>
  </record>
  <record id="x_medical_issues_form_view" model="ir.ui.view">
    <field name="name">x_medical_issues.form.view</field>
    <field name="model">x_medical_issues</field>
    <field name="active" eval="True"/>
    <field name="type">form</field>
    <field name="arch" type="xml">
      <form>
        <h1>
          <field name="x_name" required="1" placeholder="Name..."/>
        </h1>
      </form>
    </field>
  </record>
  <record id="x_medical_issues_search_view" model="ir.ui.view">
    <field name="name">x_medical_issues.search.view</field>
    <field name="model">x_medical_issues</field>
    <field name="active" eval="True"/>
    <field name="type">search</field>
    <field name="arch" type="xml">
      <search>
        <field name="x_name"/>
        <separator/>
        <filter string="Archived" name="archived_x_medical_issues" domain="[['x_active', '=', False]]"/>
        <separator/>
      </search>
    </field>
  </record>
