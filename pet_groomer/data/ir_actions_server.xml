<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="ir_actions_server_create_sale_order_from_pets" model="ir.actions.server">
        <field name="code"><![CDATA[
for record in records:
    owner = record.x_owner_ids[:1]
    if not owner:
        raise UserError("No owner defined for this pet.")

    if not record.x_standard_package_ids:
        raise UserError("No products in Standard Package for this pet.")

    order_lines = []
    for product in record.x_standard_package_ids:
        order_lines.append((0, 0, {'product_id': product.id}))

    order = env['sale.order'].create({
        'partner_id': owner.id,
        'x_pet_ids': [(4, record.id)],
        'order_line': order_lines,
    })
action = {
    'type': 'ir.actions.act_window',
    'res_model': 'sale.order',
    'res_id': order.id,
    'view_mode': 'form',
}]]></field>
    <field name="model_id" ref="x_pets_model"/>
    <field name="state">code</field>
    <field name="name">Create new sale order from pets</field>
  </record>
  <record id="ir_actions_server_view_button" model="ir.actions.server">
    <field name="code"><![CDATA[
action = {
    'view_mode': 'form',
    'res_model': 'x_pets',
    'res_id': record.id,
    'type': 'ir.actions.act_window',
}
]]></field>
    <field name="model_id" ref="x_pets_model"/>
    <field name="state">code</field>
    <field name="name">View Action</field>
  </record>
  <record id="action_window_calendar_event" model="ir.actions.server">
    <field name="name">Open Calendar Event</field>
    <field name="model_id" ref="sale.model_sale_order"/>
    <field name="state">code</field>
    <field name="code"><![CDATA[
action = {
    'type': 'ir.actions.act_window',
    'name': 'Calendar Events',
    'res_model': 'calendar.event',
    'view_mode': 'list,form',
    'domain': [('x_sale_order_id', '=', record.id)],
    'context': {
        'default_x_sale_order_id': record.id,
        'default_x_pet_ids': [(6, 0, record.x_pet_ids.ids)],
    },
}]]></field>
  </record>
  <record id="action_window_sale_order_server_action" model="ir.actions.server">
    <field name="name">Open Sale Order</field>
    <field name="model_id" ref="calendar.model_calendar_event"/>
    <field name="state">code</field>
    <field name="code"><![CDATA[
action = {
    'type': 'ir.actions.act_window',
    'name': 'Sale Orders',
    'res_model': 'sale.order',
    'view_mode': 'list,form',
    'domain': [('x_calendar_event_ids', 'in', records.ids)],
    'context': {
        'default_x_calendar_event_ids': [(6, 0, records.ids)],
        'default_x_pet_ids': [(6, 0, records.mapped('x_pet_ids').ids)],
    },
}]]></field>
  </record>
</odoo>
