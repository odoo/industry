<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Mapping fields -->
    <record id="x_remote_field_x_channex_mapping" model="ir.model.fields">
        <field name="ttype">char</field>
        <field name="field_description">Channex ID</field>
        <field name="model_id" ref="x_channex_mapping_model"/>
        <field name="name">x_id_remote</field>
    </record>
    <record id="x_model_type_field_x_channex_mapping" model="ir.model.fields">
        <field name="ttype">selection</field>
        <field name="field_description">Channex Model</field>
        <field name="model_id" ref="x_channex_mapping_model"/>
        <field name="name">x_model_type</field>
    </record>
    <record id="x_model_type_field_selection_webhook" model="ir.model.fields.selection">
        <field name="name">Webhook</field>
        <field name="field_id" ref="x_model_type_field_x_channex_mapping" />
        <field name="value">webhook</field>
    </record>
    <record id="x_model_type_field_selection_group" model="ir.model.fields.selection">
        <field name="name">Group</field>
        <field name="field_id" ref="x_model_type_field_x_channex_mapping" />
        <field name="value">group</field>
    </record>
    <record id="x_model_type_field_selection_property" model="ir.model.fields.selection">
        <field name="name">Property</field>
        <field name="field_id" ref="x_model_type_field_x_channex_mapping" />
        <field name="value">property</field>
    </record>
    <record id="x_model_type_field_selection_room_type" model="ir.model.fields.selection">
        <field name="name">Room Type</field>
        <field name="field_id" ref="x_model_type_field_x_channex_mapping" />
        <field name="value">room_type</field>
    </record>
    <record id="x_model_type_field_selection_rate_plan" model="ir.model.fields.selection">
        <field name="name">Rate Plan</field>
        <field name="field_id" ref="x_model_type_field_x_channex_mapping" />
        <field name="value">rate_plan</field>
    </record>
    <record id="x_model_type_field_selection_booking" model="ir.model.fields.selection">
        <field name="name">Booking</field>
        <field name="field_id" ref="x_model_type_field_x_channex_mapping" />
        <field name="value">booking</field>
    </record>
    <record id="x_id_local_field_x_channex_mapping" model="ir.model.fields">
        <field name="ttype">integer</field>
        <field name="field_description">Odoo ID</field>
        <field name="model_id" ref="x_channex_mapping_model"/>
        <field name="name">x_id_local</field>
    </record>
    <!-- ir cron fields -->
    <record id="x_debug_last_answer_field_ir_cron" model="ir.model.fields">
        <field name="ttype">char</field>
        <field name="field_description">debug: Last Answer</field>
        <field name="model_id" ref="base.model_ir_cron"/>
        <field name="name">x_debug_last_answer</field>
    </record>
    <!-- x_channex_datas_cron_lines fields -->
     <record id="x_cron_id_field_x_channex_datas_cron_lines" model="ir.model.fields">
        <field name="ttype">many2one</field>
        <field name="relation">ir.cron</field>
        <field name="field_description">Related Cron</field>
        <field name="model_id" ref="x_channex_datas_cron_lines_model"/>
        <field name="name">x_cron_id</field>
    </record>

    <record id="x_datas_to_send_field_ir_cron" model="ir.model.fields">
        <field name="ttype">one2many</field>
        <field name="relation">x_channex_datas_cron_lines</field>
        <field name="field_description">Datas to send to channex</field>
        <field name="model_id" ref="base.model_ir_cron"/>
        <field name="name">x_datas_to_send</field>
        <field name="relation_field">x_cron_id</field>
    </record>

    <record id="x_payload_field_x_channex_datas_cron_lines" model="ir.model.fields">
        <field name="name">x_payload</field>
        <field name="field_description">payload to send</field>
        <field name="model_id" ref="x_channex_datas_cron_lines_model"/>
        <field name="ttype">json</field>
    </record>
    <record id="x_operation_field_x_channex_datas_cron_lines" model="ir.model.fields">
        <field name="name">x_operation</field>
        <field name="field_description">Operation to do</field>
        <field name="model_id" ref="x_channex_datas_cron_lines_model"/>
        <field name="ttype">selection</field>
    </record>
    <record id="x_operation_field_x_channex_datas_cron_lines_selection_availability" model="ir.model.fields.selection">
        <field name="name">Availability</field>
        <field name="field_id" ref="x_operation_field_x_channex_datas_cron_lines" />
        <field name="value">availability</field>
    </record>
    <record id="x_operation_field_x_channex_datas_cron_lines_selection_restrictions" model="ir.model.fields.selection">
        <field name="name">Restrictions</field>
        <field name="field_id" ref="x_operation_field_x_channex_datas_cron_lines" />
        <field name="value">restrictions</field>
    </record>
    <record id="x_channex_api_key_field_res_company" model="ir.model.fields">
        <field name="ttype">char</field>
        <field name="field_description">Channex API Key</field>
        <field name="model_id" ref="base.model_res_company"/>
        <field name="name">x_channex_api_key</field>
        <field name="groups" eval="[(4, ref('base.group_system'))]"/>
    </record>
    <record id="x_setting_related_field_channel_manager_api_key" model="ir.model.fields">
        <field name="ttype">char</field>
        <field name="store" eval="False"/>
        <field name="related">company_id.x_channex_api_key</field>
        <field name="field_description">API Key</field>
        <field name="model_id" ref="base_setup.model_res_config_settings"/>
        <field name="name">x_channex_api_key</field>
    </record>
</odoo>
