<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="webhook_get_booking_create_change_or_delete" model="base.automation">
        <field name="name">Channex: Webhook Bookings</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="trigger">on_webhook</field>
        <field name="log_webhook_calls" eval="True"/>
        <field name="record_getter">model.env['sale.order'].search([], limit=1)</field>
        <field name="action_server_ids" eval="[(6, 0, [ref('webhook_action_manage_booking_create_change_or_delete')])]"/>
        <!-- url compute automatiquement; à récupérer pour utiliser le webhook -->
    </record>

    <record id="automation_on_product_product_create_or_write" model="base.automation">
        <field name="model_id" ref="product.model_product_product"/>
        <field name="action_server_ids" eval="[(6, 0, [ref('create_or_modify_room_type')])]"/>
        <field name="trigger">on_create_or_write</field>
        <field name="name">Product product Create or write</field>
        <field name="active" eval="False"/>
    </record>
</odoo>
