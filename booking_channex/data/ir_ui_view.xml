<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- channex mapping views -->
    <record id="x_channex_mapping_form_view" model="ir.ui.view">
        <field name="model">x_channex_mapping</field>
        <field name="name">Mapping Table Form</field>
        <field name="active" eval="True"/>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="x_model_type" />
                        <field name="x_local_id" />
                    </group>
                    <group>
                        <field name="x_remote_id" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="x_channex_mapping_search_view" model="ir.ui.view">
        <field name="name">x.channex.mapping.search</field>
        <field name="model">x_channex_mapping</field>
        <field name="active" eval="True"/>
        <field name="type">search</field>
        <field name="arch" type="xml">
            <search>
                <filter name="group_by_model_type" string="Model Type" context="{'group_by': 'x_model_type'}"/>
            </search>
        </field>
    </record>
    <record id="x_channex_mapping_list_view" model="ir.ui.view">
        <field name="model">x_channex_mapping</field>
        <field name="name">Mapping Table list</field>
        <field name="active" eval="True"/>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list>
                <field name="x_model_type" />
                <field name="x_local_id" />
                <field name="x_remote_id" />
            </list>
        </field>
    </record>

    <!-- rate plan views -->
    <record id="x_rate_plan_form_view" model="ir.ui.view">
        <field name="model">x_rate_plan</field>
        <field name="name">Rate Plan Form</field>
        <field name="active" eval="True"/>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <h1>
                        <field name="x_name"/>
                    </h1>
                    <group>
                        <field name="x_variant_id" domain="[('x_is_a_room_offer', '=', True)]"/>
                        <field name="x_rate_plan_value_id"/>
                        <field name="x_pricelist_id" />
                        <field name="x_total_inventory" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="x_rate_plan_list_view" model="ir.ui.view">
        <field name="model">x_rate_plan</field>
        <field name="name">Rate Plan list</field>
        <field name="active" eval="True"/>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list>
                <field name="x_name"/>
                <field name="x_variant_id" domain="[('x_is_a_room_offer', '=', True)]"/>
                <field name="x_rate_plan_value_id"/>
                <field name="x_pricelist_id" />
                <field name="x_total_inventory" />
            </list>
        </field>
    </record>

    <!-- cron data send lines views -->
     <record id="x_channex_datas_cron_lines_list_view" model="ir.ui.view">
        <field name="arch" type="xml">
            <list>
                <field name="x_payload" />
                <field name="x_operation" />
            </list>
        </field>
        <field name="model">x_channex_datas_cron_lines</field>
        <field name="name">Datas cron lines list</field>
        <field name="active" eval="True"/>
        <field name="type">list</field>
    </record>
    <!-- product pricelit views -->
    <record id="product_pricelist_view" model="ir.ui.view">
        <field name="name">booking.channex.product.pricelist.form.inherit</field>
        <field name="model">product.pricelist</field>
        <field name="inherit_id" ref="product.product_pricelist_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='company_id']" position="after">
                <field name="x_published_on_channex"/>
            </xpath>
        </field>
    </record>
    <!-- res company views -->
    <record id="res_company_extends" model="ir.ui.view">
        <field name="arch" type="xml">
            <xpath expr="//field[@name='phone']" position="before">
                <field name="x_channex_api_key" password="True"/>
            </xpath>
        </field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="model">res.company</field>
        <field name="name">Res company form view extension</field>
        <field name="active" eval="True"/>
        <field name="type">form</field>
    </record>
    <!-- ir cron views -->
    <record id="ir_cron_extends" model="ir.ui.view">
        <field name="arch" type="xml">
            <xpath expr="//field[@name='group_ids']" position="after">
                <field name="x_debug_last_answer"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page name="Datas sending">
                    <field name="x_datas_to_send"/>
                </page>
            </xpath>
        </field>
        <field name="inherit_id" ref="base.ir_cron_view_form"/>
        <field name="model">ir.cron</field>
        <field name="name">ir.cron form view extension</field>
        <field name="active" eval="True"/>
        <field name="type">form</field>
    </record>
    <!-- res config settings views -->
     <record id="res_config_settings_extends" model="ir.ui.view">
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='active_user_setting']" position="after">
                <setting id="channex_setting">
                    <button name="%(update_ari)d" icon="oi-arrow-right" type="action" string="Push ARI" class="btn-link"/>
                </setting>
            </xpath>
        </field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="model">res.config.settings</field>
        <field name="name">res.config.settings form view extension</field>
        <field name="active" eval="True"/>
        <field name="type">form</field>
    </record>
    <record id="res_config_settings_form_view_inherited_sync" model="ir.ui.view">
        <field name="name">res.config.settings.form.view.inherited.booking.engine.sync</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="50"/>
        <field name="active" eval="True"/>
        <field name="inherit_id" ref="booking_engine.res_config_settings_form_view_inherited" />
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='booking_engine_channel_manager_setting']//div" position="replace">
                <div class="content-group" invisible="not x_module_channel_manager">
                    <div class="row mt16">
                        <label for="x_channex_api_key" class="col-lg-3" invisible="not x_module_channel_manager"/>
                        <field name="x_channex_api_key" required="x_module_channel_manager" invisible="not x_module_channel_manager"/>
                    </div>
                </div>
                <div invisible="not x_module_channel_manager" class="oe_inline">
                        <button
                            type="action"
                            name="%(action_button_sync)d"
                            class="btn-primary"
                        >
                            Sync
                        </button>
                    </div>
            </xpath>
        </field>
    </record>
    <record id="product_form_view" model="ir.ui.view">
        <field name="arch" type="xml">
            <xpath expr="//group[@name='group_standard_price']//field[@name='company_id']" position="attributes">
                <attribute name="required">x_is_a_room_offer</attribute>
            </xpath>
        </field>
        <field name="inherit_id" ref="sale_planning.product_template_form_view_invoice_policy_inherit_sale_planning"/>
        <field name="mode">extension</field>
        <field name="model">product.template</field>
        <field name="name">product.template.product.form.inherit.booking_channex</field>
        <field name="priority">160</field>
        <field name="type">form</field>
        <field name="active" eval="True"/>
    </record>
</odoo>
