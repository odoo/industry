<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="ir_cron_data_channex_sender" model="ir.cron">
        <field name="name">Channex: Send Data Changes to Channex</field>
        <field name="interval_number">1</field>
        <field name="interval_type">minutes</field>
        <field name="nextcall" eval="datetime.now()+relativedelta(minutes=1)"/>
        <field name="model_id" ref="base.model_ir_cron"/>
        <field name="ir_actions_server_id" ref="cron_action_send_data_to_channex"/>
        <field name="state">code</field>
        <field name="active" eval="False"/>
    </record>

    <record id="ir_cron_actualize_rate_plans_on_start" model="ir.cron">
        <field name="name">Channex: Actualize Rate Plans on start</field>
        <field name="interval_number">1</field>
        <field name="interval_type">minutes</field>
        <field name="nextcall" eval="datetime.now()+relativedelta(minutes=1)"/>
        <field name="model_id" ref="base.model_ir_cron"/>
        <field name="code"><![CDATA[
model.env.ref('booking_channex.server_action_create_remove_rate_plans').run()
model.env['ir.cron']._commit_progress(processed=1, remaining=0, deactivate=True)
        ]]></field>
        <field name="state">code</field>
    </record>

    <record id="ir_cron_daily_sync" model="ir.cron">
        <field name="name">Channex: Daily Sync</field>
        <field name="interval_number">24</field>
        <field name="interval_type">hours</field>
        <field name="nextcall" eval="datetime.now()+relativedelta(hours=24)"/>
        <field name="model_id" ref="base.model_ir_cron"/>
        <field name="ir_actions_server_id" ref="fetch_channex_and_capture_changes_needed"/>
        <field name="state">code</field>
    </record>
</odoo>
