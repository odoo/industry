<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="ir_cron_data_channex_sender" model="ir.cron">
        <field name="name">Channex: Send Data Changes to Channex</field>
        <field name="interval_number">1</field>
        <field name="interval_type">minutes</field>
        <field name="nextcall" eval="datetime.now()+relativedelta(minutes=1)"/>
        <field name="model_id" ref="base.model_ir_cron"/>
        <field name="ir_actions_server_id" ref="cron_action_send_data_to_channex"/>
        <field name="state">code</field>
        <field name="active" eval="False"/>
    </record>
</odoo>
