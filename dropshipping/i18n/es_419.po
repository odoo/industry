#. module: dropshipping
#: model_terms:ir.ui.view,arch_db:dropshipping.welcome_article_body
msgid ""
"<strong>One-Click Confirmation:</strong> Review and confirm purchase orders "
"instantly."
msgstr ""
"<strong>Confirmación con un clic:</strong> Revise y confirme las órdenes de "
"compra al instante."

#. module: dropshipping
#: model_terms:ir.ui.view,arch_db:dropshipping.welcome_article_body
