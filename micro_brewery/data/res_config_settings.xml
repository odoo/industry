<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record model="res.config.settings" id="res_config_account_setting">
        <field name="group_analytic_accounting" eval="1"/>
        <field name="group_stock_production_lot" eval="1"/>
        <field name="group_mrp_wo_shop_floor" eval="1"/>
        <field name="module_quality_control" eval="1"/>
        <field name="group_mrp_routings" eval="1"/>
        <field name="group_product_variant" eval="1"/>
        <field name="group_uom" eval="1"/>
        <field name="group_discount_per_so_line" eval="1"/>
        <field name="group_product_pricelist" eval="1"/>
