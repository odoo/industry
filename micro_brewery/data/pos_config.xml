<?xml version='1.0' encoding='UTF-8'?>
<odoo noupdate="1">
    <record id="point_of_sale.pos_config_main" model="pos.config">
        <field name="name">Shop</field>
        <field name="warehouse_id" ref="stock.warehouse0"/>
        <field name="module_pos_restaurant" eval="False"/>
        <field name="down_payment_product_id" ref="pos_sale.default_downpayment_product"/>
    </record>
    <record id="pos_config_main_restaurant" model="pos.config">
        <field name="name">Bar</field>
        <field name="warehouse_id" ref="stock.warehouse0"/>
        <field name="iface_available_categ_ids" eval="[(6, 0, [ref('pos_category_2')])]"/>
        <field name="limit_categories" eval="True"/>
        <field name="iface_splitbill" eval="True"/>
        <field name="available_pricelist_ids" eval="[(6, 0, [ref('product_pricelist_1')])]"/>
        <field name="pricelist_id" ref="product_pricelist_1"/>
        <field name="floor_ids" eval="[(6, 0, [ref('restaurant_floor_1'), ref('restaurant_floor_2')])]"/>
    </record>
</odoo>
