<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="micro_brewery_volume" model="ir.model.fields">
        <field name="name">x_volume_l</field>
        <field name="copied" eval="True"/>
        <field name="field_description">Volume (L)</field>
        <field name="model">product.template</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="on_delete" eval="False"/>
        <field name="ttype">float</field>
    </record>
    <record id="micro_brewery_degree" model="ir.model.fields">
        <field name="name">x_alcohol_degree_</field>
        <field name="copied" eval="True"/>
        <field name="field_description">Alcohol Degree (°)</field>
        <field name="model">product.template</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="on_delete" eval="False"/>
        <field name="ttype">float</field>
    </record>
    <record id="micro_brewery_alcohol_excise" model="ir.model.fields">
        <field name="name">x_alcohol_excise</field>
        <field name="copied" eval="True"/>
        <field name="field_description">Alcohol excise</field>
        <field name="model">product.template</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="on_delete" eval="False"/>
        <field name="ttype">float</field>
    </record>
    <record id="micro_brewery_beer" model="ir.model.fields">
        <field name="name">x_beer</field>
        <field name="copied" eval="True"/>
        <field name="field_description">Beer</field>
        <field name="model">product.template</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="relation">product.template</field>
        <field name="ttype">many2one</field>
    </record>
</odoo>
