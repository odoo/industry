<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="micro_brewery.odoo_studio_product__9cf863e7-b00b-42d3-9aa1-1c2730adea08" model="ir.ui.view">
        <field name="arch" type="xml">
            <data>
                <xpath expr="//tree[1]/field[@name='name']" position="after">
                    <field name="x_studio_beer" optional="show" domain="[(&quot;categ_id&quot;, &quot;=&quot;, 10)]"/>
                </xpath>
                <xpath expr="//field[@name='list_price']" position="after">
                    <field name="base_unit_count" optional="show" string="Volume (L)"/>
                </xpath>
            </data>
        </field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="mode">extension</field>
        <field name="model">product.template</field>
        <field name="name">Odoo Studio: product.template.product.tree customization</field>
        <field name="priority">160</field>
        <field name="type">tree</field>
    </record>
    <record id="micro_brewery.odoo_studio_product__bf88caa2-f812-42ae-ae3a-8cda6e7083b0" model="ir.ui.view">
        <field name="arch" type="xml">
            <data>
                <xpath expr="//field[@name='uom_id']" position="after">
                    <field name="x_studio_beer" string="Beer" help="Link the product to the brewed product. Brewed product should be in the product category All/Brewed" domain="[(&quot;categ_id&quot;, &quot;=&quot;, 10)]"/>
                </xpath>
                <xpath expr="//form[@name='Product Template']/sheet[@name='product_form']/notebook[1]/page[@name='general_information']/group[1]/group[@name='group_general']/label[3]" position="attributes">
                    <attribute name="string">Volume (L)</attribute>
                </xpath>
            </data>
        </field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="mode">extension</field>
        <field name="model">product.template</field>
        <field name="name">Odoo Studio: product.template.product.form customization</field>
        <field name="priority">160</field>
        <field name="type">form</field>
    </record>
</odoo>
