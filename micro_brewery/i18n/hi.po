#: model_terms:ir.ui.view,arch_db:micro_brewery.welcome_article_body
msgid "Hops - Goods, inventory tracking by lot."
msgstr "हॉप्स - सामान, लॉट के ज़रिए इन्वेंट्री ट्रैकिंग।"

