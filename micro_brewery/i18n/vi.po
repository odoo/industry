#. module: micro_brewery
#: model_terms:ir.ui.view,arch_db:micro_brewery.welcome_article_body
msgid "Water - Good, no inventory tracking - Mashing"
msgstr "Nước - Hàng hóa, không theo dõi tồn kho - Thủy phân tinh bột"

#. module: micro_brewery
#: model_terms:ir.ui.view,arch_db:micro_brewery.homepage
msgid "We Brew beer with Odoo"
msgstr "Chúng tôi sản xuất bia cùng Odoo"

#. module: micro_brewery
#: model_terms:ir.ui.view,arch_db:micro_brewery.homepage
msgid ""
"Welcome to o-beer, where craft meets flavor! Our brewery is dedicated to "
"creating exceptional beers that ignite the senses and captivate the palate.\n"
"                                    With our diverse selection and "
"nationwide shipping, enjoying our handcrafted beers has never been easier.\n"
"                                    Cheers to unforgettable brews and "
"memorable moments!"
msgstr ""
"Chào mừng bạn đến với O-beer, nơi thủ công kết hợp hương vị! Nhà máy bia của "
"chúng tôi chuyên tạo ra những loại bia đặc biệt kích thích các giác quan và "
"quyến rũ khẩu vị.\n"
"Với nhiều lựa chọn đa dạng và dịch vụ giao hàng trên toàn quốc, việc thưởng "
"thức bia thủ công của chúng tôi chưa bao giờ dễ dàng đến thế.\n"
"Vì những loại bia khó quên và những khoảnh khắc đáng nhớ!"

#. module: micro_brewery
#: model_terms:web_tour.tour,rainbow_man_message:micro_brewery.knowledge_tour
msgid "Welcome! Happy exploring."
msgstr "Chào mừng bạn! Chúc bạn một chuyến khám phá bổ ích!"

