    </function>
    <function name="write" model="stock.move">
        <value model="mrp.production" eval="
            obj().search([('orderpoint_id', '=', ref('micro_brewery.stock_warehouse_orderpoint_14')), ('product_qty', '=', 1)]).move_raw_ids.ids"/>
        <value eval="{'picked': True}"/>
    </function>

    

    <!-- mark as done mo -->
    <function name="button_mark_done" model="mrp.production">
        <value model="mrp.production" eval="
            obj().search([('orderpoint_id', '=', obj().env.ref('micro_brewery.stock_warehouse_orderpoint_14').id)]).ids"/>
    </function>

    <function name="_compute_forecast_information" model="stock.move">
        <value model="mrp.production" eval="
            obj().search([('orderpoint_id', '=', ref('micro_brewery.stock_warehouse_orderpoint_14')), ('product_qty', '=', 1)]).move_raw_ids.ids"/>
