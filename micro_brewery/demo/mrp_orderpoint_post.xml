<?xml version='1.0' encoding='UTF-8'?>
<odoo>
     <!-- update quantity-->
    <record id="product_4_quant" model="stock.quant">
        <field name="product_id" ref="micro_brewery.product_product_4"/>
        <field name="inventory_quantity">2000.00</field>
        <field name="lot_id" ref="micro_brewery.stock_lot_1"></field>
        <field name="location_id" model="stock.location" eval="obj().env.ref('stock.warehouse0').lot_stock_id.id"/>
    </record>
    <record id="product_5_quant" model="stock.quant">
        <field name="product_id" ref="micro_brewery.product_product_5"/>
        <field name="inventory_quantity">1000.00</field>
        <field name="lot_id" ref="micro_brewery.stock_lot_3"></field>
        <field name="location_id" model="stock.location" eval="obj().env.ref('stock.warehouse0').lot_stock_id.id"/>
    </record>
    <record id="product_6_quant" model="stock.quant">
        <field name="product_id" ref="micro_brewery.product_product_6"/>
        <field name="lot_id" ref="micro_brewery.stock_lot_2"></field>
        <field name="inventory_quantity">1000.00</field>
        <field name="location_id" model="stock.location" eval="obj().env.ref('stock.warehouse0').lot_stock_id.id"/>
    </record>

    <function model="stock.quant" name="action_apply_inventory">
        <value model="stock.quant" eval="(
                obj().env.ref('micro_brewery.product_4_quant') +
                obj().env.ref('micro_brewery.product_5_quant') +
                obj().env.ref('micro_brewery.product_6_quant')
            ).ids"/>
    </function>

    <!-- orderpoint 00003 -->
    <function model="stock.warehouse.orderpoint" name="write">
        <value eval="[ref('micro_brewery.stock_warehouse_orderpoint_3')]"/>
        <value eval="{'qty_to_order': 150.00}"/>
    </function>

    <function model="stock.warehouse.orderpoint" name="action_replenish">
        <value eval="[
            ref('micro_brewery.stock_warehouse_orderpoint_3')]"
        />
    </function>

    <!-- orderpoint 00004 -->
