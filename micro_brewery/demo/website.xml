<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="website.default_website" model="website">
        <field name="name">microbrewery</field>
        <field name="shop_default_sort">list_price asc</field>
        <field name="shop_ppr">2</field>
        <field name="salesteam_id" ref="sales_team.salesteam_website_sales"/>
        <field name="shop_ppg">6</field>
        <field name="show_line_subtotals_tax_selection">tax_included</field>
        <field name="language_ids" eval="[(6, 0, [ref('base.lang_en')])]"/>
        <field name="default_lang_id" ref="base.lang_en"/>
        <field name="cart_recovery_mail_template_id" eval="False"/>
        <field name="logo" type="base64" file="micro_brewery/static/src/binary/website/1-logo"/>
        <field name="configurator_done" eval="True"/>
        <field name="theme_id" ref="base.module_theme_bistro"/>
        <field name="crm_default_team_id" ref="sales_team.team_sales_department"/>
    </record>
</odoo>
