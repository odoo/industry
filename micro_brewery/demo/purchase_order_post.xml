<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <function model="purchase.order" name="button_confirm">
        <value eval="[
            ref('micro_brewery.purchase_order_1'),
            ref('micro_brewery.purchase_order_2'),
            ref('micro_brewery.purchase_order_3'),
            ref('micro_brewery.purchase_order_4'),
            ref('micro_brewery.purchase_order_5'),
            ref('micro_brewery.purchase_order_6')]"
        />
    </function>

    <function name="write" model="stock.move.line">
        <value model="stock.move.line" eval="obj().search([
        ('product_id', '=', ref('micro_brewery.product_product_2')),
        ('picking_id', '=', obj().env.ref('micro_brewery.purchase_order_4').picking_ids.id)]).id"/>
        <value model="stock.lot" eval="{'lot_id': ref('micro_brewery.stock_lot_10'), 'lot_name': obj().env.ref('micro_brewery.stock_lot_10').name}"/>
    </function>
    <function name="write" model="stock.move.line">
        <value model="stock.move.line" eval="obj().search([
        ('product_id', '=', ref('micro_brewery.product_product_17')),
        ('picking_id', '=', obj().env.ref('micro_brewery.purchase_order_5').picking_ids.id)]).id"/>
        <value model="stock.lot" eval="{'lot_id': ref('micro_brewery.stock_lot_11'), 'lot_name': obj().env.ref('micro_brewery.stock_lot_11').name}"/>
    </function>
    <function name="write" model="stock.move.line">
        <value model="stock.move.line" eval="obj().search([
        ('product_id', '=', ref('micro_brewery.product_product_17')),
        ('picking_id', '=', obj().env.ref('micro_brewery.purchase_order_6').picking_ids.id)]).id"/>
        <value model="stock.lot" eval="{'lot_id': ref('micro_brewery.stock_lot_12'), 'lot_name': obj().env.ref('micro_brewery.stock_lot_12').name}"/>
    </function>

    <function name="button_validate" model="stock.picking">
        <value model="stock.picking" eval="(
                obj().env.ref('micro_brewery.purchase_order_1') +
                obj().env.ref('micro_brewery.purchase_order_2') +
                obj().env.ref('micro_brewery.purchase_order_3') +
                obj().env.ref('micro_brewery.purchase_order_4') +
                obj().env.ref('micro_brewery.purchase_order_5') +
                obj().env.ref('micro_brewery.purchase_order_6')
            ).picking_ids.ids"/>
    </function>
</odoo>