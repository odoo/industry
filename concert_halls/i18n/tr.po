msgid ""
"<strong>\n"
"                        <span class=\"h2-fs\">\n"
"                            Tips for Success<br/>\n"
"                            <br/>\n"
"                        </span>\n"
"                    </strong>"
msgstr ""
"<strong>\n"
"                        <span class=\"h2-fs\">\n"
"                            Başarı için İpuçları<br/>\n"
"                            <br/>\n"
"                       </span>\n"
"                    </strong>"

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong><span class=\"h2-fs\"/></strong><span class=\"h5-fs\">Create your "
"events in advance and use early-bird tickets to generate interest.</span>"
msgstr ""
"<strong><span class=\"h2-fs\"/></strong><span class=\"h5-"
"fs\">Etkinliklerinizi önceden oluşturun ve ilgi çekmek için erken "
"rezervasyon biletlerini kullanın.</span>"

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Accounting</strong>: Keep track of income from sales, donations, and "
"sponsors."
msgstr ""
"<strong>Muhasebe</strong>: Satışlardan, bağışlardan ve sponsor gelirlerinden "
"elde edilen geliri takip edin."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid "<strong>Apps &amp; What They Do:</strong>"
msgstr "<strong>Uygulamalar &amp; Ne Yapıyorlar?</strong>"

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Attendance</strong>: Monitor registrations and scan tickets at the "
"entrance."
msgstr ""
"<strong>Katılım</strong>: Kayıtları izleyin ve girişte biletleri tarayın."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>CRM</strong>: Track leads and partnerships with sponsors, agencies, "
"and groups."
msgstr ""
"<strong>CRM</strong>: Sponsorlar, ajanslar ve gruplarla olan potansiyel "
"müşterileri ve iş birliklerini takip edin."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid "<strong>Dashboards</strong>: Visualize performance with real-time KPIs."
msgstr ""
"<strong>Gösterge Panelleri</strong>: Gerçek zamanlı KPI'lar ile performansı "
"görselleştirin."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Email Marketing</strong>: Send newsletters and pre-sales to loyal "
"fans."
msgstr ""
"<strong>E-posta Pazarlama</strong>: Abone olan takipçilerinize haber "
"bültenleri ve ön satışlar gönderin."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Events</strong>: Create event details, schedule, tickets, pricing, "
"and reminders."
msgstr ""
"<strong>Etkinlikler</strong>: Etkinlik detaylarını, programı, biletleri, "
"fiyatları ve hatırlatmaları oluşturun."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Events</strong>: Plan, publish, and manage concerts with "
"registrations and attendance tracking."
msgstr ""
"<strong>Etkinlikler</strong>: Kayıt ve katılım takibi ile konserleri "
"planlayın, yayınlayın ve yönetin."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Get an instant overview </strong>: need to understand what needs to "
"be done? The Project Stages and Status icons give you an instant overview of "
"where things are at, and what needs to be prioritized."
msgstr ""
"<strong>Anında genel bakış elde edin </strong>: Ne yapılması gerektiğini "
"anlamanız mı gerekiyor? Proje Yönetimi Aşamaları ve Durum simgeleri, işlerin "
"hangi aşamada olduğunu ve nelere öncelik verilmesi gerektiğini anında "
"görmenizi sağlar."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid "<strong>Inventory</strong>: Stay on top of merch and bar stock levels."
msgstr "<strong>Envanter</strong>: Ürün ve bar stok seviyelerini takip edin."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid "<strong>Link Tracker</strong>: Measure performance of your campaigns."
msgstr "<strong>Link Tracker</strong>: Kampanyalarınızın performansını ölçün."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Planning</strong>: Coordinate volunteers, bar staff, and sound "
"engineers."
msgstr ""
"<strong>Planlama</strong>: Gönüllüleri, servis personellerini ve ses "
"mühendislerini koordine edin."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Point of Sale</strong>: Sell tickets and refreshments on-site with "
"real-time sync."
msgstr ""
