msgid ""
"<strong>\n"
"                        <span class=\"h2-fs\">\n"
"                            Tips for Success<br/>\n"
"                            <br/>\n"
"                        </span>\n"
"                    </strong>"
msgstr ""
"<strong>\n"
"                        <span class=\"h2-fs\">\n"
"                            نصائح لتحقيق النجاح<br/>\n"
"                            <br/>\n"
"                        </span>\n"
"                    </strong>"

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong><span class=\"h2-fs\"/></strong><span class=\"h5-fs\">Create your "
"events in advance and use early-bird tickets to generate interest.</span>"
msgstr ""
"<strong><span class=\"h2-fs\"/></strong><span class=\"h5-fs\">أنشئ فعالياتك "
"بشكل مسبق واستخدم تذاكر الحجز المبكر لجذب اهتمام الجمهور.</span>"

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Accounting</strong>: Keep track of income from sales, donations, and "
"sponsors."
msgstr ""
"<strong>المحاسبة</strong>: تتبع الإيرادات من المبيعات، والتبرعات، والجهات "
"الراعية."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid "<strong>Apps &amp; What They Do:</strong>"
msgstr "<strong>التطبيقات &amp; مميزاتها:</strong>"

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Attendance</strong>: Monitor registrations and scan tickets at the "
"entrance."
msgstr ""
"<strong>الحضور</strong>: قم بمراقبة التسجيلات ومسح التذاكر عند البوابة."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>CRM</strong>: Track leads and partnerships with sponsors, agencies, "
"and groups."
msgstr ""
"<strong>إدارة علاقات العملاء</strong>: تتبع العملاء المحتملين والشراكات مع "
"الرعاة والوكالات والمجموعات."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid "<strong>Dashboards</strong>: Visualize performance with real-time KPIs."
msgstr ""
"<strong>لوحات البيانات</strong>: تصور الأداء باستخدام مؤشرات الأداء الرئيسية "
"في الوقت الفعلي."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Email Marketing</strong>: Send newsletters and pre-sales to loyal "
"fans."
msgstr ""
"<strong>التسويق عبر البريد الإلكتروني</strong>: إرسال النشرات الإخبارية "
"وعروض ما قبل البيع إلى المعجبين المخلصين."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Events</strong>: Create event details, schedule, tickets, pricing, "
"and reminders."
msgstr ""
"<strong>الفعاليات</strong>: أنشئ تفاصيل الفعاليات مثل الأجندة والتذاكر "
"والأسعار والتذكيرات."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Events</strong>: Plan, publish, and manage concerts with "
"registrations and attendance tracking."
msgstr ""
"<strong>الفعاليات</strong>: قم بالتخطيط لفعالياتك ونشرها، وأدر الحفلاات "
"الموسيقية باستخدام خاصية تتبع التسجيلات والحضور."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Get an instant overview </strong>: need to understand what needs to "
"be done? The Project Stages and Status icons give you an instant overview of "
"where things are at, and what needs to be prioritized."
msgstr ""
"<strong>احصل على نظرة عامة فورية </strong>: هل تحتاج إلى فهم المطلوب؟ تمنحك "
