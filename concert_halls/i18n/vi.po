"                        <span class=\"h2-fs\">\n"
"                            Tips for Success<br/>\n"
"                            <br/>\n"
"                        </span>\n"
"                    </strong>"
msgstr ""
"<strong>\n"
"                        <span class=\"h2-fs\">\n"
"                            Mẹo thành công<br/>\n"
"                            <br/>\n"
"                        </span>\n"
"                    </strong>"

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong><span class=\"h2-fs\"/></strong><span class=\"h5-fs\">Create your "
"events in advance and use early-bird tickets to generate interest.</span>"
msgstr ""
"<strong><span class=\"h2-fs\"/></strong><span class=\"h5-fs\">Tạo sự kiện "
"của bạn trước và sử dụng vé sớm để thu hút sự quan tâm.</span>"

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Accounting</strong>: Keep track of income from sales, donations, and "
"sponsors."
msgstr ""
"<strong>Kế toán</strong>: Theo dõi thu nhập từ bán hàng, quyên góp và tài "
"trợ."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid "<strong>Apps &amp; What They Do:</strong>"
msgstr "<strong>Ứng dụng &amp; Chức năng của chúng:</strong>"

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Attendance</strong>: Monitor registrations and scan tickets at the "
"entrance."
msgstr ""
"<strong>Quản lý tham dự</strong>: Theo dõi đăng ký và quét vé tại cửa ra vào."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>CRM</strong>: Track leads and partnerships with sponsors, agencies, "
"and groups."
msgstr ""
"<strong>CRM</strong>: Theo dõi các cơ hội kinh doanh và quan hệ đối tác với "
"các nhà tài trợ, đại lý và tổ chức."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid "<strong>Dashboards</strong>: Visualize performance with real-time KPIs."
msgstr ""
"<strong>Báo cáo tổng quan</strong>: Hiển thị hiệu suất với các chỉ số KPI "
"theo thời gian thực."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Email Marketing</strong>: Send newsletters and pre-sales to loyal "
"fans."
msgstr ""
"<strong>Tiếp thị qua email</strong>: Gửi bản tin và thông tin trước khi bán "
"hàng cho các fan trung thành."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Events</strong>: Create event details, schedule, tickets, pricing, "
"and reminders."
msgstr ""
"<strong>Sự kiện</strong>: Tạo chi tiết sự kiện, lịch trình, vé, giá vé và "
"thông báo nhắc nhở."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Events</strong>: Plan, publish, and manage concerts with "
"registrations and attendance tracking."
msgstr ""
"<strong>Sự kiện</strong>: Lập kế hoạch, tổ chức và quản lý các buổi hòa nhạc "
"với tính năng đăng ký và theo dõi sự tham dự."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Get an instant overview </strong>: need to understand what needs to "
"be done? The Project Stages and Status icons give you an instant overview of "
"where things are at, and what needs to be prioritized."
msgstr ""
"<strong>Nắm bắt tổng quan ngay lập tức</strong>: cần biết việc gì phải làm? "
"Các Giai đoạn Dự án và biểu tượng Trạng thái sẽ cho bạn cái nhìn tức thì về "
"tiến độ công việc và những gì cần được ưu tiên."

#. module: concert_halls
