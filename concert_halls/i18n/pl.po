#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>\n"
"                        <span class=\"h2-fs\">\n"
"                            Tips for Success<br/>\n"
"                            <br/>\n"
"                        </span>\n"
"                    </strong>"
msgstr ""
"<strong>\n"
"                        <span class=\"h2-fs\">\n"
"                            Wskazówki jak osiągnąć sukces<br/>\n"
"                            <br/>\n"
"                        </span>\n"
"                    </strong>"

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong><span class=\"h2-fs\"/></strong><span class=\"h5-fs\">Create your "
"events in advance and use early-bird tickets to generate interest.</span>"
msgstr ""
"<strong><span class=\"h2-fs\"/></strong><span class=\"h5-fs\">Twórz "
"wydarzenia z wyprzedzeniem i oferuj bilety w przedsprzedaży, aby wzbudzić "
"zainteresowanie.</span>"

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Accounting</strong>: Keep track of income from sales, donations, and "
"sponsors."
msgstr ""
"<strong>Księgowość</strong>: Śledź dochody ze sprzedaży, darowizn i "
"sponsorów."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid "<strong>Apps &amp; What They Do:</strong>"
msgstr "<strong>Aplikacje &amp; do czego służą:</strong>"

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Attendance</strong>: Monitor registrations and scan tickets at the "
"entrance."
msgstr ""
"<strong>Frekwencja</strong>: Monitorowanie rejestracji i skanowanie biletów "
"przy wejściu."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>CRM</strong>: Track leads and partnerships with sponsors, agencies, "
"and groups."
msgstr ""
"<strong>CRM</strong>: Śledź potencjalnych klientów i partnerstwa ze "
"sponsorami, agencjami i grupami."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid "<strong>Dashboards</strong>: Visualize performance with real-time KPIs."
msgstr ""
"<strong>Konsole</strong>: Wizualizacja wyników za pomocą wskaźników KPI w "
"czasie rzeczywistym."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Email Marketing</strong>: Send newsletters and pre-sales to loyal "
"fans."
msgstr ""
"<strong>E-mail marketing</strong>: wysyłaj biuletyny i informacje "
"przedsprzedażowe do wiernych fanów."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Events</strong>: Create event details, schedule, tickets, pricing, "
"and reminders."
msgstr ""
"<strong>Wydarzenia</strong>: Twórz szczegóły wydarzeń, harmonogramy, bilety, "
"ceny i przypomnienia."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Events</strong>: Plan, publish, and manage concerts with "
"registrations and attendance tracking."
msgstr ""
"<strong>Wydarzenia</strong>: Planuj, publikuj i zarządzaj koncertami wraz z "
"rejestracją uczestników i śledzeniem frekwencji."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Get an instant overview </strong>: need to understand what needs to "
"be done? The Project Stages and Status icons give you an instant overview of "
"where things are at, and what needs to be prioritized."
msgstr ""
"<strong>Uzyskaj natychmiastowy przegląd </strong>: chcesz wiedzieć, co "
"należy zrobić? Ikony etapów Projektu i statusu zapewniają natychmiastowy "
"przegląd aktualnego stanu rzeczy i zadań, które należy potraktować "
"priorytetowo."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid "<strong>Inventory</strong>: Stay on top of merch and bar stock levels."
msgstr ""
"<strong>Magazyn:</strong> Bądź na bieżąco z poziomem zapasów towarów i "
"produktów barowych."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid "<strong>Link Tracker</strong>: Measure performance of your campaigns."
msgstr "<strong>Link Tracker</strong>: Mierz skuteczność swoich kampanii."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
