#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>\n"
"                        <span class=\"h2-fs\">\n"
"                            Tips for Success<br/>\n"
"                            <br/>\n"
"                        </span>\n"
"                    </strong>"
msgstr ""
"<strong>\n"
"                        <span class=\"h2-fs\">\n"
"                            Consejos para triunfar<br/>\n"
"                            <br/>\n"
"                        </span>\n"
"                    </strong>"

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong><span class=\"h2-fs\"/></strong><span class=\"h5-fs\">Create your "
"events in advance and use early-bird tickets to generate interest.</span>"
msgstr ""
"<strong><span class=\"h2-fs\"/></strong><span class=\"h5-fs\">Crea tus "
"eventos con anticipación y usa los boletos de venta anticipada para generar "
"interés.</span>"

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Accounting</strong>: Keep track of income from sales, donations, and "
"sponsors."
msgstr ""
"<strong>Contabilidad</strong>: Lleva seguimiento de los ingresos "
"provenientes de ventas, donaciones y patrocinadores."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid "<strong>Apps &amp; What They Do:</strong>"
msgstr "<strong>Aplicaciones y sus funciones:</strong>"

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Attendance</strong>: Monitor registrations and scan tickets at the "
"entrance."
msgstr ""
"<strong>Asistencias</strong>: Monitorea los registros y escanea los boletos "
"durante la entrada."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>CRM</strong>: Track leads and partnerships with sponsors, agencies, "
"and groups."
msgstr ""
"<strong>CRM</strong>: Lleva seguimiento de los contactos y las alianzas con "
"patrocinadores, agencias y grupos."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid "<strong>Dashboards</strong>: Visualize performance with real-time KPIs."
msgstr ""
"<strong>Tableros</strong>: Conoce tu rendimiento con métricas clave en "
"tiempo real."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Email Marketing</strong>: Send newsletters and pre-sales to loyal "
"fans."
msgstr ""
"<strong>Marketing por correo</strong>: Envía boletines informativos y "
"ofertas de venta anticipada a tus fans más leales."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Events</strong>: Create event details, schedule, tickets, pricing, "
"and reminders."
msgstr ""
"<strong>Eventos</strong>: Crea eventos y configura tu agenda, los boletos, "
"los precios y los recordatorios."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Events</strong>: Plan, publish, and manage concerts with "
"registrations and attendance tracking."
msgstr ""
"<strong>Eventos</strong>: Planifica, publica y gestiona conciertos, "
"encárgate de llevar seguimiento de los registros y de la asistencia."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Get an instant overview </strong>: need to understand what needs to "
"be done? The Project Stages and Status icons give you an instant overview of "
"where things are at, and what needs to be prioritized."
msgstr ""
"<strong>Información al instante</strong>: ¿Quieres saber qué actividad "
"sigue? Las etapas de proyecto y los iconos de estado te muestran en qué "
"punto estás y qué necesita atención de inmediato."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid "<strong>Inventory</strong>: Stay on top of merch and bar stock levels."
msgstr ""
"<strong>Inventario</strong>: Supervisa las existencias de mercancía y del "
"bar en todo momento."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid "<strong>Link Tracker</strong>: Measure performance of your campaigns."
msgstr ""
"<strong>Rastreador de enlaces</strong>: Mide el rendimiento de tus campañas."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Planning</strong>: Coordinate volunteers, bar staff, and sound "
"engineers."
msgstr ""
"<strong>Planeación</strong>: Coordina a tus voluntarios, personal de bar e "
"ingenieros de sonido."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Point of Sale</strong>: Sell tickets and refreshments on-site with "
"real-time sync."
msgstr ""
"<strong>Punto de venta</strong>: Vende boletos y aperitivos de forma "
"presencial con sincronización en tiempo real."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Project and Task Templates: </strong>Recurring tasks &amp; Projects "
"can be managed easily through the templates feature."
msgstr ""
"<strong>Plantillas de proyectos y tareas</strong>: Facilita la gestión de "
"proyectos y tareas recurrentes con la función de plantillas."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
