"<strong>\n"
"                        <span class=\"h2-fs\">\n"
"                            Tipps zum Erfolg<br/>\n"
"                            <br/>\n"
"                        </span>\n"
"                    </strong>"

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong><span class=\"h2-fs\"/></strong><span class=\"h5-fs\">Create your "
"events in advance and use early-bird tickets to generate interest.</span>"
msgstr ""
"<strong><span class=\"h2-fs\"/></strong><span class=\"h5-fs\">Erstellen Sie "
"Ihre Veranstaltungen im Voraus und nutzen Sie Frühbuchertickets, um "
"Interesse zu wecken.</span>"

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Accounting</strong>: Keep track of income from sales, donations, and "
"sponsors."
msgstr ""
"<strong>Buchhaltung</strong>: Führen Sie Buch über die Einnahmen aus "
"Verkäufen, Spenden und Sponsoren."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid "<strong>Apps &amp; What They Do:</strong>"
msgstr "<strong>Apps &amp; was sie können:</strong>"

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Attendance</strong>: Monitor registrations and scan tickets at the "
"entrance."
msgstr ""
"<strong>Anwesenheiten</strong>: Überwachen Sie die Anmeldungen und scannen "
"Sie die Tickets am Eingang."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>CRM</strong>: Track leads and partnerships with sponsors, agencies, "
"and groups."
msgstr ""
"<strong>CRM</strong>: Verfolgen Sie Leads und Partnerschaften mit Sponsoren, "
"Agenturen und Gruppen."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid "<strong>Dashboards</strong>: Visualize performance with real-time KPIs."
msgstr ""
"<strong>Dashboards</strong>: Visualisieren Sie die Leistung mit Echtzeit-KPI."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Email Marketing</strong>: Send newsletters and pre-sales to loyal "
"fans."
msgstr ""
"<strong>E-Mail-Marketing</strong>: Versenden Sie Newsletter und Vorab-"
"Informationen an treue Fans."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Events</strong>: Create event details, schedule, tickets, pricing, "
"and reminders."
msgstr ""
"<strong>Veranstaltungen</strong>: Erstellen Sie Veranstaltungsdetails, "
"Zeitpläne, Tickets, Preise und Erinnerungen."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Events</strong>: Plan, publish, and manage concerts with "
"registrations and attendance tracking."
msgstr ""
"<strong>Veranstaltungen</strong>: Planen, veröffentlichen und verwalten Sie "
"Konzerte mit Anmeldungen und Anwesenheitserfassung."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Get an instant overview </strong>: need to understand what needs to "
"be done? The Project Stages and Status icons give you an instant overview of "
"where things are at, and what needs to be prioritized."
msgstr ""
"<strong>Verschaffen Sie sich einen schnellen Überblick</strong>: Möchten Sie "
"wissen, was zu tun ist? Die Symbole für Projektphasen und Status bieten "
"Ihnen einen schnellen Überblick darüber, wo Sie gerade stehen und was "
"Priorität hat."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid "<strong>Inventory</strong>: Stay on top of merch and bar stock levels."
msgstr ""
"<strong>Lager</strong>: Behalten Sie den Überblick über die Lagerbestände "
"von Merchandise-Artikeln und Bar-Produkten."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid "<strong>Link Tracker</strong>: Measure performance of your campaigns."
msgstr ""
"<strong>Link-Tracker</strong>: Messen Sie die Leistung Ihrer Kampagnen."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Planning</strong>: Coordinate volunteers, bar staff, and sound "
"engineers."
msgstr ""
"<strong>Planung</strong>: Koordinieren Sie die Freiwilligen, das Barpersonal "
"und die Tontechniker."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Point of Sale</strong>: Sell tickets and refreshments on-site with "
"real-time sync."
msgstr ""
"<strong>Kassensystem</strong>: Verkaufen Sie Tickets und "
"Erfrischungsgetränke vor Ort mit Echtzeit-Synchronisierung."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Project and Task Templates: </strong>Recurring tasks &amp; Projects "
