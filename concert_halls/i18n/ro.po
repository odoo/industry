#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong><span class=\"h2-fs\"/></strong><span class=\"h5-fs\">Create your "
"events in advance and use early-bird tickets to generate interest.</span>"
msgstr ""
"<strong><span class=\"h2-fs\"/></strong><span class=\"h5-fs\">Creați "
"evenimentele cu mult timp înainte și folosiți bilete early-bird pentru a "
"genera interes.</span>"

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Accounting</strong>: Keep track of income from sales, donations, and "
"sponsors."
msgstr ""
"<strong>Contabilitate</strong>: Urmăriți veniturile din vânzări, donații și "
"sponsori."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid "<strong>Apps &amp; What They Do:</strong>"
msgstr "<strong>Aplicații &amp; Ce fac:</strong>"

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Attendance</strong>: Monitor registrations and scan tickets at the "
"entrance."
msgstr ""
"<strong>Prezență</strong>: Monitorizați înregistrările și scanați biletele "
"la intrare."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>CRM</strong>: Track leads and partnerships with sponsors, agencies, "
"and groups."
msgstr ""
"<strong>CRM</strong>: Urmăriți lead-urile și parteneriatele cu sponsorii, "
"agențiile și grupurile."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid "<strong>Dashboards</strong>: Visualize performance with real-time KPIs."
msgstr ""
"<strong>Tablouri de bord</strong>: Vizualizați performanța cu KPI-uri în "
"timp real."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Email Marketing</strong>: Send newsletters and pre-sales to loyal "
"fans."
msgstr ""
"<strong>Marketing prin Email</strong>: Trimiteți newsletter-uri și pre-"
"vânzări fanilor fideli."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Events</strong>: Create event details, schedule, tickets, pricing, "
"and reminders."
msgstr ""
"<strong>Evenimente</strong>: Creați detaliile evenimentului, programul, "
"biletele, prețurile și mementourile."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Events</strong>: Plan, publish, and manage concerts with "
"registrations and attendance tracking."
msgstr ""
"<strong>Evenimente</strong>: Planificați, publicați și gestionați concertele "
"cu înregistrări și urmărirea prezenței."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Get an instant overview </strong>: need to understand what needs to "
"be done? The Project Stages and Status icons give you an instant overview of "
"where things are at, and what needs to be prioritized."
msgstr ""
"<strong>Obțineți o privire de ansamblu instantanee </strong>: aveți nevoie "
"să înțelegeți ce trebuie făcut? Etapele Proiectului și pictogramele de "
"Status vă oferă o privire instantanee asupra situației și a ceea ce trebuie "
"prioritizat."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid "<strong>Inventory</strong>: Stay on top of merch and bar stock levels."
msgstr ""
"<strong>Inventar</strong>: Rămâneți la curent cu nivelurile de stoc pentru "
"merchandise și bar."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid "<strong>Link Tracker</strong>: Measure performance of your campaigns."
msgstr ""
"<strong>Urmăritor de Link-uri</strong>: Măsurați performanța campaniilor dvs."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Planning</strong>: Coordinate volunteers, bar staff, and sound "
"engineers."
msgstr ""
"<strong>Planificare</strong>: Coordonați voluntarii, personalul de la bar și "
"inginerii de sunet."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Point of Sale</strong>: Sell tickets and refreshments on-site with "
"real-time sync."
msgstr ""
"<strong>Point of Sale</strong>: Vindeți bilete și răcoritoare la fața "
"locului cu sincronizare în timp real."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
