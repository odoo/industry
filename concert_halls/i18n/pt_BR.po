#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>\n"
"                        <span class=\"h2-fs\">\n"
"                            Tips for Success<br/>\n"
"                            <br/>\n"
"                        </span>\n"
"                    </strong>"
msgstr ""
"<strong>\n"
"                        <span class=\"h2-fs\">\n"
"                            Dicas para o sucesso<br/>\n"
"                            <br/>\n"
"                        </span>\n"
"                    </strong>"

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong><span class=\"h2-fs\"/></strong><span class=\"h5-fs\">Create your "
"events in advance and use early-bird tickets to generate interest.</span>"
msgstr ""
"<strong><span class=\"h2-fs\"/></strong><span class=\"h5-fs\">Crie eventos "
"com antecedência e venda ingressos antecipados.</span>"

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Accounting</strong>: Keep track of income from sales, donations, and "
"sponsors."
msgstr ""
"<strong>Financeiro</strong>: Acompanhe as receitas provenientes de vendas, "
"doações e patrocinadores."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid "<strong>Apps &amp; What They Do:</strong>"
msgstr "<strong>Aplicativos e para que servem:</strong>"

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Attendance</strong>: Monitor registrations and scan tickets at the "
"entrance."
msgstr ""
"<strong>Controle de Presenças</strong>: Monitore os registros e verifique os "
"ingressos na entrada."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>CRM</strong>: Track leads and partnerships with sponsors, agencies, "
"and groups."
msgstr ""
"<strong>CRM</strong>: Acompanhe leads e parcerias com patrocinadores, "
"agências e grupos."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid "<strong>Dashboards</strong>: Visualize performance with real-time KPIs."
msgstr ""
"<strong>Paineis</strong>: Visualize o desempenho com KPIs em tempo real."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Email Marketing</strong>: Send newsletters and pre-sales to loyal "
"fans."
msgstr ""
"<strong>Marketing por e-mail</strong>: Envie newsletters e pré-vendas para "
"fãs fiéis."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Events</strong>: Create event details, schedule, tickets, pricing, "
"and reminders."
msgstr ""
"<strong>Eventos</strong>: Crie detalhes do evento, programação, ingressos, "
"preços e lembretes."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Events</strong>: Plan, publish, and manage concerts with "
"registrations and attendance tracking."
msgstr ""
"<strong>Eventos</strong>: Planeje, publique e gerencie concertos com "
"registros e acompanhamento de frequência."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Get an instant overview </strong>: need to understand what needs to "
"be done? The Project Stages and Status icons give you an instant overview of "
"where things are at, and what needs to be prioritized."
msgstr ""
"<strong>Tenha uma visão geral instantânea </strong>: Quer entender o que "
"precisa ser feito? Os ícones de estágio e status do projeto fornecem uma "
"visão geral instantânea como as coisas estão e do que precisa ser priorizado."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid "<strong>Inventory</strong>: Stay on top of merch and bar stock levels."
msgstr ""
"<strong>Inventário</strong>: Fique por dentro dos níveis de estoque de "
"mercadorias e bebidas."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid "<strong>Link Tracker</strong>: Measure performance of your campaigns."
msgstr ""
"<strong>Rastreio de Links</strong>: Avalie o desempenho das suas campanhas."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Planning</strong>: Coordinate volunteers, bar staff, and sound "
"engineers."
msgstr ""
"<strong>Planejamento</strong>: Coordene voluntários, equipe do bar e "
"engenheiros de som."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Point of Sale</strong>: Sell tickets and refreshments on-site with "
"real-time sync."
msgstr ""
"<strong>Ponto de Venda</strong>: Venda ingressos e bebidas no local com "
"sincronização em tempo real."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Project and Task Templates: </strong>Recurring tasks &amp; Projects "
"can be managed easily through the templates feature."
msgstr ""
"<strong>Modelos de projetos e tarefas:</strong> As tarefas recorrentes e os "
"projetos podem ser gerenciados facilmente por meio do recurso de modelos."

