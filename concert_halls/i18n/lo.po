msgid ""
"<strong>Accounting</strong>: Keep track of income from sales, donations, and"
" sponsors."
msgstr ""
"<strong>ການບັນຊີ</strong>: ຕິດຕາມລາຍຮັບຈາກການຂາຍ, ການບໍລິຈາກ, ແລະ ຜູ້ອຸປະຖຳ."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid "<strong>Apps &amp; What They Do:</strong>"
msgstr "<strong>ແອັບຯ ແລະ ໜ້າທີ່ຂອງພວກມັນ:</strong>"

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Attendance</strong>: Monitor registrations and scan tickets at the "
"entrance."
msgstr ""
"<strong>ການເຂົ້າຮ່ວມ</strong>: ກວດສອບການລົງທະບຽນ ແລະ ສະແກນປີ້ຢູ່ທາງເຂົ້າ."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>CRM</strong>: Track leads and partnerships with sponsors, agencies, "
"and groups."
msgstr ""
"<strong>CRM</strong>: ຕິດຕາມຜູ້ທີ່ອາດເປັນລູກຄ້າ ແລະ ການຮ່ວມມືກັບຜູ້ອຸປະຖຳ, ເອເຈນຊີ, ແລະ ກຸ່ມຕ່າ"
"ງໆ."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Dashboards</strong>: Visualize performance with real-time KPIs."
msgstr "<strong>ແດຊບອດ</strong>: ສະແດງຜົນການດຳເນີນງານດ້ວຍ KPI ແບບເວລາຈິງ."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Email Marketing</strong>: Send newsletters and pre-sales to loyal "
"fans."
msgstr ""
"<strong>ການຕະຫຼາດຜ່ານອີເມວ</strong>: ສົ່ງຂ່າວສານ ແລະ ການຂາຍລ່ວງໜ້າໃຫ້ກັບແຟນເພງທີ່ພັກດີ."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Events</strong>: Create event details, schedule, tickets, pricing, "
"and reminders."
msgstr ""
"<strong>ເຫດການ</strong>: ສ້າງລາຍລະອຽດເຫດການ, ກຳນົດເວລາ, ປີ້, ລາຄາ, ແລະ ການແຈ້ງເຕືອ"
"ນ."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Events</strong>: Plan, publish, and manage concerts with "
"registrations and attendance tracking."
msgstr ""
"<strong>ເຫດການ</strong>: ວາງແຜນ, ເຜີຍແຜ່, ແລະ ຈັດການຄອນເສີດ ພ້ອມທັງຕິດຕາມການລົງທະບຽນ "
"ແລະ ການເຂົ້າຮ່ວມ."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Get an instant overview </strong>: need to understand what needs to "
"be done? The Project Stages and Status icons give you an instant overview of"
" where things are at, and what needs to be prioritized."
msgstr ""
"<strong>ເບິ່ງພາບລວມໄດ້ທັນທີ </strong>: ຕ້ອງການເຂົ້າໃຈສິ່ງທີ່ຕ້ອງເຮັດແມ່ນບໍ່? ຂັ້ນຕອນຂອງໂຄງການ ແລ"
"ະ ໄອຄອນສະຖານະ ຈະຊ່ວຍໃຫ້ທ່ານເຫັນພາບລວມຂອງວຽກງານໄດ້ທັນທີ ແລະ ຮູ້ວ່າສິ່ງໃດທີ່ຕ້ອງໃຫ້ຄວາມສຳຄັນກ່ອນ."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid "<strong>Inventory</strong>: Stay on top of merch and bar stock levels."
msgstr ""
"<strong>ຄັງສິນຄ້າ</strong>: ຕິດຕາມລະດັບສິນຄ້າທີ່ລະນຶກ ແລະ ເຄື່ອງດື່ມຢູ່ບາ."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid "<strong>Link Tracker</strong>: Measure performance of your campaigns."
msgstr "<strong>ການຕິດຕາມລິ້ງ</strong>: ວັດແທກປະສິດທິພາບຂອງແຄມເປນຂອງທ່ານ."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Planning</strong>: Coordinate volunteers, bar staff, and sound "
"engineers."
msgstr ""
"<strong>ການວາງແຜນ</strong>: ປະສານງານກັບອາສາສະໝັກ, ພະນັກງານບາ, ແລະ ຊ່າງເຕັກນິກສຽງ."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Point of Sale</strong>: Sell tickets and refreshments on-site with "
"real-time sync."
msgstr ""
"<strong>ຈຸດຂາຍ (POS)</strong>: ຂາຍປີ້ ແລະ ເຄື່ອງດື່ມຢູ່ໜ້າງານ ພ້ອມກັບການຊິງຄ໌ຂໍ້ມູນແບບເວລາຈິງ."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Project and Task Templates: </strong>Recurring tasks &amp; Projects "
"can be managed easily through the templates feature."
msgstr ""
"<strong>ເທັມເຜລັດໂຄງການ ແລະ ວຽກງານ: </strong>ວຽກງານ ແລະ ໂຄງການທີ່ເກີດຂຶ້ນຊ້ຳໆ ສາມາດຈັດ"
"ການໄດ້ຢ່າງງ່າຍດາຍຜ່ານຟີເຈີເທັມເຜລັດ."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Projects</strong>: Coordinate all behind-the-scenes tasks for smooth"
" show execution."
msgstr ""
"<strong>ໂຄງການ</strong>: ປະສານງານທຸກວຽກງານເບື້ອງຫຼັງເພື່ອໃຫ້ການສະແດງດຳເນີນໄປຢ່າງຮາບຮື່ນ."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Projects</strong>: Plan and assign tasks for transportation, "
"accommodation, tech setup, and more."
msgstr ""
"<strong>ໂຄງການ</strong>: ວາງແຜນ ແລະ ມອບໝາຍວຽກງານສຳລັບການຂົນສົ່ງ, ທີ່ພັກ, ການຕິດຕັ້ງເຕັກນິ"
"ກ, ແລະ ອື່ນໆ."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Purchase</strong>: Reorder supplies, drinks, and gear ahead of "
"events."
msgstr ""
"<strong>ການຈັດຊື້</strong>: ສັ່ງຊື້ສະບຽງ, ເຄື່ອງດື່ມ, ແລະ ອຸປະກອນຕ່າງໆ ໄວ້ລ່ວງໜ້າກ່ອນມື້ງານ."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Sell drinks &amp; Snacks: </strong>Sell drinks &amp; snacks before "
"the concerts"
msgstr ""
"<strong>ຂາຍເຄື່ອງດື່ມ ແລະ ອາຫານວ່າງ: </strong>ຂາຍເຄື່ອງດື່ມ ແລະ ອາຫານວ່າງ ກ່ອນການສະແດງຄອ"
"ນເສີດ"

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Sell entrances </strong>: See available tickets for each of the "
"concerts"
msgstr "<strong>ຂາຍປີ້ເຂົ້າງານ </strong>: ເບິ່ງປີ້ທີ່ຍັງຫວ່າງສຳລັບແຕ່ລະຄອນເສີດ"

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Sign</strong>: Send and sign artist contracts or venue agreements "
"digitally."
msgstr ""
"<strong>ການເຊັນບັດ (Sign)</strong>: ສົ່ງ ແລະ ເຊັນສັນຍາສິນລະປິນ ຫຼື ຂໍ້ຕົກລົງສະຖານທີ່ແບບດີຈີຕອນ."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Social Marketing</strong>: Boost event visibility through scheduled "
"social media campaigns."
msgstr ""
"<strong>ການຕະຫຼາດໂຊຊຽວ</strong>: ເພີ່ມການເບິ່ງເຫັນເຫດການຜ່ານແຄມເປນໂຊຊຽວມີເດຍທີ່ກຳນົດເວລາ"
"ໄວ້."

#. module: concert_halls
#: model_terms:ir.ui.view,arch_db:concert_halls.welcome_article_body
msgid ""
"<strong>Social Marketing</strong>: Plan and post across Instagram, Facebook,"
" and more."
msgstr ""
"<strong>ການຕະຫຼາດໂຊຊຽວ</strong>: ວາງແຜນ ແລະ ໂພສລົງໃນ Instagram, Facebook, ແລະ ອື່"
"ນໆ."

