<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="calendar_event_1" model="calendar.event">
        <field name="name">Floor 1 with Jatin</field>
        <field name="appointment_type_id" ref="industry_restaurant.appointment_type_1" />
        <field name="start" model="appointment.type" eval="
            pytz.timezone(obj().env.ref('industry_restaurant.appointment_type_1').appointment_tz).localize(
                DateTime.today().date() + relativedelta(weekday=2, hour=9)
            ).astimezone(pytz.UTC).replace(tzinfo=None)
        "/>
        <field name="stop" model="appointment.type" eval="
            pytz.timezone(obj().env.ref('industry_restaurant.appointment_type_1').appointment_tz).localize(
                DateTime.today().date() + relativedelta(weekday=2, hour=10)
            ).astimezone(pytz.UTC).replace(tzinfo=None)
        "/>
        <field name="alarm_ids" eval="[(6, 0, [ref('calendar.alarm_notif_1'), ref('calendar.alarm_mail_1'), ref('appointment_sms.calendar_alarm_data_1h_sms')])]"/>
        <field name="user_id" ref="base.user_admin"/>
        <field name="partner_ids" eval="[(6, 0, [ref('industry_restaurant.res_partner_8')])]"/>
        <field name="categ_ids" eval="[(6, 0, [ref('appointment.calendar_event_type_data_online_appointment')])]" />
        <field name="description">&lt;ul&gt;&lt;li&gt;Mobile: 98765432&lt;/li&gt;&lt;li&gt;Email: jatin@test.com&lt;/li&gt;&lt;/ul&gt;</field>
    </record>
