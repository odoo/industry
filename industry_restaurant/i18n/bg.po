#. module: industry_restaurant
#: model_terms:ir.ui.view,arch_db:industry_restaurant.homepage
msgid ""
"<br/>Let the symphony of tastes and textures transport you to distant lands, "
"where every bite is a discovery and every meal a celebration of the senses. "
"Indulge in the artistry of the chef as each plate is presented with care and "
"passion, inviting you to experience a world of culinary delights right at "
"your table."
msgstr ""

#. module: industry_restaurant
#: model_terms:ir.ui.view,arch_db:industry_restaurant.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>Appointments App</b>: </font>Allow "
"customers to book tables online 24/7, reducing phone calls and optimizing "
"your seating capacity."
msgstr ""

#. module: industry_restaurant
#: model_terms:ir.ui.view,arch_db:industry_restaurant.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>Inventory App</b>: </font>Track "
"ingredients and recipes in real-time, using \"Bill of Materials\" (BoM) to "
"deduct stock automatically as dishes are sold."
msgstr ""

#. module: industry_restaurant
#: model_terms:ir.ui.view,arch_db:industry_restaurant.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>Kitchen Display / Printers</b>:</font> "
"Send orders instantly to the kitchen or bar with specific printing "
"instructions for different stations (e.g., \"Cold Station\", \"Grill\")."
msgstr ""

#. module: industry_restaurant
#: model_terms:ir.ui.view,arch_db:industry_restaurant.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>Planning App</b>:</font> Organize shifts "
"for chefs, servers, and bartenders, ensuring you are adequately staffed for "
"peak service hours."
msgstr ""

#. module: industry_restaurant
#: model_terms:ir.ui.view,arch_db:industry_restaurant.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>Purchase App</b>:</font> Automate the "
"reordering of fresh produce and dry goods based on minimum stock rules and "
"supplier lead times."
msgstr ""

#. module: industry_restaurant
#: model_terms:ir.ui.view,arch_db:industry_restaurant.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>Restaurant App (POS)</b>:</font> Manage "
"your floor plan visually, handling table seating, order taking, and bill "
"splitting directly from the interface."
msgstr ""

#. module: industry_restaurant
#: model_terms:ir.ui.view,arch_db:industry_restaurant.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>Website App</b>:</font> Showcase your "
"menu, share chef bios, and promote special events with a mouth-watering "
"online presence."
msgstr ""

