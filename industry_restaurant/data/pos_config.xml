<?xml version='1.0' encoding='UTF-8'?>
<odoo noupdate="1">
    <record id="pos_config_main_seven_star_restaurant" model="pos.config">
        <field name="name">Seven Star Restuarant - Sans Francisco</field>
        <field name="ship_later" eval="True"/>
        <field name="iface_printbill" eval="True"/>
        <field name="iface_tipproduct" eval="True"/>
        <field name="use_pricelist" eval="True"/>
        <field name="iface_customer_facing_display_local" eval="True"/>
        <field name="iface_splitbill" eval="True"/>
        <field name="receipt_footer">Thank You! Visit Again.</field>
        <field name="gift_card_settings">scan_use</field>
        <field name="cash_rounding" eval="True"/>
        <field name="rounding_method" ref="industry_restaurant.account_cash_rounding_1"/>
        <field name="start_category" eval="True"/>
        <field name="iface_start_categ_id" ref="industry_restaurant.pos_category_2"/>
        <field name="floor_ids" eval="[(6, 0, [ref('industry_restaurant.restaurant_floor_1'), ref('industry_restaurant.restaurant_floor_2')])]"/>
    </record>
</odoo>
