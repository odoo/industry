<?xml version='1.0' encoding='UTF-8'?>
<odoo noupdate="1">
    <record id="appointment_type_1" model="appointment.type">
        <field name="name">Floor 1 -Table</field>
        <field name="is_published" eval="True"/>
        <field name="appointment_tz">Europe/Brussels</field>
        <field name="schedule_based_on">resources</field>
        <field name="min_cancellation_hours">0.25</field>
        <field name="appointment_duration_formatted">1 hour</field>
        <field name="resource_ids" eval="[(6, 0, [ref('appointment_resource_1'), ref('appointment_resource_2')])]"/>
    </record>
    <record id="appointment_type_2" model="appointment.type">
        <field name="name">Floor 2</field>
        <field name="appointment_tz">Europe/Brussels</field>
        <field name="schedule_based_on">resources</field>
        <field name="min_cancellation_hours">0.25</field>
        <field name="appointment_duration_formatted">1 hour</field>
    </record>
</odoo>
