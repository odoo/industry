msgid ""
"<strong><font class=\"text-black\">\n"
"                  <span style=\"font-weight: normal\"><b>CRM App</b>: Track client interactions, preferences\n"
"                  , and follow-ups all in one central hub to nurture long-term relationships.\n"
"                  </span></font><font class=\"text-o-color-1\"/>\n"
"              </strong>"
msgstr ""
"<strong><font class=\"text-black\">\n"
"                 <span style=\"font-weight: normal\"><b>CRM-sovellus</b>: "
"Seuraa asiakaskontakteja, mieltymyksiä\n"
"                  ja seurantatoimia yhdestä keskitetystä paikasta "
"pitkäaikaisten asiakassuhteiden vaalimiseksi.\n"
"                 </span></font><font class=\"text-o-color-1\"/>\n"
"              </strong>"

#. module: beauty_parlor
#: model_terms:ir.ui.view,arch_db:beauty_parlor.welcome_article_body
msgid ""
"<strong><span class=\"display-4-fs\">Odoo for Beauty Parlor</span></strong>"
msgstr ""
"<strong><span class=\"display-4-fs\">Odoo kauneussalongille</span></strong>"

#. module: beauty_parlor
#: model_terms:ir.ui.view,arch_db:beauty_parlor.welcome_article_body
msgid ""
"<strong>Point of Sale App</strong>: Let clients pay at the front desk and purchase retail products\n"
"              immediately after their treatments."
msgstr ""
"<strong>Kassajärjestelmä-sovellus</strong>: Anna asiakkaiden maksaa "
"vastaanotossa sekä ostaa tuotteita\n"
"              heti hoitojensa jälkeen."

#. module: beauty_parlor
#: model_terms:ir.ui.view,arch_db:beauty_parlor.welcome_article_body
msgid ""
"<strong>Sales App</strong>: Sell treatment packages, gift cards, and retail products with clear quotations\n"
"              and pricing."
msgstr ""
"<strong>Myynti-sovellus</strong>: Myy hoitopaketteja, lahjakortteja ja "
"oheistuotteita selkeillä tarjouksilla\n"
"              ja hinnoittelulla."

#. module: beauty_parlor
#: model_terms:ir.ui.view,arch_db:beauty_parlor.homepage
