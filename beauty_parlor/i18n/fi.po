#. module: beauty_parlor
#: model_terms:ir.ui.view,arch_db:beauty_parlor.welcome_article_body
msgid "Would you like to discuss your Odoo setup with us or go even further?"
msgstr "Haluatko keskustella Odoo-asetuksistasi tai jatkaa vieläkin pidemmälle?"

#. module: beauty_parlor
#: model_terms:ir.ui.view,arch_db:beauty_parlor.welcome_article_body
