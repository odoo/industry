"<strong><font class=\"text-black\">\n"
"                 <span style=\"font-weight: normal\"><b> CRM-App</b>: "
"Verfolgen Sie Kundeninteraktionen, Präferenzen\n"
"                  und Nachfassaktionen an einem zentralen Ort, um "
"langfristige Beziehungen zu pflegen.\n"
"                 </span></font><font class=\"text-o-color-1\"/>\n"
"              </strong>"

#. module: beauty_parlor
#: model_terms:ir.ui.view,arch_db:beauty_parlor.welcome_article_body
