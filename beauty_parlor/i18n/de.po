"<strong><span class=\"display-4-fs\">Odoo for Beauty Parlor</span></strong>"
msgstr ""
"<strong><span class=\"display-4-fs\">Odoo für Schönheitssalons</span></"
"strong>"

#. module: beauty_parlor
#: model_terms:ir.ui.view,arch_db:beauty_parlor.welcome_article_body
msgid ""
"<strong>Point of Sale App</strong>: Let clients pay at the front desk and purchase retail products\n"
"              immediately after their treatments."
msgstr ""
"<strong>Kassensystem-App-</strong>: Ermöglichen Sie es Kunden, am Empfang zu "
"bezahlen und Einzelhandelsprodukte\n"
"              unmittelbar nach ihren Behandlungen zu erwerben."

#. module: beauty_parlor
#: model_terms:ir.ui.view,arch_db:beauty_parlor.welcome_article_body
msgid ""
"<strong>Sales App</strong>: Sell treatment packages, gift cards, and retail products with clear quotations\n"
"              and pricing."
msgstr ""
"<strong>Verkaufsapp</strong>: Verkaufen Sie Behandlungspakete, "
"Geschenkkarten und Einzelhandelsprodukte mit klaren Angeboten\n"
"              und Preisen."

