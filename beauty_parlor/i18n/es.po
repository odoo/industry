"<strong><font class=\"text-black\">\n"
"                  <span style=\"font-weight: normal\"><b>Aplicación CRM</b>: "
"haz seguimiento de las interacciones y de las preferencias\n"
"                  de tus clientes desde un solo lugar para fomentar "
"relaciones a largo plazo.\n"
"                  </span></font><font class=\"text-o-color-1\"/>\n"
"              </strong>"

