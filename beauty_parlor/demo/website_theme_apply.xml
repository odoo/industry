<?xml version='1.0' encoding='UTF-8'?>
<odoo>
  <function name="button_choose_theme"
            model="ir.module.module"
            eval="[ref('base.module_theme_artists', raise_if_not_found=False)]"
            context="{'website_id': ref('base.default_website')}"
  />

  <function model="ir.ui.view" name="write">
    <value model="ir.ui.view" eval="obj().env['website'].with_context(website_id=obj().env.ref('base.default_website').id).viewref('website.homepage').id"/>
    <value model="ir.ui.view" eval="{'arch': obj().env.ref('beauty_parlor.homepage').arch}"/>
  </function>

  <function model="ir.ui.view" name="write">
    <value model="ir.ui.view" eval="obj().env['website'].with_context(website_id=ref('base.default_website')).viewref('website.footer_custom').id"/>
    <value eval="{'active': False}"/>
  </function>

  <function model="ir.ui.view" name="write">
    <value model="ir.ui.view" eval="obj().with_context(active_test=False).search([('key', '=', 'website.template_footer_centered')]).ids"/>
    <value eval="{'active': True}"/>
  </function>

  <function model="ir.ui.view" name="write">
    <value model="ir.ui.view" eval="obj().search([('key', '=', 'website.template_header_default')]).ids"/>
    <value eval="{'active': False}"/>
  </function>

  <function model="ir.ui.view" name="write">
    <value model="ir.ui.view" eval="obj().with_context(active_test=False).search([('key', '=', 'website.template_header_vertical')], limit=1).id"/>
    <value eval="{'active': True}"/>
  </function>

  <function model="website.assets" name="make_scss_customization" context="{'website_id': ref('base.default_website')}">
    <value eval="'/website/static/src/scss/options/user_values.scss'" />
    <value eval="{
          'menu-gradient': 'NULL',
          'menu-secondary-gradient': 'null',
          'footer-gradient': 'null',
          'copyright-gradient': 'null',
          'o-cc1-bg-gradient': 'null',
          'o-cc2-bg-gradient': 'null',
          'o-cc3-bg-gradient': 'null',
          'o-cc4-bg-gradient': 'null',
          'o-cc5-bg-gradient': 'null',
          'font': 'null',
          'headings-font': 'null',
          'navbar-font': 'null',
          'buttons-font': 'null',
          'color-palettes-number': 'null',
          'color-palettes-name': 'default-24',
          'btn-ripple': 'null',
          'header-template': 'null',
          'footer-template': 'null',
          'footer-scrolltop': 'null',
      }"/>
  </function>
  <function model="website.assets" name="make_scss_customization" context="{'website_id': ref('base.default_website')}">
    <value eval="'/website/static/src/scss/options/colors/user_theme_color_palette.scss'"/>
    <value eval="{
          'success': 'null',
          'info': 'null',
          'warning': 'null',
          'danger': 'null',
      }"/>
  </function>

  <data noupdate="1">
    <function model="website.menu" name="unlink">
      <value model="website.menu" eval="obj().search([('website_id', '=', ref('base.default_website')), ('url', '=', '/appointment')]).ids"/>
    </function>
  </data>

  <function model="ir.ui.view" name="write">
    <value model="ir.ui.view" eval="obj().env.ref('beauty_parlor.ir_ui_view_3092').id"/>
    <value model="ir.ui.view" eval="{'arch': obj().env.ref('beauty_parlor.ir_ui_view_3092').arch.replace(
      '*express_facial_care_appointment_type*', str(obj().env.ref('beauty_parlor.appointment_type_1').website_url)).replace(
      '*relaxing_body_massage_appointment_type*', str(obj().env.ref('beauty_parlor.appointment_type_3').website_url)).replace(
      '*manicure_nail_care_appointment_type*', str(obj().env.ref('beauty_parlor.appointment_type_4').website_url)).replace(
      '*waxing_legs_arms_appointment_type*', str(obj().env.ref('beauty_parlor.appointment_type_5').website_url))
    }"/>
  </function>
</odoo>
