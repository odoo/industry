<?xml version='1.0' encoding='UTF-8'?>
<odoo noupdate="1">
    <record id="booking_suggestion" model="mail.template">
        <field name="name">Book your next appointment</field>
        <field name="model_id" ref="crm.model_crm_lead"/>
        <field name="subject">Looking forward to meeting you</field>
        <field name="description">Follow-up email inviting customers to book their next appointment</field>
        <field name="body_html"><![CDATA[
            <p>
                Hello, <t t-out="object.partner_id.name or 'Customer'"/>,
            </p>
            <p>
                Thank you for your presence. May I invite you to schedule your next appointment if needed?
            </p>
            <p>
                Looking forward to meeting you.
            </p>
            <br/>
            <p>
                <a class="btn btn-secondary" href="/our-services">Schedule an Appointment</a>
            </p>
        ]]>        </field>
    </record>
</odoo>
