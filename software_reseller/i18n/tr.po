#. module: software_reseller
#: model:mail.template,body_html:software_reseller.mail_template_48
msgid ""
"<div>Hello,</div>\n"
"<div>\n"
"    <br/>\n"
"</div>\n"
"<div>Your <t t-out=\"object.x_software or ''\">Odoo</t> license is available."
"</div>\n"
"<ul style=\"border-radius:0px;border-style:none;padding:0 0 0 "
"32px;margin:0px 0 16px 0;box-sizing:border-box;border-left-width:0px;border-"
"bottom-width:0px;border-right-width:0px;border-top-width:0px;list-style-"
"type:disc;\">\n"
"    <t t-if=\"object.task_properties.get('environment')\">\n"
"        <li>Environment: <t t-"
"out=\"object.task_properties.get('environment') or ''\">Production</t></li>\n"
"    </t>\n"
"    <t t-if=\"object.task_properties.get('hosted_on')\">\n"
"        <li>Hosted on: <t t-out=\"object.task_properties.get('hosted_on') or "
"''\">Odoo online</t></li>\n"
"    </t>\n"
"    <t t-if=\"object.task_properties.get('number_of_users')\">\n"
"        <li>Users: <t t-out=\"object.task_properties.get('number_of_users') "
"or ''\">2025</t></li>\n"
"    </t>\n"
"    <t t-if=\"object.task_properties.get('version')\">\n"
"        <li>Version: <t t-out=\"object.task_properties.get('version') or "
"''\">18.3</t></li>\n"
"    </t>\n"
"    <t t-if=\"object.task_properties.get('license_key')\">\n"
"        <p>License key: <t t-out=\"object.task_properties.get('license_key') "
"or ''\">LICXYZ00001</t></p>\n"
"    </t>\n"
"</ul>\n"
"<t t-if=\"object.date_deadline\">\n"
"    The license expires on the <t t-out=\"format_date(object.date_deadline)"
"\">12/3/2026</t>.\n"
"</t>\n"
"<div>Feel free to reach out in case you face difficulties.</div>\n"
"<div><br/></div>\n"
"<div><t t-out=\"user.signature or ''\">Mitchell Admin</t></div>"
msgstr ""
"<div>Merhaba,</div>\n"
"<div>\n"
"   <br/>\n"
"</div> \n"
"<div> <t t-out=\"object.x_software or ''\"> Odoo</t> lisansınız hazırdır.</"
"div>\n"
"<ul style=\"border-radius:0px;border-style:none;padding:0 0 0 "
"32px;margin:0px 0 16px 0;box-sizing:border-box;border-left-width:0px;border-"
"bottom-width:0px;border-right-width:0px;border-top-width:0px;list-style-"
"type:disc;\">\n"
"   <t t-if=\"object.task_properties.get('environment')\">\n"
"        <li> Ortam: <t t-out=\"object.task_properties.get('environment') or "
"''\">Üretim</t></li>\n"
"   </t>\n"
"    <t t-if=\"object.task_properties.get('hosted_on')\"> \n"
"       <li> Barındırma: <t t-out=\"object.task_properties.get('hosted_on') "
"or ''\">Odoo online</t></li>\n"
"   </t>\n"
"    <t t-if=\"object.task_properties.get('number_of_users')\"> \n"
"       <li> Kullanıcılar: <t t-out=\"object.task_properties.get"
"('number_of_users') or ''\">2025</t></li>\n"
"   </t>\n"
"    <t t-if=\"object.task_properties.get('version')\"> \n"
"       <li> Sürüm: <t t-out=\"object.task_properties.get('version') or ''\">"
"18.3</t></li>\n"
"   </t>\n"
"    <t t-if=\"object.task_properties.get('license_key')\"> \n"
"       <p> Lisans anahtarı: <t t-out=\"object.task_properties.get"
"('license_key') or ''\">LICXYZ00001</t></p>\n"
"   </t>\n"
"</ul> \n"
"<t t-if=\"object.date_deadline\">\n"
"    Lisansın geçerlilik süresi <t t-out=\"format_date(object.date_deadline)"
"\">3 Aralık 2026 tarihinde sona erer</t>.\n"
"</t>\n"
"<div>Herhangi bir sorunla karşılaşırsanız lütfen çekinmeden bize ulaşın.</"
"div>\n"
"<div><br/></div> \n"
"<div><t t-out=\"user.signature or ''\">Mitchell Admin</t></div>"

