#. module: software_reseller
#: model_terms:ir.ui.view,arch_db:software_reseller.welcome_article_body
msgid ""
"<span style=\"font-size: 14px;\">\n"
"                This setup if for IT companies reselling software licenses, "
"and consulting services. The typical sale is a 1 year Oracle Database "
"license that is purchased to Oracle, and resold to client at a margin, with "
"extra services to setup\n"
"                the database.\n"
"            </span>"
msgstr ""
"<span style=\"font-size: 14px;\">Cette configuration est destinée aux "
"entreprises IT qui revendent des licences logicielles et des services de "
"conseil. La vente typique concerne une licence Oracle Database d’un an, "
"achetée auprès d’Oracle puis revendue au client avec une marge, accompagnée "
"de services supplémentaires pour configurer la base de données.</span>"

