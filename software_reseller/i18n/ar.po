#, fuzzy
msgid ""
"<span style=\"font-size: 14px;\">\n"
"                This setup if for IT companies reselling software licenses, "
"and consulting services. The typical sale is a 1 year Oracle Database "
"license that is purchased to Oracle, and resold to client at a margin, with "
"extra services to setup\n"
"                the database.\n"
"            </span>"
msgstr ""
"<span style=\"font-size: 14px;\">\n"
"                هذا الإعداد مخصص لشركات تكنولوجيا المعلومات التي تعيد بيع "
"تراخيص البرمجيات والخدمات الاستشارية.  إن عملية البيع المعتادة هي عبارة عن "
"ترخيص قاعدة بيانات Oracle لمدة عام واحد يتم شراؤه من Oracle، وإعادة بيعه "
"للعميل بهامش ربح، مع خدمات إضافية لـ\n"
"                إعداد قاعدة البيانات.\n"
"            </span>"

