#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.homepage
msgid "<a href=\"#\" class=\"btn o_translate_inline btn-primary\">Discover more</a>"
msgstr ""
"<a href=\"#\" class=\"btn o_translate_inline btn-primary\">Ontdek meer</a>"

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">CRM:</font></b> Manage your customer "
"relationships and pipelines."
msgstr ""
"<b><font class=\"text-o-color-1\">CRM:</font></b> Beheer je klantrelaties en "
"pijplijnen."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Project:</font></b> Build your project "
"foundation for prototyping and reuse it for all subsequent stages."
msgstr ""
"<b><font class=\"text-o-color-1\">Project:</font></b> Bouw de basis van je "
"project voor prototyping en gebruik het voor alle daaropvolgende stappen."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Purchase:</font></b> Track supplier orders"
" and manage your entire procurement history."
msgstr ""
"<b><font class=\"text-o-color-1\">Inkoop:</font></b> Volg leveranciersorders "
"en beheer je hele inkoopgeschiedenis."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Audit Trail:</b> Keep every modification visible to ensure full "
"transparency throughout the product's development cycle."
msgstr ""
"<b>Auditspoor:</b> Elke wijziging is zichbaar om volledige transparantie te "
"garanderen gedurende de gehele ontwikkelingscyclus van het product."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Automated MTO (Make to Order):</b> Enable the <b>MTO route</b> on semi-"
"finished products. This automatically triggers a linked secondary MO the "
"moment the main manufacturing order is confirmed."
msgstr ""
"<b>Geautomatiseerde MTO (Make to Order):</b> Schakel de <b>MTO-route</b> in "
"voor halffabricaten. Dit activeert automatisch een gekoppelde secundaire PO "
"op het moment dat de hoofdproductieorder wordt bevestigd."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>BOM Integration:</b> If your project requires multiple Bills of Materials"
" (BOMs), create them directly using the dedicated BOM button."
msgstr ""
"<b>Stuklijst-integratie:</b> Als je project meerdere stuklijsten vereist, "
"kun je deze rechtstreeks aanmaken met de speciale Stuklijst-knop."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid "<b>Batch Sizes:</b> Optimize production runs."
msgstr "<b>Batchgroottes:</b> Optimaliseer productiecycli."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>By-Products:</b> Manage secondary outputs during the manufacturing "
"process."
msgstr "<b>Bijproducten:</b> Beheer secundaire output van het productieproces."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>By-products:</b> Manage leftovers from production and track them as "
"valuable inventory."
msgstr ""
"<b>Bijproducten:</b> Beheer restanten van de productie en houd ze bij als "
"waardevolle voorraad."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Centralized Hub:</b> Use the top menu to navigate effortlessly between "
"all elements linked to your project."
msgstr ""
"<b>Gecentraliseerde hub:</b> Gebruik het hoofdmenu om eenvoudig te navigeren "
"tussen alle elementen die aan je Project zijn gekoppeld."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Centralized Updates:</b> Manage all changes and approvals within a "
"single, dedicated interface."
msgstr ""
"<b>Gecentraliseerde updates:</b> Beheer alle wijzigingen en goedkeuringen "
"binnen één speciale interface."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Client Collaboration:</b> Share specific folders with your clients, "
"providing them with a secure, central location to upload and access vital "
"project files."
msgstr ""
"<b>Samenwerking met klanten:</b> Deel specifieke mappen met je klanten en "
"bied hen zo een veilige, centrale locatie om essentiële projectbestanden te "
"uploaden en te openen."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Definition:</b> All billable, non-tangible offerings provided to the "
"client."
msgstr ""
"<b>Definitie:</b> Alle factureerbare, niet-tastbare diensten die aan de "
"klant worden geleverd."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Definition:</b> All components and materials sourced directly from "
"external vendors."
msgstr ""
"<b>Definitie:</b> Alle componenten en materialen afkomstig van externe "
"leveranciers."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Definition:</b> In-house manufactured items used as sub-assemblies for "
"larger builds rather than being sold individually."
msgstr ""
"<b>Definitie:</b> Intern geproduceerde artikelen die als onderdelen worden "
"gebruikt in grotere constructies en niet afzonderlijk worden verkocht."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Definition:</b> Sale-ready goods ranging from standardized items (fixed "
"BOMs) to fully customized solutions."
msgstr ""
"<b>Definitie:</b> Verkoopklare producten, variërend van gestandaardiseerde "
"artikelen (met vaste stuklijsten) tot volledig op maat gemaakte oplossingen."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Detailed Work Orders:</b> For every operation, you can define precise "
"timings, step-by-step instructions, and mandatory <b>Quality Checks</b>."
msgstr ""
"<b>Gedetailleerde werkorders:</b> Voor elke bewerking kun je precieze "
"tijden, stapsgewijze instructies en verplichte <b>kwaliteitscontroles</b> "
"instellen."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Direct Manufacturing:</b> Launch Manufacturing Orders (MOs) from the "
"Manufacturing tab. Once confirmed, these will flow into your standard "
"manufacturing workflow. (see next section)"
msgstr ""
"<b>Directe productie:</b> Start productieorders (PO's) vanuit het tabblad "
"Productie. Na bevestiging worden ze in je standaardproductieworkflow "
"opgenomen. (zie volgende sectie)"

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Easy Billing:</b> Generate a <b>Sales Order</b> directly from the repair "
"order to invoice your client for parts and labor."
msgstr ""
"<b>Eenvoudige facturatie:</b> Genereer een <b>Verkooporder</b> rechtstreeks "
"vanuit de Reparatieorder om je klant te factureren voor onderdelen en arbeid."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Either create a project :</b> From the CRM, create a new project by "
"clicking the <b>⚙️ icon</b> and selecting a template. This project will "
"allow you to manage all the pre-sales steps, such as:"
msgstr ""
"<b>Je kunt een project aanmaken:</b> Maak vanuit het CRM een nieuw project "
"aan door op het <b>⚙️-icoon</b> te klikken en een sjabloon te selecteren. "
"Met dit project kun je alle pre-sales-stappen beheren, zoals:"

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Either you create a Quotation from the opportunity and wait for a "
"confirmation.</b>"
msgstr ""
"<b>Je kunt een offerte aanmaken vanuit de verkoopkans en wachten op een "
"bevestiging.</b>"

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Engineering Review:</b> This proposal automatically generates an "
"<b>ECO</b> in the PLM app. Engineers can then review, test, and approve the "
"change before it is officially applied to the Bill of Materials."
msgstr ""
"<b>Technische beoordeling:</b> Dit voorstel genereert automatisch een <b>ECO "
"(Engineering change order)</b> in de PLM-app. Ingenieurs kunnen de wijziging "
"vervolgens beoordelen, testen en goedkeuren voordat deze officieel wordt "
"toegepast op de stuklijst."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Financial Forecasting &amp; Actuals:</b> Compare estimated costs against "
"real costs directly from the project overview to maintain control over your "
"budget."
msgstr ""
"<b>Financiële voorspellingen &amp; Werkelijke cijfers:</b> Vergelijk "
"geschatte kosten met werkelijke kosten rechtstreeks vanuit het "
"projectoverzicht om controle te houden over je budget."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Flexible Timesheets:</b> Log time on individual tasks to monitor project "
"profitability or accurately bill clients for hours worked."
msgstr ""
"<b>Flexibele urenstaten:</b> Registreer de tijd die aan individuele taken "
"wordt besteed om de winstgevendheid van projecten te controleren of klanten "
"nauwkeurig te factureren voor gewerkte uren."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>For example:</b> A client requests a specialized scanner capable of "
"multilingual package recognition. Within a single project, you can "
"centralize product specifications, vendor quotes, and BOM designs. You can "
"then generate an initial quotation for a <b>Proof of Concept (PoC)</b> "
"directly from the project. Once confirmed, you can continue iterating within"
" the same project—creating updated quotations and Manufacturing Orders by "
"building on previous data and new insights."
msgstr ""
"<b>Bijvoorbeeld:</b> Een klant vraagt om een gespecialiseerde scanner die "
"meertalige pakketherkenning ondersteunt. Binnen één enkel project kun je "
"productspecificaties, offertes van leveranciers en stuklijstontwerpen "
"centraliseren. Vervolgens kun je rechtstreeks vanuit het project een eerste "
"offerte genereren voor een <b>Proof of Concept (PoC)</b>. Na bevestiging kun "
"je binnen hetzelfde project voortwerken: bijgewerkte offertes en "
"productieorders maken door voort te bouwen op eerdere gegevens en nieuwe "
"inzichten."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Invoice Oversight:</b> Track all related outgoing and incoming invoices "
"directly within the project interface."
msgstr ""
"<b>Factuurbeheer:</b> Volg alle gerelateerde uitgaande en inkomende facturen "
"rechtstreeks binnen de projectinterface."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid "<b>Key Benefits:</b>"
msgstr "<b>Belangrijkste voordelen:</b>"

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>MTO (Make-to-Order) Route:</b> Use this to automatically trigger a "
"Manufacturing Order whenever a Sales Order is confirmed"
msgstr ""
"<b>MTO-route (Make-to-Order):</b> Gebruik dit om automatisch een "
"productieorder te activeren wanneer een Verkooporder wordt bevestigd"

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Make to Stock (Reordering Rules):</b> Set a <b>minimum stock level</b> "
"for your sub-assemblies. The system will automatically trigger a new MO once"
" your inventory drops below this threshold, ensuring you always have enough "
"stock on hand for future production."
msgstr ""
"<b>Make to Stock (Aanvulregels):</b> Stel een <b>minimumvoorraadniveau</b> "
"in voor je subassemblages. Het systeem activeert automatisch een nieuwe PO "
"zodra je voorraad onder deze drempelwaarde zakt, zodat er altijd voldoende "
"voorraad aanwezig is voor toekomstige productie."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Manual Creation:</b> Generate secondary MOs for sub-assemblies manually "
"as the need arises."
msgstr ""
"<b>Handmatig aanmaken:</b> Genereer handmatig secundaire PO's voor "
"subassemblages wanneer dat nodig is."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Miscellaneous Notes &amp; Integration:</b> Use the HTML field (note) in "
"the <b>Miscellaneous tab</b> for advanced instructions. You can embed links "
"to internal knowledge articles, 3D plans, or external software. Operators "
"can access these links directly from the <b>Shopfloor App</b> during "
"production."
msgstr ""
"<b>Diverse notities &amp; Integratie:</b> Gebruik het HTML-veld (notitie) op "
"het <b>tabblad 'Diversen'</b> voor geavanceerde instructies. Je kunt links "
"naar interne kennisartikelen, 3D-plannen of externe software toevoegen. "
"Operatoren hebben tijdens de productie rechtstreeks toegang tot deze links "
"vanuit de <b>Werkvloer-app</b>."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Monitor Progress:</b> Visit the <b>Overview Tab</b> to see a side-by-side"
" comparison of your sales, expected costs, and real costs (derived from "
"invoices and completed Manufacturing Orders)."
msgstr ""
"<b>Houd de voortgang bij:</b> Klik op de knop <b>Overzicht</b> om een "
"vergelijking te zien van je verkoop, verwachte kosten en werkelijke kosten "
"(opgehaald uit facturen en voltooide productieorders)."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Note:</b> If you validate a transfer for a partial quantity, the system "
"will automatically create a <b>backorder</b> for the rest of the items."
msgstr ""
"<b>Opmerking:</b> Als je een verplaatsing voor een gedeeltelijke hoeveelheid "
"valideert, maakt het systeem automatisch een <b>backorder</b> aan voor de "
"rest van de artikelen."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Organized File Sharing:</b> Create custom folders (such as \"Internal\" "
"or \"Client-Facing\") via the Documents button."
msgstr ""
"<b>Georganiseerd bestanden delen:</b> Maak aangepaste mappen (zoals "
"\"Intern\" of \"Voor klanten\") via de knop 'Documenten'."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid "<b>Pro Tip: Real-Time Margin Analysis</b>"
msgstr "<b>Pro-tip: realtime margeanalyse</b>"

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Pro-Tip:</b> You can print and use barcode commands with a scanner to "
"automate and streamline your workflow."
msgstr ""
"<b>Pro-tip:</b> Je kunt barcodecommando's afdrukken en gebruiken met een "
"scanner om je workflow te automatiseren en te stroomlijnen."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Proactive Quality Checks:</b> These are predefined checks (created in the"
" Quality App) that trigger automatically at specific stages of production."
msgstr ""
"<b>Proactieve kwaliteitscontroles:</b> Dit zijn vooraf gedefinieerde "
"controles (aangemaakt in de Kwaliteit-app) die automatisch worden "
"geactiveerd in specifieke productiefases."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Propose BOM Updates:</b> If a worker discovers a more efficient method or"
" a necessary adjustment, they can propose adding a new step or component."
msgstr ""
"<b>Stuklijst-aanpassingen voorstellen:</b> Als een medewerker een "
"efficiëntere methode of een noodzakelijke aanpassing ontdekt, kan hij een "
"nieuwe stap of een nieuw onderdeel voorstellen."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Protocol:</b> Develop detailed <b>Bills of Materials (BOMs)</b> that "
"explicitly link components to their respective production stages and "
"operations."
msgstr ""
"<b>Protocol:</b> Stel gedetailleerde <b>Stuklijsten</b> op waarin onderdelen "
"expliciet gekoppeld zijn de juiste productiefases en productiebewerkingen."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Protocol:</b> For new clients or projects, create a <b>unique product "
"entry</b>. Map these to a <b>Master BOM Catalog</b> to pull in reusable "
"templates; this allows for distinct database tracking while leveraging "
"standardized production logic."
msgstr ""

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Protocol:</b> Maintain up-to-date <b>vendor assignments</b> and "
"<b>purchase pricing</b> to ensure procurement accuracy."
msgstr ""

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Reactive Quality Alerts:</b> If a worker identifies an issue on the fly, "
"they can trigger a <b>Quality Alert</b>. This creates a dedicated task in "
"the Quality App for the quality team to investigate."
msgstr ""
"<b>Reactieve kwaliteitswaarschuwingen:</b> Als een medewerker ter plekke een "
"probleem constateert, kan hij een <b>kwaliteitswaarschuwing</b> activeren. "
"Hierdoor wordt een speciale taak aangemaakt in de Kwaliteit-app zodat het "
"kwaliteitsteam het probleem kan onderzoeken."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Sales &amp; Purchase Orders:</b> Generate unlimited Sales Orders to "
"account for scope changes, and manage all project-specific Purchase Orders "
"in one place."
msgstr ""
"<b>Verkoop- &amp; inkooporders:</b> Genereer onbeperkt verkooporders bij "
"wijzigingen en beheer alle projectspecifieke inkooporders op één plek."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Scope:</b> Includes design, consulting, installation, and long-term "
"maintenance."
msgstr ""
"<b>Inhoud:</b> Omvat ontwerp, adviesverlening, installatie en onderhoud op "
"lange termijn."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Seamless Integration:</b> Create a repair order directly from a "
"<b>Helpdesk task</b> to streamline your after-sales service."
msgstr ""
"<b>Naadloze integratie:</b> Maak rechtstreeks vanuit een <b>Helpdesk-taak</"
"b> een Reparatieorder aan om je aftersales-service te stroomlijnen."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Set Forecasts:</b> Manually input your expected margin on each Sales "
"Order line."
msgstr ""
"<b>Stel voorspellingen in:</b> Voer handmatig je verwachte marge in op elke "
"verkooporderregel."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Targeted Delegation:</b> Create and assign tasks directly to the "
"appropriate team members to ensure accountability."
msgstr ""
"<b>Gerichte taakverdeling:</b> Maak taken aan en wijs ze direct toe aan de "
"juiste teamleden zodat iedereen zijn verantwoordelijkheden kent."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Use the batch size setting:</b> If you always produce in batches of a "
"specific quantity, use the <b>Batch Size</b> setting in the "
"<b>Miscellaneous</b> tab."
msgstr ""
"<b>Gebruik de instelling voor batchgrootte:</b> Als je altijd in batches van "
"een bepaalde hoeveelheid produceert, gebruik dan de instelling <b>"
"Batchgrootte</b> in het tabblad <b>Diversen</b>."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Version Control:</b> Maintain a clear history of every BOM iteration."
msgstr ""
"<b>Versiebeheer:</b> Houd een duidelijke geschiedenis bij van elke stuklijst-"
"versie."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Work Assignments:</b> Directly assign tasks to the appropriate personnel "
"to streamline the production flow."
msgstr ""
"<b>Werk toewijzen:</b> Wijs taken rechtstreeks toe aan het juiste personeel "
"om de productie te stroomlijnen."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Work Center Capacity:</b> Balance workloads and prevent bottlenecks based"
" on resource availability."
msgstr ""
"<b>Capaciteit van de werkplek:</b> Houd de werkbelasting in evenwicht en "
"voorkom knelpunten op basis van de beschikbaarheid van resources."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Work Center Capacity:</b> Optimize your production schedule by exploring "
"the capacity of your work centers."
msgstr ""
"<b>Capaciteit van de werkplek:</b> Optimaliseer je productieschema door de "
"capaciteit van je werkplekken te verkennen."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.homepage
msgid ""
"<br/>From concept design to final production, we partner with you throughout"
" the entire process, ensuring that every detail of your project is "
"meticulously crafted, providing you with the precision and quality needed to"
" excel in your industry."
msgstr ""
"<br/>Van conceptontwerp tot eindproductie werken wij gedurende het hele "
"proces met je samen en zorgen we ervoor dat elk detail zorgvuldig wordt "
"uitgewerkt, zodat je de precisie en kwaliteit krijgt die nodig is om uit te "
"blinken in je sector."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.homepage
msgid ""
"<br/>Our team offers specialized knowledge and strategic guidance to help "
"your business excel in a competitive market. We develop customized solutions"
" that promote sustainable growth and enduring success."
msgstr ""
"<br/>Ons team biedt gespecialiseerde kennis en strategische begeleiding om "
"je bedrijf te laten uitblinken in een concurrerende markt. Wij "
"personaliseren oplossingen om duurzame groei en blijvend succes te "
"bevorderen."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>Inventory:</b> </font>Maintain stock "
"accuracy and ensure you never dip below minimum levels."
msgstr ""
"<font class=\"text-o-color-1\"><b>Voorraad:</b> </font>Behoud een nauwkeurig "
"voorraadoverzicht en zorg ervoor dat je nooit onder minimale voorraadniveaus "
"zakt."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
