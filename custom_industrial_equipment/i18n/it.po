#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.homepage
msgid ""
"<a href=\"#\" class=\"btn o_translate_inline btn-primary\">Discover more</a>"
msgstr ""
"<a href=\"#\" class=\"btn o_translate_inline btn-primary\">Scopri di più</a>"

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">CRM:</font></b> Manage your customer "
"relationships and pipelines."
msgstr ""
"<b><font class=\"text-o-color-1\">CRM:</font></b> gestisci le relazioni con "
"i clienti e le pipeline."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Project:</font></b> Build your project "
"foundation for prototyping and reuse it for all subsequent stages."
msgstr ""
"<b><font class=\"text-o-color-1\">Progetti:</font></b> crea le basi del tuo "
"progetto per la prototipazione e riutilizzale in tutte le fasi successive."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">Purchase:</font></b> Track supplier orders "
"and manage your entire procurement history."
msgstr ""
"<b><font class=\"text-o-color-1\">Acquisti:</font></b> monitora gli ordini "
"dei fornitori e gestisci l'intera cronologia di approvvigionamento."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Audit Trail:</b> Keep every modification visible to ensure full "
"transparency throughout the product's development cycle."
msgstr ""
"<b>Traccia di audit:</b> rendi ogni modifica visibile per garantire totale "
"trasparenza durante il ciclo di sviluppo del prodotto."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Automated MTO (Make to Order):</b> Enable the <b>MTO route</b> on semi-"
"finished products. This automatically triggers a linked secondary MO the "
"moment the main manufacturing order is confirmed."
msgstr ""
"<b>MTO automatizzato (Make to Order): </b> abilita il <b>percorso MTO</b> "
"per i prodotti semifiniti. Al momento della conferma dell'ordine di "
"produzione principale, viene attivato un ordine di produzione secondario "
"collegato."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>BOM Integration:</b> If your project requires multiple Bills of Materials "
"(BOMs), create them directly using the dedicated BOM button."
msgstr ""
"<b>Integrazione DiBa:</b> se il tuo progetto richiede più distinte base "
"(DiBa), creale direttamente utilizzando il pulsante dedicato."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid "<b>Batch Sizes:</b> Optimize production runs."
msgstr "<b>Dimensioni lotto:</b> ottimizza i cicli di produzione."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>By-Products:</b> Manage secondary outputs during the manufacturing "
"process."
msgstr ""
"<b>Sottoprodotti:</b> gestisci i risultati secondari durante il processo di "
"produzione."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>By-products:</b> Manage leftovers from production and track them as "
"valuable inventory."
msgstr ""
"<b>Sottoprodotti:</b> gestisci gli scarti di produzione e tracciali come "
"parte delle scorte."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Centralized Hub:</b> Use the top menu to navigate effortlessly between "
"all elements linked to your project."
msgstr ""
"<b>Hub centralizzato:</b> utilizza il menu in alto per navigare facilmente "
"tra tutti gli elementi collegati al tuo progetto."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Centralized Updates:</b> Manage all changes and approvals within a "
"single, dedicated interface."
msgstr ""
"<b>Aggiornamenti centralizzati:</b> gestisci tutte le modifiche e le "
"approvazioni da un'unica interfaccia dedicata."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Client Collaboration:</b> Share specific folders with your clients, "
"providing them with a secure, central location to upload and access vital "
"project files."
msgstr ""
"<b>Collaborazione con i clienti:</b> condividi cartelle specifiche con i "
"clienti fornendo loro un posto sicuro e centralizzato dove caricare file "
"importanti per i progetti e accedervi in qualsiasi momento."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Definition:</b> All billable, non-tangible offerings provided to the "
"client."
msgstr ""
"<b>Definizione:</b> tutti i servizi non materiali fatturabili forniti al "
"cliente."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Definition:</b> All components and materials sourced directly from "
"external vendors."
msgstr ""
"<b>Definizione:</b> tutti i componenti e i materiali acquistati direttamente "
"da fornitori esterni."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Definition:</b> In-house manufactured items used as sub-assemblies for "
"larger builds rather than being sold individually."
msgstr ""
"<b>Definizione:</b> articoli prodotti in-house utilizzati come sottounità "
"per costruzioni più grandi invece di essere venduti singolarmente."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Definition:</b> Sale-ready goods ranging from standardized items (fixed "
"BOMs) to fully customized solutions."
msgstr ""
"<b>Definizione:</b> merce pronta per la vendita, da articoli standard (DiBa "
"fisse) a soluzioni completamente personalizzate."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Detailed Work Orders:</b> For every operation, you can define precise "
"timings, step-by-step instructions, and mandatory <b>Quality Checks</b>."
msgstr ""
"<b>Ordini di lavoro dettagliati:</b> per ogni operazione, è possibile "
"definire orari precisi, istruzioni passo dopo passo e <b>controlli qualità</"
"b> obbligatori."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Direct Manufacturing:</b> Launch Manufacturing Orders (MOs) from the "
"Manufacturing tab. Once confirmed, these will flow into your standard "
"manufacturing workflow. (see next section)"
msgstr ""
"<b>Produzione diretta:</b> lancia ordini di produzione dalla scheda "
"Produzione. Una volta confermati, andranno a finire nel flusso di lavoro di "
"produzione standard. (Consulta la sezione successiva)"

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Easy Billing:</b> Generate a <b>Sales Order</b> directly from the repair "
"order to invoice your client for parts and labor."
msgstr ""
"<b>Fatturazione semplice:</b> genera un <b>ordine di vendita</b> "
"direttamente dall'ordine di riparazione per fatturare al cliente componenti "
"e manodopera."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Either create a project :</b> From the CRM, create a new project by "
"clicking the <b>⚙️ icon</b> and selecting a template. This project will allow "
"you to manage all the pre-sales steps, such as:"
msgstr ""
"<b>O creare un progetto: </b>dal CRM, crea un nuovo progetto facendo clic "
"<b>sull'icona ⚙️</b> e seleziona un modello. Il progetto ti permetterà di "
"gestire tutte le fasi prevendita, come ad esempio:"

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Either you create a Quotation from the opportunity and wait for a "
"confirmation.</b>"
msgstr ""
"<b>È possibile creare un preventivo dall'opportunità e attendere una "
"conferma.</b>"

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Engineering Review:</b> This proposal automatically generates an <b>ECO</"
"b> in the PLM app. Engineers can then review, test, and approve the change "
"before it is officially applied to the Bill of Materials."
msgstr ""
"<b>Revisione tecnica:</b> questa proposta genera automaticamente un <b>ECO</"
"b> nell'app PLM. Gli ingegneri possono quindi esaminare, testare e approvare "
"la modifica prima che venga ufficialmente applicata alla distinta base."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Financial Forecasting &amp; Actuals:</b> Compare estimated costs against "
"real costs directly from the project overview to maintain control over your "
"budget."
msgstr ""
"<b>Previsioni finanziarie e dati effettivi:</b> confronta i costi stimati "
"con quelli reali direttamente dalla panoramica dei progetti per mantenere il "
"controllo sul tuo budget."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Flexible Timesheets:</b> Log time on individual tasks to monitor project "
"profitability or accurately bill clients for hours worked."
msgstr ""
"<b>Fogli ore flessibili:</b> registra il tempo dedicato alle singole "
"attività per monitorare la redditività dei progetti o fatturare con "
"precisione ai clienti le ore lavorate."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>For example:</b> A client requests a specialized scanner capable of "
"multilingual package recognition. Within a single project, you can "
"centralize product specifications, vendor quotes, and BOM designs. You can "
"then generate an initial quotation for a <b>Proof of Concept (PoC)</b> "
"directly from the project. Once confirmed, you can continue iterating within "
"the same project—creating updated quotations and Manufacturing Orders by "
"building on previous data and new insights."
msgstr ""
"<b>Ad esempio:</b> un cliente richiede uno scanner specializzato in grado di "
"riconoscere pacchetti multilingue. All'interno di un unico progetto, è "
"possibile centralizzare le specifiche del prodotto, i preventivi dei "
"fornitori e i progetti della distinta base. È quindi possibile generare un "
"preventivo iniziale per un <b>Proof of Concept (PoC)</b> direttamente dal "
"progetto. Una volta confermato, è possibile continuare a iterare all'interno "
"dello stesso progetto, creando preventivi aggiornati e ordini di produzione "
"sulla base dei dati precedenti e delle nuove informazioni."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Invoice Oversight:</b> Track all related outgoing and incoming invoices "
"directly within the project interface."
msgstr ""
"<b>Gestione delle fatture:</b> tieni traccia di tutte le fatture in uscita e "
"in entrata direttamente dall'interfaccia dei progetti."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid "<b>Key Benefits:</b>"
msgstr "<b>Vantaggi principali:</b>"

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>MTO (Make-to-Order) Route:</b> Use this to automatically trigger a "
"Manufacturing Order whenever a Sales Order is confirmed"
msgstr ""
"<b>Percorso MTO (Make-to-Order):</b> utilizzalo per attivare automaticamente "
"un ordine di produzione ogni volta che viene confermato un ordine di vendita"

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Make to Stock (Reordering Rules):</b> Set a <b>minimum stock level</b> "
"for your sub-assemblies. The system will automatically trigger a new MO once "
"your inventory drops below this threshold, ensuring you always have enough "
"stock on hand for future production."
msgstr ""
"<b>Make to stock (regole di riordino):</b> imposta un <b>livello minimo di "
"magazzino</b> per i sottoassiemi. Il sistema attiverà automaticamente un "
"nuovo ordine di produzione non appena il magazzino scenderà al di sotto di "
"questa soglia, assicurandoti di avere sempre a disposizione scorte "
"sufficienti per la produzione futura."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Manual Creation:</b> Generate secondary MOs for sub-assemblies manually "
"as the need arises."
msgstr ""
"<b>Creazione manuale:</b> genera manualmente gli ordini di produzione "
"secondari per i sottoassiemi quando necessario."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Miscellaneous Notes &amp; Integration:</b> Use the HTML field (note) in "
"the <b>Miscellaneous tab</b> for advanced instructions. You can embed links "
"to internal knowledge articles, 3D plans, or external software. Operators "
"can access these links directly from the <b>Shopfloor App</b> during "
"production."
msgstr ""
"<b>Note varie e integrazione:</b> utilizza il campo HTML (nota) nella "
"<b>scheda Varie</b> per istruzioni avanzate. È possibile incorporare "
"collegamenti ad articoli della knowledge base interna, piani 3D o software "
"esterni. Gli operatori possono accedere a questi collegamenti direttamente "
"dall'app <b>Linea di produzione</b> durante la produzione."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Monitor Progress:</b> Visit the <b>Overview Tab</b> to see a side-by-side "
"comparison of your sales, expected costs, and real costs (derived from "
"invoices and completed Manufacturing Orders)."
msgstr ""
"<b>Monitora i progressi:</b> visita la <b>scheda Panoramica</b> per "
"visualizzare un confronto affiancato tra le vendite, i costi previsti e i "
"costi reali (derivati dalle fatture e dagli ordini di produzione completati)."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Note:</b> If you validate a transfer for a partial quantity, the system "
"will automatically create a <b>backorder</b> for the rest of the items."
msgstr ""
"<b>Nota:</b> se convalidi un trasferimento per una quantità parziale, il "
"sistema creerà automaticamente un <b>ordine in sospeso</b> per il resto "
"degli articoli."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Organized File Sharing:</b> Create custom folders (such as \"Internal\" "
"or \"Client-Facing\") via the Documents button."
msgstr ""
"<b>Condivisione organizzata dei file:</b> crea cartelle personalizzate (come "
"\"Interno\" o \"Clienti\") tramite il pulsante Documenti."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid "<b>Pro Tip: Real-Time Margin Analysis</b>"
msgstr "<b>Suggerimento: analizza i margini in tempo reale</b>"

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Pro-Tip:</b> You can print and use barcode commands with a scanner to "
"automate and streamline your workflow."
msgstr ""
"<b>Suggerimento:</b> è possibile stampare e utilizzare comandi con codici a "
"barre con uno scanner per automatizzare e semplificare il flusso di lavoro."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Proactive Quality Checks:</b> These are predefined checks (created in the "
"Quality App) that trigger automatically at specific stages of production."
msgstr ""
"<b>Controlli qualità proattivi:</b> si tratta di controlli predefiniti "
"(creati nell'app Qualità) che si attivano automaticamente in fasi specifiche "
"della produzione."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Propose BOM Updates:</b> If a worker discovers a more efficient method or "
"a necessary adjustment, they can propose adding a new step or component."
msgstr ""
"<b>Proponi aggiornamenti alla DiBa:</b> se un lavoratore scopre un metodo "
"più efficiente o una modifica necessaria, può proporre l'aggiunta di una "
"nuova fase o di un nuovo componente."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Protocol:</b> Develop detailed <b>Bills of Materials (BOMs)</b> that "
"explicitly link components to their respective production stages and "
"operations."
msgstr ""
"<b>Protocollo:</b> sviluppa <b>distinte base dettagliate</b> che colleghino "
"esplicitamente i componenti alle rispettive fasi di produzione e operazioni."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Protocol:</b> For new clients or projects, create a <b>unique product "
"entry</b>. Map these to a <b>Master BOM Catalog</b> to pull in reusable "
"templates; this allows for distinct database tracking while leveraging "
"standardized production logic."
msgstr ""
"<b>Protocollo:</b> per i nuovi clienti o progetti, crea una <b>voce prodotto "
"unica</b>. Mappale in un <b>Catalogo DiBa master</b> per importare modelli "
"riutilizzabili. Ciò consente un tracciamento distinto del database "
"sfruttando al contempo una logica di produzione standardizzata."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Protocol:</b> Maintain up-to-date <b>vendor assignments</b> and "
"<b>purchase pricing</b> to ensure procurement accuracy."
msgstr ""
"<b>Protocollo:</b> mantieni aggiornate le <b>assegnazioni dei fornitori</b> "
"e i <b>prezzi degli acquisti</b> per garantire l'accuratezza "
"dell'approvvigionamento."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Reactive Quality Alerts:</b> If a worker identifies an issue on the fly, "
"they can trigger a <b>Quality Alert</b>. This creates a dedicated task in "
"the Quality App for the quality team to investigate."
msgstr ""
"<b>Avvisi di qualità reattivi:</b> se un operatore individua un problema al "
"volo, può attivare un <b>avviso di qualità</b>. Questo crea un lavoro "
"dedicato nell'app Qualità affinché il team di qualità possa indagare."

#. module: custom_industrial_equipment
#: model_terms:ir.ui.view,arch_db:custom_industrial_equipment.welcome_article_body
msgid ""
"<b>Sales &amp; Purchase Orders:</b> Generate unlimited Sales Orders to "
"account for scope changes, and manage all project-specific Purchase Orders "
"in one place."
msgstr ""
"<b>Vendite e ordini di acquisto:</b> genera ordini di vendita illimitati per "
"tenere conto delle modifiche all'ambito di applicazione e gestisci tutti gli "
"ordini di acquisto specifici dei progetti in un unico posto."

#. module: custom_industrial_equipment
