<?xml version='1.0' encoding='UTF-8'?>
<odoo noupdate="1">
  <function model="pos.config" name="load_onboarding_retail_scenario">
    <value name="with_demo_data" model="ir.module.module" eval="obj().search([('name', '=', 'bike_shop')]).demo"/>
  </function>
  <record id="point_of_sale.pos_config_retail" model="pos.config" forcecreate="1">
    <field name="name">BikeHub</field>
    <field name="use_pricelist" eval="True"/>
    <field name="email">bike_shop@example.com</field>
    <field name="website">http://odoo.com</field>
    <field name="logo" type="bytes" file="bike_shop/static/description/icon.png"/>
    <field name="warehouse_id" ref="stock.warehouse0"/>
  </record>
</odoo>
