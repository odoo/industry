#. module: bike_shop
#: model_terms:ir.ui.view,arch_db:bike_shop.repairs
msgid ""
"<br/> Customer satisfaction is our priority. Our\n"
"                                            support team is always ready to "
"assist, ensuring you\n"
"                                            have a smooth and successful "
"experience.<br/>"
msgstr ""
"<br/> ຄວາມເພິ່ງພໍໃຈຂອງລູກຄ້າແມ່ນບຸລິມະສິດຂອງພວກເຮົາ. ທີມງານ\n"
"                                            ຊ່ວຍເຫຼືອຂອງພວກເຮົາພ້ອມສະເໝີທີ່ຈະຊ່ວຍເຫຼືອ, "
"ເພື່ອຮັບປະກັນວ່າທ່ານ\n"
"                                            ຈະໄດ້ຮັບປະສົບການທີ່ສະດວກສະບາຍ ແລະ "
"ປະສົບຜົນສຳເລັດ.<br/>"

#. module: bike_shop
#: model_terms:ir.ui.view,arch_db:bike_shop.homepage
msgid ""
"<br/> Your expert partner for premium bikes, electric\n"
"                                            rides, and professional "
"servicing."
msgstr ""
"<br/> ຄູ່ຮ່ວມງານຜູ້ຊ່ຽວຊານຂອງທ່ານສຳລັບລົດຖີບພຣີມຽມ, ລົດ\n"
"                                            ໄຟຟ້າ, ແລະ ການບໍລິການແບບມືອາຊີບ."

#. module: bike_shop
#: model:mail.template,body_html:bike_shop.mail_template_warranty_claim
msgid ""
"<div style=\"margin: 0px; padding: 0px;\" data-oe-version=\"1.0\"> \n"
"            <p style=\"box-sizing:border-box;margin: 0px; padding: 0px; font-"
"size: 12px;\"> \n"
"            Dear <span style=\"font-weight:bold;\" t-"
"out=\"object.partner_id.name or ''\"/>,<br/>\n"
"            <br/> \n"
"            We are submitting a warranty claim for a customer.\n"
"            </p><ul>\n"
"                <t t-if=\"object.properties and "
"object.properties.get('order_line_id')\">\n"
"                    <t t-set=\"order_line\" t-"
"value=\"env['sale.order.line'].browse(object.properties['order_line_id'])\"/"
">\n"
"                    <li>\n"
"                        Customer Name: <t t-"
"out=\"order_line.order_id.partner_id.display_name or 'N/A'\"/>\n"
"                    </li>\n"
"                </t>\n"
"                <t t-if=\"object.properties and "
"object.properties.get('task_id')\">\n"
"                    <t t-set=\"task\" t-"
"value=\"env['project.task'].browse(object.properties['task_id'])\"/>\n"
"                    <t t-if=\"task.task_properties and "
"task.task_properties.get('serial_number_id')\">\n"
"                        <t t-set=\"serial\" t-"
"value=\"env['stock.lot'].browse(task.task_properties['serial_number_id'])\"/"
">\n"
"\n"
"                        <t t-set=\"move_lines\" t-"
"value=\"env['stock.move.line'].search([('lot_id', '=', serial.id)])\"/>\n"
"                        <t t-set=\"sale_date\" t-value=\"False\"/>\n"
"                        <t t-foreach=\"move_lines\" t-as=\"ml\">\n"
"                            <t t-if=\"ml.move_id.sale_line_id\">\n"
"                                <t t-set=\"sale_date\" t-"
"value=\"ml.move_id.sale_line_id.order_id.date_order\"/>\n"
"                                <t t-break=\"True\"/>\n"
"                            </t>\n"
"                        </t>\n"
"                        <li>\n"
"                            Serial Number: <t t-out=\"serial.name or 'N/A'\"/"
">\n"
"                        </li>\n"
"                        <li t-if=\"sale_date\">\n"
"                            Purchase Date: <t t-out=\"format_date(sale_date) "
"if sale_date else 'N/A'\"/>\n"
"                        </li>\n"
"                    </t>\n"
"                </t>\n"
"            </ul>\n"
"            Issue Description: <t t-out=\"object.description\"/>\n"
"            <br/>\n"
"            Please find attached photos of the defect.<br/>\n"
"            <br/>\n"
"            Thank you, <br/>\n"
"            <t t-out=\"object.user_id.display_name\"/> <br/>\n"
"            <t t-out=\"object.company_id.name\"/> \n"
"            </div> "
msgstr ""
"<div style=\"margin: 0px; padding: 0px;\" data-oe-version=\"1.0\"> \n"
"            <p style=\"box-sizing:border-box;margin: 0px; padding: 0px; font-"
"size: 12px;\"> \n"
"            ຮຽນ <span style=\"font-weight:bold;\" t-"
"out=\"object.partner_id.name or ''\"/>,<br/>\n"
"            <br/> \n"
"            ພວກເຮົາກຳລັງສົ່ງຄຳຮ້ອງຂໍການຮັບປະກັນສຳລັບລູກຄ້າ.\n"
"            </p><ul>\n"
"                <t t-if=\"object.properties and "
"object.properties.get('order_line_id')\">\n"
"                    <t t-set=\"order_line\" t-"
"value=\"env['sale.order.line'].browse(object.properties['order_line_id'])\"/"
">\n"
"                    <li>\n"
"                        ຊື່ລູກຄ້າ: <t t-"
"out=\"order_line.order_id.partner_id.display_name or 'N/A'\"/>\n"
"                    </li>\n"
"                </t>\n"
"                <t t-if=\"object.properties and "
"object.properties.get('task_id')\">\n"
"                    <t t-set=\"task\" t-"
"value=\"env['project.task'].browse(object.properties['task_id'])\"/>\n"
"                    <t t-if=\"task.task_properties and "
"task.task_properties.get('serial_number_id')\">\n"
"                        <t t-set=\"serial\" t-"
"value=\"env['stock.lot'].browse(task.task_properties['serial_number_id'])\"/"
">\n"
"\n"
"                        <t t-set=\"move_lines\" t-"
"value=\"env['stock.move.line'].search([('lot_id', '=', serial.id)])\"/>\n"
"                        <t t-set=\"sale_date\" t-value=\"False\"/>\n"
"                        <t t-foreach=\"move_lines\" t-as=\"ml\">\n"
"                            <t t-if=\"ml.move_id.sale_line_id\">\n"
"                                <t t-set=\"sale_date\" t-"
"value=\"ml.move_id.sale_line_id.order_id.date_order\"/>\n"
"                                <t t-break=\"True\"/>\n"
"                            </t>\n"
"                        </t>\n"
"                        <li>\n"
"                            ເລກຊຸດ (Serial Number): <t t-out=\"serial.name or "
"'N/A'\"/>\n"
"                        </li>\n"
"                        <li t-if=\"sale_date\">\n"
"                            ວັນທີຊື້: <t t-out=\"format_date(sale_date) if "
"sale_date else 'N/A'\"/>\n"
"                        </li>\n"
"                    </t>\n"
"                </t>\n"
"            </ul>\n"
"            ລາຍລະອຽດບັນຫາ: <t t-out=\"object.description\"/>\n"
"            <br/>\n"
"            ກະລຸນາເບິ່ງຮູບພາບຂອງຈຸດບົກຜ່ອງທີ່ຄັດຕິດມານີ້.<br/>\n"
"            <br/>\n"
"            ຂອບໃຈ, <br/>\n"
"            <t t-out=\"object.user_id.display_name\"/> <br/>\n"
"            <t t-out=\"object.company_id.name\"/> \n"
"            </div> "

#. module: bike_shop
#: model:mail.template,body_html:bike_shop.mail_template_order_ready
msgid ""
"<div style=\"margin: 0px; padding: 0px;\" data-oe-version=\"1.0\"> \n"
"    <p style=\"box-sizing:border-box;margin: 0px; padding: 0px; font-size: "
"12px;\"> \n"
"    Dear <span style=\"font-weight:bold;\" t-"
"out=\"object.partner_id.display_name or ''\"/>,<br/>\n"
"    <br/> \n"
"    Your order <span style=\"font-weight:bold;\" t-out=\"object.name or ''\"/"
"> is ready.\n"
"    <br/>\n"
"    You can collect it at our store at your convenience.\n"
"    <br/>\n"
"    Thank you for your trust and patience!<br/>\n"
"    <br/> \n"
"    Do not hesitate to contact us if you have any questions. <br/>\n"
"    <br/>\n"
"    <t t-if=\"not is_html_empty(object.user_id.signature)\" data-o-mail-"
"quote-container=\"1\">\n"
"        <span style=\"font-weight:bold;\" t-out=\"object.user_id.signature\"/"
">\n"
"    </t>\n"
"    </p></div>"
msgstr ""
"<div style=\"margin: 0px; padding: 0px;\" data-oe-version=\"1.0\"> \n"
"    <p style=\"box-sizing:border-box;margin: 0px; padding: 0px; font-size: "
"12px;\"> \n"
"    ຮຽນ <span style=\"font-weight:bold;\" t-"
"out=\"object.partner_id.display_name or ''\"/>,<br/>\n"
"    <br/> \n"
"    ການສັ່ງຊື້ຂອງທ່ານ <span style=\"font-weight:bold;\" t-out=\"object.name or "
"''\"/> ແມ່ນກຽມພ້ອມແລ້ວ.\n"
"    <br/>\n"
"    ທ່ານສາມາດມາຮັບໄດ້ທີ່ຮ້ານຂອງພວກເຮົາຕາມທີ່ທ່ານສະດວກ.\n"
"    <br/>\n"
"    ຂອບໃຈສຳລັບຄວາມໄວ້ວາງໃຈ ແລະ ຄວາມອົດທົນຂອງທ່ານ!<br/>\n"
"    <br/> \n"
"    ຢ່າລັງເລທີ່ຈະຕິດຕໍ່ຫາພວກເຮົາຫາກທ່ານມີຄຳຖາມໃດໆ. <br/>\n"
"    <br/>\n"
"    <t t-if=\"not is_html_empty(object.user_id.signature)\" data-o-mail-"
"quote-container=\"1\">\n"
"        <span style=\"font-weight:bold;\" t-out=\"object.user_id.signature\"/"
">\n"
"    </t>\n"
"    </p></div>"

