msgid ""
"<strong><span class=\"h2-fs\">Tips for Success<br/><br/></span></strong>"
msgstr "<strong><span class=\"h2-fs\">Mẹo thành công<br/><br/></span></strong>"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Accounting</strong>: Automate invoices, reconcile payments, and "
"track profitability per tour type"
msgstr ""
"<strong>Kế toán</strong>: Tự động hóa hóa đơn, đối chiếu thanh toán và theo "
"dõi lợi nhuận theo từng loại tour"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Activate the multilingual website setting to localize your website "
"to international audiences.</strong>"
msgstr ""
"<strong>Kích hoạt cài đặt trang web đa ngôn ngữ để tùy chỉnh trang web của "
"bạn cho đối tượng quốc tế.</strong>"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.ir_ui_view_3840
msgid ""
"<strong>Antwerp</strong> dazzles with its fashion-forward spirit and rich "
"artistic heritage. Explore the legacy of Rubens, marvel at the gothic "
"Cathedral of Our Lady, and stroll through the dynamic streets of this port "
"city where tradition meets modern creativity."
msgstr ""
"<strong>Antwerp</strong> gây ấn tượng với tinh thần thời trang tiên phong và "
"di sản nghệ thuật phong phú. Hãy khám phá dấu ấn của Rubens, chiêm ngưỡng "
"Nhà thờ Đức Bà theo phong cách gothic, và dạo bước trên những con phố sôi "
"động của thành phố cảng này — nơi truyền thống gặp gỡ sự sáng tạo hiện đại."

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Appointments</strong>: Allow customers to book private tours based "
"on availability and language preferences."
msgstr ""
"<strong>Đặt lịch hẹn</strong>: Cho phép khách hàng đặt tour riêng theo tình "
"trạng sẵn có và sở thích ngôn ngữ."

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid "<strong>Apps &amp; What They Do:</strong>"
msgstr "<strong>Ứng dụng &amp; Chức năng của chúng:</strong>"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.ir_ui_view_3840
msgid ""
"<strong>Brussels</strong>, the heart of Europe, welcomes you with grand "
"architecture, cobblestone streets, and a vibrant atmosphere. From the "
"opulent Grand Place to the surreal world of Magritte, this city is a must-"
"see for culture lovers and history buffs alike."
msgstr ""
"<strong>Brussels</strong>, trái tim của châu Âu, chào đón bạn với những công "
"trình kiến trúc tráng lệ, những con phố lát đá cổ kính và bầu không khí sôi "
"động. Từ quảng trường Grand Place lộng lẫy cho đến thế giới siêu thực của "
"Magritte, thành phố này là điểm đến không thể bỏ qua cho những ai yêu văn "
"hóa và đam mê lịch sử."

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Create services</strong> for each destination &amp; language pair"
msgstr "<strong>Tạo dịch vụ</strong> cho mỗi cặp ngôn ngữ đích &amp;."

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Create visually rich pages</strong> with images, videos, and tour "
"descriptions"
msgstr ""
"<strong>Tạo các trang web sinh động với hình ảnh, video và mô tả tour tại</"
"strong>"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Customers book online</strong> and receive <strong>automated "
"reminders</strong>"
msgstr ""
"<strong>Khách hàng đặt chỗ trực tuyến tại</strong> và nhận được các thông "
"báo tự động từ <strong>.</strong>"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid "<strong>Customize layouts easily</strong> using drag-and-drop editor"
msgstr ""
"<strong>Dễ dàng tùy chỉnh bố cục</strong> bằng trình chỉnh sửa kéo và thả"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Dashboards</strong>: Visualize your KPIs—bookings per guide, top-"
"selling tours, revenue trends"
msgstr ""
"<strong>Báo cáo tổng quan</strong>: Hiển thị các chỉ số KPI của bạn — số "
"lượng đặt chỗ trên mỗi hướng dẫn viên, các tour bán chạy nhất, xu hướng "
"doanh thu"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Define each tour</strong> as an event with time slots and capacities"
msgstr ""
"<strong>Xác định mỗi tour</strong> là một sự kiện có khung giờ và sức chứa"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid "<strong>Define guide availability</strong> per service"
msgstr "<strong>Xác định tính khả dụng của hướng dẫn</strong> cho từng dịch vụ"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Digital tickets with QR codes</strong> for easy on-site check-in"
msgstr "<strong>Vé điện tử có mã QR</strong> để đăng ký nhanh chóng tại chỗ"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Enable online booking &amp; payment</strong>, no manual follow-up "
"needed"
msgstr ""
"<strong>Bật tính năng đặt chỗ trực tuyến &amp; thanh toán</strong>, không "
"cần theo dõi thủ công"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Events</strong>: Set up group tours with schedules and manage "
"bookings and attendance."
msgstr ""
"<strong>Sự kiện</strong>: Tổ chức các tour du lịch theo nhóm với lịch trình, "
"quản lý đặt chỗ và theo dõi sự tham gia."

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.ir_ui_view_3840
msgid ""
"<strong>Ghent</strong> enchants with medieval splendor and a youthful "
"energy. Discover castles, canals, and hidden alleyways as you uncover the "
"soul of a city where past and present coexist in perfect harmony."
msgstr ""
"<strong>Ghent</strong> mê hoặc với vẻ tráng lệ thời trung cổ và sức sống trẻ "
"trung. Khám phá các lâu đài, kênh đào và những con hẻm ẩn mình khi bạn tìm "
"hiểu linh hồn của một thành phố nơi quá khứ và hiện tại hòa quyện hoàn hảo."

#. module: guided_tours
#: model_terms:event.event,description:guided_tours.event_event_2
msgid ""
"<strong>Ghent</strong> is the kind of city that sneaks up on you — and "
"steals your heart. A vibrant mix of gothic spires, canalside charm, artistic "
"rebellion, and youthful energy, Ghent is one of Belgium’s best-kept secrets… "
"though the word is definitely getting out."
msgstr ""
"<strong>Ghent</strong> là kiểu thành phố len lỏi vào trái tim bạn lúc nào "
"không hay — và rồi chiếm trọn nó. Sự pha trộn sống động giữa những ngọn tháp "
"gothic, vẻ duyên dáng bên kênh đào, tinh thần nghệ thuật nổi loạn và nguồn "
"năng lượng trẻ trung khiến Ghent trở thành một trong những bí mật được giữ "
"kín nhất của nước Bỉ… dù lời đồn thì chắc chắn đang lan rộng."

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid "<strong>Handle walk-in traffic</strong> efficiently with synced stock"
msgstr ""
"<strong>Quản lý lưu lượng khách hàng đến trực tiếp (</strong> ) một cách "
"hiệu quả với hệ thống kho hàng đồng bộ"

#. module: guided_tours
#: model_terms:event.event,description:guided_tours.event_event_1
#: model_terms:event.event,description:guided_tours.event_event_2
#: model_terms:event.event,description:guided_tours.event_event_3
#: model_terms:event.event,description:guided_tours.event_event_4
msgid "<strong>Included</strong>"
msgstr "<strong>Bao gồm</strong>"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Integrate booking buttons</strong> directly with group or private "
"tour modules"
msgstr ""
"<strong>Tích hợp nút đặt chỗ</strong> trực tiếp với các mô-đun tour nhóm "
"hoặc tour riêng"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.ir_ui_view_3841
msgid "<strong>Join Our Guided Group Tours — Discover More Together</strong>"
msgstr ""
"<strong>Tham gia các tour du lịch theo nhóm có hướng dẫn của chúng tôi — "
"Khám phá nhiều hơn cùng nhau</strong>"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.ir_ui_view_3840
msgid ""
"<strong>Namur</strong>, nestled at the confluence of the Meuse and Sambre "
"rivers, invites you to slow down and savor the beauty of Wallonia. Its "
"imposing citadel, relaxed charm, and panoramic views make it a serene yet "
"fascinating stop on your Belgian adventure."
msgstr ""
"<strong>Namur</strong>, nằm ở nơi hợp lưu của sông Meuse và Sambre, mời bạn "
"dừng chân chậm lại để tận hưởng vẻ đẹp của Wallonia. Pháo đài hùng vĩ, nét "
"duyên dáng thư thái cùng khung cảnh toàn cảnh tuyệt đẹp khiến nơi đây trở "
"thành điểm đến vừa yên bình vừa cuốn hút trong hành trình khám phá nước Bỉ "
"của bạn."

#. module: guided_tours
#: model_terms:event.event,description:guided_tours.event_event_1
#: model_terms:event.event,description:guided_tours.event_event_2
#: model_terms:event.event,description:guided_tours.event_event_3
#: model_terms:event.event,description:guided_tours.event_event_4
msgid "<strong>Not included</strong>"
msgstr "<strong>Không bao gồm</strong>"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid "<strong>Open POS session</strong> and view tour availabilities"
msgstr ""
"<strong>Mở phiên làm việc POS tại</strong> và xem các tùy chọn tour có sẵn"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid "<strong>Optimize SEO</strong> to attract tourists searching online"
msgstr ""
"<strong>Tối ưu hóa SEO cho trang web</strong> để thu hút du khách tìm kiếm "
"trực tuyến"

#. module: guided_tours
#: model_terms:event.event,description:guided_tours.event_event_1
#: model_terms:event.event,description:guided_tours.event_event_2
#: model_terms:event.event,description:guided_tours.event_event_3
#: model_terms:event.event,description:guided_tours.event_event_4
msgid "<strong>Our offering</strong><br>"
msgstr ""

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Point of Sale</strong>: Sell tickets in person, print receipts, and "
"manage real-time tour availabilities."
msgstr ""
"<strong>POS (Point of Sale)</strong>: Bán vé trực tiếp, in hóa đơn và quản "
"lý tình trạng sẵn có của tour du lịch theo thời gian thực."

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid "<strong>Print receipts</strong> with booking details"
msgstr "<strong>In hóa đơn</strong> kèm thông tin đặt chỗ"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Recruitment</strong>: Manage applications and onboarding for new "
"tour guides"
msgstr ""
"<strong>Tuyển dụng</strong>: Quản lý hồ sơ ứng tuyển và quá trình tiếp nhận "
"nhân viên mới cho vị trí hướng dẫn viên du lịch"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Regularly update website content</strong> with new tours, seasonal "
"offerings, and high-quality visuals"
msgstr ""
