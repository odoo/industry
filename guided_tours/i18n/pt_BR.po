msgstr "Venda de ingressos no local 🧾"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"Once your core operations are running smoothly, consider expanding your "
"toolset:"
msgstr ""
