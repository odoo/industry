#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong><span class=\"h2-fs\">Tips for Success<br/><br/></span></strong>"
msgstr ""
"<strong><span class=\"h2-fs\">Dicas para o sucesso<br/><br/></span></strong>"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Accounting</strong>: Automate invoices, reconcile payments, and "
"track profitability per tour type"
msgstr ""
"<strong>Financeiro</strong>: Automatize faturas, reconcilie pagamentos e "
"acompanhe a rentabilidade por tipo de excursão"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Activate the multilingual website setting to localize your website "
"to international audiences.</strong>"
msgstr ""
"<strong>Ative a configuração multilíngue do site para localizá-lo para "
"públicos internacionais.</strong>"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.ir_ui_view_3840
msgid ""
"<strong>Antwerp</strong> dazzles with its fashion-forward spirit and rich "
"artistic heritage. Explore the legacy of Rubens, marvel at the gothic "
"Cathedral of Our Lady, and stroll through the dynamic streets of this port "
"city where tradition meets modern creativity."
msgstr ""
"<strong>Antwerp</strong> deslumbra com seu espírito vanguardista e rica "
"herança artística. Explore o legado de Rubens, maravilhe-se com a catedral "
"gótica de Nossa Senhora e passeie pelas ruas dinâmicas desta cidade "
"portuária onde a tradição se encontra com a criatividade moderna."

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Appointments</strong>: Allow customers to book private tours based "
"on availability and language preferences."
msgstr ""
"<strong>Compromissos</strong>: Permita que os clientes reservem passeios "
"privados com base na disponibilidade e nas preferências de idioma."

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid "<strong>Apps &amp; What They Do:</strong>"
msgstr "<strong>Aplicativos e para que servem:</strong>"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.ir_ui_view_3840
msgid ""
"<strong>Brussels</strong>, the heart of Europe, welcomes you with grand "
"architecture, cobblestone streets, and a vibrant atmosphere. From the "
"opulent Grand Place to the surreal world of Magritte, this city is a must-"
"see for culture lovers and history buffs alike."
msgstr ""
"<strong>Bruxelas</strong>, o coração da Europa, dá-lhe as boas-vindas com a "
"sua arquitetura grandiosa, ruas de paralelepípedos e uma atmosfera vibrante. "
"Da opulenta Grand Place ao mundo surreal de Magritte, esta cidade é "
"imperdível para os amantes da cultura e os entusiastas da história."

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Create services</strong> for each destination &amp; language pair"
msgstr "<strong>Crie serviços</strong> para cada destino e par de idiomas"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Create visually rich pages</strong> with images, videos, and tour "
"descriptions"
msgstr ""
"<strong>Crie páginas visualmente ricas</strong> com imagens, vídeos e "
"descrições de passeios"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Customers book online</strong> and receive <strong>automated "
"reminders</strong>"
msgstr ""
"<strong>Clientes reservam on-line</strong> e recebem<strong> lembretes "
"automatizados</strong>"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid "<strong>Customize layouts easily</strong> using drag-and-drop editor"
msgstr ""
"<strong>Personalize layouts facilmente</strong> usando o editor de arrastar "
"e soltar"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Dashboards</strong>: Visualize your KPIs—bookings per guide, top-"
"selling tours, revenue trends"
msgstr ""
"<strong>Painéis</strong>: visualize seus KPIs — reservas por guia, passeios "
"mais vendidos, tendências de receita"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Define each tour</strong> as an event with time slots and capacities"
msgstr ""
"<strong>Defina cada excursão</strong> como um evento com horários e "
"capacidades"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid "<strong>Define guide availability</strong> per service"
msgstr "<strong>Definir disponibilidade do guia</strong>por serviço"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Digital tickets with QR codes</strong> for easy on-site check-in"
msgstr ""
"<strong>Ingressos digitais com códigos QR</strong> para facilitar o check-in "
"no local"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Enable online booking &amp; payment</strong>, no manual follow-up "
"needed"
msgstr ""
"<strong>Habilitar reservas e pagamentos online </strong>, não é necessário "
"acompanhamento manual"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Events</strong>: Set up group tours with schedules and manage "
"bookings and attendance."
msgstr ""
"<strong>Eventos</strong>: Organize excursões em grupo com horários e "
"gerencie reservas e participações."

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.ir_ui_view_3840
msgid ""
"<strong>Ghent</strong> enchants with medieval splendor and a youthful "
"energy. Discover castles, canals, and hidden alleyways as you uncover the "
"soul of a city where past and present coexist in perfect harmony."
msgstr ""
"<strong>Ghent</strong> encanta com seu esplendor medieval e energia jovem. "
"Descubra castelos, canais e vielas escondidas enquanto descobre a alma de "
"uma cidade onde o passado e o presente coexistem em perfeita harmonia."

#. module: guided_tours
#: model_terms:event.event,description:guided_tours.event_event_2
msgid ""
"<strong>Ghent</strong> is the kind of city that sneaks up on you — and "
"steals your heart. A vibrant mix of gothic spires, canalside charm, artistic "
"rebellion, and youthful energy, Ghent is one of Belgium’s best-kept secrets… "
"though the word is definitely getting out."
msgstr ""
"<strong>Ghent</strong> é o tipo de cidade que te surpreende — e rouba seu "
"coração. Uma mistura vibrante de torres góticas, charme à beira do canal, "
"rebeldia artística e energia jovem, Ghent é um dos segredos mais bem "
"guardados da Bélgica... embora a notícia esteja definitivamente se "
"espalhando."

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid "<strong>Handle walk-in traffic</strong> efficiently with synced stock"
msgstr ""
"<strong>Lide com o fluxo de clientes </strong> de forma eficiente com "
"estoque sincronizado"

#. module: guided_tours
#: model_terms:event.event,description:guided_tours.event_event_1
#: model_terms:event.event,description:guided_tours.event_event_2
#: model_terms:event.event,description:guided_tours.event_event_3
#: model_terms:event.event,description:guided_tours.event_event_4
msgid "<strong>Included</strong>"
msgstr "<strong>Incluso:</strong>"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Integrate booking buttons</strong> directly with group or private "
"tour modules"
msgstr ""
"<strong>Integre botões de reserva</strong> diretamente com módulos de "
"excursões em grupo ou privadas"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.ir_ui_view_3841
msgid "<strong>Join Our Guided Group Tours — Discover More Together</strong>"
msgstr ""
"<strong>Participe das nossas visitas guiadas em grupo — Vamos explorar "
"juntos</strong>"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.ir_ui_view_3840
msgid ""
"<strong>Namur</strong>, nestled at the confluence of the Meuse and Sambre "
"rivers, invites you to slow down and savor the beauty of Wallonia. Its "
"imposing citadel, relaxed charm, and panoramic views make it a serene yet "
"fascinating stop on your Belgian adventure."
msgstr ""
"<strong>Namur</strong>, situada na confluência dos rios Meuse e Sambre, "
"convida você a desacelerar e saborear a beleza da Valônia. Sua imponente "
"cidadela, charme descontraído e vistas panorâmicas fazem dela uma parada "
"serena, mas fascinante, em sua aventura belga."

#. module: guided_tours
#: model_terms:event.event,description:guided_tours.event_event_1
#: model_terms:event.event,description:guided_tours.event_event_2
#: model_terms:event.event,description:guided_tours.event_event_3
#: model_terms:event.event,description:guided_tours.event_event_4
msgid "<strong>Not included</strong>"
msgstr "<strong>Não incluso</strong>"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid "<strong>Open POS session</strong> and view tour availabilities"
msgstr ""
"<strong>Abra a sessão do PDV</strong> e veja as disponibilidades dos passeios"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid "<strong>Optimize SEO</strong> to attract tourists searching online"
msgstr ""
"<strong>Otimize o SEO</strong> para atrair turistas através de pesquisas on-"
"line"

#. module: guided_tours
#: model_terms:event.event,description:guided_tours.event_event_1
#: model_terms:event.event,description:guided_tours.event_event_2
#: model_terms:event.event,description:guided_tours.event_event_3
#: model_terms:event.event,description:guided_tours.event_event_4
msgid "<strong>Our offering</strong><br>"
msgstr "<strong>Nossas ofertas</strong><br>"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Point of Sale</strong>: Sell tickets in person, print receipts, and "
"manage real-time tour availabilities."
msgstr ""
"<strong>Ponto de Venda</strong>: Venda ingressos pessoalmente, imprima "
"recibos e gerencie a disponibilidade de passeios em tempo real."

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid "<strong>Print receipts</strong> with booking details"
msgstr "<strong>Imprimir recibos</strong> com detalhes da reserva"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Recruitment</strong>: Manage applications and onboarding for new "
"tour guides"
msgstr ""
"<strong>Recrutamento</strong>: Gerencie candidaturas e integração de novos "
"guias turísticos"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Regularly update website content</strong> with new tours, seasonal "
"offerings, and high-quality visuals"
msgstr ""
"<strong>Atualize regularmente o conteúdo do site</strong> com novas "
"excursões, ofertas sazonais e imagens de alta qualidade"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid "<strong>Reminders &amp; confirmation emails</strong> reduce no-shows"
msgstr ""
"<strong>Lembretes e e-mails de confirmação</strong> reduzem o número de "
"ausências"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid "<strong>Sell remaining spots</strong> for today’s tours or future ones"
msgstr ""
"<strong>Venda as vagas restantes</strong> para as excursões de hoje ou "
"futuras"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Social Marketing</strong>: Schedule and post on social media to "
"boost tour visibility"
msgstr ""
"<strong>Redes Sociais</strong>: Programe e publique nas redes sociais para "
"aumentar a visibilidade dos tours"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Surveys</strong>: Gather guest feedback after each tour to "
"continuously improve"
msgstr ""
"<strong>Pesquisas</strong>: Receba feedback dos visitantes após cada visita "
"guiada para continuar sempre melhorando"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Track attendance live</strong> from a mobile device or the "
"attendances app"
msgstr ""
"<strong>Acompanhe a frequência ao vivo</strong> a partir de um dispositivo "
"móvel ou do aplicativo Controle de Presenças"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid "<strong>Train staff</strong> on using POS for quick ticketing"
msgstr ""
"<strong>Treine a equipe</strong> sobre o uso do PDV para emissão rápida de "
"ingressos"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid "<strong>Use QR check-ins</strong> to save time and reduce human error"
msgstr ""
"<strong>Use check-ins com QR code</strong> para economizar tempo e evitar "
"erros humanos"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Use automated emails</strong> to remind customers of their upcoming "
"tours"
msgstr ""
"<strong>Use e-mails automáticos</strong> para lembrar os clientes de suas "
"próximas excursões"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Use dashboards:</strong> Track key metrics like most popular cities "
"and languages"
msgstr ""
"<strong>Use painéis:</strong> Acompanhe métricas importantes, como as "
"cidades e os idiomas mais populares"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Website</strong>: Build attractive pages to present your tours and "
"convert visitors into customers."
msgstr ""
"<strong>Site</strong>: Crie páginas atraentes para apresentar seus passeios "
