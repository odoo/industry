#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid "Appointments App Documentation"
msgstr "Documentación sobre Citas"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"Appointments allow visitors to book private tours by date, language, or "
"guide availability."
msgstr ""
"Las citas permiten que los visitantes reserven recorridos privados por "
"fecha, idioma o guía disponible."

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.homepage
