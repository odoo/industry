#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Accounting</strong>: Automate invoices, reconcile payments, and "
"track profitability per tour type"
msgstr ""
"<strong>Contabilidad</strong>: Automatiza tus facturas, concilia pagos y "
"lleva control de la rentabilidad de cada tipo de recorrido"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Activate the multilingual website setting to localize your website "
"to international audiences.</strong>"
msgstr ""
"<strong>Activa la función de varios idiomas en tu sitio web y localízalo "
"para audiencias internacionales.</strong>"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Appointments</strong>: Allow customers to book private tours based "
"on availability and language preferences."
msgstr ""
"<strong>Citas</strong>: Permite que los clientes reserven recorridos "
"privados según tu disponibilidad y sus preferencias de idioma."

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid "<strong>Apps &amp; What They Do:</strong>"
msgstr "<strong>Aplicaciones y sus funciones:</strong>"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Create services</strong> for each destination &amp; language pair"
msgstr "<strong>Crea servicios</strong> para cada destino e idioma"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Create visually rich pages</strong> with images, videos, and tour "
"descriptions"
msgstr ""
"<strong>Crea páginas visuales</strong> con imágenes, videos y descripciones "
"de los recorridos"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Customers book online</strong> and receive <strong>automated "
"reminders</strong>"
msgstr ""
"<strong>Los clientes reservan en línea</strong> y reciben "
"<strong>recordatorios automáticos</strong>"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid "<strong>Customize layouts easily</strong> using drag-and-drop editor"
msgstr ""
"<strong>Personaliza diseños con facilidad</strong> con el editor de "
"arrastrar y soltar"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Dashboards</strong>: Visualize your KPIs—bookings per guide, top-"
"selling tours, revenue trends"
msgstr ""
"<strong>Tableros</strong>: Visualiza las métricas de tus reservaciones por "
"guía, recorridos más vendidos y tendencias de ingresos"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Define each tour</strong> as an event with time slots and capacities"
msgstr ""
"<strong>Define cada recorrido</strong> como un evento con horarios y "
"capacidades"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid "<strong>Define guide availability</strong> per service"
msgstr "<strong>Define la disponibilidad de guías</strong> por servicio"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Digital tickets with QR codes</strong> for easy on-site check-in"
msgstr ""
"<strong>Boletos digitales con códigos QR</strong> para agilizar el registro "
"en el lugar"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Enable online booking &amp; payment</strong>, no manual follow-up "
"needed"
msgstr ""
"<strong>Activa la reservación y el pago en línea</strong> y olvídate de "
"realizar seguimiento manual"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Events</strong>: Set up group tours with schedules and manage "
"bookings and attendance."
msgstr ""
"<strong>Eventos</strong>: Configura recorridos grupales con horarios y "
"gestiona las reservaciones y la asistencia."

#. module: guided_tours
#: model_terms:event.event,description:guided_tours.event_event_2
msgid ""
"<strong>Ghent</strong> is the kind of city that sneaks up on you — and "
"steals your heart. A vibrant mix of gothic spires, canalside charm, artistic "
"rebellion, and youthful energy, Ghent is one of Belgium’s best-kept secrets… "
"though the word is definitely getting out."
msgstr ""
"<strong>Gante</strong> es el tipo de ciudad que se convierte en una de tus "
"favoritas. Debido a una vibrante mezcla de torres góticas, canales "
"encantadores, rebeldía artística y energía juvenil, Gante es uno de los "
"secretos mejor guardados de Bélgica... aunque cada vez más gente lo descubre."

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid "<strong>Handle walk-in traffic</strong> efficiently with synced stock"
msgstr ""
"<strong>Atiende visitas que no tienen cita</strong> de forma eficiente y "
"mantén tus existencias sincronizadas"

#. module: guided_tours
#: model_terms:event.event,description:guided_tours.event_event_1
#: model_terms:event.event,description:guided_tours.event_event_2
#: model_terms:event.event,description:guided_tours.event_event_3
#: model_terms:event.event,description:guided_tours.event_event_4
msgid "<strong>Included</strong>"
msgstr "<strong>¿Qué incluye?</strong>"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Integrate booking buttons</strong> directly with group or private "
"tour modules"
msgstr ""
"<strong>Integra los botones de reservación</strong> en los módulos de "
"recorridos grupales o privados"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.ir_ui_view_3841
msgid "<strong>Join Our Guided Group Tours — Discover More Together</strong>"
msgstr ""
"<strong>Únete a nuestros recorridos grupales guiados y descubramos más "
"juntos</strong>"

#. module: guided_tours
#: model_terms:event.event,description:guided_tours.event_event_1
#: model_terms:event.event,description:guided_tours.event_event_2
#: model_terms:event.event,description:guided_tours.event_event_3
#: model_terms:event.event,description:guided_tours.event_event_4
msgid "<strong>Not included</strong>"
msgstr "<strong>No incluido</strong>"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid "<strong>Open POS session</strong> and view tour availabilities"
msgstr ""
"<strong>Abre una sesión de Punto de venta</strong> y consulta la "
"disponibilidad de tus recorridos"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid "<strong>Optimize SEO</strong> to attract tourists searching online"
msgstr ""
"<strong>Optimiza el SEO</strong> para atraer a los turistas que hacen sus "
"búsquedas en línea"

#. module: guided_tours
#: model_terms:event.event,description:guided_tours.event_event_1
#: model_terms:event.event,description:guided_tours.event_event_2
#: model_terms:event.event,description:guided_tours.event_event_3
#: model_terms:event.event,description:guided_tours.event_event_4
msgid "<strong>Our offering</strong><br>"
msgstr "<strong>Nuestra oferta</strong><br>"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Point of Sale</strong>: Sell tickets in person, print receipts, and "
"manage real-time tour availabilities."
msgstr ""
"<strong>Punto de venta</strong>: Vende boletos de forma presencial, imprime "
"recibos y gestiona la disponibilidad de los recorridos en tiempo real."

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid "<strong>Print receipts</strong> with booking details"
msgstr "<strong>Imprime recibos</strong> con los detalles de la reservación"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Recruitment</strong>: Manage applications and onboarding for new "
"tour guides"
msgstr ""
"<strong>Reclutamiento</strong>: Gestiona las postulaciones y la capacitación "
"de los nuevos guías turísticos"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Regularly update website content</strong> with new tours, seasonal "
"offerings, and high-quality visuals"
msgstr ""
"<strong>Actualiza el contenido del sitio web de forma regular</strong> con "
"nuevos recorridos, ofertas de temporada y material visual de alta calidad"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid "<strong>Reminders &amp; confirmation emails</strong> reduce no-shows"
msgstr ""
"<strong>Los recordatorios y correos de confirmación</strong> reducen las "
"inasistencias"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid "<strong>Sell remaining spots</strong> for today’s tours or future ones"
msgstr ""
"<strong>Vende los lugares restantes</strong> para los recorridos de hoy o "
"los próximos"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Social Marketing</strong>: Schedule and post on social media to "
"boost tour visibility"
msgstr ""
"<strong>Redes sociales</strong>: Programa y publica en redes sociales para "
"aumentar la visibilidad de los recorridos"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Surveys</strong>: Gather guest feedback after each tour to "
"continuously improve"
msgstr ""
"<strong>Encuestas</strong>: Consigue los comentarios de los asistentes "
"después de cada recorrido para mejorar de manera continua"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Track attendance live</strong> from a mobile device or the "
"attendances app"
msgstr ""
"<strong>Lleva seguimiento de la asistencia en vivo</strong> desde un "
"dispositivo móvil o desde la aplicación Asistencias"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid "<strong>Train staff</strong> on using POS for quick ticketing"
msgstr ""
"<strong>Capacita al personal</strong> para que usen Punto de venta y emitan "
"boletos de forma rápida"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid "<strong>Use QR check-ins</strong> to save time and reduce human error"
msgstr ""
"<strong>Usa registros con código QR</strong> para ahorrar tiempo y reducir "
"errores humanos"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Use automated emails</strong> to remind customers of their upcoming "
"tours"
msgstr ""
"<strong>Usa correos automatizados</strong> para recordarle los próximos "
"recorridos a tus clientes"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Use dashboards:</strong> Track key metrics like most popular cities "
"and languages"
msgstr ""
"<strong>Usa Tableros:</strong> Lleva seguimiento de métricas clave como las "
"ciudades y los idiomas más populares"

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.welcome_article_body
msgid ""
"<strong>Website</strong>: Build attractive pages to present your tours and "
"convert visitors into customers."
msgstr ""
"<strong>Sitio web</strong>: Crea páginas llamativas para mostrar tus "
"recorridos y convertir a los visitantes en clientes."

#. module: guided_tours
#: model_terms:ir.ui.view,arch_db:guided_tours.ir_ui_view_3841
msgid "A relaxed pace with time for photos, fun facts, and local tips"
msgstr ""
"Un ritmo relajado con tiempo para fotos, datos curiosos y consejos locales"

