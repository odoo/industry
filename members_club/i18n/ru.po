msgstr ""
"Вечер включает в себя непринужденную беседу у камина, сессию вопросов и "
"ответов с аудиторией и время для общения с коллегами по клубу за напитками."

#. module: members_club
#: model_terms:product.public.category,website_description:members_club.product_public_category_3
msgid "Thoughtful presents for every occasion."
msgstr "Продуманные подарки на любой случай."

#. module: members_club
#: model_terms:ir.ui.view,arch_db:members_club.welcome_article_body
msgid ""
