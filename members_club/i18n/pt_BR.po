#. module: members_club
#: model_terms:ir.ui.view,arch_db:members_club.homepage
msgid "<strong>Are partnerships with other clubs approved?</strong>"
msgstr "<strong>As parcerias com outros clubes são aprovadas?</strong>"

#. module: members_club
#: model_terms:ir.ui.view,arch_db:members_club.welcome_article_body
msgid ""
"<strong>Audience Segmentation:</strong> Target specific groups—like VIP "
"members or recent joiners—for more personalized outreach."
msgstr ""
"<strong>Segmentação de público-alvo:</strong> Segmente grupos específicos - "
"como membros VIP ou novos - para um alcance mais personalizado."

#. module: members_club
#: model_terms:ir.ui.view,arch_db:members_club.welcome_article_body
msgid ""
"<strong>Automate Your Renewals</strong><br/>\n"
"                <br/>\n"
"                Set up automatic reminders and renewal workflows in the "
"Subscription app to avoid missed payments and lapses in membership. Combine "
"it with automated email marketing to re-engage members who haven't renewed."
msgstr ""
"<strong>Automatize suas renovações</strong><br/>\n"
"                <br/>\n"
"                Configure lembretes automáticos e fluxos de trabalho de "
"renovação no aplicativo Assinaturas para não perder prazos de pagamento e "
"ficar sem sua associação. Combine isso com marketing por e-mail para "
"reengajar os membros que não renovaram."

#. module: members_club
#: model_terms:ir.ui.view,arch_db:members_club.welcome_article_body
msgid ""
"<strong>Automated Billing &amp; Invoicing:</strong> Reduce administrative "
"overhead by automating invoicing and payment reminders."
msgstr ""
"<strong>Faturamento e Cobranças automatizados:</strong> Reduza a sobrecarga "
"administrativa automatizando o faturamento e os lembretes de pagamento."

#. module: members_club
#: model_terms:ir.ui.view,arch_db:members_club.welcome_article_body
msgid ""
"<strong>Branded Products:</strong> Offer branded items like t-shirts, mugs, "
"or event tickets in your online shop."
msgstr ""
"<strong>Produtos da marca:</strong> Ofereça itens como camisetas, canecas ou "
"ingressos para eventos em sua loja on-line."

#. module: members_club
#: model_terms:ir.ui.view,arch_db:members_club.welcome_article_body
msgid "<strong>Bundle Memberships with Exclusive Products or Events</strong>"
msgstr "<strong>Agrupe associações com produtos ou eventos exclusivos</strong>"

#. module: members_club
#: model_terms:ir.ui.view,arch_db:members_club.welcome_article_body
msgid ""
"<strong>CRM Integration:</strong> Capture new leads directly from event sign-"
"ups and follow up post-event."
msgstr ""
"<strong>Integração do CRM:</strong> Capture novos leads pelas inscrições no "
"evento e faça o acompanhamento após o evento."

#. module: members_club
#: model_terms:ir.ui.view,arch_db:members_club.homepage
msgid "<strong>Can you trust our community partners?</strong>"
msgstr "<strong>Os parceiros da nossa cominidade são confiáveis?</strong>"

#. module: members_club
#: model_terms:ir.ui.view,arch_db:members_club.welcome_article_body
msgid ""
"<strong>Churn Reduction:</strong> Use metrics and automatic follow-ups to "
"reduce cancellations and boost renewals."
msgstr ""
"<strong>Redução de cancelamentos:</strong> Use métricas e acompanhamentos "
"automáticos para reduzir os cancelamentos e aumentar as renovações."

#. module: members_club
#: model_terms:ir.ui.view,arch_db:members_club.welcome_article_body
msgid ""
"<strong>Coupons &amp; Promotions:</strong> Launch exclusive offers and "
"campaigns to drive traffic and sales."
msgstr ""
"<strong>Cupons e Promoções:</strong> Lance ofertas e campanhas exclusivas "
"para impulsionar o tráfego e as vendas."

#. module: members_club
#: model_terms:ir.ui.view,arch_db:members_club.welcome_article_body
msgid ""
"<strong>Email Campaigns:</strong> Announce new events, welcome new members, "
"or send newsletters with beautifully designed emails."
msgstr ""
"<strong>Campanhas de e-mail:</strong> Anuncie novos eventos, dê as boas-"
"vindas a novos membros ou envie newsletters com e-mails de design atraente."

#. module: members_club
#: model_terms:ir.ui.view,arch_db:members_club.welcome_article_body
msgid ""
"<strong>Event Management:</strong> Plan and manage seminars, galas, "
"tournaments, or online webinars with ease."
msgstr ""
"<strong>Gerenciamento de eventos:</strong> Planeje e gerencie seminários, "
"galas, torneios ou webinários on-line com facilidade."

#. module: members_club
#: model_terms:ir.ui.view,arch_db:members_club.welcome_article_body
msgid ""
"<strong>Event Pages:</strong> Automatically create sleek event pages with "
"schedules, speaker bios, and registration forms."
msgstr ""
"<strong>Páginas de eventos:</strong> Crie belas páginas de eventos "
"automaticamente e inclua as programações, biografias de palestrantes e "
"formulários de inscrição."

#. module: members_club
#: model_terms:ir.ui.view,arch_db:members_club.welcome_article_body
msgid ""
"<strong>Flexible Plans:</strong> Create different subscription models—"
"monthly, annual, family, student, etc."
msgstr ""
"<strong>Planos flexíveis:</strong> Crie diferentes modelos de assinatura - "
"mensal, anual, familiar, estudantil, etc."

#. module: members_club
#: model_terms:ir.ui.view,arch_db:members_club.welcome_article_body
msgid ""
"<strong>Follow-Ups and Reminders:</strong> Automate communications for "
"membership expirations, event invitations, and special announcements to keep "
"your community engaged."
msgstr ""
"<strong>Acompanhamento e lembretes:</strong> Automatize as comunicações "
"sobre vencimentos de associação, convites para eventos e outros anúncios "
"para manter sua comunidade engajada."

#. module: members_club
#: model_terms:event.event,description:members_club.event_event_1
msgid "<strong>Free for members | Guests €30</strong>"
msgstr "<strong>Gratuito para membros | Convidados € 30</strong>"

#. module: members_club
#: model_terms:ir.ui.view,arch_db:members_club.homepage
msgid "<strong>How is your privacy protected?</strong>"
msgstr "<strong>Como protegemos sua privacidade?</strong>"

#. module: members_club
#: model_terms:ir.ui.view,arch_db:members_club.welcome_article_body
msgid ""
"<strong>Integrated Contact Forms:</strong> Connect your forms directly to "
"your CRM pipeline to follow up with interest."
msgstr ""
"<strong>Formulários de contato integrados:</strong> Conecte seus formulários "
"diretamente ao seu funil do CRM para acompanhar o interesse."

#. module: members_club
#: model_terms:ir.ui.view,arch_db:members_club.homepage
msgid "<strong>Is the membership process straightforward?</strong>"
msgstr "<strong>O processo de associação é simples?</strong>"

#. module: members_club
#: model_terms:ir.ui.view,arch_db:members_club.welcome_article_body
msgid ""
"<strong>Lead Management:</strong> Track incoming requests, categorize "
"potential members, and nurture them through a personalized onboarding "
"journey."
msgstr ""
"<strong>Gerenciamento de leads:</strong> Rastreie as solicitações recebidas, "
"categorize os membros em potencial e incentive-os com uma jornada de "
"integração personalizada."

#. module: members_club
#: model_terms:ir.ui.view,arch_db:members_club.welcome_article_body
msgid ""
"<strong>Marketing Automation:</strong> Trigger actions based on user behavior"
"—for example, follow up with visitors who abandon their subscription cart."
msgstr ""
"<strong>Automação de marketing:</strong> Acione ações com base no "
"comportamento do usuário - por exemplo, envie mensagens a visitantes que "
"abandonam um carrinho com assinatura."

#. module: members_club
#: model_terms:ir.ui.view,arch_db:members_club.welcome_article_body
msgid ""
"<strong>Member Portal:</strong> Let members log in to view their "
"subscriptions, past orders, and upcoming events."
msgstr ""
"<strong>Portal do membro:</strong> Permita que os membros façam login para "
"visualizar suas assinaturas, pedidos anteriores e eventos futuros."

#. module: members_club
#: model_terms:ir.ui.view,arch_db:members_club.welcome_article_body
msgid ""
"<strong>Membership Database:</strong> Manage your current members in one "
"place—view statuses, membership levels, renewal dates, and more."
msgstr ""
"<strong>Base de dados de associação:</strong> Gerencie os sócios atuais em "
"um só lugar - visualize status, níveis de associação, datas de renovação e "
"muito mais."

#. module: members_club
#: model_terms:ir.ui.view,arch_db:members_club.welcome_article_body
msgid ""
"<strong>Memberships in the Shop:</strong> Sell memberships just like products"
"—visitors can sign up and pay online in minutes."
msgstr ""
"<strong>Associações na loja:</strong> Venda associações como se fossem "
"produtos - os visitantes podem se inscrever e pagar on-line em minutos."

#. module: members_club
#: model_terms:blog.post,content:members_club.blog_post_1
msgid ""
"<strong>Next up:</strong> Stay tuned for our <em>Silent Mornings</em> pilot "
"sessions launching in June—quiet co-working, guided journaling, and "
"intentional starts to the day."
msgstr ""
"<strong>Próximo evento:</strong> Fique de olho no lançamento das sessões-"
"piloto de <em>Manhãs silenciosas</em> em junho — trabalho em equipe "
"silencioso, diário guiado e início intencional do dia."

#. module: members_club
#: model_terms:ir.ui.view,arch_db:members_club.welcome_article_body
msgid ""
"<strong>Opportunities &amp; Upsells:</strong> Identify and follow up on "
"upselling opportunities such as premium memberships or VIP event passes."
msgstr ""
"<strong>Oportunidades e upsells:</strong> Identifique e acompanhe as "
"oportunidades de upselling, como associações premium ou passes para eventos "
"VIP."

#. module: members_club
#: model_terms:ir.ui.view,arch_db:members_club.welcome_article_body
msgid ""
"<strong>SEO &amp; Analytics:</strong> Optimize visibility and track visitor "
"behavior to keep improving."
msgstr ""
"<strong>SEO e Analítica:</strong> Otimize a visibilidade e acompanhe o "
"comportamento dos visitantes para continuar melhorando."

#. module: members_club
#: model_terms:event.event,description:members_club.event_event_1
msgid "<strong>Schedule</strong>"
msgstr "<strong>Cronograma</strong>"

#. module: members_club
#: model_terms:ir.ui.view,arch_db:members_club.welcome_article_body
msgid ""
"<strong>Segment Your Community for Better Engagement</strong><br/>\n"
"                <br/>\n"
"                Use tags and filters in the <strong>CRM</strong> and "
"<strong>Email Marketing</strong> apps to segment your members based on "
"interests, membership tier, or activity. This lets you send targeted "
"campaigns and event invitations\n"
"                that feel personal."
msgstr ""
"<strong>Segmente sua comunidade para melhorar o envolvimento</strong><br/>\n"
"<br/>\n"
" Use marcadores e filtros nos aplicativos <strong>CRM</strong> e "
"<strong>Marketing e-mail</strong> para segmentar seus membros com base em "
"interesses, nível de associação ou atividade. Isso permite que você envie "
"campanhas direcionadas e convites para eventos\n"
" com maior personalização."

#. module: members_club
#: model_terms:ir.ui.view,arch_db:members_club.welcome_article_body
msgid ""
"<strong>Self-Service Portal:</strong> Let members manage their own accounts, "
"upgrade plans, or cancel via your website."
msgstr ""
"<strong>Portal de autoatendimento:</strong> Permita que os membros gerenciem "
"suas próprias contas, atualizem ou cancelem planos pelo site."

#. module: members_club
#: model_terms:ir.ui.view,arch_db:members_club.welcome_article_body
msgid ""
"<strong>Social Media Dashboard:</strong> Schedule posts, track engagement, "
"and manage your platforms in one place."
msgstr ""
"<strong>Painel de redes sociais:</strong> Programe postagens, acompanhe o "
"engajamento e gerencie suas plataformas em um só lugar."

#. module: members_club
#: model_terms:ir.ui.view,arch_db:members_club.welcome_article_body
msgid ""
"<strong>Ticketing System:</strong> Set up ticket tiers, early bird "
"discounts, and QR-code-based check-ins."
msgstr ""
"<strong>Sistema de emissão de chamados:</strong> Configure níveis de "
"chamados, descontos e check-ins baseados em código QR."

#. module: members_club
#: model_terms:ir.ui.view,arch_db:members_club.welcome_article_body
msgid "<strong>Tips for success</strong>"
msgstr "<strong>Dicas para o sucesso</strong>"

#. module: members_club
#: model_terms:ir.ui.view,arch_db:members_club.welcome_article_body
msgid "<strong>Track Key Metrics in Real Time</strong>"
msgstr "<strong>Acompanhe as principais métricas em tempo real</strong>"

#. module: members_club
#: model_terms:ir.ui.view,arch_db:members_club.welcome_article_body
msgid "<strong>Use the Sign App for Smooth Onboarding</strong>"
msgstr ""
"<strong>Use o aplicativo Assinar para simplificar o processo de associação</"
"strong>"

#. module: members_club
#: model_terms:ir.ui.view,arch_db:members_club.welcome_article_body
