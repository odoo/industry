msgid "<span class=\"h1-fs\"><strong>Basics</strong></span>"
msgstr "<span class=\"h1-fs\"><strong>ພື້ນຖານ</strong></span>"

#. module: wellness_practitioner
#: model_terms:ir.ui.view,arch_db:wellness_practitioner.welcome_article_body
msgid "<span class=\"h1-fs\"><strong>Do you want to go further?</strong></span>"
msgstr ""
"<span class=\"h1-fs\"><strong>ທ່ານຕ້ອງການໄປໃຫ້ໄກກວ່ານີ້ບໍ່?</strong></span>"

#. module: wellness_practitioner
#: model_terms:ir.ui.view,arch_db:wellness_practitioner.welcome_article_body
msgid ""
"<strong>1. Canned responses</strong><br/><br/>Click \"<strong>Send "
"message</strong>\", then type <strong>\"::\"</strong> in the message content"
" to display canned responses in the system. Then just select the one you "
"want, click send, and the customer receives the message! It's that easy! "
"<br/><br/>"
msgstr ""
"<strong>1. ຂໍ້ຄວາມທີ່ຕອບໄວ້ລ່ວງໜ້າ</strong><br/><br/>ຄລິກ \"<strong>ສົ່ງຂໍ້ຄວາມ</strong>"
"\", ແລ້ວພິມ <strong>\"::\"</strong> ໃນເນື້ອຫາຂໍ້ຄວາມເພື່ອສະແດງຂໍ້ຄວາມທີ່ຕອບໄວ້ລ່ວງໜ້າໃນລະບົ"
"ບ. ຈາກນັ້ນເລືອກອັນທີ່ທ່ານຕ້ອງການ, ຄລິກສົ່ງ, ແລະ ລູກຄ້າຈະໄດ້ຮັບຂໍ້ຄວາມທັນທີ! ມັນງ່າຍດາຍຫຼາຍ! <br/>"
"<br/>"

#. module: wellness_practitioner
#: model_terms:ir.ui.view,arch_db:wellness_practitioner.welcome_article_body
msgid "<strong>2. Email templates</strong>"
msgstr "<strong>2. ຕົວແບບອີເມລ</strong>"

#. module: wellness_practitioner
#: model_terms:ir.ui.view,arch_db:wellness_practitioner.welcome_article_body
msgid ""
"<strong><font class=\"text-black\"><span style=\"font-weight: normal\"><b>CRM App</b>: Nurture long-term relationships by tracking client interactions, preferences, and\n"
"                follow-up reminders in one central hub.</span></font><font class=\"text-o-color-1\"/></strong><br/>"
msgstr ""
"<strong><font class=\"text-black\"><span style=\"font-weight: normal\"><b>ແອັ"
"ບ CRM</b>: ສ້າງຄວາມສຳພັນໄລຍະຍາວໂດຍການຕິດຕາມການພົວພັນກັບລູກຄ້າ, ສິ່ງທີ່ລູກຄ້າມັກ, ແລະ\n"
"                ການແຈ້ງເຕືອນການຕິດຕາມໃນສູນກາງດຽວ.</span></font><font "
"class=\"text-o-color-1\"/></strong><br/>"

#. module: wellness_practitioner
#: model_terms:ir.ui.view,arch_db:wellness_practitioner.welcome_article_body
msgid ""
"<strong><font class=\"text-black\"><span style=\"font-weight: normal\"><b>Knowledge App</b>: Securely store and organize detailed patient notes, treatment plans, and holistic\n"
"                health records for easy reference.</span></font></strong><br/>"
msgstr ""
"<strong><font class=\"text-black\"><span style=\"font-weight: normal\"><b>ແອັບ"
"ຄັງຄວາມຮູ້</b>: ເກັບຮັກສາ ແລະ ຈັດລະບຽບບັນທຶກຂອງຄົນເຈັບ, ແຜນການປິ່ນປົວ, ແລະ ບັນທຶກ\n"
"                ສຸຂະພາບແບບອົງລວມຢ່າງປອດໄພເພື່ອໃຫ້ງ່າຍຕໍ່ການອ້າງອີງ.</span></font></"
"strong><br/>"

#. module: wellness_practitioner
#: model_terms:ir.ui.view,arch_db:wellness_practitioner.welcome_article_body
msgid ""
"<strong><span class=\"display-4-fs\">Odoo for Therapy "
"Practices</span></strong>"
msgstr ""
"<strong><span class=\"display-4-fs\">Odoo ສຳລັບການບໍລິການບຳບັດສຸຂະພາບ</span></"
"strong>"

#. module: wellness_practitioner
#: model_terms:ir.ui.view,arch_db:wellness_practitioner.welcome_article_body
msgid ""
"<strong>Email templates </strong>can be set up in the Email Templates "
"technical menu. To access it, admins can enable debug mode and search for "
"the \"Email Templates\" menu from the homescreen."
msgstr ""
"<strong>ຕົວແບບອີເມລ </strong>ສາມາດຕັ້ງຄ່າໄດ້ໃນເມນູ Email Templates. ເພື່ອເຂົ້າເຖິງ, ຜູ້ດູແລລ"
"ະບົບສາມາດເປີດໂໝດ debug ແລະ ຄົ້ນຫາເມນູ \"Email Templates\" ຈາກໜ້າຫຼັກ."

#. module: wellness_practitioner
#: model_terms:ir.ui.view,arch_db:wellness_practitioner.welcome_article_body
msgid ""
"A free, personalized, integrated<strong><font class=\"text-o-color-1\"> "
"Website </font></strong>in a few clicks. Get new leads or direct appointment"
" online in a few clicks."
msgstr ""
"ສ້າງ <strong><font class=\"text-o-color-1\"> ເວັບໄຊ </font></strong> ທີ່ປັບແຕ່ງໄດ້ ແ"
"ລະ ເຊື່ອມຕໍ່ກັນໄດ້ຟຣີໃນບໍ່ກີ່ຄລິກ. ຮັບລູກຄ້າໃໝ່ ຫຼື ໃຫ້ມີການນັດໝາຍໂດຍກົງທາງອອນລາຍຢ່າງງ່າຍດາຍ."

#. module: wellness_practitioner
#: model_terms:ir.ui.view,arch_db:wellness_practitioner.welcome_article_body
msgid "Add an upfront payment in your Appointment Type."
msgstr "ເພີ່ມການຊຳລະເງິນລ່ວງໜ້າໃນປະເພດການນັດໝາຍຂອງທ່ານ."

#. module: wellness_practitioner
#: model_terms:ir.ui.view,arch_db:wellness_practitioner.welcome_article_body
msgid ""
"Add the Subscription App and invoice automatically based on a subscription "
"type."
msgstr "ເພີ່ມແອັບການຈອງສະມາຊິກ ແລະ ອອກໃບບິນໂດຍອັດຕະໂນມັດຕາມປະເພດການສະໝັກ."

#. module: wellness_practitioner
#: model_terms:ir.ui.view,arch_db:wellness_practitioner.welcome_article_body
msgid ""
"After each appointment, you can use the <strong>same methods </strong>to "
"plan your next session with your patient."
msgstr ""
"ຫຼັງຈາກການນັດໝາຍແຕ່ລະຄັ້ງ, ທ່ານສາມາດໃຊ້ <strong>ວິທີການດຽວກັນ </strong>ເພື່ອວາງແຜນການບຳບັດຄັ້"
"ງຕໍ່ໄປກັບຄົນເຈັບຂອງທ່ານ."

#. module: wellness_practitioner
#: model_terms:ir.ui.view,arch_db:wellness_practitioner.welcome_article_body
msgid ""
"Alternatively, you can also use the \"Log Note\" button on your contacts or "
"create a specific knowledge article (like this one) for each of your "
"patients."
msgstr ""
"ນອກຈາກນັ້ນ, ທ່ານຍັງສາມາດໃຊ້ປຸ່ມ \"Log Note\" ໃນລາຍຊື່ຜູ້ຕິດຕໍ່ ຫຼື ສ້າງບົດຄວາມຄວາມຮູ້ສະເພາະ (ຄືກັບບົ"
"ດຄວາມນີ້) ສຳລັບຄົນເຈັບແຕ່ລະຄົນ."

#. module: wellness_practitioner
#: model_terms:ir.ui.view,arch_db:wellness_practitioner.welcome_article_body
msgid ""
"Any meeting within Odoo contains a \"Notes\" field. Type, upload images, "
"create tables, and much more."
msgstr ""
"ທຸກໆການປະຊຸມໃນ Odoo ຈະມີຊ່ອງ \"ບັນທຶກ\". ທ່ານສາມາດພິມ, ອັບໂຫລດຮູບພາບ, ສ້າງຕາຕະລາງ ແລະ ອື່ນ"
"ໆອີກຫຼາຍຢ່າງ."

#. module: wellness_practitioner
