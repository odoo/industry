#. module: wellness_practitioner
#: model_terms:ir.ui.view,arch_db:wellness_practitioner.welcome_article_body
msgid ""
"<b>Appointments App</b>: Offer seamless online booking for consultations and "
"sessions, allowing clients to schedule\n"
"                time with you 24/7."
msgstr ""
"<b>App Compromissos</b>: Ofereça agendamentos online sem complicações para "
"consultas e sessões, permitindo que os clientes marquem horários com você 24 "
"horas por dia, 7 dias por semana."

#. module: wellness_practitioner
#: model_terms:ir.ui.view,arch_db:wellness_practitioner.welcome_article_body
msgid ""
"<b>Calendar App</b>: Manage your daily schedule efficiently, avoiding double "
"bookings and ensuring you have adequate\n"
"                preparation time between clients."
msgstr ""
"<b>App Calendário</b>: Gerencie sua agenda diária com eficiência, evitando "
"agendamentos duplicados e garantindo que você tenha tempo suficiente para se "
"preparar entre um cliente e outro."

#. module: wellness_practitioner
#: model_terms:ir.ui.view,arch_db:wellness_practitioner.welcome_article_body
#, fuzzy
msgid ""
"<b>Contacts App</b>: Maintain a clean and organized directory of all your "
"clients, suppliers, and professional\n"
"                partners."
msgstr ""
"<b>App Contatos</b>: mantenha um diretório limpo e organizado de todos os "
"seus clientes, fornecedores e parceiros profissionais."

#. module: wellness_practitioner
#: model_terms:ir.ui.view,arch_db:wellness_practitioner.welcome_article_body
#, fuzzy
msgid ""
"<b>Invoicing App</b>: Simplify your finances by generating professional "
"invoices for sessions and packages, ensuring\n"
"                you get paid on time."
msgstr ""
"<b>App Faturamento</b>: Simplifique suas finanças gerando faturas "
"profissionais para sessões e pacotes, garantindo que você receba seus "
"pagamentos em dia."

