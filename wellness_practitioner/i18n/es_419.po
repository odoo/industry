#. module: wellness_practitioner
#: model_terms:ir.ui.view,arch_db:wellness_practitioner.welcome_article_body
msgid ""
"<b>Appointments App</b>: Offer seamless online booking for consultations and "
"sessions, allowing clients to schedule\n"
"                time with you 24/7."
msgstr ""
"<b>Citas</b>: Ofrece reservaciones en línea sin complicaciones para "
"consultas y sesiones. Permite que tus clientes agenden\n"
"            reuniones contigo las 24 horas del día, los 7 días de la semana."

#. module: wellness_practitioner
#: model_terms:ir.ui.view,arch_db:wellness_practitioner.welcome_article_body
msgid ""
"<b>Calendar App</b>: Manage your daily schedule efficiently, avoiding double "
"bookings and ensuring you have adequate\n"
"                preparation time between clients."
msgstr ""
"<b>Calendario</b>: Gestiona tu agenda diaria con eficiencia, evita "
"reservaciones dobles y asegúrate de contar con el\n"
"            tiempo de preparación adecuado entre clientes."

#. module: wellness_practitioner
#: model_terms:ir.ui.view,arch_db:wellness_practitioner.welcome_article_body
msgid ""
"<b>Contacts App</b>: Maintain a clean and organized directory of all your "
"clients, suppliers, and professional\n"
"                partners."
msgstr ""
"<b>Contactos</b>: Mantén un directorio limpio y organizado de todos tus "
"clientes, proveedores y socios\n"
"                    profesionales."

#. module: wellness_practitioner
#: model_terms:ir.ui.view,arch_db:wellness_practitioner.welcome_article_body
msgid ""
"<b>Invoicing App</b>: Simplify your finances by generating professional "
"invoices for sessions and packages, ensuring\n"
"                you get paid on time."
msgstr ""
"<b>Facturación</b>: Simplifica tus finanzas y genera facturas profesionales "
"para sesiones y paquetes, así\n"
"                    siempre recibirás tus pagos a tiempo."

