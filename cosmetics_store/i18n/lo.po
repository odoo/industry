msgstr "<u>ວັນສຸກ</u><br/>8.00 ໂມງເຊົ້າ-6.00 ໂມງແລງ"

#. module: cosmetics_store
#: model_terms:ir.ui.view,arch_db:cosmetics_store.ir_ui_view_2258
msgid "<u>Monday</u><br/>8.00am-6.00pm"
msgstr "<u>ວັນຈັນ</u><br/>8.00 ໂມງເຊົ້າ-6.00 ໂມງແລງ"

#. module: cosmetics_store
#: model_terms:ir.ui.view,arch_db:cosmetics_store.ir_ui_view_2258
