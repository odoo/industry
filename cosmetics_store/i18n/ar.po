#. module: cosmetics_store
#: model_terms:ir.ui.view,arch_db:cosmetics_store.welcome_article_body
msgid ""
"Monitor your carbon footprint, ethical sourcing, and sustainable goals with "
"the <strong>ESG app</strong>."
msgstr ""
"راقب بصمتك الكربونية ومصادر التوريد الصديقة للبيئة وأهداف الاستدامة باستخدام "
"<strong>تطبيق ESG</strong>."

#. module: cosmetics_store
#: model:product.template,name:cosmetics_store.product_template_11
