<?xml version='1.0' encoding='UTF-8'?>
<odoo noupdate="1">
    <record id="documents.mail_documents_activity_data_Inbox" model="mail.activity.type" forcecreate="1">
        <field name="name">Inbox</field>
        <field name="res_model">documents.document</field>
    </record>
    <record id="sale.mail_act_sale_upsell" model="mail.activity.type" forcecreate="1">
        <field name="name">Order Upsell</field>
        <field name="icon">fa-line-chart</field>
        <field name="res_model">sale.order</field>
    </record>
    <record id="account_reports.tax_closing_activity_type" model="mail.activity.type" forcecreate="1">
        <field name="name">Tax Report</field>
        <field name="summary">Tax Report</field>
        <field name="res_model">account.journal</field>
        <field name="category">tax_report</field>
    </record>
    <record id="documents.mail_documents_activity_data_md" model="mail.activity.type" forcecreate="1">
        <field name="name">Requested Document</field>
        <field name="delay_from">current_date</field>
        <field name="res_model">documents.document</field>
        <field name="chaining_type">trigger</field>
        <field name="triggered_next_type_id" ref="documents.mail_documents_activity_data_Inbox"/>
        <field name="category">upload_file</field>
    </record>
</odoo>
