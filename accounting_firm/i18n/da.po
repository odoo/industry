#: model_terms:ir.ui.view,arch_db:accounting_firm.welcome_article_body
msgid "🎓 CRM"
msgstr "🎓 CRM"

#. module: accounting_firm
#: model_terms:ir.ui.view,arch_db:accounting_firm.welcome_article_body
msgid "🎓 Documents"
msgstr "🎓 Dokumenter"

#. module: accounting_firm
#: model_terms:ir.ui.view,arch_db:accounting_firm.welcome_article_body
msgid "🎓 Invoicing"
msgstr "🎓 Fakturering"

#. module: accounting_firm
#: model_terms:ir.ui.view,arch_db:accounting_firm.welcome_article_body
msgid "🎓 Project"
msgstr "🎓 Projekt"

#. module: accounting_firm
#: model_terms:ir.ui.view,arch_db:accounting_firm.welcome_article_body
msgid "🎓 Project Dashboard"
msgstr "🎓 Projekt-dashboard"

#. module: accounting_firm
#: model_terms:ir.ui.view,arch_db:accounting_firm.welcome_article_body
msgid "🎓 Sales"
msgstr "🎓 Salg"

