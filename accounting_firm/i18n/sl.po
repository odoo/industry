msgstr "🎓 Dokumenti"

#. module: accounting_firm
#: model_terms:ir.ui.view,arch_db:accounting_firm.welcome_article_body
msgid "🎓 Invoicing"
msgstr "🎓 Izdajanje računov"

#. module: accounting_firm
#: model_terms:ir.ui.view,arch_db:accounting_firm.welcome_article_body
msgid "🎓 Project"
msgstr "🎓 Projekt"

#. module: accounting_firm
#: model_terms:ir.ui.view,arch_db:accounting_firm.welcome_article_body
msgid "🎓 Project Dashboard"
msgstr "🎓 Nadzorna plošča projekta"

#. module: accounting_firm
#: model_terms:ir.ui.view,arch_db:accounting_firm.welcome_article_body
msgid "🎓 Sales"
msgstr "🎓 Prodaja"

