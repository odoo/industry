#: model_terms:ir.ui.view,arch_db:accounting_firm.welcome_article_body
msgid "🎓 Documents"
msgstr "🎓 Documents"

#. module: accounting_firm
#: model_terms:ir.ui.view,arch_db:accounting_firm.welcome_article_body
msgid "🎓 Invoicing"
msgstr "🎓 Facturation"

#. module: accounting_firm
#: model_terms:ir.ui.view,arch_db:accounting_firm.welcome_article_body
msgid "🎓 Project"
msgstr "🎓 Projet"

#. module: accounting_firm
#: model_terms:ir.ui.view,arch_db:accounting_firm.welcome_article_body
msgid "🎓 Project Dashboard"
msgstr "🎓 Tableau de bord Projet"

#. module: accounting_firm
#: model_terms:ir.ui.view,arch_db:accounting_firm.welcome_article_body
msgid "🎓 Sales"
msgstr "🎓 Ventes"

