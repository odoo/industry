#. module: accounting_firm
#: model_terms:ir.ui.view,arch_db:accounting_firm.welcome_article_body
#, fuzzy
msgid ""
"<b>Accounting App</b>: Streamline your billing cycle and manage the firm's "
"own financials with robust invoicing tools."
msgstr ""
"<b>Účtovná aplikácia</b>: Zefektívnite svoj fakturačný cyklus a spravujte "
"financie firmy pomocou robustných nástrojov na fakturáciu."

#. module: accounting_firm
#: model_terms:ir.ui.view,arch_db:accounting_firm.welcome_article_body
#, fuzzy
msgid ""
"<b>Contacts App</b>: Centralize all client data and maintain a clean, "
"organized directory of customers and contacts."
msgstr ""
"<b>Aplikácia Kontakty</b>: Centralizujte všetky údaje o klientoch a "
"udržiavajte prehľadný a organizovaný adresár zákazníkov a kontaktov."

#. module: accounting_firm
#: model_terms:ir.ui.view,arch_db:accounting_firm.welcome_article_body
#, fuzzy
msgid ""
"<b>Databases App</b>: Access and interact with your clients' Odoo databases "
"instantly from a single dashboard."
msgstr ""
"<b>Aplikácia Databázy</b>: Okamžitý prístup a interakcia s databázami Odoo "
"vašich klientov z jediného riadiaceho panela."

#. module: accounting_firm
#: model_terms:ir.ui.view,arch_db:accounting_firm.welcome_article_body
#, fuzzy
msgid ""
"<b>Documents App</b>: Automate the request, collection, and management of "
"client files for a paperless office."
msgstr ""
"<b>Aplikácia Dokumenty</b>: Automatizujte žiadosti, zber a správu súborov "
"klientov pre bezpapierovú kanceláriu."

#. module: accounting_firm
#: model_terms:ir.ui.view,arch_db:accounting_firm.welcome_article_body
#, fuzzy
msgid ""
"<b>Equity App</b>: Simplify compliance by gathering and visualizing Ultimate "
"Beneficial Owners (UBOs) structures."
msgstr ""
"<b>Aplikácia Správa kapitálu</b>: Zjednodušte dodržiavanie predpisov "
"zhromažďovaním a vizualizáciou štruktúr konečných vlastníkov (UBO)."

#. module: accounting_firm
#: model_terms:ir.ui.view,arch_db:accounting_firm.welcome_article_body
#, fuzzy
msgid ""
"<b>Project App</b>: Organize client files, track tasks, and manage your "
"team's workload to meet every deadline."
msgstr ""
"<b>Aplikácia Projekt:</b> Usporiadajte súbory klientov, sledujte úlohy a "
"spravujte pracovnú záťaž svojho tímu, aby ste stihli všetky termíny."

#. module: accounting_firm
#: model_terms:ir.ui.view,arch_db:accounting_firm.welcome_article_body
#, fuzzy
msgid ""
"<b>Sign App</b>: Accelerate approvals and agreements by capturing secure "
"electronic document signatures instantly."
msgstr ""
"<b>Aplikácia E-podpis</b>: Urýchlite schvaľovanie a uzatváranie zmlúv "
"prostredníctvom okamžitého zaznamenávania bezpečných elektronických podpisov "
"dokumentov."

#. module: accounting_firm
#: model_terms:ir.ui.view,arch_db:accounting_firm.welcome_article_body
#, fuzzy
msgid ""
"<b>Timesheets App</b>: Track billable hours with precision and analyze your "
"team's efforts for better profitability."
msgstr ""
"<b>Aplikácia Pracovné výkazy</b>: Presne sledujte fakturovateľné hodiny a "
"analyzujte výkonnosť svojho tímu s cieľom dosiahnuť vyššiu ziskovosť."

