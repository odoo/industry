#. module: accounting_firm
#: model_terms:ir.ui.view,arch_db:accounting_firm.welcome_article_body
msgid ""
"<b>Accounting App</b>: Streamline your billing cycle and manage the firm's "
"own financials with robust invoicing tools."
msgstr ""
"<b>Aplicación Contabilidad</b>: optimiza tu ciclo de facturación y gestiona "
"las finanzas de la empresa con maravillosas y útiles herramientas de "
"facturación."

#. module: accounting_firm
#: model_terms:ir.ui.view,arch_db:accounting_firm.welcome_article_body
msgid ""
"<b>Contacts App</b>: Centralize all client data and maintain a clean, "
"organized directory of customers and contacts."
msgstr ""
"<b>Aplicación Contactos</b>: centraliza todos los datos de los clientes y "
"mantén un directorio limpio y organizado de clientes y contactos."

#. module: accounting_firm
#: model_terms:ir.ui.view,arch_db:accounting_firm.welcome_article_body
msgid ""
"<b>Databases App</b>: Access and interact with your clients' Odoo databases "
"instantly from a single dashboard."
msgstr ""
"<b>Aplicación Bases de datos</b>: accede instantáneamente a las bases de "
"datos de Odoo de tus clientes e interactúa con estas desde un solo tablero."

#. module: accounting_firm
#: model_terms:ir.ui.view,arch_db:accounting_firm.welcome_article_body
msgid ""
"<b>Documents App</b>: Automate the request, collection, and management of "
"client files for a paperless office."
msgstr ""
"<b>Aplicación Documentos</b>: automatiza la solicitud, recopilación y "
"gestión de archivos de clientes para digitalizar tus operaciones."

#. module: accounting_firm
#: model_terms:ir.ui.view,arch_db:accounting_firm.welcome_article_body
msgid ""
"<b>Equity App</b>: Simplify compliance by gathering and visualizing Ultimate "
"Beneficial Owners (UBOs) structures."
msgstr ""
"Aplicación <b>Patrimonio neto</b>: simplifica el cumplimiento normativo "
"mediante la recopilación y visualización de las estructuras de los titulares "
"reales (UBO)."

#. module: accounting_firm
#: model_terms:ir.ui.view,arch_db:accounting_firm.welcome_article_body
msgid ""
"<b>Project App</b>: Organize client files, track tasks, and manage your "
"team's workload to meet every deadline."
msgstr ""
"<b>Aplicacion Proyectos</b>: organiza los archivos de los clientes, realiza "
"un seguimiento de las tareas y gestiona la carga de trabajo de tu equipo "
"para cumplir todos los plazos."

#. module: accounting_firm
#: model_terms:ir.ui.view,arch_db:accounting_firm.welcome_article_body
msgid ""
"<b>Sign App</b>: Accelerate approvals and agreements by capturing secure "
"electronic document signatures instantly."
msgstr ""
"<b>Aplicación Firma electrónica</b>: agiliza aprobaciones y acuerdos "
"mediante la captura instantánea de firmas electrónicas seguras."

#. module: accounting_firm
#: model_terms:ir.ui.view,arch_db:accounting_firm.welcome_article_body
msgid ""
"<b>Timesheets App</b>: Track billable hours with precision and analyze your "
"team's efforts for better profitability."
msgstr ""
"<b>Aplicación Partes de horas</b>: realiza un seguimiento preciso de las "
"horas facturables y analiza el trabajo del equipo para mejorar la "
"rentabilidad."

