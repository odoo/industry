#. module: accounting_firm
#: model_terms:ir.ui.view,arch_db:accounting_firm.welcome_article_body
msgid ""
"<b>Accounting App</b>: Streamline your billing cycle and manage the firm's "
"own financials with robust invoicing tools."
msgstr ""
"<b>Contabilidad</b>: Optimiza tu ciclo de facturación y gestiona las "
"finanzas de la empresa con maravillosas y útiles herramientas de facturación."

#. module: accounting_firm
#: model_terms:ir.ui.view,arch_db:accounting_firm.welcome_article_body
msgid ""
"<b>Contacts App</b>: Centralize all client data and maintain a clean, "
"organized directory of customers and contacts."
msgstr ""
"<b>Contactos</b>: Centraliza todos los datos de clientes y mantén un "
"directorio claro y organizado de clientes y contactos."

#. module: accounting_firm
#: model_terms:ir.ui.view,arch_db:accounting_firm.welcome_article_body
msgid ""
"<b>Databases App</b>: Access and interact with your clients' Odoo databases "
"instantly from a single dashboard."
msgstr ""
"<b>Bases de datos</b>: Accede e interactúa al instante con las bases de "
"datos de Odoo de tus clientes desde un solo tablero."

#. module: accounting_firm
#: model_terms:ir.ui.view,arch_db:accounting_firm.welcome_article_body
msgid ""
"<b>Documents App</b>: Automate the request, collection, and management of "
"client files for a paperless office."
msgstr ""
"<b>Documentos</b>: Automatiza la solicitud, recopilación y gestión de "
"archivos de clientes para digitalizar tus operaciones."

#. module: accounting_firm
#: model_terms:ir.ui.view,arch_db:accounting_firm.welcome_article_body
msgid ""
"<b>Equity App</b>: Simplify compliance by gathering and visualizing Ultimate "
"Beneficial Owners (UBOs) structures."
msgstr ""
"<b>Patrimonio</b>: Simplifica el cumplimiento normativo al recopilar y "
"visualizar estructuras de beneficiarios finales."

#. module: accounting_firm
#: model_terms:ir.ui.view,arch_db:accounting_firm.welcome_article_body
msgid ""
"<b>Project App</b>: Organize client files, track tasks, and manage your "
"team's workload to meet every deadline."
msgstr ""
"<b>Proyectos</b>: Organiza archivos de clientes, lleva seguimiento de las "
"tareas y gestiona la carga de trabajo del equipo para cumplir todas las "
"fechas límites."

#. module: accounting_firm
#: model_terms:ir.ui.view,arch_db:accounting_firm.welcome_article_body
msgid ""
"<b>Sign App</b>: Accelerate approvals and agreements by capturing secure "
"electronic document signatures instantly."
msgstr ""
"<b>Firma electrónica</b>: Agiliza las aprobaciones y los acuerdos al "
"capturar firmas electrónicas seguras en documentos al instante."

#. module: accounting_firm
#: model_terms:ir.ui.view,arch_db:accounting_firm.welcome_article_body
msgid ""
"<b>Timesheets App</b>: Track billable hours with precision and analyze your "
"team's efforts for better profitability."
msgstr ""
"<b>Registro de horas</b>: Registra las horas facturables con precisión y "
"analiza el trabajo del equipo para mejorar la rentabilidad."

