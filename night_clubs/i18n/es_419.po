#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong><span class=\"h2-fs\">Tips for Success</span></strong>"
msgstr "<strong><span class=\"h2-fs\">Consejos para triunfar</span></strong>"

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Accounting</strong>: Keep finances under control with automated "
"invoicing, reconciliations, and reporting."
msgstr ""
"<strong>Contabilidad</strong>: Mantén tus finanzas bajo control con "
"facturación automatizada, conciliaciones y reportes."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Analytics</strong>: Measure engagement, clicks, and follower growth."
msgstr ""
"<strong>Analítica</strong>: Mide las interacciones, los clics y el "
"crecimiento de tus seguidores."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>Apps &amp; What They Do:</strong>"
msgstr "<strong>Aplicaciones y sus funciones:</strong>"

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Automate confirmations</strong>: Set up email templates for tickets "
"to save staff time and improve customer experience."
msgstr ""
"<strong>Automatiza las confirmaciones</strong>: Configura plantillas de "
"correo en los boletos para ahorrarle tiempo a tu personal y mejorar la "
"experiencia de tus clientes."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Email Marketing</strong>: Send newsletters to announce new events or "
"loyalty discounts."
msgstr ""
"<strong>Marketing por correo</strong>: Envía boletines para anunciar nuevos "
"eventos o descuentos por lealtad."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Emails</strong>: Configure automatic confirmation emails with event "
"details."
msgstr ""
"<strong>Correos</strong>: Configura correos electrónicos de confirmación "
"automáticos con los detalles del evento."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>Engagement features to use:</strong>"
msgstr "<strong>Funciones para interacción que puedes usar:</strong>"

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Events</strong>: Manage schedules, bookings, and attendee check-ins."
msgstr ""
"<strong>Eventos</strong>: Gestiona horarios, reservaciones y registros de "
"asistentes."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Events</strong>: Set up event categories (VIP vs. General "
"Admission), manage capacities, and track attendees."
msgstr ""
"<strong>Eventos </strong>: Establece categorías del evento (como VIP o "
"Admisión general), gestiona capacidades y rastrea a los asistentes."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>How to optimize bar operations:</strong>"
msgstr "<strong>Cómo optimizar las operaciones del bar:</strong>"

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Integration</strong>: Link with Inventory for accurate stock levels."
msgstr ""
"<strong>Integración</strong>: Vincúlate con Inventario para tener niveles de "
"stock correctos."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Integration</strong>: Publish simultaneously across multiple "
"platforms."
msgstr ""
"<strong>Integración</strong>: Publica en varias plataformas de forma "
"simultánea."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Inventory sync</strong>: Automatic stock updates when items are sold."
msgstr ""
"<strong>Sincronización de inventario</strong>: Actualizaciones de "
"existencias automáticas al vender artículos."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Inventory</strong>: Track every bottle, mixer, and accessory in real "
"time."
msgstr ""
"<strong>Inventario</strong>: Monitorea cada botella, mezclador y accesorio "
"en tiempo real."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>Key features to use:</strong>"
msgstr "<strong>Funciones clave que puedes usar:</strong>"

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Multiple bars</strong>: Configure separate PoS for each bar station."
msgstr ""
"<strong>Varios bares</strong>: Configura estaciones separadas de Punto de "
"venta para cada bar."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Payments</strong>: Accept multiple methods (cash, card, mobile "
"payments)."
msgstr ""
"<strong>Pagos</strong>: Acepta varios métodos (efectivo, tarjeta, pagos con "
"celular)."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Payroll</strong>: Manage staff salaries, bonuses, and contracts "
"seamlessly."
msgstr ""
"<strong>Nómina</strong>: Gestiona los sueldos del personal, bonos y "
"contratos de manera sencilla."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Plan shifts with Planning</strong>: Organize staff schedules and "
"ensure enough people at the bar, entrance, and security."
msgstr ""
"<strong>Planea turnos con Planeación</strong>: Organiza los horarios del "
"personal y asegúrate de tener suficientes personas en el bar, la entrada y "
"en seguridad."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Point of Sale</strong>: Add drinks as products with categories "
"(cocktails, beers, shots)."
msgstr ""
"<strong>Punto de venta</strong>: Agrega bebidas como productos y categorías "
"(cocteles, cervezas o tragos de shot)."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Point of Sale</strong>: Configure products as ticket types for on-"
"the-spot sales."
msgstr ""
"<strong>Punto de venta</strong>: Configura productos como tipos de boletos "
"para ventas en el momento."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Point of Sale</strong>: Sell tickets or drinks at the entrance and "
"bar with seamless payments."
msgstr ""
"<strong>Punto de venta</strong>: Vende boletos o bebidas en la entrada y el "
"bar con pagos sencillos."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Purchase</strong>: Automate supplier management and resupply of "
"drinks and consumables."
msgstr ""
"<strong>Compra</strong>: Automatiza la gestión de proveedores y el "
"reabastecimiento de bebidas y productos consumibles."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>QR Codes</strong>: Scan at the entrance for seamless check-ins."
msgstr ""
"<strong>Códigos QR</strong>: Escanéalos en la entrada para acceso rápido."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Reorder rules</strong>: Automatically trigger replenishments when "
"stock falls below thresholds."
msgstr ""
"<strong>Reglas de reordenamiento</strong>: Activa reabastecimientos de forma "
"automática cuando las existencias caigan por debajo del mínimo."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Reports</strong>: Track how many people bought tickets at the door."
msgstr ""
"<strong>Reportes</strong>: Rastrea cuántas personas compraron boletos en la "
"puerta del lugar."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>Scheduling</strong>: Plan posts around key events."
msgstr ""
"<strong>Programación</strong>: Planea publicaciones cerca de las fechas de "
"eventos clave."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Screens</strong>: Use touchscreens or tablets for fast order-taking."
msgstr ""
"<strong>Pantallas</strong>: Usa pantallas táctiles o tabletas para tomar "
"órdenes de forma rápida."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Segment fans</strong>: Use Social Marketing and Email Marketing to "
"target VIPs differently from casual visitors."
msgstr ""
"<strong>Segmentación de aficionados</strong>: Usa Redes sociales y Marketing "
"por correo para interactuar con las personas VIP de forma diferente a los "
"visitantes casuales."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Social Marketing</strong>: Boost visibility with integrated "
"campaigns on Instagram, Facebook, YouTube, and X."
msgstr ""
"<strong>Redes sociales</strong>: Aumenta la visibilidad con campañas "
"integradas en Instagram, Facebook, YouTube y X (Twitter)."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>Suppliers</strong>: Save vendor details for quick reordering."
msgstr ""
"<strong>Proveedores</strong>: Guarda los detalles del proveedor para "
"reordenamiento rápido."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Targeting</strong>: Tailor campaigns for VIP guests vs. general "
"audience."
msgstr ""
"<strong>Segmentación</strong>: Personaliza campañas para invitados VIP y la "
"audiencia general."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Tracking</strong>: Monitor costs per supplier and optimize "
"negotiations."
msgstr ""
"<strong>Rastreo</strong>: Monitorea costos por proveedor y optimiza "
"organizaciones."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Use Dashboards</strong>: Create tailored dashboards to track "
"revenue, ticket sales, bar performance, and costs at a glance."
msgstr ""
"<strong>Usa Tableros</strong>: Crea tableros personalizados para monitorear "
"los ingresos, ventas de boletos, rendimiento del bar y costos al instante."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>Ways to leverage Odoo Purchase:</strong>"
msgstr "<strong>Formas de usar Compras de Odoo:</strong>"

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Website</strong>: Design a branded landing page for upcoming events "
"with integrated e-commerce checkout."
msgstr ""
"<strong>Sitio web</strong>: Diseña una página de inicio que demuestre tu "
"marca para próximos eventos con el proceso de pago integrado a Comercio "
"electrónico."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Website</strong>: Sell event tickets online and deliver "
"confirmations with QR codes."
msgstr ""
"<strong>Sitio web</strong>: Vende boletos para el evento en línea y envía "
"confirmaciones con códigos QR."

