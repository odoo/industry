"👗 <strong>Dress code</strong>: Wear white or neon — the lights will do the "
"rest"
msgstr ""
"👗 <strong>Quy định trang phục</strong>: Mặc trang phục màu trắng hoặc neon "
"— ánh sáng sẽ làm phần còn lại"

#. module: night_clubs
#: model_terms:event.event,description:night_clubs.event_event_2
msgid "👟 <strong>Dress code</strong>: Streetwear, sneakers, keep it fresh"
msgstr ""
"👟 <strong>Quy định trang phục</strong>: Trang phục đường phố, giày thể "
"thao, giữ phong cách tươi mới"

#. module: night_clubs
#: model_terms:event.event,description:night_clubs.event_event_3
msgid ""
"💃 <strong>Atmosphere</strong>: Couples spinning, hips shaking, tropical "
"rhythms"
msgstr ""
"💃 <strong>Không khí</strong>: Các cặp đôi xoay tròn, hông lắc lư, nhịp điệu "
"nhiệt đới"

#. module: night_clubs
#: model_terms:event.event,description:night_clubs.event_event_3
msgid "💃 Latin Fever Friday"
msgstr "💃 Thứ Sáu Sốt Latin"

#. module: night_clubs
#: model_terms:event.event,description:night_clubs.event_event_1
msgid ""
"💡 <strong>Atmosphere</strong>: UV lights, neon décor, glowing accessories"
msgstr ""
"💡 <strong>Không gian</strong>: Đèn UV, trang trí neon, phụ kiện phát sáng"

#. module: night_clubs
#: model_terms:event.event,description:night_clubs.event_event_2
msgid ""
"💡 <strong>Atmosphere</strong>: Urban beats, flashing lights, pure energy on "
"the dance floor"
msgstr ""
"💡 <strong>Không khí</strong>: Nhịp điệu đô thị, ánh sáng nhấp nháy, năng "
"lượng thuần khiết trên sàn nhảy"

#. module: night_clubs
#: model_terms:event.event,description:night_clubs.event_event_1
msgid "💫 Tickets are limited — secure yours now and let’s glow!"
msgstr "💫 Số lượng vé có hạn — hãy đặt vé ngay và cùng nhau tỏa sáng!"

#. module: night_clubs
#: model_terms:event.event,description:night_clubs.event_event_2
msgid ""
"🔥 <strong>Vibes</strong>: Booming bass, freestyle drops, and MCs hyping the "
"crowd"
msgstr ""
"🔥 <strong>Vibes</strong>: Âm bass mạnh mẽ, những đoạn drop tự do và các MC "
"khuấy động đám đông"

#. module: night_clubs
#: model_terms:event.event,description:night_clubs.event_event_3
msgid "🔥 Secure your ticket now and join the fiesta!"
msgstr "🔥 Đặt vé ngay và tham gia lễ hội!"
