#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong><span class=\"h2-fs\">Tips for Success</span></strong>"
msgstr "<strong><span class=\"h2-fs\">Başarı İçin İpuçları</span></strong>"

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Accounting</strong>: Keep finances under control with automated "
"invoicing, reconciliations, and reporting."
msgstr ""
"<strong>Muhasebe</strong>: Otomatik faturalama, mutabakatlar ve raporlama "
"ile finansmanı kontrol altında tutun."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Analytics</strong>: Measure engagement, clicks, and follower growth."
msgstr ""
"<strong>Analytics</strong>: Etkileşimi, tıklamaları ve takipçi büyümesini "
"takip edin."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>Apps &amp; What They Do:</strong>"
msgstr "<strong>Uygulamalar &amp; Ne Yapıyorlar?</strong>"

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Automate confirmations</strong>: Set up email templates for tickets "
"to save staff time and improve customer experience."
msgstr ""
"<strong>Onayları otomatikleştirin</strong>: Personelin zamanından tasarruf "
"etmek ve müşteri deneyimini iyileştirmek için e-posta bilet şablonları "
"oluşturun."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Email Marketing</strong>: Send newsletters to announce new events or "
"loyalty discounts."
msgstr ""
"<strong>E-posta Pazarlama</strong>: Yeni etkinlikleri veya sadakat "
"indirimlerini duyurmak için haber bültenleri gönderin."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Emails</strong>: Configure automatic confirmation emails with event "
"details."
msgstr ""
"<strong>E-postalar</strong>: Etkinlik ayrıntılarını içeren otomatik onay e-"
"postalarını yapılandırın."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>Engagement features to use:</strong>"
msgstr "<strong>Katılımı artırmak için kullanılacak özellikler:</strong>"

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Events</strong>: Manage schedules, bookings, and attendee check-ins."
msgstr ""
"<strong>Etkinlikler</strong>: Programları, rezervasyonları ve katılımcı "
"check-in'lerini yönetin."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Events</strong>: Set up event categories (VIP vs. General "
"Admission), manage capacities, and track attendees."
msgstr ""
"<strong>Etkinlikler</strong>: Etkinlik kategorilerini ayarlayın (VIP ve "
"Genel Kabul), kapasiteleri yönetin ve katılımcıları takip edin."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>How to optimize bar operations:</strong>"
msgstr "<strong>Bar operasyonları nasıl optimize edilir?</strong>"

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Integration</strong>: Link with Inventory for accurate stock levels."
msgstr ""
"<strong>Entegrasyon</strong>: Doğru stok seviyeleri için envanter ile "
"bağlantı kurun."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Integration</strong>: Publish simultaneously across multiple "
"platforms."
msgstr ""
"<strong>Entegrasyon</strong>: Birden fazla platformda aynı anda yayınlayın."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Inventory sync</strong>: Automatic stock updates when items are sold."
msgstr ""
"<strong>Envanter senkronizasyonu</strong>: Ürünler satıldığında otomatik "
"stok güncellemeleri."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Inventory</strong>: Track every bottle, mixer, and accessory in real "
"time."
msgstr ""
"<strong>Envanter</strong>: Her şişeyi, karıştırıcıyı ve aksesuarı gerçek "
"zamanlı olarak takip edin."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>Key features to use:</strong>"
msgstr "<strong>Kullanılacak temel özellikler:</strong>"

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Multiple bars</strong>: Configure separate PoS for each bar station."
msgstr ""
"<strong>Birden fazla bar</strong>: Her bar istasyonu için ayrı Satış Noktası "
"yapılandırın."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Payments</strong>: Accept multiple methods (cash, card, mobile "
"payments)."
msgstr ""
"<strong>Ödemeler</strong>: Birden fazla yöntemi kabul edin (nakit, kart, "
"mobil ödemeler)."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Payroll</strong>: Manage staff salaries, bonuses, and contracts "
"seamlessly."
msgstr ""
"<strong>Bordro</strong>: Personel maaşlarını, ikramiyelerini ve "
"sözleşmelerini sorunsuz bir şekilde yönetin."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Plan shifts with Planning</strong>: Organize staff schedules and "
"ensure enough people at the bar, entrance, and security."
msgstr ""
"<strong>Planlama uygulaması ile vardiyaları planlayın</strong>: Personel "
"programlarını düzenleyerek barda, resepsiyonda ve güvenlikte yeterli sayıda "
"kişi olmasını sağlayın."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Point of Sale</strong>: Add drinks as products with categories "
"(cocktails, beers, shots)."
msgstr ""
"<strong>Satış Noktası</strong>: İçecekleri kategorilerle (kokteyller, "
"biralar, shotlar) ürün olarak ekleyin."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Point of Sale</strong>: Configure products as ticket types for on-"
"the-spot sales."
msgstr ""
"<strong>Satış Noktası</strong>: Yerinde satış için ürünleri bilet türleri "
"olarak yapılandırın."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Point of Sale</strong>: Sell tickets or drinks at the entrance and "
"bar with seamless payments."
msgstr ""
"<strong>Satış Noktası</strong>: Girişte veya barda sorunsuz ödemelerle bilet "
"veya içecek satın."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Purchase</strong>: Automate supplier management and resupply of "
"drinks and consumables."
msgstr ""
"<strong>Satın alma</strong>: Tedarikçi yönetimini ve içecek ve sarf "
"malzemelerinin yeniden tedarikini otomatikleştirin."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>QR Codes</strong>: Scan at the entrance for seamless check-ins."
msgstr ""
"<strong>QR Kodları</strong>: Sorunsuz check-in işlemleri için girişte okutun."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Reorder rules</strong>: Automatically trigger replenishments when "
"stock falls below thresholds."
msgstr ""
"<strong>Yeniden sipariş kuralları</strong>: Stok eşik değerlerin altına "
"düştüğünde siparişleri otomatik olarak yenileyin."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Reports</strong>: Track how many people bought tickets at the door."
msgstr ""
"<strong>Raporlar</strong>: Kapıda kaç kişinin bilet aldığını takip edin."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>Scheduling</strong>: Plan posts around key events."
msgstr ""
"<strong>Zamanlama</strong>: Gönderileri önemli etkinliklere göre planlayın."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Screens</strong>: Use touchscreens or tablets for fast order-taking."
msgstr ""
"<strong>Ekranlar</strong>: Hızlı sipariş almak için dokunmatik ekranları "
"veya tabletleri kullanın."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Segment fans</strong>: Use Social Marketing and Email Marketing to "
"target VIPs differently from casual visitors."
msgstr ""
"<strong>Hayranları segmentlere ayırın</strong>: VIP'leri sıradan "
"ziyaretçilerden farklı bir şekilde hedeflemek için Sosyal Medyada Pazarlama "
"ve E-posta Pazarlamasını kullanın."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Social Marketing</strong>: Boost visibility with integrated "
"campaigns on Instagram, Facebook, YouTube, and X."
msgstr ""
"<strong>Sosyal Medyada Pazarlama</strong>: Instagram, Facebook, YouTube ve "
"X'te entegre kampanyalarla görünürlüğü artırın."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>Suppliers</strong>: Save vendor details for quick reordering."
msgstr ""
"<strong>Tedarikçiler</strong>: Hızlı yeniden sipariş için satıcı "
"ayrıntılarını kaydedin."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Targeting</strong>: Tailor campaigns for VIP guests vs. general "
"audience."
msgstr ""
"<strong>Hedefleme</strong>: Kampanyaları VIP konuklara ve genel kitleye göre "
"uyarlayın."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Tracking</strong>: Monitor costs per supplier and optimize "
"negotiations."
msgstr ""
"<strong>Takip</strong>: Tedarikçi başına maliyetleri izleyin ve görüşmeleri "
"optimize edin."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Use Dashboards</strong>: Create tailored dashboards to track "
"revenue, ticket sales, bar performance, and costs at a glance."
msgstr ""
"<strong>Gösterge Panellerini Kullanın</strong>: Gelir, bilet satışları, bar "
"performansı ve maliyetleri bir bakışta izlemek için özel gösterge panelleri "
"oluşturun."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>Ways to leverage Odoo Purchase:</strong>"
msgstr "<strong>Odoo Satın Alma uygulamasından yararlanma yolları:</strong>"

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Website</strong>: Design a branded landing page for upcoming events "
"with integrated e-commerce checkout."
msgstr ""
"<strong>Web sitesi</strong>: Yaklaşan etkinlikler için, entegre e-ticaret "
"ödemesi ile yaklaşan etkinlikler için markalaştırılmış bir açılış sayfası "
"tasarlayın."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Website</strong>: Sell event tickets online and deliver "
"confirmations with QR codes."
msgstr ""
"<strong>Web sitesi</strong>: Etkinlik biletlerini çevrimiçi satın ve QR "
"kodları ile onayları iletin."

#. module: night_clubs
#: model:product.public.category,name:night_clubs.product_public_category_2
msgid "Accessories"
msgstr "Aksesuarlar"

#. module: night_clubs
#: model:event.tag.category,name:night_clubs.event_tag_category_1
msgid "Age"
msgstr "Yaş"

#. module: night_clubs
#: model:product.template,name:night_clubs.product_product_62_product_template
