#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong><span class=\"h2-fs\">Tips for Success</span></strong>"
msgstr "<strong><span class=\"h2-fs\">Dicas para o sucesso</span></strong>"

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Accounting</strong>: Keep finances under control with automated "
"invoicing, reconciliations, and reporting."
msgstr ""
"<strong>Financeiro</strong>: Mantenha suas finanças sob controle com "
"faturamento, reconciliações e relatórios automatizados."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Analytics</strong>: Measure engagement, clicks, and follower growth."
msgstr ""
"<strong>Analítico</strong>: Meça o engajamento, os cliques e o crescimento "
"do número de seguidores."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>Apps &amp; What They Do:</strong>"
msgstr "<strong>Aplicativos e para que servem:</strong>"

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Automate confirmations</strong>: Set up email templates for tickets "
"to save staff time and improve customer experience."
msgstr ""
"<strong>Automatizar confirmações</strong>: Configure modelos de e-mail para "
"ingressos para economizar tempo da equipe e melhorar a experiência do "
"cliente."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Email Marketing</strong>: Send newsletters to announce new events or "
"loyalty discounts."
msgstr ""
"<strong>Marketing por E-mail</strong>: Envie newsletters para anunciar novos "
"eventos ou descontos por fidelidade."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Emails</strong>: Configure automatic confirmation emails with event "
"details."
msgstr ""
"<strong>E-mails</strong>: Configure e-mails de confirmação automática com "
"detalhes do evento."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>Engagement features to use:</strong>"
msgstr "<strong>Recursos de engajamento a usar:</strong>"

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Events</strong>: Manage schedules, bookings, and attendee check-ins."
msgstr ""
"<strong>Eventos</strong>: Gerencie programações, reservas e check-ins de "
"participantes."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Events</strong>: Set up event categories (VIP vs. General "
"Admission), manage capacities, and track attendees."
msgstr ""
"<strong>Eventos</strong>: Configure categorias de eventos (VIP vs. Admissão "
"Geral), gerencie capacidades e acompanhe os participantes."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>How to optimize bar operations:</strong>"
msgstr "<strong>Como otimizar as operações do bar:</strong>"

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Integration</strong>: Link with Inventory for accurate stock levels."
msgstr ""
"<strong>Integração</strong>: Vincule-se ao Inventário para obter níveis de "
"estoque precisos."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Integration</strong>: Publish simultaneously across multiple "
"platforms."
msgstr ""
"<strong>Integração</strong>: Publique simultaneamente em várias plataformas."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Inventory sync</strong>: Automatic stock updates when items are sold."
msgstr ""
"<strong>Sincronização de inventário</strong>: Atualizações automáticas de "
"estoque quando os itens são vendidos."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Inventory</strong>: Track every bottle, mixer, and accessory in real "
"time."
msgstr ""
"<strong>Inventário</strong>: Rastreie cada garrafa, mixer e demais "
"acessórios em tempo real."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>Key features to use:</strong>"
msgstr "<strong>Principais recursos a usar:</strong>"

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Multiple bars</strong>: Configure separate PoS for each bar station."
msgstr ""
"<strong>Múltiplos bares</strong>: Configure um PDV separado para cada "
"estação de bar."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Payments</strong>: Accept multiple methods (cash, card, mobile "
"payments)."
msgstr ""
"<strong>Pagamentos</strong>: Aceite várias formas de pagamento (dinheiro, "
"cartão, pagamentos móveis)."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Payroll</strong>: Manage staff salaries, bonuses, and contracts "
"seamlessly."
msgstr ""
"<strong>Folha de Pagamento</strong>: Gerencie salários, bônus e contratos de "
"funcionários de maneira integrada."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Plan shifts with Planning</strong>: Organize staff schedules and "
"ensure enough people at the bar, entrance, and security."
msgstr ""
"<strong>Planeje turnos com o app Planejamento</strong>: Organize os horários "
"dos funcionários e garanta que haja pessoal suficiente no bar, na entrada e "
"na segurança."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Point of Sale</strong>: Add drinks as products with categories "
"(cocktails, beers, shots)."
msgstr ""
"<strong>Ponto de Venda</strong>: Adicione bebidas como produtos com "
"categorias (coquetéis, cervejas, shots)."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Point of Sale</strong>: Configure products as ticket types for on-"
"the-spot sales."
msgstr ""
"<strong>Ponto de Venda</strong>: Configure os produtos como tipos de "
"ingresso para vendas no local."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Point of Sale</strong>: Sell tickets or drinks at the entrance and "
"bar with seamless payments."
msgstr ""
"<strong>Ponto de Venda</strong>: Venda ingressos ou bebidas na entrada e no "
"bar, sem complicações nos pagamentos."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Purchase</strong>: Automate supplier management and resupply of "
"drinks and consumables."
msgstr ""
"<strong>Compras</strong>: Automatize a gestão de fornecedores e a reposição "
"de bebidas e consumíveis."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>QR Codes</strong>: Scan at the entrance for seamless check-ins."
msgstr ""
"<strong>Códigos QR</strong>: Digitalize na entrada para fazer o check-in sem "
"complicações."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Reorder rules</strong>: Automatically trigger replenishments when "
"stock falls below thresholds."
msgstr ""
"<strong>Regras de reposição</strong>: acione reposições automaticamente "
"quando o estoque estiver abaixo dos limites."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Reports</strong>: Track how many people bought tickets at the door."
msgstr ""
"<strong>Relatórios</strong>: Acompanhe quantas pessoas compraram ingressos "
"na bilheteria."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>Scheduling</strong>: Plan posts around key events."
msgstr ""
"<strong>Agendamento</strong>: Planeje publicações em torno de eventos "
"importantes."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Screens</strong>: Use touchscreens or tablets for fast order-taking."
msgstr ""
"<strong>Telas</strong>: Use telas sensíveis ao toque ou tablets para um "
"rápido atendimento de pedidos."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Segment fans</strong>: Use Social Marketing and Email Marketing to "
"target VIPs differently from casual visitors."
msgstr ""
"<strong>Segmente os fãs</strong>: use o Marketing de redes sociais e o "
"marketing por e-mail para direcionar os VIPs de maneira diferente dos "
"visitantes casuais."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Social Marketing</strong>: Boost visibility with integrated "
"campaigns on Instagram, Facebook, YouTube, and X."
msgstr ""
"<strong>Redes Sociais</strong>: Aumente a visibilidade com campanhas "
"integradas no Instagram, Facebook, YouTube e X."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>Suppliers</strong>: Save vendor details for quick reordering."
msgstr ""
"<strong>Fornecedores</strong>: Salve os detalhes do fornecedor para "
"facilitar novos pedidos."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Targeting</strong>: Tailor campaigns for VIP guests vs. general "
"audience."
msgstr ""
"<strong>Direcionamento para</strong>: personalize campanhas para convidados "
"VIPs e público em geral."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Tracking</strong>: Monitor costs per supplier and optimize "
"negotiations."
msgstr ""
"<strong>Acompanhamento de</strong>: Monitore os custos por fornecedor e "
"otimize as negociações."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Use Dashboards</strong>: Create tailored dashboards to track "
"revenue, ticket sales, bar performance, and costs at a glance."
msgstr ""
"<strong>Use painéis de controle</strong>: crie painéis personalizados para "
"acompanhar rapidamente a receita, a venda de ingressos, o desempenho do bar "
"e os custos."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>Ways to leverage Odoo Purchase:</strong>"
msgstr "<strong>Formas de aproveitar o Odoo Compras:</strong>"

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Website</strong>: Design a branded landing page for upcoming events "
"with integrated e-commerce checkout."
msgstr ""
"<strong>Site</strong>: Crie uma página inicial com a marca para os próximos "
"eventos, com checkout de comércio eletrônico integrado."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Website</strong>: Sell event tickets online and deliver "
"confirmations with QR codes."
msgstr ""
"<strong>Site</strong>: Venda ingressos para eventos online e envie "
"confirmações com códigos QR."

