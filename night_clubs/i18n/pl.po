#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong><span class=\"h2-fs\">Tips for Success</span></strong>"
msgstr ""
"<strong><span class=\"h2-fs\">Wskazówki jak odnieść sukces</span></strong>"

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Accounting</strong>: Keep finances under control with automated "
"invoicing, reconciliations, and reporting."
msgstr ""
"<strong>Księgowość:</strong> Miej finanse pod kontrolą dzięki "
"zautomatyzowanemu fakturowaniu, uzgodnieniom i raportom."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Analytics</strong>: Measure engagement, clicks, and follower growth."
msgstr ""
"<strong>Analityka</strong>: Mierz zaangażowanie, kliknięcia i wzrost liczby "
"obserwujących."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>Apps &amp; What They Do:</strong>"
msgstr "<strong>Aplikacje i do czego służą:</strong>"

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Automate confirmations</strong>: Set up email templates for tickets "
"to save staff time and improve customer experience."
msgstr ""
"<strong>Automatyzuj potwierdzenia</strong>: Skonfiguruj szablony e-mail "
"biletów, aby oszczędzić czas personelu i poprawić wrażenia klientów."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Email Marketing</strong>: Send newsletters to announce new events or "
"loyalty discounts."
msgstr ""
"<strong>E-mail marketing</strong>: Wysyłaj newslettery, aby ogłaszać nowe "
"wydarzenia lub zniżki lojalnościowe."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Emails</strong>: Configure automatic confirmation emails with event "
"details."
msgstr ""
"<strong>E-maile</strong>: Konfiguruj automatyczne e-maile ze szczegółami "
"wydarzenia."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>Engagement features to use:</strong>"
msgstr "<strong>Funkcje zaangażowania:</strong>"

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Events</strong>: Manage schedules, bookings, and attendee check-ins."
msgstr ""
"<strong>Wydarzenia</strong>: Zarządzaj harmonogramami, rezerwacjami i "
"rejestracją uczestników."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Events</strong>: Set up event categories (VIP vs. General "
"Admission), manage capacities, and track attendees."
msgstr ""
"<strong>Wydarzenia</strong>: Konfiguruj kategorie wydarzeń (VIP vs. wstęp "
"ogólny), zarządzaj pojemnością i śledź uczestników."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>How to optimize bar operations:</strong>"
msgstr "<strong>Jak zoptymalizować operacje na barze:</strong>"

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Integration</strong>: Link with Inventory for accurate stock levels."
msgstr ""
"<strong>Integracja</strong>: Połącz z magazynem, aby otrzymać trafne poziomy "
"magazynowe."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Integration</strong>: Publish simultaneously across multiple "
"platforms."
msgstr ""
"<strong>Integracja</strong>: Publikuj jednocześnie na wielu platformach."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Inventory sync</strong>: Automatic stock updates when items are sold."
msgstr ""
"<strong>Synchronizacja magazynu</strong>: Automatycznie aktualizacje "
"poziomów magazynowych przy sprzedaży produktów."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Inventory</strong>: Track every bottle, mixer, and accessory in real "
"time."
msgstr ""
"<strong>Magazyn</strong>: Śledź każdą butelkę, mikser i akcesorium w czasie "
"rzeczywistym."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>Key features to use:</strong>"
msgstr "<strong>Kluczowe cechy:</strong>"

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Multiple bars</strong>: Configure separate PoS for each bar station."
msgstr ""
"<strong>Wiele barów</strong>: Skonfiguruj oddzielne PoS dla każdej stacji "
"barowej."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Payments</strong>: Accept multiple methods (cash, card, mobile "
"payments)."
msgstr ""
"<strong>Płatności</strong>: Akceptuj wiele metod (gotówka, karta, płatności "
"mobilne)."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Payroll</strong>: Manage staff salaries, bonuses, and contracts "
"seamlessly."
msgstr ""
"<strong>Wynagrodzenia</strong>: Bez wysiłku zarządzaj wypłatami pracowników, "
"bonusami i umowami."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Plan shifts with Planning</strong>: Organize staff schedules and "
"ensure enough people at the bar, entrance, and security."
msgstr ""
"<strong>Planuj zmiany za pomocą Planowania</strong>: Organizuj grafiki pracy "
"i zapewnij wystarczającą liczbę osób przy barze, wejściu i ochronie."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Point of Sale</strong>: Add drinks as products with categories "
"(cocktails, beers, shots)."
msgstr ""
"<strong>Punkt Sprzedaży</strong>: Dodaj napoje jako produkty z kategoriami "
"(koktajle, piwa, shoty)."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Point of Sale</strong>: Configure products as ticket types for on-"
"the-spot sales."
msgstr ""
"<strong>Punkt Sprzedaży</strong>: Skonfiguruj produkty jako typy biletów do "
"sprzedaży na bramce."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Point of Sale</strong>: Sell tickets or drinks at the entrance and "
"bar with seamless payments."
msgstr ""
"<strong>Punkt Sprzedaży</strong>: Sprzedawaj bilety lub drinki przy wejściu "
"i na barze, dzięki łatwym płatnościom."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Purchase</strong>: Automate supplier management and resupply of "
"drinks and consumables."
msgstr ""
"<strong>Zakupy</strong>: Zautomatyzuj zarządzanie dostawcami i uzupełnianie "
"zapasów drinków i innych produktów."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>QR Codes</strong>: Scan at the entrance for seamless check-ins."
msgstr ""
"<strong>Kody QR</strong>: Skanuj przy wejściu, aby usprawnić przyjmowanie "
"gości."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Reorder rules</strong>: Automatically trigger replenishments when "
"stock falls below thresholds."
msgstr ""
"<strong>Reguły ponownego zamawiania</strong>: Automatycznie uruchamiaj "
"uzupełnienia, gdy stan magazynowy spadnie poniżej progów."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Reports</strong>: Track how many people bought tickets at the door."
msgstr "<strong>Raporty</strong>: Śledź, ile osób kupiło bilety przy wejściu."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>Scheduling</strong>: Plan posts around key events."
msgstr ""
"<strong>Planowanie</strong>: Planuj posty w czasie kluczowych wydarzeń."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Screens</strong>: Use touchscreens or tablets for fast order-taking."
msgstr ""
"<strong>Ekrany</strong>: Korzystaj z ekranów dotykowych lub tabletów, aby "
"szybko zbierać zamówienia."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Segment fans</strong>: Use Social Marketing and Email Marketing to "
"target VIPs differently from casual visitors."
msgstr ""
"<strong>Segmentuj odbiorców</strong>: Korzystaj z marketingu "
"społecznościowego i email marketingu, aby strukturyzować komunikację z "
"gośćmi VIP w odróżnieniu do zwykłych bywalców."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Social Marketing</strong>: Boost visibility with integrated "
"campaigns on Instagram, Facebook, YouTube, and X."
msgstr ""
"<strong>Marketing w mediach społecznościowych</strong>: Zwiększ widoczność "
"dzięki zintegrowanym kampaniom na Instagramie, Facebooku, YouTubie i X."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>Suppliers</strong>: Save vendor details for quick reordering."
msgstr ""
"<strong>Dostawcy</strong>: Zapisz szczegóły dostawcy, aby szybciej "
"uzupełniać towary."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Targeting</strong>: Tailor campaigns for VIP guests vs. general "
"audience."
msgstr ""
"<strong>Targeting</strong>: Dostosuj kampanie dla gości VIP vs. ogólnej "
"publiczności."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Tracking</strong>: Monitor costs per supplier and optimize "
"negotiations."
msgstr ""
"<strong>Śledzenie</strong>: Monitoruj koszty według dostawcy i optymalizuj "
"negocjacje."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Use Dashboards</strong>: Create tailored dashboards to track "
"revenue, ticket sales, bar performance, and costs at a glance."
msgstr ""
"<strong>Korzystaj z konsoli</strong>: Twórz dostosowane konsole do śledzenia "
"zysku, sprzedaży biletów, wydajności baru i wydatków."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>Ways to leverage Odoo Purchase:</strong>"
msgstr "<strong>Sposoby, na które można wykorzystać Odoo Zakupy:</strong>"

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Website</strong>: Design a branded landing page for upcoming events "
"with integrated e-commerce checkout."
msgstr ""
"<strong>Strona internetowa</strong>: Zaprojektuj stronę internetową marki, "
"na której będziesz publikować nadchodzące wydarzenia ze zintegrowaną kasą e-"
"commerce."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Website</strong>: Sell event tickets online and deliver "
"confirmations with QR codes."
msgstr ""
"<strong>Strona internetowa</strong>: Sprzedawaj bilety na wydarzenia online "
"i dostarczaj potwierdzenia z użyciem kodów QR."

#. module: night_clubs
#: model:product.public.category,name:night_clubs.product_public_category_2
msgid "Accessories"
msgstr "Akcesoria"

#. module: night_clubs
#: model:event.tag.category,name:night_clubs.event_tag_category_1
msgid "Age"
msgstr "Wiek"

#. module: night_clubs
#: model:product.template,name:night_clubs.product_product_62_product_template
msgid "Alcholic Drink 1"
msgstr "Napój alkoholowy 1"

#. module: night_clubs
#: model:product.template,name:night_clubs.product_product_61_product_template
msgid "Alcoholic Drink 2"
msgstr "Napój alkoholowy 2"

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.ir_ui_view_3858
msgid "All Parties"
msgstr "Wszystkie imprezy"

#. module: night_clubs
#: model_terms:product.template,description:night_clubs.product_product_45_product_template
msgid "All the zest without the alcohol: lime, mint, sugar, and soda over ice."
msgstr "Cały smak bez alkoholu: limonka, mięta, cukier i woda sodowa z lodem."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"Also check out Email Marketing for Email Newsletter management &amp; sending."
msgstr "Sprawdź także marketing e-mail do zarządzania i wysyłki newsletterów."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"Also use a barcode scanner to check in registered guests at the entrance "
"using the <strong>Barcode app</strong>."
msgstr ""
"Użyj również skanera kodów kreskowych, aby zameldować zarejestrowanych gości "
"przy wejściu za pomocą aplikacji <strong>Kody kreskowe</strong>."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.homepage
msgid ""
"An unforgettable nightlife experience. I highly recommend the signature "
"cocktails, simply amazing."
