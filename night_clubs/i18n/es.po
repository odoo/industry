#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong><span class=\"h2-fs\">Tips for Success</span></strong>"
msgstr "<strong><span class=\"h2-fs\">Consejos para el éxito</span></strong>"

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Accounting</strong>: Keep finances under control with automated "
"invoicing, reconciliations, and reporting."
msgstr ""
"<strong>Contabilidad</strong>: mantén tus finanzas bajo control con "
"facturación automatizada, conciliaciones e informes."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Analytics</strong>: Measure engagement, clicks, and follower growth."
msgstr ""
"<strong>Analítica</strong>: mide las interacciones, los clics y el aumento "
"de tus seguidores."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>Apps &amp; What They Do:</strong>"
msgstr "<strong>Aplicaciones y sus funciones:</strong>"

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Automate confirmations</strong>: Set up email templates for tickets "
"to save staff time and improve customer experience."
msgstr ""
"<strong>Automatiza las confirmaciones</strong>: configura plantillas de "
"correo para las entradas con el fin de ahorrarle tiempo al personal y "
"mejorar la experiencia del cliente."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Email Marketing</strong>: Send newsletters to announce new events or "
"loyalty discounts."
msgstr ""
"<strong>Marketing por correo electrónico</strong>: envía boletines "
"informativos para anunciar nuevos eventos o descuentos por fidelidad."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Emails</strong>: Configure automatic confirmation emails with event "
"details."
msgstr ""
"<strong>Correos</strong>: configura correos electrónicos de confirmación "
"automáticos con la información del evento."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>Engagement features to use:</strong>"
msgstr "<strong>Funciones para fomentar la interacción:</strong>"

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Events</strong>: Manage schedules, bookings, and attendee check-ins."
msgstr ""
"<strong>Eventos</strong>: gestiona horarios, reservas y el acceso de los "
"asistentes."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Events</strong>: Set up event categories (VIP vs. General "
"Admission), manage capacities, and track attendees."
msgstr ""
"<strong>Eventos </strong>: define categorías de evento (VIP o entrada "
"general), controla el aforo y haz seguimiento de los asistentes."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>How to optimize bar operations:</strong>"
msgstr "<strong>Cómo optimizar la operativa del bar:</strong>"

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Integration</strong>: Link with Inventory for accurate stock levels."
msgstr ""
"<strong>Integración</strong> con la aplicación Inventario para garantizar la "
"precisión del stock."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Integration</strong>: Publish simultaneously across multiple "
"platforms."
msgstr ""
"<strong>Integración</strong>: publica simultáneamente en varias plataformas."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Inventory sync</strong>: Automatic stock updates when items are sold."
msgstr ""
"<strong>Sincronización de inventario</strong>: el stock se actualiza "
"automáticamente al realizar ventas."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Inventory</strong>: Track every bottle, mixer, and accessory in real "
"time."
msgstr ""
"<strong>Inventario</strong>: realiza un seguimiento de cada botella, "
"mezclador y accesorio en tiempo real."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>Key features to use:</strong>"
msgstr "<strong>Funciones clave que puedes usar:</strong>"

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Multiple bars</strong>: Configure separate PoS for each bar station."
msgstr ""
"<strong>Múltiples barras</strong>: configura un punto de venta distinto para "
"cada barra."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Payments</strong>: Accept multiple methods (cash, card, mobile "
"payments)."
msgstr ""
"<strong>Pagos</strong>: acepta varios métodos (efectivo, tarjeta, pagos con "
"el móvil)."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Payroll</strong>: Manage staff salaries, bonuses, and contracts "
"seamlessly."
msgstr ""
"<strong>Nómina</strong>: gestiona el salario del personal, bonificaciones y "
"contratos de manera sencilla."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Plan shifts with Planning</strong>: Organize staff schedules and "
"ensure enough people at the bar, entrance, and security."
msgstr ""
"<strong>Organiza turnos de trabajo con la aplicación Planificación</strong>: "
"coordina los horarios del equipo y asegúrate de que haya suficiente personal "
"en la barra, la entrada y seguridad."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Point of Sale</strong>: Add drinks as products with categories "
"(cocktails, beers, shots)."
msgstr ""
"<strong>Punto de venta</strong>: añade bebidas como productos con categorías "
"(cócteles, cervezas o chupitos)."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Point of Sale</strong>: Configure products as ticket types for on-"
"the-spot sales."
msgstr ""
"<strong>Punto de venta</strong>: configura productos como tipos de entradas "
"para ventas in situ."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Point of Sale</strong>: Sell tickets or drinks at the entrance and "
"bar with seamless payments."
msgstr ""
"<strong>Punto de venta</strong>: vende entradas o bebidas en la zona de "
"acceso y en la barra con pagos sencillos."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Purchase</strong>: Automate supplier management and resupply of "
"drinks and consumables."
msgstr ""
"<strong>Compra</strong>: automatiza la gestión de proveedores y el "
"reabastecimiento de bebidas y consumibles."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>QR Codes</strong>: Scan at the entrance for seamless check-ins."
msgstr ""
"<strong>Códigos QR</strong>: escanéalos en la entrada para garantizar un "
"acceso rápido."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Reorder rules</strong>: Automatically trigger replenishments when "
"stock falls below thresholds."
msgstr ""
"<strong>Reglas de reposición </strong>: activa la reposición de forma "
"automática cuando las existencias caigan por debajo del mínimo."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Reports</strong>: Track how many people bought tickets at the door."
msgstr ""
"<strong>Informes</strong>: realiza un seguimiento de cuántas personas "
"compraron entradas en taquilla."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>Scheduling</strong>: Plan posts around key events."
msgstr ""
"<strong>Planificación</strong>: programa publicaciones en torno a eventos "
"clave."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Screens</strong>: Use touchscreens or tablets for fast order-taking."
msgstr ""
"<strong>Pantallas</strong>: utiliza pantallas táctiles o tablets para tomar "
"nota del pedido de forma más rápida."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Segment fans</strong>: Use Social Marketing and Email Marketing to "
"target VIPs differently from casual visitors."
msgstr ""
"<strong>Segmentación de los seguidores</strong>: utiliza las aplicaciones "
"Marketing social y Marketing por correo electrónico para interactuar con los "
"usuarios VIP y los visitantes ocasionales de manera distinta."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Social Marketing</strong>: Boost visibility with integrated "
"campaigns on Instagram, Facebook, YouTube, and X."
msgstr ""
"<strong>Redes sociales</strong>: aumenta la visibilidad con campañas "
"integradas en Instagram, Facebook, YouTube y X."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>Suppliers</strong>: Save vendor details for quick reordering."
msgstr ""
"<strong>Proveedores</strong>: guarda la información del proveedor para "
"volver a realizar pedidos mediante ese proveedor."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Targeting</strong>: Tailor campaigns for VIP guests vs. general "
"audience."
msgstr ""
"<strong>Segmentación</strong>: adapta las campañas para invitados VIP vs. "
"público general."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Tracking</strong>: Monitor costs per supplier and optimize "
"negotiations."
msgstr ""
"<strong>Seguimiento</strong>: supervisa los costes por proveedor y optimiza "
"las negociaciones."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Use Dashboards</strong>: Create tailored dashboards to track "
"revenue, ticket sales, bar performance, and costs at a glance."
msgstr ""
"<strong>Utiliza los tableros</strong>: crea tableros personalizados para "
"realizar un seguimiento de los ingresos, la venta de entradas, el "
"rendimiento de la barra y los costes."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>Ways to leverage Odoo Purchase:</strong>"
msgstr "<strong>Cómo sacarle partido a la aplicación Compras de Odoo:</strong>"

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Website</strong>: Design a branded landing page for upcoming events "
"with integrated e-commerce checkout."
msgstr ""
"<strong>Sitio web</strong>: crea una landing page personalizada para "
"próximos eventos con pago online integrado."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Website</strong>: Sell event tickets online and deliver "
"confirmations with QR codes."
msgstr ""
"<strong>Sitio web</strong>: vende entradas online para el evento y envía "
"confirmaciones mediante códigos QR."

