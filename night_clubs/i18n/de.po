#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong><span class=\"h2-fs\">Tips for Success</span></strong>"
msgstr "<strong><span class=\"h2-fs\">Tipps zum Erfolg</span></strong>"

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Accounting</strong>: Keep finances under control with automated "
"invoicing, reconciliations, and reporting."
msgstr ""
"<strong>Buchhaltung</strong>:Behalten Sie Ihre Finanzen mit automatisierter "
"Rechnungsstellung, Abstimmungen und Berichterstellung unter Kontrolle."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Analytics</strong>: Measure engagement, clicks, and follower growth."
msgstr ""
"<strong>Analysen</strong>: Messen Sie Interaktionen, Klicks und das Wachstum "
"Ihrer Follower."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>Apps &amp; What They Do:</strong>"
msgstr "<strong>Apps &amp; was sie können:</strong>"

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Automate confirmations</strong>: Set up email templates for tickets "
"to save staff time and improve customer experience."
msgstr ""
"<strong>Bestätigungen automatisieren</strong>: Richten Sie E-Mail-Vorlagen "
"für Tickets ein, um Ihren Mitarbeitern Zeit zu sparen und das Kundenerlebnis "
"zu verbessern."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Email Marketing</strong>: Send newsletters to announce new events or "
"loyalty discounts."
msgstr ""
"<strong>E-Mail-Marketing</strong>: Versenden Sie Newsletter, um über neue "
"Veranstaltungen oder Treuerabatte zu informieren."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Emails</strong>: Configure automatic confirmation emails with event "
"details."
msgstr ""
"<strong>E-Mails</strong>: Konfigurieren Sie automatische Bestätigungsmails "
"mit Veranstaltungsdetails."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>Engagement features to use:</strong>"
msgstr ""
"<strong>Zu verwendende Funktionen zur Förderung der Interaktion:</strong>"

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Events</strong>: Manage schedules, bookings, and attendee check-ins."
msgstr ""
"<strong>Veranstaltungen</strong>: Verwalten Sie Zeitpläne, Buchungen und die "
"Anmeldungen der Teilnehmer."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Events</strong>: Set up event categories (VIP vs. General "
"Admission), manage capacities, and track attendees."
msgstr ""
"<strong>Veranstaltungen</strong>: Legen Sie Veranstaltungskategorien fest "
"(VIP vs. allgemeiner Eintritt), verwalten Sie Kapazitäten und verfolgen Sie "
"die Teilnehmerzahlen."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>How to optimize bar operations:</strong>"
msgstr "<strong>Optimierung des Barbetriebs:</strong>"

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Integration</strong>: Link with Inventory for accurate stock levels."
msgstr ""
"<strong>Integration</strong>: Verknüpfen Sie Ihr Lager für genaue "
"Bestandsangaben."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Integration</strong>: Publish simultaneously across multiple "
"platforms."
msgstr ""
"<strong>Integration</strong>: Veröffentlichen Sie gleichzeitig auf mehreren "
"Plattformen."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Inventory sync</strong>: Automatic stock updates when items are sold."
msgstr ""
"<strong>Bestandsynchronisierung</strong>: Automatische "
"Bestandsaktualisierung bei Verkauf von Artikeln."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Inventory</strong>: Track every bottle, mixer, and accessory in real "
"time."
msgstr ""
"<strong>Lager</strong>: Verfolgen Sie jede Flasche, jeden Mixer und jedes "
"Zubehörteil in Echtzeit."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>Key features to use:</strong>"
msgstr "<strong>Wichtige Funktionen:</strong>"

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Multiple bars</strong>: Configure separate PoS for each bar station."
msgstr ""
"<strong>Mehrere Bars</strong>: Konfigurieren Sie für jede Bar-Station ein "
"separates Kassensystem."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Payments</strong>: Accept multiple methods (cash, card, mobile "
"payments)."
msgstr ""
"<strong>Zahlungen</strong>: Akzeptieren Sie verschiedene Zahlungsmethoden "
"(Bargeld, Karte, mobile Zahlungen)."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Payroll</strong>: Manage staff salaries, bonuses, and contracts "
"seamlessly."
msgstr ""
"<strong>Personalabrechnung</strong>: Verwalten Sie die Gehälter, Boni und "
"Verträge Ihrer Mitarbeiter reibungslos."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Plan shifts with Planning</strong>: Organize staff schedules and "
"ensure enough people at the bar, entrance, and security."
msgstr ""
"<strong>Mit Odoo Planung planen</strong>: Organisieren Sie die Dienstpläne "
"Ihrer Mitarbeiter und stellen Sie sicher, dass ausreichend Personal an der "
"Bar, am Eingang und im Sicherheitsdienst vorhanden ist."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Point of Sale</strong>: Add drinks as products with categories "
"(cocktails, beers, shots)."
msgstr ""
"<strong>Kassensystem</strong>: Fügen Sie Getränke als Produkte mit "
"Kategorien hinzu (Cocktails, Biere, Schnäpse)."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Point of Sale</strong>: Configure products as ticket types for on-"
"the-spot sales."
msgstr ""
"<strong>Kassensystem</strong>: Konfigurieren Sie Produkte als Tickettypen "
"für den Verkauf vor Ort."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Point of Sale</strong>: Sell tickets or drinks at the entrance and "
"bar with seamless payments."
msgstr ""
"<strong>Kassensystem</strong>: Verkaufen Sie Eintrittskarten oder Getränke "
"am Eingang und an der Bar mit nahtlosen Zahlungsvorgängen."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Purchase</strong>: Automate supplier management and resupply of "
"drinks and consumables."
msgstr ""
"<strong>Einkauf</strong>: Automatisieren Sie das Lieferantenmanagement und "
"die Nachlieferung von Getränken und Konsumgütern."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>QR Codes</strong>: Scan at the entrance for seamless check-ins."
msgstr ""
"<strong>QR-Codes</strong>: Scannen Sie am Eingang für einen reibungslosen "
"Eintritt."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Reorder rules</strong>: Automatically trigger replenishments when "
"stock falls below thresholds."
msgstr ""
"<strong>Nachbestellregeln</strong>: Lösen Sie automatisch Auffüllungen aus, "
"wenn der Lagerbestand unter bestimmte Schwellenwerte fällt."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Reports</strong>: Track how many people bought tickets at the door."
msgstr ""
"<strong>Berichte</strong>: Erfassen Sie, wie viele Personen Eintrittskarten "
"an der Tür erworben haben."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>Scheduling</strong>: Plan posts around key events."
msgstr ""
"<strong>Planung</strong>: Planen Sie Beiträge rund um wichtige "
"Veranstaltungen."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Screens</strong>: Use touchscreens or tablets for fast order-taking."
msgstr ""
"<strong>Bildschirme</strong>: Verwenden Sie Touchscreens oder Tablets für "
"eine schnelle Bestellannahme."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Segment fans</strong>: Use Social Marketing and Email Marketing to "
"target VIPs differently from casual visitors."
msgstr ""
"<strong>Fans segmentieren</strong>: Nutzen Sie Social Marketing und E-Mail-"
"Marketing, um VIPs anders anzusprechen als gelegentliche Besucher."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Social Marketing</strong>: Boost visibility with integrated "
"campaigns on Instagram, Facebook, YouTube, and X."
msgstr ""
"<strong>Social Marketing</strong>: Steigern Sie Ihre Sichtbarkeit mit "
"integrierten Kampagnen auf Instagram, Facebook, YouTube und X."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>Suppliers</strong>: Save vendor details for quick reordering."
msgstr ""
"<strong>Lieferanten</strong>: Speichern Sie die Daten Ihrer Lieferanten, um "
"schnell Nachbestellungen aufzugeben."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Targeting</strong>: Tailor campaigns for VIP guests vs. general "
"audience."
msgstr ""
"<strong>Zielgruppen ansprechen</strong>: Passen Sie Kampagnen für VIP-Gäste "
"und das allgemeine Publikum individuell an."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Tracking</strong>: Monitor costs per supplier and optimize "
"negotiations."
msgstr ""
"<strong>Nachverfolgung</strong>: Überwachen Sie die Kosten pro Lieferant und "
"optimieren Sie die Verhandlungen."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Use Dashboards</strong>: Create tailored dashboards to track "
"revenue, ticket sales, bar performance, and costs at a glance."
msgstr ""
"<strong>Dashboards verwenden</strong>: Erstellen Sie maßgeschneiderte "
"Dashboards, um Einnahmen, Ticketverkäufe, Barumsätze und Kosten auf einen "
"Blick zu verfolgen."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid "<strong>Ways to leverage Odoo Purchase:</strong>"
msgstr "<strong>Möglichkeiten zur Nutzung von Odoo Einkauf:</strong>"

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Website</strong>: Design a branded landing page for upcoming events "
"with integrated e-commerce checkout."
msgstr ""
"<strong>Website</strong>: Entwerfen Sie eine Landingpage für bevorstehende "
"Veranstaltungen mit integriertem E-Commerce-Kassiervorgang."

#. module: night_clubs
#: model_terms:ir.ui.view,arch_db:night_clubs.welcome_article_body
msgid ""
"<strong>Website</strong>: Sell event tickets online and deliver "
"confirmations with QR codes."
msgstr ""
"<strong>Website</strong>: Verkaufen Sie Veranstaltungstickets online und "
"versenden Sie Bestätigungen mit QR-Codes."

