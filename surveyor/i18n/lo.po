#. module: surveyor
#: model_terms:ir.ui.view,arch_db:surveyor.about-us
#: model_terms:ir.ui.view,arch_db:surveyor.homepage
msgid "<b>ABOUT US</b>"
msgstr "<b>ກ່ຽວກັບພວກເຮົາ</b>"

#. module: surveyor
#: model_terms:ir.ui.view,arch_db:surveyor.welcome_article_body
msgid ""
"<b>CRM App</b>: Track potential projects and manage relationships with developers, construction firms, and\n"
"                private property owners."
msgstr ""
"<b>ແອັບ CRM</b>: ຕິດຕາມໂຄງການທີ່ມີທ່າແຮງ ແລະ ບໍລິຫານຄວາມສຳພັນກັບຜູ້ພັດທະນາອະສັງຫາລິມະຊັບ, ບໍລິສັ"
"ດກໍ່ສ້າງ ແລະ\n"
"                ເຈົ້າຂອງຊັບສິນສ່ວນບຸກຄົນ."

#. module: surveyor
#: model_terms:ir.ui.view,arch_db:surveyor.welcome_article_body
msgid ""
"<b>Documents App</b>: Securely store, organize, and share heavy files such as topographic maps, CAD drawings,\n"
"                and compliance reports."
msgstr ""
"<b>ແອັບເອກະສານ</b>: ເກັບຮັກສາ, ຈັດລະບຽບ ແລະ ແບ່ງປັນໄຟລ໌ທີ່ມີຂະໜາດໃຫຍ່ຢ່າງປອດໄພ ເຊັ່ນ: ແຜນທີ່ພູ"
"ມສັນຖານ, ແບບແຕ້ມ CAD,\n"
"                ແລະ ບົດລາຍງານການປະຕິບັດຕາມລະບຽບການ."

#. module: surveyor
#: model_terms:ir.ui.view,arch_db:surveyor.welcome_article_body
msgid ""
"<b>Invoicing App</b>: Bill clients accurately based on project milestones or time spent on site, maintaining\n"
"                healthy cash flow."
msgstr ""
"<b>ແອັບການອອກໃບແຈ້ງໜີ້</b>: ເກັບເງິນລູກຄ້າຢ່າງຊັດເຈນຕາມຂັ້ນຕອນຂອງໂຄງການ ຫຼື ເວລາທີ່ໃຊ້ໃນພາກສະໜ"
"າມ, ເພື່ອຮັກສາ\n"
"                ກະແສເງິນສົດໃຫ້ໝັ້ນຄົງ."

#. module: surveyor
#: model_terms:ir.ui.view,arch_db:surveyor.welcome_article_body
msgid ""
"<b>Knowledge App</b>: Create a central repository for internal procedures, safety guidelines, and technical\n"
"                standards accessible to all staff."
msgstr ""
"<b>ແອັບຄວາມຮູ້</b>: ສ້າງສູນລວມຂໍ້ມູນສຳລັບຂັ້ນຕອນພາຍໃນ, ຄຳແນະນຳດ້ານຄວາມປອດໄພ ແລະ ມາດຕະຖາ"
"ນ\n"
"                ເຕັກນິກ ທີ່ພະນັກງານທຸກຄົນສາມາດເຂົ້າເຖິງໄດ້."

#. module: surveyor
#: model_terms:ir.ui.view,arch_db:surveyor.welcome_article_body
msgid ""
"<b>Planning App</b>: Optimize your field operations by visually scheduling surveyors and equipment to specific\n"
"                locations and times."
msgstr ""
"<b>ແອັບການວາງແຜນ</b>: ເພີ່ມປະສິດທິພາບການເຮັດວຽກພາກສະໜາມ ໂດຍການຈັດຕາຕະລາງນັກສຳຫຼວດ ແລະ "
"ອຸປະກອນ ໄປຍັງ\n"
"                ສະຖານທີ່ ແລະ ເວລາທີ່ກຳນົດໄວ້."

#. module: surveyor
#: model_terms:ir.ui.view,arch_db:surveyor.welcome_article_body
msgid ""
"<b>Project App</b>: Manage complex surveying sites as distinct projects, tracking tasks like initial\n"
"                measurements, data processing, and report generation."
msgstr ""
"<b>ແອັບໂຄງການ</b>: ບໍລິຫານຈັດການສະຖານທີ່ສຳຫຼວດທີ່ຊັບຊ້ອນໃຫ້ເປັນໂຄງການແຍກຕ່າງຫາກ, ຕິດຕາມວຽກງາ"
"ນຕ່າງໆ ເຊັ່ນ: ການວັດແທກ\n"
"                ເບື້ອງຕົ້ນ, ການປະມວນຜົນຂໍ້ມູນ ແລະ ການສ້າງບົດລາຍງານ."

#. module: surveyor
#: model_terms:ir.ui.view,arch_db:surveyor.welcome_article_body
msgid ""
"<b>Sales App</b>: Generate detailed proposals and contracts for surveying services, ensuring clear scope and\n"
"                pricing agreements."
msgstr ""
"<b>ແອັບການຂາຍ</b>: ສ້າງໃບສະເໜີລາຄາ ແລະ ສັນຍາທີ່ລະອຽດສຳລັບການບໍລິການສຳຫຼວດ, ເພື່ອຮັບປະກັນຂອບ"
"ເຂດວຽກ ແລະ\n"
"                ຂໍ້ຕົກລົງດ້ານລາຄາທີ່ຊັດເຈນ."

