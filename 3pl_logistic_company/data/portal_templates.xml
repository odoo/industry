<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="portal_my_home_products" model="portal.entry">
        <field name="name">Your Products</field>
        <field name="description">Manage your products and stock</field>
        <field name="url">/website/action/products</field>
        <field name="image" type="bytes" file="3pl_logistic_company/static/src/binary/ir_attachment/ir_attachment_3.png"/>
        <field name="is_config_card" eval="True"/>
    </record>

    <template id="portal_products" name="Your Products">
        <t t-call="portal.portal_layout">
            <t t-set="logged_user" t-value="request.env.user"/>
            <t t-set="user_products" t-value="request.env['stock.quant'].sudo().search([('product_id.x_owner_id', 'in', [logged_user.partner_id.id, logged_user.partner_id.parent_id.id]), ('location_id.usage', '=', 'internal'), ('quantity', '!=', '0')])"/>
            <t t-call="portal.portal_searchbar" title.translate="Products"/>
            <div t-if="not user_products" class="alert alert-info">
                There are currently no products for your account.
            </div>
            <t t-else="">
                <t t-call="portal.portal_table">
                    <thead>
                        <tr>
                            <th>Display Name</th>
                            <th>Lot</th>
                            <th>Expiration date</th>
                            <th>Available quantity</th>
                            <th>Reserved quantity</th>
                            <th>Uom</th>
                            <th>Packages</th>
                        </tr>
                    </thead>
                    <t t-foreach="user_products" t-as="stock_quant">
                        <tr>
                            <td><t t-out="stock_quant.product_id.display_name"/></td>
                            <td><t t-out="stock_quant.lot_id.name"/></td>
                            <td><t t-out="stock_quant.expiration_date"/></td>
                            <td><t t-out="stock_quant.available_quantity"/></td>
                            <td><t t-out="stock_quant.reserved_quantity"/></td>
                            <td><t t-out="stock_quant.product_id.uom_id.name"/></td>
                            <td><t t-out="stock_quant.package_id.complete_name"/></td>
                        </tr>
                    </t>
                </t>
            </t>
        </t>
    </template>
</odoo>
