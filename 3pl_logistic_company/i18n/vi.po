#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<span class=\"h6-fs\">This Odoo module <b>optimizes your logistics and "
"warehousing</b>,\n"
"                offering a complete solution to boost efficiency and "
"customer satisfaction across\n"
"                all services. It streamlines operations for everything from "
"long-term storage to\n"
"                pallet management and transport. You can effortlessly manage "
"client stock, schedule\n"
"                movements, ensure full traceability, optimize billing, and "
"provide customers with <font class=\"text-o-color-5\">real-time stock "
"visibility.</font></span>\n"
"            <br/>"
msgstr ""
"<span class=\"h6-fs\">Phân hệ Odoo này <b>tối ưu hóa hoạt động logistics và "
"kho bãi</b>,\n"
"                cung cấp giải pháp toàn diện để nâng cao hiệu quả và sự hài "
"lòng của khách hàng đối với\n"
"                tất cả dịch vụ. Nó tối ưu hóa quy trình cho mọi hoạt động từ "
"lưu trữ dài hạn đến\n"
"                quản lý pallet và vận chuyển. Bạn có thể dễ dàng quản lý "
"hàng tồn kho của khách hàng, lên lịch\n"
"                di chuyển, đảm bảo truy xuất nguồn gốc đầy đủ, tối ưu hóa "
"hóa đơn và cung cấp cho khách hàng <font class=\"text-o-color-5\">khả năng "
"theo dõi hàng tồn kho theo thời gian thực.</font></span>\n"
" <br/>"

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<span class=\"h6-fs\">Use the <b>Document</b> app to manage all your "
"internal and external\n"
"                document and use the Sign App for automated customer "
"signature</span>"
msgstr ""
"<span class=\"h6-fs\">Dùng ứng dụng <b>Tài liệu</b> để quản lý toàn bộ tài "
"liệu nội bộ và bên ngoài,\n"
"và dùng ứng dụng Ký tên để tự động hóa việc ký của khách hàng</span>"

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
