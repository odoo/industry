#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<span class=\"h6-fs\">This Odoo module <b>optimizes your logistics and "
"warehousing</b>,\n"
"                offering a complete solution to boost efficiency and "
"customer satisfaction across\n"
"                all services. It streamlines operations for everything from "
"long-term storage to\n"
"                pallet management and transport. You can effortlessly manage "
"client stock, schedule\n"
"                movements, ensure full traceability, optimize billing, and "
"provide customers with <font class=\"text-o-color-5\">real-time stock "
"visibility.</font></span>\n"
"            <br/>"
msgstr ""
"<span class=\"h6-fs\">Dette Odoo-modul <b>optimerer din logistik og "
"lagerstyring</b>,\n"
"                og tilbyder en komplet løsning til at øge effektiviteten og "
"kundetilfredsheden for\n"
"                alle tjenester. Det strømliner processerne fra "
"langtidsopbevaring til\n"
"                pallehåndtering og transport. Du kan nemt administrere "
"kundelagre, planlægge lagerbevægelser,\n"
"                sikre fuld sporbarhed, optimere faktureringen og give dine "
"kunder <font class=\"text-o-color-5\">realtidsindsigt i lagerbeholdningen.</"
"font></span>\n"
"            <br/>"

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<span class=\"h6-fs\">Use the <b>Document</b> app to manage all your "
"internal and external\n"
"                document and use the Sign App for automated customer "
"signature</span>"
msgstr ""
"<span class=\"h6-fs\">Brug <b>Dokumenterappen</b> til at administrere alle "
"dine interne og eksterne\n"
"                dokumenter, og brug e-Signaturappen til automatiseret "
"kundeunderskrivning</span>"

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<span class=\"h6-fs\">Use the <b>Purchase</b> app to manage all your "
"internal product\n"
"                purchasing.</span>"
msgstr ""
"<span class=\"h6-fs\">Brug <b>Indkøbsappen</b> til at administrere alle dine "
"interne\n"
"                produktindkøb.</span>"

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
