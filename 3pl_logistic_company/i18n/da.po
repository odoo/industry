"<span class=\"h6-fs\">Welcome to the <strong>\n"
"                    <font style=\"color: rgb(113, 75, 103);\">Odoo Logistic "
"company package</font>\n"
"                </strong>\n"
"                !</span>\n"
"            <br/>"
msgstr ""
"<span class=\"h6-fs\">Velkommen til <strong>\n"
"                    <font style=\"color: rgb(113, 75, 103);\">Odoos pakke "
"til logistikvirksomheder</font>\n"
"                </strong>\n"
"                !</span>\n"
"            <br/>"

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<span class=\"h6-fs\">When you need to manually move stock—like returning "
"items to a\n"
"                quality check location or moving products after a customer "
"validation—use an\n"
"                internal transfer.<strong/></span>\n"
"            <br/>"
msgstr ""
"<span class=\"h6-fs\">Når du skal flytte lagerbeholdningen manuelt – f.eks. "
"ved returnering af varer til et\n"
"                sted for kvalitetskontrol eller flytning af produkter efter "
"en kundevalidering – skal du bruge en\n"
"                intern overførsel.<strong/></span>\n"
"           <br/>"

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<span class=\"h6-fs\">You can add specific quality checks required by your "
"customer. For\n"
"                each check, define how it should be performed, when it "
"should be completed, and\n"
"                which samples it applies to.</span>"
msgstr ""
"<span class=\"h6-fs\">Du kan tilføje specifikke kvalitetskontroller, som din "
"kunde kræver. For\n"
"                hver kontrol skal du angive, hvordan den skal udføres, "
"hvornår den skal være afsluttet, og\n"
"                hvilke eksempler den gælder for.</span>"

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
