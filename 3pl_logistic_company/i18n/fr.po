#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<b>Available Quantity:</b> The amount of stock on hand that has not yet "
"been\n"
"                    reserved for delivery."
msgstr ""
"<b>Quantité disponible :</b> la quantité de stock disponible qui n’a pas "
"encore été\n"
"                réservée pour la livraison."

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<b>Connected Printer:</b> Automate label printing by connecting your\n"
"                            printer."
msgstr ""
"<b>Imprimante connectée :</b> Automatisez l'impression d'étiquettes en "
"connectant votre\n"
"                            imprimante."

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<b>Create Storage Categories:</b> Define\n"
"                        categories that can be linked to the capacity of one "
"or more package\n"
"                        types."
msgstr ""
"<b>Créer des catégories de stockage :</b> Définissez\n"
"                        des catégories qui peuvent être liées à la capacité "
"d’un ou plusieurs types\n"
"                        de colis."

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<b>Create your stock locations:</b> Each stock\n"
"                        location can be linked to a storage category, a "
"barcode, and a removal\n"
"                        strategy. To create or update many locations at "
"once, use the built-in\n"
"                        import/export documentation and templates."
msgstr ""
"<b>Créez vos emplacements de stock :</b> chaque emplacement de stock\n"
"                    peut être lié à une catégorie de stockage, un code-"
"barres et une stratégie de retrait.\n"
"                    pour créer ou mettre à jour de nombreux emplacements en "
"une seule fois, utilisez la\n"
"                    documentation et les modèles d’import/export intégrés."

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<b>Define your warehouse flow:</b> Update your <b>Warehouse\n"
"                        Settings</b> to choose a 1, 2, or 3-step process for "
"receiving and shipping\n"
"                        goods. This allows you to tailor the workflow to "
"your specific needs,\n"
"                        whether you prefer a simple direct transfer or a "
"more detailed multi-step\n"
"                        verification process."
msgstr ""
"<b>Définissez votre flux d’entrepôt :</b> mettez à jour vos <b>paramètres "
"d’entrepôt\n"
"                    </b> pour choisir un processus en 1, 2 ou 3 étapes pour "
"la réception et l’expédition\n"
"                    des marchandises. Cela vous permet d’adapter le flux de "
"travail à vos besoins spécifiques,\n"
"                    que vous préfériez un transfert direct simple ou un "
"processus de vérification\n"
"                     en plusieurs étapes plus détaillé."

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<b>Generate a new invoice</b> directly from the existing <b>Sales\n"
"                                    Order.</b>"
msgstr ""
"<b>Générez une nouvelle facture</b> directement depuis la <b>commande client "
"existante.</b>"

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid "<b>Going Further!</b>"
msgstr "<b>Plus d'infos</b>"

