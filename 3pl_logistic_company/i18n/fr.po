"                <font style=\"color: rgb(113, 75, 103);\">package Odoo pour "
"entreprises logistiques</font>\n"
"            </strong>\n"
"            !</span>\n"
"        <br/>"

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<span class=\"h6-fs\">When you need to manually move stock—like returning "
"items to a\n"
"                quality check location or moving products after a customer "
"validation—use an\n"
"                internal transfer.<strong/></span>\n"
"            <br/>"
msgstr ""
"<span class=\"h6-fs\">Lorsque vous devez déplacer manuellement des stocks — "
"par exemple pour renvoyer des articles vers un\n"
"            emplacement de contrôle qualité ou déplacer des produits après "
"validation client — utilisez un\n"
"            transfert interne.<strong/></span>\n"
"       <br/>"

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
