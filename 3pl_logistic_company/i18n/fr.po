#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<span class=\"h6-fs\">This Odoo module <b>optimizes your logistics and "
"warehousing</b>,\n"
"                offering a complete solution to boost efficiency and "
"customer satisfaction across\n"
"                all services. It streamlines operations for everything from "
"long-term storage to\n"
"                pallet management and transport. You can effortlessly manage "
"client stock, schedule\n"
"                movements, ensure full traceability, optimize billing, and "
"provide customers with <font class=\"text-o-color-5\">real-time stock "
"visibility.</font></span>\n"
"            <br/>"
msgstr ""
"<span class=\"h6-fs\">Ce module Odoo <b>optimise votre logistique et votre "
"stockage en entrepôt</b>,\n"
"            offrant une solution complète pour améliorer l’efficacité et la "
"satisfaction client sur\n"
"            tous les services. Il rationalise les opérations, du stockage "
"longue durée à\n"
"            la gestion des palettes et au transport. Vous pouvez facilement "
"gérer les stocks clients, planifier\n"
"            les mouvements, assurer une traçabilité complète, optimiser la "
"facturation et fournir aux clients une <font class=\"text-o-"
"color-5\">visibilité du stock en temps réel.</font></span>\n"
"       <br/>"

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<span class=\"h6-fs\">Use the <b>Document</b> app to manage all your "
"internal and external\n"
"                document and use the Sign App for automated customer "
"signature</span>"
msgstr ""
"<span class=\"h6-fs\">Utilisez l’app <b>Documents</b> pour gérer tous vos "
"documents internes et externes\n"
"            et utilisez l’app Signature pour les signatures clients "
"automatisées.</span>"

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
