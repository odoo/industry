msgid "<b>Validate</b> the quotation to finalize the sales order."
msgstr ""
"<b>Подтвердите</b> коммерческое предложение, чтобы завершить оформление "
"заказа на продажу."

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid "<b>Validate</b> the transfer."
msgstr "<b>Подтвердите</b> перемещение."

