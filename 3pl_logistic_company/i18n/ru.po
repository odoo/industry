#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<span class=\"h6-fs\">This Odoo module <b>optimizes your logistics and "
"warehousing</b>,\n"
"                offering a complete solution to boost efficiency and "
"customer satisfaction across\n"
"                all services. It streamlines operations for everything from "
"long-term storage to\n"
"                pallet management and transport. You can effortlessly manage "
"client stock, schedule\n"
"                movements, ensure full traceability, optimize billing, and "
"provide customers with <font class=\"text-o-color-5\">real-time stock "
"visibility.</font></span>\n"
"            <br/>"
msgstr ""
"<span class=\"h6-fs\">Этот модуль Odoo <b>оптимизирует логистику и складские "
"процессы</b>,\n"
"                обеспечивая комплексное решение для повышения эффективности "
"и удовлетворенности клиентов\n"
"                по всем услугам. Он упрощает управление операциями – от "
"долгосрочного хранения до\n"
"                управления палетами и транспортом. Вы сможете легко "
"управлять запасами клиентов, планировать\n"
"                перемещения, обеспечивать полную прослеживаемость, "
"оптимизировать выставление счетов и предоставлять клиентам <font "
"class=\"text-o-color-5\">данные об остатках в режиме реального времени.</"
"font></span>\n"
"            <br/>"

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<span class=\"h6-fs\">Use the <b>Document</b> app to manage all your "
"internal and external\n"
"                document and use the Sign App for automated customer "
"signature</span>"
msgstr ""
"<span class=\"h6-fs\">Используйте модуль <b>Документооборот</b> для "
"управления всеми внутренними и внешними\n"
"                документами, а модуль Подпись – для автоматического "
"получения подписи клиента.</span>"

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<span class=\"h6-fs\">Use the <b>Purchase</b> app to manage all your "
"internal product\n"
"                purchasing.</span>"
msgstr ""
"<span class=\"h6-fs\">Используйте модуль <b>Закупки</b> для управления всеми "
"внутренними закупками\n"
"                товаров.</span>"

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
