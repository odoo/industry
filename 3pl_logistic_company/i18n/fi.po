#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<span class=\"h6-fs\">This Odoo module <b>optimizes your logistics and "
"warehousing</b>,\n"
"                offering a complete solution to boost efficiency and "
"customer satisfaction across\n"
"                all services. It streamlines operations for everything from "
"long-term storage to\n"
"                pallet management and transport. You can effortlessly manage "
"client stock, schedule\n"
"                movements, ensure full traceability, optimize billing, and "
"provide customers with <font class=\"text-o-color-5\">real-time stock "
"visibility.</font></span>\n"
"            <br/>"
msgstr ""
"<span class=\"h6-fs\">Tämä Odoo-moduuli <b>optimoi logistiikan ja "
"varastoinnin</b>,\n"
"                tarjoten kattavan ratkaisun tehokkuuden sekä "
"asiakastyytyväisyyden parantamiseksi kaikissa\n"
"                palveluissa. Se virtaviivaistaa toimintoja aina "
"pitkäaikaisesta varastoinnista\n"
"                kuormalavojen hallintaan ja kuljetukseen asti. Hallinnoi "
"vaivattomasti asiakkaan varastoa, aikatauluta\n"
"                siirtoja, varmista täydellinen jäljitettävyys, optimoi "
"laskutus ja tarjoa asiakkaille <font class=\"text-o-color-5\">reaaliaikainen "
"varastonäkyvyys.</font></span>\n"
"           <br/>"

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<span class=\"h6-fs\">Use the <b>Document</b> app to manage all your "
"internal and external\n"
"                document and use the Sign App for automated customer "
"signature</span>"
msgstr ""
"<span class=\"h6-fs\">Käytä <b>Asiakirjat</b>-sovellusta kaikkien sisäisten "
"ja ulkoisten\n"
"                asiakirjojesi hallintaan sekä Allekirjoita-sovellusta "
"asiakkaidesi allekirjoitusten automatisoimiseksi.</span>"

#. module: 3pl_logistic_company
