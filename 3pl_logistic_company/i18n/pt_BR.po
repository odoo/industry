#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<span class=\"h6-fs\">This Odoo module <b>optimizes your logistics and "
"warehousing</b>,\n"
"                offering a complete solution to boost efficiency and "
"customer satisfaction across\n"
"                all services. It streamlines operations for everything from "
"long-term storage to\n"
"                pallet management and transport. You can effortlessly manage "
"client stock, schedule\n"
"                movements, ensure full traceability, optimize billing, and "
"provide customers with <font class=\"text-o-color-5\">real-time stock "
"visibility.</font></span>\n"
"            <br/>"
msgstr ""
"<span class=\"h6-fs\">Este módulo do Odoo <b>otimiza sua logística e "
"armazenamento</b>,\n"
"                oferecendo uma solução completa para aumentar a eficiência e "
"a satisfação do cliente em\n"
"                todos os serviços. Ele simplifica todas as operações, desde "
"armazenamento de longo prazo até\n"
"                gestão de paletes e transporte. Você pode gerenciar "
"facilmente o estoque do cliente, programar\n"
"                movimentações, garantir rastreabilidade total, otimizar o "
"faturamento e fornecer aos clientes <font class=\"text-o-"
"color-5\">visibilidade do estoque em tempo real.</font></span>\n"
"           <br/>"

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<span class=\"h6-fs\">Use the <b>Document</b> app to manage all your "
"internal and external\n"
"                document and use the Sign App for automated customer "
"signature</span>"
msgstr ""
"<span class=\"h6-fs\">Use o aplicativo <b>Documentos</b> para gerenciar "
"todos os seus documentos internos e externos, e use o aplicativo Assinar "
"para automatizar a assinatura do cliente.</span>"

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<span class=\"h6-fs\">Use the <b>Purchase</b> app to manage all your "
"internal product\n"
"                purchasing.</span>"
msgstr ""
"<span class=\"h6-fs\">Use o aplicativo <b>Compras</b> para gerenciar todas "
"as suas compras internas de produtos.\n"
".</span>"

