#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid "<b>Validate</b> the transfer."
msgstr "<b>Valide</b> a transferência."

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid "<b>Validate</b> to finalize the order."
msgstr "<b>Valide</b> para finalizar o pedido."

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.ir_ui_view_2473
msgid ""
"<br/>Leverage advanced 3PL automation and real-time transparency for "
"unparalleled efficiency and competitive advantage.<br/><br/>"
msgstr ""
"<br/>Aproveite a automação avançada de 3PL e a transparência em tempo real "
"para obter eficiência e vantagem competitiva imbatíveis.<br/><br/>"

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<em>Example:  A category named \"5 Std Pal\" can be configured to hold\n"
"                        five standard pallets.</em>"
msgstr ""
"<em>Exemplo: Uma categoria chamada \"5 Pal Pad\" pode ser configurada para\n"
"                        cinco paletes padrão.</em>"

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<em>Example: A client who had 150 pallets at €0.30/day and 55 pallets at\n"
"                        €0.45/day in August.</em>"
msgstr ""
"<em>Exemplo: Um cliente que tinha 150 paletes a € 0,30/dia e 55 paletes a\n"
"                        € 0,45/dia em agosto.</em>"

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>Barcode App</b>:</font> Streamlines "
"warehouse floor operations by enabling\n"
"                    fast and accurate scanning of pallets, locations, and "
"stock movements."
msgstr ""
"<font class=\"text-o-color-1\"><b>App Código de Barras</b>:</font> Otimiza "
"as operações no chão de fábrica, permitindo\n"
"                    a leitura rápida e precisa de paletes, locais e "
"movimentações de estoque."

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>CRM App</b>:</font> Tracks leads and "
"opportunities efficiently, helping\n"
"                    logistics companies follow up on prospects and manage "
"long-term customer relationships."
msgstr ""
"<font class=\"text-o-color-1\"><b>App CRM</b>:</font> Rastreia leads e "
"oportunidades com eficiência, ajudando\n"
"                    as empresas de logística a acompanhar os clientes "
"potenciais e gerenciar relacionamentos de longo prazo com os clientes."

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>Documents App</b>:</font> Centralizes "
"contracts, delivery notes, and\n"
"                    transport documentation in a searchable digital space."
msgstr ""
"<font class=\"text-o-color-1\"><b>App Documentos</b>:</font> Centraliza "
"contratos, notas de entrega e\n"
"documentação de transporte em um espaço digital pesquisável."

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>Inventory App</b>:</font> Enables precise "
"stock management across multiple\n"
"                    warehouses and clients, ensuring full tracking of "
"inbound, outbound, and internal movements."
msgstr ""
"<font class=\"text-o-color-1\"><b>App Inventário</b>:</font> Permite o "
"gerenciamento preciso do inventário em vários\n"
"                    armazéns e clientes, garantindo o rastreamento completo "
"das entradas, saídas e movimentações internas."

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>Invoicing App</b>:</font> Automates "
"billing calculations based on storage\n"
"                    duration, volume, and handling services, with support "
"for custom pricing per client."
msgstr ""
"<font class=\"text-o-color-1\"><b>App Faturamento</b>:</font> Automatiza "
"cálculos de faturamento com base na duração do armazenamento, volume e "
"serviços de manuseio, com suporte para preços personalizados por cliente."

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>Sales App</b>:</font> Generates "
"professional quotations and sales orders for\n"
"                    storage, transport, and value-added logistics services."
msgstr ""
"<font class=\"text-o-color-1\"><b>App Vendas</b>:</font> Gera cotações "
"profissionais e pedidos de venda para\n"
"                    serviços de armazenamento, transporte e logística de "
"valor agregado."

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>Subscriptions App</b>:</font> Manages "
"recurring billing for long-term\n"
"                    storage services with customizable plans."
msgstr ""
"<font class=\"text-o-color-1\"><b>App Assinaturas</b>:</font> Gerencia o "
"faturamento recorrente para serviços de armazenamento de longo prazo\n"
"com planos personalizáveis."

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>Website &amp; Portal</b>:</font> Provides "
"clients with a self-service portal\n"
"                    for real-time access to stock levels, service requests, "
"and downloadable documents."
msgstr ""
"<font class=\"text-o-color-1\"><b>Site &amp; Portal</b>:</font> Oferece aos "
"clientes um portal de autoatendimento\n"
"                    para acesso em tempo real aos níveis de estoque, "
"solicitações de serviço e documentos para download."

