#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid "<b>Password:</b> portal"
msgstr "<b>Senha: </b> portal"

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<b>Picking Optimization:</b> Optimize picking with different methods like "
"<b>Batch\n"
"                            Picking, Wave Picking,</b> and <b>Cluster "
"Picking</b>."
msgstr ""
"<b>Otimização da separação:</b> Otimize o processo de separação com "
"diferentes métodos, como <b>Separação em lote,\n"
"                            em onda</b> e <b>em cluster</b>."

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<b>Putaway Rules:</b> Customize how products are stored based on your own\n"
"                            rules."
msgstr ""
"<b>Regras de armazenamento:</b> Personalize como os produtos são armazenados "
"com base nas suas próprias\n"
"regras."

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<b>Quality Report:</b> Gives information on the number of quality checks\n"
"                            performed."
msgstr ""
"<b>Relatório de Qualidade:</b> Fornece informações sobre o número de "
"verificações de qualidade\n"
"                            realizadas."

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<b>Reserved Quantity:</b> The amount of stock that has already been "
"allocated for\n"
"                    a scheduled shipment."
msgstr ""
"<b>Quantidade reservada:</b> A quantidade de estoque que já foi alocada "
"para\n"
"                    uma remessa programada."

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<b>Set up location-based fees:</b> In the configuration, you can define\n"
"                        different <b>Fee Rates</b> and link them to specific "
"storage locations. This\n"
"                        lets you apply different prices to various types of "
"storage, such as\n"
"                        refrigerated or high-bay areas. This granular "
"control allows for automated\n"
"                        and accurate invoicing based on the number of "
"pallets per fee rate."
msgstr ""
"<b>Configure tarifas baseadas na localização:</b> Na configuração, você pode "
"definir\n"
"diferentes <b>Porcentagens de Tarifas</b> e vinculá-las a locais de "
"armazenamento específicos. Isso\n"
"permite aplicar preços diferentes a vários tipos de armazenamento, como\n"
"áreas refrigeradas ou com prateleiras altas. Esse controle granular permite "
"o faturamento automatizado\n"
"e preciso com base no número de paletes por tarifa."

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<b>Shipping Connector:</b> Connect with various carriers directly within\n"
"                            Odoo."
msgstr ""
"<b>Conector de envio:</b> Conecte-se com várias transportadoras diretamente "
"no Odoo."

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid ""
"<b>Storage Report:</b> Shows the amount of packages stored per day,\n"
"                            broken down by fee rate."
msgstr ""
"<b>Relatório de armazenamento:</b> Mostra a quantidade de pacotes "
"armazenados por dia,\n"
"                            discriminado por taxa de tarifa."

#. module: 3pl_logistic_company
#: model_terms:ir.ui.view,arch_db:3pl_logistic_company.welcome_article_body
msgid "<b>User:</b> portal@portal.com"
msgstr "<b>Usuário:</b> portal@portal.com"

