#. module: tattoo_shop
#: model:mail.template,body_html:tattoo_shop.mail_template_booking_mail
msgid ""
"<div data-oe-version=\"1.0\">\n"
"            Hi <t t-out=\"object.contact_name\" or=\"\"/>,\n"
"            <br/><br/>\n"
"            Don't hesitate to book an appointment with us if you're interested in booking our services.\n"
"            <br/><br/>\n"
"            Here's the link:\n"
"            <br/>\n"
"            <a t-att-href=\"'/appointment/' + str(env.ref('tattoo_shop.appointment_type_1').id)\">Book Now</a>\n"
"            <br/><br/>\n"
"            Have a nice day!\n"
"            <br/><br/>\n"
"            <t t-out=\"object.user_id.signature\"/></div>\n"
"        "
msgstr ""
"<div data-oe-version=\"1.0\">\n"
"            Hei <t t-out=\"object.contact_name\" or=\"\"/>,\n"
"            <br/><br/>\n"
"            Varaa aika rohkeasti, jos olet kiinnostunut palveluistamme.\n"
"            <br/><br/>\n"
"            Tässä linkki:\n"
"            <br/>\n"
"            <a t-att-href=\"'/appointment/' + str(env.ref('tattoo_shop.appointment_type_1').id)\">Varaa nyt</a>\n"
"            <br/><br/>\n"
"            Mukavaa päivänjatkoa!\n"
"            <br/><br/>\n"
"            <t t-out=\"object.user_id.signature\"/></div>\n"
"        "

#. module: tattoo_shop
#: model:mail.template,body_html:tattoo_shop.mail_template_after_care
msgid ""
"<div data-oe-version=\"1.0\">\n"
"            Hi <t t-out=\"object.contact_name\" or=\"\"/>,\n"
"            <br/><br/>\n"
"            We hope you had a nice experience at our Tattoo shop.\n"
"            <br/>\n"
"            In attachment, you'll find a tattoo aftercare sheet for some tips and tricks.\n"
"            <br/><br/>\n"
"            Have a nice day,\n"
"            <br/><br/>\n"
"            <t t-out=\"object.activity_user_id.signature\"/>\n"
"            </div>\n"
"        "
msgstr ""
"<div data-oe-version=\"1.0\">\n"
"            Hei <t t-out=\"object.contact_name\" or=\"\"/>,\n"
"            <br/><br/>\n"
"            Toivomme, että kokemuksesi tatuointiliikkeessämme oli sinulle mieluisa.\n"
"            <br/>\n"
"            Löydät liitteistä tatuoinnin jälkihoito-ohjeet.\n"
"            <br/><br/>\n"
"            Mukavaa päivänjatkoa,\n"
"            <br/><br/>\n"
"            <t t-out=\"object.activity_user_id.signature\"/>\n"
"            </div>\n"
"        "

