#. module: physical_therapy
#: model:mail.template,body_html:physical_therapy.booking_suggestion
msgid ""
"<p>\n"
"                Hello,\n"
"            </p>\n"
"            <p>\n"
"                Thank you for your presence. May I invite you to schedule your next appointment if needed?\n"
"            </p>\n"
"            <p>\n"
"                Looking forward to meeting you.\n"
"            </p>\n"
"            \n"
"            <p>\n"
"                <a class=\"btn btn-secondary\" href=\"/book/wellness_session\">Schedule an Appointment</a>\n"
"            </p>\n"
"        "
msgstr ""
"<p>\n"
"                ສະບາຍດີ,\n"
"            </p>\n"
"            <p>\n"
"                ຂອບໃຈທີ່ທ່ານມາໃຊ້ບໍລິການ. ຂໍເຊີນທ່ານກຳນົດເວລານັດໝາຍຄັ້ງຕໍ່ໄປ ຖ້າຫາກທ່ານຈຳເປັ"
"ນ.\n"
"            </p>\n"
"            <p>\n"
"                ຫວັງຢ່າງຍິ່ງວ່າຈະໄດ້ພົບທ່ານ.\n"
"            </p>\n"
"            \n"
"            <p>\n"
"                <a class=\"btn btn-secondary\" href=\"/book/"
"wellness_session\">ກຳນົດເວລານັດໝາຍ</a>\n"
"            </p>\n"
"        "

#. module: physical_therapy
#: model_terms:ir.ui.view,arch_db:physical_therapy.welcome_article_body
