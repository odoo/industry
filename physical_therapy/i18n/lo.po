"<span class=\"display-4-fs\"><strong><font class=\"text-800\"><span "
"class=\"h1-fs\">ກໍລະນີການນຳໃຊ້</span></font></strong></span>"

#. module: physical_therapy
#: model_terms:ir.ui.view,arch_db:physical_therapy.welcome_article_body
msgid "<span class=\"h1-fs\"><strong>Basics</strong></span>"
msgstr "<span class=\"h1-fs\"><strong>ພື້ນຖານ</strong></span>"

#. module: physical_therapy
#: model_terms:ir.ui.view,arch_db:physical_therapy.welcome_article_body
msgid "<span class=\"h1-fs\"><strong>Do you want to go further?</strong></span>"
msgstr ""
"<span class=\"h1-fs\"><strong>ທ່ານຕ້ອງການໄປຕໍ່ໃຫ້ໄກກວ່ານີ້ບໍ?</strong></span>"

#. module: physical_therapy
#: model_terms:ir.ui.view,arch_db:physical_therapy.welcome_article_body
msgid ""
"<strong><font class=\"text-black\"><span style=\"font-weight: "
"normal;\">Manage your schedule and your availability in the "
"</span></font><font class=\"text-o-color-1\">Calendar App</font><font "
"class=\"text-black\"><span style=\"font-weight: "
"normal;\">.</span></font></strong>"
msgstr ""
"<strong><font class=\"text-black\"><span style=\"font-weight: normal;\">ຈັດການ"
"ຕາຕະລາງ ແລະ ເວລາຫວ່າງຂອງທ່ານໃນ </span></font><font class=\"text-o-color-1\">ແອັບ"
"ປະຕິທິນ</font><font class=\"text-black\"><span style=\"font-weight: normal;\">"
".</span></font></strong>"

#. module: physical_therapy
#: model_terms:ir.ui.view,arch_db:physical_therapy.welcome_article_body
msgid ""
"<strong><span class=\"display-4-fs\">Odoo for Physical "
"Therapy</span></strong>"
msgstr ""
"<strong><span class=\"display-4-fs\">Odoo ສຳລັບ ກາຍະພາບຳບັດ</span></strong>"

#. module: physical_therapy
#: model_terms:ir.ui.view,arch_db:physical_therapy.welcome_article_body
msgid "Add an upfront payment in your Appointment Type."
msgstr "ເພີ່ມການຊຳລະລ່ວງໜ້າໃນປະເພດການນັດໝາຍຂອງທ່ານ."

#. module: physical_therapy
#: model_terms:ir.ui.view,arch_db:physical_therapy.welcome_article_body
msgid ""
"Add the Subscription App and invoice automatically based on a subscription "
"type."
msgstr ""
"ເພີ່ມແອັບການສະໝັກສະມາຊິກ ແລະ ອອກໃບເກັບເງິນໂດຍອັດຕະໂນມັດຕາມປະເພດການສະໝັກ."

#. module: physical_therapy
#: model_terms:ir.ui.view,arch_db:physical_therapy.welcome_article_body
msgid ""
"All emails sent and received are automatically recorded in the "
"<strong>Chatter</strong>, giving you a clear history of your communication "
"with the patient. Once the patient books an appointment, it is automatically"
" synchronized across CRM, Appointments, and Calendar, keeping your schedule "
"up to date without manual work."
msgstr ""
"ອີເມວທັງໝົດທີ່ສົ່ງ ແລະ ຮັບ ຈະຖືກບັນທຶກໄວ້ໃນ <strong>Chatter</strong> ໂດຍອັດຕະໂນມັດ, ເຮັດໃຫ້ທ່າ"
"ນເຫັນປະຫວັດການຕິດຕໍ່ກັບຄົນເຈັບຢ່າງຈະແຈ້ງ. ເມື່ອຄົນເຈັບຈອງນັດໝາຍ, ຂໍ້ມູນຈະຖືກເຊື່ອມໂຍງລະຫວ່າງ CRM, ກ"
"ານນັດໝາຍ, ແລະ ປະຕິທິນໂດຍອັດຕະໂນມັດ, ເຮັດໃຫ້ຕາຕະລາງຂອງທ່ານທັນສະໄໝຢູ່ສະເໝີໂດຍບໍ່ຕ້ອງເຮັດເອງ."

#. module: physical_therapy
#: model_terms:ir.ui.view,arch_db:physical_therapy.welcome_article_body
msgid ""
"As you review her needs, you move the opportunity to Qualified, indicating "
"that a consultation is required."
msgstr ""
"ໃນຂະນະທີ່ທ່ານກວດສອບຄວາມຕ້ອງການຂອງລາວ, ທ່ານສາມາດຍ້າຍໂອກາດໄປທີ່ຂັ້ນຕອນ \"ມີຄຸນສົມບັດ\", ເຊິ່ງບົ່ງ"
"ບອກວ່າຈຳເປັນຕ້ອງມີການປຶກສາ."

#. module: physical_therapy
#: model_terms:ir.ui.view,arch_db:physical_therapy.welcome_article_body
msgid "Auto-post your invoice on a regular basis."
msgstr "ລົງບັນຊີໃບເກັບເງິນຂອງທ່ານໂດຍອັດຕະໂນມັດເປັນປະຈຳ."

#. module: physical_therapy
#: model_terms:ir.ui.view,arch_db:physical_therapy.welcome_article_body
msgid ""
"Automated recurring invoicing with the <strong><font class=\"text-o-"
"color-1\">Subscription App</font></strong>."
msgstr ""
"ການອອກໃບເກັບເງິນແບບຊ້ຳຄືນອັດຕະໂນມັດດ້ວຍ <strong><font class=\"text-o-color-1\">ແອັບກາ"
"ນສະໝັກສະມາຊິກ</font></strong>."

#. module: physical_therapy
#: model_terms:ir.ui.view,arch_db:physical_therapy.welcome_article_body
msgid ""
"Be careful, using the \"Log Note\" in your contact will be displayed only "
"for you and your eventual team. If you select the \"Send message\" option, "
"this will notify your customer (which can be really interesting also)."
msgstr ""
"ຂໍ້ຄວນລະວັງ, ການໃຊ້ \"ບັນທຶກຂໍ້ຄວາມ\" (Log Note) ໃນລາຍຊື່ຜູ້ຕິດຕໍ່ ຈະສະແດງໃຫ້ເຫັນສະເພາະທ່ານ ແລ"
"ະ ທີມງານຂອງທ່ານເທົ່ານັ້ນ. ຖ້າທ່ານເລືອກຕົວເລືອກ \"ສົ່ງຂໍ້ຄວາມ\", ມັນຈະແຈ້ງເຕືອນໃຫ້ລູກຄ້າຂອງທ່ານຊາບ "
"(ເຊິ່ງກໍມີປະໂຫຍດຫຼາຍ)."

#. module: physical_therapy
#: model_terms:ir.ui.view,arch_db:physical_therapy.welcome_article_body
msgid "Block time slots for treatments or personal availability"
msgstr "ປິດຊ່ວງເວລາໄວ້ສຳລັບການປິ່ນປົວ ຫຼື ເວລາສ່ວນຕົວ"

#. module: physical_therapy
#: model:mail.template,name:physical_therapy.booking_suggestion
msgid "Book your next appointment"
msgstr "ຈອງນັດໝາຍຄັ້ງຕໍ່ໄປຂອງທ່ານ"

#. module: physical_therapy
#: model_terms:ir.ui.view,arch_db:physical_therapy.welcome_article_body
msgid ""
"By doing this, the corresponding time slots are automatically reserved and "
"will no longer be available on the public booking link, ensuring your "
"availability remains accurate."
msgstr ""
"ໂດຍການເຮັດແບບນີ້, ຊ່ວງເວລາທີ່ກ່ຽວຂ້ອງຈະຖືກຈອງໄວ້ໂດຍອັດຕະໂນມັດ ແລະ ຈະບໍ່ຫວ່າງໃນລິ້ງການຈອງສາທາລະ"
"ນະອີກຕໍ່ໄປ, ເພື່ອໃຫ້ແນ່ໃຈວ່າເວລາຫວ່າງຂອງທ່ານແມ່ນຖືກຕ້ອງ."

#. module: physical_therapy
#: model_terms:ir.ui.view,arch_db:physical_therapy.welcome_article_body
msgid ""
"By installing this package, you gain access to a set of essential "
"applications, including CRM, Appointments, Calendar, and Invoicing, allowing"
" you to focus on patient care while Odoo handles your daily operations."
msgstr ""
"ໂດຍການຕິດຕັ້ງແພັກເກັດນີ້, ທ່ານຈະສາມາດເຂົ້າເຖິງຊຸດແອັບພລິເຄຊັນທີ່ຈຳເປັນ, ລວມມີ CRM, ການນັດໝາຍ, ປະຕິ"
"ທິນ, ແລະ ການອອກໃບເກັບເງິນ, ເຊິ່ງຊ່ວຍໃຫ້ທ່ານສຸມໃສ່ການເບິ່ງແຍງຄົນເຈັບ ໃນຂະນະທີ່ Odoo ຈັດການວຽກງາ"
"ນປະຈຳວັນໃຫ້ທ່ານ."

#. module: physical_therapy
#: model_terms:ir.ui.view,arch_db:physical_therapy.welcome_article_body
msgid ""
"By uploading this module's demo data, your database has been filled with a "
"few contacts."
msgstr ""
"ໂດຍການອັບໂຫຼດຂໍ້ມູນຕົວຢ່າງຂອງໂມດູນນີ້, ຖານຂໍ້ມູນຂອງທ່ານຈະຖືກເພີ່ມລາຍຊື່ຜູ້ຕິດຕໍ່ຕົວຢ່າງຈຳນວນໜຶ່ງ."

#. module: physical_therapy
#: model_terms:ir.ui.view,arch_db:physical_therapy.welcome_article_body
msgid "Cancel a session"
msgstr "ຍົກເລີກຮອບການບຳບັດ"

#. module: physical_therapy
#: model_terms:ir.ui.view,arch_db:physical_therapy.welcome_article_body
msgid ""
"Create a dedicated <strong>knowledge article</strong> for each patient to "
"track progress, exercises, or treatment plans"
msgstr ""
"ສ້າງ <strong>ບົດຄວາມຄວາມຮູ້</strong> ສະເພາະສຳລັບຄົນເຈັບແຕ່ລະຄົນ ເພື່ອຕິດຕາມຄວາມຄືບໜ້າ, ການອ"
"ອກກຳລັງກາຍ, ຫຼື ແຜນການປິ່ນປົວ"

#. module: physical_therapy
#: model_terms:ir.ui.view,arch_db:physical_therapy.welcome_article_body
msgid ""
"Create a professional <font class=\"text-o-"
"color-1\"><strong>Website</strong></font> for your practice and allow "
"patients to book appointments online."
msgstr ""
"ສ້າງ <font class=\"text-o-color-1\"><strong>ເວັບໄຊ</strong></font> ທີ່ເປັນມືອາຊີບສຳລັ"
"ບຄລີນິກຂອງທ່ານ ແລະ ອະນຸຍາດໃຫ້ຄົນເຈັບຈອງນັດໝາຍທາງອອນລາຍ."

#. module: physical_therapy
#: model_terms:ir.ui.view,arch_db:physical_therapy.welcome_article_body
msgid "Discover more about Odoo by diving into our"
msgstr "ຄົ້ນຫາເພີ່ມເຕີມກ່ຽວກັບ Odoo ໂດຍການເຂົ້າເບິ່ງ"

#. module: physical_therapy
#: model_terms:ir.ui.view,arch_db:physical_therapy.welcome_article_body
msgid ""
"During or after a therapy session, you can easily record clinical notes:"
msgstr ""
"ໃນລະຫວ່າງ ຫຼື ຫຼັງຮອບການບຳບັດ, ທ່ານສາມາດບັນທຶກຂໍ້ມູນການປິ່ນປົວໄດ້ຢ່າງງ່າຍດາຍ:"

#. module: physical_therapy
#: model_terms:ir.ui.view,arch_db:physical_therapy.welcome_article_body
msgid ""
"Ease your invoicing process with the <strong><font class=\"text-o-"
"color-1\">Invoice App</font></strong>."
msgstr ""
