#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<b><span class=\"h4-fs\"><strong>Order preparation</strong></span></b><br/>"
msgstr ""
"<b><span class=\"h4-fs\"><strong>Forberedelse af ordre</strong></span></b>"
"<br/>"

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<b><span class=\"h4-fs\"><strong>Processing a click and collect "
"transaction</strong></span></b>"
msgstr ""
"<b><span class=\"h4-fs\"><strong>Behandling af en klik-og-hent-"
"transaktion</strong></span></b>"

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Accepted payment methods</b>."
msgstr "<b>Accepterede betalingsformer</b>."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Add all necessary products</b> to the order."
msgstr "<b>Føj alle nødvendige produkter</b> til ordren."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<b>Add specific locations</b> within your warehouse as needed. (You'll first"
" need to enable the \"Locations\" setting in your Inventory configurations "
"to use this feature.)"
msgstr ""
"<b>Tilføj om nødvendigt specifikke placeringer</b> i dit lager. (For at "
"bruge denne funktion skal du først aktivere indstillingen \"Placeringer\" i "
"lagerkonfigurationen.)"

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Available delivery options</b>."
msgstr "<b>Tilgængelige leveringsmuligheder</b>."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<b>Confirm it.</b> Odoo will automatically generate a <b>receipt</b> for the"
" incoming products."
msgstr ""
"<b>Bekræft den.</b> Odoo genererer automatisk en <b>kvittering</b> for de "
"indkommende produkter."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<b>Create a B2B webpage</b> to cater specifically to your business clients."
msgstr "<b>Opret en B2B-hjemmeside,</b> der er målrettet dine erhvervskunder."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Define Vendors and Lead time on products</b><br/>"
msgstr "<b>Angiv leverandører og leveringstid for produkter</b><br/>"

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Gather all the products</b> for that order."
msgstr "<b>Saml alle produkter</b> til den pågældende ordre."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<b>Integrate WhatsApp</b> to send automatic reminders about deliveries, "
"keeping your customers informed effortlessly."
msgstr ""
"<b>Integrér med WhatsApp</b> for at sende automatiske leveringspåmindelser "
"og holde dine kunder opdateret."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<b>Leverage Social Marketing</b> to effectively promote your new arrivals "
"and reach a wider audience."
msgstr ""
"<b>Brug markedsføring på sociale medier</b> til effektivt at promovere dine "
"nye produkter og nå ud til et bredere publikum."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Open the Inventory App</b> and go to <b>\"Replenishment.\"</b>"
msgstr "<b>Åbn Lagerappen,</b> og gå til <b>\"Genopfyldning.\"</b>"

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Order all the products</b> you need to replenish."
msgstr "<b>Bestil alle de produkter,</b> du har brug for at genopfylde."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Process the receipt</b> once the products arrive."
msgstr "<b>Håndtér varemodtagelsen,</b> når produkterne ankommer."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Select the order</b> you're starting."
msgstr "<b>Vælg den ordre,</b> du ønsker at starte."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Send the purchase order</b> to your vendor."
msgstr "<b>Send indkøbsordren</b> til din leverandør."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<b>Set up reordering rules</b> for your products to automatically maintain "
"minimum stock levels."
msgstr ""
"<b>Opret genbestillingsregler</b> for dine produkter, så du automatisk "
"opretholder minimumslageret."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Validate!</b>"
msgstr "<b>Validér!</b>"

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Validate</b> the preparation."
msgstr "<b>Validér</b> klargørelsen."

