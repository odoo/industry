#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<b><span class=\"h4-fs\"><strong>Order preparation</strong></span></b><br/>"
msgstr ""
"<b><span class=\"h4-fs\"><strong>ການກະກຽມຄຳສັ່ງຊື້</strong></span></b><br/>"

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<b><span class=\"h4-fs\"><strong>Processing a click and collect "
"transaction</strong></span></b>"
msgstr ""
"<b><span class=\"h4-fs\"><strong>ການປະມວນຜົນການສັ່ງອອນລາຍແລ້ວຮັບຢູ່ຮ້ານ</strong></"
"span></b>"

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Accepted payment methods</b>."
msgstr "<b>ຊ່ອງທາງການຊຳລະເງິນທີ່ຍອມຮັບ</b>."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Add all necessary products</b> to the order."
msgstr "<b>ເພີ່ມສິນຄ້າທີ່ຈຳເປັນທັງໝົດ</b> ເຂົ້າໃນຄຳສັ່ງຊື້."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<b>Add specific locations</b> within your warehouse as needed. (You'll first"
" need to enable the \"Locations\" setting in your Inventory configurations "
"to use this feature.)"
msgstr ""
"<b>ເພີ່ມສະຖານທີ່ຈັດເກັບສະເພາະ</b> ໃນສາງສິນຄ້າຂອງທ່ານຕາມຄວາມຕ້ອງການ. (ທ່ານຈຳເປັນຕ້ອງເປີດການຕັ້"
"ງຄ່າ \"ສະຖານທີ່\" ໃນການກຳນົດຄ່າສາງສິນຄ້າກ່ອນເພື່ອໃຊ້ຟີເຈີນີ້.)"

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Available delivery options</b>."
msgstr "<b>ທາງເລືອກການຈັດສົ່ງທີ່ມີ</b>."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<b>Confirm it.</b> Odoo will automatically generate a <b>receipt</b> for the"
" incoming products."
msgstr ""
"<b>ຢືນຢັນ.</b> Odoo ຈະສ້າງ <b>ໃບຮັບສິນຄ້າ</b> ສຳລັບສິນຄ້າຂາເຂົ້າໂດຍອັດຕະໂນມັດ."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<b>Create a B2B webpage</b> to cater specifically to your business clients."
msgstr "<b>ສ້າງເວັບໄຊ B2B</b> ເພື່ອຮອງຮັບລູກຄ້າກຸ່ມທຸລະກິດໂດຍສະເພາະ."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Define Vendors and Lead time on products</b><br/>"
msgstr "<b>ກຳນົດຜູ້ສະໜອງ ແລະ ໄລຍະເວລາການສະໜອງສິນຄ້າ</b><br/>"

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Gather all the products</b> for that order."
msgstr "<b>ຮວບຮວມສິນຄ້າທັງໝົດ</b> ສຳລັບຄຳສັ່ງຊື້ນັ້ນ."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<b>Integrate WhatsApp</b> to send automatic reminders about deliveries, "
"keeping your customers informed effortlessly."
msgstr ""
"<b>ເຊື່ອມຕໍ່ WhatsApp</b> ເພື່ອສົ່ງຂໍ້ຄວາມແຈ້ງເຕືອນການຈັດສົ່ງແບບອັດຕະໂນມັດ, ເຮັດໃຫ້ລູກຄ້າຂອງທ່ານຮັບຊ"
"າບຂໍ້ມູນໄດ້ຢ່າງງ່າຍດາຍ."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<b>Leverage Social Marketing</b> to effectively promote your new arrivals "
"and reach a wider audience."
msgstr ""
"<b>ນຳໃຊ້ການຕະຫຼາດຜ່ານສື່ສັງຄົມ</b> ເພື່ອໂຄສະນາສິນຄ້າໃໝ່ຢ່າງມີປະສິດທິພາບ ແລະ ເຂົ້າເຖິງກຸ່ມລູກຄ້າທີ່ກວ້າງ"
"ຂຶ້ນ."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Open the Inventory App</b> and go to <b>\"Replenishment.\"</b>"
msgstr ""
"<b>ເປີດແອັບສາງສິນຄ້າ (Inventory)</b> ແລະ ໄປທີ່ <b>\"ການເຕີມສິນຄ້າ (Replenishment).\"</"
"b>"

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Order all the products</b> you need to replenish."
msgstr "<b>ສັ່ງຊື້ສິນຄ້າທັງໝົດ</b> ທີ່ທ່ານຕ້ອງການເຕີມ."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Process the receipt</b> once the products arrive."
msgstr "<b>ປະມວນຜົນການຮັບສິນຄ້າ</b> ເມື່ອສິນຄ້າມາຮອດ."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Select the order</b> you're starting."
msgstr "<b>ເລືອກຄຳສັ່ງຊື້</b> ທີ່ທ່ານກຳລັງເລີ່ມດຳເນີນການ."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Send the purchase order</b> to your vendor."
msgstr "<b>ສົ່ງໃບສັ່ງຊື້</b> ໃຫ້ກັບຜູ້ສະໜອງຂອງທ່ານ."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<b>Set up reordering rules</b> for your products to automatically maintain "
"minimum stock levels."
msgstr ""
"<b>ຕັ້ງກົດການສັ່ງຊື້ຄືນ</b> ສຳລັບສິນຄ້າຂອງທ່ານ ເພື່ອຮັກສາລະດັບສິນຄ້າຄົງສັງຂັ້ນຕ່ຳແບບອັດຕະໂນມັດ."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Validate!</b>"
msgstr "<b>ຢືນຢັນ!</b>"

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Validate</b> the preparation."
msgstr "<b>ຢືນຢັນ</b> ການກະກຽມ."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>Barcode App</b>:</font> Empower staff to perform stock counts, receive goods,\n"
"                    and check prices on the shop floor using mobile scanners."
msgstr ""
"<font class=\"text-o-color-1\"><b>ແອັບບາໂຄດ (Barcode)</b>:</font> ຊ່ວຍໃຫ້ພະນັກງານ"
"ສາມາດກວດນັບສິນຄ້າ, ຮັບສິນຄ້າ,\n"
"                    ແລະ ກວດສອບລາຄາຢູ່ໜ້າຮ້ານໄດ້ໂດຍໃຊ້ເຄື່ອງສະແກນແບບມືຖື."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>Inventory App</b>: </font>Manage stock with precision using\n"
"                    <b>Lots &amp; Serial Numbers</b> and <b>Expiration Dates</b> to track perishables and automate removal\n"
"                    strategies."
msgstr ""
"<font class=\"text-o-color-1\"><b>ແອັບສາງສິນຄ້າ (Inventory)</b>: </font>ຈັດການສິນຄ້"
"າຄົງສັງຢ່າງແມ່ນຢຳໂດຍໃຊ້\n"
"                    <b>ເລກລັອດ (Lots) &amp; ເລກຊີຣີ (Serial Numbers)</b> ແລະ <b>"
"ວັນໝົດອາຍຸ</b> ເພື່ອຕິດຕາມສິນຄ້າທີ່ເສຍງ່າຍ ແລະ ວາງແຜນການລະບາຍສິນຄ້າແບບອັດຕະໂນມັດ."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>Invoicing App</b>:</font> Simplify your financial workflows by integrating\n"
"                    supplier bills and customer invoices directly into your accounting system."
msgstr ""
"<font class=\"text-o-color-1\"><b>ແອັບການອອກໃບແຈ້ງໜີ້ (Invoicing)</b>:</font> ຫຼຸດຜ່"
"ອນຂັ້ນຕອນການເງິນຂອງທ່ານໂດຍການເຊື່ອມຕໍ່\n"
"                    ໃບບິນຜູ້ສະໜອງ ແລະ ໃບແຈ້ງໜີ້ລູກຄ້າເຂົ້າໃນລະບົບບັນຊີຂອງທ່ານໂດຍກົງ."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>Point of Sale App</b>:</font> Process transactions rapidly with an interface\n"
"                    optimized for speed, supporting barcode scanners, integrated scales, and customer loyalty cards."
msgstr ""
"<font class=\"text-o-color-1\"><b>ແອັບຈຸດຂາຍສິນຄ້າ (Point of Sale)</b>:</font> ປະ"
"ມວນຜົນທຸລະກຳຢ່າງວ່ອງໄວດ້ວຍໜ້າຈໍ\n"
"                    ທີ່ອອກແບບມາເພື່ອຄວາມໄວ, ຮອງຮັບເຄື່ອງສະແກນບາໂຄດ, ຊິງຊັ່ງທີ່ເຊື່ອມຕໍ່ລະບົບ, "
"ແລະ ບັດສະມາຊິກລູກຄ້າ."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>Purchase App</b>:</font> Automate the reordering of fast-moving goods based on\n"
"                    minimum stock rules, ensuring you never run out of milk or bread."
msgstr ""
"<font class=\"text-o-color-1\"><b>ແອັບການຈັດຊື້ (Purchase)</b>:</font> ສັ່ງຊື້ສິນຄ້າທີ່ຂາ"
"ຍດີແບບອັດຕະໂນມັດຕາມ\n"
"                    ກົດເກນສິນຄ້າຄົງສັງຂັ້ນຕ່ຳ, ເພື່ອຮັບປະກັນວ່າສິນຄ້າຂອງທ່ານຈະບໍ່ຂາດສາງ."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>eCommerce App</b>:</font> Expand your reach by offering online ordering for\n"
"                    \"click and collect\" or home delivery services."
msgstr ""
"<font class=\"text-o-color-1\"><b>ແອັບອີຄອມເມີຊ (eCommerce)</b>:</font> ຂະຫຍາຍຖາ"
"ນລູກຄ້າດ້ວຍການສັ່ງຊື້ອອນລາຍສຳລັບ\n"
"                    ການສັ່ງແລ້ວຮັບຢູ່ຮ້ານ ຫຼື ບໍລິການຈັດສົ່ງເຖິງບ້ານ."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.ir_ui_view_3972
msgid ""
"<i class=\"fa fa-1x fa-fw fa-envelope me-2\"/>\n"
"                                                <span>info@yourcompany.example.com</span>"
msgstr ""
"<i class=\"fa fa-1x fa-fw fa-envelope me-2\"/>\n"
"                                                <span>"
"info@yourcompany.example.com</span>"

