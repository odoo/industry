#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<b><span class=\"h4-fs\"><strong>Order preparation</strong></span></b><br/>"
msgstr ""
"<b><span class=\"h4-fs\"><strong>Préparation de la commande</strong></span></"
"b><br/>"

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<b><span class=\"h4-fs\"><strong>Processing a click and collect transaction</"
"strong></span></b>"
msgstr ""
"<b><span class=\"h4-fs\"><strong>Traitement d'une transaction click and "
"collect</strong></span></b>"

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Accepted payment methods</b>."
msgstr "<b>Moyens de paiement acceptés</b>."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Add all necessary products</b> to the order."
msgstr "<b>Ajoutez tous les produits nécessaires</b> à la commande."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<b>Add specific locations</b> within your warehouse as needed. (You'll first "
"need to enable the \"Locations\" setting in your Inventory configurations to "
"use this feature.)"
msgstr ""
"<b>Ajoutez des emplacements spécifiques</b> dans votre entrepôt si "
"nécessaire. (Activez d'abord le paramètre \"Emplacements\" dans votre "
"configuration d'Inventaire pour utiliser cette fonctionnalité.)"

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Available delivery options</b>."
msgstr "<b>Options de livraison disponibles</b>."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<b>Confirm it.</b> Odoo will automatically generate a <b>receipt</b> for the "
"incoming products."
msgstr ""
"<b>Validez.</b> Odoo générera automatiquement un <b>reçu</b> pour les "
"produits entrants."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<b>Create a B2B webpage</b> to cater specifically to your business clients."
msgstr ""
"<b>Créez une page web B2B</b> destinée spécifiquement à vos clients "
"professionnels."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Define Vendors and Lead time on products</b><br/>"
msgstr "<b>Définissez les fournisseurs et le délai sur les produits</b><br/>"

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Gather all the products</b> for that order."
msgstr "<b>Rassemblez tous les produits</b> pour cette commande."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<b>Integrate WhatsApp</b> to send automatic reminders about deliveries, "
"keeping your customers informed effortlessly."
msgstr ""
"<b>Intégrez WhatsApp</b> pour envoyer des rappels automatiques sur les "
"livraisons afin de tenir vos clients informés."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<b>Leverage Social Marketing</b> to effectively promote your new arrivals "
"and reach a wider audience."
msgstr ""
"<b>Utilisez Social Marketing</b> pour promouvoir efficacement vos nouveautés "
"et atteindre un public plus large."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Open the Inventory App</b> and go to <b>\"Replenishment.\"</b>"
msgstr ""
"<b>Ouvrez l'app Inventaire</b> et allez dans <b>\"Réapprovisionnement.\"</b>"

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Order all the products</b> you need to replenish."
msgstr "<b>Commandez tous les produits</b> que vous devez réapprovisionner."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Process the receipt</b> once the products arrive."
msgstr "<b>Traitez le reçu</b> une fois les produits arrivés."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Select the order</b> you're starting."
msgstr "<b>Sélectionnez la commande</b> que vous souhaitez traiter."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Send the purchase order</b> to your vendor."
msgstr "<b>Envoyez le bon de commande</b> à votre fournisseur."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<b>Set up reordering rules</b> for your products to automatically maintain "
"minimum stock levels."
msgstr ""
"<b>Configurez des règles de réapprovisionnement</b> pour vos produits afin "
"de maintenir automatiquement des niveaux de stock minimums."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Validate!</b>"
msgstr "<b>Validez !</b>"

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Validate</b> the preparation."
msgstr "<b>Validez</b> la préparation."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>Barcode App</b>:</font> Empower staff to "
"perform stock counts, receive goods,\n"
"                    and check prices on the shop floor using mobile scanners."
msgstr ""
"<font class=\"text-o-color-1\"><b>App Code-barres</b> :</font> donnez au "
"personnel les moyens d'effectuer des comptages de stock, de réceptionner des "
"marchandises,\n"
"                et de vérifier les prix dans l'atelier à l'aide de scanners "
"mobiles."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>Inventory App</b>: </font>Manage stock "
"with precision using\n"
"                    <b>Lots &amp; Serial Numbers</b> and <b>Expiration "
"Dates</b> to track perishables and automate removal\n"
"                    strategies."
msgstr ""
"<font class=\"text-o-color-1\"><b>App Inventaire</b> : </font>gérez le stock "
"avec précision à l'aide des\n"
"                <b>lots et numéros de série</b> et des <b>dates "
"d'expiration</b> pour suivre les produits périssables et automatiser les "
"stratégies\n"
"                de retrait."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>Invoicing App</b>:</font> Simplify your "
"financial workflows by integrating\n"
"                    supplier bills and customer invoices directly into your "
"accounting system."
msgstr ""
"<font class=\"text-o-color-1\"><b>App Facturation</b> :</font> simplifiez "
"vos workflows financiers en intégrant\n"
"                les factures fournisseur et les factures client directement "
"dans votre système de comptabilité."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>Point of Sale App</b>:</font> Process "
"transactions rapidly with an interface\n"
"                    optimized for speed, supporting barcode scanners, "
"integrated scales, and customer loyalty cards."
msgstr ""
"<font class=\"text-o-color-1\"><b>App Point de Vente</b> :</font> traitez "
"les transactions rapidement avec une interface\n"
"                optimisée pour la rapidité, prenant en charge les scanners "
"de codes-barres, les balances intégrées et les cartes de fidélité client."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>Purchase App</b>:</font> Automate the "
"reordering of fast-moving goods based on\n"
"                    minimum stock rules, ensuring you never run out of milk "
"or bread."
msgstr ""
"<font class=\"text-o-color-1\"><b>App Achats</b> :</font> automatisez le "
"réapprovisionnement des produits à forte rotation en fonction de règles de "
"stock minimum, afin de ne jamais manquer de lait ou de pain."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>eCommerce App</b>:</font> Expand your "
"reach by offering online ordering for\n"
"                    \"click and collect\" or home delivery services."
msgstr ""
"<font class=\"text-o-color-1\"><b>App eCommerce</b> :</font> développez "
"votre portée en proposant la commande en ligne pour\n"
"                les services de \"click and collect\" ou de livraison à "
"domicile."

