#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<b><span class=\"h4-fs\"><strong>Order preparation</strong></span></b><br/>"
msgstr ""
"<b><span class=\"h4-fs\"><strong>Chuẩn bị đơn hàng</strong></span></b><br/>"

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<b><span class=\"h4-fs\"><strong>Processing a click and collect transaction</"
"strong></span></b>"
msgstr ""
"<b><span class=\"h4-fs\"><strong>Xử lý giao dịch đặt hàng trực tuyến và nhận "
"hàng tại cửa hàng</strong></span></b>"

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Accepted payment methods</b>."
msgstr "<b>Các phương thức thanh toán được chấp nhận</b>."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Add all necessary products</b> to the order."
msgstr "<b>Thêm tất cả sản phẩm cần thiết</b> vào đơn hàng."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<b>Add specific locations</b> within your warehouse as needed. (You'll first "
"need to enable the \"Locations\" setting in your Inventory configurations to "
"use this feature.)"
msgstr ""
"<b>Thêm các vị trí cụ thể</b> trong kho của bạn khi cần. (Trước tiên, bạn "
"cần bật tùy chọn \"Vị trí\" trong phần cấu hình Tồn kho để sử dụng tính năng "
"này.)"

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Available delivery options</b>."
msgstr "<b>Các tùy chọn giao hàng có sẵn</b>."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<b>Confirm it.</b> Odoo will automatically generate a <b>receipt</b> for the "
"incoming products."
msgstr ""
"<b>Xác nhận.</b> Odoo sẽ tự động tạo <b>phiếu nhập kho</b> cho các sản phẩm "
"nhập về."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<b>Create a B2B webpage</b> to cater specifically to your business clients."
msgstr ""
"<b>Tạo trang web B2B</b> để phục vụ riêng cho khách hàng doanh nghiệp của "
"bạn."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Define Vendors and Lead time on products</b><br/>"
msgstr ""
"<b>Xác định nhà cung cấp và thời gian giao hàng cho các sản phẩm</b><br/>"

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Gather all the products</b> for that order."
msgstr "<b>Thu thập tất cả sản phẩm</b> cho đơn hàng đó."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<b>Integrate WhatsApp</b> to send automatic reminders about deliveries, "
"keeping your customers informed effortlessly."
msgstr ""
"<b>Tích hợp WhatsApp</b> để gửi các lời nhắc tự động về việc giao hàng, giúp "
"khách hàng của bạn luôn được cập nhật một cách dễ dàng."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<b>Leverage Social Marketing</b> to effectively promote your new arrivals "
"and reach a wider audience."
msgstr ""
"<b>Sử dụng Marketing trên MXH</b> để quảng bá hiệu quả các sản phẩm mới và "
"tiếp cận đối tượng khách hàng rộng hơn."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Open the Inventory App</b> and go to <b>\"Replenishment.\"</b>"
msgstr "Mở <b>ứng dụng Tồn kho</b> và đi đến <b>\"Bổ sung tồn kho.\"</b>"

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Order all the products</b> you need to replenish."
msgstr "<b>Đặt hàng tất cả các sản phẩm</b> mà bạn cần để bổ sung."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Process the receipt</b> once the products arrive."
msgstr "<b>Xử lý phiếu nhập kho</b> sau khi hàng hóa đến."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Select the order</b> you're starting."
msgstr "<b>Chọn đơn hàng</b> mà bạn đang bắt đầu."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Send the purchase order</b> to your vendor."
msgstr "<b>Gửi đơn mua hàng</b> cho nhà cung cấp của bạn."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<b>Set up reordering rules</b> for your products to automatically maintain "
"minimum stock levels."
msgstr ""
"<b>Cài đặt quy tắc tái đặt hàng</b> cho sản phẩm của bạn để duy trì mức tồn "
"kho tối thiểu một cách tự động."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Validate!</b>"
msgstr "<b>Xác thực!</b>"

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Validate</b> the preparation."
msgstr "<b>Xác minh</b> quá trình chuẩn bị."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>Barcode App</b>:</font> Empower staff to "
"perform stock counts, receive goods,\n"
"                    and check prices on the shop floor using mobile scanners."
msgstr ""

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>Inventory App</b>: </font>Manage stock "
"with precision using\n"
"                    <b>Lots &amp; Serial Numbers</b> and <b>Expiration "
"Dates</b> to track perishables and automate removal\n"
"                    strategies."
msgstr ""

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>Invoicing App</b>:</font> Simplify your "
"financial workflows by integrating\n"
"                    supplier bills and customer invoices directly into your "
"accounting system."
msgstr ""

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>Point of Sale App</b>:</font> Process "
"transactions rapidly with an interface\n"
"                    optimized for speed, supporting barcode scanners, "
"integrated scales, and customer loyalty cards."
msgstr ""

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>Purchase App</b>:</font> Automate the "
"reordering of fast-moving goods based on\n"
"                    minimum stock rules, ensuring you never run out of milk "
"or bread."
msgstr ""

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>eCommerce App</b>:</font> Expand your "
"reach by offering online ordering for\n"
"                    \"click and collect\" or home delivery services."
msgstr ""

