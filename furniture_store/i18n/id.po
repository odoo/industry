#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<b><span class=\"h4-fs\"><strong>Order preparation</strong></span></b><br/>"
msgstr ""
"<b><span class=\"h4-fs\"><strong>Persiapan pesanan</strong></span></b><br/>"

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<b><span class=\"h4-fs\"><strong>Processing a click and collect transaction</"
"strong></span></b>"
msgstr ""
"<b><span class=\"h4-fs\"><strong>Memproses transaksi click and collect</"
"strong></span></b>"

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Accepted payment methods</b>."
msgstr "<b>Metode pembayaran yang diterima</b>."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Add all necessary products</b> to the order."
msgstr "<b>Tambahkan semua produk-produk yang diperlukan</b> ke pesanan."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<b>Add specific locations</b> within your warehouse as needed. (You'll first "
"need to enable the \"Locations\" setting in your Inventory configurations to "
"use this feature.)"
msgstr ""
"<b>Tambahkan lokasi tertentu</b> dalam gudang Anda sesuai kebutuhan. (Anda "
"harus pertama-tama mengaktifkan pengaturan \"Lokasi\" di konfigurasi "
"Inventaris untuk menggunakan fitur ini.)"

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Available delivery options</b>."
msgstr "<b>Opsi pengiriman tersedia</b>."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<b>Confirm it.</b> Odoo will automatically generate a <b>receipt</b> for the "
"incoming products."
msgstr ""
"<b>Konfirmasi.</b> Odoo akan otomatis membuat <b>kwitansi</b> untuk produk-"
"produk masuk."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<b>Create a B2B webpage</b> to cater specifically to your business clients."
msgstr ""
"<b>Buat halaman website B2B</b> untuk mendukung secara khusus bisnis klien "
"Anda."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Define Vendors and Lead time on products</b><br/>"
msgstr "<b>Definisikan Vendor dan Waktu Tunggu di produk</b><br/>"

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Gather all the products</b> for that order."
msgstr "<b>Kumpulkan semua produk-produk</b> untuk pesanan tersebut."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<b>Integrate WhatsApp</b> to send automatic reminders about deliveries, "
"keeping your customers informed effortlessly."
msgstr ""
"<b>Integrasikan WhatsApp</b> untuk mengirim pengingat otomatis mengenai "
"pengiriman, memastikan pelanggan Anda tetap diinformasikan tanpa upaya."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<b>Leverage Social Marketing</b> to effectively promote your new arrivals "
"and reach a wider audience."
msgstr ""
"<b>Gunakan Social Marketing</b> untuk secara efektif mempromosikan produk "
"baru Anda dan mencapai lebih banyak audiens."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Open the Inventory App</b> and go to <b>\"Replenishment.\"</b>"
msgstr "<b>Buka Aplikasi Inventaris</b> dan kunjungi <b>\"Pemulihan.\"</b>"

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Order all the products</b> you need to replenish."
msgstr "<b>Pesan semua produk</b> yang diperlukan untuk isi ulang stok."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Process the receipt</b> once the products arrive."
msgstr "<b>Proses tanda terima</b> setelah produk tiba."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Select the order</b> you're starting."
msgstr "<b>Pilih pesanan</b> yang akan Anda mulai."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Send the purchase order</b> to your vendor."
msgstr "<b>Kirimkan purchase order</b> ke vendor Anda."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<b>Set up reordering rules</b> for your products to automatically maintain "
"minimum stock levels."
msgstr ""
"<b>Konfigutasi aturan order ulang</b> untuk produk agar tingkat stok minimal "
"terjaga secara otomatis."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Validate!</b>"
msgstr "<b>Validasi!</b>"

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid "<b>Validate</b> the preparation."
msgstr "<b>Validasi</b> persiapan."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>Barcode App</b>:</font> Empower staff to "
"perform stock counts, receive goods,\n"
"                    and check prices on the shop floor using mobile scanners."
msgstr ""
"<font class=\"text-o-color-1\"><b>Aplikasi Barcode</b>:</font> Dorong staf "
"untuk melakukan penghitungan stok, menerima barang,\n"
"                    dan memeriksa harga di shop floor menggunakan pemindai "
"seluler."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>Inventory App</b>: </font>Manage stock "
"with precision using\n"
"                    <b>Lots &amp; Serial Numbers</b> and <b>Expiration "
"Dates</b> to track perishables and automate removal\n"
"                    strategies."
msgstr ""
"<font class=\"text-o-color-1\"><b>Aplikasi Inventaris</b>: </font>Kelola "
"stok dengan akurat menggunakan\n"
"                   <b> Lot &amp; Nomor Seri</b> dan <b>Tanggal Kedaluwarsa</"
"b> untuk melacak barang yang mudah rusak dan mengotomatiskan strategi\n"
"                    pembuangan."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>Invoicing App</b>:</font> Simplify your "
"financial workflows by integrating\n"
"                    supplier bills and customer invoices directly into your "
"accounting system."
msgstr ""
"<font class=\"text-o-color-1\"><b>Aplikasi Faktur</b>:</font> Sederhanakan "
"alur kerja keuangan Anda dengan mengintegrasikan\n"
"                    tagihan pemasok dan faktur pelanggan langsung ke sistem "
"Akuntansi Anda."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>Point of Sale App</b>:</font> Process "
"transactions rapidly with an interface\n"
"                    optimized for speed, supporting barcode scanners, "
"integrated scales, and customer loyalty cards."
msgstr ""
"<font class=\"text-o-color-1\"><b>Aplikasi Point of Sale (POS)</b>:</font> "
"Proses transaksi dengan cepat menggunakan antarmuka\n"
"                    yang dioptimalkan untuk kecepatan, mendukung pemindai "
"barcode, timbangan terintegrasi, dan kartu loyalitas pelanggan."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>Purchase App</b>:</font> Automate the "
"reordering of fast-moving goods based on\n"
"                    minimum stock rules, ensuring you never run out of milk "
"or bread."
msgstr ""
"<font class=\"text-o-color-1\"><b>Aplikasi Purchase</b>:</font> Otomatiskan "
"pemesanan ulang barang-barang yang cepat habis berdasarkan\n"
"                    aturan stok minimum agar Anda tidak kehabisan bahan baku "
"lagi."

#. module: furniture_store
#: model_terms:ir.ui.view,arch_db:furniture_store.welcome_article_body
msgid ""
"<font class=\"text-o-color-1\"><b>eCommerce App</b>:</font> Expand your "
"reach by offering online ordering for\n"
"                    \"click and collect\" or home delivery services."
msgstr ""
"<font class=\"text-o-color-1\"><b>Aplikasi eCommerce</b>:</font> Perluas "
"jangkauan Anda dengan menawarkan pemesanan online untuk\n"
"                    layanan \"klik dan ambil\" atau pengiriman ke rumah."

