<?xml version='1.0' encoding='UTF-8'?>
<odoo>
  <record id="odoo_studio_stock_pi_a2f93bf4-089e-4696-bcea-c76b0da99856" model="ir.ui.view">
    <field name="arch" type="xml">
      <data>
        <xpath expr="//kanban" position="attributes">
          <attribute name="create">0</attribute>
        </xpath>
        <xpath expr="//field[@name='user_id']" position="replace"/>
        <xpath expr="//field[@name='activity_ids']" position="replace"/>
        <xpath expr="//field[@name='state']" position="replace">
          <field name="move_ids" display="full" widget="x2_many_media_viewer" string="Products" options="{}"/>
          <field widget="statinfo" class="bg-danger text-white fw-bold text-uppercase ms-auto" name="activity_type_icon" display="full" string="Late"
            invisible="(state in ['assigned', 'waiting', 'confirmed']) and (scheduled_date and scheduled_date &gt;= current_date)"/>
        </xpath>
      </data>
    </field>
    <field name="inherit_id" ref="stock.stock_picking_kanban"/>
    <field name="mode">extension</field>
    <field name="active" eval="True"/>
    <field name="model">stock.picking</field>
    <field name="name">Odoo Studio: stock.picking.kanban customization</field>
    <field name="priority">99</field>
    <field name="type">kanban</field>
  </record>

