<?xml version='1.0' encoding='UTF-8'?>
<odoo noupdate="1">
  <record id="pos_config_libraries" model="pos.config">
    <field name="name">Library</field>
    <field name="available_pricelist_ids" eval="[(6, 0, [ref('product_pricelist_2')])]"/>
    <field name="tip_product_id" eval="False"/>
    <field name="advanced_employee_ids" eval="[(6, 0, [ref('hr.employee_admin')])]"/>
    <field name="use_pricelist" eval="True"/>
  </record>
  <record model="pos.config" id="pos_config_libraries">
      <field name="payment_method_ids" eval="[
          Command.link(ref('pos_payment_method_1')),
          Command.link(ref('pos_payment_method_2')),
          Command.link(ref('pos_payment_method_3')),
      ]"/>
    </record>
</odoo>
