  <record id="form_view_for_x_pets_line_model" model="ir.ui.view">
    <field name="name">Default form view for x_pets_line_model customization</field>
    <field name="inherit_id" ref="form_view_for_x_pets_line_model_default"/>
    <field name="mode">extension</field>
    <field name="model">x_pets_line_model</field>
    <field name="active" eval="True"/>
    <field name="priority">99</field>
    <field name="type">form</field>
    <field name="arch" type="xml">
      <data>
        <xpath expr="//form[1]/sheet[1]/div[not(@name)][1]" position="before">
          <div name="button_box" class="oe_button_box">
            <button name="%(sale_order_x_pet_window_action)d" class="oe_stat_button" icon="fa-dollar" type="action">
              <field widget="statinfo" name="x_x_pet_sale_order_count" string="Sales Order"/>
            </button>
            <button name="%(ir_actions_server_795)d" string="Catalog" type="action" class="oe_stat_button" icon="fa-cart-plus">
              <field widget="statinfo" name="x_products" string="Catalog"/>
            </button>
          </div>
          <field name="x_picture" widget="image" class="oe_avatar ml-3 mr-3" options="{&quot;size&quot;:[0,90],&quot;zoom&quot;:true}"/>
        </xpath>
        <xpath expr="//field[@name='x_name']" position="attributes">
          <attribute name="force_save">1</attribute>
          <attribute name="invisible">False</attribute>
          <attribute name="readonly">True</attribute>
          <attribute name="required">False</attribute>
        </xpath>
        <xpath expr="//group[@name='studio_group_343124_left']" position="attributes">
          <attribute name="string">Pet Details</attribute>
        </xpath>
        <xpath expr="//group[@name='studio_group_343124_left']" position="inside">
          <field name="x_appointment_date"/>
          <field name="x_pet_owner" required="True"/>
          <field name="x_pet_name" widget="char" required="True"/>
          <field name="x_microchip_number" required="True"/>
          <field name="x_species" options="{'create_name_field': 'x_name'}"/>
          <field name="x_breed" options="{'create_name_field': 'x_name'}"/>
          <field name="x_aggression_level" widget="badge"/>
          <field name="x_reproductive_status"/>
          <field name="x_pet_date_of_birth"/>
        </xpath>
        <xpath expr="//group[@name='studio_group_343124_right']" position="attributes">
          <attribute name="string">General observations</attribute>
        </xpath>
        <xpath expr="//group[@name='studio_group_343124_right']" position="inside">
          <field widget="file" invisible="True" name="x_bloodwork_filename"/>
          <field name="x_observed_illnesses" widget="many2many_tags"/>
          <field name="x_diet_nutrition"/>
          <field name="x_activity_level_exercise"/>
          <field name="x_sale_order_line_count" invisible="True"/>
          <field name="x_total_sale_price" invisible="True"/>
          <field name="x_currency_id" invisible="True"/>
          <field name="x_sale_order_link" invisible="True"/>
        </xpath>
        <xpath expr="//group[@name='studio_group_343124']" position="after">
          <group name="studio_group_27e_1ijt7d29e" string="Appointment summary">
            <field name="x_general_remarks" help="Visit remarks" placeholder="Meeting remarks"/>
            <field name="x_vaccines_given" widget="many2many_tags"/>
          </group>
          <notebook name="studio_notebook_6if_1ijskjq87">
            <page string="Physical" name="studio_page_6if">
              <group name="studio_group_6if">
                <group name="studio_group_6if_left">
                  <field name="x_weight" string="Weight"/>
                  <field name="x_temperature"/>
                  <field name="x_heart_rate"/>
                  <field name="x_respiration_rate"/>
                </group>
                <group name="studio_group_6if_right">
                  <field name="x_dental_health"/>
                  <field name="x_skin_condition"/>
                  <field name="x_coat_condition"/>
                  <field name="x_ear_health"/>
                  <field name="x_nose_health"/>
                </group>
              </group>
              <group name="studio_group_4i4_1ijsot21s" string="Rehabilitation or Physical Therapy Plan">
                <field name="x_rehabilitation_plan" string="Details"/>
              </group>
            </page>
            <page string="Lab Tests &amp; Diagnostics" name="studio_page_8ar_1ijslo2fe">
              <group name="studio_group_8ar">
                <group name="studio_group_8ar_left">
                  <field widget="binary" filename="x_bloodwork_filename" name="x_bloodwork"/>
                  <field widget="file" filename="x_x_ray_filename" name="x_x_ray"/>
                  <field widget="file" filename="x_ultrasound_filename" name="x_ultrasound"/>
                  <field widget="file" filename="x_mri_filename" name="x_mri"/>
                  <field widget="file" invisible="True" name="x_mri_filename"/>
                  <field widget="file" invisible="True" name="x_ultrasound_filename"/>
                  <field widget="file" invisible="True" name="x_x_ray_filename"/>
                </group>
                <group name="studio_group_8ar_right">
                  <field widget="file" filename="x_urinalysis_filename" name="x_urinalysis"/>
                  <field widget="file" filename="x_fecal_exam_results_filename" name="x_fecal_exam_results"/>
                  <field widget="file" invisible="True" name="x_fecal_exam_results_filename"/>
                  <field widget="file" invisible="True" name="x_urinalysis_filename"/>
                </group>
              </group>
            </page>
          </notebook>
        </xpath>
        <xpath expr="//form[1]/sheet[1]" position="after">
          <chatter/>
        </xpath>
      </data>
    </field>
  </record>
  <record id="form_view_for_x_pets" model="ir.ui.view">
    <field name="name">Default form view for x_pets customization</field>
    <field name="inherit_id" ref="form_view_for_x_pets_default"/>
    <field name="mode">extension</field>
    <field name="model">x_pets</field>
    <field name="active" eval="True"/>
    <field name="priority">99</field>
    <field name="type">form</field>
    <field name="arch" type="xml">
      <data>
        <xpath expr="//widget[@name='web_ribbon']" position="before">
          <div name="button_box" class="oe_button_box">
            <button name="%(veterinary_visits_window_action)d" class="oe_stat_button" icon="fa-heart" type="action">
              <field widget="statinfo" name="x_x_many2many_field_6r2_1ijqjdqkq_calendar_event_count" string="Appointments"/>
            </button>
          </div>
        </xpath>
        <xpath expr="//field[@name='x_active']" position="after">
          <field name="x_avatar_image" widget="image" class="oe_avatar ml-3 mr-3"/>
        </xpath>
        <xpath expr="//group[@name='left_group']" position="attributes">
          <attribute name="string">Identifiers</attribute>
        </xpath>
        <xpath expr="//group[@name='left_group']" position="inside">
          <field name="x_owner" options="{&quot;no_create&quot;:true}" required="True"/>
          <field name="x_owner_email"/>
          <field name="x_owner_phonemobile"/>
          <field name="x_microchip_number"/>
        </xpath>
        <xpath expr="//group[@name='right_group']" position="attributes">
          <attribute name="string">Information</attribute>
        </xpath>
        <xpath expr="//group[@name='right_group']" position="inside">
          <field name="x_date_of_birth"/>
          <field name="x_species" options="{&quot;create_name_field&quot;:&quot;x_name&quot;,&quot;no_create&quot;:true}"/>
          <field name="x_breed" options="{'create_name_field': 'x_name'}"/>
          <field name="x_gender"/>
          <field name="x_reproductive_status"/>
        </xpath>
        <xpath expr="//group[@name='main_group']" position="after">
          <group name="group_handling_instructions" string="Handling instructions">
            <field name="x_instructions"/>
            <field name="x_aggression_level" widget="selection_badge" options="{&quot;size&quot;:&quot;sm&quot;}"/>
          </group>
        </xpath>
        <xpath expr="//form[1]/sheet[1]/group[not(@name)][1]" position="attributes">
          <attribute name="string">General remarks</attribute>
        </xpath>
        <xpath expr="//field[@name='x_notes']" position="attributes">
          <attribute name="help">Type down your notes here...</attribute>
        </xpath>
        <xpath expr="//page[@name='lines']" position="attributes">
          <attribute name="string">Appointment log</attribute>
        </xpath>
        <xpath expr="//field[@name='x_pets_line_ids_3673c']" position="attributes">
          <attribute name="string">Consultations</attribute>
        </xpath>
        <xpath expr="//field[@name='x_pets_line_ids_3673c']" position="inside">
          <list open_form_view="true" editable="bottom">
            <field name="x_sequence" widget="handle"/>
            <field name="x_name" column_invisible="False" invisible="False" string="Consultation ID" readonly="True"/>
            <field optional="show" name="x_appointment_date_1"/>
            <field optional="show" name="x_general_remarks_1" string="Appointment summary"/>
            <field optional="show" name="x_weight_1"/>
            <field name="x_vaccines_given" optional="show" widget="many2many_tags"/>
            <field name="x_observed_illnesses" optional="show" widget="many2many_tags"/>
          </list>
        </xpath>
      </data>
    </field>
  </record>
