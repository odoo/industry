  <record id="calendar_event_custom_form_view" model="ir.ui.view">
    <field name="name">calendar.event.form customization</field>
    <field name="inherit_id" ref="calendar.view_calendar_event_form"/>
    <field name="mode">extension</field>
    <field name="model">calendar.event</field>
    <field name="active" eval="True"/>
    <field name="priority">160</field>
    <field name="type">form</field>
    <field name="arch" type="xml">
      <data>
        <xpath expr="//form[1]/sheet[1]/group[1]/group[1]/label[6]" position="replace"/>
        <xpath expr="//button[@name='set_discuss_videocall_location']" position="replace"/>
        <xpath expr="//form[1]/sheet[1]/group[1]/group[1]/label[5]" position="replace"/>
        <xpath expr="//div[@name='videocall_location_div']" position="after">
          <xpath expr="//field[@name='videocall_location']" position="move"/>
        </xpath>
        <xpath expr="//field[@name='categ_ids']" position="attributes">
          <attribute name="invisible">True</attribute>
        </xpath>
        <xpath expr="//field[@name='show_as']" position="attributes">
          <attribute name="invisible">True</attribute>
        </xpath>
        <xpath expr="//field[@name='privacy']" position="attributes">
          <attribute name="invisible">True</attribute>
        </xpath>
        <xpath expr="//field[@name='user_id']" position="after">
          <xpath expr="//form[1]/sheet[1]/group[1]/group[1]/field[@name='appointment_type_id']" position="move"/>
          <xpath expr="//field[@name='appointment_status']" position="move"/>
        </xpath>
        <xpath expr="//form[1]/sheet[1]/group[1]/group[2]/div[2]" position="after">
          <field name="create_uid" invisible="True"/>
          <field name="appointment_booker_id" string="Pet Owner"/>
        </xpath>
        <xpath expr="//form[1]/sheet[1]/group[1]/group[2]/div[3]" position="after">
          <xpath expr="//field[@name='location']" position="move"/>
        </xpath>
        <xpath expr="//page[@name='page_invitations']" position="attributes">
          <attribute name="invisible">True</attribute>
        </xpath>
        <xpath expr="//form[1]/sheet[1]/notebook[1]/page[@name='page_invitations']/field[@name='attendee_ids']/list[1]" position="attributes">
          <attribute name="open_form_view">true</attribute>
        </xpath>
        <xpath expr="//page[@name='page_questions']" position="before">
          <page string="Pets">
            <field name="x_many2many_field_6r2_1ijqjdqkq" domain="[('x_owner', '=', appointment_booker_id)]" context="{'default_x_owner': appointment_booker_id}">
              <list>
                <field name="x_sequence" widget="handle"/>
                <field name="x_name" string="Name"/>
                <field name="x_species" optional="show"/>
                <field name="x_gender" optional="show"/>
                <field name="x_breed" optional="show"/>
                <field name="x_aggression_level" optional="show"/>
                <field name="x_date_of_birth" optional="show"/>
                <field name="x_owner" optional="show"/>
                <button name="%(ir_actions_server_790)d" type="action" string="View"/>
              </list>
            </field>
          </page>
        </xpath>
        <xpath expr="//field[@name='videocall_location']" position="attributes">
          <attribute name="force_save"/>
          <attribute name="invisible">True</attribute>
          <attribute name="readonly"/>
          <attribute name="string"/>
          <attribute name="widget"/>
        </xpath>
        <xpath expr="//form[1]/sheet[1]/group[1]/group[1]/field[@name='appointment_type_id']" position="attributes">
          <attribute name="invisible">False</attribute>
        </xpath>
      </data>
    </field>
  </record>
