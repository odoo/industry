#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>\n"
"            Use the Sign App to manage consent forms, employee contracts, "
"and more !<br/>\n"
"            <br/>\n"
"        </strong>"
msgstr ""
"<strong>\n"
"            Gunakan Aplikasi Tanda Tangan untuk mengelola formulir "
"persetujuan, kontrak karyawan, dan masih banyak lagi!<br/>\n"
"            <br/>\n"
"        </strong>"

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong><b>Appointments App</b>:</strong> Streamline the booking process for "
"pet owners, allowing them to\n"
"                schedule check-ups and surgeries online 24/7.<br/>"
msgstr ""
"<strong><b>Aplikasi Appointment</b>:</strong> Permudah proses pemesanan "
"janji temu untuk para pemilik hewan agar mereka\n"
"                dapat menjadwalkan pemeriksaan dan operasi secara online "
"24/7.<br/>"

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong><b>Invoicing App</b>:</strong> Simplify your finances by "
"automatically generating invoices from\n"
"                completed consultations and product sales.<br/>"
msgstr ""
"<strong><b>Aplikasi Faktur</b>:</strong> Sederhanakan proses keuangan Anda "
"dengan membuat faktur secara otomatis dari\n"
"                penyelesaian konsultasi dan penjualan produk.<br/>"

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong><b>Marketing App</b>: </strong>Engage your community with targeted "
"email campaigns for vaccination\n"
"                reminders and seasonal health check-ups.<br/>"
msgstr ""
"<strong><b>Aplikasi Marketing</b>: </strong>Pastikan komunitas Anda selalu "
"terhubung dengan kampanye email bertarget untuk pengingat\n"
"                vaksinasi dan pemeriksaan kesehatan musiman.<br/>"

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong><b>Point of Sale App</b>: </strong>Facilitate a smooth checkout "
"experience by linking consultations and\n"
"                product sales directly to your payment terminal.<br/>"
msgstr ""
"<strong><b>Aplikasi Point of Sale</b>: </strong>Berikan pengalaman "
"pembayaran yang mulus dengan menghubungkan konsultasi dan\n"
"                penjualan produk langsung ke terminal pembayaran Anda.<br/>"

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong><b>Website App</b>: </strong>Build a professional online presence to "
"market your clinic, share health\n"
"                tips, and attract new pet owners.<br/>"
msgstr ""
"<strong><b>Aplikasi Website</b>: </strong>Bangun presensi online yang "
"profesional untuk memasarkan klinik Anda, berbagi tips\n"
"                kesehatan, dan memikat pemilik peliharaan baru.<br/>"

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid "<strong><span class=\"h2-fs\">Tips for Success</span></strong>"
msgstr "<strong><span class=\"h2-fs\">Tips agar Sukses</span></strong>"

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Attachments</strong> store lab results, X‑rays, or referral letters "
"alongside notes in the <strong>Lab Tests &amp; Diagnostics tab</strong>."
msgstr ""
"<strong>Lampiran</strong> simpan hasil lab, X‑ray, atau surat rujukan "
"beserta catatan di <strong>tab Uji Lab &amp; Diagnostik</strong>."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Automate reminders.</strong> SMS or email nudges cut no‑shows and "
"keep vaccinations on schedule."
msgstr ""
"<strong>Otomatiskan pengingat.</strong> SMS atau email pengingat dapat "
"mengurangi tingkat ketidakhadiran dan memastikan jadwal vaksinasi berjalan "
"lancar."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Automatic confirmations &amp; reminders</strong> via email/SMS keep "
"owners informed."
msgstr ""
"<strong>Konfirmasi &amp; pengingat otomatis</strong> melalui email/SMS "
"memastikan pemilik hewan tetap mendapatkan informasi."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Barcode &amp; RFID</strong> scanning speeds up product selection."
msgstr ""
"Pemindaian <strong>barcode &amp; RFID</strong> mempercepat pemilihan produk."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Booking widget</strong> automatically links to the Appointment app "
"for real‑time availability."
msgstr ""
"<strong>Widget pemesanan</strong> secara otomatis terhubung ke aplikasi "
"Appointment untuk melacak ketersediaan secara real-time."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid "<strong>Buffer times</strong> between consults prevent overruns."
msgstr ""
"<strong>Waktu buffer</strong> di sela-sela konsultasi akan mencegah "
"keterlambatan."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Custom fields</strong> capture weight, insurance, behavior notes, or "
"anything you need."
msgstr ""
"<strong>Field kustom</strong> dapat digunakan untuk mencatat berat, "
"asuransi, catatan perilaku, atau apa pun yang Anda butuhkan."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Drag‑and‑drop builder</strong> to create service, team, and FAQ "
"pages in minutes."
msgstr ""
"<strong>Gunakan builder tarik-lepas</strong> untuk membuat halaman layanan, "
"tim, dan FAQ dalam hitungan menit."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Electronic signatures</strong> accelerate acceptance for surgeries "
"or long‑term care plans."
msgstr ""
"<strong>Tanda tangan elektronik</strong> mempercepat persetujuan operasi "
"atau rencana perawatan jangka panjang."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Experiment ! </strong>Did you know you can create a copy of your "
"database to try things out ? Simply go to"
msgstr ""
"<strong>Eksperimen! </strong>Apakah Anda tahu Anda dapat membuat salinan "
"database untuk mencoba hal-hal baru ? Cukup kunjungi"

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Live chat</strong> answers visitor questions and captures leads 24/7."
msgstr ""
"<strong>Live chat</strong> menjawab pertanyaan pengunjung dan mengumpulkan "
"prospek 24/7."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid "<strong>Lot/serial tracking</strong> meets pharmaceutical compliance."
msgstr ""
"<strong>Pelacakan lot/nomor seri</strong> untuk memenuhi kepatuhan farmasi."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Multiple payment methods</strong> (cash, card, vouchers) in one "
"screen."
msgstr ""
"<strong>Beragam metode pembayaran</strong> (tunai, kartu, voucher) dalam "
"satu layar."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Multiple units</strong> (dose, box, bottle) with automatic "
"conversions."
msgstr ""
"<strong>Beragam unit</strong> (dosis, kotak, botol) dengan konversi otomatis."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>One‑click product picker</strong> adds vaccines or meds directly to "
"the visit through the <strong>catalog</strong>."
msgstr ""
"<strong>Pemilih produk sekali klik</strong> menambahkan vaksin atau obat "
"langsung ke kunjungan melalui katalog <strong></strong> ."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>One‑click quotation</strong> from consultation converts to invoice "
"or POS ticket."
msgstr ""
"<strong>Surat penawaran sekali klik</strong> dari konsultasi menjadi faktur "
"atau tiket POS."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Online calendar</strong> shows real‑time slots for each vet or room."
msgstr ""
"<strong>Kalender online</strong> menampilkan slot waktu setiap dokter atau "
"ruang secara real-time."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Our Appointment app enables self‑service booking, calendar sync, and "
