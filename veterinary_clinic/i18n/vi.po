#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid "<strong><span class=\"h2-fs\">Tips for Success</span></strong>"
msgstr "<strong><span class=\"h2-fs\">Mẹo thành công</span></strong>"

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Attachments</strong> store lab results, X‑rays, or referral letters "
"alongside notes in the <strong>Lab Tests &amp; Diagnostics tab</strong>."
msgstr ""
"<strong>Phụ lục</strong> lưu trữ kết quả xét nghiệm, phim X-quang hoặc thư "
"giới thiệu cùng với ghi chú trong phần \" <strong>\" (Thông tin bệnh nhân) "
"của tab \"Lab Tests\" (Xét nghiệm) trong phần \" &amp; \" (Chẩn đoán)</"
"strong>."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Automate reminders.</strong> SMS or email nudges cut no‑shows and "
"keep vaccinations on schedule."
msgstr ""
"<strong>Tự động hóa các lời nhắc.</strong> Các lời nhắc qua tin nhắn SMS "
"hoặc email giúp giảm tỷ lệ vắng mặt và đảm bảo tiêm chủng đúng lịch."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Automatic confirmations &amp; reminders</strong> via email/SMS keep "
"owners informed."
msgstr ""
"<strong>Xác nhận tự động &amp; Nhắc nhở</strong> qua email/SMS giúp chủ sở "
"hữu luôn được cập nhật thông tin."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Barcode &amp; RFID</strong> scanning speeds up product selection."
msgstr ""
"<strong>Mã vạch &amp; RFID</strong> giúp tăng tốc độ quét, từ đó nâng cao "
"hiệu quả lựa chọn sản phẩm."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Booking widget</strong> automatically links to the Appointment app "
"for real‑time availability."
msgstr ""
"<strong>Widget đặt lịch</strong> tự động kết nối với ứng dụng Đặt lịch để "
"hiển thị tình trạng sẵn có theo thời gian thực."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid "<strong>Buffer times</strong> between consults prevent overruns."
msgstr ""
"<strong>Thời gian đệm</strong> giữa các cuộc tư vấn giúp tránh tình trạng "
"vượt quá thời gian."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Custom fields</strong> capture weight, insurance, behavior notes, or "
"anything you need."
msgstr ""
"<strong>Các trường tùy chỉnh</strong> cho phép bạn ghi lại trọng lượng, "
"thông tin bảo hiểm, ghi chú về hành vi hoặc bất kỳ thông tin nào bạn cần."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Drag‑and‑drop builder</strong> to create service, team, and FAQ "
"pages in minutes."
msgstr ""
"<strong>Trình tạo trang kéo và thả</strong> giúp bạn tạo các trang dịch vụ, "
"đội ngũ và câu hỏi thường gặp chỉ trong vài phút."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Electronic signatures</strong> accelerate acceptance for surgeries "
"or long‑term care plans."
msgstr ""
"<strong>Chữ ký điện tử</strong> giúp đẩy nhanh quá trình chấp thuận cho các "
"ca phẫu thuật hoặc kế hoạch chăm sóc dài hạn."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Experiment ! </strong>Did you know you can create a copy of your "
"database to try things out ? Simply go to"
msgstr ""
"<strong>Thử nghiệm! </strong>Bạn có biết rằng bạn có thể tạo một bản sao của "
"cơ sở dữ liệu để thử nghiệm các tính năng mới không? Chỉ cần truy cập"

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Live chat</strong> answers visitor questions and captures leads 24/7."
msgstr ""
"<strong>Trò chuyện trực tuyến</strong> trả lời câu hỏi của khách truy cập và "
"thu thập thông tin khách hàng tiềm năng 24/7."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid "<strong>Lot/serial tracking</strong> meets pharmaceutical compliance."
msgstr ""
"<strong>Theo dõi lô/số seri</strong> tuân thủ các quy định về dược phẩm."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Multiple payment methods</strong> (cash, card, vouchers) in one "
"screen."
msgstr ""
"<strong>Nhiều phương thức thanh toán (</strong> ) (tiền mặt, thẻ, phiếu giảm "
"giá) trên cùng một màn hình."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Multiple units</strong> (dose, box, bottle) with automatic "
"conversions."
msgstr ""
"<strong>Các đơn vị đo lường đa dạng (</strong> ) cho liều lượng, hộp, chai "
"với tính năng chuyển đổi tự động."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>One‑click product picker</strong> adds vaccines or meds directly to "
"the visit through the <strong>catalog</strong>."
msgstr ""
"<strong>Công cụ chọn sản phẩm một cú nhấp chuột</strong> cho phép thêm vắc-"
"xin hoặc thuốc trực tiếp vào lịch trình thăm khám thông qua danh mục sản "
"phẩm của Hiệp hội Bác sĩ Gia đình Hoa Kỳ ( <strong>) tại</strong>."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>One‑click quotation</strong> from consultation converts to invoice "
"or POS ticket."
msgstr ""
"<strong>Báo giá một cú nhấp chuột</strong> từ cuộc tư vấn có thể chuyển đổi "
"thành hóa đơn hoặc phiếu bán hàng POS."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Online calendar</strong> shows real‑time slots for each vet or room."
msgstr ""
"<strong>Lịch trực tuyến</strong> hiển thị các khung giờ trống theo thời gian "
"thực cho từng bác sĩ thú y hoặc phòng khám."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Our Appointment app enables self‑service booking, calendar sync, and "
"effortless follow‑ups.</strong>"
msgstr ""
"<strong>Ứng dụng Đặt lịch hẹn của chúng tôi cho phép đặt lịch tự động, đồng "
"bộ lịch và theo dõi dễ dàng.</strong>"

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Our Consultation sheets record symptoms, vitals, and actions while "
"keeping the vet’s workflow fluid.</strong>"
msgstr ""
"<strong>Phiếu tư vấn của chúng tôi ghi chép các triệu chứng, chỉ số sinh tồn "
"và các biện pháp can thiệp, đồng thời đảm bảo quy trình làm việc của bác sĩ "
"thú y diễn ra trơn tru.</strong>"

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Our POS lets receptionists scan, split bills, and print receipts—"
"while stock levels adjust instantly.</strong>"
msgstr ""
"<strong>Hệ thống POS của chúng tôi cho phép nhân viên lễ tân quét mã, chia "
"hóa đơn và in biên lai—trong khi mức tồn kho được điều chỉnh ngay lập tức.</"
"strong>"

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Our Pet records feature centralizes identity, vaccination status, "
"and allergies for safer treatments.</strong>"
msgstr ""
"<strong>Tính năng Hồ sơ Thú cưng của chúng tôi tập trung quản lý thông tin "
"nhận dạng, tình trạng tiêm phòng và dị ứng để đảm bảo các phương pháp điều "
"trị an toàn hơn.</strong>"

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Our Product management keeps pricing, barcodes, and expiry dates "
"accurate across sales channels.</strong>"
msgstr ""
"<strong>Bộ phận Quản lý Sản phẩm của chúng tôi đảm bảo giá cả, mã vạch và "
"ngày hết hạn luôn chính xác trên tất cả các kênh bán hàng.</strong>"

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Our Sales app groups treatments, products, and services into neat "
"documents owners trust.</strong>"
msgstr ""
"<strong>Ứng dụng Bán hàng của chúng tôi phân loại các liệu trình, sản phẩm "
"và dịch vụ thành các tài liệu gọn gàng mà chủ sở hữu tin tưởng.</strong>"

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Our Website app lets you publish pages, embed booking widgets, and "
"convert visitors into appointments.</strong>"
msgstr ""
"<strong>Ứng dụng trang web của chúng tôi cho phép bạn đăng tải trang web, "
"nhúng các tiện ích đặt lịch và chuyển đổi khách truy cập thành lịch hẹn.</"
"strong>"

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Owner relationship</strong> connects contact details for billing and "
"reminders."
msgstr ""
"<strong>Mối quan hệ chủ sở hữu</strong> kết nối thông tin liên hệ cho việc "
"thanh toán và nhắc nhở."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Payment terms</strong> handle deposits, installments, or immediate "
"pay."
msgstr ""
"<strong>Điều kiện thanh toán</strong> xử lý tiền đặt cọc, thanh toán theo "
"đợt hoặc thanh toán ngay lập tức."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Price lists &amp; promos</strong> support wellness plans or "
"discounted packages."
msgstr ""
"<strong>Bảng giá &amp; khuyến mãi</strong> hỗ trợ các gói chăm sóc sức khỏe "
"hoặc gói ưu đãi."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Real‑time sync</strong> with accounting and inventory for zero "
"re‑entry."
msgstr ""
"<strong>Đồng bộ hóa thời gian thực</strong> với kế toán và tồn kho để loại "
"bỏ việc nhập lại dữ liệu."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Reorder rules</strong> trigger purchase orders before you run out."
msgstr ""
"<strong>Quy tắc đặt hàng lại</strong> kích hoạt đơn đặt hàng trước khi hết "
"hàng."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Revenue reporting</strong> reveals top services, margins, and "
"seasonal trends."
msgstr ""
"<strong>Báo cáo doanh thu</strong> cho thấy các dịch vụ hàng đầu, biên lợi "
"nhuận và xu hướng theo mùa."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>SEO tools</strong> improve ranking so local pet owners find you "
"first."
msgstr ""
"<strong>Công cụ SEO</strong> giúp cải thiện thứ hạng để chủ nuôi thú cưng "
"địa phương tìm thấy bạn đầu tiên."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Staff agenda integration</strong> syncs with Google, Outlook, and "
"mobile calendars."
msgstr ""
"<strong>Tích hợp lịch làm việc của nhân viên</strong> đồng bộ với Google, "
"Outlook và lịch trên thiết bị di động."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Start small, iterate.</strong> Configure your website and "
"appointments first, then add your products to the mix, before managing your "
"consultations."
msgstr ""
"<strong>Bắt đầu từ những điều nhỏ, sau đó cải tiến dần.</strong> Đầu tiên, "
"hãy cấu hình trang web và lịch hẹn của bạn, sau đó thêm sản phẩm vào, trước "
"khi quản lý các cuộc tư vấn."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Template fields </strong>(vaccines, agression level, observed "
"ilnesses, etc.) speed up SOAP or problem‑oriented entries."
msgstr ""
"<strong>Các trường mẫu ( </strong>) (vắc-xin, mức độ tấn công, các bệnh lý "
"được quan sát, v.v.) giúp tăng tốc quá trình nhập liệu theo định dạng SOAP "
"hoặc theo hướng vấn đề."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>The chatter </strong>can be used to track ongoing discussion about a "
"pet's consultation for record keeping."
msgstr ""
"<strong>Trang web </strong>có thể được sử dụng để theo dõi các cuộc thảo "
"luận đang diễn ra về cuộc tư vấn cho thú cưng nhằm mục đích lưu trữ hồ sơ."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Touch interface</strong> optimized for tablets or desktop stations."
msgstr ""
"<strong>Giao diện cảm ứng</strong> được tối ưu hóa cho máy tính bảng hoặc "
"trạm làm việc để bàn."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Unique pet IDs</strong> with breed, color, microchip, and photo."
msgstr ""
"<strong>Mã định danh thú cưng duy nhất</strong> bao gồm giống, màu lông, "
"chip điện tử và hình ảnh."

#. module: veterinary_clinic
#: model_terms:ir.ui.view,arch_db:veterinary_clinic.welcome_article_body
msgid ""
"<strong>Vaccination timeline</strong> shows past and due shots at a glance."
msgstr ""
"<strong>Lịch tiêm chủng</strong> hiển thị các mũi tiêm đã tiêm và các mũi "
"tiêm sắp đến hạn một cách nhanh chóng."

