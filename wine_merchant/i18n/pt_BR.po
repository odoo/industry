#. module: wine_merchant
#: model_terms:ir.ui.view,arch_db:wine_merchant.welcome_article_body
msgid ""
"<b>CRM App</b>: Cultivate lasting relationships with wine lovers by managing "
"interactions and tracking potential\n"
"            leads for private sales or memberships."
msgstr ""
"<b>Aplicativo CRM</b>: Cultive relacionamentos duradouros com os "
"apreciadores de vinho, gerenciando interações e acompanhando leads "
"potenciais\n"
"para vendas privadas ou associações."

#. module: wine_merchant
#: model_terms:ir.ui.view,arch_db:wine_merchant.ir_ui_view_3281
msgid "<b>Designed</b> for companies"
msgstr "<b>Projetado</b> para empresas"

#. module: wine_merchant
#: model_terms:ir.ui.view,arch_db:wine_merchant.welcome_article_body
msgid ""
"<b>Events App</b>: Engage your community by organizing and managing "
"registrations for wine tastings, workshops, and\n"
"            exclusive release parties."
msgstr ""
"<b>App Eventos</b>: Envolva sua comunidade organizando e gerenciando "
"inscrições para degustações de vinhos, workshops e\n"
"            festas de lançamento exclusivas."

#. module: wine_merchant
#: model_terms:ir.ui.view,arch_db:wine_merchant.welcome_article_body
msgid ""
"<b>Inventory App</b>: Manage your cellar with precision, ensuring structure "
"and clarity for thousands of bottles,\n"
"            vintages, and locations."
msgstr ""
"<b>App Inventário</b>: Gerencie sua adega com precisão, garantindo estrutura "
"e clareza para milhares de garrafas,\n"
" safras e locais."

#. module: wine_merchant
#: model_terms:ir.ui.view,arch_db:wine_merchant.ir_ui_view_3281
msgid ""
"<b>My Company</b><br/>250 Executive Park Blvd, Suite 3400 <br/> San "
"Francisco CA 94134 <br/>United States"
msgstr ""
"<b>Minha empresa</b><br/>Av. Brasil, Nº 250, Apto. 3400 <br/> Rio de Janeiro "
"RJ 94134-777 <br/> Brasil"

#. module: wine_merchant
#: model_terms:ir.ui.view,arch_db:wine_merchant.welcome_article_body
msgid ""
"<b>Point of Sale App</b>: Deliver a smooth in-store experience with an "
"intuitive interface that handles bottle and\n"
"            case sales seamlessly."
msgstr ""
"<b>Aplicativo Ponto de Venda</b>: Ofereça uma experiência tranquila na loja "
"com uma interface intuitiva que lida com vendas de garrafas e\n"
"caixas de forma integrada."

#. module: wine_merchant
#: model_terms:ir.ui.view,arch_db:wine_merchant.welcome_article_body
msgid ""
"<b>Purchase App</b>: Automate the replenishment of your stock by tracking "
"purchase orders and managing supplier\n"
"            relationships effectively."
msgstr ""
"<b>Aplicativo Compras</b>: Automatize a reposição do seu estoque rastreando "
"pedidos de compra e gerenciando relacionamentos com fornecedores de maneira "
"eficaz."

#. module: wine_merchant
#: model_terms:ir.ui.view,arch_db:wine_merchant.welcome_article_body
msgid ""
"<b>Sales App</b>: Streamline your B2B and B2C transactions by creating "
"professional quotations and sales orders\n"
"            efficiently."
msgstr ""
"<b>Aplicativo de vendas</b>: simplifique suas transações B2B e B2C criando "
"cotações profissionais e pedidos de venda de maneira eficiente."

#. module: wine_merchant
#: model_terms:ir.ui.view,arch_db:wine_merchant.welcome_article_body
msgid ""
"<b>eCommerce App</b>: Expand your reach beyond the shop floor by showcasing "
"your wine selection and enabling secure\n"
"            online purchases."
msgstr ""
"<b>Aplicativo e-Commerce </b>: Expanda seu alcance além do Chão de Fábrica, "
"exibindo sua seleção de vinhos e permitindo compras online seguras."

