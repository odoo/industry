    <record id="pharmaceuticals_retailers.odoo_studio_account__10669c84-d170-4e8c-873a-04c171a1440b" model="ir.ui.view">
        <field name="name">Odoo Studio: account.move.form customization</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form" />
        <field name="arch" type="xml">
            <data>
                <xpath expr="//form[1]/sheet[1]/group[1]/group[1]/label[1]" position="attributes">
                    <attribute name="string">Patient Name</attribute>
                </xpath>
                <xpath expr="//form[1]/sheet[1]/group[1]/group[2]/field[@name='currency_id']" position="after">
                    <field name="x_studio_doctor_name" string="Doctor Name" />
                </xpath>
            </data>
        </field>
        <field name="type">form</field>
        <field name="mode">extension</field>
        <field name="priority">160</field>
    </record>
    <record id="pharmaceuticals_retailers.odoo_studio_product__c9384baa-e7e5-4d36-a581-be6934ec0b8c" model="ir.ui.view">
        <field name="name">Odoo Studio: product.template.product.form customization</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view" />
        <field name="arch" type="xml">
            <data>
                <xpath expr="//form[@name='Product Template']/sheet[@name='product_form']/notebook[1]/page[@name='general_information']/group[1]/group[@name='group_standard_price']/label[1]" position="attributes">
                    <attribute name="string">MRP</attribute>
                </xpath>
                <xpath expr="//field[@name='categ_id']" position="attributes">
                    <attribute name="options">{"no_create_edit":false}</attribute>
                </xpath>
                <xpath expr="//field[@name='default_code']" position="attributes">
                    <attribute name="string">Alias Name</attribute>
                </xpath>
                <xpath expr="//field[@name='barcode']" position="after">
                    <field name="x_studio_manufacture" string="Manufacture" domain='[("x_studio_is_a_manufacturer", "=", True)]' />
                    <field name="x_studio_therapeutic_classification" string="Therapeutic Classification" />
                    <field name="x_studio_medical_item_type" string="Medical Item Type" />
                    <field name="x_studio_kind_of_medicine" string="Kind of Medicine" />
                    <field name="x_studio_generic_name" string="Generic Name" widget="autosave_many2many_tags" />
                </xpath>
            </data>
        </field>
        <field name="type">form</field>
        <field name="mode">extension</field>
        <field name="priority">160</field>
        <field name="active" eval="False" />
    </record>
    <record id="pharmaceuticals_retailers.odoo_studio_product__ccc5a006-bdb6-4c1a-a206-d7724b7ce96d" model="ir.ui.view">
        <field name="name">Odoo Studio: product.template.product.form customization</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view" />
        <field name="arch" type="xml">
            <data>
                <xpath expr="//form[@name='Product Template']/sheet[@name='product_form']/notebook[1]/page[@name='general_information']/group[1]/group[@name='group_general']/div[not(@name)][1]" position="after">
                    <field name="x_studio_manufacture" domain='[("x_studio_is_a_manufacturer", "=", True)]' />
                </xpath>
                <xpath expr="//field[@name='list_price']" position="attributes">
                    <attribute name="string">MRP</attribute>
                </xpath>
                <xpath expr="//field[@name='default_code']" position="attributes">
                    <attribute name="string">Alias Name</attribute>
                </xpath>
                <xpath expr="//field[@name='product_tag_ids']" position="attributes">
                    <attribute name="string">Generic Name</attribute>
                </xpath>
            </data>
        </field>
        <field name="type">form</field>
        <field name="mode">extension</field>
        <field name="priority">160</field>
    </record>
    <record id="pharmaceuticals_retailers.odoo_studio_purchase_c357197d-c315-4096-8792-a968375b00cd" model="ir.ui.view">
        <field name="name">Odoo Studio: purchase.order.form customization</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form" />
        <field name="arch" type="xml">
            <data>
                <xpath expr="//field[@name='partner_id']" position="attributes">
                    <attribute name="domain">[("supplier_rank", "&gt;", 0)]</attribute>
                </xpath>
            </data>
        </field>
        <field name="type">form</field>
        <field name="mode">extension</field>
        <field name="priority">160</field>
    </record>
    <record id="pharmaceuticals_retailers.odoo_studio_report_s_5c20c366-f492-4363-865f-7d5559cf151e" model="ir.ui.view">
        <field name="name">Odoo Studio: report_saleorder_document customization</field>
        <field name="inherit_id" ref="sale.report_saleorder_document" />
        <field name="arch" type="xml">
            <data>
                <xpath expr="/t/t/div/div[2]" position="after">
                    <div class="row">
                        <div class="col-3">
                            <span>
                                <strong>Doctor:</strong>
                                <br />
                            </span>
                            <span t-field="doc.x_studio_doctor" />
                        </div>
                        <div class="col-3" />
                        <div class="col-3" />
                        <div class="col-3" />
                    </div>
                </xpath>
            </data>
        </field>
        <field name="type">qweb</field>
        <field name="mode">extension</field>
        <field name="priority">160</field>
        <field name="key">gen_key.1896a2</field>
    </record>
    <record id="pharmaceuticals_retailers.odoo_studio_res_comp_8604f1e2-f1f8-434c-81d1-8c92e05516a5" model="ir.ui.view">
        <field name="name">Odoo Studio: res.company.form customization</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form" />
        <field name="arch" type="xml">
            <data>
                <xpath expr="//field[@name='website']" position="after">
                    <field name="x_studio_drug_license_number" string="Drug License Number" />
                    <field name="x_studio_drug_license_date" string="Drug License Date" />
                </xpath>
            </data>
        </field>
        <field name="type">form</field>
        <field name="mode">extension</field>
        <field name="priority">10000</field>
    </record>
    <record id="pharmaceuticals_retailers.odoo_studio_res_part_76a253e1-3020-45a3-ba98-6a13f898e059" model="ir.ui.view">
        <field name="name">Odoo Studio: res.partner.form customization</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form" />
        <field name="arch" type="xml">
            <data>
                <xpath expr="//field[@name='company_type']" position="attributes">
                    <attribute name="options">{"horizontal":true}</attribute>
                </xpath>
                <xpath expr="//field[@name='vat']" position="after">
                    <field name="x_studio_drug_license_number" string="Drug License Number" />
                    <field name="x_studio_drug_license_date" string="Drug License Date" options='{"warn_future":false}' />
                    <field name="x_studio_registration_number" string="Registration Number" />
                </xpath>
                <xpath expr="//field[@name='category_id']" position="after">
                    <field name="x_studio_is_a_doctor" string="Is a Doctor" />
                    <field name="x_studio_is_a_manufacturer" string="Is a Manufacturer" />
                </xpath>

                <xpath expr="//form[1]/sheet[1]/notebook[1]/page[@name='sales_purchases']/group[@name='container_row_2']/group[@name='sale']/field[@name='user_id']" position="before">
                    <field name="customer_rank" string="Is Customer" />
                </xpath>
                <xpath expr="//field[@name='buyer_id']" position="before">
                    <field name="supplier_rank" string="Is Supplier" />
                </xpath>
            </data>
        </field>
        <field name="type">form</field>
        <field name="mode">extension</field>
        <field name="priority">360</field>
    </record>
    <record id="pharmaceuticals_retailers.odoo_studio_sale_ord_108c17c0-66ee-4666-acd7-3e5c6c0dc68e" model="ir.ui.view">
