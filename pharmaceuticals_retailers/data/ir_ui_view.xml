<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="account_move_form_customization_pharma" model="ir.ui.view">
        <field name="name">account.move.form.customization.pharma</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="type">form</field>
        <field name="mode">extension</field>
        <field name="priority">160</field>
        <field name="arch" type="xml">
            <data>
                <xpath expr="//form[1]/sheet[1]/group[1]/group[1]/label[1]" position="attributes">
                    <attribute name="string">Patient Name</attribute>
                </xpath>
                <xpath expr="//form[1]/sheet[1]/group[1]/group[2]/field[@name='currency_id']" position="after">
                    <field name="x_doctor_name" string="Doctor Name"/>
                </xpath>
            </data>
        </field>
    </record>
    <record id="product_template_product_form_customization_pharma_2" model="ir.ui.view">
        <field name="name">product.template.product.form.customization.pharma</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="type">form</field>
        <field name="mode">extension</field>
        <field name="priority">160</field>
        <field name="arch" type="xml">
            <data>
                <xpath expr="//group[@name='group_general']/div[not(@name)][1]" position="after">
                    <field name="x_manufacture" domain='[("x_is_a_manufacturer", "=", True)]'/>
                </xpath>
                <xpath expr="//field[@name='list_price']" position="attributes">
                    <attribute name="string">MRP</attribute>
                </xpath>
                <xpath expr="//field[@name='default_code']" position="attributes">
                    <attribute name="string">Alias Name</attribute>
                </xpath>
                <xpath expr="//field[@name='product_tag_ids']" position="attributes">
                    <attribute name="string">Generic Name</attribute>
                </xpath>
            </data>
        </field>
    </record>
    <record id="purchase_order_form_customization_pharma" model="ir.ui.view">
        <field name="name">purchase.order.form.customization.pharma</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="type">form</field>
        <field name="mode">extension</field>
        <field name="priority">160</field>
        <field name="arch" type="xml">
            <data>
                <xpath expr="//field[@name='partner_id']" position="attributes">
                    <attribute name="domain">[("supplier_rank", "&gt;", 0)]</attribute>
                </xpath>
            </data>
        </field>
    </record>
    <record id="report_saleorder_document_customization_pharma" model="ir.ui.view">
        <field name="name">report_saleorder_document.customization.pharma</field>
        <field name="inherit_id" ref="sale.report_saleorder_document"/>
        <field name="type">qweb</field>
        <field name="mode">extension</field>
        <field name="priority">160</field>
        <field name="key">gen_key.1896a2</field>
        <field name="arch" type="xml">
            <data>
                <xpath expr="/t/t/div/div[2]" position="after">
                    <div class="row">
                        <div class="col-3">
                            <span>
                                <strong>Doctor:</strong>
                                <br/>
                            </span>
                            <span t-field="doc.x_doctor"/>
                        </div>
                        <div class="col-3"/>
                        <div class="col-3"/>
                        <div class="col-3"/>
                    </div>
                </xpath>
            </data>
        </field>
    </record>
    <record id="res_company_form_customization_pharma" model="ir.ui.view">
        <field name="name">res.company.form.customization.pharma</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="type">form</field>
        <field name="mode">extension</field>
        <field name="priority">10000</field>
        <field name="arch" type="xml">
            <data>
                <xpath expr="//field[@name='website']" position="after">
                    <field name="x_drug_license_number" string="Drug License Number"/>
                    <field name="x_drug_license_date" string="Drug License Date"/>
                </xpath>
            </data>
        </field>
    </record>
    <record id="res_partner_form_customization_pharma" model="ir.ui.view">
        <field name="name">res.partner.form.customization.pharma</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="type">form</field>
        <field name="mode">extension</field>
        <field name="priority">360</field>
        <field name="arch" type="xml">
            <data>
                <xpath expr="//field[@name='company_type']" position="attributes">
                    <attribute name="options">{"horizontal":true}</attribute>
                </xpath>
                <xpath expr="//field[@name='vat']" position="after">
                    <field name="x_drug_license_number" string="Drug License Number"/>
                    <field name="x_drug_license_date" string="Drug License Date" options='{"warn_future":false}'/>
                    <field name="x_registration_number" string="Registration Number"/>
                </xpath>
                <xpath expr="//field[@name='category_id']" position="after">
                    <field name="x_is_a_doctor" string="Is a Doctor"/>
                    <field name="x_is_a_manufacturer" string="Is a Manufacturer"/>
                </xpath>

                <xpath expr="//group[@name='container_row_2']/group[@name='sale']/field[@name='user_id']" position="before">
                    <field name="customer_rank" string="Is Customer"/>
                </xpath>
                <xpath expr="//field[@name='buyer_id']" position="before">
                    <field name="supplier_rank" string="Is Supplier"/>
                </xpath>
            </data>
        </field>
    </record>
    <record id="sale_order_tree_customization_pharma" model="ir.ui.view">
        <field name="name">sale.order.tree.customization.pharma</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_quotation_tree_with_onboarding"/>
        <field name="type">tree</field>
        <field name="mode">extension</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <data>
                <xpath expr="//field[@name='partner_id']" position="attributes">
                    <attribute name="string">Patient Name</attribute>
                </xpath>
            </data>
        </field>
    </record>
    <record id="sale_order_form_customization_pharma" model="ir.ui.view">
        <field name="name">sale.order.form.customization.pharma</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="type">form</field>
        <field name="mode">extension</field>
        <field name="priority">160</field>
        <field name="arch" type="xml">
            <data>
                <xpath expr="//field[@name='partner_id']" position="attributes">
                    <attribute name="domain">[("customer_rank", "&gt;", 0)]</attribute>
                    <attribute name="string">Customer Name</attribute>
                </xpath>
                <xpath expr="//field[@name='validity_date']" position="before">
                    <field name="x_doctor" string="Doctor" domain='[("x_is_a_doctor", "=", True)]'/>
                </xpath>
            </data>
        </field>
    </record>
</odoo>
