                </xpath>
            </data>
        </field>
        <field name="type">tree</field>
        <field name="mode">extension</field>
        <field name="priority">99</field>
    </record>
    <record id="pharmaceuticals_retailers.odoo_studio_sale_ord_8312a4f7-a946-46dc-b006-9ab2396f6f0b" model="ir.ui.view">
        <field name="name">Odoo Studio: sale.order.form customization</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form" />
        <field name="arch" type="xml">
            <data>
                <xpath expr="//field[@name='partner_id']" position="attributes">
                    <attribute name="domain">[("customer_rank", "&gt;", 0)]</attribute>
                    <attribute name="string">Customer Name</attribute>
                </xpath>
                <xpath expr="//field[@name='validity_date']" position="before">
                    <field name="x_studio_doctor" string="Doctor" domain='[("x_studio_is_a_doctor", "=", True)]' />
                </xpath>
            </data>
        </field>
        <field name="type">form</field>
        <field name="mode">extension</field>
        <field name="priority">160</field>
    </record>
