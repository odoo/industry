<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id='fleet_vehicle_model_tyre_type_action' model='ir.actions.act_window'>
        <field name="name">Tyres Type</field>
        <field name="res_model">x_tyre_type</field>
        <field name="view_mode">list</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new tyre type
            </p>
            <p>
                Tyre types will help you manage your fleet more efficiently and arrange your vehicles.
            </p>
        </field>
    </record>
    <record id="ir_actions_act_window_open_linked_vehicles" model="ir.actions.act_window">
        <field name="name">Open linked vehicle of partner</field>
        <field name="domain">[('x_owner_id', '=', active_id)]</field>
        <field name="res_model">fleet.vehicle</field>
    </record>
    <record id="ir_actions_act_window_open_linked_invoices" model="ir.actions.act_window">
        <field name="name">Open linked invoices</field>
        <field name="domain">[('x_task_id', '=', active_id)]</field>
        <field name="res_model">account.move</field>
    </record>
</odoo>
