<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="base_automation_on_update_odometer" model="base.automation">
        <field name="name">On Odometer Update</field>
        <field name="action_server_ids" eval="[(6, 0, [ref('action_update_vehicle_odometer')])]"/>
        <field name="model_id" ref="project.model_project_task"/>
        <field name="on_change_field_ids" eval="[(6, 0, [ref('field_x_odometer')])]"/>
        <field name="trigger">on_create_or_write</field>
    </record>
    <record id="base_automation_on_update_vehicle" model="base.automation">
        <field name="name">On Update vehicle to set the linked customer</field>
        <field name="action_server_ids" eval="[(6, 0, [ref('action_update_vehicle_to_set_linked_customer')])]"/>
        <field name="model_id" ref="project.model_project_task" />
        <field name="trigger">on_change</field>
        <field name="on_change_field_ids" eval="[(6, 0, [ref('x_vehicle_id_field_model_project_task')])]" />
    </record>
    <record id="base_automation_on_update_vehicle_partner_sale_order" model="base.automation">
        <field name="name">On Update vehicle to set the linked customer</field>
        <field name="action_server_ids" eval="[(6, 0, [ref('action_update_vehicle_to_set_linked_customer_sale_order')])]"/>
        <field name="model_id" ref="sale.model_sale_order" />
        <field name="trigger">on_change</field>
        <field name="on_change_field_ids" eval="[(6, 0, [ref('x_vehicle_id_field')])]" />
    </record>
</odoo>
