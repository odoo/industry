<odoo noupdate="1">
    <record id="res_config_settings_fmcg_store" model="res.config.settings">
       <!-- sales -->
       <field name="group_discount_per_so_line" eval="1"/>
       <field name="group_sale_pricelist" eval="1"/>
       <field name="product_pricelist_setting">advanced</field>
       <!-- purchase -->
       <field name="group_product_variant" eval="1"/>
       <field name="group_stock_packaging" eval="1"/>
       <field name="group_uom" eval="1"/>
       <!-- inventory -->
       <field name="group_stock_multi_locations" eval="1"/>
       <field name="group_stock_adv_location" eval="1"/>
       <!-- accounting -->
       <field name="deferred_amount_computation_method">day</field>
       <!-- pos -->
       <field name="point_of_sale_ticket_unique_code" eval="1"/>
    </record>

    <function model="res.config.settings" name="execute">
        <value eval="[ref('res_config_settings_fmcg_store')]"/>
    </function>
</odoo>
