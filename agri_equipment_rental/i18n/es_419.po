#: model_terms:ir.ui.view,arch_db:agri_equipment_rental.welcome_article_body
msgid ""
"<strong>Fleet:</strong> Keep track of vehicles used for delivery and pickup."
msgstr ""
"<strong>Flotilla:</strong> Lleva control de los vehículos utilizados para "
"realizar entregas y recolecciones."

#. module: agri_equipment_rental
#: model_terms:ir.ui.view,arch_db:agri_equipment_rental.welcome_article_body
