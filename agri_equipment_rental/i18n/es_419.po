#: model_terms:ir.ui.view,arch_db:agri_equipment_rental.welcome_article_body
msgid ""
"<strong>Field Service App</strong> allows you to plan on-site interventions, "
"assign tasks, and ensure preventive maintenance is carried out on time."
msgstr ""
"La aplicación <strong>Servicio externo</strong> te permite planificar "
"intervenciones presenciales, asignar tareas y garantizar que el "
"mantenimiento preventivo se realice a tiempo."

#. module: agri_equipment_rental
#: model_terms:ir.ui.view,arch_db:agri_equipment_rental.welcome_article_body
msgid "<strong>Final word</strong>"
msgstr "<strong>Nota final</strong>"

