msgstr ""
"ウェブサイトのフォーム、Eメール、手入力による問い合わせから<strong>リードを追"
"跡</strong>します。"

#. module: agri_equipment_rental
#: model_terms:ir.ui.view,arch_db:agri_equipment_rental.welcome_article_body
msgid ""
"<strong>Track payments and follow up</strong> with automatic reminders."
msgstr "<strong>支払いを追跡し、自動リマインダーで</strong> をフォローアップします。"

#. module: agri_equipment_rental
#: model_terms:ir.ui.view,arch_db:agri_equipment_rental.welcome_article_body
msgid ""
"<strong>Track serial numbers</strong> and view their availability instantly."
msgstr "<strong>シリアルナンバーを追跡</strong>し、在庫状況を即座に確認できます。"

#. module: agri_equipment_rental
#: model_terms:ir.ui.view,arch_db:agri_equipment_rental.welcome_article_body
msgid "<strong>Use case</strong>"
msgstr "<strong>ユースケース</strong>"

#. module: agri_equipment_rental
#: model_terms:ir.ui.view,arch_db:agri_equipment_rental.welcome_article_body
msgid ""
