#. module: agri_equipment_rental
#: model_terms:ir.ui.view,arch_db:agri_equipment_rental.welcome_article_body
msgid ""
"<strong>Generate tasks</strong> automatically when equipment is moved to "
"maintenance location."
msgstr ""
"<strong>تمكن من إنشاء المهام</strong> تلقائيًا عند نقل المعدات إلى موقع "
"الصيانة."

#. module: agri_equipment_rental
#: model_terms:ir.ui.view,arch_db:agri_equipment_rental.welcome_article_body
msgid "<strong>Handle recurring tasks</strong> based on runtime readings."
msgstr "<strong>قم بإدارة المهام المتكررة</strong>بناءً على قراءات وقت التشغيل."

#. module: agri_equipment_rental
#: model_terms:ir.ui.view,arch_db:agri_equipment_rental.welcome_article_body
