msgstr ""
"<strong>تتبع العملاء المحتملين</strong> من استمارات الموقع الإلكتروني أو "
"البريد الإلكتروني أو الاستفسارات المدخلة يدويًا."

#. module: agri_equipment_rental
#: model_terms:ir.ui.view,arch_db:agri_equipment_rental.welcome_article_body
msgid "<strong>Track payments and follow up</strong> with automatic reminders."
msgstr ""
"<strong>تتبع المدفوعات وتابع العملاء</strong> باستخدام التذكيرات التلقائية."

#. module: agri_equipment_rental
#: model_terms:ir.ui.view,arch_db:agri_equipment_rental.welcome_article_body
msgid ""
"<strong>Track serial numbers</strong> and view their availability instantly."
msgstr "<strong>تتبع الأرقام التسلسلية</strong> واطلع على توفرها على الفور."

#. module: agri_equipment_rental
#: model_terms:ir.ui.view,arch_db:agri_equipment_rental.welcome_article_body
