msgstr ""
"Odoo <strong><font class=\"text-o-color-1\">मार्केटिंग ऑटोमेशन</font></strong>, "
"<strong><font class=\"text-o-color-1\">ईमेल मार्केटिंग</font></strong>, \n"
"                        <strong><font class=\"text-o-color-1\">सोशल मीडिया "
