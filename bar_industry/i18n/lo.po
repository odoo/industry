msgstr "ບາ ແລະ ການບໍລິການ"

#. module: bar_industry
#: model:pos.category,name:bar_industry.pos_category_3
msgid "Beers"
msgstr "ເບຍ"

#. module: bar_industry
#: model:uom.uom,name:bar_industry.uom_uom_1
msgid "Bin"
msgstr "ຖັງ"

#. module: bar_industry
#: model:product.template,name:bar_industry.product_product_26_product_template
msgid "Blond Beer"
msgstr "ເບຍ Blond"

#. module: bar_industry
#: model_terms:ir.ui.view,arch_db:bar_industry.welcome_article_body
msgid "By doing so, you have only 23 beers left in your stock."
msgstr "ໂດຍການເຮັດແນວນັ້ນ, ທ່ານຈະເຫຼືອເບຍພຽງແຕ່ 23 ຂວດໃນສະຕັອກຂອງທ່ານ."

#. module: bar_industry
#: model_terms:ir.ui.view,arch_db:bar_industry.welcome_article_body
msgid ""
