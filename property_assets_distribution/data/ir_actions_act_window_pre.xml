<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="analytic_accounts_act_window" model="ir.actions.act_window">
        <field name="context">{'search_default_x_property': active_id, 'default_x_property': active_id}</field>
        <field name="name">Property Analytic Accounts</field>
        <field name="res_model">account.analytic.account</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="owner_properties_contact_smart_button" model="ir.actions.act_window">
        <field name="context">{'search_default_x_current_owner': active_id,'default_x_current_owner': active_id}</field>
        <field name="domain">[('x_current_owner', 'in', active_ids)]</field>
        <field name="name">Properties</field>
        <field name="res_model">x_property</field>
    </record>
</odoo>
