<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="automation_set_usage_meter_reading" model="base.automation">
        <field name="name">Set Usage in Meter Readings</field>
        <field name="model_id" ref="model_meter_reading"/>
        <field name="action_server_ids" eval="[(6, 0, [ref('action_server_set_usage_meter_reading')])]"/>
        <field name="trigger">on_create_or_write</field>
        <field name="trigger_field_ids" eval="[(6, 0, [ref('field_meter_reading_date'), ref('field_meter_reading_quantity'), ref('field_meter_reading_meter_id')])]"/>
    </record>
    <record id="automation_validate_property_tenant_dates" model="base.automation">
        <field name="name">Validate tenant dates</field>
        <field name="model_id" ref="model_x_property_tenant"/>
        <field name="action_server_ids" eval="[(6, 0, [ref('action_validate_property_tenant_dates')])]"/>
        <field name="trigger">on_create_or_write</field>
        <field name="trigger_field_ids" eval="[(6, 0, [ref('field_property_tenant_property_id'), ref('field_property_tenant_start_date'), ref('field_property_tenant_end_date')])]"/>
    </record>
</odoo>
