<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <!-- x_buildings -->
    <record id="description_building" model="ir.model.fields">
        <field name="name">x_name</field>
        <field name="ttype">char</field>
        <field name="field_description">Name</field>
        <field name="model_id" ref="model_buildings"/>
        <field name="required" eval="True"/>
        <field name="tracking">1</field>
        <field name="translate">standard</field>
    </record>
    <record id="active_buildings" model="ir.model.fields">
        <field name="name">x_active</field>
        <field name="ttype">boolean</field>
        <field name="copied" eval="True"/>
        <field name="field_description">Active</field>
        <field name="model_id" ref="model_buildings"/>
        <field name="tracking">1</field>
    </record>
    <record id="sequence_buildings" model="ir.model.fields">
        <field name="name">x_sequence</field>
        <field name="ttype">integer</field>
        <field name="copied" eval="True"/>
        <field name="field_description">Sequence</field>
        <field name="model_id" ref="model_buildings"/>
    </record>
    <record id="street" model="ir.model.fields">
        <field name="name">x_street</field>
        <field name="ttype">char</field>
        <field name="field_description">Street</field>
        <field name="model_id" ref="model_buildings"/>
    </record>
    <record id="street2" model="ir.model.fields">
        <field name="name">x_street2</field>
        <field name="ttype">char</field>
        <field name="field_description">Street2</field>
        <field name="model_id" ref="model_buildings"/>
    </record>
    <record id="city" model="ir.model.fields">
        <field name="name">x_city</field>
        <field name="ttype">char</field>
        <field name="field_description">City</field>
        <field name="model_id" ref="model_buildings"/>
    </record>
    <record id="zip" model="ir.model.fields">
        <field name="name">x_zip</field>
        <field name="ttype">char</field>
        <field name="field_description">ZIP</field>
        <field name="model_id" ref="model_buildings"/>
    </record>
    <record id="country" model="ir.model.fields">
        <field name="name">x_country</field>
        <field name="ttype">many2one</field>
        <field name="field_description">Country</field>
        <field name="model_id" ref="model_buildings"/>
        <field name="relation">res.country</field>
    </record>
    <record id="country_state" model="ir.model.fields">
        <field name="name">x_state</field>
        <field name="ttype">many2one</field>
        <field name="field_description">State</field>
        <field name="model_id" ref="model_buildings"/>
        <field name="relation">res.country.state</field>
    </record>

    <!-- x_buildings_tag -->
    <record id="name_buildings_tags" model="ir.model.fields">
        <field name="name">x_name</field>
        <field name="ttype">char</field>
        <field name="field_description">Name</field>
        <field name="model_id" ref="model_buildings_tags"/>
        <field name="required" eval="True"/>
    </record>
    <record id="color_buildings_tags" model="ir.model.fields">
        <field name="name">x_color</field>
        <field name="ttype">integer</field>
        <field name="field_description">Color</field>
        <field name="model_id" ref="model_buildings_tags"/>
    </record>
    <record id="tags_buildings" model="ir.model.fields">
        <field name="name">x_tag_ids</field>
        <field name="ttype">many2many</field>
        <field name="copied" eval="True"/>
        <field name="field_description">Tags</field>
        <field name="model_id" ref="model_buildings"/>
        <field name="relation">x_buildings_tag</field>
        <field name="relation_table">x_buildings_tag_rel</field>
    </record>

    <!-- x_property -->
    <record id="field_property_name" model="ir.model.fields">
        <field name="name">x_name</field>
        <field name="ttype">char</field>
        <field name="field_description">Name</field>
        <field name="model_id" ref="model_x_property"/>
        <field name="required" eval="True"/>
        <field name="tracking">1</field>
        <field name="translate">standard</field>
    </record>
    <record id="field_property_active" model="ir.model.fields">
        <field name="name">x_active</field>
        <field name="ttype">boolean</field>
        <field name="field_description">Active</field>
        <field name="model_id" ref="model_x_property"/>
        <field name="tracking">1</field>
    </record>
    <record id="field_property_sequence" model="ir.model.fields">
        <field name="name">x_sequence</field>
        <field name="ttype">integer</field>
        <field name="field_description">Sequence</field>
        <field name="model_id" ref="model_x_property"/>
    </record>
    <record id="field_property_building" model="ir.model.fields">
        <field name="name">x_building</field>
        <field name="ttype">many2one</field>
        <field name="field_description">Building</field>
        <field name="model_id" ref="model_x_property"/>
        <field name="relation">x_buildings</field>
    </record>
    <record id="field_property_type" model="ir.model.fields">
        <field name="name">x_type</field>
        <field name="ttype">many2one</field>
        <field name="field_description">Type</field>
        <field name="model_id" ref="model_x_property"/>
        <field name="relation">x_properties_types</field>
    </record>
    <record id="field_property_floor" model="ir.model.fields">
        <field name="name">x_floor</field>
        <field name="ttype">char</field>
        <field name="field_description">Floor</field>
        <field name="model_id" ref="model_x_property"/>
    </record>
    <record id="field_property_area" model="ir.model.fields">
        <field name="name">x_area</field>
        <field name="ttype">float</field>
        <field name="field_description">Area</field>
        <field name="model_id" ref="model_x_property"/>
    </record>
    <record id="field_property_tags" model="ir.model.fields">
        <field name="name">x_tags</field>
        <field name="ttype">many2many</field>
        <field name="field_description">Tags</field>
        <field name="model_id" ref="model_x_property"/>
        <field name="relation">x_properties_tag</field>
        <field name="relation_table">x_properties_tag_x_property_rel</field>
    </record>
    <record id="field_current_owner_property" model="ir.model.fields">
        <field name="ttype">many2one</field>
        <field name="copied" eval="True"/>
        <field name="field_description">Current Owner</field>
        <field name="model_id" ref="model_x_property"/>
        <field name="name">x_current_owner</field>
        <field name="relation">res.partner</field>
    </record>
    <record id="field_analytic_property" model="ir.model.fields">
        <field name="ttype">many2one</field>
        <field name="copied" eval="True"/>
        <field name="field_description">Property</field>
        <field name="model_id" ref="analytic.model_account_analytic_account"/>
        <field name="name">x_property</field>
        <field name="relation">x_property</field>
    </record>
    <record id="field_property_account_ids" model="ir.model.fields">
        <field name="ttype">one2many</field>
        <field name="field_description">Accounts</field>
        <field name="model_id" ref="model_x_property"/>
        <field name="name">x_account_ids</field>
        <field name="relation">account.analytic.account</field>
        <field name="relation_field">x_property</field>
    </record>
    <record id="field_property_invoice_count" model="ir.model.fields">
        <field name="name">x_account_ids_count</field>
        <field name="field_description">Accounts Count</field>
        <field name="model_id" ref="model_x_property"/>
        <field name="ttype">integer</field>
        <field name="readonly" eval="True"/>
        <field name="store" eval="False"/>
        <field name="compute">
for record in self: record['x_account_ids_count'] = len(record.x_account_ids)
        </field>
    </record>
    <record id="field_property_company_id" model="ir.model.fields">
        <field name="ttype">many2one</field>
        <field name="copied" eval="True"/>
        <field name="field_description">Company</field>
        <field name="model_id" ref="model_x_property"/>
        <field name="name">x_company_id</field>
        <field name="relation">res.company</field>
    </record>

    <!-- x_properties_tag -->
    <record id="name_properties_tags" model="ir.model.fields">
        <field name="name">x_name</field>
        <field name="ttype">char</field>
        <field name="field_description">Name</field>
        <field name="model_id" ref="model_properties_tags"/>
        <field name="required" eval="True"/>
    </record>
    <record id="color_properties_tag" model="ir.model.fields">
        <field name="name">x_color</field>
        <field name="ttype">integer</field>
        <field name="field_description">Color</field>
        <field name="model_id" ref="model_properties_tags"/>
    </record>

    <!-- x_properties_types -->
    <record id="description_property_types" model="ir.model.fields">
        <field name="name">x_name</field>
        <field name="ttype">char</field>
        <field name="field_description">Name</field>
        <field name="model_id" ref="model_properties_types"/>
        <field name="required" eval="True"/>
        <field name="tracking">1</field>
        <field name="translate">standard</field>
    </record>
    <record id="active_properties_type" model="ir.model.fields">
        <field name="name">x_active</field>
        <field name="ttype">boolean</field>
        <field name="field_description">Active</field>
        <field name="model_id" ref="model_properties_types"/>
        <field name="tracking">1</field>
    </record>
    <record id="sequence_properties_types" model="ir.model.fields">
        <field name="name">x_sequence</field>
        <field name="ttype">integer</field>
        <field name="field_description">Sequence</field>
        <field name="model_id" ref="model_properties_types"/>
    </record>

    <!-- x_meters -->
    <record id="field_meters_name" model="ir.model.fields">
        <field name="name">x_name</field>
        <field name="ttype">char</field>
        <field name="field_description">Description</field>
        <field name="model_id" ref="model_meters"/>
        <field name="required" eval="True"/>
    </record>
    <record id="field_meters_sequence" model="ir.model.fields">
        <field name="name">x_sequence</field>
        <field name="ttype">integer</field>
        <field name="field_description">Sequence</field>
        <field name="model_id" ref="model_meters"/>
    </record>

    <!-- x_meter_reading -->
    <record id="field_meter_reading_meter_id" model="ir.model.fields">
        <field name="name">x_meter_id</field>
        <field name="ttype">many2one</field>
        <field name="field_description">Meter</field>
        <field name="model_id" ref="model_meter_reading"/>
        <field name="relation">x_meters</field>
    </record>
    <record id="field_meter_reading_date" model="ir.model.fields">
        <field name="name">x_date</field>
        <field name="ttype">date</field>
        <field name="field_description">Date</field>
        <field name="model_id" ref="model_meter_reading"/>
        <field name="required" eval="True"/>
    </record>
    <record id="field_meter_reading_property" model="ir.model.fields">
        <field name="name">x_property</field>
        <field name="ttype">many2one</field>
        <field name="field_description">Property</field>
        <field name="model_id" ref="model_meter_reading"/>
        <field name="relation">x_property</field>
    </record>
    <record id="field_property_meter_reading_ids" model="ir.model.fields">
        <field name="ttype">one2many</field>
        <field name="field_description">Meter Reading ids</field>
        <field name="model_id" ref="model_x_property"/>
        <field name="name">x_meter_reading_ids</field>
        <field name="relation">x_meter_reading</field>
        <field name="relation_field">x_property</field>
    </record>
    <record id="field_meter_reading_quantity" model="ir.model.fields">
        <field name="name">x_quantity</field>
        <field name="ttype">float</field>
        <field name="field_description">Quantity</field>
        <field name="model_id" ref="model_meter_reading"/>
    </record>
    <record id="field_meter_reading_usage" model="ir.model.fields">
        <field name="name">x_usage</field>
        <field name="ttype">float</field>
        <field name="field_description">Usage</field>
        <field name="model_id" ref="model_meter_reading"/>
        <field name="readonly" eval="True"/>
    </record>
    <record id="field_meter_reading_description" model="ir.model.fields">
        <field name="name">x_description</field>
        <field name="ttype">char</field>
        <field name="field_description">Description</field>
        <field name="model_id" ref="model_meter_reading"/>
    </record>
    <record id="meter_image" model="ir.model.fields">
        <field name="name">x_image</field>
        <field name="field_description">Attachment</field>
        <field name="ttype">binary</field>
        <field name="model_id" ref="model_meter_reading"/>
    </record>
    <record id="meter_image_name" model="ir.model.fields">
        <field name="name">x_image_filename</field>
        <field name="field_description">Attachment name </field>
        <field name="ttype">char</field>
        <field name="model_id" ref="model_meter_reading"/>
    </record>

    <!-- x_stake_holder fields -->
    <record id="field_stake_holder_property_id" model="ir.model.fields">
        <field name="ttype">many2one</field>
        <field name="copied" eval="True"/>
        <field name="field_description">Property</field>
        <field name="model_id" ref="model_x_stake_holder"/>
        <field name="name">x_property_id</field>
        <field name="relation">x_property</field>
    </record>
    <record id="field_stake_holder_start_date" model="ir.model.fields">
        <field name="ttype">date</field>
        <field name="copied" eval="True"/>
        <field name="field_description">Start Date</field>
        <field name="model_id" ref="model_x_stake_holder"/>
        <field name="name">x_start_date</field>
    </record>
    <record id="field_stake_holder_end_date" model="ir.model.fields">
        <field name="ttype">date</field>
        <field name="copied" eval="True"/>
        <field name="field_description">End Date</field>
        <field name="model_id" ref="model_x_stake_holder"/>
        <field name="name">x_end_date</field>
    </record>
    <record id="field_stake_holder_partner_id" model="ir.model.fields">
        <field name="ttype">many2one</field>
        <field name="copied" eval="True"/>
        <field name="field_description">Stakeholder</field>
        <field name="model_id" ref="model_x_stake_holder"/>
        <field name="name">x_stake_holder</field>
        <field name="relation">res.partner</field>
    </record>
    <record id="field_property_stake_holder_ids" model="ir.model.fields">
        <field name="ttype">one2many</field>
        <field name="field_description">Stakeholder ids</field>
        <field name="model_id" ref="model_x_property"/>
        <field name="name">x_stake_holder_ids</field>
        <field name="relation">x_stake_holder</field>
        <field name="relation_field">x_property_id</field>
    </record>
    <record id="field_property_stake_holder_type" model="ir.model.fields">
        <field name="name">x_type</field>
        <field name="field_description">Type</field>
        <field name="model_id" ref="model_x_stake_holder"/>
        <field name="ttype">selection</field>
    </record>
    <record id="field_property_stake_holder_type_selection_tenant" model="ir.model.fields.selection">
        <field name="name">Tenant</field>
        <field name="field_id" ref="field_property_stake_holder_type" />
        <field name="value">tenant</field>
    </record>
    <record id="field_property_tenant_ids" model="ir.model.fields">
        <field name="ttype">one2many</field>
        <field name="field_description">Tenant ids</field>
        <field name="model_id" ref="model_x_property"/>
        <field name="name">x_tenant_ids</field>
        <field name="relation">x_stake_holder</field>
        <field name="relation_field">x_property_id</field>
        <field name="domain">[('x_type', '=', 'tenant')]</field>
    </record>
    <record id="field_property_line_account" model="ir.model.fields">
        <field name="ttype">many2one</field>
        <field name="copied" eval="True"/>
        <field name="field_description">Account</field>
        <field name="model_id" ref="model_x_stake_holder"/>
        <field name="name">x_account</field>
        <field name="relation">account.analytic.account</field>
    </record>
    
    <!-- analytic.account fields -->
    <record id="field_analytic_stake_holder_line" model="ir.model.fields">
        <field name="ttype">many2one</field>
        <field name="copied" eval="True"/>
        <field name="field_description">Stakeholder Line</field>
        <field name="model_id" ref="analytic.model_account_analytic_account"/>
        <field name="name">x_stake_holder_line</field>
        <field name="relation">x_stake_holder</field>
    </record>
    <record id="field_account_analytic_account_start_date" model="ir.model.fields">
        <field name="ttype">date</field>
        <field name="related">x_stake_holder_line.x_start_date</field>
        <field name="field_description">Start Date</field>
        <field name="model_id" ref="analytic.model_account_analytic_account"/>
        <field name="name">x_start_date</field>
        <field name="readonly" eval="True"/>
        <field name="store" eval="False"/>
    </record>
    <record id="field_account_analytic_account_end_date" model="ir.model.fields">
        <field name="ttype">date</field>
        <field name="related">x_stake_holder_line.x_end_date</field>
        <field name="field_description">End Date</field>
        <field name="model_id" ref="analytic.model_account_analytic_account"/>
        <field name="name">x_end_date</field>
        <field name="readonly" eval="True"/>
        <field name="store" eval="False"/>
    </record>
    <record id="field_account_analytic_account_type" model="ir.model.fields">
        <field name="ttype">selection</field>
        <field name="related">x_stake_holder_line.x_type</field>
        <field name="field_description">Type</field>
        <field name="model_id" ref="analytic.model_account_analytic_account"/>
        <field name="name">x_type</field>
        <field name="readonly" eval="True"/>
        <field name="store" eval="False"/>
    </record>

    <!-- analytic.plan fields -->
    <record id="x_is_a_property_plan" model="ir.model.fields">
        <field name="name">x_is_a_property_plan</field>
        <field name="ttype">boolean</field>
        <field name="field_description">Property plan</field>
        <field name="model_id" ref="analytic.model_account_analytic_plan"/>
    </record>
</odoo>
