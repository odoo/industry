"<strong><b>Sales App</b>:</strong> Sell lessons, exams, and course packages "
"directly to students, managing\n"
"            invoices and payments in one place.<br/>"
msgstr ""

#. module: driving_school
#: model_terms:ir.ui.view,arch_db:driving_school.welcome_article_body
