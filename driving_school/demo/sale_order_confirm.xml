<?xml version='1.0' encoding='UTF-8'?>
<odoo noupdate="1">
  <!--Update sale order stages-->
  <function model="sale.order" name="action_confirm">
    <value eval="[ref('sale_order_29')]"/>
  </function>

  <!-- Updating the loyalty reward -->

  <record id="reward_wizard_1" model="sale.loyalty.reward.wizard">
    <field name="order_id" ref="sale_order_30"/>
    <field name="reward_ids" eval="[(6, 0, [ref('loyalty_reward_9')])]"/>
    <field name="selected_reward_id" ref="loyalty_reward_9"/>
  </record>

  <function model="sale.loyalty.reward.wizard" name="action_apply">
    <value eval="[ref('reward_wizard_1')]"/>
  </function>

</odoo>
