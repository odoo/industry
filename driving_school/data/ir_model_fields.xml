<?xml version='1.0' encoding='UTF-8'?>
<odoo>
  <record id="appointment_model_appointment_resource_x_appointment_resource_ids_appointment_manage_leaves_count_field" model="ir.model.fields">
    <field name="compute"><![CDATA[
for record in self: record['x_appointment_resource_ids_appointment_manage_leaves_count'] = self.env['appointment.manage.leaves'].search_count([('appointment_resource_ids', '=', record.id)])
]]></field>
    <field name="ttype">integer</field>
    <field name="field_description">Resources count</field>
    <field name="model">appointment.resource</field>
    <field name="model_id" ref="appointment.model_appointment_resource"/>
    <field name="name">x_appointment_resource_ids_appointment_manage_leaves_count</field>
    <field name="selectable" eval="False"/>
    <field name="store" eval="False"/>
  </record>
</odoo>
