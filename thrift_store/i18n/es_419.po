#. module: thrift_store
#: model_terms:ir.ui.view,arch_db:thrift_store.welcome_article_body
msgid "<strong>Accounting:</strong> Full financial tracking and reporting."
msgstr ""
"<strong>Contabilidad:</strong> Seguimiento financiero completo y reportes."

#. module: thrift_store
#: model_terms:ir.ui.view,arch_db:thrift_store.welcome_article_body
msgid ""
"<strong>Contacts:</strong> Maintain donor, community partner and customer\n"
"                    information."
msgstr ""
"<strong>Contactos:</strong> Conserva la información de donantes, socios "
"comunitarios\n"
"                    y clientes."

#. module: thrift_store
#: model_terms:ir.ui.view,arch_db:thrift_store.welcome_article_body
msgid ""
"<strong>Employees App:</strong>  Centralize information for all your staff "
"members and volunteers in one secure directory."
msgstr ""
"<strong>Empleados:</strong> Centraliza la información de todo tu personal y "
"tus voluntarios en un mismo directorio seguro."

#. module: thrift_store
#: model_terms:ir.ui.view,arch_db:thrift_store.welcome_article_body
msgid ""
"<strong>Inventory:</strong> Gain deeper insight into donation stock and "
"turnover."
msgstr ""
"<strong>Inventario:</strong> Obtén más información sobre el inventario de "
"donaciones y tus ventas."

#. module: thrift_store
#: model_terms:ir.ui.view,arch_db:thrift_store.welcome_article_body
msgid ""
"<strong>Keep shifts balanced:</strong> Plan employee coverage across peak "
"hours\n"
"                    (weekends, donation drive days)."
msgstr ""
"<strong>Dale equilibrio a tus turnos:</strong> Planifica que tus empleados "
"asistan durante las horas con mayor afluencia\n"
"                    (fines de semana y eventos de donaciones)."

#. module: thrift_store
#: model_terms:ir.ui.view,arch_db:thrift_store.welcome_article_body
msgid ""
"<strong>Leaves:</strong> Easily manage employee's time off and plan work\n"
"                    accordingly."
msgstr ""
"<strong>Permisos:</strong> Gestiona el tiempo libre de tus empleados con "
"facilidad y programa tus actividades\n"
"                   con esa información."

#. module: thrift_store
#: model_terms:ir.ui.view,arch_db:thrift_store.welcome_article_body
msgid ""
"<strong>Leverage promotions:</strong> Use Odoo POS’s discount and pricing "
"rules\n"
"                    for events like “fill a bag” sales."
msgstr ""
"<strong>Aprovecha las promociones:</strong> Usa las reglas para descuentos y "
"precios en la aplicación Punto de venta de Odoo \n"
"                    durante eventos como ventas especiales."

#. module: thrift_store
#: model_terms:ir.ui.view,arch_db:thrift_store.welcome_article_body
msgid ""
"<strong>Planning App:</strong> Organize shifts and schedules easily, "
"ensuring you always have enough hands on deck for sorting and sales."
msgstr ""
"<strong>Planeación:</strong> Organiza los turnos y horarios con facilidad y "
"asegúrate de que siempre tengas suficiente personal para ordenar la tienda y "
"realizar ventas."

#. module: thrift_store
#: model_terms:ir.ui.view,arch_db:thrift_store.welcome_article_body
msgid ""
"<strong>Point of Sale App:</strong> Process transactions quickly with a "
"flexible checkout system that supports sales by product, fixed amount, or "
"weight."
msgstr ""
"<strong>Punto de venta:</strong> Procesa transacciones al instante con un "
"sistema de pago flexible compatible con ventas por producto, una cantidad "
"fija o peso."

#. module: thrift_store
#: model_terms:ir.ui.view,arch_db:thrift_store.welcome_article_body
msgid ""
"<strong>Purchase:</strong> Manage store supply needs (bags, hangers, "
"cleaning\n"
"                    supplies)."
msgstr ""
"<strong>Compras:</strong> Gestiona las necesidades de suministros de la "
"tienda (bolsas, ganchos, \n"
"                    artículos de limpieza)."

#. module: thrift_store
#: model_terms:ir.ui.view,arch_db:thrift_store.welcome_article_body
msgid ""
"<strong>Standardize categories:</strong> Use consistent product categories "
"(e.g.,\n"
"                    clothing, books, household) to keep reporting clear."
msgstr ""
"<strong>Estandariza las categorías:</strong> Usa categorías de producto "
"consistentes (como \n"
"                    ropa, libros, hogar) para que los reportes siempre sean "
"claros."

#. module: thrift_store
#: model_terms:ir.ui.view,arch_db:thrift_store.welcome_article_body
msgid ""
"<strong>Train your staff:</strong> Volunteers and part-time staff pick up "
"faster\n"
"                    with Odoo’s intuitive POS interface."
msgstr ""
"<strong>Capacita a tu personal:</strong> Los voluntarios y empleados de "
"medio tiempo pueden actuar más rápido \n"
"                    con la intuitiva interfaz de la aplicación PdV de Odoo."

#. module: thrift_store
#: model_terms:ir.ui.view,arch_db:thrift_store.welcome_article_body
msgid "<strong>Website:</strong> Showcase your mission and events online."
msgstr "<strong>Sitio web:</strong> Muestra tu misión y tus eventos en línea."

#. module: thrift_store
#: model_terms:ir.ui.view,arch_db:thrift_store.welcome_article_body
msgid ""
"<strong>eCommerce:</strong> Sell select high-value items online to reach "
"wider\n"
"                    audiences."
msgstr ""
"<strong>Comercio electrónico:</strong> Vende artículos selectos de alto "
"valor en línea para llegar a más \n"
"                    público."

#. module: thrift_store
#: model:product.template,name:thrift_store.product_template_12
msgid "Accessories"
msgstr "Accesorios"

#. module: thrift_store
#: model_terms:ir.ui.view,arch_db:thrift_store.welcome_article_body
msgid ""
"Add a product to the order, 10 for example, and adjust the count per the\n"
"                        number of pieces with that price in the customer "
"basket!"
msgstr ""
"Agrega un producto a la orden, 10 por ejemplo, y ajusta la cantidad según\n"
"                        el número de piezas con ese precio en el carrito del "
"cliente."

#. module: thrift_store
#: model_terms:ir.ui.view,arch_db:thrift_store.welcome_article_body
msgid ""
"Add the product labelled By Weight and adjust the quantity per measured\n"
"                        weight"
msgstr ""
"Agrega el producto etiquetado como Por peso y ajusta la cantidad según el "
"peso\n"
"                        medido"

#. module: thrift_store
#: model_terms:ir.ui.view,arch_db:thrift_store.welcome_article_body
msgid "Adjust the shift time, specify the role and save it"
msgstr "Ajusta el horario, especifica la función y guarda los cambios"

