#. module: thrift_store
#: model_terms:ir.ui.view,arch_db:thrift_store.welcome_article_body
msgid "Odoo for Thrift Store"
msgstr "Odoo para Lojas de Brechós e Briques"

#. module: thrift_store
#: model_terms:ir.ui.view,arch_db:thrift_store.welcome_article_body
msgid ""
"Once your week plan is ready, Publish it to share their shifts with your\n"
"                        employees"
msgstr ""
"Quando o plano semanal estiver pronto, publique-o para compartilhar os "
"turnos com seus\n"
"funcionários"

#. module: thrift_store
#: model_terms:ir.ui.view,arch_db:thrift_store.welcome_article_body
