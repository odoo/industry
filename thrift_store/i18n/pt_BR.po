#. module: thrift_store
#: model_terms:ir.ui.view,arch_db:thrift_store.welcome_article_body
msgid "<strong>Accounting:</strong> Full financial tracking and reporting."
msgstr ""
"<strong>Financeiro:</strong> Acompanhamento financeiro completo e relatórios."

#. module: thrift_store
#: model_terms:ir.ui.view,arch_db:thrift_store.welcome_article_body
msgid ""
"<strong>Contacts:</strong> Maintain donor, community partner and customer\n"
"                    information."
msgstr ""
"<strong>Contatos:</strong>Mantenha informações sobre doadores, parceiros da "
"comunidade\n"
"e clientes."

#. module: thrift_store
#: model_terms:ir.ui.view,arch_db:thrift_store.welcome_article_body
msgid ""
"<strong>Employees App:</strong>  Centralize information for all your staff "
"members and volunteers in one secure directory."
msgstr ""
"<strong>Aplicativo Funcionários:</strong> Centralize as informações de todos "
"os seus funcionários e voluntários em um diretório seguro."

#. module: thrift_store
#: model_terms:ir.ui.view,arch_db:thrift_store.welcome_article_body
msgid ""
"<strong>Inventory:</strong> Gain deeper insight into donation stock and "
"turnover."
msgstr ""
"<strong>Inventário:</strong> Obtenha uma visão mais aprofundada sobre o "
"estoque e a rotatividade das doações."

#. module: thrift_store
#: model_terms:ir.ui.view,arch_db:thrift_store.welcome_article_body
msgid ""
"<strong>Keep shifts balanced:</strong> Plan employee coverage across peak "
"hours\n"
"                    (weekends, donation drive days)."
msgstr ""
"<strong>Mantenha os turnos equilibrados:</strong>Planeje a cobertura dos "
"funcionários durante os horários de pico\n"
"(fins de semana, dias de campanha de doações)."

#. module: thrift_store
#: model_terms:ir.ui.view,arch_db:thrift_store.welcome_article_body
msgid ""
"<strong>Leaves:</strong> Easily manage employee's time off and plan work\n"
"                    accordingly."
msgstr ""
"<strong>Licenças:</strong> Gerencie facilmente as folgas dos funcionários e "
"planeje o trabalho\n"
"de acordo."

#. module: thrift_store
#: model_terms:ir.ui.view,arch_db:thrift_store.welcome_article_body
msgid ""
"<strong>Leverage promotions:</strong> Use Odoo POS’s discount and pricing "
"rules\n"
"                    for events like “fill a bag” sales."
msgstr ""
"<strong>Tire proveito de promoções:</strong> Use as regras de desconto e "
"preços do Odoo PDV\n"
"para eventos como vendas do tipo “encha a sacola”."

#. module: thrift_store
#: model_terms:ir.ui.view,arch_db:thrift_store.welcome_article_body
msgid ""
"<strong>Planning App:</strong> Organize shifts and schedules easily, "
"ensuring you always have enough hands on deck for sorting and sales."
msgstr ""
"<strong>Aplicativo Planejamento:</strong> Organize turnos e horários com "
"facilidade, garantindo que você sempre tenha pessoal suficiente para a "
"classificação e as vendas."

#. module: thrift_store
#: model_terms:ir.ui.view,arch_db:thrift_store.welcome_article_body
msgid ""
"<strong>Point of Sale App:</strong> Process transactions quickly with a "
"flexible checkout system that supports sales by product, fixed amount, or "
"weight."
msgstr ""
"<strong>Aplicativo Ponto de Venda:</strong> Processe transações rapidamente "
"com um sistema de checkout flexível que suporta vendas por produto, valor "
"fixo ou peso."

#. module: thrift_store
#: model_terms:ir.ui.view,arch_db:thrift_store.welcome_article_body
msgid ""
"<strong>Purchase:</strong> Manage store supply needs (bags, hangers, "
"cleaning\n"
"                    supplies)."
msgstr ""
"<strong>Compras:</strong> Gerenciar as necessidades de suprimentos da loja "
"(sacolas, cabides, produtos de limpeza)."

#. module: thrift_store
#: model_terms:ir.ui.view,arch_db:thrift_store.welcome_article_body
msgid ""
"<strong>Standardize categories:</strong> Use consistent product categories "
"(e.g.,\n"
"                    clothing, books, household) to keep reporting clear."
msgstr ""
"<strong>Padronizar categorias:</strong> Use categorias de produtos "
"consistentes (ex.:\n"
"                    roupas, livros, produtos domésticos) para clareza nos "
"relatórios."

#. module: thrift_store
#: model_terms:ir.ui.view,arch_db:thrift_store.welcome_article_body
msgid ""
"<strong>Train your staff:</strong> Volunteers and part-time staff pick up "
"faster\n"
"                    with Odoo’s intuitive POS interface."
msgstr ""
"<strong>Treine sua equipe:</strong> Voluntários e funcionários a tempo "
"parcial aprendem mais rapidamente\n"
"com a interface intuitiva do PDV da Odoo."

#. module: thrift_store
#: model_terms:ir.ui.view,arch_db:thrift_store.welcome_article_body
msgid "<strong>Website:</strong> Showcase your mission and events online."
msgstr "<strong>Site:</strong> Divulgue sua missão e seus eventos online."

#. module: thrift_store
#: model_terms:ir.ui.view,arch_db:thrift_store.welcome_article_body
msgid ""
"<strong>eCommerce:</strong> Sell select high-value items online to reach "
"wider\n"
"                    audiences."
msgstr ""
"<strong>e-Commerce:</strong> Venda itens selecionados para alcançar um "
"público\n"
"mais amplo."

#. module: thrift_store
#: model:product.template,name:thrift_store.product_template_12
msgid "Accessories"
msgstr "Acessórios"

#. module: thrift_store
#: model_terms:ir.ui.view,arch_db:thrift_store.welcome_article_body
msgid ""
"Add a product to the order, 10 for example, and adjust the count per the\n"
"                        number of pieces with that price in the customer "
"basket!"
msgstr ""
"Adicione um produto ao pedido, 10 por exemplo, e ajuste o número de acordo "
"com o\n"
"número de peças com esse preço na cesta do cliente!"

#. module: thrift_store
#: model_terms:ir.ui.view,arch_db:thrift_store.welcome_article_body
msgid ""
"Add the product labelled By Weight and adjust the quantity per measured\n"
"                        weight"
msgstr ""
"Adicione o produto rotulado “Por Peso” e ajuste a quantidade por peso \n"
"medido"

#. module: thrift_store
#: model_terms:ir.ui.view,arch_db:thrift_store.welcome_article_body
msgid "Adjust the shift time, specify the role and save it"
msgstr "Ajuste o horário do turno, especifique a função e salve-o"

