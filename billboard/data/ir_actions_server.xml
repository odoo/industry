<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="execute_code_server_action" model="ir.actions.server">
        <field name="name">Execute Code</field>
        <field name="model_id" ref="project.model_project_task"/>
        <field name="state">code</field>
        <field name="binding_model_id" ref="project.model_project_task"/>
        <field name="code"><![CDATA[if record.sale_order_id.analytic_account_id:
        record['analytic_account_id'] = record.sale_order_id.analytic_account_id
        #record['project_id'] = record.sale_order_id.analytic_account_id.project_ids[:1]
]]></field>
    </record>
</odoo>
