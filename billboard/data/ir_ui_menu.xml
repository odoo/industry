<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="billboards_icon" model="ir.ui.menu">
        <field name="name">Billboards</field>
        <field name="web_icon">fa fa-desktop,#262c34,#FFFFFF</field>
    </record>
    <record id="billboards_billboard" model="ir.ui.menu">
        <field name="name">Billboards</field>
        <field name="action" ref="billboards_record"/>
        <field name="parent_id" ref="billboards_icon"/>
    </record>
    <record id="billboards_address" model="ir.ui.menu">
        <field name="name">Addresses</field>
        <field name="action" ref="address_record"/>
        <field name="parent_id" ref="billboards_icon"/>
        <field name="sequence">11</field>
    </record>
    <record id="billboards_contacts" model="ir.ui.menu">
        <field name="name">Contacts</field>
        <field name="action" ref="contacts_record"/>
        <field name="active" eval="False"/>
        <field name="parent_id" ref="billboards_icon"/>
        <field name="sequence">12</field>
    </record>
</odoo>
