    <record id="new_checkbox_analyti_cbdb6eec-6151-4fc8-bf1e-d3e8846b84b2" model="ir.model.fields">
        <field name="compute"><![CDATA[for record in self:
        sales_orders = self.env['sale.order'].search([('analytic_account_id', '=', record.id)])
        #account.has_ongoing_orders = any(order.subscription_state == 'ongoing' for order in sales_orders)
        #record['x_studio_state'] = any(order.subscription_state == 'ongoing' for order in sales_orders)
        if sales_orders and any(order.subscription_state == '3_progress' for order in sales_orders):
             record['x_studio_state'] = False
        else:
                record['x_studio_state'] = True]]></field>
        <field name="ttype">boolean</field>
        <field name="depends">x_studio_orders</field>
        <field name="field_description">Available</field>
        <field name="model_id" ref="analytic.model_account_analytic_account"/>
        <field name="name">x_studio_state</field>
        <field name="on_delete" eval="False"/>
        <field name="readonly" eval="True"/>
    </record>
