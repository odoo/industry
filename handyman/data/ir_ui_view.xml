<?xml version='1.0' encoding='UTF-8'?>
<odoo>
  <record id="odoo_studio_sale_ord_32ec879f-972d-4a88-9335-51a572b5f299" model="ir.ui.view" context="{'studio': True}">
    <field name="arch" type="xml">
      <data>
        <xpath expr="//field[@name='sale_order_template_id']" position="after">
          <field name="x_studio_various_materials_budget"/>
        </xpath>
      </data>
    </field>
    <field name="inherit_id" ref="sale.view_order_form"/>
    <field name="mode">extension</field>
    <field name="model">sale.order</field>
    <field name="name">Odoo Studio: sale.order.form customization</field>
    <field name="priority">160</field>
    <field name="type">form</field>
  </record>
  <record id="odoo_studio_project__b1458ce7-81d0-4c13-b6fc-7e5eead2165f" model="ir.ui.view" context="{'studio': True}">
    <field name="arch" type="xml">
      <data>
        <xpath expr="//field[@name='personal_stage_type_id']" position="after">
          <button string="Add Vendor Bill" name="820" type="action"/>
        </xpath>
        <xpath expr="//form[1]/sheet[1]/div[@name='button_box']/button[@name='action_preview_worksheet']" position="after">
          <button class="oe_stat_button" icon="fa-file-text-o" type="action" name="handyman.vendor_bills_e46dd0ba-7777-4f92-bcab-d02a3843a103">
            <field widget="statinfo" name="x_x_studio_task_account_move_count" string="Vendor Bills"/>
          </button>
        </xpath>
        <xpath expr="//form[1]/sheet[1]/group[1]/group[1]/field[@name='tag_ids']" position="after">
          <field name="x_studio_related_field_53b_1ic3h7amc" string="Materials Budget"/>
          <label for="x_studio_vendor_bills"/>
          <div class="d-flex" name="bills">
            <field class="oe_inline" name="x_studio_vendor_bills"/>
            <span class="ml4">(</span>
            <field class="oe_inline" name="x_studio_percent_bills_1" widget="percentage"/>
            <span>)</span>
          </div>
        </xpath>
      </data>
    </field>
    <field name="inherit_id" ref="project.view_task_form2"/>
    <field name="mode">extension</field>
    <field name="model">project.task</field>
    <field name="name">Odoo Studio: project.task.form customization</field>
    <field name="priority">9990</field>
    <field name="type">form</field>
  </record>
  <record id="odoo_studio_project__b0d7209e-1c1f-47d3-a88a-71cef80f962a" model="ir.ui.view" context="{'studio': True}">
    <field name="arch" type="xml">
      <data>
        <xpath expr="//field[@name='activity_ids']" position="after">
          <field name="x_studio_expenses_budget_percent" optional="show" widget="percentage"/>
          <xpath expr="//field[@name='tag_ids']" position="move"/>
        </xpath>
      </data>
    </field>
    <field name="inherit_id" ref="industry_fsm.project_task_view_list_fsm"/>
    <field name="mode">extension</field>
    <field name="model">project.task</field>
    <field name="name">Odoo Studio: project.task.list.fsm customization</field>
    <field name="priority">9990</field>
    <field name="type">list</field>
  </record>
  <record id="odoo_studio_account__7d26ff3f-33e8-493e-86d1-db44d85e0132" model="ir.ui.view" context="{'studio': True}">
    <field name="arch" type="xml">
      <data>
        <xpath expr="//form[1]/sheet[1]/group[1]/group[1]/field[@name='ref']" position="after">
          <field name="x_studio_task" force_save="0" readonly="False" options="{&quot;no_create&quot;:true}"/>
        </xpath>
      </data>
    </field>
    <field name="inherit_id" ref="account.view_move_form"/>
    <field name="mode">extension</field>
    <field name="model">account.move</field>
    <field name="name">Odoo Studio: account.move.form customization</field>
    <field name="priority">160</field>
    <field name="type">form</field>
  </record>
  <record id="industry_fsm_report.x_project_task_worksheet_template_1_ir_ui_view_2" model="ir.ui.view" forcecreate="1">
    <field name="arch" type="xml">
      <list default_order="create_date DESC">
        <field name="create_date"/>
        <field name="x_name"/>
      </list>
    </field>
    <field name="model">x_project_task_worksheet_template_1</field>
    <field name="name">list_view_Default_Worksheet</field>
    <field name="type">list</field>
  </record>
  <record id="industry_fsm_report.x_project_task_worksheet_template_1_ir_ui_view_3" model="ir.ui.view" forcecreate="1">
    <field name="arch" type="xml">
      <search>
        <field name="x_name"/>
        <filter string="Created on" date="create_date" name="create_date"/>
        <filter name="group_by_month" string="Created on" context="{'group_by': 'create_date:month'}"/>
      </search>
    </field>
    <field name="model">x_project_task_worksheet_template_1</field>
    <field name="name">search_view_Default_Worksheet</field>
    <field name="type">search</field>
  </record>
  <record id="industry_fsm_report.x_project_task_worksheet_template_1_ir_ui_view_1" model="ir.ui.view" forcecreate="1">
    <field name="arch" type="xml">
      <form create="false" duplicate="false">
        <sheet>
          <h1 invisible="context.get('studio') or context.get('default_x_project_task_id')">
            <field name="x_project_task_id"/>
          </h1>
          <group>
            <field name="x_comments" placeholder="Add details about your intervention..."/>
          </group>
        </sheet>
      </form>
    </field>
    <field name="model">x_project_task_worksheet_template_1</field>
    <field name="name">template_view_Default_Worksheet</field>
    <field name="type">form</field>
  </record>
</odoo>
