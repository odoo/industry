<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="field_various_material_budget" model="ir.model.fields">
        <field name="name">x_various_materials_budget</field>
        <field name="ttype">monetary</field>
        <field name="copied" eval="True"/>
        <field name="field_description">Various Materials Budget</field>
        <field name="model_id" ref="sale.model_sale_order"/>
    </record>
    <record id="new_material_budget_related_field" model="ir.model.fields">
        <field name="name">x_related_material_budget_field</field>
        <field name="ttype">monetary</field>
        <field name="related">sale_order_id.x_various_materials_budget</field>
        <field name="field_description">Materials Budget</field>
        <field name="model_id" ref="project.model_project_task"/>
        <field name="readonly" eval="True"/>
        <field name="store" eval="False"/>
    </record>
    <record id="x_task_field" model="ir.model.fields">
        <field name="name">x_task_id</field>
        <field name="ttype">many2one</field>
        <field name="copied" eval="True"/>
        <field name="field_description">Task</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="relation">project.task</field>
    </record>
    <record id="field_analytic_account_id" model="ir.model.fields">
        <field name="name">x_analytic_account_id</field>
        <field name="field_description">Analytic Account</field>
        <field name="ttype">many2one</field>
        <field name="model_id" ref="project.model_project_task"/>
        <field name="relation">account.analytic.account</field>
    </record>
    <record id="field_related_analytic_account_credit" model="ir.model.fields">
        <field name="name">x_credit</field>
        <field name="ttype">monetary</field>
        <field name="compute"><![CDATA[
for task in self:
    task['x_credit'] = task.x_analytic_account_id.credit]]></field>
        <field name="field_description">Costs</field>
        <field name="model_id" ref="project.model_project_task"/>
        <field name="readonly" eval="True"/>
        <field name="store" eval="False"/>
        <field name="depends">x_analytic_account_id.credit</field>
    </record>
    <record id="x_percent_bills_1_field" model="ir.model.fields">
        <field name="name">x_percent_bills_1</field>
        <field name="compute"><![CDATA[
for task in self:
    task['x_percent_bills_1'] = task.x_credit / task.x_related_material_budget_field if task.x_related_material_budget_field else 0]]></field>
        <field name="ttype">float</field>
        <field name="depends">name</field>
        <field name="field_description">Percent bills</field>
        <field name="model_id" ref="project.model_project_task"/>
        <field name="readonly" eval="True"/>
        <field name="store" eval="False"/>
    </record>
    <record id="field_related_analytic_account_vendor_bill_count" model="ir.model.fields">
        <field name="name">x_vendor_bill_count</field>
        <field name="ttype">integer</field>
        <field name="related">x_analytic_account_id.vendor_bill_count</field>
        <field name="field_description">Vendor Bills</field>
        <field name="model_id" ref="project.model_project_task"/>
        <field name="readonly" eval="True"/>
        <field name="store" eval="False"/>
    </record>
</odoo>
