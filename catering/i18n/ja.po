msgstr ""
"<font class=\"text-o-color-1\"><b>CRM&amp; 販売アプリ:</b></font> すべての顧"
"客連絡先と見積書を一元管理します。"

#. module: catering
#: model_terms:ir.ui.view,arch_db:catering.welcome_article_body
msgid ""
