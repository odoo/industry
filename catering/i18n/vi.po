msgstr ""
"<font class=\"text-o-color-1\"><b>Ứng dụng CRM &amp; Bán hàng:</b></font> "
"Quản lý tất cả liên hệ khách hàng và báo giá của bạn."

#. module: catering
#: model_terms:ir.ui.view,arch_db:catering.welcome_article_body
msgid ""
