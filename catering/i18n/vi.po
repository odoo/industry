#. module: catering
#: model_terms:ir.ui.view,arch_db:catering.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">The Invoicing App:</font></b> Keep a clear "
"record of all your invoices."
msgstr ""
"<b><font class=\"text-o-color-1\">Ứng dụng Hóa đơn:</font></b> Đảm bảo ghi "
"chép rõ ràng tất cả hóa đơn của bạn."

#. module: catering
#: model_terms:ir.ui.view,arch_db:catering.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">The Project &amp; Planning Apps:</font></"
"b> Manage event-related tasks and track their progress through customizable "
"stages."
msgstr ""
"<b><font class=\"text-o-color-1\">Ứng dụng Dự án &amp; Kế hoạch:</font></b> "
"Quản lý các nhiệm vụ liên quan đến sự kiện và theo dõi tiến độ của chúng qua "
"các giai đoạn có thể tùy chỉnh."

#. module: catering
#: model_terms:ir.ui.view,arch_db:catering.welcome_article_body
msgid ""
"<b><font class=\"text-o-color-1\">The Purchase App:</font></b> Accurately "
"track all purchased and rented products."
msgstr ""
"<b><font class=\"text-o-color-1\">Ứng dụng Mua hàng:</font></b> Theo dõi "
"chính xác tất cả sản phẩm đã mua và thuê."

#. module: catering
#: model_terms:ir.ui.view,arch_db:catering.welcome_article_body
msgid "<b>Adapt the stages and tasks</b> to match your standard workflow."
msgstr ""
"<b>Điều chỉnh các giai đoạn và công việc</b> cho phù hợp với quy trình chuẩn "
"của bạn."

#. module: catering
#: model_terms:sale.order.template,note:catering.sale_order_template_2
#: model_terms:sale.order.template,note:catering.sale_order_template_3
msgid "<b>Cancellation and Rescheduling Policy.</b>"
msgstr "<b>Chính sách hủy bỏ và thay đổi lịch trình.</b>"

#. module: catering
#: model_terms:sale.order.template,note:catering.sale_order_template_2
#: model_terms:sale.order.template,note:catering.sale_order_template_3
msgid ""
"<b>Cleanup and Breakdown Details:</b> Clarification on who is responsible "
"for plate scraping, trash removal, and general cleanup."
msgstr ""
"<b>Chi tiết dọn dẹp và tháo dỡ:</b> Làm rõ ai chịu trách nhiệm dọn đĩa, thu "
"rác và dọn dẹp chung."

#. module: catering
#: model_terms:sale.order.template,note:catering.sale_order_template_2
#: model_terms:sale.order.template,note:catering.sale_order_template_3
msgid ""
"<b>Guaranteed Guest Count Deadline:</b> The date by which the final, non-"
"adjustable guest count must be confirmed (often 1-2 weeks prior)."
msgstr ""
"<b>Hạn chốt số lượng khách đảm bảo:</b> Ngày mà bạn phải xác nhận số lượng "
"khách cuối cùng và không còn được điều chỉnh nữa (thường là trước 1–2 tuần)."

#. module: catering
#: model_terms:ir.ui.view,arch_db:catering.welcome_article_body
