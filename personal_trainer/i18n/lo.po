#. module: personal_trainer
#: model_terms:ir.ui.view,arch_db:personal_trainer.welcome_article_body
msgid ""
"<span class=\"display-4-fs\"><strong>Odoo for Personal "
"Trainer</strong></span>"
msgstr ""
"<span class=\"display-4-fs\"><strong>Odoo ສໍາລັບຄູເຝິກສ່ວນຕົວ</strong></span>"

#. module: personal_trainer
#: model_terms:ir.ui.view,arch_db:personal_trainer.welcome_article_body
msgid ""
"<strong>Configure Appointment Types</strong>: In the Appointment app, create"
" types that match your services."
msgstr ""
"<strong>ກໍາໜົດຄ່າປະເພດການນັດໝາຍ</strong>: ໃນແອັບການນັດໝາຍ, ໃຫ້ສ້າງປະເພດທີ່ກົງກັບການບໍລິການຂ"
"ອງທ່ານ."

#. module: personal_trainer
#: model_terms:ir.ui.view,arch_db:personal_trainer.welcome_article_body
msgid ""
"<strong>Create Client Profiles</strong>: As you get inquiries, add them to "
"your CRM and Contacts."
msgstr ""
"<strong>ສ້າງໂປຣໄຟລ໌ລູກຄ້າ</strong>: ເມື່ອທ່ານໄດ້ຮັບການສອບຖາມ, ໃຫ້ເພີ່ມພວກເຂົາເຂົ້າໃນ CRM ແລ"
"ະ ຜູ້ຕິດຕໍ່ຂອງທ່ານ."

#. module: personal_trainer
#: model_terms:ir.ui.view,arch_db:personal_trainer.welcome_article_body
msgid ""
"<strong>Invoice Your Clients</strong>: Use the Invoicing app to bill clients"
" for completed services."
msgstr ""
"<strong>ອອກໃບເກັບເງິນໃຫ້ລູກຄ້າ</strong>: ໃຊ້ແອັບການອອກໃບເກັບເງິນເພື່ອຮຽກເກັບເງິນນໍາລູກຄ້າສໍາລັບ"
"ການບໍລິການທີ່ສໍາເລັດແລ້ວ."

#. module: personal_trainer
#: model_terms:ir.ui.view,arch_db:personal_trainer.welcome_article_body
msgid ""
"<strong>Manage Your Calendar</strong>: Use the Calendar app to block off "
"your availability and personal time."
msgstr ""
"<strong>ຈັດການປະຕິທິນຂອງທ່ານ</strong>: ໃຊ້ແອັບປະຕິທິນເພື່ອຈອງເວລາຫວ່າງ ແລະ ເວລາສ່ວນຕົວຂອງທ່"
"ານ."

#. module: personal_trainer
#: model_terms:ir.ui.view,arch_db:personal_trainer.welcome_article_body
msgid ""
"<strong>Set Up Your Services</strong>: Navigate to Sales &gt; Products and "
"set up your coaching services."
msgstr ""
"<strong>ຕັ້ງຄ່າການບໍລິການຂອງທ່ານ</strong>: ໄປທີ່ ການຂາຍ &gt; ສິນຄ້າ ແລະ ຕັ້ງຄ່າການບໍລິການສອນ"
"ຂອງທ່ານ."

#. module: personal_trainer
#: model_terms:ir.ui.view,arch_db:personal_trainer.welcome_article_body
msgid ""
"<strong>Start Tracking Projects</strong>: For services that require ongoing "
"management, create a project in the Project app."
msgstr ""
"<strong>ເລີ່ມຕິດຕາມໂຄງການ</strong>: ສໍາລັບການບໍລິການທີ່ຕ້ອງການການຈັດການຢ່າງຕໍ່ເນື່ອງ, ໃຫ້ສ້າງໂຄ"
"ງການໃນແອັບໂຄງການ."

#. module: personal_trainer
#: model_terms:ir.ui.view,arch_db:personal_trainer.welcome_article_body
msgid "Appointment Scheduling 📆"
msgstr "ການກໍາໜົດເວລານັດໝາຍ 📆"

#. module: personal_trainer
#: model_terms:ir.ui.view,arch_db:personal_trainer.welcome_article_body
msgid "Basics"
msgstr "ພື້ນຖານ"

#. module: personal_trainer
#: model_terms:ir.ui.view,arch_db:personal_trainer.welcome_article_body
msgid "Client Management (CRM) 🎯"
msgstr "ການຈັດການລູກຄ້າ (CRM) 🎯"

#. module: personal_trainer
#: model_terms:ir.ui.view,arch_db:personal_trainer.welcome_article_body
msgid "Collaborate with clients on their goals"
msgstr "ຮ່ວມມືກັບລູກຄ້າກ່ຽວກັບເປົ້າໝາຍຂອງພວກເຂົາ"

#. module: personal_trainer
#: model_terms:ir.ui.view,arch_db:personal_trainer.welcome_article_body
msgid "Convert leads into clients"
msgstr "ປ່ຽນຜູ້ທີ່ສົນໃຈໃຫ້ກາຍເປັນລູກຄ້າ"

#. module: personal_trainer
#: model_terms:ir.ui.view,arch_db:personal_trainer.welcome_article_body
msgid ""
"Create a stunning <strong>Website</strong> to showcase your coaching "
"services and allow clients to book sessions online."
msgstr ""
"ສ້າງ <strong>ເວັບໄຊ</strong> ທີ່ສວຍງາມເພື່ອສະແດງການບໍລິການສອນຂອງທ່ານ ແລະ ໃຫ້ລູກຄ້າສາມາດຈອ"
"ງຊ່ວງເວລາທາງອອນລາຍໄດ້."

#. module: personal_trainer
#: model_terms:ir.ui.view,arch_db:personal_trainer.welcome_article_body
msgid "Create and manage your coaching services:"
msgstr "ສ້າງ ແລະ ຈັດການການບໍລິການສອນຂອງທ່ານ:"

#. module: personal_trainer
#: model_terms:ir.ui.view,arch_db:personal_trainer.welcome_article_body
msgid "Create tasks for each stage of a client's journey"
msgstr "ສ້າງໜ້າວຽກສໍາລັບແຕ່ລະຂັ້ນຕອນຂອງການເດີນທາງຂອງລູກຄ້າ"

#. module: personal_trainer
#: model_terms:ir.ui.view,arch_db:personal_trainer.welcome_article_body
msgid "Define pricing and project tracking needs for each service"
msgstr "ກໍາໜົດລາຄາ ແລະ ຄວາມຕ້ອງການໃນການຕິດຕາມໂຄງການສໍາລັບແຕ່ລະບໍລິການ"

#. module: personal_trainer
#: model_terms:ir.ui.view,arch_db:personal_trainer.welcome_article_body
msgid "Define your availability"
msgstr "ກໍາໜົດເວລາຫວ່າງຂອງທ່ານ"

#. module: personal_trainer
#: model_terms:ir.ui.view,arch_db:personal_trainer.welcome_article_body
msgid ""
"Develop and sell online fitness courses with the <strong>eLearning</strong> "
"platform, expanding your reach beyond in-person training."
msgstr ""
"ພັດທະນາ ແລະ ຂາຍຄໍສຟິດເນັດອອນລາຍດ້ວຍແພລັດຟອມ <strong>eLearning</strong>, ເພື່ອຂະຫຍາຍກາ"
"ນບໍລິການຂອງທ່ານໃຫ້ກາຍການເຝິກຊ້ອມແບບຕົວຕໍ່ຕົວ."

#. module: personal_trainer
#: model_terms:ir.ui.view,arch_db:personal_trainer.welcome_article_body
msgid "Do you want to go further?"
msgstr "ທ່ານຕ້ອງການໄປຕໍ່ໃຫ້ໄກກວ່ານີ້ບໍ່?"

#. module: personal_trainer
#: model:project.task.type,name:personal_trainer.project_task_type_12
msgid "Done"
msgstr "ຈົບແລ້ວ"

#. module: personal_trainer
#: model_terms:ir.ui.view,arch_db:personal_trainer.welcome_article_body
msgid "Easily bill clients for your services:"
msgstr "ຮຽກເກັບເງິນນໍາລູກຄ້າສໍາລັບການບໍລິການຂອງທ່ານໄດ້ຢ່າງງ່າຍດາຍ:"

#. module: personal_trainer
#: model_terms:ir.ui.view,arch_db:personal_trainer.welcome_article_body
msgid ""
"Encourage clients to book through your Appointment page to reduce scheduling"
" back-and-forth."
msgstr ""
"ສົ່ງເສີມໃຫ້ລູກຄ້າຈອງຜ່ານໜ້າການນັດໝາຍຂອງທ່ານເພື່ອຫຼຸດຜ່ອນການສື່ສານກັບໄປກັບມາໃນການຈັດຕາຕະລາງ."

#. module: personal_trainer
#: model_terms:ir.ui.view,arch_db:personal_trainer.welcome_article_body
msgid ""
"Engage clients with targeted campaigns using <strong>Email "
"Marketing</strong> and <strong>Social Marketing</strong>."
msgstr ""
"ສ້າງຄວາມຜູກພັນກັບລູກຄ້າດ້ວຍແຄມເປນທີ່ກົງເປົ້າໝາຍໂດຍໃຊ້ <strong>ການຕະຫຼາດຜ່ານອີເມລ</strong> ແລ"
"ະ <strong>ການຕະຫຼາດຜ່ານໂຊຊຽວ</strong>."

#. module: personal_trainer
#: model:product.template,name:personal_trainer.product_product_11_product_template
msgid "Fitness Assessment"
msgstr "ການປະເມີນສະພາບຮ່າງກາຍ"

#. module: personal_trainer
#: model_terms:ir.ui.view,arch_db:personal_trainer.welcome_article_body
msgid "Follow up on inquiries"
msgstr "ຕິດຕາມການສອບຖາມ"

#. module: personal_trainer
#: model_terms:ir.ui.view,arch_db:personal_trainer.welcome_article_body
msgid ""
"Gather valuable client feedback and track progress effortlessly using "
"<strong>Surveys</strong>."
msgstr ""
"ຮວບຮວມຄໍາຄິດເຫັນທີ່ມີຄຸນຄ່າຈາກລູກຄ້າ ແລະ ຕິດຕາມຄວາມຄືບໜ້າໄດ້ຢ່າງງ່າຍດາຍໂດຍໃຊ້ <strong>ການສໍາຫຼວ"
"ດ</strong>."

#. module: personal_trainer
#: model_terms:ir.ui.view,arch_db:personal_trainer.welcome_article_body
msgid "Generate invoices automatically from sales orders"
msgstr "ສ້າງໃບເກັບເງິນໂດຍອັດຕະໂນມັດຈາກໃບສັ່ງຂາຍ"

#. module: personal_trainer
#: model_terms:ir.ui.view,arch_db:personal_trainer.welcome_article_body
msgid "Getting Started"
msgstr "ເລີ່ມຕົ້ນການໃຊ້ງານ"

#. module: personal_trainer
#: model_terms:ir.ui.view,arch_db:personal_trainer.welcome_article_body
msgid ""
"If you want to push your quotation building much further and add all the "
"power of Spreadsheet beneath any line of your Sales Orders, use the quote "
"calculation feature."
msgstr ""
"ຫາກທ່ານຕ້ອງການຍົກລະດັບການສ້າງໃບສະເໜີລາຄາໃຫ້ຫຼາຍຂຶ້ນ ແລະ ໃຊ້ປະສິດທິພາບຂອງ Spreadsheet ໃນແຕ່ລ"
"ະລາຍການຂອງໃບສັ່ງຂາຍ, ໃຫ້ໃຊ້ຟີເຈີການຄໍານວນລາຄາ."

#. module: personal_trainer
#: model_terms:ir.ui.view,arch_db:personal_trainer.welcome_article_body
msgid "Invoicing 🧾"
msgstr "ການອອກໃບເກັບເງິນ 🧾"

#. module: personal_trainer
#: model_terms:ir.ui.view,arch_db:personal_trainer.welcome_article_body
msgid "Let clients book directly through your booking page"
msgstr "ໃຫ້ລູກຄ້າຈອງໂດຍກົງຜ່ານໜ້າການຈອງຂອງທ່ານ"

#. module: personal_trainer
#: model_terms:ir.ui.view,arch_db:personal_trainer.welcome_article_body
msgid "Manage leads and opportunities"
msgstr "ຈັດການລາຍຊື່ຜູ້ສົນໃຈ ແລະ ໂອກາດໃນການຂາຍ"

#. module: personal_trainer
#: model_terms:ir.ui.view,arch_db:personal_trainer.welcome_article_body
msgid "Manage your services 👟"
msgstr "ຈັດການການບໍລິການຂອງທ່ານ 👟"

#. module: personal_trainer
#: model_terms:ir.ui.view,arch_db:personal_trainer.welcome_article_body
msgid ""
"Manage your team of coaches and staff efficiently with "
"<strong>Employees</strong>."
msgstr ""
"ຈັດການທີມງານຄູເຝິກ ແລະ ພະນັກງານຂອງທ່ານຢ່າງມີປະສິດທິພາບດ້ວຍ <strong>ພະນັກງານ</strong>."

#. module: personal_trainer
#: model:crm.stage,name:personal_trainer.crm_stage_5
msgid "Negotiation"
msgstr "ການເຈລະຈາ"

#. module: personal_trainer
#: model:project.task.type,name:personal_trainer.project_task_type_9
msgid "New"
msgstr "ໃໝ່"

#. module: personal_trainer
#: model_terms:ir.ui.view,arch_db:personal_trainer.welcome_article_body
msgid "Odoo offers you infinite possibilities, such as:"
msgstr "Odoo ມອບຄວາມເປັນໄປໄດ້ທີ່ບໍ່ສິ້ນສຸດໃຫ້ທ່ານ ເຊັ່ນ:"

#. module: personal_trainer
#: model_terms:ir.ui.view,arch_db:personal_trainer.welcome_article_body
msgid ""
"Organize group classes, workshops, and fitness events easily with the "
"<strong>Events</strong> app."
msgstr ""
"ຈັດລະບຽບການຮຽນແບບກຸ່ມ, ເວີກຊັອບ ແລະ ກິດຈະກໍາຟິດເນັດໄດ້ຢ່າງງ່າຍດາຍດ້ວຍແອັບ <strong>ກິດຈະກໍາ</"
"strong>."

#. module: personal_trainer
#: model_terms:ir.ui.view,arch_db:personal_trainer.welcome_article_body
msgid "Project Tracking 📈"
msgstr "ການຕິດຕາມໂຄງການ 📈"

#. module: personal_trainer
#: model_terms:ir.ui.view,arch_db:personal_trainer.welcome_article_body
msgid "Reach us"
msgstr "ຕິດຕໍ່ພວກເຮົາ"

#. module: personal_trainer
#: model_terms:ir.ui.view,arch_db:personal_trainer.welcome_article_body
msgid ""
"Regularly update your CRM to keep track of potential clients and follow-ups."
msgstr ""
