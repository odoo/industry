{
    "name": "Industry",
    "vars": {
        "module_filter": "-*,industry/*"
    },
    "steps": [
        {
            "name": "Install template database",
            "db_name": "industry",
            "job_type": "odoo",
            "demo_mode": "without_demo",
            "install_modules": "base_import_module,website_sale,point_of_sale,sale_purchase_stock,hr,web_hierarchy,project,web_studio,knowledge,crm,calendar,hr_skills,project,pos_sale,sale_project,planning,appointment,hr_timesheet,sale_timesheet,timesheet_grid,industry_fsm,sale_subscription,documents_account,sign,documents,sale_planning,website_partner,link_tracker,loyalty,pos_loyalty,website_sale_loyalty,sale_loyalty_delivery,event,website_event,mrp,website_event_sale,mass_mailing,pos_self_order,industry/test_*"
        },
        {
            "name": "Test all Industries",
            "job_type": "command",
            "db_name": "industry",
            "command": "odoo/odoo-bin --addons-path={{addons_path}} test_industry -d {{db_name}} --data-dir {{data_dir}} --all --test-enable --log-db runbot_logs --log-db-level=26 --industry-demo",
            "check_logs": ["ERROR", "WARNING"],
            "expected_logs": ["Initiating shutdown", "Starting post tests"]
        }
    ]
}
