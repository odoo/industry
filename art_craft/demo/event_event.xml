<?xml version='1.0' encoding='UTF-8'?>
<odoo noupdate="1" context="{'mail_auto_subscribe_no_notify': True}">
    <record id="event_event_1" model="event.event">
        <field name="is_published" eval="True"/>
        <field name="name">DIY Workshop Painting</field>
        <field name="description"><![CDATA[<section class="s_text_block o_colored_level">
            <p>When was the last time you did something <i>just for fun</i>? No screens, no endless scrolling, no checking your watch—just pure, hands-on creativity.</p><p>If your walls are looking a little bare (or you’re just looking for a great excuse to hang out with fun people), we’ve got you covered.</p><p>We are officially hosting our <b>DIY Painting Workshop</b>, and your canvas is waiting!</p>
        </section>]]></field>
        <field name="user_id" ref="base.user_admin"/>
        <field name="stage_id" ref="event.event_stage_booked"/>
        <field name="date_tz" model="res.users" eval="obj().env.ref('base.user_admin').tz or 'Europe/Brussels'"/>
        <field name="date_begin" model="res.users" eval="(DateTime.now().replace(hour=12, minute=30, second=0)).replace(tzinfo=pytz.timezone(obj().env.user.tz or 'UTC')).astimezone(pytz.UTC).replace(tzinfo=None)"/>
        <field name="date_end" model="res.users" eval="(DateTime.now().replace(hour=14, minute=30) + relativedelta(days=10)).replace(tzinfo=pytz.timezone(obj().env.user.tz or 'UTC')).astimezone(pytz.UTC).replace(tzinfo=None)"/>
        <field name="lang">en_US</field>
        <field name="question_ids" eval="[(6, 0, [ref('event.event_question_name'), ref('event.event_question_email'), ref('event.event_question_phone')])]"/>
    </record>
</odoo>
