#. module: art_craft
#: model:product.template,description_sale:art_craft.product_template_21
msgid ""
"\n"
"            Condition For Online sales\n"
"            - This is saleable from physical store only. For that You need "
"to contact Us.\n"
"\n"
"            Assigned Title: Radha and Krishna with Female Attendants and "
"Musicians\n"
"            Date: c.1800\n"
"            Place of Origin: Rajasthan, India\n"
"            Medium: Watercolour on paper\n"
"            Dimensions: Visible image: H. 33 cm, W. 28 cm; Frame: H. 38 cm, "
"W. 32 cm\n"
"            Department: Pre-Modern Art\n"
"        "
msgstr ""
"\n"
"            ऑनलाइन सेल्स के लिए शर्त\n"
"            - यह सिर्फ़ फ़िजिकल स्टोर से खरीदा जा सकता है. इसके लिए आपको हमसे संपर्क "
"करना होगा.\n"
"\n"
"            निर्धारित शीर्षक: सखियों और संगीतकारों के साथ राधा और कृष्ण\n"
"            तारीख: लगभग 1800\n"
"            उत्पत्ति का स्थान: राजस्थान, भारत\n"
"            माध्यम: कागज़ पर वॉटरकलर\n"
"            डाइमेंशन: दिखने वाली इमेज: ऊंचाई 33 सेमी, चौड़ाई 28 सेमी; फ्रेम: ऊंचाई 38 "
"सेमी, चौड़ाई 32 सेमी\n"
"            विभाग: प्री-मॉडर्न आर्ट\n"
"        "

