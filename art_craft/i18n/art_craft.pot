#. module: art_craft
#: model_terms:ir.ui.view,arch_db:art_craft.welcome_article_body
msgid ""
"<b>Ready to scale your reach?</b> Explore the <b>SMS Marketing</b>, "
"<b>Social Marketing</b>, and <b>Marketing Automation</b> apps to build "
"advanced, multi-channel campaigns."
msgstr ""

#. module: art_craft
#: model_terms:ir.ui.view,arch_db:art_craft.welcome_article_body
