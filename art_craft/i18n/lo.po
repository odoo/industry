#: model_terms:ir.ui.view,arch_db:art_craft.welcome_article_body
msgid ""
"<span style=\"color: rgb(0, 0, 0); background-color: transparent; font-"
"weight: 700; font-style: normal; text-decoration: none; font-size: "
"24px;\">The Arts and Crafts Shop</span>"
msgstr ""
"<span style=\"color: rgb(0, 0, 0); background-color: transparent; font-"
"weight: 700; font-style: normal; text-decoration: none; font-size: 24px;\">ຮ້າ"
"ນສິລະປະ ແລະ ຫັດຖະກຳ</span>"

#. module: art_craft
#: model_terms:ir.ui.view,arch_db:art_craft.welcome_article_body
msgid ""
"<span style=\"font-size: 13pt; color: #000000; background-color: transparent; font-weight: 400; font-style: normal; text-decoration: none;\"/>\n"
"            <span class=\"text-o-color-2\" style=\"background-color: transparent; font-weight: 400; font-style: normal; text-decoration: none;\">\n"
"                <font class=\"text-800\">\n"
"                    An arts and crafts store is a haven for creative individuals and hobbyists, offering a diverse range of supplies and materials for various artistic endeavours. From painting and drawing, scrap booking. These stores provide a\n"
"                    colourful array of paints, brushes, paper, beads, tools, colourful trays and other crafting (Handmade) essentials. They are a treasure trove for anyone seeking to express their creativity, explore new hobbies, or create\n"
"                    beautiful handmade items.\n"
"                </font>\n"
"            </span>"
msgstr ""
"<span style=\"font-size: 13pt; color: #000000; background-color: "
"transparent; font-weight: 400; font-style: normal; text-decoration: none;\"/>"
"\n"
"            <span class=\"text-o-color-2\" style=\"background-color: "
"transparent; font-weight: 400; font-style: normal; text-decoration: none;\">"
"\n"
"                <font class=\"text-800\">\n"
"                    ຮ້ານສິລະປະ ແລະ ຫັດຖະກຳ ແມ່ນແຫຼ່ງລວມສຳລັບຜູ້ທີ່ມີຄວາມຄິດສ້າງສັນ ແລະ ນັກສະສົ"
"ມ, ໂດຍມີອຸປະກອນ ແລະ ວັດສະດຸທີ່ຫຼາກຫຼາຍສຳລັບວຽກງານສິລະປະຕ່າງໆ. ນັບແຕ່ການແຕ້ມຮູບ, ການຂຽນ, ໄປຈົນ"
"ເຖິງການເຮັດປຶ້ມບັນທຶກ. ຮ້ານເຫຼົ່ານີ້ມີ\n"
"                    ສີສັນຫຼາກຫຼາຍຊະນິດ, ແປງຖູ, ເຈ້ຍ, ລູກປັດ, ເຄື່ອງມື, ຖາດສີສັນ ແລະ ສິ່ງຈຳເປັນ"
"ອື່ນໆ ສຳລັບວຽກງານຫັດຖະກຳ. ທີ່ນີ້ຄືຂຸມຊັບສຳລັບທຸກຄົນທີ່ຕ້ອງການສະແດງຄວາມຄິດສ້າງສັນ, ຄົ້ນຫາວຽກອະດິເລກໃ"
"ໝ່ ຫຼື ສ້າງສັນ\n"
"                    ຜົນງານເຮັດດ້ວຍມືທີ່ສວຍງາມ.\n"
"                </font>\n"
"            </span>"

