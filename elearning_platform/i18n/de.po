#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Calculate the area of a rectangle\n"
"area = length * width"
msgstr ""
"# Die Fläche eines Vierecks berechnen\n"
"area = length * width"

#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Easy to read\n"
"def calculate_area(length, width):\n"
"    return length * width"
msgstr ""
"# Einfach zu lesen\n"
"def calculate_area(length, width):\n"
"    return length * width"

#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Overcomplicated\n"
"if not (score &lt; 50):\n"
"    print(\"You passed!\")\n"
"\n"
"# Simpler and clearer\n"
"if score &gt;= 50:\n"
"    print(\"You passed!\")"
msgstr ""
"# Zu kompliziert\n"
"if not (score &lt; 50):\n"
"    print(\"Bestanden!\")\n"
"\n"
"# Einfacher und übersichtlicher\n"
"if score &gt;= 50:\n"
"    print(\"Bestanden!\")"

#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Repetition\n"
"print(\"Hello, Alice!\")\n"
"print(\"Hello, Bob!\")\n"
"print(\"Hello, Carol!\")\n"
"\n"
"# DRY version\n"
"names = [\"Alice\", \"Bob\", \"Carol\"]\n"
"for name in names:\n"
"    print(\"Hello,\", name + \"!\")"
msgstr ""
"# Wiederholung\n"
"print(\"Guten Tag, Alice!\")\n"
"print(\"Guten Tag, Bob!\")\n"
"print(\"Guten Tag, Carol!\")\n"
"\n"
"# DRY-Version\n"
"names = [\"Alice\", \"Bob\", \"Carol\"]\n"
"for name in names:\n"
"    print(\"Guten Tag,\", name + \"!\")"

