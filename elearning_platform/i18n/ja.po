#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Calculate the area of a rectangle\n"
"area = length * width"
msgstr ""
"# 長方形の面積を計算する\n"
"面積 = 長さ * 幅"

#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Easy to read\n"
"def calculate_area(length, width):\n"
"    return length * width"
msgstr ""
"# 読みやすい\n"
"def calculate_area(長さ, 幅):\n"
"    return 長さ * 幅"

#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Overcomplicated\n"
"if not (score &lt; 50):\n"
"    print(\"You passed!\")\n"
"\n"
"# Simpler and clearer\n"
"if score &gt;= 50:\n"
"    print(\"You passed!\")"
msgstr ""
"# 複雑すぎる書き方\n"
"if not (score &lt; 50):\n"
"    print(\"合格です!\")\n"
"\n"
"# よりシンプルでわかりやすい書き方\n"
"if score &gt;= 50:\n"
"    print(\"合格です!\")"

#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Repetition\n"
"print(\"Hello, Alice!\")\n"
"print(\"Hello, Bob!\")\n"
"print(\"Hello, Carol!\")\n"
"\n"
"# DRY version\n"
"names = [\"Alice\", \"Bob\", \"Carol\"]\n"
"for name in names:\n"
"    print(\"Hello,\", name + \"!\")"
msgstr ""
"# 繰り返し\n"
"print(\"こんにちは、アリスさん!\")\n"
"print(\"こんにちは、ボブさん!\")\n"
"print(\"こんにちは、キャロルさん!\")\n"
"\n"
"# 簡潔バージョン\n"
"names = [\"アリス\", \"ボブ\", \"キャロル\"]\n"
"for name in names:\n"
"    print(\"こんにちは,\", name + \"さん!\")"

