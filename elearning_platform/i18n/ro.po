"# Calculate the area of a rectangle\n"
"area = length * width"
msgstr ""
"# Calculează aria unui dreptunghi\n"
"aria = lungime * lățime"

#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Easy to read\n"
"def calculate_area(length, width):\n"
"    return length * width"
msgstr ""
"# Ușor de citit\n"
"def calculează_aria(lungime, lățime):\n"
"    return lungime * lățime"

#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Overcomplicated\n"
"if not (score &lt; 50):\n"
"    print(\"You passed!\")\n"
"\n"
"# Simpler and clearer\n"
"if score &gt;= 50:\n"
"    print(\"You passed!\")"
msgstr ""
"# Prea complicat\n"
"dacă nu (scor &lt; 50):\n"
"    print(\"Ai trecut!\")\n"
"\n"
"# Mai simplu și mai clar\n"
"dacă scor &gt;= 50:\n"
"    print(\"Ai trecut!\")"

#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Repetition\n"
"print(\"Hello, Alice!\")\n"
"print(\"Hello, Bob!\")\n"
"print(\"Hello, Carol!\")\n"
"\n"
"# DRY version\n"
"names = [\"Alice\", \"Bob\", \"Carol\"]\n"
"for name in names:\n"
"    print(\"Hello,\", name + \"!\")"
msgstr ""
"# Repetiție\n"
"print(\"Salut, Alice!\")\n"
"print(\"Salut, Bob!\")\n"
"print(\"Salut, Carol!\")\n"
"\n"
"# Versiunea DRY\n"
"nume = [\"Alice\", \"Bob\", \"Carol\"]\n"
"pentru nume în nume:\n"
"    print(\"Salut,\", nume + \"!\")"

