#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_52
msgid ""
"Welcome to the Number Guessing Game!\n"
"Enter your guess (1–20): 10\n"
"Too low, try again!\n"
"Enter your guess (1–20): 15\n"
"Too high, try again!\n"
"Enter your guess (1–20): 12\n"
"🎉 Congratulations! You guessed the number!"
msgstr ""
