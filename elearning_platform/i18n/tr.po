#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Calculate the area of a rectangle\n"
"area = length * width"
msgstr ""
"# Bir dikdörtgenin alanını hesaplayın\n"
"alan = uzunluk * genişlik"

#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Easy to read\n"
"def calculate_area(length, width):\n"
"    return length * width"
msgstr ""
"# Okuması kolay\n"
"def calculate_area(uzunluk, genişlik):\n"
"    return uzunluk * genişlik"

#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Overcomplicated\n"
"if not (score &lt; 50):\n"
"    print(\"You passed!\")\n"
"\n"
"# Simpler and clearer\n"
"if score &gt;= 50:\n"
"    print(\"You passed!\")"
msgstr ""
"# Aşırı Karmaşık\n"
"if not (score &lt; 50):\n"
"    print(\"Geçtiniz!\")\n"
"\n"
"# Daha basit ve anlaşılır\n"
"eğer puan &gt;= 50:\n"
"    print(\"Geçtiniz!\")"

#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Repetition\n"
"print(\"Hello, Alice!\")\n"
"print(\"Hello, Bob!\")\n"
"print(\"Hello, Carol!\")\n"
"\n"
"# DRY version\n"
"names = [\"Alice\", \"Bob\", \"Carol\"]\n"
"for name in names:\n"
"    print(\"Hello,\", name + \"!\")"
msgstr ""
"# Tekrarlama\n"
"print(\"Merhaba, Alice!\")\n"
"print(\"Merhaba, Bob!\")\n"
"print(\"Merhaba, Carol!\")\n"
"\n"
"# DRY sürümü\n"
"names = [\"Alice\", \"Bob\", \"Carol\"]\n"
"for isim in isimler:\n"
"    print(\"Merhaba,\", isim + \"!\")"

