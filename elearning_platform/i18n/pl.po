#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Bad\n"
"x = 100\n"
"\n"
"# Good\n"
"max_score = 100"
msgstr ""
"# Źle\n"
"x = 100\n"
"\n"
"# Dobrze\n"
"max_score = 100"

#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Calculate the area of a rectangle\n"
"area = length * width"
msgstr ""
"# Oblicz pole prostokąta\n"
"area = length * width"

#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Easy to read\n"
"def calculate_area(length, width):\n"
"    return length * width"
msgstr ""
"# Łatwe do odczytania\n"
"def calculate_area(length, width):\n"
"    return length * width"

#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Overcomplicated\n"
"if not (score &lt; 50):\n"
"    print(\"You passed!\")\n"
"\n"
"# Simpler and clearer\n"
"if score &gt;= 50:\n"
"    print(\"You passed!\")"
msgstr ""
"# Zbyt skomplikowane\n"
"if not (score &lt; 50):\n"
"    print(\"Zaliczone!\")\n"
"\n"
"# Prostsze i bardziej czytelne\n"
"if score &gt;= 50:\n"
"    print(\"Zaliczone!\")"

#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Repetition\n"
"print(\"Hello, Alice!\")\n"
"print(\"Hello, Bob!\")\n"
"print(\"Hello, Carol!\")\n"
"\n"
"# DRY version\n"
"names = [\"Alice\", \"Bob\", \"Carol\"]\n"
"for name in names:\n"
"    print(\"Hello,\", name + \"!\")"
msgstr ""
"# Powtórzenie\n"
"print(\"Hej, Ala!\")\n"
"print(\"Hej, Bartek!\")\n"
"print(\"Hej, Karol!\")\n"
"\n"
"# wersja DRY\n"
"names = [\"Ala\", \"Bartek\", \"Karol\"]\n"
"for name in names:\n"
"    print(\"Hej,\", name + \"!\")"

