msgid ""
"# Bad\n"
"x = 100\n"
"\n"
"# Good\n"
"max_score = 100"
msgstr ""
"# 欠佳\n"
"x = 100\n"
"\n"
"# 良好\n"
"max_score = 100"

#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Calculate the area of a rectangle\n"
"area = length * width"
msgstr ""
"# 計算長方形面積\n"
"area = length * width"

#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Easy to read\n"
"def calculate_area(length, width):\n"
"    return length * width"
msgstr ""
"# 容易閱讀\n"
"def calculate_area(length, width):\n"
"    return length * width"

#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Overcomplicated\n"
"if not (score &lt; 50):\n"
"    print(\"You passed!\")\n"
"\n"
"# Simpler and clearer\n"
"if score &gt;= 50:\n"
"    print(\"You passed!\")"
msgstr ""
"# 過於複雜\n"
"if not (score &lt; 50):\n"
"    print(\"你及格了！\")\n"
"\n"
"# 較簡單及清晰\n"
"if score &gt;= 50:\n"
"    print(\"你及格了！\")"

#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Repetition\n"
"print(\"Hello, Alice!\")\n"
"print(\"Hello, Bob!\")\n"
"print(\"Hello, Carol!\")\n"
"\n"
"# DRY version\n"
"names = [\"Alice\", \"Bob\", \"Carol\"]\n"
"for name in names:\n"
"    print(\"Hello,\", name + \"!\")"
msgstr ""
"# 重複\n"
"print(\"你好，愛蓮！\")\n"
"print(\"你好，寶強！\")\n"
"print(\"你好，嘉露！\")\n"
"\n"
"# 乾淨版本（DRY 原則）\n"
"names = [\"愛蓮\", \"寶強\", \"嘉露\"]\n"
"for name in names:\n"
"    print(\"你好，\", name + \"！\")"

