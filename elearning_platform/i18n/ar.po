#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Calculate the area of a rectangle\n"
"area = length * width"
msgstr ""
"# احسب مساحة المستطيل\n"
"المساحة = الطول * العرض"

#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Easy to read\n"
"def calculate_area(length, width):\n"
"    return length * width"
msgstr ""
"# سهل القراءة\n"
"def calculate_area(length, width):\n"
"    return length * width"

#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Overcomplicated\n"
"if not (score &lt; 50):\n"
"    print(\"You passed!\")\n"
"\n"
"# Simpler and clearer\n"
"if score &gt;= 50:\n"
"    print(\"You passed!\")"
msgstr ""
"# معقد للغاية\n"
"إذا لم تكن (النتيجة &lt; 50):\n"
"    اطبع(\"لقد نجحت!\")\n"
"\n"
"# أبسط وأكثر وضوحًا\n"
"إذا كانت النتيجة &gt;= 50:\n"
"    اطبع(\"لقد نجحت!\")"

#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Repetition\n"
"print(\"Hello, Alice!\")\n"
"print(\"Hello, Bob!\")\n"
"print(\"Hello, Carol!\")\n"
"\n"
"# DRY version\n"
"names = [\"Alice\", \"Bob\", \"Carol\"]\n"
"for name in names:\n"
"    print(\"Hello,\", name + \"!\")"
msgstr ""
"# التكرار\n"
"print(\"مرحباً، أليس!\")\n"
"print(\"مرحباً، بوب!\")\n"
"print(\"مرحباً، كارول!\")\n"
"\n"
"# نسخة DRY\n"
"الأسماء = [\"أليس\"، \"بوب\"، \"كارول\"]\n"
"للأسماء الموجودة في قسل الأسماء:\n"
"    اطبع(\"مرحباً\"، الاسم + \"!\")"

