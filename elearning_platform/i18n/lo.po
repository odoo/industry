#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Bad\n"
"x = 100\n"
"\n"
"# Good\n"
"max_score = 100"
msgstr ""
"# ບໍ່ດີ\n"
"x = 100\n"
"\n"
"# ດີ\n"
"max_score = 100"

#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Calculate the area of a rectangle\n"
"area = length * width"
msgstr ""
"# ຄິດໄລ່ເນື້ອທີ່ຂອງຮູບສີ່ແຈສາກ\n"
"area = length * width"

#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Easy to read\n"
"def calculate_area(length, width):\n"
"    return length * width"
msgstr ""
"# ອ່ານງ່າຍ\n"
"def calculate_area(length, width):\n"
"    return length * width"

#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Overcomplicated\n"
"if not (score &lt; 50):\n"
"    print(\"You passed!\")\n"
"\n"
"# Simpler and clearer\n"
"if score &gt;= 50:\n"
"    print(\"You passed!\")"
msgstr ""
"# ຊັບຊ້ອນເກີນໄປ\n"
"if not (score &lt; 50):\n"
"    print(\"ທ່ານສອບເສັງຜ່ານ!\")\n"
"\n"
"# ງ່າຍດາຍ ແລະ ຊັດເຈນກວ່າ\n"
"if score &gt;= 50:\n"
"    print(\"ທ່ານສອບເສັງຜ່ານ!\")"

#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Repetition\n"
"print(\"Hello, Alice!\")\n"
"print(\"Hello, Bob!\")\n"
"print(\"Hello, Carol!\")\n"
"\n"
"# DRY version\n"
"names = [\"Alice\", \"Bob\", \"Carol\"]\n"
"for name in names:\n"
"    print(\"Hello,\", name + \"!\")"
msgstr ""
"# ການຂຽນຊ້ຳ\n"
"print(\"ສະບາຍດີ, Alice!\")\n"
"print(\"ສະບາຍດີ, Bob!\")\n"
"print(\"ສະບາຍດີ, Carol!\")\n"
"\n"
"# ເວີຊັນ DRY (ຢ່າຂຽນຊ້ຳ)\n"
"names = [\"Alice\", \"Bob\", \"Carol\"]\n"
"for name in names:\n"
"    print(\"ສະບາຍດີ,\", name + \"!\")"

