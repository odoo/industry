msgstr "Аналогия из жизни: Книга рецептов"

#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_50
msgid "Real-Life Analogy: Building IKEA Furniture"
msgstr "Аналогия из жизни: Сборка мебели IKEA"

#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_50
msgid "Remove the toast."
msgstr "Достаньте тост."

#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_50
