#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Calculate the area of a rectangle\n"
"area = length * width"
msgstr ""
"# Calcula el área de un rectángulo\n"
"area = largo * ancho"

#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Easy to read\n"
"def calculate_area(length, width):\n"
"    return length * width"
msgstr ""
"# Fácil de leer\n"
"def calcular_area(largo, ancho):\n"
"    return largo * ancho"

#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Overcomplicated\n"
"if not (score &lt; 50):\n"
"    print(\"You passed!\")\n"
"\n"
"# Simpler and clearer\n"
"if score &gt;= 50:\n"
"    print(\"You passed!\")"
msgstr ""
"# Demasiado complicado\n"
"if not (puntaje &lt; 50):\n"
"    print(\"¡Aprobaste!\")\n"
"\n"
"# Más simple y claro\n"
"if puntaje &gt;= 50:\n"
"    print(\"¡Aprobaste!\")"

#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Repetition\n"
"print(\"Hello, Alice!\")\n"
"print(\"Hello, Bob!\")\n"
"print(\"Hello, Carol!\")\n"
"\n"
"# DRY version\n"
"names = [\"Alice\", \"Bob\", \"Carol\"]\n"
"for name in names:\n"
"    print(\"Hello,\", name + \"!\")"
msgstr ""
"# Repetición\n"
"print(\"¡Hola, Alicia!\")\n"
"print(\"¡Hola, Bruno!\")\n"
"print(\"¡Hola, Carolina!\")\n"
"\n"
"# Versión DRY (de \"Don't Repeat Yourself\", por sus siglas en inglés, o "
"conocido como el método \"No te repitas\")\n"
"nombres = [\"Alicia\", \"Bruno\", \"Carolina\"]\n"
"for nombre in nombres:\n"
"    print(\"¡Hola,\", nombre + \"!\")"

