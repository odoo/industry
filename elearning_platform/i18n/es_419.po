"import random\n"
"\n"
"print(\"¡Bienvenido al juego de adivinanzas!\")\n"
"\n"
"# Paso 1: Genera un número al azar entre 1 y 20\n"
"secret_number = random.randint(1, 20)\n"
"guess = None\n"
"\n"
"# Paso 2: Sigue preguntando hasta que el jugador adivine bien\n"
"while guess != secret_number:\n"
"    guess = int(input(\"Enter your guess (1–20): \"))\n"
"    \n"
"    if guess &lt; secret_number:\n"
"        print(\"Muy bajo, vuelve a intentarlo.\")\n"
"    elif guess &gt; secret_number:\n"
"        print(\"Muy alto, vuelve a intentarlo.\")\n"
"    else:\n"
