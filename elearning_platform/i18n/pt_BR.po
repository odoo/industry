#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Calculate the area of a rectangle\n"
"area = length * width"
msgstr ""
"# Calcule a área de um retângulo\n"
"área = comprimento * largura"

#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Easy to read\n"
"def calculate_area(length, width):\n"
"    return length * width"
msgstr ""
"# Fácil de ler\n"
"def calculate_area(comprimento, largura):\n"
"    devolver comprimento * largura"

#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Overcomplicated\n"
"if not (score &lt; 50):\n"
"    print(\"You passed!\")\n"
"\n"
"# Simpler and clearer\n"
"if score &gt;= 50:\n"
"    print(\"You passed!\")"
msgstr ""
"# Muito complicado\n"
"if not (score &lt; 50):\n"
"    print(\"Aprovado!\")\n"
"\n"
"# Mais simples e claro\n"
"if score &gt;= 50:\n"
"    print(\"Aprovado!\")"

#. module: elearning_platform
#: model_terms:slide.slide,html_content:elearning_platform.slide_slide_51
msgid ""
"# Repetition\n"
"print(\"Hello, Alice!\")\n"
"print(\"Hello, Bob!\")\n"
"print(\"Hello, Carol!\")\n"
"\n"
"# DRY version\n"
"names = [\"Alice\", \"Bob\", \"Carol\"]\n"
"for name in names:\n"
"    print(\"Hello,\", name + \"!\")"
msgstr ""
"# Repetição\n"
"print(\"Olá, Alice!\")\n"
"print(\"Olá, Bob!\")\n"
"print(\"Olá, Carol!\")\n"
"\n"
"# Versão DRY\n"
"names = [\"Alice\", \"Bob\", \"Carol\"]\n"
"for name in names:\n"
"    print(\"Olá,\", nome + \"!\")"

