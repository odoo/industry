<?xml version='1.0' encoding='UTF-8'?>
<odoo auto_sequence="1" noupdate="1">
  <record id="survey.survey_feedback_p1" model="survey.question" forcecreate="1">
    <field name="title">About you</field>
    <field name="description"><![CDATA[<p>This section is about general information about you. Answering them helps qualifying your answers.</p>]]></field>
    <field name="is_page" eval="True"/>
    <field name="survey_id" ref="survey.survey_feedback"/>
  </record>
  <record id="website_slides_survey.furniture_certification_page_1" model="survey.question" forcecreate="1">
    <field name="title">Furniture</field>
    <field name="description"><![CDATA[<p>Test your furniture knowledge!</p>]]></field>
    <field name="is_page" eval="True"/>
    <field name="survey_id" ref="website_slides_survey.furniture_certification"/>
  </record>
  <record id="survey.survey_feedback_p1_q1" model="survey.question" forcecreate="1">
    <field name="title">Where do you live?</field>
    <field name="question_type">char_box</field>
    <field name="question_placeholder">Brussels</field>
    <field name="survey_id" ref="survey.survey_feedback"/>
  </record>
  <record id="website_slides_survey.furniture_certification_page_1_question_1" model="survey.question" forcecreate="1">
    <field name="title">What type of wood is the best for furniture?</field>
    <field name="question_type">simple_choice</field>
    <field name="survey_id" ref="website_slides_survey.furniture_certification"/>
    <field name="is_scored_question" eval="True"/>
    <field name="constr_mandatory" eval="True"/>
  </record>
  <record id="survey.survey_feedback_p1_q2" model="survey.question" forcecreate="1">
    <field name="title">When is your date of birth?</field>
    <field name="question_type">date</field>
    <field name="survey_id" ref="survey.survey_feedback"/>
  </record>
  <record id="website_slides_survey.furniture_certification_page_1_question_2" model="survey.question" forcecreate="1">
    <field name="title">Select all the furniture shown in the video</field>
    <field name="question_type">multiple_choice</field>
    <field name="survey_id" ref="website_slides_survey.furniture_certification"/>
    <field name="is_scored_question" eval="True"/>
  </record>
  <record id="survey.survey_feedback_p1_q3" model="survey.question" forcecreate="1">
    <field name="title">How frequently do you buy products online?</field>
    <field name="question_type">simple_choice</field>
    <field name="survey_id" ref="survey.survey_feedback"/>
    <field name="comments_allowed" eval="True"/>
    <field name="comment_count_as_answer" eval="True"/>
    <field name="constr_mandatory" eval="True"/>
  </record>
  <record id="website_slides_survey.furniture_certification_page_1_question_3" model="survey.question" forcecreate="1">
    <field name="title">What do you think about the content of the course? (not rated)</field>
    <field name="question_type">text_box</field>
    <field name="survey_id" ref="website_slides_survey.furniture_certification"/>
  </record>
  <record id="survey.survey_feedback_p1_q4" model="survey.question" forcecreate="1">
    <field name="title">How many times did you order products on our website?</field>
    <field name="question_type">numerical_box</field>
    <field name="survey_id" ref="survey.survey_feedback"/>
    <field name="constr_mandatory" eval="True"/>
  </record>
  <record id="survey.survey_feedback_p2" model="survey.question" forcecreate="1">
    <field name="title">About our ecommerce</field>
    <field name="description"><![CDATA[<p>This section is about our eCommerce experience itself.</p>]]></field>
    <field name="is_page" eval="True"/>
    <field name="survey_id" ref="survey.survey_feedback"/>
  </record>
  <record id="survey.survey_feedback_p2_q1" model="survey.question" forcecreate="1">
    <field name="title">Which of the following words would you use to describe our products?</field>
    <field name="question_type">multiple_choice</field>
    <field name="survey_id" ref="survey.survey_feedback"/>
    <field name="comments_allowed" eval="True"/>
    <field name="constr_mandatory" eval="True"/>
  </record>
  <record id="survey.survey_feedback_p2_q2" model="survey.question" forcecreate="1">
    <field name="title">What do you think about our new eCommerce?</field>
    <field name="question_type">matrix</field>
    <field name="survey_id" ref="survey.survey_feedback"/>
    <field name="matrix_subtype">multiple</field>
    <field name="constr_mandatory" eval="True"/>
  </record>
  <record id="survey.survey_feedback_p2_q3" model="survey.question" forcecreate="1">
    <field name="title">Do you have any other comments, questions, or concerns?</field>
    <field name="question_type">text_box</field>
    <field name="survey_id" ref="survey.survey_feedback"/>
  </record>
</odoo>
