#. module: florist
#: model_terms:ir.ui.view,arch_db:florist.welcome_article_body
msgid ""
"<strong>\n"
"                    <font style=\"color: rgb(113, 75, 103);\">The Point of Sale app </font><font class=\"text-o-color-5\"><span style=\"font-weight: normal;\">h</span></font>\n"
"                </strong>\n"
"                andles in-store sales of bouquets, flowers, gift cards, and more."
msgstr ""
"<strong>\n"
"                    <font style=\"color: rgb(113, 75, 103);\">ແອັບຈຸດຂາຍ (POS) "
"</font><font class=\"text-o-color-5\"><span style=\"font-weight: normal;\">ຊ່ວ"
"ຍ</span></font>\n"
"                </strong>\n"
"                ຈັດການການຂາຍພາຍໃນຮ້ານສຳລັບຊໍ່ດອກໄມ້, ດອກໄມ້, ບັດຂອງຂວັນ ແລະ ອື່ນໆ."

#. module: florist
#: model_terms:ir.ui.view,arch_db:florist.welcome_article_body
msgid ""
"<strong>\n"
"                    <font style=\"color: rgb(113, 75, 103);\">The Sales app </font>\n"
"                    <font class=\"text-o-color-5\"><span style=\"font-weight: normal;\">makes it simple to handle customer orders, including big floral arrangements for weddings, corporate events, and other special occasions.</span></font>\n"
"                </strong>"
msgstr ""
"<strong>\n"
"                    <font style=\"color: rgb(113, 75, 103);\">ແອັບການຂາຍ </"
"font>\n"
"                    <font class=\"text-o-color-5\"><span style=\"font-"
"weight: normal;\">ຊ່ວຍໃຫ້ການຈັດການຄຳສັ່ງຊື້ຂອງລູກຄ້າເປັນເລື່ອງງ່າຍ, ລວມທັງການຈັດດອກໄມ້ຂະໜາດໃຫ"
"ຍ່ສຳລັບງານແຕ່ງດອງ, ງານລ້ຽງບໍລິສັດ ແລະ ໂອກາດພິເສດອື່ນໆ.</span></font>\n"
"                </strong>"

#. module: florist
#: model_terms:ir.ui.view,arch_db:florist.welcome_article_body
msgid ""
"<strong><font style=\"color: rgb(113, 75, 103);\">The CRM "
"app</font></strong><font class=\"text-o-color-5\"> helps you manage customer"
" relationships, event requests, and flower inquiries easily.</font><br/>"
msgstr ""
"<strong><font style=\"color: rgb(113, 75, 103);\">ແອັບ CRM</font></strong>"
"<font class=\"text-o-color-5\"> ຊ່ວຍໃຫ້ທ່ານຈັດການຄວາມສຳພັນກັບລູກຄ້າ, ການຮ້ອງຂໍຈັດງານ ແລ"
"ະ ການສອບຖາມກ່ຽວກັບດອກໄມ້ໄດ້ຢ່າງງ່າຍດາຍ.</font><br/>"

#. module: florist
#: model_terms:ir.ui.view,arch_db:florist.welcome_article_body
msgid ""
"<strong><font style=\"color: rgb(113, 75, 103);\">The Purchase "
"app</font></strong> manages vendor and ensures your shop is stocked with the"
" freshest flowers."
msgstr ""
"<strong><font style=\"color: rgb(113, 75, 103);\">ແອັບການຈັດຊື້ </font></strong> "
"ຈັດການຜູ້ສະໜອງ ແລະ ຮັບປະກັນວ່າຮ້ານຂອງທ່ານມີດອກໄມ້ທີ່ສົດໃໝ່ສະເໝີ."

#. module: florist
#: model_terms:ir.ui.view,arch_db:florist.welcome_article_body
msgid ""
"<strong><font style=\"color: rgb(113, 75, 103);\">The Website app "
"</font></strong>allows customers to showcase your flowers vision and "
"services online."
msgstr ""
"<strong><font style=\"color: rgb(113, 75, 103);\">ແອັບເວັບໄຊ </font></strong> ຊ່"
"ວຍໃຫ້ທ່ານສະແດງພາບລັກດອກໄມ້ ແລະ ບໍລິການຂອງທ່ານໃຫ້ລູກຄ້າເຫັນຜ່ານທາງອອນລາຍ."

#. module: florist
#: model_terms:ir.ui.view,arch_db:florist.contactus
msgid ""
"<strong><strong><i class=\"fa fa-phone fa-"
"fw\"/></strong></strong>&amp;nbsp;+44 1223 123456"
msgstr ""
"<strong><strong><i class=\"fa fa-phone fa-fw\"/></strong></strong>"
"&amp;nbsp;+44 1223 123456"

#. module: florist
#: model_terms:ir.ui.view,arch_db:florist.welcome_article_body
msgid ""
"<strong>Activate payment methods: </strong>Activate payment options such as "
"Cash, Card, Mobile Payments, and Gift Cards directly in your POS settings."
msgstr ""
"<strong>ເປີດນຳໃຊ້ວິທີການຊຳລະເງິນ: </strong>ເປີດໃຊ້ຕົວເລືອກການຊຳລະເງິນ ເຊັ່ນ: ເງິນສົດ, ບັດ, ກ"
"ານຊຳລະຜ່ານມືຖື ແລະ ບັດຂອງຂວັນ ໂດຍກົງໃນການຕັ້ງຄ່າ POS ຂອງທ່ານ."

#. module: florist
#: model_terms:ir.ui.view,arch_db:florist.welcome_article_body
msgid "<strong>Basics</strong>"
msgstr "<strong>ພື້ນຖານ</strong>"

#. module: florist
#: model_terms:ir.ui.view,arch_db:florist.welcome_article_body
msgid ""
"<strong>Choose the best deal</strong>: Pick the vendor offering the best "
"deal for the requested materials."
msgstr ""
"<strong>ເລືອກຂໍ້ສະເໜີທີ່ດີທີ່ສຸດ</strong>: ເລືອກຜູ້ສະໜອງທີ່ໃຫ້ຂໍ້ສະເໜີທີ່ດີທີ່ສຸດສຳລັບວັດສະດຸທີ່ຕ້ອງການ."

#. module: florist
#: model_terms:ir.ui.view,arch_db:florist.welcome_article_body
msgid ""
"<strong>Create a Purchase Order</strong>: Order the flowers, plants, and "
"accessories you need for your business."
msgstr ""
"<strong>ສ້າງໃບສັ່ງຊື້</strong>: ສັ່ງຊື້ດອກໄມ້, ຕົ້ນໄມ້ ແລະ ອຸປະກອນເສີມທີ່ທ່ານຕ້ອງການສຳລັບທຸລະກິດຂອງ"
"ທ່ານ."

#. module: florist
#: model_terms:ir.ui.view,arch_db:florist.welcome_article_body
msgid ""
"<strong>Create tailored sales quotations: </strong>Generate a customized "
"Sales Quotation for weddings, birthdays, or corporate floral events, "
"directly on the sales app."
msgstr ""
"<strong>ສ້າງໃບສະເໜີລາຄາສະເພາະ: </strong>ສ້າງໃບສະເໜີລາຄາການຂາຍທີ່ປັບແຕ່ງຕາມຄວາມຕ້ອງການສ"
"ຳລັບງານແຕ່ງດອງ, ງານວັນເກີດ ຫຼື ງານດອກໄມ້ຂອງບໍລິສັດ ໂດຍກົງໃນແອັບການຂາຍ."

#. module: florist
#: model_terms:ir.ui.view,arch_db:florist.welcome_article_body
msgid ""
"<strong>Extend your offerings: </strong>Configure Gift Cards to offer "
"flexible floral gifts and provide more options for your clients."
msgstr ""
"<strong>ເພີ່ມການບໍລິການຂອງທ່ານ: </strong>ຕັ້ງຄ່າບັດຂອງຂວັນເພື່ອສະເໜີຂອງຂວັນດອກໄມ້ທີ່ຫຼາກຫຼາຍ ແລ"
"ະ ເພີ່ມທາງເລືອກໃຫ້ກັບລູກຄ້າຂອງທ່ານ."

#. module: florist
