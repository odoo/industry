#. module: florist
#: model_terms:ir.ui.view,arch_db:florist.welcome_article_body
msgid ""
"<strong>\n"
"                    <font style=\"color: rgb(113, 75, 103);\">The Point of Sale app </font><font class=\"text-o-color-5\"><span style=\"font-weight: normal;\">h</span></font>\n"
"                </strong>\n"
"                andles in-store sales of bouquets, flowers, gift cards, and more."
msgstr ""
"<strong>\n"
"                    <font style=\"color: rgb(113, 75, 103);\">ແອັບ ຈຸດຂາຍ "
"(POS) </font><font class=\"text-o-color-5\"><span style=\"font-weight: "
"normal;\">ຈັ</span></font>\n"
"                </strong>\n"
"                ດການການຂາຍພາຍໃນຮ້ານ ທັງຊໍ່ດອກໄມ້, ດອກໄມ້, ບັດຂອງຂວັນ ແລະ ອື່ນໆ."

#. module: florist
#: model_terms:ir.ui.view,arch_db:florist.welcome_article_body
msgid ""
"<strong>\n"
"                    <font style=\"color: rgb(113, 75, 103);\">The Sales app </font>\n"
"                    <font class=\"text-o-color-5\"><span style=\"font-weight: normal;\">makes it simple to handle customer orders, including big floral arrangements for weddings, corporate events, and other special occasions.</span></font>\n"
"                </strong>"
msgstr ""
"<strong>\n"
"                    <font style=\"color: rgb(113, 75, 103);\">ແອັບ ການຂາຍ </"
"font>\n"
"                    <font class=\"text-o-color-5\"><span style=\"font-"
"weight: normal;\">ຊ່ວຍໃຫ້ການຈັດການຄຳສັ່ງຊື້ຂອງລູກຄ້າເປັນເລື່ອງງ່າຍ, ລວມທັງການຈັດດອກໄມ້ຂະໜາດໃຫ"
"ຍ່ສຳລັບງານແຕ່ງງານ, ງານລ້ຽງບໍລິສັດ ແລະ ໂອກາດພິເສດອື່ນໆ.</span></font>\n"
"                </strong>"

#. module: florist
#: model_terms:ir.ui.view,arch_db:florist.welcome_article_body
msgid ""
"<strong><font style=\"color: rgb(113, 75, 103);\">The CRM "
"app</font></strong><font class=\"text-o-color-5\"> helps you manage customer"
" relationships, event requests, and flower inquiries easily.</font><br/>"
msgstr ""
"<strong><font style=\"color: rgb(113, 75, 103);\">ແອັບ CRM</font></strong>"
"<font class=\"text-o-color-5\"> ຊ່ວຍໃຫ້ທ່ານຈັດການຄວາມສຳພັນກັບລູກຄ້າ, ການຮ້ອງຂໍຈັດງານ ແລ"
"ະ ການສອບຖາມກ່ຽວກັບດອກໄມ້ໄດ້ຢ່າງງ່າຍດາຍ.</font><br/>"

#. module: florist
#: model_terms:ir.ui.view,arch_db:florist.welcome_article_body
msgid ""
"<strong><font style=\"color: rgb(113, 75, 103);\">The Purchase "
"app</font></strong> manages vendor and ensures your shop is stocked with the"
" freshest flowers."
msgstr ""
"<strong><font style=\"color: rgb(113, 75, 103);\">ແອັບ ການຈັດຊື້</font></strong> "
"ຈັດການຜູ້ສະໜອງ ແລະ ຮັບປະກັນວ່າຮ້ານຂອງທ່ານມີດອກໄມ້ທີ່ສົດໃໝ່ຢູ່ສະເໝີ."

#. module: florist
#: model_terms:ir.ui.view,arch_db:florist.welcome_article_body
msgid ""
"<strong><font style=\"color: rgb(113, 75, 103);\">The Website app "
"</font></strong>allows customers to showcase your flowers vision and "
"services online."
msgstr ""
"<strong><font style=\"color: rgb(113, 75, 103);\">ແອັບ ເວັບໄຊ </font></strong>ຊ່"
"ວຍໃຫ້ທ່ານສາມາດສະແດງຮູບແບບການຈັດດອກໄມ້ ແລະ ການບໍລິການຂອງທ່ານຜ່ານທາງອອນລາຍ."

#. module: florist
#: model_terms:ir.ui.view,arch_db:florist.contactus
msgid ""
"<strong><strong><i class=\"fa fa-phone fa-"
"fw\"/></strong></strong>&amp;nbsp;+44 1223 123456"
msgstr ""
"<strong><strong><i class=\"fa fa-phone fa-fw\"/></strong></strong>"
"&amp;nbsp;+44 1223 123456"

#. module: florist
#: model_terms:ir.ui.view,arch_db:florist.welcome_article_body
msgid ""
"<strong>Activate payment methods: </strong>Activate payment options such as "
"Cash, Card, Mobile Payments, and Gift Cards directly in your POS settings."
msgstr ""
"<strong>ເປີດໃຊ້ວິທີການຊຳລະເງິນ: </strong>ເປີດໃຊ້ທາງເລືອກການຊຳລະເງິນ ເຊັ່ນ: ເງິນສົດ, ບັດ, ກາ"
"ນຊຳລະຜ່ານມືຖື ແລະ ບັດຂອງຂວັນ ໂດຍກົງໃນການຕັ້ງຄ່າ POS ຂອງທ່ານ."

#. module: florist
#: model_terms:ir.ui.view,arch_db:florist.welcome_article_body
msgid "<strong>Basics</strong>"
msgstr "<strong>ພື້ນຖານ</strong>"

#. module: florist
#: model_terms:ir.ui.view,arch_db:florist.welcome_article_body
msgid ""
"<strong>Choose the best deal</strong>: Pick the vendor offering the best "
"deal for the requested materials."
msgstr ""
"<strong>ເລືອກຂໍ້ສະເໜີທີ່ດີທີ່ສຸດ</strong>: ເລືອກຜູ້ສະໜອງທີ່ໃຫ້ຂໍ້ສະເໜີທີ່ດີທີ່ສຸດສຳລັບວັດສະດຸທີ່ຕ້ອງການ."

#. module: florist
#: model_terms:ir.ui.view,arch_db:florist.welcome_article_body
msgid ""
"<strong>Create a Purchase Order</strong>: Order the flowers, plants, and "
"accessories you need for your business."
msgstr ""
"<strong>ສ້າງໃບສັ່ງຊື້</strong>: ສັ່ງຊື້ດອກໄມ້, ຕົ້ນໄມ້ ແລະ ອຸປະກອນເສີມທີ່ທ່ານຕ້ອງການສຳລັບທຸລະກິດຂອງ"
"ທ່ານ."

#. module: florist
#: model_terms:ir.ui.view,arch_db:florist.welcome_article_body
msgid ""
"<strong>Create tailored sales quotations: </strong>Generate a customized "
"Sales Quotation for weddings, birthdays, or corporate floral events, "
"directly on the sales app."
msgstr ""
"<strong>ສ້າງໃບສະເໜີລາຄາສະເພາະ: </strong>ສ້າງໃບສະເໜີລາຄາການຂາຍທີ່ປັບແຕ່ງຕາມຄວາມຕ້ອງການສ"
"ຳລັບງານແຕ່ງງານ, ວັນເກີດ ຫຼື ງານລ້ຽງບໍລິສັດ ໄດ້ໂດຍກົງໃນແອັບການຂາຍ."

#. module: florist
#: model_terms:ir.ui.view,arch_db:florist.welcome_article_body
msgid ""
"<strong>Extend your offerings: </strong>Configure Gift Cards to offer "
"flexible floral gifts and provide more options for your clients."
msgstr ""
"<strong>ເພີ່ມຂໍ້ສະເໜີຂອງທ່ານ: </strong>ຕັ້ງຄ່າບັດຂອງຂວັນເພື່ອມອບເປັນຂອງຂວັນດອກໄມ້ ແລະ ເພີ່ມທາງເ"
"ລືອກໃຫ້ກັບລູກຄ້າຂອງທ່ານ."

#. module: florist
#: model_terms:ir.ui.view,arch_db:florist.welcome_article_body
msgid ""
"<strong>Manage customer requests</strong>: Track customer inquiries coming from your Website (such as wedding floral requests or custom bouquet orders), manage engagement, follow up easily, and convert them into confirmed sales\n"
"            opportunities."
msgstr ""
"<strong>ຈັດການການຮ້ອງຂໍຂອງລູກຄ້າ</strong>: ຕິດຕາມການສອບຖາມຂອງລູກຄ້າທີ່ມາຈາກເວັບໄຊຂອງທ່ານ "
"(ເຊັ່ນ: ການຮ້ອງຂໍຈັດດອກໄມ້ງານແຕ່ງງານ ຫຼື ການສັ່ງຊໍ່ດອກໄມ້ແບບພິເສດ), ຈັດການການມີສ່ວນຮ່ວມ, ຕິດຕາມໄດ້"
"ງ່າຍ ແລະ ປ່ຽນໃຫ້ເປັນໂອກາດການຂາຍທີ່ຢືນຢັນແລ້ວ."

#. module: florist
#: model_terms:ir.ui.view,arch_db:florist.welcome_article_body
msgid ""
"<strong>Organize event projects: </strong>Create a project to manage and "
"organize specific events, assign tasks, set deadlines, and track progress."
msgstr ""
"<strong>ຈັດການໂຄງການຈັດງານ: </strong>ສ້າງໂຄງການເພື່ອຈັດການ ແລະ ວາງແຜນງານຕ່າງໆ, ມອບໝາ"
"ຍວຽກ, ກຳນົດກຳນົດເວລາ ແລະ ຕິດຕາມຄວາມຄືບໜ້າ."

#. module: florist
#: model_terms:ir.ui.view,arch_db:florist.welcome_article_body
msgid ""
"<strong>Set up product offering: </strong>Create and configure your flower products and add variants if you have different size or color for the same product. You can also add an extra charges for specific options (e.g., +£2 for a\n"
"            red tulip, +£10 for a medium bouquet)."
msgstr ""
"<strong>ຕັ້ງຄ່າສິນຄ້າ: </strong>ສ້າງ ແລະ ຕັ້ງຄ່າຜະລິດຕະພັນດອກໄມ້ຂອງທ່ານ ແລະ ເພີ່ມລຸ້ນຍ່ອຍຫາກທ່ານ"
"ມີຂະໜາດ ຫຼື ສີທີ່ແຕກຕ່າງກັນ. ທ່ານຍັງສາມາດເພີ່ມຄ່າບໍລິການເພີ່ມເຕີມສຳລັບທາງເລືອກສະເພາະ (ເຊັ່ນ: +2 ກີບ "
"ສຳລັບດອກທິວລິບສີແດງ, +10 ກີບ ສຳລັບຊໍ່ດອກໄມ້ຂະໜາດກາງ)."

#. module: florist
#: model_terms:ir.ui.view,arch_db:florist.welcome_article_body
msgid ""
"<strong>Showcase your floral vision and offer: </strong>Configure your "
"website to highlight your floral style, present your services and get new "
"opportunities through a contact form."
msgstr ""
"<strong>ສະແດງຮູບແບບ ແລະ ຂໍ້ສະເໜີຂອງທ່ານ: </strong>ຕັ້ງຄ່າເວັບໄຊຂອງທ່ານເພື່ອເນັ້ນຮູບແບບການຈັດດ"
"ອກໄມ້, ນຳສະເໜີການບໍລິການ ແລະ ຮັບໂອກາດໃໝ່ໆຜ່ານແບບຟອມຕິດຕໍ່."

#. module: florist
#: model_terms:ir.ui.view,arch_db:florist.welcome_article_body
msgid ""
"<strong>Take orders in Point of Sale</strong>: Open a register and process "
"in-store purchases such as bouquets, flowers, cards, and more."
msgstr ""
"<strong>ຮັບຄຳສັ່ງຊື້ໃນຈຸດຂາຍ (POS)</strong>: ເປີດເຄື່ອງບັນທຶກການຂາຍ ແລະ ດຳເນີນການຂາຍພາຍໃນ"
"ຮ້ານ ເຊັ່ນ: ຊໍ່ດອກໄມ້, ດອກໄມ້, ບັດ ແລະ ອື່ນໆ."

#. module: florist
#: model_terms:ir.ui.view,arch_db:florist.welcome_article_body
msgid "<strong>Use Case</strong>"
msgstr "<strong>ກໍລະນີການນຳໃຊ້</strong>"

#. module: florist
#: model_terms:ir.ui.view,arch_db:florist.welcome_article_body
