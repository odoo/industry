#. module: coworking
#: model_terms:ir.ui.view,arch_db:coworking.welcome_article_body
msgid ""
"<strong><font class=\"text-o-color-1\">Appointment</font></strong>: Allow "
"prospects to book a free tour, shared desk, or meeting room online."
msgstr ""
"<strong><font class=\"text-o-color-1\">Compromissos</font></strong>: Permita "
"que os clientes em potencial reservem online uma visita gratuita, uma mesa "
"compartilhada ou uma sala de reuniões."

#. module: coworking
#: model_terms:ir.ui.view,arch_db:coworking.welcome_article_body
