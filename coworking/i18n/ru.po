#: model_terms:ir.ui.view,arch_db:coworking.welcome_article_body
msgid "Use <strong>Auto-Plan</strong> to assign shifts based on availability."
msgstr ""
"Используйте <strong>Автопланирование</strong> для назначения смен на основе "
"доступности сотрудников."

#. module: coworking
#: model_terms:ir.ui.view,arch_db:coworking.welcome_article_body
msgid ""
"Use <strong>Rental</strong> to support a \"Private office\" offer in your "
"coworking."
msgstr ""
"Используйте модуль <strong>Аренда</strong> для поддержки предложения «Личный "
"офис» в вашем коворкинге."

