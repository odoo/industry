msgstr ""
"Отслеживайте и планируйте ремонт оборудования, например, принтеров или "
"кофемашин, с помощью <strong>модуля Обслуживание</strong>."

#. module: coworking
#: model:crm.tag,name:coworking.crm_tag_1
#: model:product.template,name:coworking.product_product_13_product_template
msgid "Unlimited Pass"
msgstr "Безлимитный абонемент"

