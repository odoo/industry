#: model_terms:ir.ui.view,arch_db:coworking.ir_ui_view_4092
msgid "brown leather couch near brown wooden table"
msgstr "啡色皮質沙發，旁邊有啡色木桌"

#. module: coworking
#: model_terms:ir.ui.view,arch_db:coworking.ir_ui_view_3304
#: model_terms:ir.ui.view,arch_db:coworking.ir_ui_view_4092
msgid "brown wooden table with yellow steel frame"
msgstr "啡色木桌配黃色鋼架"

