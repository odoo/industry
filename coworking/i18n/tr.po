#. module: coworking
#: model_terms:event.event,description:coworking.event_event_2
msgid ""
"☕ <strong>Quality Coffee &amp; Tea</strong> – Fuel for a productive day "
"ahead."
msgstr ""
"☕ <strong>Kaliteli Kahve &amp; Çay</strong> - Önünüzdeki verimli bir gün "
"için yakıt."

#. module: coworking
#: model_terms:event.event,description:coworking.event_event_3
msgid ""
"✍ <strong>Hands-On Exercises</strong> – Apply new methods immediately to "
"your work."
msgstr ""
"✍ <strong>Uygulamalı Alıştırmalar</strong> - Yeni yöntemleri hemen işinize "
"uygulayın."

#. module: coworking
#: model_terms:event.event,description:coworking.event_event_1
msgid ""
"🍹 <strong>Drinks &amp; Snacks</strong> – A curated selection to keep the "
"conversation flowing."
msgstr ""
"🍹 <strong>İçecekler &amp; Atıştırmalıklar</strong> - Sohbetin akışını "
"sağlamak için seçilmiş bir seçki."

#. module: coworking
#: model_terms:event.event,description:coworking.event_event_2
msgid ""
"👋 <strong>Morning Networking</strong> – Meet fellow members before diving "
"into work."
msgstr ""
"👋 <strong>Sabah Networking</strong> - İşe dalmadan önce diğer üyelerle "
"tanışın."

#. module: coworking
#: model_terms:event.event,description:coworking.event_event_1
msgid ""
"💡 <strong>Inspiration</strong> – Exchange ideas in a relaxed, social "
"setting."
msgstr ""
"💡 <strong>İlham</strong> - Rahat ve sosyal bir ortamda fikir alışverişinde "
"bulunun."

#. module: coworking
#: model_terms:event.event,description:coworking.event_event_3
msgid ""
"🤝 <strong>Collaborative Atmosphere</strong> – Connect with others who value "
"creativity and growth."
msgstr ""
"🤝 <strong>İşbirlikçi Atmosfer</strong> - Yaratıcılığa ve büyümeye değer "
"veren diğer kişilerle bağlantı kurun."

#. module: coworking
#: model_terms:event.event,description:coworking.event_event_1
msgid ""
"🤝 <strong>Networking</strong> – Meet entrepreneurs, freelancers, and "
"creatives."
msgstr ""
"🤝 <strong>Networking</strong> - Girişimciler, serbest çalışanlar ve "
"yaratıcılarla tanışın."

#. module: coworking
#: model_terms:event.event,description:coworking.event_event_2
msgid ""
"🥯 <strong>Fresh Bagels</strong> – With a variety of toppings to suit every "
"taste."
msgstr "🥯 <strong>Taze Simitler</strong> - Her zevke uygun çeşitli soslarla."

#. module: coworking
#: model_terms:event.event,description:coworking.event_event_3
msgid ""
"🧠 <strong>Proven Strategies</strong> – Learn practical tools to stay "
"productive and inspired."
msgstr ""
"🧠 <strong>Kanıtlanmış Stratejiler</strong> - Üretken ve ilham verici kalmak "
"için pratik araçlar öğrenin."

