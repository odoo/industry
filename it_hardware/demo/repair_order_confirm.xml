<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <function name="write" model="stock.move">
        <value model="stock.move" eval="obj().search([
            ('product_id', '=', ref('product_product_10')),
            ('repair_id', '=', ref('repair_order_1'))
        ]).id"/>
        <value model="stock.lot" eval="{'lot_ids': obj().env.ref('it_hardware.stock_lot_11')}"/>
    </function> 
    <function model="repair.order" name="action_validate">
        <value eval="[ref('it_hardware.repair_order_1')]"/>
    </function>
    <record model="stock.warn.insufficient.qty.repair" id="open_repair_wizard">
