<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <data noupdate="1">
        <record id="stock_location_7" model="stock.location">
            <field name="name">WH</field>
            <field name="usage">view</field>
            <field name="company_id" ref="base.main_company"/>
            <field name="warehouse_view_ids" eval="[(6, 0, [ref('stock.warehouse0')])]"/>
            <field name="location_id" ref="stock.stock_location_locations"/>
            <field name="warehouse_id" ref="stock.warehouse0"/>
        </record>
        <record id="stock.stock_location_stock" model="stock.location">
            <field name="location_id" ref="stock_location_7"/>
        </record>
        <record id="stock_location_17" model="stock.location">
            <field name="name">Repair</field>
            <field name="complete_name">WH/Repair</field>
            <field name="company_id" ref="base.main_company"/>
            <field name="last_inventory_date" eval="DateTime.today() - relativedelta(months=5)"/>
            <field name="return_location" eval="True"/>
            <field name="location_id" ref="stock_location_7"/>
            <field name="warehouse_id" ref="stock.warehouse0"/>
        </record>
    </data>
</odoo>
