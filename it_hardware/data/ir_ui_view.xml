<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="it_hardware.odoo_studio_crm_lead_f53a9596-735e-4ca5-82a9-a9e3dfc1212d" model="ir.ui.view">
        <field name="name">Odoo Studio: crm.lead.form customization</field>
        <field name="model">crm.lead</field>
        <field name="type">form</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form" />
        <field name="mode">extension</field>
        <field name="priority">160</field>
        <field name="arch" type="xml">
            <xpath expr="//form[1]/sheet[1]/group[1]/group[not(@name)][1]/field[@name='tag_ids']" position="after">
                <field name="x_studio_product" string="Product" options="{&quot;no_create&quot;:true,&quot;no_opening&quot;:true}" />
                <field name="x_studio_no_of_quantity" string="No Of Quantity" />
            </xpath>
        </field>
    </record> 
    <record id="it_hardware.odoo_studio_helpdesk_9e573606-d6bf-4434-af27-f232fe489d2a" model="ir.ui.view">
        <field name="name">Odoo Studio: helpdesk.ticket.form customization</field>
        <field name="model">helpdesk.ticket</field>
        <field name="type">form</field>
        <field name="inherit_id" ref="helpdesk_stock.helpdesk_ticket_view_form_inherit_helpdesk_stock"/>
        <field name="mode">extension</field>
        <field name="priority">800</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='email_cc']" position="after">
                <field name="product_id" invisible="1"/>
                <field name="lot_id" invisible="1"/>
                <field name="x_studio_warranty_date" string="Warranty Date" invisible="lot_id == False" readonly="1"/>
            </xpath>
        </field>
    </record>
    <record id="it_hardware.odoo_studio_product__9f35526f-5aa6-4bad-a44e-d680ff93e045" model="ir.ui.view">
        <field name="name">Odoo Studio: product.template.product.form customization</field>
        <field name="model">product.template</field>
        <field name="type">form</field>
        <field name="inherit_id" ref="product.product_template_only_form_view" />
        <field name="mode">extension</field>
        <field name="priority">160</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='default_code']" position="attributes">
                <attribute name="string">Part Code</attribute>
            </xpath>
            <xpath expr="//form[@name='Product Template']/sheet[@name='product_form']/notebook[1]/page[@name='inventory']/group[@name='inventory']/group[@name='expiry_and_lots']/div[4]" position="after">
                <label for="x_studio_warranty_date" />
                <div>
                    <field name="x_studio_warranty_date" class="oe_inline" string="Warranty Date" />
                    <span> days after delivery</span>
                </div>
            </xpath>
        </field>
    </record>
    <record id="it_hardware.odoo_studio_repair_f_301f3e90-2bf5-424c-b3c5-46a6cb9c8f46" model="ir.ui.view">
        <field name="name">Odoo Studio: repair.form customization</field>
        <field name="model">repair.order</field>
        <field name="type">form</field>
        <field name="inherit_id" ref="repair.view_repair_order_form" />
        <field name="mode">extension</field>
        <field name="priority">160</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='picking_id']" position="attributes">
                <attribute name="domain">[("picking_type_id", "in", [8])]</attribute>
                <attribute name="string">Repair Return</attribute>
            </xpath>
        </field>
    </record>
    <record id="it_hardware.odoo_studio_stock_pr_86553829-1db0-4c73-8dcb-23cc06066a9a" model="ir.ui.view">
        <field name="name">Odoo Studio: stock.production.lot.form customization</field>
        <field name="model">stock.lot</field>
        <field name="type">form</field>
        <field name="inherit_id" ref="stock.view_production_lot_form" />
        <field name="mode">extension</field>
        <field name="priority">160</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='removal_date']" position="after">
                <field name="x_studio_warranty_date" string="Warranty Date" />
            </xpath>
        </field>
    </record>
</odoo>
