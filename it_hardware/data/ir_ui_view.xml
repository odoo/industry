<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="crm_lead_form_customization_it_hardware" model="ir.ui.view">
        <field name="name">crm.lead.form.customization.it.hardware</field>
        <field name="model">crm.lead</field>
        <field name="type">form</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="mode">extension</field>
        <field name="priority">160</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='tag_ids']" position="after">
                <field name="x_product" options="{'no_create':true,'no_opening':true}"/>
                <field name="x_no_of_quantity"/>
            </xpath>
        </field>
    </record> 
    <record id="helpdesk_ticket_form_customization_it_hardware" model="ir.ui.view">
        <field name="name">helpdesk.ticket.form.customization.it.hardware</field>
        <field name="model">helpdesk.ticket</field>
        <field name="type">form</field>
        <field name="inherit_id" ref="helpdesk_stock.helpdesk_ticket_view_form_inherit_helpdesk_stock"/>
        <field name="mode">extension</field>
        <field name="priority">800</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='email_cc']" position="after">
                <field name="product_id"/>
                <field name="lot_id"/>
                <field name="x_warranty_date" invisible="lot_id == False" readonly="1"/>
            </xpath>
        </field>
    </record>
    <record id="product_template_form_customization_it_hardware" model="ir.ui.view">
        <field name="name">product.template.product.form.customization.it.hardware</field>
        <field name="model">product.template</field>
        <field name="type">form</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="mode">extension</field>
        <field name="priority">160</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='default_code']" position="attributes">
                <attribute name="string">Part Code</attribute>
            </xpath>
            <xpath expr="//div[field[@name='alert_time']]" position="after">
                <label for="x_warranty_date"/>
                <div>
                    <field name="x_warranty_date" class="oe_inline"/>
                    <span> days after delivery</span>
                </div>
            </xpath>
        </field>
    </record>
    <record id="repair_form_customization_it_hardware" model="ir.ui.view">
        <field name="name">repair.form.customization.it.hardware</field>
        <field name="model">repair.order</field>
        <field name="type">form</field>
        <field name="inherit_id" ref="repair.view_repair_order_form"/>
        <field name="mode">extension</field>
        <field name="priority">160</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='picking_id']" position="attributes">
                <attribute name="domain">[("picking_type_id", "in", [8])]</attribute>
                <attribute name="string">Repair Return</attribute>
            </xpath>
            <xpath expr="//field[@name='tag_ids']" position="after">
                <field name="ticket_id" readonly="1" invisible="ticket_id == False"/>
            </xpath>
        </field>
    </record>
    <record id="stock_pr_lot_form_customization_it_hardware" model="ir.ui.view">
        <field name="name">stock.production.lot.form.customization.it.hardware</field>
        <field name="model">stock.lot</field>
        <field name="type">form</field>
        <field name="inherit_id" ref="stock.view_production_lot_form"/>
        <field name="mode">extension</field>
        <field name="priority">160</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='removal_date']" position="after">
                <field name="x_warranty_date"/>
            </xpath>
        </field>
    </record>
</odoo>
