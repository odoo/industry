<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="res_config_settings_form_view_inherited" model="ir.ui.view">
        <field name="name">res.config.settings.form.view.inherited.hotel</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="40"/>
        <field name="active" eval="True"/>
        <field name="inherit_id" ref="booking_engine.res_config_settings_form_view_inherited" />
        <field name="arch" type="xml">
            <xpath expr="//app[@name='accomodation']" position="attributes">
                <attribute name="string">Hotel</attribute>
                <attribute name="logo">/hotel/static/description/icon.png</attribute>
            </xpath>
        </field>
    </record>
    <data noupdate="1">
        <record model="res.config.settings" id="res_config_settings_enable">
            <field name="x_module_house_keeping" eval="1"/>
            <field name="x_setting_steering" eval="1"/>
            <field name="x_setting_automated_assignment" eval="1"/>
        </record>
        <function model="res.config.settings" name="execute" eval="[ref('res_config_settings_enable')]"/>
    </data>
</odoo>
