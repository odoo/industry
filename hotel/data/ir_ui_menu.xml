<?xml version='1.0' encoding='UTF-8'?>
<odoo auto_sequence="1">
  <record id="booking_engine.booking_engine_menu_root" model="ir.ui.menu" forcecreate="1">
    <field name="web_icon_data" type="base64" file="hotel/static/description/icon_no_border.png"/>
    <field name="name">Hotel</field>
  </record>
  <record id="hotel_offers_search_view" model="ir.ui.view">
    <field name="arch" type="xml">
      <data>
        <xpath expr="//filter[@name='pos_categ_ids']" position="replace">
          <filter name="Role" string="Planning Role" context="{'group_by': 'planning_role_id'}"/>
        </xpath>
        <xpath expr="//filter[@name='filter_to_availabe_pos']" position="replace"/>
        <xpath expr="//filter[@name='is_storable']" position="replace"/>
        <xpath expr="//search[1]/field[@name='name']" position="after">
          <field name="planning_role_id"/>
        </xpath>
      </data>
    </field>
    <field name="inherit_id" ref="booking_engine.booking_engine_offers_search"/>
    <field name="mode">extension</field>
    <field name="model">product.template</field>
    <field name="name">product.template.search.inherit.hotel</field>
    <field name="priority">99</field>
    <field name="type">search</field>
    <field name="active" eval="True"/>
  </record>
</odoo>
