<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!-- Create the demo website with a lower sequence than the one created by Odoo -->
    <record id="website_industry" model="website">
        <field name="name">Hotel</field>
        <field name="sequence">1</field>
        <field name="configurator_done" eval="True"/>
        <field name="user_id" ref="base.public_user"/>
        <field name="salesperson_id" ref="base.user_admin"/>
        <field name="show_line_subtotals_tax_selection">tax_included</field>
        <field name="cart_recovery_mail_template_id" eval="False"/>
        <field name="logo" type="bytes" file="hotel/static/src/img/content/website/logo.webp"/>
        <field name="favicon" type="bytes" file="hotel/static/src/img/content/website/favicon.png"/>
    </record>

    <function name="write" model="ir.model.data">
        <value model="ir.model.data" search="[
            ('name', '=', 'default_website'),
            ('module', '=', 'website'),
            ('model', '=', 'website'),
        ]"/>
        <value eval="{'res_id': ref('website_industry')}"/>
    </function>
</odoo>
