<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_page_contactus" model="ir.ui.view">
        <field name="name">Contact Us</field>
        <field name="key">hotel.page_contactus</field>
        <field name="type">qweb</field>
        <field name="website_id" ref="website_industry"/>
        <field name="arch" type="xml">
            <t name="Contact Us" t-name="hotel.page_contactus">
                <t t-call="website.layout">
                    <t t-set="logged_partner" t-value="request.env['website.visitor']._get_visitor_from_request().partner_id"/>
                    <t t-set="contactus_form_values" t-value="{ 'email_to': res_company.email, 'name': request.params.get('name', ''), 'phone': request.params.get('phone', ''), 'email_from': request.params.get('email_from', ''), 'company': request.params.get('company', ''), 'subject': request.params.get('subject', ''), }"/>
                    <t t-set="contactus_form_values" t-value="dict(contactus_form_values, **{ 'contact_name': request.params.get('contact_name', ''), 'partner_name': request.params.get('partner_name', ''), 'description': request.params.get('description', ''), })"/>
                    <span class="hidden" data-for="contactus_form" t-att-data-values="contactus_form_values"/>
                    <div id="wrap" class="oe_structure oe_empty">
                        <section class="s_title bg-black-50 o_colored_level s_parallax_no_overflow_hidden oe_img_bg o_bg_img_center o_bg_img_origin_border_box pt144" data-vcss="001" data-snippet="s_title" data-scroll-background-ratio="0" style="background-image: url(&quot;/hotel/static/src/img/content/website/hotel-image-02.webp&quot;);" data-format-mimetype="image/webp" data-original-src="/hotel/static/src/img/content/website/hotel-image-02.webp" data-resize-width="1344" data-mimetype="image/webp">
                            <div class="o_we_bg_filter" style="background-image: linear-gradient(135deg, rgba(0, 0, 0, 0.81) 0%, rgba(0, 0, 0, 0.29) 100%);"/>
                            <div class="container">
                                <h1 class="display-1-fs" style="text-align: center;">Contact us</h1>
                                <div class="s_hr pt32 pb32" data-snippet="s_hr" data-name="Separator">
                                    <hr class="w-100 mx-auto" style="border-top-width: 0px;"/>
                                </div>
                            </div>
                        </section>
                        <section class="s_title o_colored_level" data-vcss="001" data-snippet="s_title" data-name="Title">
                            <div class="s_allow_columns container">
                                <div class="s_hr pt32 pb32" data-snippet="s_hr" data-name="Separator">
                                    <hr class="w-100 mx-auto" style="border-top-width: 0px;"/>
                                </div>
                                <h1 style="text-align: center;" class="display-1">
                                    <span class="h2-fs">
                                        <span style="color: rgb(198, 185, 179);">
                                            Norris
                                        </span>
                                    </span>
                                </h1>
                                <p style="text-align: center;">
                                    <span class="h4-fs">
                                        <span class="text-o-color-1">
                                            Feel free to contact us if you have any questions
                                        </span>
                                    </span>
                                </p>
                                <div class="s_hr pt32 pb32 d-lg-none o_snippet_desktop_invisible" data-snippet="s_hr" data-name="Separator" data-invisible="1">
                                    <hr class="w-100 mx-auto" style="border-top-width: 0px;"/>
                                </div>
                            </div>
                        </section>
                        <section class="s_numbers_boxed o_colored_level o_cc o_cc1" data-snippet="s_numbers_boxed" data-name="Numbers boxed">
                            <div class="container">
                                <div class="row o_grid_mode" data-row-count="6" style="row-gap: 20px; column-gap: 40px;">
                                    <div class="o_grid_item g-col-lg-4 border rounded o_colored_level g-height-5 col-lg-4" style="grid-area: 2 / 1 / 7 / 5; --grid-item-padding-y: 72px; text-align: center; z-index: 2; border-radius: 9.6px !important;">
                                        <h2 class="display-3-fs">
                                            <span style="background-image: linear-gradient(135deg, rgb(169, 169, 152) 15%, rgb(96, 70, 59) 100%);" class="text-gradient">
                                                Find us
                                            </span>
                                            <br/>
                                        </h2>
                                        <p>
                                            <span class="o_small-fs"><br/>Route des Glaciers 14</span><br/>1937 Orsières,
                                            <span class="text-o-color-1">
                                                Switzerland
                                            </span>
                                        </p>
                                    </div>
                                    <div class="o_grid_item g-col-lg-4 border rounded o_colored_level g-height-5 col-lg-4" style="grid-area: 2 / 5 / 7 / 9; --grid-item-padding-y: 72px; text-align: center; z-index: 3; border-radius: 9.6px !important;">
                                        <h2 class="display-3-fs">
                                            <span style="background-image: linear-gradient(45deg, rgb(169, 169, 152) 15%, rgb(96, 70, 59) 100%);" class="text-gradient">
                                                Email us
                                            </span>
                                            <br/>
                                        </h2>
                                        <p>
                                            <span style="font-style: normal;" class="o_small-fs">
                                                <br/>You can reach us at
                                                <span class="text-o-color-1">
                                                    info@grandnorrispalace.com
                                                </span>
                                                or by using the contact form below.
                                            </span>
                                        </p>
                                    </div>
                                    <div class="o_grid_item g-col-lg-4 border rounded o_colored_level g-height-5 col-lg-4" style="grid-area: 2 / 9 / 7 / 13; --grid-item-padding-y: 72px; text-align: center; z-index: 4; border-radius: 9.6px !important;">
                                        <h2 class="display-3-fs">
                                            <span style="background-image: linear-gradient(45deg, rgb(169, 169, 152) 15%, rgb(96, 70, 59) 100%);" class="text-gradient">
                                                Call us
                                            </span>
                                            <br/>
                                        </h2>
                                        <p>
                                            <span class="o_small-fs">
                                                <br/>Our reception is open 24/7, and you can reach us<br/>anytime at
                                                <span class="text-o-color-1">
                                                    +41 27 000 00 00
                                                </span>
                                                .
                                            </span>
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </section>
                        <section class="s_form_aside o_colored_level pt40 pb32" data-snippet="s_form_aside" data-name="Form Aside">
                            <div class="container">
                                <div class="row o_grid_mode" data-row-count="13">
                                    <div class="o_colored_level o_grid_item o_cc o_cc1 rounded border g-col-lg-12 g-height-11 col-lg-12" style="z-index: 1; grid-area: 1 / 1 / 12 / 13; --grid-item-padding-y: 40px; --grid-item-padding-x: 40px; --box-border-bottom-left-radius: 10px; --box-border-bottom-right-radius: 10px; --box-border-top-right-radius: 10px; --box-border-top-left-radius: 10px;">
                                        <h2>
                                            <span class="text-gradient" style="background-image: linear-gradient(135deg, rgb(169, 169, 152) 15%, rgb(96, 70, 59) 100%);">
                                                <strong>Contact us</strong>
                                            </span>
                                        </h2>
                                        <p class="lead">Chat with us or fill in this form to get information about anything related to our rooms or the palace.<br/><br/></p>
                                        <section class="s_website_form pt16 pb16" data-vcss="001" data-snippet="s_website_form" data-name="Form">
                                            <div class="container-fluid">
                                                <form action="/website/form/" method="post" enctype="multipart/form-data" class="o_mark_required" data-mark="*" data-pre-fill="true" data-model_name="mail.mail" data-success-mode="redirect" data-success-page="/contactus-thank-you">
                                                    <div class="s_website_form_rows row s_col_no_bgcolor">
                                                        <div data-name="Field" class="s_website_form_field mb-3 col-12 s_website_form_dnone">
                                                            <div class="row s_col_no_resize s_col_no_bgcolor">
                                                                <label class="col-form-label col-sm-auto s_website_form_label" style="width: 200px"><span class="s_website_form_label_content"/><br/></label>
                                                                <div class="col-sm">
                                                                    <input type="hidden" class="form-control s_website_form_input" name="email_to" value="info@yourcompany.example.com"/>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div data-name="Field" class="s_website_form_field mb-3 col-12 s_website_form_custom s_website_form_required col-lg-6" data-type="char">
                                                            <div class="row s_col_no_resize s_col_no_bgcolor">
                                                                <label class="col-form-label col-sm-auto s_website_form_label" style="width: 200px" for="osbmqzgp595"><span class="s_website_form_label_content">Your Name</span> <span class="s_website_form_mark">*</span></label>
                                                                <div class="col-sm">
                                                                    <input class="form-control s_website_form_input" type="text" name="name" required="" placeholder="" id="osbmqzgp595" data-fill-with="name"/>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div data-name="Field" class="s_website_form_field mb-3 col-12 s_website_form_custom col-lg-6" data-type="tel">
                                                            <div class="row s_col_no_resize s_col_no_bgcolor">
                                                                <label class="col-form-label col-sm-auto s_website_form_label" style="width: 200px" for="ondxi31e3oso"><span class="s_website_form_label_content">Phone Number</span></label>
                                                                <div class="col-sm">
                                                                    <input class="form-control s_website_form_input" type="tel" name="phone" value="" placeholder="" id="ondxi31e3oso" data-fill-with="phone"/>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div data-name="Field" class="s_website_form_field mb-3 col-12 s_website_form_model_required col-lg-6" data-type="email">
                                                            <div class="row s_col_no_resize s_col_no_bgcolor">
                                                                <label class="col-form-label col-sm-auto s_website_form_label" style="width: 200px" for="otjy8jzhinga"><span class="s_website_form_label_content">Your Email</span> <span class="s_website_form_mark">*</span></label>
                                                                <div class="col-sm">
                                                                    <input class="form-control s_website_form_input" type="email" name="email_from" required="" value="" placeholder="" id="otjy8jzhinga" data-fill-with="email"/>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div data-name="Field" class="s_website_form_field mb-3 col-12 s_website_form_custom col-lg-6" data-type="char">
                                                            <div class="row s_col_no_resize s_col_no_bgcolor">
                                                                <label class="col-form-label col-sm-auto s_website_form_label" style="width: 200px" for="o44jt808qeot"><span class="s_website_form_label_content">Your Company</span></label>
                                                                <div class="col-sm">
                                                                    <input class="form-control s_website_form_input" type="text" name="company" value="" placeholder="" id="o44jt808qeot" data-fill-with="commercial_company_name"/>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div data-name="Field" class="s_website_form_field mb-3 col-12 s_website_form_model_required" data-type="char">
                                                            <div class="row s_col_no_resize s_col_no_bgcolor">
                                                                <label class="col-form-label col-sm-auto s_website_form_label" style="width: 200px" for="op0y21c8yrx"><span class="s_website_form_label_content">Subject</span> <span class="s_website_form_mark">*</span></label>
                                                                <div class="col-sm">
                                                                    <input class="form-control s_website_form_input" type="text" name="subject" required="" value="" placeholder="" id="op0y21c8yrx" data-fill-with="undefined"/>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div data-name="Field" class="s_website_form_field mb-3 col-12 s_website_form_custom s_website_form_required" data-type="text">
                                                            <div class="row s_col_no_resize s_col_no_bgcolor">
                                                                <label class="col-form-label col-sm-auto s_website_form_label" style="width: 200px" for="og68dua1ike8"><span class="s_website_form_label_content">Your Question</span> <span class="s_website_form_mark">*</span></label>
                                                                <div class="col-sm">
                                                                    <textarea class="form-control s_website_form_input" name="description" required="" placeholder="" id="og68dua1ike8" rows="3" />
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="mb-0 py-2 col-12 s_website_form_submit text-end s_website_form_no_submit_label pb16 pt24" data-name="Submit Button">
                                                            <div style="width: 200px;" class="s_website_form_label">
                                                                <br/>
                                                            </div>
                                                            <span id="s_website_form_result"/><a href="#" role="button" class="btn btn-primary s_website_form_send">Submit</a>
                                                        </div>
                                                    </div>
                                                </form>
                                            </div>
                                        </section>
                                    </div>
                                    <div class="o_grid_item o_colored_level g-col-lg-12 g-height-2 col-lg-12" style="grid-area: 12 / 1 / 14 / 13; z-index: 2; --grid-item-padding-y: 36px;">
                                        <p style="text-align: center;">Our team will be delighted to assist you and will respond to your message within 2 open&amp;nbsp;days</p>
                                    </div>
                                </div>
                            </div>
                        </section>
                        <section class="s_image_punchy o_cc o_cc2 o_colored_level" data-snippet="s_image_punchy" data-name="Punchy Image">
                            <div class="container-fluid">
                                <div class="row o_grid_mode" data-row-count="7">
                                    <div class="o_grid_item o_grid_item_image g-col-lg-12 o_colored_level g-height-7 col-lg-12 o_cc o_cc1" style="grid-area: 1 / 1 / 8 / 13; z-index: 1; --grid-item-padding-y: 0px; --grid-item-padding-x: 0px;">
                                        <img src="/hotel/static/src/img/content/website/hotel-image-01.webp" alt="" class="figure-img img-fluid rounded img o_we_custom_image" data-format-mimetype="image/webp" data-original-src="/hotel/static/src/img/content/website/hotel-image-01.webp" data-mimetype-before-conversion="image/png" data-resize-width="1273" data-mimetype="image/webp" loading="lazy"/>
                                    </div>
                                </div>
                            </div>
                        </section>
                    </div>
                </t>
            </t>
        </field>
    </record>

    <data noupdate="1">
        <record id="page_contactus" model="website.page" forcecreate="0">
            <field name="view_id" ref="view_page_contactus"/>
            <field name="url">/contactus</field>
            <field name="is_published" eval="True"/>
            <field name="website_indexed" eval="True"/>
            <field name="website_id" ref="website_industry"/>
        </record>
    </data>
</odoo>
