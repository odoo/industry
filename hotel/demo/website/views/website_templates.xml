<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="footer_copyright_company_name" model="ir.ui.view">
        <field name="name">Hotel - Footer Copyright Company Name</field>
        <field name="inherit_id" ref="website.footer_copyright_company_name"/>
        <field name="website_id" ref="website_industry"/>
        <field name="arch" type="xml">
            <xpath expr="//footer//span[hasclass('o_footer_copyright_name')]" position="replace">
                <span class="o_footer_copyright_name me-2 small" style="text-align: center;">Copyright &amp;copy; <strong>GRAND NORRIS PALACE</strong></span>
            </xpath>
        </field>
    </record>

    <record id="template_footer_minimalist" model="ir.ui.view">
        <field name="name">Hotel - Minimalist</field>
        <field name="key">website.template_footer_minimalist</field>
        <field name="inherit_id" ref="website.layout"/>
        <field name="website_id" ref="website_industry"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='footer']" position="replace">
                <div id="footer" class="oe_structure oe_structure_solo text-break" t-ignore="true" t-if="not no_footer">
                    <section class="s_text_block pb0 pt0" data-snippet="s_text_block" data-name="Container">
                        <div class="container">
                            <div class="row align-items-center">
                                <div class="col-lg-2 offset-lg-0 col-8 offset-2 pt16 pb16 o_colored_level">
                                    <a href="/" class="o_footer_logo logo">
                                        <img src="/hotel/static/src/img/content/website/hotel-image-03.webp" alt="" class="img-fluid d-block mx-auto img o_we_custom_image" style="width: 50% !important;" data-format-mimetype="image/webp" data-original-src="/hotel/static/src/img/content/website/hotel-image-03.webp" data-resize-width="1920" data-mimetype="image/webp" loading="lazy"/>
                                    </a>
                                </div>
                                <div class="col-lg-8 pt16 pb16 o_colored_level">
                                    <nav class="nav align-items-center justify-content-center flex-column flex-lg-row">
                                        <a class="nav-link btn btn-custom text-o-color-4" href="/" style="background-color: rgba(0, 0, 0, 0); border-width: 0px; border-color: rgb(128, 93, 78); border-style: none;">Home</a>
                                        <a class="nav-link btn btn-custom text-o-color-4" href="/shop" style="background-color: rgba(0, 0, 0, 0); border-width: 0px; border-color: rgb(128, 93, 78); border-style: none;">Rooms</a>
                                        <a class="nav-link btn btn-custom text-o-color-4" href="/contactus" style="background-color: rgba(0, 0, 0, 0); border-width: 0px; border-color: rgb(128, 93, 78); border-style: none;">Contact us</a>
                                    </nav>
                                </div>
                                <div class="col-lg-2 pt16 pb16 o_colored_level">
                                    <div class="s_social_media no_icon_color o_not_editable text-center" data-snippet="s_social_media" data-name="Social Media">
                                        <h5 class="s_social_media_title d-none">Follow us</h5>
                                        <a href="/website/social/facebook" class="s_social_media_facebook" target="_blank"><i class="fa fa-facebook fa-stack o_editable_media o_cc o_cc1 rounded-circle"/></a>
                                        <a href="/website/social/twitter" class="s_social_media_twitter" target="_blank"><i class="fa fa-twitter fa-stack o_editable_media o_cc o_cc1 rounded-circle"/></a>
                                        <a href="/website/social/instagram" class="s_social_media_instagram" target="_blank"><i class="fa fa-instagram fa-stack o_editable_media o_cc o_cc1 rounded-circle"/></a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
