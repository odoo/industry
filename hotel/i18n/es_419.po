#. module: hotel
#: model_terms:ir.ui.view,arch_db:hotel.welcome_article_body
msgid ""
"<strong><b>Contacts App</b>: </strong>Record guest identities securely, "
"linking them to their rental orders for\n"
"                compliance and personalized service."
msgstr ""
"<strong><b>Contactos</b>: </strong>Registra la identidad de tus huéspedes de "
"forma segura y vincúlalas con sus órdenes de alquiler\n"
"            para cumplir con las normativas y ofrecer un servicio "
"personalizado."

#. module: hotel
#: model_terms:ir.ui.view,arch_db:hotel.welcome_article_body
msgid ""
"<strong><b>Discuss App</b>: </strong>Facilitate communication between staff "
"members, ensuring that maintenance\n"
"                requests or special guest needs are shared instantly.<br/>"
msgstr ""
"<strong><b>Conversaciones</b>: </strong>Facilita la comunicación entre el "
"personal y asegura que las solicitudes de mantenimiento\n"
"            o necesidades especiales de los huéspedes se compartan al "
"instante.<br/>"

#. module: hotel
#: model_terms:ir.ui.view,arch_db:hotel.welcome_article_body
msgid ""
"<strong><b>Invoicing App</b>: </strong>Simplify billing by generating "
"professional invoices that include room\n"
"                charges, extra services, and automatically computed city "
"taxes."
msgstr ""
"<strong><b>Facturación</b>: </strong>Simplifica la facturación al generar "
"facturas profesionales que incluyan cargos\n"
"            por habitación, servicios adicionales e impuestos locales "
"calculados de forma automática."

#. module: hotel
#: model_terms:ir.ui.view,arch_db:hotel.welcome_article_body
msgid ""
"<strong><b>Planning App</b>: </strong>Organize housekeeping and front desk "
"shifts, binding them to rental orders\n"
"                to ensure rooms are ready for new arrivals."
msgstr ""
"<strong><b>Planeación</b>: </strong>Organiza turnos de limpieza y recepción, "
"y vincúlalos con órdenes de alquiler\n"
"            para asegurar que las habitaciones estén listas para las nuevas "
"llegadas."

#. module: hotel
#: model_terms:ir.ui.view,arch_db:hotel.welcome_article_body
msgid ""
"<strong><b>Rental App</b>: </strong>Manage room availability and pricing "
"models, ensuring that every booking is\n"
"                tracked and double-bookings are impossible.<br/>"
msgstr ""
"<strong><b>Alquiler</b>: </strong>Gestiona la disponibilidad de las "
"habitaciones y los modelos de precios. Asegúrate de que cada reservación\n"
"            quede registrada y evita que estén duplicadas.<br/>"

#. module: hotel
#: model_terms:ir.ui.view,arch_db:hotel.welcome_article_body
msgid ""
"<strong><b>Website &amp; eCommerce App</b>: </strong>specific your rooms and "
"amenities online, enabling\n"
"                customers to book directly through a professional, mobile-"
"friendly portal.<br/>"
msgstr ""
"<strong><b>Sitio web y Comercio electrónico</b>: </strong>Especifica tus "
"habitaciones y servicios en línea para permitir que los\n"
"            clientes reserven de forma directa desde un portal profesional y "
"compatible con sus celulares.<br/>"

