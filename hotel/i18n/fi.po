#. module: hotel
#: model_terms:ir.ui.view,arch_db:hotel.welcome_article_body
msgid ""
"<strong><b>Contacts App</b>: </strong>Record guest identities securely, "
"linking them to their rental orders for\n"
"                compliance and personalized service."
msgstr ""
"<strong><b>Yhteystiedot-sovellus</b>: </strong>Tallenna vieraiden "
"henkilöllisyystiedot turvallisesti ja linkitä ne heidän "
"vuokraustilauksiinsa\n"
"                säännösten noudattamisen ja henkilökohtaisen palvelun "
"varmistamiseksi."

#. module: hotel
#: model_terms:ir.ui.view,arch_db:hotel.welcome_article_body
msgid ""
"<strong><b>Discuss App</b>: </strong>Facilitate communication between staff "
"members, ensuring that maintenance\n"
"                requests or special guest needs are shared instantly.<br/>"
msgstr ""
"<strong><b>Viestintä-sovellus</b>: </strong>Helpottaa viestintää "
"henkilökunnan jäsenten välillä sekä varmistaa, että huoltopyynnöt\n"
"                tai erityiset vierastarpeet jaetaan välittömästi.<br/>"

#. module: hotel
#: model_terms:ir.ui.view,arch_db:hotel.welcome_article_body
msgid ""
"<strong><b>Invoicing App</b>: </strong>Simplify billing by generating "
"professional invoices that include room\n"
"                charges, extra services, and automatically computed city "
"taxes."
msgstr ""
"<strong><b>Laskutus-sovellus</b>: </strong>Yksinkertaista laskutusprosessia "
"luomalla ammattimaisia laskuja, jotka sisältävät huonemaksut,\n"
"                lisäpalvelut ja automaattisesti lasketut kunnallisverot."

#. module: hotel
#: model_terms:ir.ui.view,arch_db:hotel.welcome_article_body
msgid ""
"<strong><b>Planning App</b>: </strong>Organize housekeeping and front desk "
"shifts, binding them to rental orders\n"
"                to ensure rooms are ready for new arrivals."
msgstr ""
"<strong><b>Suunnittelu-sovellus</b>: </strong>Järjestä taloudenhoidon sekä "
"vastaanoton vuorot ja liitä ne vuokraustilauksiin\n"
"                varmistaaksesi, että huoneet ovat valmiina uusille vieraille."

#. module: hotel
#: model_terms:ir.ui.view,arch_db:hotel.welcome_article_body
msgid ""
"<strong><b>Rental App</b>: </strong>Manage room availability and pricing "
"models, ensuring that every booking is\n"
"                tracked and double-bookings are impossible.<br/>"
msgstr ""
"<strong><b>Vuokraus-sovellus</b>: </strong>Hallinnoi huoneiden saatavuutta "
"ja hinnoittelumalleja. Varmista, että jokaista varausta\n"
"                seurataan ja päällekkäiset varaukset estetään.<br/>"

#. module: hotel
#: model_terms:ir.ui.view,arch_db:hotel.welcome_article_body
msgid ""
"<strong><b>Website &amp; eCommerce App</b>: </strong>specific your rooms and "
"amenities online, enabling\n"
"                customers to book directly through a professional, mobile-"
"friendly portal.<br/>"
msgstr ""
"<strong><b>Verkkosivu &amp; Verkkokauppa-sovellus</b>: </strong>määritä "
"huoneesi ja palvelusi verkossa, jolloin\n"
"                asiakkaat voivat tehdä varauksia suoraan ammattimaisen ja "
"mobiiliystävällisen portaalin kautta.<br/>"

#. module: hotel
#: model_terms:ir.ui.view,arch_db:hotel.view_page_home
msgid ""
"<strong><span class=\"text-o-color-1\">The Grand Norris Palace</span></"
"strong> is a place where <b><span class=\"text-o-color-1\">luxury meets "
"wilderness</span></b>, where silence becomes a form of poetry, and where "
