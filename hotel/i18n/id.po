#. module: hotel
#: model_terms:ir.ui.view,arch_db:hotel.welcome_article_body
msgid ""
"<strong><b>Contacts App</b>: </strong>Record guest identities securely, "
"linking them to their rental orders for\n"
"                compliance and personalized service."
msgstr ""
"<strong><b>Aplikasi Kontak</b>: </strong>Catat identitas tamu dengan aman, "
"hubungkan tamu dengan rental ordernya untuk\n"
"                keperluan kepatuhan dan personalisasi layanan."

#. module: hotel
#: model_terms:ir.ui.view,arch_db:hotel.welcome_article_body
msgid ""
"<strong><b>Discuss App</b>: </strong>Facilitate communication between staff "
"members, ensuring that maintenance\n"
"                requests or special guest needs are shared instantly.<br/>"
msgstr ""
"<strong><b>Aplikasi Diskusi</b>: </strong>Fasilitasi komunikasi antar "
"anggota staf, memastikan permintaan maintenance\n"
"                atau kebutuhan tamu khusus dibagikan secara instan.<br/>"

#. module: hotel
#: model_terms:ir.ui.view,arch_db:hotel.welcome_article_body
msgid ""
"<strong><b>Invoicing App</b>: </strong>Simplify billing by generating "
"professional invoices that include room\n"
"                charges, extra services, and automatically computed city "
"taxes."
msgstr ""
"<strong><b>Aplikasi Faktur</b>: </strong>Sederhanakan penagihan dengan "
"membuat faktur profesional yang sudah mencakup biaya kamar,\n"
"                layanan tambahan, dan pajak kota yang dihitung secara "
"otomatis."

#. module: hotel
#: model_terms:ir.ui.view,arch_db:hotel.welcome_article_body
msgid ""
"<strong><b>Planning App</b>: </strong>Organize housekeeping and front desk "
"shifts, binding them to rental orders\n"
"                to ensure rooms are ready for new arrivals."
msgstr ""
"<strong><b>Aplikasi Perencanaan</b>: </strong>Atur tugas kebersihan dan "
"shift resepsionis, hubungkan dengan rental order\n"
"                untuk memastikan kamar siap dihuni tamu baru."

#. module: hotel
#: model_terms:ir.ui.view,arch_db:hotel.welcome_article_body
msgid ""
"<strong><b>Rental App</b>: </strong>Manage room availability and pricing "
"models, ensuring that every booking is\n"
"                tracked and double-bookings are impossible.<br/>"
msgstr ""
"<strong><b>Aplikasi Rental</b>: </strong>Kelola ketersediaan kamar dan model "
"harga untuk memastikan bahwa setiap pemesanan\n"
"                dilacak dan mencegah terbuatnya pemesanan ganda.<br/>"

#. module: hotel
#: model_terms:ir.ui.view,arch_db:hotel.welcome_article_body
msgid ""
"<strong><b>Website &amp; eCommerce App</b>: </strong>specific your rooms and "
"amenities online, enabling\n"
"                customers to book directly through a professional, mobile-"
"friendly portal.<br/>"
msgstr ""
"<strong><b>Aplikasi Website &amp; eCommerce</b>: </strong>cantumkan kamar "
"dan fasilitas secara online agar\n"
"                pelanggan dapat memesan langsung melalui portal profesional "
"yang kompatibel dengan perangkat mobile.<br/>"

#. module: hotel
#: model_terms:ir.ui.view,arch_db:hotel.view_page_home
msgid ""
"<strong><span class=\"text-o-color-1\">The Grand Norris Palace</span></"
"strong> is a place where <b><span class=\"text-o-color-1\">luxury meets "
"wilderness</span></b>, where silence becomes a form of poetry, and where "
"every horizon reminds you how vast and beautiful the world can be."
msgstr ""
"<strong><span class=\"text-o-color-1\">The Grand Norris Palace</span></"
"strong> adalah tempat yang <b><span class=\"text-o-color-1\">memadukan "
"kemewahan dengan alam liar</span></b>, mengubah keheningan menjadi puisi, "
"dan setiap cakrawala mengingatkan akan betapa luas dan indahnya dunia ini."

#. module: hotel
#: model_terms:ir.ui.view,arch_db:hotel.welcome_article_body
msgid "<strong>Basics</strong>"
msgstr "<strong>Basics</strong>"

#. module: hotel
#: model_terms:ir.ui.view,arch_db:hotel.welcome_article_body
msgid "<strong>Company specific offers</strong>"
msgstr "<strong>Penawaran khusus perusahaan</strong>"

#. module: hotel
#: model_terms:ir.ui.view,arch_db:hotel.welcome_article_body
