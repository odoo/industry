#. module: hotel
#: model_terms:ir.ui.view,arch_db:hotel.welcome_article_body
msgid ""
"<strong><b>Contacts App</b>: </strong>Record guest identities securely, "
"linking them to their rental orders for\n"
"                compliance and personalized service."
msgstr ""
"<strong><b>Ứng dụng Liên hệ</b>: </strong>Lưu trữ thông tin danh tính của "
"khách một cách an toàn, liên kết với các đơn đặt phòng của họ để đảm bảo "
"tuân thủ và cá nhân hoá dịch vụ."

#. module: hotel
#: model_terms:ir.ui.view,arch_db:hotel.welcome_article_body
msgid ""
"<strong><b>Discuss App</b>: </strong>Facilitate communication between staff "
"members, ensuring that maintenance\n"
"                requests or special guest needs are shared instantly.<br/>"
msgstr ""
"<strong><b>Ứng dụng Thảo luận</b>: </strong>Tạo điều kiện trao đổi giữa các "
"nhân viên, đảm bảo các yêu cầu bảo trì\n"
"hoặc nhu cầu đặc biệt của khách được chia sẻ ngay lập tức.<br/>"

#. module: hotel
#: model_terms:ir.ui.view,arch_db:hotel.welcome_article_body
msgid ""
"<strong><b>Invoicing App</b>: </strong>Simplify billing by generating "
"professional invoices that include room\n"
"                charges, extra services, and automatically computed city "
"taxes."
msgstr ""
"<strong><b>Ứng dụng Hoá đơn</b>: </strong>Đơn giản hoá việc lập hoá đơn bằng "
"cách tạo các hoá đơn chuyên nghiệp, bao gồm chi phí phòng, dịch vụ bổ sung "
"và thuế du lịch được tính tự động."

#. module: hotel
#: model_terms:ir.ui.view,arch_db:hotel.welcome_article_body
msgid ""
"<strong><b>Planning App</b>: </strong>Organize housekeeping and front desk "
"shifts, binding them to rental orders\n"
"                to ensure rooms are ready for new arrivals."
msgstr ""
"<strong><b>Ứng dụng Kế hoạch</b>: </strong>Tổ chức công việc dọn phòng và ca "
"trực quầy lễ tân, liên kết chúng với các đơn đặt phòng\n"
"                để đảm bảo phòng sẵn sàng cho khách mới đến."

#. module: hotel
#: model_terms:ir.ui.view,arch_db:hotel.welcome_article_body
msgid ""
"<strong><b>Rental App</b>: </strong>Manage room availability and pricing "
"models, ensuring that every booking is\n"
"                tracked and double-bookings are impossible.<br/>"
msgstr ""
"<strong><b>Ứng dụng Cho thuê</b>: </strong>Quản lý tình trạng phòng trống và "
"các mô hình giá, đảm bảo mọi đặt phòng\n"
"đều được theo dõi và không xảy ra tình trạng đặt trùng.<br/>"

#. module: hotel
#: model_terms:ir.ui.view,arch_db:hotel.welcome_article_body
msgid ""
"<strong><b>Website &amp; eCommerce App</b>: </strong>specific your rooms and "
"amenities online, enabling\n"
"                customers to book directly through a professional, mobile-"
"friendly portal.<br/>"
msgstr ""
"<strong><b>Ứng dụng Trang web &amp; Thương mại điện tử</b>: </strong>cấu "
"hình phòng và tiện nghi của bạn online, cho phép khách hàng đặt trực tiếp "
"thông qua một nền tảng chuyên nghiệp, thân thiện với thiết bị di động.<br/>"

