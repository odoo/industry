<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="uninstall_hook_base_automation" model="base.automation">
        <field name="model_id" ref="base.model_ir_module_module"/>
        <field name="trigger">on_state_set</field>
        <field name="trg_selection_field_id" ref="base.selection__ir_module_module__state__to_remove"/>
        <field name="filter_domain">[('state', '=', 'to remove')]</field>
        <field name="name">Property Management: Uninstall Hook</field>
        <field name="trigger_field_ids" eval="[(6, 0, [ref('base.field_ir_module_module__state')])]"/>
        <field name="filter_pre_domain" eval="[('id', '=', ref('base.module_industry_real_estate'))]"/>
    </record>
        <record id="uninstall_hook_action_server" model="ir.actions.server">
        <field name="code"><![CDATA[
crm_crm_lead_action_pipeline = env.ref('crm.crm_lead_action_pipeline', raise_if_not_found=False)
crm_crm_lead_action_pipeline['context'] = {'default_type': 'opportunity', 'search_default_assigned_to_me': 1, 'show_user_team_stages': 1,} if crm_crm_lead_action_pipeline else ''
    ]]></field>
        <field name="model_id" ref="base.model_ir_module_module"/>
        <field name="base_automation_id" ref="uninstall_hook_base_automation"/>
        <field name="state">code</field>
        <field name="name">Property Management: Uninstall Hook</field>
        <field name="usage">base_automation</field>
    </record>
</odoo>
