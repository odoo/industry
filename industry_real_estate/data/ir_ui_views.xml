<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="property_form_view" model="ir.ui.view">
        <field name="type">form</field>
        <field name="model">x_property</field>
        <field name="inherit_id" ref="property_assets_distribution.x_property_form_view"/>
        <field name="active" eval="True"/>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="%(action_create_invoice_meters)d" type="action" string="Create Invoice" invisible="not x_rental_contract_id or x_invoice_status != 'to_invoice'"/>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button" type="action" name="%(subscriptions_action)d" icon="fa-book" invisible="x_subscription_count == 0">
                    <field string="Rental Contracts" name="x_subscription_count" widget="statinfo"/>
                </button>
            </xpath>
            <xpath expr="//field[@name='x_active']" position="after">
                <field name="x_property_image" widget="image" class="oe_avatar ms-3 me-3" options="{'size': [0, 180]}"/>
            </xpath>
            <xpath expr="//group[@name='property_group_detailleft']" position="inside">
                <field name="x_rental_contract_id"/>
                <field name="x_property_address"/>
            </xpath>
            <xpath expr="//group[@name='property_group_detailright']" position="inside">
                <field name="x_invoice_status"/>
            </xpath>
        </field>
    </record>
    <record id="property_kanban_view" model="ir.ui.view">
        <field name="model">x_property</field>
        <field name="mode">primary</field>
        <field name="active" eval="True"/>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <kanban>
                <templates>
                    <t t-name="card">
                        <div class="d-flex align-item-start">
                            <div class="o_kanban_image" style="margin-right: 9px;">
                                <field name="x_property_image" widget="image" options="{'size': [94, 94]}"/>
                            </div>
                            <div class="o_kanban_details">
                                <strong>
                                    <field name="x_name"/>
                                </strong>
                                <div class="o_kanban_record_field">
                                    <field name="x_building"/>
                                </div>
                                <div class="o_kanban_record_field">
                                    <field name="x_property_address" class="text-muted"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <record id="view_crm_lead_form_inherit" model="ir.ui.view">
        <field name="name">crm.leam.form.inherit.industry_real_estate</field>
        <field name="model">crm.lead</field>
        <field name="active" eval="True"/>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="priority">160</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <data>
                <xpath expr="//group[@name='opportunity_partner']//field[@name='lost_reason_id']" position="before">
                    <field name="x_property_id"/>
                </xpath>
            </data>
        </field>
    </record>
    <record id="view_crm_lead_kanban_inherit" model="ir.ui.view">
        <field name="name">crm.lead.kanban.inherit.industry_real_estate</field>
        <field name="model">crm.lead</field>
        <field name="active" eval="True"/>
        <field name="inherit_id" ref="crm.crm_case_kanban_view_leads"/>
        <field name="priority">320</field>
        <field name="type">kanban</field>
        <field name="arch" type="xml">
            <data>
                <xpath expr="//t[@t-name='card']/field[@name='name']" position="after">
                    <field name="x_property_id" display="full"/>
                </xpath>
            </data>
        </field>
    </record>

    <record id="view_crm_lead_form_quick_create_inherit" model="ir.ui.view">
        <field name="name">crm.lead.form.quick_create</field>
        <field name="model">crm.lead</field>
        <field name="active" eval="True"/>
        <field name="inherit_id" ref="crm.quick_create_opportunity_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[1]" position="inside">
                <div class="d-flex align-items-center" colspan="2">
                    <i class="fa fa-home fa-lg" title="Property"/>
                    <field name="x_property_id" string="Property" placeholder="Property's name" nolabel="1" class="o_field_highlight w-100 mb-0"/>
                </div>
            </xpath>
        </field>
    </record>

    <record id="rental_gantt_view" model="ir.ui.view">
        <field name="model">sale.order</field>
        <field name="mode">primary</field>
        <field name="active" eval="True"/>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <gantt date_start="start_date" date_stop="end_date" color="partner_id" default_scale="year" display_unavailability="true" string="Availability" />
        </field>
    </record>

    <record id="rental_form_view" model="ir.ui.view">
        <field name="model">sale.order</field>
        <field name="mode">primary</field>
        <field name="active" eval="True"/>
        <field name="priority">150</field>
        <field name="inherit_id" ref="sale_subscription.sale_subscription_order_view_form"/>
        <field name="arch" type="xml">
            <field name="partner_id" position="attributes">
                <attribute name="string">Tenant</attribute>
            </field>
            <field name="partner_id" position="after">
                <field name="x_property_id" readonly="state == 'sale'"/>
                <field name="x_guarant_partner_id"/>
            </field>
            <xpath expr="//div[@name='plan_block']/span" position="replace"/>
            <xpath expr="//div[@name='plan_block']/field[@name='end_date']" position="replace"/>
            <xpath expr="//div[@name='plan_block']" position="after">
                <label string="From" for="start_date"/>
                <div class="o_row">
                    <field name="start_date"/>
                    <span>to</span>
                    <field name="end_date" required="True"/>
                </div>
            </xpath>
        </field>
    </record>
    <record id="meters_list_view_inherit" model="ir.ui.view">
        <field name="model">x_meters</field>
        <field name="inherit_id" ref="property_assets_distribution.meters_list_view"/>
        <field name="active" eval="True"/>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <field name="x_price" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
