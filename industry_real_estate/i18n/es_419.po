#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.homepage
#: model_terms:ir.ui.view,arch_db:industry_real_estate.ir_ui_view_1416
msgid "<b>ABOUT US</b>"
msgstr "<b>SOBRE NOSOTROS</b>"

#. module: industry_real_estate
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_27
msgid ""
"<b>Architectural Excellence:</b> A modern duplex layout that maximizes both "
"privacy and social space."
msgstr ""
"<b>Excelencia arquitectónica:</b> Una distribución dúplex moderna que "
"aprovecha al máximo tanto la privacidad como los espacios sociales."

#. module: industry_real_estate
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_27
msgid ""
"<b>Breathtaking Views:</b> Wide-angle vistas of the Uccle skyline from your "
"private balcony."
msgstr ""
"<b>Vistas impresionantes:</b> Vistas panorámicas de Uccle desde tu balcón."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>CRM App</b>: Manage your leads efficiently, tracking ongoing buying and "
"selling opportunities in a visual\n"
"                pipeline."
msgstr ""
"<b>CRM</b>: Gestiona tus leads con eficiencia y dale seguimiento a las "
"oportunidades activas de compra y venta en un\n"
"            flujo visual."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Contacts App: </b>Centralize all stakeholder data, managing the unique "
"relationships between property owners,\n"
"                tenants, and service providers within a single, searchable "
"directory with full communication history."
msgstr ""
"<b>Contactos: </b>Centraliza todos los datos de las partes interesadas y "
"gestiona las relaciones únicas entre propietarios,\n"
"            inquilinos y proveedores de servicios en un solo directorio con "
"búsqueda y con un historial completo de comunicaciones."

#. module: industry_real_estate
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_20
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_21
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_22
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_26
msgid "<b>Contemporary Heritage Living</b>"
msgstr "<b>Vida contemporánea con herencia histórica</b>"

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Create a Contract:</b> Click \"New\" and select the tenant as the "
"\"Customer\" and add the Rental fee product."
msgstr ""
"<b>Crear un contrato:</b> Haz clic en \"Nuevo\", selecciona al inquilino "
"como \"Cliente\" y agrega el producto de alquiler."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Create a Property:</b> Click \"New\" to create a unit. Fill in its "
"building, location and other details."
msgstr ""
"<b>Crear una propiedad:</b> Haz clic en \"Nuevo\" para crear una unidad. "
"Completa el edificio, la ubicación y otros detalles."

#. module: industry_real_estate
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_20
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_21
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_22
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_26
msgid ""
"<b>Designer Interiors:</b> Each unit features unique, modern furniture "
"packages and high-quality flooring."
msgstr ""
"<b>Interiores de diseñador:</b> Cada espacio cuenta con mobiliario moderno y "
"único, además de pisos de alta calidad."

#. module: industry_real_estate
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_23
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_24
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_25
msgid ""
"<b>Diverse Space Options:</b> Whether you need a collaborative hub "
"(<b>Office M</b>), a focused executive suite (<b>Office S</b>), or a "
"spacious flagship floor (<b>Office T</b>), we have the right fit for your "
"team."
msgstr ""
"<b>Varias opciones de espacio:</b> Ya sea que necesites un espacio "
"colaborativo (<b>Oficina M</b>), una suite ejecutiva enfocada (<b>Oficina S</"
"b>) o un piso espacioso (<b>Oficina T</b>), tenemos la opción ideal para tu "
"equipo."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Documents App:</b> Store signed leases, property deeds, and insurance "
"certificates with expiration alerts."
msgstr ""
"<b>Documentos:</b> Almacena contratos de arrendamiento firmados, escrituras "
"de propiedad y certificados de seguro con alertas de vencimiento."

#. module: industry_real_estate
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_23
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_24
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_25
msgid ""
"<b>Elite Location:</b> Situated in the prestigious <b>Louise area</b>, "
"providing immediate access to world-class dining, high-end retail, and "
"excellent transport links."
msgstr ""
"<b>Ubicación exclusiva:</b> Ubicado en la prestigiosa <b>zona Louise</b>, "
"con acceso inmediato a restaurantes de primer nivel, tiendas de alta gama y "
"excelentes conexiones de transporte."

#. module: industry_real_estate
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_23
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_24
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_25
msgid ""
"<b>Fully Equipped Amenities:</b> Access to premium lounges, designer meeting "
"rooms, and state-of-the-art infrastructure."
msgstr ""
"<b>Amenidades totalmente equipadas:</b> Accede a salas premium, salas de "
"reuniones de diseñador e infraestructura novedosa."

#. module: industry_real_estate
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_20
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_21
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_22
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_23
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_24
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_25
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_26
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_27
msgid "<b>Key Highlights:</b>"
msgstr "<b>Puntos clave:</b>"

#. module: industry_real_estate
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_23
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_24
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_25
msgid ""
"<b>Modern Industrial Aesthetic:</b> Features high ceilings, exposed "
"ductwork, and abundant natural light to foster creativity and productivity."
msgstr ""
"<b>Estética industrial moderna:</b> Cuenta con techos altos, ductos a la "
"vista y abundante luz natural para aumentar la creatividad y la "
"productividad."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Move-in Logs:</b> Utilize the dedicated property tab to record meter "
"readings (water, electricity) at the\n"
"                time of the tenant's entry to ensure accurate utility re-"
"billing later."
msgstr ""
"<b>Registros de mudanza:</b> Usa la pestaña específica de la propiedad para "
"registrar las lecturas de los medidores (agua, electricidad) al\n"
"            momento de la entrada del inquilino para garantizar la correcta "
"refacturación de los servicios después."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Open the Availability</b>: Open the <strong>Properties App</strong> and "
"navigate through the app menu\n"
"                Availability."
msgstr ""
"<b>Abrir Disponibilidad</b>: Abre la aplicación <strong>Propiedades</strong> "
"y navega por el menú de la aplicación\n"
"            Disponibilidad."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Open the Contracts</b>: Open the <strong>Properties App</strong> to reach "
"the Subscriptions."
msgstr ""
"<b>Abrir los contratos</b>: Abre la aplicación <strong>Propiedades</strong> "
"para acceder a las suscripciones."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Open the Properties: </b>Open the <b>Properties App </b>and navigate "
"through the app menu Properties /\n"
"                Properties."
msgstr ""
"<b>Abrir las propiedades: </b>Abre la aplicación<b>Propiedades </b>y navega "
"por el menú de la aplicación Propiedades /\n"
"            Propiedades."

#. module: industry_real_estate
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_20
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_21
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_22
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_26
msgid ""
"<b>Peaceful Setting:</b> Set within the quiet, green surroundings of a "
"beautifully repurposed farmhouse."
msgstr ""
"<b>Entorno tranquilo:</b> Ubicado en un entorno silencioso y verde dentro de "
"una hermosa casa de campo remodelada."

#. module: industry_real_estate
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_27
msgid ""
"<b>Prime Location:</b> Situated in one of Brussels' most sought-after "
"residential districts."
msgstr ""
"<b>Ubicación increíble:</b> Situado en una de las zonas residenciales más "
"cotizadas de Bruselas."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Pro Tip:</b> You can create a new rental contract directly from this view "
"by clicking on an empty slot in\n"
"                    the timeline."
msgstr ""
"<b>Consejo:</b> Puedes crear un nuevo contrato de alquiler directo desde "
"esta vista al hacer clic en un espacio vacío de\n"
"                la línea de tiempo."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Properties App: </b>Organize your portfolio with a dedicated app to "
"manage property listings, contracts, and\n"
"                availability status."
msgstr ""
"<b>Propiedades: </b>Organiza tu portafolio con una aplicación dedicada para "
"gestionar anuncios de propiedades, contratos y\n"
"            estado de disponibilidad."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Sales App: </b>Handle offers, negotiations, and closing deals with "
"professional quotations and digital\n"
"                signatures."
msgstr ""
"<b>Ventas: </b>Gestiona ofertas, negociaciones y cierres mediante "
"cotizaciones profesionales y firmas\n"
"            digitales."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid "<b>Select the Property:</b> Select the \"Property\" to rent."
msgstr ""
"<b>Selecciona la propiedad:</b> Selecciona la \"propiedad\" a alquilar."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Sign App:</b> Send lease agreements for legally binding electronic "
"signatures."
msgstr ""
"<b>Firma electrónica:</b> Envía contratos de arrendamiento para obtener "
"firmas electrónicas con validez legal."

#. module: industry_real_estate
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_27
msgid "<b>Sky-High Sophistication in Uccle</b>"
msgstr "<b>Sofisticación en las alturas de Uccle</b>"

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Subscriptions App: </b>Automate the collection of recurring rent and "
"service charges with flexible billing\n"
"                cycles, ensuring consistent cash flow and effortless lease "
"renewals."
msgstr ""
"<b>Suscripciones: </b>Automatiza el cobro de los alquileres recurrentes y "
"cargos por servicios con ciclos de facturación flexibles,\n"
"            esto te permitirá garantizar un flujo de efectivo constante y "
"podrás renovar contratos sin dificultades."

#. module: industry_real_estate
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_23
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_24
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_25
msgid "<b>The Future of Work in the Heart of Brussels</b>"
msgstr "<b>El futuro del trabajo en el corazón de Bruselas</b>"

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Timeline:</b> Specify the start date, the recurring period (monthly, "
"quarterly, etc.) and the expiration of\n"
"                the contract."
msgstr ""
"<b>Línea de tiempo:</b> Especifica la fecha de inicio, el periodo recurrente "
"(mensual, trimestral, etc.) y el vencimiento del\n"
"            contrato."

#. module: industry_real_estate
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_20
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_21
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_22
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_26
msgid ""
"<b>Versatile Layouts:</b> From cozy 1-bedroom setups to more expansive open-"
"plan living areas."
msgstr ""
"<b>Distribuciones versátiles:</b> Desde acogedores espacios de una "
"habitación hasta áreas abiertas y amplias."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Website App: </b>Drive qualified traffic by promoting your listings on a "
"beautiful, mobile-responsive\n"
"                property management portal."
msgstr ""
"<b>Sitio web: </b>Atrae tráfico calificado al promocionar tus anuncios en un "
"portal de gestión de propiedades llamativo y\n"
"            responsivo para celulares."

