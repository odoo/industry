#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.homepage
#: model_terms:ir.ui.view,arch_db:industry_real_estate.ir_ui_view_1416
msgid "<b>ABOUT US</b>"
msgstr "<b>CHI SIAMO</b>"

#. module: industry_real_estate
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_27
msgid ""
"<b>Architectural Excellence:</b> A modern duplex layout that maximizes both "
"privacy and social space."
msgstr ""
"<b>Eccellenza architettonica:</b> una moderna disposizione a duplex che "
"massimizza sia la privacy che lo spazio sociale."

#. module: industry_real_estate
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_27
msgid ""
"<b>Breathtaking Views:</b> Wide-angle vistas of the Uccle skyline from your "
"private balcony."
msgstr ""
"<b>Panorami mozzafiato:</b> vista panoramica dello skyline di Uccle dal tuo "
"balcone privato."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>CRM App</b>: Manage your leads efficiently, tracking ongoing buying and "
"selling opportunities in a visual\n"
"                pipeline."
msgstr ""
"<b>CRM</b>: gestisci i tuoi lead in modo efficiente, monitorando le "
"opportunità di acquisto e vendita in corso in una pipeline visiva."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Contacts App: </b>Centralize all stakeholder data, managing the unique "
"relationships between property owners,\n"
"                tenants, and service providers within a single, searchable "
"directory with full communication history."
msgstr ""
"<b>Contatti: </b>centralizza tutti i dati degli stakeholder, gestendo le "
"relazioni uniche tra proprietari immobiliari,\n"
"inquilini e fornitori di servizi all'interno di un unico elenco consultabile "
"con cronologia completa delle comunicazioni."

#. module: industry_real_estate
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_20
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_21
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_22
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_26
msgid "<b>Contemporary Heritage Living</b>"
msgstr "<b>Vita contemporanea e patrimonio culturale</b>"

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Create a Contract:</b> Click \"New\" and select the tenant as the "
"\"Customer\" and add the Rental fee product."
msgstr ""
"<b>Crea un contratto:</b> fai clic su \"Nuovo\" e seleziona l'inquilino come "
"\"Cliente\", quindi aggiungi il prodotto \"Canone di locazione\"."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Create a Property:</b> Click \"New\" to create a unit. Fill in its "
"building, location and other details."
msgstr ""
"<b>Crea una proprietà:</b> fai clic su \"Nuovo\" per creare un'unità. "
"Inserisci l'edificio, la posizione e altri dettagli."

#. module: industry_real_estate
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_20
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_21
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_22
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_26
msgid ""
"<b>Designer Interiors:</b> Each unit features unique, modern furniture "
"packages and high-quality flooring."
msgstr ""
"<b>Interni di design:</b> ogni unità è dotata di arredi moderni e unici e di "
"pavimenti di alta qualità."

#. module: industry_real_estate
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_23
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_24
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_25
msgid ""
"<b>Diverse Space Options:</b> Whether you need a collaborative hub "
"(<b>Office M</b>), a focused executive suite (<b>Office S</b>), or a "
"spacious flagship floor (<b>Office T</b>), we have the right fit for your "
"team."
msgstr ""
"<b>Diverse opzioni di spazio:</b> che tu abbia bisogno di un hub "
"collaborativo (<b>Ufficio M</b>), di una suite executive dedicata "
"(<b>Ufficio S</b>) o di un ampio piano flagship (<b>Ufficio T</b>), abbiamo "
"la soluzione giusta per il tuo team."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Documents App:</b> Store signed leases, property deeds, and insurance "
"certificates with expiration alerts."
msgstr ""
"<b>Documenti:</b> archivia contratti di locazione firmati, atti di proprietà "
"e certificati assicurativi con avvisi di scadenza."

#. module: industry_real_estate
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_23
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_24
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_25
msgid ""
"<b>Elite Location:</b> Situated in the prestigious <b>Louise area</b>, "
"providing immediate access to world-class dining, high-end retail, and "
"excellent transport links."
msgstr ""
"<b>Posizione d'élite:</b> situato nella prestigiosa <b>Louise</b> con "
"accesso immediato a ristoranti di fama mondiale, negozi di lusso ed "
"eccellenti collegamenti di trasporto."

#. module: industry_real_estate
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_23
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_24
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_25
msgid ""
"<b>Fully Equipped Amenities:</b> Access to premium lounges, designer meeting "
"rooms, and state-of-the-art infrastructure."
msgstr ""
"<b>Servizi completi:</b> accesso a lounge premium, sale riunioni di design e "
"infrastrutture all'avanguardia."

#. module: industry_real_estate
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_20
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_21
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_22
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_23
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_24
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_25
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_26
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_27
msgid "<b>Key Highlights:</b>"
msgstr "<b>Punti salienti:</b>"

#. module: industry_real_estate
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_23
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_24
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_25
msgid ""
"<b>Modern Industrial Aesthetic:</b> Features high ceilings, exposed "
"ductwork, and abundant natural light to foster creativity and productivity."
msgstr ""
"<b>Estetica industriale moderna:</b> caratterizzata da soffitti alti, "
"condutture a vista e abbondante luce naturale per favorire la creatività e "
"la produttività."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Move-in Logs:</b> Utilize the dedicated property tab to record meter "
"readings (water, electricity) at the\n"
"                time of the tenant's entry to ensure accurate utility re-"
"billing later."
msgstr ""
"<b>Registri di ingresso:</b> utilizza la scheda dedicata alla proprietà per "
"registrare le letture dei contatori (acqua, elettricità) al\n"
"                momento dell'ingresso dell'inquilino, in modo da garantire "
"una fatturazione accurata delle utenze in un secondo momento."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Open the Availability</b>: Open the <strong>Properties App</strong> and "
"navigate through the app menu\n"
"                Availability."
msgstr ""
"<b>Controlla le disponibilità</b>: apri l'app <strong>Proprietà</strong> e "
"naviga nel menu\n"
"                Disponibilità."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Open the Contracts</b>: Open the <strong>Properties App</strong> to reach "
"the Subscriptions."
msgstr ""
"<b>Apri i contratti</b>: apri l'app <strong>Proprietà</strong> per accedere "
"agli abbonamenti."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Open the Properties: </b>Open the <b>Properties App </b>and navigate "
"through the app menu Properties /\n"
"                Properties."
msgstr ""
"<b>accedi alle proprietà: </b>Apri l'app <b>Proprietà </b> e naviga nel "
"menu\n"
"                Proprietà."

#. module: industry_real_estate
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_20
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_21
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_22
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_26
msgid ""
"<b>Peaceful Setting:</b> Set within the quiet, green surroundings of a "
"beautifully repurposed farmhouse."
msgstr ""
"<b>Ambiente tranquillo:</b> situato nei tranquilli e verdeggianti dintorni "
"di una fattoria splendidamente ristrutturata."

#. module: industry_real_estate
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_27
msgid ""
"<b>Prime Location:</b> Situated in one of Brussels' most sought-after "
"residential districts."
msgstr ""
"<b>Posizione privilegiata:</b> situato in uno dei quartieri residenziali più "
"ambiti di Bruxelles."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Pro Tip:</b> You can create a new rental contract directly from this view "
"by clicking on an empty slot in\n"
"                    the timeline."
msgstr ""
"<b>Consiglio:</b> è possibile creare un nuovo contratto di noleggio "
"direttamente da questa schermata cliccando su uno slot vuoto nella\n"
"                    linea temporale."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Properties App: </b>Organize your portfolio with a dedicated app to "
"manage property listings, contracts, and\n"
"                availability status."
msgstr ""
"<b>Proprietà: </b>organizza il tuo portfolio con un'app dedicata alla "
"gestione di annunci immobiliari, contratti e\n"
"                stato di disponibilità."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Sales App: </b>Handle offers, negotiations, and closing deals with "
"professional quotations and digital\n"
"                signatures."
msgstr ""
"<b>Vendite: </b>gestisci offerte, trattative e conclusioni di accordi con "
"preventivi professionali e firme digitali\n"
"                ."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid "<b>Select the Property:</b> Select the \"Property\" to rent."
msgstr "<b>Seleziona la proprietà:</b> seleziona l'immobile da affittare."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Sign App:</b> Send lease agreements for legally binding electronic "
"signatures."
msgstr ""
"<b>Firma:</b> invia contratti di locazione per firme elettroniche legalmente "
"vincolanti."

#. module: industry_real_estate
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_27
msgid "<b>Sky-High Sophistication in Uccle</b>"
msgstr "<b>Sofisticatezza alle stelle a Uccle</b>"

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Subscriptions App: </b>Automate the collection of recurring rent and "
"service charges with flexible billing\n"
"                cycles, ensuring consistent cash flow and effortless lease "
"renewals."
msgstr ""
"<b>Abbonamenti: </b>automatizza la riscossione degli affitti ricorrenti e "
"delle spese condominiali con cicli di fatturazione flessibili,\n"
"garantendo un flusso di cassa costante e rinnovi dei contratti di locazione "
"senza sforzo."

#. module: industry_real_estate
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_23
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_24
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_25
msgid "<b>The Future of Work in the Heart of Brussels</b>"
msgstr "<b>Il futuro del lavoro nel cuore di Bruxelles</b>"

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Timeline:</b> Specify the start date, the recurring period (monthly, "
"quarterly, etc.) and the expiration of\n"
"                the contract."
msgstr ""
"<b>Calendario:</b> specifica la data di inizio, la periodicità (mensile, "
"trimestrale, ecc.) e la scadenza del\n"
"                contratto."

#. module: industry_real_estate
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_20
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_21
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_22
#: model_terms:product.template,description_ecommerce:industry_real_estate.product_template_prop_26
msgid ""
"<b>Versatile Layouts:</b> From cozy 1-bedroom setups to more expansive open-"
"plan living areas."
msgstr ""
"<b>Disposizioni versatili:</b> da accoglienti configurazioni con 1 camera da "
"letto a zone giorno open space più ampie."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Website App: </b>Drive qualified traffic by promoting your listings on a "
"beautiful, mobile-responsive\n"
"                property management portal."
msgstr ""
"<b>Sito web: </b>attira traffico qualificato promuovendo i tuoi annunci su "
"un bellissimo portale di gestione immobiliare ottimizzato per dispositivi "
"mobili."

