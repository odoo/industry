#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.homepage
#: model_terms:ir.ui.view,arch_db:industry_real_estate.ir_ui_view_1416
msgid "<b>ABOUT US</b>"
msgstr "<b>ກ່ຽວກັບພວກເຮົາ</b>"

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>CRM App</b>: Manage your leads efficiently, tracking ongoing buying and selling opportunities in a visual\n"
"                pipeline."
msgstr ""
"<b>ແອັບ CRM</b>: ຈັດການລາຍຊື່ຜູ້ສົນໃຈຂອງທ່ານຢ່າງມີປະສິດທິພາບ, ຕິດຕາມໂອກາດການຊື້ ແລະ ການຂາຍທີ່ກ"
"ຳລັງດຳເນີນຢູ່ ໃນຮູບແບບຂັ້ນຕອນການຂາຍ."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Contacts App: </b>Centralize all stakeholder data, managing the unique relationships between property owners,\n"
"                tenants, and service providers within a single, searchable directory with full communication history."
msgstr ""
"<b>ແອັບລາຍຊື່ຜູ້ຕິດຕໍ່: </b>ລວບລວມຂໍ້ມູນຜູ້ມີສ່ວນຮ່ວມທັງໝົດໄວ້ບ່ອນດຽວ, ຈັດການຄວາມສຳພັນລະຫວ່າງເຈົ້າຂອງຊັ"
"ບສິນ, ຜູ້ເຊົ່າ, ແລະ ຜູ້ໃຫ້ບໍລິການ ພາຍໃນລະບົບທີ່ສາມາດຄົ້ນຫາໄດ້ ພ້ອມປະຫວັດການຕິດຕໍ່ສື່ສານທີ່ຄົບຖ້ວນ."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Create a Contract:</b> Click \"New\" and select the tenant as the "
"\"Customer\" and add the Rental fee product."
msgstr ""
"<b>ສ້າງສັນຍາ:</b> ຄລິກ \"ໃໝ່\" ແລະ ເລືອກຜູ້ເຊົ່າເປັນ \"ລູກຄ້າ\" ແລ້ວເພີ່ມສິນຄ້າຄ່າເຊົ່າ."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Create a Property:</b> Click \"New\" to create a unit. Fill in its "
"building, location and other details."
msgstr ""
"<b>ສ້າງຊັບສິນ:</b> ຄລິກ \"ໃໝ່\" ເພື່ອສ້າງຫ້ອງ. ປ້ອນຂໍ້ມູນອາຄານ, ສະຖານທີ່ ແລະ ລາຍລະອຽດອື່ນໆ."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Documents App:</b> Store signed leases, property deeds, and insurance "
"certificates with expiration alerts."
msgstr ""
"<b>ແອັບເອກະສານ:</b> ເກັບຮັກສາສັນຍາເຊົ່າທີ່ເຊັນແລ້ວ, ໃບຕາດິນ, ແລະ ໃບຢັ້ງຢືນການປະກັນໄພ ພ້ອມລະບົບ"
"ເຕືອນການໝົດອາຍຸ."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Move-in Logs:</b> Utilize the dedicated property tab to record meter readings (water, electricity) at the\n"
"                time of the tenant's entry to ensure accurate utility re-billing later."
msgstr ""
"<b>ບັນທຶກການຍ້າຍເຂົ້າ:</b> ນຳໃຊ້ແຖບຊັບສິນທີ່ກຳນົດໄວ້ ເພື່ອບັນທຶກຄ່າມີເຕີ (ນ້ຳ, ໄຟຟ້າ) ໃນເວລາທີ່ຜູ້ເຊົ່າເ"
"ລີ່ມເຂົ້າຢູ່ ເພື່ອຮັບປະກັນການອອກບິນຄ່າສາທາລະນຸປະໂພກທີ່ຖືກຕ້ອງໃນພາຍຫຼັງ."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Open the Availability</b>: Open the <strong>Properties App</strong> and navigate through the app menu\n"
"                Availability."
msgstr ""
"<b>ເປີດຄວາມພ້ອມໃຊ້ງານ</b>: ເປີດ <strong>ແອັບຊັບສິນ</strong> ແລະ ໄປທີ່ເມນູຂອງແອັບ ຄວາມພ້ອ"
"ມ\n"
"                ໃຊ້ງານ."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Open the Contracts</b>: Open the <strong>Properties App</strong> to reach"
" the Subscriptions."
msgstr ""
"<b>ເປີດເບິ່ງສັນຍາ</b>: ເປີດ <strong>ແອັບຊັບສິນ</strong> ເພື່ອໄປທີ່ສ່ວນ ການສະໝັກໃຊ້."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Open the Properties: </b>Open the <b>Properties App </b>and navigate through the app menu Properties /\n"
"                Properties."
msgstr ""
"<b>ເປີດເບິ່ງຊັບສິນ: </b>ເປີດ <b>ແອັບຊັບສິນ </b>ແລະ ໄປທີ່ເມນູ ຊັບສິນ / ຊັບສິນ."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Pro Tip:</b> You can create a new rental contract directly from this view by clicking on an empty slot in\n"
"                    the timeline."
msgstr ""
"<b>ເຄັດລັບ:</b> ທ່ານສາມາດສ້າງສັນຍາເຊົ່າໃໝ່ໄດ້ໂດຍກົງຈາກມຸມມອງນີ້ ໂດຍການຄລິກໃສ່ຊ່ອງຫວ່າງໃນແຖບເວລ"
"າ."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Properties App: </b>Organize your portfolio with a dedicated app to manage property listings, contracts, and\n"
"                availability status."
msgstr ""
"<b>ແອັບຊັບສິນ: </b>ຈັດລະບຽບລາຍການຊັບສິນຂອງທ່ານດ້ວຍແອັບສະເພາະ ເພື່ອຈັດການລາຍການຊັບສິນ, ສັນຍ"
"າ, ແລະ ສະຖານະຫວ່າງ."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Sales App: </b>Handle offers, negotiations, and closing deals with professional quotations and digital\n"
"                signatures."
msgstr ""
"<b>ແອັບການຂາຍ: </b>ຈັດການການສະເໜີລາຄາ, ການເຈລະຈາ, ແລະ ການປິດການຂາຍດ້ວຍໃບສະເໜີລາຄາມືອ"
"າຊີບ ແລະ ການເຊັນຊື່ແບບດິຈິຕອນ."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid "<b>Select the Property:</b> Select the \"Property\" to rent."
msgstr "<b>ເລືອກຊັບສິນ:</b> ເລືອກ \"ຊັບສິນ\" ທີ່ຕ້ອງການໃຫ້ເຊົ່າ."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Sign App:</b> Send lease agreements for legally binding electronic "
"signatures."
msgstr ""
"<b>ແອັບເຊັນຊື່:</b> ສົ່ງສັນຍາເຊົ່າເພື່ອເຊັນຊື່ແບບເອເລັກໂຕຣນິກທີ່ມີຜົນທາງກົດໝາຍ."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Subscriptions App: </b>Automate the collection of recurring rent and service charges with flexible billing\n"
"                cycles, ensuring consistent cash flow and effortless lease renewals."
msgstr ""
"<b>ແອັບການສະໝັກໃຊ້: </b>ຈັດການການເກັບຄ່າເຊົ່າ ແລະ ຄ່າບໍລິການແບບປະຈຳໂດຍອັດຕະໂນມັດ ດ້ວຍຮອບວຽນ"
"ການອອກບິນທີ່ຍືດຫຍຸ່ນ, ເພື່ອຮັບປະກັນກະແສເງິນສົດທີ່ຕໍ່ເນື່ອງ ແລະ ການຕໍ່ສັນຍາເຊົ່າທີ່ງ່າຍດາຍ."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Timeline:</b> Specify the start date, the recurring period (monthly, quarterly, etc.) and the expiration of\n"
"                the contract."
msgstr ""
"<b>ແຖບເວລາ:</b> ກຳນົດວັນທີເລີ່ມຕົ້ນ, ໄລຍະເວລາທີ່ເກີດຂຶ້ນຊ້ຳ (ລາຍເດືອນ, ລາຍໄຕມາດ, ແລະ ອື່ນໆ) ແ"
"ລະ ວັນໝົດອາຍຸຂອງສັນຍາ."

#. module: industry_real_estate
#: model_terms:ir.ui.view,arch_db:industry_real_estate.welcome_article_body
msgid ""
"<b>Website App: </b>Drive qualified traffic by promoting your listings on a beautiful, mobile-responsive\n"
"                property management portal."
msgstr ""
"<b>ແອັບເວັບໄຊ: </b>ດຶງດູດລູກຄ້າທີ່ມີຄຸນນະພາບໂດຍການໂຄສະນາລາຍການຊັບສິນຂອງທ່ານໃນເວັບໄຊຈັດການຊັບສິ"
"ນທີ່ສວຍງາມ ແລະ ຮອງຮັບການສະແດງຜົນເທິງມືຖື."

