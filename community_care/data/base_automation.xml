<?xml version='1.0' encoding='UTF-8'?>
<odoo>
  <record id="automation_on_date_of_birth_update" model="base.automation">
    <field name="name">On Date of Birth Update</field>
    <field name="model_id" ref="base.model_res_partner"/>
    <field name="action_server_ids" eval="[(6, 0, [ref('set_age_according_to_date_of_birth_server_action')])]"/>
    <field name="trigger">on_create_or_write</field>
    <field name="trigger_field_ids" eval="[(6, 0, [ref('base_model_res_partner_x_date_of_birth_field')])]"/>
    <field name="filter_domain">[("x_is_resident", "=", True)]</field>
  </record>
  <record id="automation_on_edit_shortcut_inputs" model="base.automation">
    <field name="name">On edit of shortcut inputs</field>
    <field name="model_id" ref="model_x_res_partner_shortcut"/>
    <field name="trigger">on_create_or_write</field>
    <field name="trigger_field_ids" eval="[(6, 0, [ref('x_res_partner_shortcut_model_x_name_field'), ref('x_res_partner_shortcut_model_x_shortcut_field')])]"/>
    <field name="action_server_ids" eval="[(6, 0, [ref('action_update_shortcut_url')])]"/>
  </record>
  <record id="automation_on_edit_shortcut_pattern" model="base.automation">
    <field name="name">On edit of shortcut pattern</field>
    <field name="model_id" ref="model_x_shortcut"/>
    <field name="trigger">on_create_or_write</field>
    <field name="trigger_field_ids" eval="[(6, 0, [ref('x_shortcut_model_x_pattern_field')])]"/>
    <field name="action_server_ids" eval="[(6, 0, [ref('action_recompute_shortcut_urls')])]"/>
  </record>
</odoo>
