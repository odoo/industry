<?xml version='1.0' encoding='UTF-8'?>
<odoo auto_sequence="1">
  <record id="residents_menu_root" model="ir.ui.menu">
    <field name="name">Residents</field>
    <field name="web_icon_data" type="bytes" file="community_care/static/description/icon.png" />
    <field name="sequence">1</field>
  </record>
  <record id="residents_resident_menu" model="ir.ui.menu">
    <field name="action" ref="action_window_resident" />
    <field name="name">Residents</field>
    <field name="sequence">1</field>
    <field name="parent_id" ref="residents_menu_root" />
  </record>
  <record id="residents_docs_menu" model="ir.ui.menu">
    <field name="action" ref="action_window_docs" />
    <field name="name">Docs</field>
    <field name="parent_id" ref="residents_menu_root" />
  </record>
  <record id="residents_configuration_menu_root" model="ir.ui.menu">
    <field name="action" ref="base.action_open_website" />
    <field name="name">Configuration</field>
    <field name="parent_id" ref="residents_menu_root" />
  </record>
  <record id="residents_allergies_menu" model="ir.ui.menu">
    <field name="action" ref="action_window_allergies" />
    <field name="name">Allergies</field>
    <field name="parent_id" ref="residents_configuration_menu_root" />
  </record>
  <record id="residents_languages_menu" model="ir.ui.menu">
    <field name="action" ref="action_window_languages" />
    <field name="name">Languages</field>
    <field name="parent_id" ref="residents_configuration_menu_root" />
  </record>
  <record id="menu_family_unit" model="ir.ui.menu">
    <field name="action" ref="action_window_family_unit" />
    <field name="name">Family Units</field>
    <field name="parent_id" ref="residents_configuration_menu_root" />
    <field name="sequence">4</field>
  </record>
  <record id="menu_stay" model="ir.ui.menu">
    <field name="action" ref="action_window_stay" />
    <field name="name">Stays</field>
    <field name="parent_id" ref="residents_menu_root" />
    <field name="sequence">2</field>
  </record>
</odoo>
