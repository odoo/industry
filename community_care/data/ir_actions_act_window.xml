<?xml version='1.0' encoding='UTF-8'?>
<odoo>
  <record id="action_window_resident" model="ir.actions.act_window">
    <field name="domain">[('x_is_resident', '=', True)]</field>
    <field name="name">Residents</field>
    <field name="res_model">res.partner</field>
    <field name="context">{'default_x_is_resident': True, 'search_default_filter_admitting': 1,
      'search_default_filter_admitted': 1, 'search_default_filter_transitionning': 1}</field>
    <field name="view_mode">kanban,list,form,activity</field>
  </record>
  <record id="action_window_allergies" model="ir.actions.act_window">
    <field name="name">Allergies</field>
    <field name="res_model">x_allergy</field>
    <field name="view_mode">list</field>
  </record>
  <record id="action_window_languages" model="ir.actions.act_window">
    <field name="name">Languages</field>
    <field name="res_model">x_languages</field>
    <field name="view_mode">list</field>
  </record>
  <record id="action_window_docs" model="ir.actions.act_window">
    <field name="name">Docs</field>
    <field name="res_model">documents.document</field>
    <field name="view_mode">kanban,list,form,activity</field>
  </record>
  <record id="action_window_family_unit" model="ir.actions.act_window">
    <field name="name">Family Units</field>
    <field name="res_model">x_family_unit</field>
    <field name="view_mode">kanban,form</field>
  </record>
  <record id="action_window_stay" model="ir.actions.act_window">
    <field name="name">Stays</field>
    <field name="res_model">x_stay</field>
    <field name="view_mode">list,form</field>
    <field name="context">{'search_default_filter_ongoing': 1}</field>
  </record>
  <record id="action_window_log_notes" model="ir.actions.act_window">
    <field name="context">{'search_default_address_id': active_id,'default_address_id': active_id}</field>
    <field name="domain">[('address_id', '=', active_id)]</field>
    <field name="name">Log Notes</field>
    <field name="res_model">hr.employee.public</field>
  </record>
  <record id="action_partner_meeting_focus" model="ir.actions.act_window">
    <field name="name">Meeting Notes</field>
    <field name="res_model">knowledge.article</field>
    <field name="view_mode">list,form</field>
    <field name="context">{'default_is_article_item': True}</field>
  </record>
  <record id="action_partner_log_notes" model="ir.actions.act_window">
    <field name="name">Log Notes</field>
    <field name="res_model">knowledge.article</field>
    <field name="view_mode">list,form</field>
    <field name="context">{'default_is_article_item': True}</field>
  </record>
  <record id="action_partner_detailed_notes" model="ir.actions.act_window">
    <field name="name">Detailed Notes</field>
    <field name="res_model">knowledge.article</field>
    <field name="view_mode">list,form</field>
    <field name="context">{'default_is_article_item': True}</field>
  </record>
</odoo>
