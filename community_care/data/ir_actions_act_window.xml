<?xml version='1.0' encoding='UTF-8'?>
<odoo>
  <record id="action_window_resident" model="ir.actions.act_window">
    <field name="domain">[('x_is_resident', '=', True)]</field>
    <field name="name">Residents</field>
    <field name="res_model">res.partner</field>
    <field name="context">{'default_x_is_resident': True}</field>
    <field name="view_mode">kanban,list,form,activity</field>
  </record>
  <record id="action_window_allergies" model="ir.actions.act_window">
    <field name="name">Allergies</field>
    <field name="res_model">x_allergy</field>
    <field name="view_mode">list</field>
  </record>
  <record id="action_window_contact_natures" model="ir.actions.act_window">
    <field name="name">Contact Natures</field>
    <field name="res_model">x_contact_nature</field>
    <field name="view_mode">list</field>
  </record>
  <record id="action_window_languages" model="ir.actions.act_window">
    <field name="name">Languages</field>
    <field name="res_model">x_languages</field>
    <field name="view_mode">list</field>
  </record>
  <record id="action_window_docs" model="ir.actions.act_window">
    <field name="name">Docs</field>
    <field name="res_model">documents.document</field>
    <field name="view_mode">kanban,list,form,activity</field>
  </record>
</odoo>
