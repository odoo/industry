  <record id="base_model_res_partner_x_meeting_focus_count_field" model="ir.model.fields">
    <field name="compute"><![CDATA[
for record in self:
    parent_article = self.env.ref('community_care.knowledge_article_team_meetings', raise_if_not_found=False)
    if not parent_article:
        parent_article = self.env['knowledge.article'].search([('name', '=', 'Team meetings')], limit=1)
    if not parent_article:
        record['x_meeting_focus_count'] = 0
        continue
    prop_name = '6839f9f644ed3af5'
    for prop in (parent_article.article_properties_definition or []):
        if prop.get('string') == 'Resident focus':
            prop_name = prop.get('name')
            break
    count = self.env['knowledge.article'].search_count([
        ('parent_id', '=', parent_article.id),
        ('is_article_item', '=', True),
        ('article_properties.%s' % prop_name, 'in', [record.id])
    ])
    record['x_meeting_focus_count'] = count
]]>    </field>
    <field name="ttype">integer</field>
    <field name="field_description">Meeting Focus Count</field>
    <field name="model_id" ref="base.model_res_partner"/>
    <field name="name">x_meeting_focus_count</field>
    <field name="selectable" eval="False"/>
    <field name="store" eval="False"/>
  </record>
