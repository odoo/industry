  <record id="base_model_res_partner_x_meeting_focus_count_field" model="ir.model.fields">
    <field name="compute"><![CDATA[
for record in self:
    record['x_meeting_focus_count'] = self.env['knowledge.article'].search_count([('article_properties.resident_focus', 'in', [record.id])]) if record.id else 0
]]></field>
    <field name="ttype">integer</field>
