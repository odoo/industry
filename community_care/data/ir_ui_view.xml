  <record id="x_res_partner_line_form_view" model="ir.ui.view">
    <field name="active" eval="True"/>
    <field name="model">x_res_partner_line</field>
    <field name="name">Default form view for x_res_partner_line</field>
    <field name="type">form</field>
    <field name="arch" type="xml">
      <form>
        <header/>
        <sheet string="res_partner_line">
          <div class="oe_title">
            <h1>
              <field name="x_name" required="1" placeholder="Name..."/>
            </h1>
          </div>
          <group name="group_details">
            <group name="group_details_left"/>
            <group name="group_details_right"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>
  <record id="x_res_partner_line_search_view" model="ir.ui.view">
    <field name="active" eval="True"/>
    <field name="model">x_res_partner_line</field>
    <field name="name">Default search view for x_res_partner_line</field>
