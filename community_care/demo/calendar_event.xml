<?xml version='1.0' encoding='UTF-8'?>
<odoo noupdate="1">
  <record id="calendar_event_1" model="calendar.event" context="{'no_mail_to_attendees': True, 'mail_notrack': True}">
    <field name="partner_ids" eval="[(6, 0, [ref('res_partner_8')])]"/>
    <field name="name">Ed U. Cator on Time Off : 32:00 hours</field>
    <field name="description"><![CDATA[<div><strong>Contact Details</strong><br>Ed U. Cator<br><a href="mailto:ed.u.cator@example.com">ed.u.cator@example.com</a></div>]]></field>
    <field name="user_id" ref="base.user_admin"/>
    <field name="privacy">confidential</field>
    <field name="duration">32.0</field>
    <field name="allday" eval="True"/>
    <field name="start_date" eval="DateTime.today().date() + relativedelta(days=3)" />
    <field name="stop_date" eval="DateTime.today().date() + relativedelta(days=6)"/>
    <field name="res_model_id" ref="hr_holidays.model_hr_leave"/>
    <field name="alarm_ids" eval="[(6, 0, [ref('calendar.alarm_notif_1')])]"/>
  </record>
</odoo>
