<?xml version='1.0' encoding='UTF-8'?>
<odoo noupdate="1">
  <record id="hr_leave_1" model="hr.leave">
    <field name="employee_id" ref="hr_employee_1" />
    <field name="work_entry_type_id" ref="hr_work_entry.generic_work_entry_type_unpaid_leave" />
    <field name="request_date_from" eval="datetime.today() + relativedelta(days=3)" />
    <field name="request_date_to" eval="datetime.today() + relativedelta(days=3)" />
    <field name="meeting_id" ref="calendar_event_1" />
  </record>
  <function model="hr.leave" name="action_approve">
    <value eval="[ref('hr_leave_1')]" />
  </function>
</odoo>
