#: model:ir.actions.server,name:hvac_services.update_fs_task_serials_on_delivery
msgid "Update FS Task Serials on Delivery"
msgstr ""
"Actualizar la serie de las tareas de servicio de campo en el momento de la "
"entrega"

#. module: hvac_services
#: model:ir.actions.server,name:hvac_services.update_fs_task_serials_on_create
msgid "Update FS Task Serials on create"
msgstr "Actualizar la serie de las tareas de servicio de campo al crear"

