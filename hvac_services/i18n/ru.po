msgstr "Через смарт-кнопки перейдите к документам товара."

#. module: hvac_services
#: model_terms:ir.ui.view,arch_db:hvac_services.welcome_article_body
msgid "HVAC Services"
msgstr "Системы ОВКВ"

#. module: hvac_services
#: model_terms:ir.ui.view,arch_db:hvac_services.welcome_article_body
