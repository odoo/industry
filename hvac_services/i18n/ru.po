#. module: hvac_services
#: model_terms:ir.ui.view,arch_db:hvac_services.welcome_article_body
msgid ""
"Efficiently order your providers with the <strong>\n"
"                    <font class=\"text-o-color-1\">Purchase Apps</font>\n"
"                </strong>."
