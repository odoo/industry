msgstr ""
"एक इनवॉइस बनाएं, जिसमें रिपोर्ट किए गए टाइमशीट इनपुट और जोड़े गए प्रॉडक्ट\n"
"                का खर्च शामिल होगा।"

#. module: hvac_services
#: model_terms:ir.ui.view,arch_db:hvac_services.welcome_article_body
msgid ""
"Create great quotations and manage your services in the <strong>\n"
"                    <font class=\"text-o-color-1\">Sales App</font>\n"
"                </strong>."
msgstr ""
"<strong>\n"
"                    <font class=\"text-o-color-1\">सेल्स ऐप</font>\n"
"                </strong> शानदार कोटेशन बनाएं और अपनी सेवाएं मैनेज करें।"

#. module: hvac_services
#: model_terms:ir.ui.view,arch_db:hvac_services.x_project_task_worksheet_template_search_view
