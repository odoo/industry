#: model:ir.model.fields,field_description:hvac_services.x_date_field
#: model_terms:ir.ui.view,arch_db:hvac_services.x_project_task_worksheet_template_form_view
#: model_terms:ir.ui.view,arch_db:hvac_services.x_project_task_worksheet_template_qweb_view
