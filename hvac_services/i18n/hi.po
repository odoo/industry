#. module: hvac_services
#: model_terms:ir.ui.view,arch_db:hvac_services.welcome_article_body
msgid "A customer call you for an incident on a device?"
msgstr "किसी डिवाइस पर हुई घटना के लिए ग्राहक आपको कॉल करता है?"

#. module: hvac_services
#: model_terms:ir.ui.view,arch_db:hvac_services.welcome_article_body
msgid ""
"A maintenance indicator is here to help you know at first sight whether this\n"
"                device is under ongoing maintenance contract or not."
msgstr ""
"यह जानने के लिए कि इस डिवाइस का रखरखाव का कॉन्ट्रैक्ट चल रहा है या नहीं, आपको\n"
"                पहली नज़र में ही मेंटनेंस इंडिकेटर यहां दिख जाएगा।"

#. module: hvac_services
#: model_terms:ir.ui.view,arch_db:hvac_services.welcome_article_body
msgid ""
"Access devices history and related field services from the <strong>\n"
"                    <font class=\"text-o-color-1\">Contacts App</font>\n"
"                </strong>."
msgstr ""
"<strong>\n"
"                    <font class=\"text-o-color-1\">कॉन्टैक्ट ऐप</font>\n"
"                </strong> से डिवाइस का इतिहास और संबंधित फ़ील्ड सर्विस ऐक्सेस करें।"

#. module: hvac_services
