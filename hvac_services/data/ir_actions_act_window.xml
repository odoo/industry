<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="get_maintenances_action" model="ir.actions.act_window">
        <field name="name">Maintenances</field>
        <field name="context">{'search_default_x_maintained_serials_ids': active_id,'default_x_maintained_serials_ids': [active_id]}</field>
        <field name="domain">[('x_maintained_serials_ids', '=', active_id)]</field>
        <field name="res_model">sale.order</field>
    </record>
    <record id="get_field_services_action" model="ir.actions.act_window">
        <field name="name">Field Services</field>
        <field name="context">{'search_default_x_serials': active_id,'default_x_serials': [active_id]}</field>
        <field name="domain">[('x_serials', '=', active_id)]</field>
        <field name="res_model">project.task</field>
    </record>
    <record id="display_stock_lot_view_with_maintenances" model="ir.actions.act_window">
        <field name="name">Stock lot for HVAC</field>
        <field name="res_model">stock.lot</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('partner_ids', 'child_of', active_ids)]</field>
    </record>
    <record id="x_new_devices_action" model="ir.actions.act_window">
        <field name="name">New Device</field>
        <field name="res_model">x_new_devices</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{
            'default_x_partner_id': active_id,
        }</field>
        <field name="binding_model_id" ref="base.model_res_partner"/>
        <field name="binding_view_types">form</field>
    </record>
    <record id="action_product_related_document" model="ir.actions.act_window">
        <field name="name">Documents</field>
        <field name="domain">[('res_id', '=', active_id)]</field>
        <field name="res_model">product.document</field>
    </record>
</odoo>
