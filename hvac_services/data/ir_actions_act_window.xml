<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="report_refrigerant_consumption_action" model="ir.actions.act_window">
        <field name="name">Refrigerant Consumption</field>
        <field name="domain">[('x_refrigerant_product','!=',False)]</field>
        <field name="res_model">x_project_task_worksheet_template_2</field>
        <field name="view_mode">pivot,form</field>
    </record>
    <record id="get_maintenances_action" model="ir.actions.act_window">
        <field name="name">Maintenances</field>
        <field name="context">{'search_default_x_maintained_serials': active_id,'default_x_maintained_serials': [active_id]}</field>
        <field name="domain">[('x_maintained_serials', '=', active_id)]</field>
        <field name="res_model">sale.order</field>
    </record>
    <record id="get_field_services_action" model="ir.actions.act_window">
        <field name="name">Field Services</field>
        <field name="context">{'search_default_x_serials': active_id,'default_x_serials': [active_id]}</field>
        <field name="domain">[('x_serials', '=', active_id)]</field>
        <field name="res_model">project.task</field>
    </record>
</odoo>
