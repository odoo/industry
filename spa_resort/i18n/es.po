#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid ""
"<strong>Events</strong> lets you create and manage workshops, wellness "
"weekends, or private retreats with online registration and ticketing."
msgstr ""
"La aplicación <strong>Eventos</strong> permite crear y gestionar talleres, "
"escapadas de bienestar o retiros privados con inscripción y venta de "
"entradas online."

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid "<strong>Gift Cards</strong>"
msgstr "<strong>Tarjetas regalo</strong>"

