#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid "<strong> Plan Shifts</strong>"
msgstr "<strong> Schichten planen</strong>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid ""
"<strong><b>Appointment App</b>: </strong>Manage bookings for spa entrances "
"and massages with a clear, flexible schedule that prevents double-booking."
"<br/>"
msgstr ""
"<strong><b>Termine-App</b>: </strong>Verwalten Sie Buchungen für Spa-Besuche "
"und Massagen mit einem übersichtlichen, flexiblen Zeitplan, der "
"Doppelbuchungen verhindert.<br/>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid ""
"<strong><b>Inventory App</b>: </strong>Monitor the consumption of wellness "
"products like essential oils and towels to ensure you are always prepared."
"<br/>"
msgstr ""
"<strong><b>Lager-App</b>: </strong>Überwachen Sie den Verbrauch von "
"Wellnessprodukten wie ätherischen Ölen und Handtüchern, damit Sie immer gut "
"vorbereitet sind.<br/>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid ""
"<strong><b>Planning App</b>: </strong>Organize your therapists' schedules "
"efficiently to match staff availability with treatment bookings.<br/>"
msgstr ""
"<strong><b>Planungsapp</b> : </strong>Organisieren Sie die Termine Ihrer "
"Therapeuten effizient, um die Verfügbarkeit Ihrer Mitarbeiter mit den "
"Behandlungsterminen abzustimmen.<br/>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid ""
"<strong><b>Point of Sale App</b>: </strong>Upsell relaxation by selling "
"tickets, cosmetics, and accessories like bathrobes directly at the reception."
"<br/>"
msgstr ""
"<strong><b>Kassensystemapp</b>: </strong>Steigern Sie Ihren Umsatz, indem "
"Sie Tickets, Kosmetikartikel und Accessoires wie Bademäntel direkt an der "
"Rezeption verkaufen.<br/>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid ""
"<strong><b>Sales App</b>: </strong>Handle complex bookings like group offers "
"and special spa packages by sending professional quotations.<br/>"
msgstr ""
"<strong><b>Verkaufsapp</b>: </strong>Bearbeiten Sie komplexe Buchungen wie "
"Gruppenangebote und spezielle Spa-Pakete, indem Sie professionelle Angebote "
"versenden.<br/>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid ""
"<strong><b>Website &amp; eCommerce App</b>: </strong>Showcase your wellness "
"menu online, allowing guests to book treatments and buy gift cards 24/7.<br/>"
msgstr ""
"<strong><b>Website- &amp; E-Commerce-App</b>: </strong>Präsentieren Sie Ihr "
"Wellnessangebot online, damit Gäste rund um die Uhr Behandlungen buchen und "
"Geschenkgutscheine kaufen können.<br/>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid ""
"<strong>Accounting</strong> helps you manage all finances, payments, and "
"reconciliations in one integrated system."
msgstr ""
"<strong>Odoo Buchhaltung</strong> hilft Ihnen, alle Finanzen, Zahlungen und "
"Abstimmungen in einem integrierten System zu verwalten."

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid "<strong>Coupons</strong>"
msgstr "<strong>Gutscheine </strong>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
