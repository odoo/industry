#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.homepage
msgid ""
"<span class=\"h3-fs\">Our philosophy is grounded in holistic wellness and "
"personalized care. What began as a small initiative has transformed into a "
"center committed to fostering health and well-being through tailored "
"programs and community engagement.</span>"
msgstr ""
"<span class=\"h3-fs\">Triết lý của chúng tôi dựa trên sức khỏe toàn diện và "
"chăm sóc cá nhân hóa. Những gì bắt đầu như một sáng kiến nhỏ đã trở thành "
"một trung tâm cam kết thúc đẩy sức khỏe và hạnh phúc thông qua các chương "
"trình được thiết kế riêng và sự gắn kết cộng đồng.</span>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid ""
"<span style=\"font-size: 30px;\">Basics</span><span class=\"h1-fs\">\n"
"        </span>"
msgstr ""
"<span style=\"font-size: 30px;\">Cơ bản</span><span class=\"h1-fs\">\n"
"       </span>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.homepage
msgid ""
"<strong>\n"
"                        <font class=\"text-o-color-1\">OUR PHILOSOPHY</"
"font>\n"
"                      </strong>"
msgstr ""
"<strong>\n"
"                        <font class=\"text-o-color-1\">PHƯƠNG CHÂM CỦA CHÚNG "
"TÔI</font>\n"
"                      </strong>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid "<strong> Plan Shifts</strong>"
msgstr "<strong>Kế hoạch ca làm</strong>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid ""
"<strong><b>Appointment App</b>: </strong>Manage bookings for spa entrances "
"and massages with a clear, flexible schedule that prevents double-booking."
"<br/>"
msgstr ""
"<strong><b>Ứng dụng Lịch hẹn</b>: </strong>Quản lý các đặt chỗ cho dịch vụ "
"spa và massage với lịch trình rõ ràng, linh hoạt giúp tránh đặt trùng lịch."
"<br/>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid ""
"<strong><b>Inventory App</b>: </strong>Monitor the consumption of wellness "
"products like essential oils and towels to ensure you are always prepared."
"<br/>"
msgstr ""
"<strong><b>Ứng dụng Tồn kho</b>: </strong>Theo dõi việc sử dụng các sản phẩm "
"chăm sóc sức khỏe như tinh dầu và khăn tắm để đảm bảo bạn luôn sẵn sàng.<br/>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid ""
"<strong><b>Planning App</b>: </strong>Organize your therapists' schedules "
"efficiently to match staff availability with treatment bookings.<br/>"
msgstr ""
"<strong><b>Ứng dụng Kế hoạch</b>: </strong>Sắp xếp lịch trình của các nhà "
"trị liệu một cách hiệu quả để khớp khung giờ rảnh của nhân viên với các lịch "
"hẹn điều trị.<br/>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid ""
"<strong><b>Point of Sale App</b>: </strong>Upsell relaxation by selling "
"tickets, cosmetics, and accessories like bathrobes directly at the reception."
"<br/>"
msgstr ""
"<strong><b>Ứng dụng POS</b>: </strong>Tăng doanh thu bằng cách bán vé, mỹ "
"phẩm và phụ kiện như áo choàng tắm trực tiếp tại quầy lễ tân.<br/>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid ""
"<strong><b>Sales App</b>: </strong>Handle complex bookings like group offers "
"and special spa packages by sending professional quotations.<br/>"
msgstr ""
"<strong><b>Ứng dụng Bán hàng</b>: </strong>Xử lý các đặt chỗ phức tạp như ưu "
"đãi nhóm và gói spa đặc biệt bằng cách gửi báo giá chuyên nghiệp.<br/>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid ""
"<strong><b>Website &amp; eCommerce App</b>: </strong>Showcase your wellness "
"menu online, allowing guests to book treatments and buy gift cards 24/7.<br/>"
msgstr ""
"<strong><b>Ứng dụng Trang web &amp; Thương mại điện tử</b>: </strong>Hiển "
"thị menu chăm sóc sức khỏe của bạn online, cho phép khách hàng đặt dịch vụ "
"và mua thẻ quà tặng 24/7.<br/>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid ""
"<strong>Accounting</strong> helps you manage all finances, payments, and "
"reconciliations in one integrated system."
msgstr ""
"<strong>Kế toán</strong> giúp bạn quản lý toàn bộ tình hình tài chính, thanh "
"toán và đối chiếu trong một hệ thống tích hợp duy nhất."

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid "<strong>Coupons</strong>"
msgstr "<strong>Phiếu giảm giá</strong>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid "<strong>Define Hours &amp; Roles</strong>"
msgstr "<strong>Xác định giờ &amp; vai trò</strong>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid ""
"<strong>Events</strong> lets you create and manage workshops, wellness "
"weekends, or private retreats with online registration and ticketing."
msgstr ""
"<strong>Sự kiện</strong> cho phép bạn tạo và quản lý các buổi workshop, cuối "
"tuần chăm sóc sức khỏe hoặc các kỳ nghỉ riêng tư với tính năng đăng ký và "
"bán vé trực tuyến."

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid "<strong>Gift Cards</strong>"
msgstr "<strong>Thẻ quà tặng</strong>"

