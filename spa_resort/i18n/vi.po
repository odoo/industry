#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid "<strong>Loyalty Cards, Gift Cards, Coupons &amp; Promo Codes</strong>"
msgstr ""
"<strong>Thẻ thành viên, Thẻ quà tặng, Phiếu giảm giá Mã khuyến mãi &amp;</"
"strong>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid "<strong>Loyalty Cards</strong>"
msgstr "<strong>Thẻ khách hàng thân thiết</strong>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid ""
"<strong>Maintenance</strong> schedules and monitors upkeep for spa equipment "
"such as saunas, massage tables, pools, and other installations."
msgstr ""
"<strong></strong>, phụ trách lập lịch và giám sát việc bảo dưỡng thiết bị "
"spa như phòng xông hơi, bàn massage, bể bơi và các thiết bị khác."

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid "<strong>Manage Purchases</strong>"
msgstr "<strong>Quản lý mua hàng</strong>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid "<strong>Point of Sale (POS) at Reception</strong>"
msgstr "<strong>POS tại quầy lễ tân</strong>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid "<strong>Promo Codes</strong>"
msgstr "<strong>Mã khuyến mãi</strong>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid "<strong>Quotations for Groups or Special Requests</strong>"
msgstr "<strong>Báo giá cho nhóm hoặc yêu cầu đặc biệt</strong>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid ""
"<strong>Restaurant/Bar Point of Sale</strong> allows you to sell food and "
"drinks if your spa resort offers a restaurant or bar service."
msgstr ""
"<strong>POS Nhà Hàng/Bar</strong> cho phép bạn bán đồ ăn và đồ uống nếu khu "
"nghỉ dưỡng spa của bạn có dịch vụ nhà hàng hoặc quầy bar."

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid "<strong>Set Pricelists</strong>"
msgstr "<strong>Thiết lập bảng giá</strong>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid "<strong>Set Up Appointments</strong>"
msgstr "<strong>Đặt lịch hẹn</strong>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid "<strong>Staff Access</strong>"
msgstr "<strong>Quyền truy cập của nhân viên</strong>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid "<strong>Track Products</strong>"
