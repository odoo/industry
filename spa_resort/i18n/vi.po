#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid "<strong>Website &amp; eCommerce</strong>"
msgstr "<strong>Trang web &amp; Thương mại điện tử</strong>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.wellness_access
msgid ""
"A full day of unlimited spa &amp;amp; sauna access. Perfect for unwinding "
"and leaving daily stress behind.&amp;nbsp;"
msgstr ""
"Một ngày trọn vẹn với quyền truy cập không giới hạn vào các dịch vụ spa "
"&amp;amp; và sauna. Hoàn hảo để thư giãn và xua tan căng thẳng hàng "
"ngày.&amp;nbsp;"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.massages_treatments
msgid ""
"A rejuvenating facial ritual designed to hydrate and brighten your skin, "
"leaving you refreshed and radiant."
msgstr ""
"Một liệu trình chăm sóc da mặt tái tạo, được thiết kế để cấp ẩm và làm sáng "
"da, mang lại cho bạn làn da tươi mới và rạng rỡ."

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.massages_treatments
msgid ""
"A targeted massage that works deep into the muscles to release tension and "
"improve circulation."
msgstr ""
"Một liệu pháp massage chuyên sâu tác động vào các cơ để giải phóng căng "
"thẳng và cải thiện tuần hoàn máu."

#. module: spa_resort
#: model:pos.category,name:spa_resort.pos_category_1
msgid "Accessories / Spa Essentials"
msgstr "Phụ kiện/Dụng cụ spa"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid "Adjust schedules quickly for peak hours or last-minute changes."
msgstr ""
"Điều chỉnh lịch trình nhanh chóng cho giờ cao điểm hoặc các thay đổi vào "
"phút chót."

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid ""
"Allow guests to book spa entries, massage sessions, or treatments online."
msgstr ""
"Cho phép khách hàng đặt lịch hẹn spa, các buổi massage hoặc các liệu trình "
"chăm sóc sức khỏe online."

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid "Applied automatically at checkout for eligible services."
msgstr "Được áp dụng tự động tại bước thanh toán cho các dịch vụ đủ điều kiện."

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid "Apply coupons, gift cards, or loyalty cards during the sale."
msgstr ""
"Áp dụng mã giảm giá, thẻ quà tặng hoặc thẻ thành viên trong thời gian khuyến "
"mãi."

#. module: spa_resort
#: model:product.template,name:spa_resort.product_product_25_product_template
msgid "Aromatherapy Massage Oil (100ml)"
msgstr "Dầu massage trị liệu bằng hương thơm (100ml)"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid ""
"Assign <strong>staff or resources</strong> (therapists, rooms, spa areas) to "
"each appointment."
msgstr ""
"Phân công <strong>nhân viên hoặc tài nguyên</strong> (như nhà trị liệu, "
"phòng khám, khu vực spa) cho từng lịch hẹn."

