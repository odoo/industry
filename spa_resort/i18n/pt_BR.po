#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid "<strong> Plan Shifts</strong>"
msgstr "<strong> Turnos do planejamento</strong>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid ""
"<strong><b>Appointment App</b>: </strong>Manage bookings for spa entrances "
"and massages with a clear, flexible schedule that prevents double-booking."
"<br/>"
msgstr ""
"<strong><b>App Agendamento</b>: </strong>Gerencie reservas para entradas no "
"spa e massagens com uma agenda clara e flexível que evita reservas "
"duplicadas.<br/>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid ""
"<strong><b>Inventory App</b>: </strong>Monitor the consumption of wellness "
"products like essential oils and towels to ensure you are always prepared."
"<br/>"
msgstr ""
"<strong><b>App Inventário</b>: </strong>Monitore o consumo de produtos de "
"bem-estar, como óleos essenciais e toalhas, para garantir que você esteja "
"sempre preparado.<br/>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid ""
"<strong><b>Planning App</b>: </strong>Organize your therapists' schedules "
"efficiently to match staff availability with treatment bookings.<br/>"
msgstr ""
"<strong><b>App Planejamento</b>: </strong>Organize a agenda dos seus "
"terapeutas de forma eficiente para combinar a disponibilidade da equipe com "
"as reservas de tratamentos.<br/>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid ""
"<strong><b>Point of Sale App</b>: </strong>Upsell relaxation by selling "
"tickets, cosmetics, and accessories like bathrobes directly at the reception."
"<br/>"
msgstr ""
"<strong><b>App Ponto de Venda</b>: </strong>Aumente as vendas vendendo "
"ingressos, cosméticos e acessórios, como roupões de banho, diretamente na "
"recepção.<br/>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid ""
"<strong><b>Sales App</b>: </strong>Handle complex bookings like group offers "
"and special spa packages by sending professional quotations.<br/>"
msgstr ""
"<strong><b>App Vendas</b>: </strong>Gerencie reservas complexas, como "
"ofertas para grupos e pacotes especiais de spa, enviando orçamentos "
"profissionais.<br/>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid ""
"<strong><b>Website &amp; eCommerce App</b>: </strong>Showcase your wellness "
"menu online, allowing guests to book treatments and buy gift cards 24/7.<br/>"
msgstr ""
"<strong><b>App Site e e-Commerce</b>: </strong>Apresente seu menu de bem-"
"estar online, permitindo que os hóspedes reservem tratamentos e comprem "
"cartões-presente 24 horas por dia, 7 dias por semana.<br/>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid ""
"<strong>Accounting</strong> helps you manage all finances, payments, and "
"reconciliations in one integrated system."
msgstr ""
"<strong>O Financeiro</strong> ajuda a gerenciar todas as finanças, "
"pagamentos e reconciliações em um sistema integrado."

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid "<strong>Coupons</strong>"
msgstr "<strong>Cupons </strong>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid "<strong>Define Hours &amp; Roles</strong>"
msgstr "<strong>Definir horas &amp; Funções</strong>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid ""
"<strong>Events</strong> lets you create and manage workshops, wellness "
"weekends, or private retreats with online registration and ticketing."
msgstr ""
"O app <strong>Eventos</strong> permite criar e gerenciar workshops, fins de "
"semana de bem-estar ou retiros privados, com inscrições e venda de ingressos "
"online."

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid "<strong>Gift Cards</strong>"
msgstr "<strong>Cartões-presente</strong>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid "<strong>Link Appointments to Products</strong>"
msgstr "<strong>Vincule compromissos a produtos</strong>"

