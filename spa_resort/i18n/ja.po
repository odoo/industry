msgstr ""
"<strong>整備</strong> サウナ、マッサージテーブル、プール、その他の設備など、"
"スパ設備の整備スケジュールと監視を行います。"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid "<strong>Manage Purchases</strong>"
msgstr "<strong>購買を管理する</strong>"

