#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid "<strong> Plan Shifts</strong>"
msgstr "<strong>Planifier les horaires</strong>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid ""
"<strong><b>Appointment App</b>: </strong>Manage bookings for spa entrances "
"and massages with a clear, flexible schedule that prevents double-booking."
"<br/>"
msgstr ""
"<strong><b>Application rendez-vous </b>: </strong>gérez les réservations "
"pour les accès au spa et les massages grâce à un planning clair et flexible "
"qui évite les doubles réservations.<br/>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid ""
"<strong><b>Inventory App</b>: </strong>Monitor the consumption of wellness "
"products like essential oils and towels to ensure you are always prepared."
"<br/>"
msgstr ""
"<strong><b>Application inventaire</b> : </strong>suivez la consommation des "
"produits wellness tels que les huiles essentielles et les serviettes afin "
"d’être toujours préparés.<br/>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid ""
"<strong><b>Planning App</b>: </strong>Organize your therapists' schedules "
"efficiently to match staff availability with treatment bookings.<br/>"
msgstr ""
"<strong><b>Application planification</b> : </strong>organisez efficacement "
"les agendas de vos thérapeutes afin d’aligner la disponibilité du personnel "
"avec les rendez-vous de soins.<br/>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid ""
"<strong><b>Point of Sale App</b>: </strong>Upsell relaxation by selling "
"tickets, cosmetics, and accessories like bathrobes directly at the reception."
"<br/>"
msgstr ""
"<strong><b>Application point de vente</b> : </strong>augmentez vos ventes en "
"proposant des tickets, des cosmétiques et des accessoires comme des "
"peignoirs directement à la réception.<br/>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid ""
"<strong><b>Sales App</b>: </strong>Handle complex bookings like group offers "
"and special spa packages by sending professional quotations.<br/>"
msgstr ""
"<strong><b>Application ventes</b> : </strong>gérez les réservations "
"complexes comme les offres de groupe et les forfaits spa spéciaux en "
"envoyant des devis professionnels.<br/>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid ""
"<strong><b>Website &amp; eCommerce App</b>: </strong>Showcase your wellness "
"menu online, allowing guests to book treatments and buy gift cards 24/7.<br/>"
msgstr ""
"<strong><b>Application site web &amp; eCommerce</b>: </strong>présentez "
"votre offre wellness en ligne afin que les clients puissent réserver des "
"soins et acheter des chèques-cadeaux 24/7.<br/>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid ""
"<strong>Accounting</strong> helps you manage all finances, payments, and "
"reconciliations in one integrated system."
msgstr ""
"L’application <strong>Comptabilité</strong> vous permet de gérer toutes vos "
"finances, paiements et réconciliations dans un système intégré."

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid "<strong>Coupons</strong>"
msgstr "<strong>Bons de réduction</strong>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid "<strong>Define Hours &amp; Roles</strong>"
msgstr "<strong>Définir les heures &amp; rôles</strong>"

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid ""
"<strong>Events</strong> lets you create and manage workshops, wellness "
"weekends, or private retreats with online registration and ticketing."
msgstr ""
"L’application <strong>Événements</strong> vous permet de créer et de gérer "
"des ateliers, des week-ends wellness ou des retraites privées avec "
"inscription et billetterie en ligne."

#. module: spa_resort
#: model_terms:ir.ui.view,arch_db:spa_resort.welcome_article_body
msgid "<strong>Gift Cards</strong>"
msgstr "<strong>Cartes-cadeaux</strong>"

