#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>CRM</strong>: Manages customer relationships, tracks leads and "
"inquiries, and boosts sales potential."
msgstr ""
"<strong>CRM</strong>: Zarządza relacjami z klientami, śledzi leady i "
"zapytania oraz zwiększa Twój potencjał sprzedaży."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Contacts</strong>: Organizes and stores client information for "
"personalized follow-ups."
msgstr ""
"<strong>Kontakty</strong>: Organizuje i przechowuje informacje klienta, aby "
"oferować spersonalizowane działania następcze."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid "<strong>Create a Product</strong>:"
