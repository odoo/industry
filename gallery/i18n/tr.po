#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Email &amp; Social Marketing</strong>: Promote upcoming exhibitions "
"and special sales across different platforms"
msgstr ""
"<strong>E-posta &amp; Sosyal Medyada Pazarlama</strong>: Yaklaşan sergileri "
"ve özel satışları farklı platformlarda tanıtın"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Events</strong>: Organize art exhibitions, artist meet-ups, and "
"gallery openings."
msgstr ""
"<strong>Etkinlikler</strong>: Sanat sergileri, sanatçı buluşmaları ve galeri "
"açılışları düzenleyin."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid "<strong>Extending the Workflow with Studio</strong>"
msgstr "<strong>Studio ile İş Akışını Genişletme</strong>"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid "<strong>Manage Online Visibility</strong>:"
