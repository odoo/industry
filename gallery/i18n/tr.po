#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>CRM</strong>: Manages customer relationships, tracks leads and "
"inquiries, and boosts sales potential."
msgstr ""
"<strong>CRM</strong>: Müşteri ilişkilerini yönetir, potansiyel müşterileri "
"ve talepleri takip eder ve satış potansiyelini artırır."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Contacts</strong>: Organizes and stores client information for "
"personalized follow-ups."
msgstr ""
"<strong>Kişiler</strong>: Kişiselleştirilmiş takipler için müşteri "
"bilgilerini düzenler ve saklar."

