#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>CRM</strong>: Manages customer relationships, tracks leads and "
"inquiries, and boosts sales potential."
msgstr ""
"<strong>CRM</strong>: Hallinnoi asiakassuhteita, seuraa liidejä ja "
"tiedusteluja ja maksimoi myyntipotentiaali."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Contacts</strong>: Organizes and stores client information for "
"personalized follow-ups."
msgstr ""
"<strong>Yhteystiedot</strong>: Järjestä ja tallenna asiakastiedot "
"personoituja yhteydenottoja varten."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
