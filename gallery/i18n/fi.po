#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Email &amp; Social Marketing</strong>: Promote upcoming exhibitions "
"and special sales across different platforms"
msgstr ""
"<strong>Sähköposti &amp; Somemarkkinointi</strong>: Mainosta tulevia "
"näyttelyitä ja erikoismyyntejä eri alustoilla."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Events</strong>: Organize art exhibitions, artist meet-ups, and "
"gallery openings."
msgstr ""
"<strong>Tapahtumat</strong>: Järjestä taidenäyttelyitä, taiteilijatapaamisia "
"ja gallerian avajaisia."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
