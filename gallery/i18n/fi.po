msgstr "<strong>Julkaise taideteos</strong>:"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Purchase</strong>: Helps manage vendor relationships and streamline "
"procurement processes."
msgstr ""
"<strong>Ostot</strong>: Hallinnoi suhteita toimittajiin ja tehosta "
"ostoprosesseja."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
