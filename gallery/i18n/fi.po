#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Marketing Automation</strong>: Engage potential buyers with "
"personalized campaigns and newsletters."
msgstr ""
"<strong>Markkinoinnin automaatio</strong>: Vedä puoleesi potentiaalisia "
"ostajia personoiduilla kampanjoilla ja uutiskirjeillä."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Memberships &amp; Subscriptions</strong>: Offer exclusive content, "
"VIP access, and limited-event participation."
msgstr ""
"<strong>Jäsenyydet &amp; tilaukset</strong>: Tarjoa eksklusiivista sisältöä, "
"VIP-pääsy ja rajattuja tapahtumia."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.ir_ui_view_3577
msgid ""
"<strong>My Gallery</strong>\n"
"                      <br/>"
msgstr ""
"<strong>Galleriani</strong>\n"
"                      <br/>"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>POS</strong>: Enables fast, in-store transactions for walk-in "
"customers."
msgstr ""
"<strong>Kassajärjestelmä</strong>: Mahdollistaa nopeat ostot ja maksut "
"myymälässä asioiville asiakkaille."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Projects</strong>: Manage large-scale exhibitions or arts festivals, "
"integrating planning, tasks, and team collaboration."
msgstr ""
"<strong>Projektit</strong>: Hallinnoi suuria näyttelyitä tai "
"taidefestivaaleja: suunnittelu, tehtävät ja tiimityö yhdessä paikassa."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
