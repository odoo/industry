#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid "<strong>Create a Purchase Order</strong>:"
msgstr "<strong>Tạo một đơn mua hàng</strong>:"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Email &amp; Social Marketing</strong>: Promote upcoming exhibitions "
"and special sales across different platforms"
msgstr ""
"<strong>Marketing qua email & qua MXH</strong>: Quảng bá các triển lãm sắp "
"tới và chương trình khuyến mại đặc biệt trên nhiều nền tảng khác nhau."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Events</strong>: Organize art exhibitions, artist meet-ups, and "
"gallery openings."
msgstr ""
"<strong>Sự kiện</strong>: Tổ chức các buổi triển lãm nghệ thuật, gặp gỡ nghệ "
"sĩ và khai trương phòng trưng bày."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid "<strong>Extending the Workflow with Studio</strong>"
msgstr "<strong>Mở rộng chức năng với Studio</strong>"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid "<strong>Manage Online Visibility</strong>:"
msgstr "<strong>Quản lý phòng trưng bày trên môi trường số</strong>:"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid "<strong>Manage your agreements 📝</strong>"
msgstr "<strong>Quản lý hợp đồng 📝</strong>"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid "<strong>Managing Commissions  👩‍🎨</strong>"
msgstr "<strong>Quản lý hoa hồng 👩‍🎨</strong>"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Marketing Automation</strong>: Engage potential buyers with "
"personalized campaigns and newsletters."
msgstr ""
"<strong>Tự động hóa marketing</strong>: Thu hút người mua tiềm năng bằng các "
"chiến dịch và bản tin email được cá nhân hóa."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Memberships &amp; Subscriptions</strong>: Offer exclusive content, "
"VIP access, and limited-event participation."
msgstr ""
"<strong>Thành viên & Đăng ký</strong>: Cung cấp nội dung độc quyền, quyền "
"truy cập VIP và tham gia sự kiện giới hạn."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.ir_ui_view_3577
msgid ""
"<strong>My Gallery</strong>\n"
"                      <br/>"
msgstr ""
"<strong>My Gallery</strong>\n"
"                      <br/>"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>POS</strong>: Enables fast, in-store transactions for walk-in "
"customers."
msgstr ""
"<strong>POS</strong>: Hỗ trợ giao dịch nhanh chóng tại chỗ cho khách đến "
"trực tiếp."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Projects</strong>: Manage large-scale exhibitions or arts festivals, "
"integrating planning, tasks, and team collaboration."
msgstr ""
"<strong>Dự án</strong>: Quản lý các triển lãm quy mô lớn hoặc lễ hội nghệ "
"thuật, tích hợp kế hoạch, nhiệm vụ và hợp tác nhóm."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid "<strong>Publish the Artwork</strong>:"
msgstr "<strong>Đăng tác phẩm nghệ thuật</strong>:"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Purchase</strong>: Helps manage vendor relationships and streamline "
"procurement processes."
msgstr ""
"<strong>Mua hàng</strong>: Hỗ trợ quản lý mối quan hệ với nhà cung cấp và "
"đơn giản hóa quy trình mua sắm."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid "<strong>Receive the Artwork</strong>:"
msgstr "<strong>Nhận tác phẩm nghệ thuật</strong>:"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Sales</strong>: Validates orders, creates custom quotations, and "
"streamlines the sales process."
msgstr ""
"<strong>Bán hàng</strong>: Xác nhận đơn hàng, tạo báo giá tùy chỉnh và tối "
"ưu hóa quy trình bán hàng."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid "<strong>Track New Artwork Opportunities</strong>:"
msgstr "<strong>Theo dõi cơ hội tác phẩm nghệ thuật mới</strong>:"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.ir_ui_view_1680
msgid "<strong>We are MyGallery.</strong>"
msgstr "<strong>Chúng tôi là MyGallery.</strong>"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Website &amp; eCommerce</strong>: Your gallery’s online storefront, "
"where customers can browse and purchase artworks anytime, anywhere."
msgstr ""
"<strong>Trang web & Thương mại điện tử</strong>: Cửa hàng online cho phòng "
"trưng bày của bạn, nơi khách hàng có thể xem và mua tác phẩm nghệ thuật mọi "
"lúc, mọi nơi."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"A potential buyer has inquired about an artwork—how exciting! Let’s go "
"through the steps to turn this inquiry into a sale."
msgstr ""
"Một người mua tiềm năng vừa hỏi về một tác phẩm nghệ thuật — thật tuyệt! Hãy "
"xem các bước để biến yêu cầu này thành một giao dịch thành công."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"Accept various payment methods, including cash, credit cards, and mobile "
"payments."
msgstr ""
"Chấp nhận nhiều phương thức thanh toán khác nhau, bao gồm tiền mặt, thẻ và "
"thanh toán qua ứng dụng di động."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"Acquiring new pieces for your gallery is seamless with <strong>CRM</strong> "
"and the <strong>Purchase App</strong>."
msgstr ""
"Việc tiếp nhận tác phẩm mới cho phòng trưng bày của bạn trở nên dễ dàng với "
"ứng dụng <strong>CRM</strong> và <strong>Mua hàng</strong>."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"Add detailed product pages with high-resolution images, descriptions, and "
"pricing."
msgstr ""
"Thêm trang sản phẩm chi tiết với hình ảnh độ phân giải cao, mô tả và giá bán."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"Add tags to your contacts to make it easy to sort between Artists and "
"Customers"
msgstr ""
"Thêm thẻ vào các liên hệ của bạn để dễ dàng phân loại Nghệ sĩ và Khách hàng."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"Add the artwork as a product, specifying quantity, price, and expected "
"delivery date."
msgstr ""
"Thêm tác phẩm nghệ thuật như một sản phẩm, đồng thời chỉ định số lượng, giá "
"bán và ngày giao hàng dự kiến."

