#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Accounting</strong>: Easily generate tax reports and other financial "
"documents thanks to our localization packages."
msgstr ""
"<strong>Buchhaltung:</strong> Dank unserer Lokalisierungspakete können Sie "
"Steuerberichte und andere Finanzdokumente ganz einfach erstellen."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid "<strong>Add Images &amp; Categorization</strong>:"
msgstr "<strong>Bilder &amp; Kategorisierung hinzufügen</strong>:"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>CRM</strong>: Manages customer relationships, tracks leads and "
"inquiries, and boosts sales potential."
msgstr ""
"<strong>CRM</strong>: Verwaltet Kundenbeziehungen, verfolgt Leads und "
"Anfragen und steigert das Umsatzpotenzial."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Contacts</strong>: Organizes and stores client information for "
"personalized follow-ups."
msgstr ""
"<strong>Kontakte</strong>: Organisiert und speichert Kundeninformationen für "
"personalisierte Nachfassaktionen."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid "<strong>Create a Product</strong>:"
msgstr "<strong>Ein Produkt erstellen</strong>:"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid "<strong>Create a Purchase Order</strong>:"
msgstr "<strong>Eine Bestellung erstellen</strong>:"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Email &amp; Social Marketing</strong>: Promote upcoming exhibitions "
"and special sales across different platforms"
msgstr ""
"<strong>E-Mail-Marketing &amp; Social Marketing</strong>: Bewerben Sie "
"bevorstehende Ausstellungen und Sonderverkäufe auf verschiedenen Plattformen."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Events</strong>: Organize art exhibitions, artist meet-ups, and "
"gallery openings."
msgstr ""
"<strong>Veranstaltungen</strong>: Organisieren Sie Kunstausstellungen, "
"Künstlertreffen und Galerieeröffnungen."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid "<strong>Extending the Workflow with Studio</strong>"
msgstr "<strong>Arbeitsablauf mit Studio erweitern</strong>"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid "<strong>Manage Online Visibility</strong>:"
msgstr "<strong>Online-Sichtbarkeit verwalten</strong>:"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid "<strong>Manage your agreements 📝</strong>"
msgstr "<strong>Vereinbarungen verwalten 📝</strong>"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid "<strong>Managing Commissions  👩‍🎨</strong>"
msgstr "<strong>Provisionen verwalten 👩‍🎨</strong>"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Marketing Automation</strong>: Engage potential buyers with "
"personalized campaigns and newsletters."
msgstr ""
"<strong>Marketing-Automatisierung</strong>: Binden Sie potenzielle Käufer "
"mit personalisierten Kampagnen und Newslettern."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Memberships &amp; Subscriptions</strong>: Offer exclusive content, "
"VIP access, and limited-event participation."
msgstr ""
"<strong>Mitgliedschaft &amp; Abonnements</strong>: Bieten Sie exklusive "
"Inhalte, VIP-Zugang und die Teilnahme an limitierten Veranstaltungen an."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.ir_ui_view_3577
msgid ""
"<strong>My Gallery</strong>\n"
"                      <br/>"
msgstr ""
"<strong>Meine Galerie</strong>\n"
"                      <br/>"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>POS</strong>: Enables fast, in-store transactions for walk-in "
"customers."
msgstr ""
"<strong>Kassensystem</strong>: Ermöglicht schnelle Transaktionen im Geschäft "
"für Laufkundschaft."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Projects</strong>: Manage large-scale exhibitions or arts festivals, "
"integrating planning, tasks, and team collaboration."
msgstr ""
"<strong>Projekte</strong>: Organisieren Sie umfangreiche Ausstellungen oder "
"Kunstfestivals und koordinieren Sie dabei Planung, Aufgaben und Teamarbeit."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid "<strong>Publish the Artwork</strong>:"
msgstr "<strong>Kunstwerk veröffentlichen</strong>:"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Purchase</strong>: Helps manage vendor relationships and streamline "
"procurement processes."
msgstr ""
"<strong>Einkauf</strong>: Unterstützt die Verwaltung von "
"Lieferantenbeziehungen und optimiert Beschaffungsprozesse."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid "<strong>Receive the Artwork</strong>:"
msgstr "<strong>Kunstwerk erhalten</strong>:"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Sales</strong>: Validates orders, creates custom quotations, and "
"streamlines the sales process."
msgstr ""
"<strong>Verkauf</strong>: Validiert Bestellungen, erstellt individuelle "
"Angebote und optimiert den Verkaufsprozess."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid "<strong>Track New Artwork Opportunities</strong>:"
msgstr "<strong>Chancen auf neue Kunstwerke verfolgen</strong>:"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.ir_ui_view_1680
msgid "<strong>We are MyGallery.</strong>"
msgstr "<strong>Wir sind MeineGalerie.</strong>"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Website &amp; eCommerce</strong>: Your gallery’s online storefront, "
"where customers can browse and purchase artworks anytime, anywhere."
msgstr ""
"<strong>Website &amp; E-Commerce</strong>: Der Onlineshop Ihrer Galerie, in "
"dem Kunden jederzeit und überall Kunstwerke ansehen und erwerben können."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"A potential buyer has inquired about an artwork—how exciting! Let’s go "
"through the steps to turn this inquiry into a sale."
msgstr ""
"Ein potenzieller Käufer hat sich nach einem Kunstwerk erkundigt – wie "
"aufregend! Lassen Sie uns die Schritte durchgehen, um diese Anfrage in einen "
"Verkauf umzuwandeln."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"Accept various payment methods, including cash, credit cards, and mobile "
"payments."
msgstr ""
"Akzeptieren Sie verschiedene Zahlungsmethoden, einschließlich Bargeld, "
"Kreditkarten und mobile Zahlungen."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"Acquiring new pieces for your gallery is seamless with <strong>CRM</strong> "
"and the <strong>Purchase App</strong>."
msgstr ""
"Mit der <strong>CRM-</strong> und der <strong>Einkaufsapp</strong> ist die "
"Anschaffung neuer Werke für Ihre Galerie ein reibungsloser Vorgang."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"Add detailed product pages with high-resolution images, descriptions, and "
"pricing."
msgstr ""
"Fügen Sie detaillierte Produktseiten mit hochauflösenden Bildern, "
"Beschreibungen und Preisen hinzu."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"Add tags to your contacts to make it easy to sort between Artists and "
"Customers"
msgstr ""
"Fügen Sie Ihren Kontakten Stichwörter hinzu, um sie einfach nach Künstlern "
"und Kunden sortieren zu können."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"Add the artwork as a product, specifying quantity, price, and expected "
"delivery date."
msgstr ""
"Fügen Sie das Kunstwerk als Produkt hinzu und geben Sie die Menge, den Preis "
"und den voraussichtlichen Liefertermin an."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid "Adding Artwork to Your Collection 🎨"
msgstr "Kunstwerke zur Kollektion hinzufügen 🎨"

