#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Accounting</strong>: Easily generate tax reports and other financial "
"documents thanks to our localization packages."
msgstr ""
"<strong>Bogføring</strong>: Generér nemt skatterapporter og andre "
"finansielle dokumenter med hjælp fra vores lokaliseringspakker."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid "<strong>Add Images &amp; Categorization</strong>:"
msgstr "<strong>Tilføj billeder og kategorisering</strong>:"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>CRM</strong>: Manages customer relationships, tracks leads and "
"inquiries, and boosts sales potential."
msgstr ""
"<strong>CRM</strong>: Administrerer kundeforhold, sporer leads og "
"forespørgsler samt øger omsætningspotentialet."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Contacts</strong>: Organizes and stores client information for "
"personalized follow-ups."
msgstr ""
"<strong>Kontakter</strong>: Organiserer og gemmer kundeoplysninger med "
"henblik på personlig opfølgning."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid "<strong>Create a Product</strong>:"
msgstr "<strong>Opret et produkt</strong>:"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid "<strong>Create a Purchase Order</strong>:"
msgstr "<strong>Opret en indkøbsordre</strong>:"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Email &amp; Social Marketing</strong>: Promote upcoming exhibitions "
"and special sales across different platforms"
msgstr ""
"<strong>E-mail og markedsføring af sociale medier</strong>: Markedsfør "
"kommende udstillinger og særlige tilbud på flere platforme"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Events</strong>: Organize art exhibitions, artist meet-ups, and "
"gallery openings."
msgstr ""
"<strong>Arrangementer</strong>: Organisér kunstudstillinger, kunstnermøder "
"og galleriåbninger."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid "<strong>Extending the Workflow with Studio</strong>"
msgstr "<strong>Udvid din arbejdsgang med Studio</strong>"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid "<strong>Manage Online Visibility</strong>:"
msgstr "<strong>Håndtér synlighed online</strong>:"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid "<strong>Manage your agreements 📝</strong>"
msgstr "<strong>Administrér dine aftaler 📝</strong>"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid "<strong>Managing Commissions  👩‍🎨</strong>"
msgstr "<strong>Administrér provisioner  👩‍🎨</strong>"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Marketing Automation</strong>: Engage potential buyers with "
"personalized campaigns and newsletters."
msgstr ""
"<strong>Automatiseret marketing</strong>: Engagér potentielle købere gennem "
"personlige kampagner og nyhedsbreve."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Memberships &amp; Subscriptions</strong>: Offer exclusive content, "
"VIP access, and limited-event participation."
msgstr ""
"<strong>Medlemskab og abonnementer</strong>: Tilbyd eksklusivt indhold, VIP-"
"adgang og adgang til særlige arrangementer."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.ir_ui_view_3577
msgid ""
"<strong>My Gallery</strong>\n"
"                      <br/>"
msgstr ""
"<strong>Mit galleri</strong>\n"
"                      <br/>"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>POS</strong>: Enables fast, in-store transactions for walk-in "
"customers."
msgstr ""
"<strong>POS</strong>: Gør det nemt for kunder at gennemføre hurtige køb i "
"butikken."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Projects</strong>: Manage large-scale exhibitions or arts festivals, "
"integrating planning, tasks, and team collaboration."
msgstr ""
"<strong>Projekter</strong>: Planlæg og gennemfør store udstillinger eller "
"kunstfestivaler, og styr koordinering af opgaver og teamwork."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid "<strong>Publish the Artwork</strong>:"
msgstr "<strong>Offentliggør kunstværket</strong>:"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Purchase</strong>: Helps manage vendor relationships and streamline "
"procurement processes."
msgstr ""
"<strong>Indkøb</strong>: Hjælper med at administrere leverandørrelationer og "
"effektivisere indkøbsprocesser."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid "<strong>Receive the Artwork</strong>:"
msgstr "<strong>Modtag kunstværket</strong>:"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Sales</strong>: Validates orders, creates custom quotations, and "
"streamlines the sales process."
msgstr ""
"<strong>Salg</strong>: Validerer ordrer, opretter tilpassede tilbud og "
"strømliner salgsprocessen."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid "<strong>Track New Artwork Opportunities</strong>:"
msgstr "<strong>Identificér nye muligheder for kunstværker</strong>:"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.ir_ui_view_1680
msgid "<strong>We are MyGallery.</strong>"
msgstr "<strong>Vi er MitGalleri.</strong>"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Website &amp; eCommerce</strong>: Your gallery’s online storefront, "
"where customers can browse and purchase artworks anytime, anywhere."
msgstr ""
"<strong>Hjemmeside og e-Handel</strong>: Dit galleris onlinebutik – hvor "
"kunder kan browse og købe kunstværker når som helst og hvor som helst."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"A potential buyer has inquired about an artwork—how exciting! Let’s go "
"through the steps to turn this inquiry into a sale."
msgstr ""
"En potentiel køber har vist interesse for et kunstværk – hvor spændende! Lad "
"os gennemgå trinnene for at omsætte forespørgslen til et salg."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"Accept various payment methods, including cash, credit cards, and mobile "
"payments."
msgstr ""
"Accepter forskellige betalingsformer, herunder kontanter, kreditkort og "
"mobilbetalinger."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"Acquiring new pieces for your gallery is seamless with <strong>CRM</strong> "
"and the <strong>Purchase App</strong>."
msgstr ""
"Det er nemt at erhverve nye værker til dit galleri med <strong>CRM</strong> "
"og <strong>Indkøbsappen</strong>."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"Add detailed product pages with high-resolution images, descriptions, and "
"pricing."
msgstr ""
"Tilføj detaljerede produktsider med billeder i høj opløsning, beskrivelser "
"og priser."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"Add tags to your contacts to make it easy to sort between Artists and "
"Customers"
msgstr ""
"Tilføj tags til dine kontakter, så du nemt kan sortere dem efter kunstnere "
"og kunder"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"Add the artwork as a product, specifying quantity, price, and expected "
"delivery date."
msgstr ""
"Tilføj kunstværket som produkt, og angiv mængde, pris samt forventet "
"leveringsdato."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid "Adding Artwork to Your Collection 🎨"
msgstr "Føj kunstværker til kollektionen 🎨"

