#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>CRM</strong>: Manages customer relationships, tracks leads and "
"inquiries, and boosts sales potential."
msgstr ""
"<strong>सीआरएम</strong>: ग्राहकों को संभालता है, लीड और पूछताछ को ट्रैक करता है, और "
"सेल्स की संभावना को बढ़ाता है।"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Contacts</strong>: Organizes and stores client information for "
"personalized follow-ups."
msgstr ""
"<strong>कॉन्टैक्ट</strong>: क्लाइंट की जानकारी व्यवस्थित करता है और सेव करता है, ताकि "
"उनकी ज़रूरतों के हिसाब से उनसे बातचीत की जा सके।"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid "<strong>Create a Product</strong>:"
msgstr "<strong>प्रॉडक्ट बनाएं</strong>:"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid "<strong>Create a Purchase Order</strong>:"
