#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Accounting</strong>: Easily generate tax reports and other financial "
"documents thanks to our localization packages."
msgstr ""
"<strong>Comptabilité</strong> : générez facilement des rapports fiscaux et "
"d’autres documents financiers grâce à nos packs de localisation."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid "<strong>Add Images &amp; Categorization</strong>:"
msgstr "<strong>Ajouter des images et une catégorisation</strong> :"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>CRM</strong>: Manages customer relationships, tracks leads and "
"inquiries, and boosts sales potential."
msgstr ""
"<strong>CRM</strong> : gère les relations clients, suit les pistes et les "
"demandes et stimule le potentiel de vente."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Contacts</strong>: Organizes and stores client information for "
"personalized follow-ups."
msgstr ""
"<strong>Contacts</strong> : organise et stocke les informations clients pour "
"des suivis personnalisés."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid "<strong>Create a Product</strong>:"
msgstr "<strong>Créer un produit</strong> :"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid "<strong>Create a Purchase Order</strong>:"
msgstr "<strong>Créer un bon de commande</strong> :"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Email &amp; Social Marketing</strong>: Promote upcoming exhibitions "
"and special sales across different platforms"
msgstr ""
"<strong>E-mail Marketing &amp; Social Marketing</strong> : promouvez les "
"expositions à venir et les ventes spéciales sur différentes plateformes"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"<strong>Events</strong>: Organize art exhibitions, artist meet-ups, and "
"gallery openings."
msgstr ""
"<strong>Événements</strong> : organisez des expositions d’art, des "
"rencontres avec des artistes et des ouvertures de galeries."

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid "<strong>Extending the Workflow with Studio</strong>"
msgstr "<strong>Étendre le workflow avec Studio</strong>"

#. module: gallery
#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid "<strong>Manage Online Visibility</strong>:"
msgstr "<strong>Gérer la visibilité en ligne</strong> :"

