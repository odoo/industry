#: model_terms:ir.ui.view,arch_db:gallery.welcome_article_body
msgid ""
"Assign the correct <strong>Product Category</strong> (e.g., Paintings, "
"Sculptures, Prints)."
msgstr ""
"Asigna la <strong>categoría de producto</strong> correcta (pintura, "
