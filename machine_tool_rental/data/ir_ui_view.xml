<?xml version='1.0' encoding='UTF-8'?>
<odoo>
  <record id="x_run_time_meter_form_view" model="ir.ui.view">
    <field name="name">Default form view for x_run_time_meter</field>
    <field name="model">x_run_time_meter</field>
    <field name="active" eval="True"/>
    <field name="type">form</field>
    <field name="arch" type="xml">
      <form>
        <header/>
        <sheet string="Run-Time Meter">
          <widget name="web_ribbon" text="Archived" bg_color="text-bg-danger" invisible="x_active"/>
          <field name="x_active" invisible="1"/>
          <group name="main_details">
            <group name="left_column"/>
            <group name="right_column"/>
          </group>
          <group>
            <field name="x_notes" placeholder="Type down your notes here..." nolabel="1" colspan="2"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>
  <record id="x_run_time_meter_search_view" model="ir.ui.view">
    <field name="name">Default search view for x_run_time_meter</field>
    <field name="model">x_run_time_meter</field>
    <field name="active" eval="True"/>
    <field name="type">search</field>
    <field name="arch" type="xml">
      <search>
        <field name="x_serial"/>
        <field name="x_product"/>
        <separator/>
        <filter string="Archived" name="archived_x_run_time_meter" domain="[['x_active', '=', False]]"/>
        <separator/>
      </search>
    </field>
  </record>
  <record id="x_run_time_meter_form_custom" model="ir.ui.view">
    <field name="name">Default form view for x_run_time_meter customization</field>
    <field name="inherit_id" ref="x_run_time_meter_form_view"/>
    <field name="mode">extension</field>
    <field name="active" eval="True"/>
    <field name="model">x_run_time_meter</field>
    <field name="priority">99</field>
    <field name="type">form</field>
    <field name="arch" type="xml">
      <data>
        <xpath expr="//group[@name='left_column']" position="inside">
          <field name="x_product" required="True" domain="[(&quot;rent_ok&quot;, &quot;!=&quot;, False)]"/>
          <field name="x_serial" required="True" domain="[]"/>
        </xpath>
        <xpath expr="//group[@name='right_column']" position="inside">
          <field name="x_date" options="{&quot;warn_future&quot;:true}" required="True"/>
          <field name="x_run_time" options="{&quot;digits&quot;:[2,1]}" required="True" string="Run-Time (h)"/>
          <field name="x_run_time_increment_h"/>
        </xpath>
      </data>
    </field>
  </record>
  <record id="x_run_time_meter_list_custom" model="ir.ui.view">
    <field name="name">Default list view for x_run_time_meter customization</field>
    <field name="model">x_run_time_meter</field>
    <field name="active" eval="True"/>
    <field name="priority">99</field>
    <field name="arch" type="xml">
       <list default_group_by="x_serial" default_order="x_date desc">
         <field name="x_date" optional="show"/>
         <field name="x_product" optional="show"/>
         <field name="x_serial" optional="show"/>
         <field name="x_run_time_increment_h" optional="show"/>
         <field name="x_run_time" optional="show"/>
       </list>
    </field>
  </record>
  <record id="x_run_time_meter_graph_view" model="ir.ui.view" context="{'studio': True}">
    <field name="name">Graph view for Run Time Meter</field>
    <field name="model">x_run_time_meter</field>
    <field name="priority">99</field>
    <field name="arch" type="xml">
      <graph string="Run Time Meter" type="line" stacked="False">
            <field name="x_date" type="col"/>
            <field name="x_serial" type="col"/>
            <field name="x_run_time_increment_h" type="measure"/>
      </graph>
    </field>
  </record>
  <record id="stock_production_lot_form_custom" model="ir.ui.view">
    <field name="name">stock.production.lot.form customization</field>
    <field name="inherit_id" ref="stock.view_production_lot_form"/>
    <field name="mode">extension</field>
    <field name="model">stock.lot</field>
    <field name="active" eval="True"/>
    <field name="priority">160</field>
    <field name="type">form</field>
    <field name="arch" type="xml">
      <data>
        <xpath expr="//button[@name='action_view_stock_valuation_layers']" position="after">
          <button class="oe_stat_button" icon="fa-clock-o" type="action" name="%(run_time_meters_eb6cfd1a-85bd-4ae7-a596-d4a46dff6c37)d">
            <field widget="statinfo" name="x_x_serial_x_run_time_meter_count" string="Run-Time"/>
          </button>
          <button class="oe_stat_button" icon="fa-rotate-right" type="action" name="%(maintenance_0a3a4c50-920f-4497-826d-c4dffe37b04b)d">
            <field widget="statinfo" name="x_x_serial_project_task_count" string="Maintenance"/>
          </button>
        </xpath>
        <xpath expr="//field[@name='location_id']" position="after">
          <field name="x_run_time_meter_h" options="{&quot;digits&quot;:[2,1]}"/>
        </xpath>
        <xpath expr="//field[@name='name']" position="after">
          <widget name="web_ribbon" title="Available" invisible="x_status != 'Available'"/>
          <widget name="web_ribbon" title="Out" invisible="x_status != 'Out'" bg_color="text-bg-danger"/>
          <widget name="web_ribbon" title="Reception" invisible="x_status != 'Reception'" bg_color="text-bg-warninbg"/>
          <widget name="web_ribbon" title="Maintenance" invisible="x_status != 'Maintenance'" bg_color="text-bg-warninbg"/>
        </xpath>
      </data>
    </field>
  </record>
  <record id="stock_production_lot_list_custom" model="ir.ui.view">
    <field name="name">stock.production.lot.list customization</field>
    <field name="inherit_id" ref="stock.view_production_lot_tree"/>
    <field name="mode">extension</field>
    <field name="model">stock.lot</field>
    <field name="active" eval="True"/>
    <field name="priority">99</field>
    <field name="type">list</field>
    <field name="arch" type="xml">
      <data>
        <xpath expr="//field[@name='activity_ids']" position="replace"/>
        <xpath expr="//field[@name='create_date']" position="replace">
          <field name="x_run_time_meter_h" optional="show"/>
          <field name="location_id" optional="show"/>
          <field name="x_status" optional="show" widget="badge" decoration-success="x_status == 'Available'" decoration-danger="x_status == 'Out'" decoration-warning="x_status == 'Reception' or x_status == 'Maintenance'"/>
        </xpath>
        <xpath expr="//field[@name='ref']" position="replace"/>
      </data>
    </field>
  </record>
  <record id="rental_order_form_custom" model="ir.ui.view">
    <field name="name">rental.order.form customization</field>
    <field name="inherit_id" ref="sale_renting.rental_order_primary_form_view"/>
    <field name="mode">extension</field>
    <field name="model">sale.order</field>
    <field name="active" eval="True"/>
    <field name="priority">160</field>
    <field name="type">form</field>
    <field name="arch" type="xml">
      <data>
        <xpath expr="//field[@name='is_rental_order']" position="after">
          <button string="Record Run-Time" type="action" invisible="rental_status != &quot;returned&quot;" name="%(industry_record_run__61707535-5357-4c39-a25a-ffbaf7cd8a96)d"/>
        </xpath>
      </data>
    </field>
  </record>
  <record id="product_template_product_form_custom" model="ir.ui.view">
    <field name="name">product.template.product.form customization</field>
    <field name="inherit_id" ref="product.product_template_only_form_view"/>
    <field name="mode">extension</field>
    <field name="model">product.template</field>
    <field name="active" eval="True"/>
    <field name="priority">160</field>
    <field name="type">form</field>
    <field name="arch" type="xml">
      <data>
        <xpath expr="//field[@name='recurrence_id']" position="attributes">
          <attribute name="domain">[]</attribute>
        </xpath>
      </data>
    </field>
  </record>
  <record id="project_task_form_custom" model="ir.ui.view">
    <field name="name">project.task.form customization</field>
    <field name="inherit_id" ref="project.view_task_form2"/>
    <field name="mode">extension</field>
    <field name="model">project.task</field>
    <field name="active" eval="True"/>
    <field name="priority">9990</field>
    <field name="type">form</field>
    <field name="arch" type="xml">
      <data>
        <xpath expr="//field[@name='under_warranty']" position="after">
          <field name="x_maintenance"/>
          <label for="x_serial"/>
          <div class="d-flex" name="serial">
            <field class="oe_inline" name="x_serial"/>
            <field name="x_product"/>
          </div>
        </xpath>
      </data>
    </field>
  </record>
  <record id="x_maintenance_rules_form_view" model="ir.ui.view">
    <field name="name">Default form view for x_maintenance_rules</field>
    <field name="model">x_maintenance_rules</field>
    <field name="type">form</field>
    <field name="active" eval="True"/>
    <field name="arch" type="xml">
      <form>
        <header/>
        <sheet string="Maintenance Rules">
          <widget name="web_ribbon" text="Archived" bg_color="text-bg-danger" invisible="x_active"/>
          <field name="x_active" invisible="1"/>
          <group name="studio_group_656456">
    </group>
        </sheet>
        <chatter/>
      </form>
    </field>
  </record>
  <record id="x_maintenance_rules_search_view" model="ir.ui.view">
    <field name="name">Default search view for x_maintenance_rules</field>
    <field name="model">x_maintenance_rules</field>
    <field name="type">search</field>
    <field name="active" eval="True"/>
    <field name="arch" type="xml">
      <search>
        <filter string="Archived" name="archived_x_maintenance_rules" domain="[['x_active', '=', False]]"/>
        <separator/>
      </search>
    </field>
  </record>
  <record id="x_maintenance_rules_custom_form_view" model="ir.ui.view">
    <field name="name">Default form view for x_maintenance_rules customization</field>
    <field name="inherit_id" ref="x_maintenance_rules_form_view"/>
    <field name="mode">extension</field>
    <field name="model">x_maintenance_rules</field>
    <field name="active" eval="True"/>
    <field name="priority">99</field>
    <field name="type">form</field>
    <field name="arch" type="xml">
      <data>
        <xpath expr="//group[@name='studio_group_656456']" position="inside">
          <field name="x_product" required="True" domain="[]"/>
          <field name="x_run_time_increment_h" help="Run-time increment between two maintenance tasks " options="{&quot;digits&quot;:[0,0]}"/>
        </xpath>
      </data>
    </field>
  </record>
  <record id="x_maintenance_rules_list_view" model="ir.ui.view">
    <field name="name">List view for Maintenance Rules</field>
    <field name="model">x_maintenance_rules</field>
    <field name="priority">99</field>
    <field name="arch" type="xml">
      <list editable="bottom">
            <field name="x_run_time_increment_h" optional="show"/>
            <field name="x_product" optional="show"/>
        </list>
    </field>
  </record>
  <record id="stock_location_route_form_custom" model="ir.ui.view">
    <field name="name">stock.location.route.form customization</field>
    <field name="inherit_id" ref="stock.stock_location_route_form_view"/>
    <field name="mode">extension</field>
    <field name="model">stock.route</field>
    <field name="priority">160</field>
    <field name="active" eval="True"/>
    <field name="type">form</field>
    <field name="arch" type="xml">
      <data>
        <xpath expr="//form[1]/sheet[1]/group[not(@name)][2]/field[@name='rule_ids']/list[1]/field[@name='sequence']" position="after">
          <field name="name" optional="show"/>
        </xpath>
      </data>
    </field>
  </record>
  <record id="stock_rule_list_custom" model="ir.ui.view">
    <field name="name">stock.rule.list customization</field>
    <field name="inherit_id" ref="stock.view_stock_rule_tree"/>
    <field name="mode">extension</field>
    <field name="model">stock.rule</field>
    <field name="active" eval="True"/>
    <field name="priority">99</field>
    <field name="type">list</field>
    <field name="arch" type="xml">
      <data>
        <xpath expr="//field[@name='action']" position="before">
          <xpath expr="//list[1]/field[@name='name']" position="move"/>
        </xpath>
        <xpath expr="//list[1]/field[@name='name']" position="attributes">
          <attribute name="optional">show</attribute>
        </xpath>
      </data>
    </field>
  </record>
  <record id="stock_picking_form_custom" model="ir.ui.view">
    <field name="name">stock.picking.form customization</field>
    <field name="inherit_id" ref="stock.view_picking_form"/>
    <field name="mode">extension</field>
    <field name="model">stock.picking</field>
    <field name="active" eval="True"/>
    <field name="priority">160</field>
    <field name="type">form</field>
    <field name="arch" type="xml">
      <data>
        <xpath expr="//button[@name='action_cancel']" position="after">
          <button string="Plan Maintenance" type="action" class="oe_highlight" invisible="state != &quot;done&quot; or ( not quality_check_fail and state == &quot;assigned&quot; )"/>
        </xpath>
      </data>
    </field>
  </record>
  <record id="stock_storage_category_form_custom_view" model="ir.ui.view">
    <field name="name">stock.storage.category.form customization</field>
    <field name="inherit_id" ref="stock.stock_storage_category_form"/>
    <field name="mode">extension</field>
    <field name="model">stock.storage.category</field>
    <field name="active" eval="True"/>
    <field name="priority">99</field>
    <field name="type">form</field>
    <field name="arch" type="xml">
      <data>
        <xpath expr="//form[1]/sheet[1]/group[1]/group[2]/div[1]" position="after">
          <field name="x_serial_status"/>
        </xpath>
      </data>
    </field>
  </record>
</odoo>
