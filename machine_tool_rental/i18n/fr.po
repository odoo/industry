msgstr ""
"<strong>Suivez les pistes</strong> issus des formulaires du site web, des e-"
"mails ou des demandes saisies manuellement."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
