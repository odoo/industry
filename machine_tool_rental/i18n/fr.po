#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong/>From any contact form, hit the <strong>Consolidated Down Payment</"
"strong> button to generate a single invoice for all ongoing Rental contracts."
msgstr ""
"<strong/>Depuis n’importe quelle fiche contact, cliquez sur le bouton "
"<strong>Acompte consolidé</strong> afin de générer une facture unique pour "
"l’ensemble des contrats de location en cours."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Accounting:</strong> Full financial management with real-time "
"insights."
msgstr ""
"<strong>Comptabilité :</strong> Gestion financière complète avec des "
"analyses en temps réel."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Assign maintenance locations</strong> for equipment under service."
msgstr ""
"<strong>Attribuez des emplacements de maintenance</strong> aux équipements "
"en cours d’entretien."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Assign technicians</strong> with calendar view and route "
"optimization."
msgstr ""
"<strong>Attribuez des techniciens</strong> avec une vue calendrier et une "
"optimisation des itinéraires."

