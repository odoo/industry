#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Check equipment availability</strong> in real time with serial "
"tracking."
msgstr ""
"<strong>Verifique a disponibilidade do equipamento</strong> em tempo real "
"com o rastreamento de série."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Collaborate in chatter</strong> to keep all communication "
"centralized."
msgstr ""
"<strong>Colabore no chatter</strong> para manter toda a comunicação "
"centralizada."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid "<strong>Convert to offer</strong> any opportunity in one click."
msgstr ""
"<strong>Converta em oferta</strong> qualquer oportunidade em um clique."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Create rental orders</strong> from CRM opportunities or directly in "
"the app."
msgstr ""
"<strong>Crie pedidos de aluguel</strong> a partir de oportunidades de CRM ou "
"diretamente no aplicativo."

