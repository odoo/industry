#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Accounting:</strong> Full financial management with real-time "
"insights."
msgstr ""
"<strong>ການບັນຊີ:</strong> ການຈັດການດ້ານການເງິນແບບເຕັມຮູບແບບ ພ້ອມຂໍ້ມູນວິເຄາະແບບສົດໆ."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Assign maintenance locations</strong> for equipment under service."
msgstr ""
"<strong>ກຳນົດສະຖານທີ່ບຳລຸງຮັກສາ</strong> ສຳລັບອຸປະກອນທີ່ກຳລັງຮັບບໍລິການ."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Assign technicians</strong> with calendar view and route "
"optimization."
msgstr ""
"<strong>ມອບໝາຍຊ່າງເຕັກນິກ</strong> ດ້ວຍມຸມມອງປະຕິທິນ ແລະ ການວາງແຜນເສັ້ນທາງທີ່ດີທີ່ສຸດ."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid "<strong>Basics</strong>"
msgstr "<strong>ພື້ນຖານ</strong>"

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Check equipment availability</strong> in real time with serial "
"tracking."
msgstr ""
"<strong>ກວດສອບຄວາມພ້ອມຂອງອຸປະກອນ</strong> ແບບສົດໆ ດ້ວຍການຕິດຕາມເລກລຳດັບ."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Collaborate in chatter</strong> to keep all communication "
"centralized."
msgstr ""
"<strong>ຮ່ວມມືກັນຜ່ານຊ່ອງສົນທະນາ</strong> ເພື່ອລວມສູນທຸກການສື່ສານໄວ້ບ່ອນດຽວ."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid "<strong>Convert to offer</strong> any opportunity in one click."
msgstr "<strong>ປ່ຽນເປັນຂໍ້ສະເໜີ</strong> ຈາກທຸກໂອກາດການຂາຍດ້ວຍການຄລິກດຽວ."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Create rental orders</strong> from CRM opportunities or directly in "
"the app."
msgstr "<strong>ສ້າງໃບສັ່ງເຊົ່າ</strong> ຈາກໂອກາດໃນ CRM ຫຼື ສ້າງໂດຍກົງໃນແອັບ."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid "<strong>Do you want to go further?</strong>"
msgstr "<strong>ເຈົ້າຕ້ອງການໄປໄກກວ່ານີ້ບໍ?</strong>"

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Employees:</strong> Manage HR operations including time-off and "
"contracts."
msgstr ""
"<strong>ພະນັກງານ:</strong> ຈັດການວຽກງານບຸກຄະລາກອນ ລວມທັງການລາພັກ ແລະ ສັນຍາຈ້າງ."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid "<strong>Enable recurring billing</strong> for long-term rentals."
msgstr "<strong>ເປີດໃຊ້ການເກັບເງິນແບບຕໍ່ເນື່ອງ</strong> ສຳລັບການເຊົ່າໄລຍະຍາວ."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid "<strong>Final word</strong>"
msgstr "<strong>ຄຳລົງທ້າຍ</strong>"

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Fleet:</strong> Keep track of vehicles used for delivery and pickup."
msgstr "<strong>ພາຫະນະ:</strong> ຕິດຕາມຍານພາຫະນະທີ່ໃຊ້ໃນການສົ່ງ ແລະ ຮັບເຄື່ອງ."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid "<strong>Generate invoices</strong> directly from rental orders."
msgstr "<strong>ສ້າງໃບເກັບເງິນ</strong> ໂດຍກົງຈາກໃບສັ່ງເຊົ່າ."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Generate tasks</strong> automatically when equipment is moved to "
"maintenance location."
msgstr ""
"<strong>ສ້າງໜ້າວຽກ</strong> ໂດຍອັດຕະໂນມັດ ເມື່ອອຸປະກອນຖືກຍ້າຍໄປບ່ອນບຳລຸງຮັກສາ."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid "<strong>Handle recurring tasks</strong> based on runtime readings."
msgstr "<strong>ຈັດການໜ້າວຽກທີ່ຊໍ້າຄືນ</strong> ໂດຍອີງຕາມຄ່າເວລາເຮັດວຽກ."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid "<strong>How to Use:</strong>"
msgstr "<strong>ວິທີການນຳໃຊ້:</strong>"

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>In such situation, feel free to experiment with this database and "
"then to create a new one for your own usage.</strong>"
msgstr ""
"<strong>ໃນກໍລະນີນັ້ນ, ເຈົ້າສາມາດທົດລອງກັບຖານຂໍ້ມູນນີ້ໄດ້ ແລະ ຫຼັງຈາກນັ້ນຈຶ່ງສ້າງຖານຂໍ້ມູນໃໝ່ເພື່ອໃຊ້ງານຈິ"
"ງ.</strong>"

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Integrate with inventory</strong> to automatically trigger quality "
"checks."
msgstr ""
"<strong>ເຊື່ອມຕໍ່ກັບສາງສິນຄ້າ</strong> ເພື່ອເປີດການກວດສອບຄຸນນະພາບໂດຍອັດຕະໂນມັດ."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Link runtime data</strong> to serials for maintenance planning."
msgstr ""
"<strong>ເຊື່ອມໂຍງຂໍ້ມູນເວລາເຮັດວຽກ</strong> ກັບເລກລຳດັບ ເພື່ອວາງແຜນການບຳລຸງຮັກສາ."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Log inspection results</strong> and mark equipment as available only"
" if it passes."
msgstr ""
"<strong>ບັນທຶກຜົນການກວດສອບ</strong> ແລະ ກໍານົດໃຫ້ອຸປະກອນພ້ອມໃຊ້ງານກໍຕໍ່ເມື່ອຜ່ານການກວດສອບເທົ່າ"
"ນັ້ນ."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid "<strong>Log service reports</strong> directly from a mobile device."
msgstr "<strong>ບັນທຶກລາຍງານການບໍລິການ</strong> ໂດຍກົງຈາກອຸປະກອນມືຖື."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid "<strong>Manage returns</strong> and extensions easily from the order."
msgstr "<strong>ຈັດການການສົ່ງຄືນ</strong> ແລະ ການຕໍ່ເວລາໄດ້ງ່າຍໆ ຈາກໃບສັ່ງ."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Organize pipelines</strong> by stages (e.g., New Lead → Quotation "
"Sent → Won/Lost)."
msgstr ""
"<strong>ຈັດລະບຽບຂະບວນການຂາຍ</strong> ຕາມຂັ້ນຕອນ (ເຊັ່ນ: ຜູ້ມຸ່ງຫວັງໃໝ່ → ສົ່ງໃບສະເໜີລາຄາ → "
"ປິດການຂາຍໄດ້/ເສຍ)."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Perform two-step returns</strong>: Receive and then perform a "
"Quality Check."
msgstr ""
"<strong>ດຳເນີນການສົ່ງຄືນສອງຂັ້ນຕອນ</strong>: ຮັບເຄື່ອງເຂົ້າ ແລະ ຈາກນັ້ນຈຶ່ງກວດສອບຄຸນນະພາບ."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid "<strong>Schedule follow-ups</strong> directly from the CRM dashboard."
msgstr "<strong>ກຳນົດເວລາຕິດຕາມວຽກ</strong> ໂດຍກົງຈາກໜ້າຕ່າງ CRM."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Set quality control points</strong> for post-return inspections."
msgstr "<strong>ກຳນົດຈຸດຄວບຄຸມຄຸນນະພາບ</strong> ສຳລັບການກວດສອບຫຼັງການສົ່ງຄືນ."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Track leads</strong> from website forms, email, or manually entered "
"inquiries."
msgstr ""
"<strong>ຕິດຕາມຜູ້ມຸ່ງຫວັງ</strong> ຈາກແບບຟອມເວັບໄຊ, ອີເມລ ຫຼື ຂໍ້ມູນທີ່ປ້ອນດ້ວຍຕົນເອງ."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Track payments and follow up</strong> with automatic reminders."
msgstr ""
