#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong/>From any contact form, hit the <strong>Consolidated Down Payment</"
"strong> button to generate a single invoice for all ongoing Rental contracts."
msgstr ""
"<strong/>Desde cualquier formulario de contacto, haz clic en el botón "
"<strong>Anticipo consolidado</strong> para generar una sola factura para "
"todos los contratos de alquiler activos."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Accounting:</strong> Full financial management with real-time "
"insights."
msgstr ""
"<strong>Contabilidad:</strong> Gestión financiera completa con información "
"en tiempo real."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Assign maintenance locations</strong> for equipment under service."
msgstr ""
"<strong>Asigna ubicaciones de mantenimiento</strong> a los equipos en "
"servicio."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Assign technicians</strong> with calendar view and route "
"optimization."
msgstr ""
"<strong>Asigna técnicos</strong> desde la vista de calendario y utiliza "
"rutas optimizadas."

