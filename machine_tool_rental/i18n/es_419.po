msgstr ""
"<strong>Lleva seguimiento de los leads</strong> recibidos mediante "
"formularios web, correo o registrados de forma manual."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
