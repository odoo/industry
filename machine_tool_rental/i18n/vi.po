#: model:base.automation,name:machine_tool_rental.create_task_on_maintenance_move
msgid "Create task on maintenance move"
msgstr "Tạo nhiệm vụ trong quá trình bảo trì"

#. module: machine_tool_rental
#: model:product.template,name:machine_tool_rental.product_product_7_product_template
msgid "Cut-off saw DSH 600-22 Battery"
msgstr "Máy cưa cắt DSH 600-22 chạy bằng pin"

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"Define different quality checks for different product categories or products "
"being more specific and the requirements!"
msgstr ""
"Xác định kiểm tra chất lượng khác nhau cho danh mục sản phẩm hoặc sản phẩm "
"cụ thể và các yêu cầu!"

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"Deleting invoices generated from the <strong>Consolidated Down Payment</"
"strong> is not advised, as it may break the mechanism used to generate "
"future invoices."
msgstr ""
"Không nên xóa các hóa đơn được tạo từ <strong>Khoản trả trước hợp nhất</"
"strong>, vì điều này có thể làm hỏng cơ chế được sử dụng để tạo các hóa đơn "
"trong tương lai."

#. module: machine_tool_rental
#: model:product.template,name:machine_tool_rental.product_product_18_product_template
