#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Accounting:</strong> Full financial management with real-time "
"insights."
msgstr ""
"<strong>Kế toán:</strong> Quản lý tài chính toàn diện với thông tin theo "
"thời gian thực."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Assign maintenance locations</strong> for equipment under service."
msgstr "<strong>Gán vị trí bảo trì</strong> cho thiết bị đang được bảo trì."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Assign technicians</strong> with calendar view and route "
"optimization."
msgstr ""
"<strong>Phân công kỹ thuật viên</strong> với chế độ xem lịch và tối ưu hóa "
"lộ trình."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid "<strong>Basics</strong>"
msgstr "<strong>Cơ bản</strong>"

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Check equipment availability</strong> in real time with serial "
"tracking."
msgstr ""
"<strong>Kiểm tra tình trạng sẵn có của thiết bị</strong> theo thời gian thực "
"với tính năng theo dõi số sê-ri."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Collaborate in chatter</strong> to keep all communication "
"centralized."
msgstr ""
"<strong>Hợp tác trong cửa sổ trò chuyện</strong> để tập trung tất cả các "
"cuộc trao đổi."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid "<strong>Convert to offer</strong> any opportunity in one click."
msgstr ""
"<strong>Chuyển đổi để cung cấp</strong> bất kỳ cơ hội nào chỉ với một cú "
"nhấp chuột."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Create rental orders</strong> from CRM opportunities or directly in "
"the app."
msgstr ""
"<strong>Tạo đơn hàng cho thuê</strong> từ cơ hội trong CRM hoặc trực tiếp "
"trong ứng dụng."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid "<strong>Do you want to go further?</strong>"
msgstr "<strong>Bạn có muốn tiến xa hơn không?</strong>"

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Employees:</strong> Manage HR operations including time-off and "
"contracts."
msgstr ""
"<strong>Nhân viên:</strong> Quản lý các hoạt động nhân sự, bao gồm nghỉ phép "
"và hợp đồng lao động."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid "<strong>Enable recurring billing</strong> for long-term rentals."
msgstr ""
"<strong>Bật tính năng thanh toán định kỳ</strong> cho các hợp đồng thuê dài "
"hạn."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid "<strong>Final word</strong>"
msgstr "<strong>Lưu ý cuối cùng</strong>"

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Fleet:</strong> Keep track of vehicles used for delivery and pickup."
msgstr ""
"<strong>Đội xe:</strong> Theo dõi các phương tiện được sử dụng cho việc giao "
"hàng và nhận hàng."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid "<strong>Generate invoices</strong> directly from rental orders."
msgstr "<strong>Tạo hóa đơn</strong> trực tiếp từ đơn hàng cho thuê."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Generate tasks</strong> automatically when equipment is moved to "
"maintenance location."
msgstr ""
"<strong>Tự động tạo nhiệm vụ</strong> khi thiết bị được di chuyển đến vị trí "
"bảo trì."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid "<strong>Handle recurring tasks</strong> based on runtime readings."
msgstr ""
"<strong>Xử lý nhiệm vụ định kỳ</strong> dựa trên các giá trị đọc trong thời "
"gian thực."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid "<strong>How to Use:</strong>"
msgstr "<strong>Cách sử dụng:</strong>"

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>In such situation, feel free to experiment with this database and "
"then to create a new one for your own usage.</strong>"
msgstr ""
"<strong>Trong trường hợp đó, bạn cứ thoải mái thử nghiệm với cơ sở dữ liệu "
"này, rồi tạo một cơ sở dữ liệu mới để sử dụng cho mục đích riêng của mình.</"
"strong>"

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Integrate with inventory</strong> to automatically trigger quality "
"checks."
msgstr ""
"<strong>Tích hợp với tồn kho</strong> để tự động kích hoạt các kiểm tra chất "
"lượng."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid "<strong>Link runtime data</strong> to serials for maintenance planning."
msgstr ""
"<strong>Kết nối dữ liệu thời gian chạy</strong> với các số sê-ri để lập kế "
"hoạch bảo trì."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Log inspection results</strong> and mark equipment as available only "
"if it passes."
msgstr ""
"<strong>Ghi lại kết quả kiểm tra</strong> và đánh dấu thiết bị là sẵn sàng "
"chỉ khi đạt kiểm tra."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid "<strong>Log service reports</strong> directly from a mobile device."
msgstr ""
"<strong>Ghi nhận báo cáo dịch vụ </strong> trực tiếp từ thiết bị di động."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid "<strong>Manage returns</strong> and extensions easily from the order."
msgstr ""
"<strong>Quản lý trả hàng</strong> và gia hạn một cách dễ dàng từ đơn hàng."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Organize pipelines</strong> by stages (e.g., New Lead → Quotation "
"Sent → Won/Lost)."
msgstr ""
"<strong>Tổ chức quy trình sales</strong> theo các giai đoạn (ví dụ: Lead mới "
"→ Gửi báo giá → Đạt/Không đạt)."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Perform two-step returns</strong>: Receive and then perform a "
"Quality Check."
msgstr ""
"<strong>Thực hiện quy trình trả hàng hai bước</strong>: Nhận hàng và sau đó "
"thực hiện kiểm tra chất lượng."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid "<strong>Schedule follow-ups</strong> directly from the CRM dashboard."
msgstr ""
"<strong>Lên lịch follow-up</strong> trực tiếp từ báo cáo tổng quan CRM."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Set quality control points</strong> for post-return inspections."
msgstr ""
"<strong>Thiết lập điểm kiểm soát chất lượng</strong> cho các cuộc kiểm tra "
"sau khi hàng hóa được trả lại."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Track leads</strong> from website forms, email, or manually entered "
"inquiries."
msgstr ""
"<strong>Theo dõi lead</strong> từ các biểu mẫu trên trang web, email hoặc "
"các yêu cầu được nhập thủ công."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid "<strong>Track payments and follow up</strong> with automatic reminders."
msgstr "<strong>Theo dõi và follow up</strong> với tính năng nhắc nhở tự động."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Track serial numbers</strong> and view their availability instantly."
msgstr ""
"<strong>Theo dõi số sê-ri</strong> và xem tình trạng sẵn có của chúng ngay "
"lập tức."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid "<strong>Use case</strong>"
msgstr "<strong>Trường hợp vận dụng</strong>"

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"<strong>Website &amp; eCommerce:</strong> Display rental catalog online and "
"allow direct booking."
msgstr ""
"<strong>Trang web &amp; Thương mại điện tử:</strong> Hiển thị danh mục cho "
"thuê trực tuyến và cho phép đặt chỗ trực tiếp."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"Automate your invoicing flow with recurring invoices that are triggered by "
"ongoing rental contracts."
msgstr ""
"Tự động hóa quy trình lập hóa đơn của bạn với các hóa đơn định kỳ được kích "
"hoạt bởi những hợp đồng cho thuê đang diễn ra."

#. module: machine_tool_rental
#: model_terms:ir.ui.view,arch_db:machine_tool_rental.welcome_article_body
msgid ""
"By uploading this module's demo data, your database has been filled with a "
"few products, sale orders and more."
msgstr ""
"Bằng cách tải lên dữ liệu demo của phân hệ này, cơ sở dữ liệu của bạn đã có "
"sẵn một số sản phẩm, đơn bán hàng và nhiều dữ liệu khác."

#. module: machine_tool_rental
#: model:product.template,name:machine_tool_rental.product_product_4_product_template
msgid "Compressor 8bar 50L"
msgstr "Máy nén khí 8 bar, dung tích 50 lít"

