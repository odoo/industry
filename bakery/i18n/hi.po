#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Quote and Confirm:</strong>\n"
"                    If a specific demand requires pricing, generate a "
"quotation directly from the\n"
"                    <strong>Sales</strong> app. The client can then confirm "
"and sign it online."
