#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Payroll:</strong>\n"
"                    Use this feature to handle <strong>employee salaries and "
"manage holiday\n"
"                    requests.</strong>"
msgstr ""

