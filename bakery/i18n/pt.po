#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid "<span style=\"font-size: 36px;\"><strong>Bakery </strong></span>"
msgstr "<span style=\"font-size: 36px;\"><strong>Padaria </strong></span>"

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Accept flexible payments</strong>: Provide multiple payment options "
"(cash, card, mobile)."
msgstr ""
"<strong>Aceitar pagamentos flexíveis</strong>: Fornecer várias opções de "
"pagamento (dinheiro, cartão, celular)."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Bulk orders for events</strong>: Allow customers to place large "
"orders for events like company breakfasts, ensuring they can select from a "
"variety of breads, pastries, and baked goods with flexible delivery or "
"pickup options."
msgstr ""
"<strong>Pedidos em massa para eventos</strong>: Permita que os clientes "
"façam grandes pedidos para eventos, como cafés da manhã da empresa, "
"garantindo que tenham uma grande variedade de pães, bolos e produtos de "
"padaria à escolha, com opções flexíveis de entrega ou retirada."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Choose the best vendor</strong>: Pick the vendor offering the best "
"deal for the requested materials."
msgstr ""
"<strong>Escolha o melhor fornecedor</strong>: Escolha o fornecedor que "
"oferece a melhor oferta para os materiais solicitados."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Create a purchase order</strong>: Select the materials you need for "
"your breads and pastries."
msgstr ""
"<strong>Criar um pedido de compra</strong>: Selecione os materiais "
"necessários para seus pães e bolos."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Employee scheduling:</strong> Use the <strong>Planning App</strong> "
"to create and manage employee schedules, ensuring you have the right staff "
"at the right times for busy days and specific orders."
msgstr ""
"<strong>Escala de funcionários:</strong> Use o <strong>app Planejamento</"
"strong> para criar e gerenciar as escalas dos funcionários, garantindo que "
"você tenha a equipe certa nos horários certos para dias de grande movimento "
"e pedidos específicos."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Pre-order system</strong>: Enable customers to place orders in "
"advance, ensuring product availability and timely preparation, especially "
"during busy times like Sunday mornings or holidays."
msgstr ""
"<strong>Sistema de pré-venda</strong>: Permita que os clientes façam pedidos "
"com antecedência, garantindo a disponibilidade do produto e a preparação em "
"tempo hábil, especialmente em horários de pico, como domingos pela manhã ou "
"feriados."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Restaurant mode</strong>: Manage tables, orders, and payments with "
"the Point of Sale system if you offer an \"eat-in\" option."
msgstr ""
"<strong>Modo Restaurante</strong>: Gerencie mesas, pedidos e pagamentos com "
"o sistema de ponto de venda se você oferecer a opção \"refeição no local\"."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Take orders in Point of Sale</strong>: Process in-store bread, loaf "
"and pastries orders quickly using the Point of Sale system."
msgstr ""
"<strong>Tirar pedidos no Ponto de Venda</strong>: Processe rapidamente os "
"pedidos de pães, doces e bolos na loja com o sistema de ponto de venda."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>You didn't import demo data?</strong> You can still do it. Go to "
"<strong>Apps &gt; Industries &gt; Upgrade your Bakery Package</strong> and "
"check the related box."
msgstr ""
"<strong>Não importou dados de demonstração?</strong> Você ainda pode fazer "
"isso. Vá para <strong>Aplicativos > Setores, atualize seu pacote Padaria</"
"strong> e marque a caixa relacionada."

