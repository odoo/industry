#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Accounting:</strong>\n"
"                    Automatically log payments, close sessions, and generate "
"tax reports."
msgstr ""

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Automatic Delivery:</strong>\n"
"                    Once the quote is accepted, it's possible to deliver the "
"products just as it does for a regular e-commerce order."
msgstr ""

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Crucial Review:</strong>\n"
"                    You must review all e-commerce settings to ensure they "
"align with your\n"
"                    internal business policies (e.g., when invoices are "
"generated, whether a\n"
"                    mandatory customer check-in is required for ordering, "
"etc.)."
msgstr ""

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Define B2B Pricing:</strong>\n"
"                    Create and assign a dedicated pricelist to each B2B "
"contact. Ensure this pricelist\n"
"                    is active on your website so the customer sees their "
"agreed-upon prices upon login."
msgstr ""

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Delivery Methods:</strong>\n"
"                    Go to <strong>Website &gt; Configuration &gt; Delivery "
"Methods</strong>\n"
"                    to define all available options and their costs."
msgstr ""

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>E-commerce Category:</strong> For easier product retrieval by "
"customers on your online store."
msgstr ""

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Employee Scheduling:</strong>\n"
"                    Use the <strong>Planning App</strong> to create and "
"manage employee schedules,\n"
"                    ensuring you have the right staff at the right times for "
"busy days and specific orders."
msgstr ""

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>External Providers:</strong>\n"
"                            Check if a predefined Odoo connection exists if "
"you work with\n"
"                            specific shipping carriers."
msgstr ""

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>In-Store Pickup (Click &amp; Collect):</strong>\n"
"                            If you wish to offer this, you must\n"
"                            <strong>activate the setting</strong> within "
"the\n"
"                            <strong>Website Settings</strong> first."
msgstr ""

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Layout Settings:</strong>\n"
"                    Adjust the visual presentation and layout of products "
"using the\n"
"                    <strong>website editor</strong>."
msgstr ""

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Loyalty Programs:</strong>\n"
"                            Implement <strong>loyalty cards</strong> as a "
"core strategy to <strong>activate customer retentio\n"
"                            </strong> and increase customer lifetime value."
msgstr ""

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Note:</strong> Increased capability leads to higher complexity and "
"more maintenance."
msgstr ""

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Our Advice:</strong> Stick with your current streamlined "
"configuration until\n"
"                        you're fully comfortable. When you're ready to "
"upgrade, try the inventory module on a duplicated database first to ensure "
"it fits\n"
"                        your workflow. 😉"
msgstr ""

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Payment Providers &amp; Methods:</strong>\n"
"                    Go to <strong>Website &gt; Configuration &gt; Payment "
"Providers</strong>\n"
"                    and install all the payment methods and providers you "
"plan to offer\n"
"                    (e.g., credit card processors, PayPal, etc.)."
