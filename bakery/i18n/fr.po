#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid "<span style=\"font-size: 36px;\"><strong>Bakery </strong></span>"
msgstr "<span style=\"font-size: 36px;\"><strong>Boulangerie</strong></span>"

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Accept flexible payments</strong>: Provide multiple payment options "
"(cash, card, mobile)."
msgstr ""
"<strong>Acceptez des paiements flexibles</strong> : proposez plusieurs "
"options de paiement (espèces, carte, téléphone mobile)."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Bulk orders for events</strong>: Allow customers to place large "
"orders for events like company breakfasts, ensuring they can select from a "
"variety of breads, pastries, and baked goods with flexible delivery or "
"pickup options."
msgstr ""
"<strong>Commandes en gros pour événements</strong> : Offrez à vos clients la "
"possibilité de passer de grandes commandes pour leurs événements, comme des "
"petits-déjeuners d’entreprise. Proposez un large choix de pains, "
"viennoiseries et pâtisseries, avec des options de livraison ou de retrait "
"flexibles."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Choose the best vendor</strong>: Pick the vendor offering the best "
"deal for the requested materials."
msgstr ""
"<strong>Choisissez le meilleur fournisseur</strong> : sélectionnez la "
"meilleure offre pour votre demande."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Create a purchase order</strong>: Select the materials you need for "
"your breads and pastries."
msgstr ""
"<strong>Créez un bon de commande</strong> : Choisissez les matières "
"premières essentielles à la préparation de vos pains et pâtisseries."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Employee scheduling:</strong> Use the <strong>Planning App</strong> "
"to create and manage employee schedules, ensuring you have the right staff "
"at the right times for busy days and specific orders."
msgstr ""
"<strong>Planification des employés</strong> : Utilisez l'application "
"<strong>Planification</strong> pour organiser et gérer les horaires, afin "
"d'assurer la présence du personnel nécessaire lors des journées chargées et "
"des commandes spécifiques."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Pre-order system</strong>: Enable customers to place orders in "
"advance, ensuring product availability and timely preparation, especially "
"during busy times like Sunday mornings or holidays."
msgstr ""
"<strong>Système de précommande</strong> : Offrez à vos clients la "
"possibilité de commander à l’avance pour garantir la disponibilité des "
"produits et une préparation optimale, notamment lors des périodes de forte "
"affluence comme les dimanches matins ou les jours fériés."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Restaurant mode</strong>: Manage tables, orders, and payments with "
"the Point of Sale system if you offer an \"eat-in\" option."
msgstr ""
"<strong>Mode restaurant</strong> : Gérez les tables, les commandes et les "
"paiements avec le système de Point de Vente si vous proposez un service de "
"consommation sur place."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Take orders in Point of Sale</strong>: Process in-store bread, loaf "
"and pastries orders quickly using the Point of Sale system."
msgstr ""
"<strong>Prise de commandes dans le Point de Vente</strong> : Accélérez le "
"traitement des commandes en magasin pour pains, baguettes et viennoiseries "
"grâce à un système de Point de Vente efficace."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>You didn't import demo data?</strong> You can still do it. Go to "
"<strong>Apps &gt; Industries &gt; Upgrade your Bakery Package</strong> and "
"check the related box."
msgstr ""
"<strong>Vous n’avez pas importé les données de démonstration ?</strong> Vous "
"pouvez encore le faire. Allez dans <strong>Applications > Industries > "
"Mettre à niveau le pack Boulangerie</strong> et cochez la case "
"correspondante."

