#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid "<span style=\"font-size: 36px;\"><strong>Bakery </strong></span>"
msgstr "<span style=\"font-size: 36px;\"><strong>Tiệm bánh mì</strong></span>"

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Accept flexible payments</strong>: Provide multiple payment options "
"(cash, card, mobile)."
msgstr ""
"<strong>Chấp nhận thanh toán linh hoạt</strong>: Cung cấp nhiều phương thức "
"thanh toán (tiền mặt, thẻ, di động)."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Bulk orders for events</strong>: Allow customers to place large "
"orders for events like company breakfasts, ensuring they can select from a "
"variety of breads, pastries, and baked goods with flexible delivery or "
"pickup options."
msgstr ""
"<strong>Đặt hàng số lượng lớn cho sự kiện</strong>: Cho phép khách hàng đặt "
"trước các đơn hàng lớn cho những dịp như bữa sáng công ty, với nhiều lựa "
"chọn bánh mì, bánh ngọt và các sản phẩm nướng khác, kèm theo tùy chọn giao "
"hàng linh hoạt hoặc nhận tại cửa hàng."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Choose the best vendor</strong>: Pick the vendor offering the best "
"deal for the requested materials."
msgstr ""
"<strong>Chọn nhà cung cấp tốt nhất</strong>: Lựa chọn nhà cung cấp đưa ra ưu "
"đãi tốt nhất cho nguyên liệu cần thiết."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Create a purchase order</strong>: Select the materials you need for "
"your breads and pastries."
msgstr ""
"<strong>Tạo đơn mua hàng</strong>: Chọn nguyên liệu cần thiết cho bánh mì và "
"bánh ngọt của bạn."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Employee scheduling:</strong> Use the <strong>Planning App</strong> "
"to create and manage employee schedules, ensuring you have the right staff "
"at the right times for busy days and specific orders."
msgstr ""
"<strong>Lịch trình nhân viên</strong>: Sử dụng <strong>ứng dụng Kế hoạch</"
"strong> để tạo và quản lý lịch làm việc của nhân viên, đảm bảo có đúng nhân "
"sự vào đúng thời điểm cho những ngày bận rộn và các đơn hàng cụ thể."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Pre-order system</strong>: Enable customers to place orders in "
"advance, ensuring product availability and timely preparation, especially "
"during busy times like Sunday mornings or holidays."
msgstr ""
"<strong>Hệ thống đặt hàng trước</strong>: Cho phép khách hàng đặt hàng trước "
"để đảm bảo có sẵn sản phẩm và chuẩn bị kịp thời, đặc biệt trong những thời "
"điểm bận rộn như sáng Chủ nhật hoặc các dịp lễ."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Restaurant mode</strong>: Manage tables, orders, and payments with "
"the Point of Sale system if you offer an \"eat-in\" option."
msgstr ""
"<strong>Chế độ nhà hàng</strong>: Quản lý bàn, đơn hàng và thanh toán bằng "
"hệ thống POS nếu bạn cung cấp tùy chọn \"dùng tại chỗ\"."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Take orders in Point of Sale</strong>: Process in-store bread, loaf "
"and pastries orders quickly using the Point of Sale system."
msgstr ""
"<strong>Nhận đơn hàng tại POS</strong>: Xử lý nhanh chóng các đơn hàng bánh "
"mì và bánh ngọt tại cửa hàng bằng hệ thống POS."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>You didn't import demo data?</strong> You can still do it. Go to "
"<strong>Apps &gt; Industries &gt; Upgrade your Bakery Package</strong> and "
"check the related box."
msgstr ""
"<strong>Bạn chưa nhập dữ liệu demo?</strong> Đừng lo! Bạn vẫn có thể làm "
"được bằng cách đi đến <strong>Ứng dụng &gt; Ngành &gt; Nâng cấp gói Tiệm "
"bánh mì của bạn</strong> và đánh dấu vào ô liên quan."

