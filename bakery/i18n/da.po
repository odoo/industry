#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid "<span style=\"font-size: 36px;\"><strong>Bakery </strong></span>"
msgstr "<span style=\"font-size: 36px;\"><strong>Bageri </strong></span>"

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Accept flexible payments</strong>: Provide multiple payment options "
"(cash, card, mobile)."
msgstr ""
"<strong>Acceptér fleksible betalinger</strong>: Tilbyd flere "
"betalingsmuligheder (kontanter, kort og mobilbetaling)."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Bulk orders for events</strong>: Allow customers to place large "
"orders for events like company breakfasts, ensuring they can select from a "
"variety of breads, pastries, and baked goods with flexible delivery or "
"pickup options."
msgstr ""
"<strong>Større ordrer til arrangementer</strong>: Giv dine kunder mulighed "
"for at bestille større mængder til arrangementer som firmafrokoster, og lad "
"dem vælge mellem et bredt udvalg af brød, kager og bagværk med fleksible "
"leverings- eller afhentningsmuligheder."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Choose the best vendor</strong>: Pick the vendor offering the best "
"deal for the requested materials."
msgstr ""
"<strong>Vælg den bedste leverandør</strong>: Vælg den leverandør, der giver "
"det mest fordelagtige tilbud på de ønskede materialer."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Create a purchase order</strong>: Select the materials you need for "
"your breads and pastries."
msgstr ""
"<strong>Opret en ordre</strong>: Vælg de produkter, du har brug for til dine "
"brød og kager."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Employee scheduling:</strong> Use the <strong>Planning App</strong> "
"to create and manage employee schedules, ensuring you have the right staff "
"at the right times for busy days and specific orders."
msgstr ""
"<strong>Medarbejderplanlægning</strong>: Brug <strong>Planlægningsappen</"
"strong> til at oprette og administrere vagtplaner, så det rette personale er "
"til stede på de rette tidspunkter, f.eks. i spidsbelastningsperioder, og til "
"at oprette kundespecifikke ordrer."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Pre-order system</strong>: Enable customers to place orders in "
"advance, ensuring product availability and timely preparation, especially "
"during busy times like Sunday mornings or holidays."
msgstr ""
"<strong>Forudbestillingssystem</strong>: Lad dine kunder afgive ordrer på "
"forhånd for at sikre, at produkterne er tilgængelige og kan forberedes til "
"tiden – især i travle perioder som søndag morgen eller på helligdage."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Restaurant mode</strong>: Manage tables, orders, and payments with "
"the Point of Sale system if you offer an \"eat-in\" option."
msgstr ""
"<strong>Restauranttilstand</strong>: Hvis du tilbyder spisning på stedet, "
"kan du administrere borde, bestillinger og betalinger direkte i "
"kassesystemet."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Take orders in Point of Sale</strong>: Process in-store bread, loaf "
"and pastries orders quickly using the Point of Sale system."
msgstr ""
"<strong>Registrér bestillinger i kassesystemet</strong>: Håndtér køb af "
"brød, brødstykker og kager direkte i kassesystemet, når kunderne handler i "
"butikken."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>You didn't import demo data?</strong> You can still do it. Go to "
"<strong>Apps &gt; Industries &gt; Upgrade your Bakery Package</strong> and "
"check the related box."
msgstr ""
"<strong>Har du ikke importeret demo-data?</strong> Det kan du stadig nå. Gå "
"til <strong>Apps &gt; Brancher &gt; Opdatér din bageriepakke,</strong> og "
"markér det relevante felt."

