#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid "<span style=\"font-size: 36px;\"><strong>Bakery </strong></span>"
msgstr "<span style=\"font-size: 36px;\"><strong>Panadería </strong></span>"

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Accept flexible payments</strong>: Provide multiple payment options "
"(cash, card, mobile)."
msgstr ""
"<strong>Acepte pagos flexibles</strong>: proporcione varias opciones de pago "
"(efectivo, tarjeta, móvil)."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Bulk orders for events</strong>: Allow customers to place large "
"orders for events like company breakfasts, ensuring they can select from a "
"variety of breads, pastries, and baked goods with flexible delivery or "
"pickup options."
msgstr ""
"<strong>Pedidos grandes para eventos</strong>: permita a sus clientes "
"realizar pedidos grandes para eventos como desayunos de empresa y asegúrese "
"de que puedan elegir entre una gran variedad de panes, pasteles y productos "
"de panadería con opciones flexibles de entrega o recogida."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Choose the best vendor</strong>: Pick the vendor offering the best "
"deal for the requested materials."
msgstr ""
"<strong>Seleccione al mejor proveedor</strong>: elija al proveedor que "
"ofrezca el mejor precio para los materiales que necesita."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Create a purchase order</strong>: Select the materials you need for "
"your breads and pastries."
msgstr ""
"<strong>Cree un pedido de compra</strong>: seleccione los ingredientes que "
"necesita para elaborar sus panes y bollos."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Employee scheduling:</strong> Use the <strong>Planning App</strong> "
"to create and manage employee schedules, ensuring you have the right staff "
"at the right times for busy days and specific orders."
msgstr ""
"<strong>Horarios de empleados:</strong> use la aplicación "
"<strong>Planificación</strong> para crear y gestionar los horarios de sus "
"empleados. Asegúrese de contar con el personal adecuado cuando más lo "
"necesita, por ejemplo en las horas de mayor actividad, y cree pedidos "
"individuales."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Pre-order system</strong>: Enable customers to place orders in "
"advance, ensuring product availability and timely preparation, especially "
"during busy times like Sunday mornings or holidays."
msgstr ""
"<strong>Sistema de pedidos anticipados</strong>: permita a los clientes "
"realizar pedidos con antelación y garantice la disponibilidad de los "
"productos y su preparación a tiempo, especialmente en horas de mayor "
"actividad como los domingos por la mañana o los días festivos."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Restaurant mode</strong>: Manage tables, orders, and payments with "
"the Point of Sale system if you offer an \"eat-in\" option."
msgstr ""
"<strong>Modo restaurante</strong>: gestione mesas, pedidos y pagos con el "
"sistema de TPV si ofrece la opción de comer en el local."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Take orders in Point of Sale</strong>: Process in-store bread, loaf "
"and pastries orders quickly using the Point of Sale system."
msgstr ""
"<strong>Tome pedidos en su TPV</strong>: procese los pedidos de panes y "
"tartas con rapidez en su tienda gracias al sistema de TPV."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>You didn't import demo data?</strong> You can still do it. Go to "
"<strong>Apps &gt; Industries &gt; Upgrade your Bakery Package</strong> and "
"check the related box."
msgstr ""
"<strong>¿No ha importado los datos de demostración?</strong> Todavía puede "
"hacerlo. Vaya a <strong>Aplicaciones > Industrias, actualice el paquete para "
"panaderías</strong> y seleccione la casilla correspondiente."

