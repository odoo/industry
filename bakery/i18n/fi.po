#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid "<span style=\"font-size: 36px;\"><strong>Bakery </strong></span>"
msgstr "<span style=\"font-size: 36px;\"><strong>Leipomo</strong></span>"

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Accept flexible payments</strong>: Provide multiple payment options "
"(cash, card, mobile)."
msgstr ""
"<strong>Hyväksy joustavat maksut</strong>: Tarjoa useita maksuvaihtoehtoja "
"(käteinen, kortti, mobiili)."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Bulk orders for events</strong>: Allow customers to place large "
"orders for events like company breakfasts, ensuring they can select from a "
"variety of breads, pastries, and baked goods with flexible delivery or "
"pickup options."
msgstr ""
"<strong>Massatilaukset tapahtumiin</strong>: Anna asiakkaiden tehdä "
"suurtilauksia esimerkiksi yritysaamiaisia varten, jolloin he voivat valita "
"erilaisia leipiä, leivonnaisia ja muita leipomotuotteita joustavilla "
"toimitus- tai noutovaihtoehdoilla."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Choose the best vendor</strong>: Pick the vendor offering the best "
"deal for the requested materials."
msgstr ""
"<strong>Valitse paras toimittaja</strong>: Valitse toimittaja, joka tarjoaa "
"parhaan tarjouksen pyydetyistä materiaaleista."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Create a purchase order</strong>: Select the materials you need for "
"your breads and pastries."
msgstr ""
"<strong>Luo ostotilaus</strong>: Valitse leipien ja leivonnaisten "
"valmistukseen tarvittavat raaka-aineet."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Employee scheduling:</strong> Use the <strong>Planning App</strong> "
"to create and manage employee schedules, ensuring you have the right staff "
"at the right times for busy days and specific orders."
msgstr ""
"<strong>Työvuorosuunnittelu</strong>: Käytä <strong>Suunnittelu-sovellusta</"
"strong> työvuorojen luomiseen ja hallintaan, jotta varmistat, että oikea "
"määrä henkilökuntaa on paikalla kiireisinä päivinä ja erikoistilauksia "
"varten."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Pre-order system</strong>: Enable customers to place orders in "
"advance, ensuring product availability and timely preparation, especially "
"during busy times like Sunday mornings or holidays."
msgstr ""
"<strong>Ennakkotilausjärjestelmä</strong>: Anna asiakkaidesi tehdä tilauksia "
"etukäteen ja varmista tuotteiden saatavuus ja valmistus ajallaan, "
"erityisesti kiireisinä aikoina, kuten sunnuntaiaamuina tai juhlapyhinä."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Restaurant mode</strong>: Manage tables, orders, and payments with "
"the Point of Sale system if you offer an \"eat-in\" option."
msgstr ""
"<strong>Ravintola-tila</strong>: Hallinnoi pöytiä, tilauksia ja maksuja "
"Kassajärjestelmällä, mikäli tarjoat \"syö ravintolassa\"-vaihtoehdon."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>Take orders in Point of Sale</strong>: Process in-store bread, loaf "
"and pastries orders quickly using the Point of Sale system."
msgstr ""
"<strong>Vastaanota tilauksia Kassajärjestelmässa</strong>: Käsittele "
"myymälään tulleet leipä-, leivonnais- ja pullatilaukset nopeasti "
"Kassajärjestelmän avulla."

#. module: bakery
#: model_terms:ir.ui.view,arch_db:bakery.welcome_article_body
msgid ""
"<strong>You didn't import demo data?</strong> You can still do it. Go to "
"<strong>Apps &gt; Industries &gt; Upgrade your Bakery Package</strong> and "
"check the related box."
msgstr ""
"<strong>Etkö tuonut demodataasi?</strong> Voit yhä tehdö sen. Siirry "
"<strong>Sovellukset &gt; Toimialat &gt; Päivitä Leipomopakettisi</strong> ja "
"laita rasti oleellisiin ruutuihin."

