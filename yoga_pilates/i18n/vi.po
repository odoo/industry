#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<span style=\"font-size: 36px;\"><strong>Yoga &amp; Pilates Studio</strong></"
"span>"
msgstr ""
"<span style=\"font-size: 36px;\"><strong>Phòng tập Yoga &amp; Pilates</"
"strong></span>"

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong><font style=\"color: rgb(113, 75, 103);\">The Appointment App</"
"font></strong> schedules yoga and pilates classes for easy booking."
msgstr ""
"<strong><font style=\"color: rgb(113, 75, 103);\">Ứng dụng Lịch hẹn</font></"
"strong> giúp lên lịch các lớp yoga và pilates, hỗ trợ việc đặt lớp dễ dàng "
"hơn."

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong><font style=\"color: rgb(113, 75, 103);\">The CRM App</font></"
"strong> converts leads into long-term members."
msgstr ""
"<strong><font style=\"color: rgb(113, 75, 103);\">Ứng dụng CRM</font></"
"strong> giúp chuyển đổi lead thành hội viên lâu dài."

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong><font style=\"color: rgb(113, 75, 103);\">The Employees App</font></"
"strong> tracks schedules, roles, and expertise."
msgstr ""
"<strong><font style=\"color: rgb(113, 75, 103);\">Ứng dụng Nhân sự</font></"
"strong> giúp theo dõi lịch làm việc, vai trò và chuyên môn của nhân viên."

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong><font style=\"color: rgb(113, 75, 103);\">The Planning App</font></"
"strong> assigns instructors based on expertise and availability."
msgstr ""
"<strong><font style=\"color: rgb(113, 75, 103);\">Ứng dụng Kế hoạch</font></"
"strong> phân công huấn luyện viên dựa trên chuyên môn và thời gian trống của "
"họ."

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong><font style=\"color: rgb(113, 75, 103);\">The Sales App</font></"
"strong> simplifies membership purchases and upgrades."
msgstr ""
"<strong><font style=\"color: rgb(113, 75, 103);\">Ứng dụng Bán hàng</font></"
"strong> giúp đơn giản hóa việc mua và nâng cấp gói hội viên."

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong><font style=\"color: rgb(113, 75, 103);\">The Subscription App</"
"font></strong> manages memberships like The Flow Membership: Unlimited Yoga "
"for one month."
msgstr ""
"<strong><font style=\"color: rgb(113, 75, 103);\">Ứng dụng Đăng ký</font></"
"strong> giúp quản lý các gói hội viên như Gói hội viên Thư thái: Tập Yoga "
"không giới hạn trong một tháng."

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong><font style=\"color: rgb(113, 75, 103);\">The Survey App</font></"
"strong> collects feedback to ensure your wellbeing offerings align with your "
"clients' expectations."
msgstr ""
"<strong><font style=\"color: rgb(113, 75, 103);\">Ứng dụng Khảo sát</font></"
"strong> thu thập ý kiến phản hồi để đảm bảo các dịch vụ chăm sóc sức khỏe "
"của bạn phù hợp với kỳ vọng của khách hàng."

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong><font style=\"color: rgb(113, 75, 103);\">The Website App</font></"
"strong> promotes your studio, explain your approach and enables online class "
"bookings."
msgstr ""
"<strong><font style=\"color: rgb(113, 75, 103);\">Ứng dụng Trang web</font></"
"strong> giúp quảng bá phòng tập của bạn, giới thiệu phương pháp luyện tập và "
"cho phép đặt lớp học online."

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid "<strong>Assign Membership Levels Automatically</strong>"
msgstr "<strong>Tự động gán cấp độ hội viên</strong>"

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong>Assign instructors automatically: </strong>With the <strong>auto-"
"plan</strong> option, instructors will be assigned to classes based on their "
"expertise and availability."
msgstr ""
"<strong>Tự động phân công huấn luyện viên:</strong> Với tùy chọn <strong>lên "
"lịch tự động</strong>, huấn luyện viên sẽ được phân công vào các lớp dựa "
"trên chuyên môn và thời gian trống của họ."

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong>Automate Renewals</strong><br/>\n"
"                    For recurring plans like monthly unlimited passes, "
"activate automatic renewal using the <strong>Subscriptions</strong> module."
msgstr ""
"<strong>Tự động gia hạn:</strong><br/> Với các gói định kỳ như thẻ không "
"giới hạn theo tháng, hãy kích hoạt tính năng tự động gia hạn bằng cách sử "
"dụng phân hệ <strong>Đăng ký</strong>."

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid "<strong>Basics</strong>"
msgstr "<strong>Cơ bản</strong>"

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong>Create Your Products</strong><br/>\n"
"                    Set up flexible options for your clients:"
msgstr ""
"<strong>Tạo sản phẩm của bạn</strong><br/>\n"
"                    Thiết lập các lựa chọn linh hoạt dành cho khách hàng:"

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong>Create engaging events</strong>: Use the <strong>Events app</strong> "
"to organize and promote special sessions like prenatal yoga."
msgstr ""
"<strong>Tạo sự kiện hấp dẫn</strong>: Sử dụng <strong>ứng dụng Sự kiện</"
"strong> để tổ chức và quảng bá các buổi học đặc biệt như yoga tiền sản."

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong>Create private session products</strong>: Set up offerings like "
"\"Private Yoga Class – Group Session\" for tailored experiences."
msgstr ""
"<strong>Tạo sản phẩm cho buổi tập riêng</strong>: Thiết lập các dịch vụ như "
"“Lớp yoga riêng – Buổi học nhóm” để mang đến trải nghiệm cá nhân hóa cho "
"khách hàng."

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid "<strong>Create your Yoga and Pilates schedule:</strong>"
msgstr "<strong>Tạo lịch học yoga và pilates của bạn:</strong>"

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong>Customize the \"Contact Us\" form</strong>: Adjust on your Studio "
"Website, the form to handle specific requests such as corporate events or "
"wellbeing retreats."
msgstr ""
"<strong>Tùy chỉnh biểu mẫu \"Liên hệ với chúng tôi\"</strong>: Điều chỉnh "
"biểu mẫu trên Trang web của Phòng tập để xử lý các yêu cầu cụ thể như sự "
"kiện doanh nghiệp hoặc chương trình nghỉ dưỡng chăm sóc sức khỏe."

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong>Define instructor expertise: </strong>In the <strong>Work "
"Information</strong> section of an employee, define employee's expertise by "
"using the <strong>Role</strong> field."
msgstr ""
"<strong>Xác định chuyên môn của huấn luyện viên:</strong> Trong phần "
"<strong>Thông tin công việc</strong> của nhân viên, hãy xác định chuyên môn "
"bằng cách sử dụng trường <strong>Vai trò</strong>."

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid "<strong>Do you want to go further?</strong>"
msgstr "<strong>Bạn có muốn tiến xa hơn không?</strong>"

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong>Enable easy online bookings</strong>: Utilize <strong>eCommerce "
"features</strong> to set up online booking and secure payment options for "
"classes."
msgstr ""
"<strong>Kích hoạt đặt lớp online dễ dàng</strong>: Sử dụng các <strong>tính "
"năng Thương mại điện tử</strong> để thiết lập hệ thống đặt lớp và thanh toán "
"an toàn cho khách hàng."

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong>Generate customized quotations:</strong> Use the \"Private Yoga "
"Class – Group Session (15+ People) Quotation Template\" to quickly create "
"tailored proposals for private or group bookings based on client requests."
msgstr ""
"<strong>Tạo báo giá tùy chỉnh:</strong> Sử dụng Mẫu báo giá “Lớp yoga riêng "
"– Buổi học nhóm (15+ người)” để nhanh chóng soạn thảo đề xuất phù hợp với "
"yêu cầu về các buổi học riêng hoặc nhóm của khách hàng."

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong>Manage Cancellations</strong><br/>\n"
"                    Set an end date for the subscription to close "
"automatically, or let clients cancel their subscription anytime via their "
"<strong>Odoo portal</strong>."
msgstr ""
"<strong>Quản lý Hủy đăng ký</strong><br/>\n"
"Bạn có thể đặt ngày kết thúc để gói hội viên tự động kết thúc, hoặc cho phép "
"khách hàng chủ động hủy đăng ký bất kỳ lúc nào thông qua <strong>cổng thông "
"tin Odoo</strong> của họ."

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong>Present studio offerings</strong>: In the <strong>Website app</"
"strong>, showcase your wellbeing approach and membership options."
msgstr ""
"<strong>Giới thiệu dịch vụ của phòng tập</strong>: Trong <strong>ứng dụng "
"Trang web</strong>, hãy trình bày phương pháp chăm sóc sức khỏe và các lựa "
"chọn hội viên của bạn."

