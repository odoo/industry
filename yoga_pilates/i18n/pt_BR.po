#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<span style=\"font-size: 36px;\"><strong>Yoga &amp; Pilates Studio</strong></"
"span>"
msgstr ""
"<span style=\"font-size: 36px;\"><strong>Estúdio de Ioga e Pilates</strong></"
"span>"

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong><font style=\"color: rgb(113, 75, 103)\"><b>Appointments App</b>: </"
"font></strong><font class=\"text-black\">Enable clients to easily book their "
"favorite yoga or pilates classes online, reducing administrative friction.</"
"font>"
msgstr ""
"<strong><font style=\"color: rgb(113, 75, 103)\"><b>App Compromissos</b>: </"
"font></strong><font class=\"text-black\"> Permita que os clientes reservem "
"facilmente suas aulas favoritas de ioga ou pilates online, reduzindo o "
"atrito administrativo.</font>"

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong><font style=\"color: rgb(113, 75, 103)\"><b>CRM App</b>: </font></"
"strong><font class=\"text-black\">Convert drop-in visitors into long-term "
"members by tracking leads and nurturing relationships.</font>"
msgstr ""
"<strong><font style=\"color: rgb(113, 75, 103)\"><b>App CRM</b>: </font></"
"strong><font class=\"text-black\"> Converta visitantes ocasionais em membros "
"de longo prazo, acompanhando leads e cultivando relacionamentos.</font>"

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong><font style=\"color: rgb(113, 75, 103)\"><b>Employees App</b>: </"
"font></strong><font class=\"text-black\">Track instructor schedules and "
"manage their skills to ensure high-quality service delivery.</font>"
msgstr ""
"<strong><font style=\"color: rgb(113, 75, 103)\"><b>App Funcionários</b>: </"
"font></strong><font class=\"text-black\"> Acompanhe os horários dos "
"instrutores e gerencie suas habilidades para garantir a prestação de "
"serviços de alta qualidade.</font>"

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong><font style=\"color: rgb(113, 75, 103)\"><b>Events App</b>: </font></"
"strong><font class=\"text-black\">Organize and manage special wellness "
"workshops or retreats to deeply engage your community.</font>"
msgstr ""
"<strong><font style=\"color: rgb(113, 75, 103)\"><b>App Eventos</b>: </"
"font></strong><font class=\"text-black\"> Organize e gerencie workshops ou "
"retiros especiais de bem-estar para envolver profundamente sua comunidade.</"
"font>"

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong><font style=\"color: rgb(113, 75, 103)\"><b>Sales App</b>: </font></"
"strong><font class=\"text-black\">Simplify the process of selling "
"memberships, class packs, and merchandise with a unified system.</font>"
msgstr ""
"<strong><font style=\"color: rgb(113, 75, 103)\"><b>App Vendas</b>: </font></"
"strong><font class=\"text-black\"> Simplifique o processo de venda de "
"assinaturas, pacotes de aulas e mercadorias com um sistema unificado.</font>"

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong><font style=\"color: rgb(113, 75, 103)\"><b>Subscription App</b>: </"
"font></strong><font class=\"text-black\">Secure revenue with automated "
"recurring billing for memberships like \"Unlimited Monthly Yoga.\"</font>"
msgstr ""
"<strong><font style=\"color: rgb(113, 75, 103)\"><b>App Assinatura</b>: </"
"font></strong><font class=\"text-black\"> Garanta sua receita com o "
"faturamento recorrente automatizado para assinaturas como “Yoga mensal "
"ilimitado”.</font>"

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong><font style=\"color: rgb(113, 75, 103)\"><b>Survey App</b>: </font></"
"strong><font class=\"text-black\">Gather valuable feedback from students to "
"ensure your classes and instructors meet their expectations.</font>"
msgstr ""
"<strong><font style=\"color: rgb(113, 75, 103)\"><b>App Pesquisas</b>: </"
"font></strong><font class=\"text-black\"> Obtenha feedback valioso dos "
"alunos para garantir que suas aulas e instrutores atendam às expectativas "
"deles.</font>"

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong><font style=\"color: rgb(113, 75, 103)\">Planning App:</font></"
"strong> Efficiently assign instructors to classes based on their specific "
"skills, availability, and expertise."
msgstr ""
"<strong><font style=\"color: rgb(113, 75, 103)\">App Planejamento:</font></"
"strong> Atribua instrutores às aulas de forma eficiente com base em suas "
"habilidades específicas, disponibilidade e experiência."

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid "<strong>Assign Membership Levels Automatically</strong>"
msgstr "<strong>Atribuir níveis de associação automaticamente</strong>"

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong>Assign instructors automatically: </strong>With the <strong>auto-"
"plan</strong> option, instructors will be assigned to classes based on their "
"expertise and availability."
msgstr ""
"<strong>Atribuir instrutores automaticamente: </strong>Com a opção "
"<strong>planejamento automático</strong>, os instrutores serão atribuídos às "
"aulas com base em sua experiência e disponibilidade."

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong>Automate Renewals</strong><br/>\n"
"                    For recurring plans like monthly unlimited passes, "
"activate automatic renewal using the <strong>Subscriptions</strong> module."
msgstr ""
"<strong>Renovações automáticas</strong><br/>\n"
"                    Para planos recorrentes, como passes mensais ilimitados, "
"ative a renovação automática usando o módulo <strong>Assinaturas</strong>."

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid "<strong>Basics</strong>"
msgstr "<strong>Noções básicas</strong>"

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong>Create Your Products</strong><br/>\n"
"                    Set up flexible options for your clients:"
msgstr ""
"<strong>Crie seus produtos</strong><br/>\n"
"                    Configure opções flexíveis para seus clientes:"

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong>Create engaging events</strong>: Use the <strong>Events app</strong> "
"to organize and promote special sessions like prenatal yoga."
msgstr ""
"<strong>Crie eventos envolventes</strong>: Use o aplicativo <strong>Eventos</"
"strong> para organizar e promover sessões especiais, como ioga pré-natal."

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong>Create private session products</strong>: Set up offerings like "
"\"Private Yoga Class – Group Session\" for tailored experiences."
msgstr ""
"<strong>Crie produtos para sessões particulares</strong>: Crie ofertas como "
"\"Aula particular de ioga - Sessão em grupo\" para experiências "
"personalizadas."

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid "<strong>Create your Yoga and Pilates schedule:</strong>"
msgstr "<strong>Crie sua programação de Ioga e Pilates:</strong>"

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong>Customize the \"Contact Us\" form</strong>: Adjust on your Studio "
"Website, the form to handle specific requests such as corporate events or "
"wellbeing retreats."
msgstr ""
"<strong>Personalize o formulário \"Entre em contato conosco\"</strong>: "
"Ajuste em seu site do Estúdio o formulário para lidar com solicitações "
"específicas, como eventos corporativos ou retiros de bem-estar."

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong>Define instructor expertise: </strong>In the <strong>Work "
"Information</strong> section of an employee, define employee's expertise by "
"using the <strong>Role</strong> field."
msgstr ""
"<strong>Definir a experiência do instrutor: </strong>Na seção "
"<strong>Informação profisssionais</strong> de um funcionário, defina a "
"experiência do funcionário usando o campo <strong>Funções</strong>."

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid "<strong>Do you want to go further?</strong>"
msgstr "<strong>Quer ir mais além?</strong>"

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong>Enable easy online bookings</strong>: Utilize <strong>eCommerce "
"features</strong> to set up online booking and secure payment options for "
"classes."
msgstr ""
"<strong>Habilite agendamentos online e fáceis</strong>: Utilize os "
"<strong>recursos do e-Commerce</strong> para configurar a reserva on-line e "
"opções de pagamento seguro para as aulas."

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong>Generate customized quotations:</strong> Use the \"Private Yoga "
"Class – Group Session (15+ People) Quotation Template\" to quickly create "
"tailored proposals for private or group bookings based on client requests."
msgstr ""
"<strong>Gere cotações personalizadas:</strong> Use o \"Modelo de cotação "
"para aula particular de ioga - sessão em grupo (15+ pessoas)\" para criar "
"rapidamente propostas personalizadas para reservas particulares ou em grupo "
"com base nas solicitações dos clientes."

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong>Manage Cancellations</strong><br/>\n"
"                    Set an end date for the subscription to close "
"automatically, or let clients cancel their subscription anytime via their "
"<strong>Odoo portal</strong>."
msgstr ""
"<strong>Gerecie cancelamentos</strong><br/>\n"
"                    Defina uma data de término para que a assinatura seja "
"encerrada automaticamente ou permita que os clientes cancelem a assinatura a "
"qualquer momento pelo <strong>portal Odoo</strong>."

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong>Present studio offerings</strong>: In the <strong>Website app</"
"strong>, showcase your wellbeing approach and membership options."
msgstr ""
"<strong>Envie ofertas do estúdio</strong>: No <strong>app Site</strong>, "
"mostre sua abordagem de bem-estar e opções de associação."

