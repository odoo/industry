#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong>Assign instructors automatically: </strong>With the <strong>auto-"
"plan</strong> option, instructors will be assigned to classes based on their "
"expertise and availability."
msgstr ""
"<strong>Automatisk tildeling af undervisere: </strong>Med indstillingen "
"<strong>automatisk planlægning</strong> tildeles undervisere hold ud fra "
"deres faglige kompetencer og tilgængelighed."

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong>Automate Renewals</strong><br/>\n"
"                    For recurring plans like monthly unlimited passes, "
"activate automatic renewal using the <strong>Subscriptions</strong> module."
msgstr ""
"<strong>Automatisér fornyelser</strong><br/>\n"
"                    For abonnementsordninger med tilbagevendende betaling, "
"såsom månedlige ubegrænsede adgangskort, kan du aktivere automatisk "
"fornyelse via modulet <strong>Abonnementer</strong>."

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
