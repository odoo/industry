#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong>Assign instructors automatically: </strong>With the <strong>auto-"
"plan</strong> option, instructors will be assigned to classes based on their "
"expertise and availability."
msgstr ""
"<strong>Määrää ohjaajia automaattisesti:</strong><strong>Automaattisen "
"suunnittelun</strong>avulla tunneille voidaan määrätä ohjaajia heidän "
"osaamiseensa ja saatavuutensa perusteella."

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong>Automate Renewals</strong><br/>\n"
"                    For recurring plans like monthly unlimited passes, "
"activate automatic renewal using the <strong>Subscriptions</strong> module."
msgstr ""
"<strong>Automatisoi uusinnat</strong><br/>\n"
"                                        Aktivoi toistuville tilauksille, "
"kuten rajoittamattomallle kuukausikortille, automaattinen uusiminen "
"<strong>Tilaukset-</strong>moduulin avulla."

