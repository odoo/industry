#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<span style=\"font-size: 36px;\"><strong>Yoga &amp; Pilates Studio</strong></"
"span>"
msgstr ""
"<span style=\"font-size: 36px;\"><strong>Studio Yoga &amp; "
"Pilates</strong></span>"

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong><font style=\"color: rgb(113, 75, 103)\"><b>Appointments App</b>: </"
"font></strong><font class=\"text-black\">Enable clients to easily book their "
"favorite yoga or pilates classes online, reducing administrative friction.</"
"font>"
msgstr ""
"<strong><font style=\"color: rgb(113, 75, 103)\"><b>Application de rendez-"
"vous</b> : </font></strong><font class=\"text-black\">permettez à vos "
"clients de réserver facilement en ligne leurs cours de yoga ou de pilates "
"préférés, tout en réduisant la charge administrative.</font>"

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong><font style=\"color: rgb(113, 75, 103)\"><b>CRM App</b>: </font></"
"strong><font class=\"text-black\">Convert drop-in visitors into long-term "
"members by tracking leads and nurturing relationships.</font>"
msgstr ""
"<strong><font style=\"color: rgb(113, 75, 103)\"><b>Application CRM</b> : "
"</font></strong><font class=\"text-black\">transformez les visiteurs "
"occasionnels en membres fidèles en suivant les pistes et en entretenant les "
"relations.</font>"

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong><font style=\"color: rgb(113, 75, 103)\"><b>Employees App</b>: </"
"font></strong><font class=\"text-black\">Track instructor schedules and "
"manage their skills to ensure high-quality service delivery.</font>"
msgstr ""
"<strong><font style=\"color: rgb(113, 75, 103)\"><b>Application Employés</b> "
": </font></strong><font class=\"text-black\">suivez les plannings des "
"instructeurs et gérez leurs compétences afin de garantir une prestation de "
"service de haute qualité.</font>"

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong><font style=\"color: rgb(113, 75, 103)\"><b>Events App</b>: </font></"
"strong><font class=\"text-black\">Organize and manage special wellness "
"workshops or retreats to deeply engage your community.</font>"
msgstr ""
"<strong><font style=\"color: rgb(113, 75, 103)\"><b>Application Événements</"
"b> : </font></strong><font class=\"text-black\">organisez et gérez des "
"ateliers bien-être ou des retraites pour engager votre communauté en "
"profondeur.</font>"

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong><font style=\"color: rgb(113, 75, 103)\"><b>Sales App</b>: </font></"
"strong><font class=\"text-black\">Simplify the process of selling "
"memberships, class packs, and merchandise with a unified system.</font>"
msgstr ""
"<strong><font style=\"color: rgb(113, 75, 103)\"><b>Application Ventes</b> : "
"</font></strong><font class=\"text-black\">simplifiez la vente d'adhésions, "
"de packs de cours et de produits dérivés grâce à un système unifié.</font>"

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong><font style=\"color: rgb(113, 75, 103)\"><b>Subscription App</b>: </"
"font></strong><font class=\"text-black\">Secure revenue with automated "
"recurring billing for memberships like \"Unlimited Monthly Yoga.\"</font>"
msgstr ""
"<strong><font style=\"color: rgb(113, 75, 103)\"><b>Application Abonnements</"
"b> : </font></strong><font class=\"text-black\">sécurisez vos revenus grâce "
"à une facturation récurrente automatisée pour des formules comme "
"\"yoga illimité mensuel\".</font>"

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong><font style=\"color: rgb(113, 75, 103)\"><b>Survey App</b>: </font></"
"strong><font class=\"text-black\">Gather valuable feedback from students to "
"ensure your classes and instructors meet their expectations.</font>"
msgstr ""
"<strong><font style=\"color: rgb(113, 75, 103)\"><b>Application Sondage</b> :"
" </font></strong><font class=\"text-black\">collectez du feedback précieux "
"auprès des participants afin de vous assurer que vos cours et instructeurs "
"répondent à leurs attentes.</font>"

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong><font style=\"color: rgb(113, 75, 103)\">Planning App:</font></"
"strong> Efficiently assign instructors to classes based on their specific "
"skills, availability, and expertise."
msgstr ""
"<strong><font style=\"color: rgb(113, 75, 103)\">Application Planification "
":</font></strong>attribuez efficacement les instructeurs aux cours selon "
"leurs compétences spécifiques, leur disponibilité et leur expertise."

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid "<strong>Assign Membership Levels Automatically</strong>"
msgstr "<strong>Attribuer automatiquement les niveaux d’adhésion</strong>"

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong>Assign instructors automatically: </strong>With the <strong>auto-"
"plan</strong> option, instructors will be assigned to classes based on their "
"expertise and availability."
msgstr ""
"<strong>Attribuer automatiquement les instructeurs : </strong>avec l’option "
"<strong>planification automatique</strong>, les instructeurs sont affectés "
"aux cours en fonction de leur expertise et de leur disponibilité."

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong>Automate Renewals</strong><br/>\n"
"                    For recurring plans like monthly unlimited passes, "
"activate automatic renewal using the <strong>Subscriptions</strong> module."
msgstr ""
"<strong>Automatiser les renouvellements</strong><br/> pour les formules "
"récurrentes comme les pass mensuels illimités, activez le renouvellement "
"automatique avec le module <strong>Abonnements</strong>."

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid "<strong>Basics</strong>"
msgstr "<strong>Les bases</strong>"

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong>Create Your Products</strong><br/>\n"
"                    Set up flexible options for your clients:"
msgstr ""
"<strong>Créer vos produits</strong><br/>\n"
"Configurez des options flexibles pour vos clients :"

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong>Create engaging events</strong>: Use the <strong>Events app</strong> "
"to organize and promote special sessions like prenatal yoga."
msgstr ""
"<strong>Créer des événements attrayants</strong> : utilisez l’<strong>app "
"Événements</strong> pour organiser et promouvoir des séances spéciales comme "
"le yoga prénatal."

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong>Create private session products</strong>: Set up offerings like "
"\"Private Yoga Class – Group Session\" for tailored experiences."
msgstr ""
"<strong>Créer des produits pour des séances privées</strong> : configurez "
"des offres comme \"Cours de yoga privé – séance de groupe\" pour des "
"expériences sur mesure."

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid "<strong>Create your Yoga and Pilates schedule:</strong>"
msgstr "<strong>Créer votre planning yoga et pilates :</strong>"

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong>Customize the \"Contact Us\" form</strong>: Adjust on your Studio "
"Website, the form to handle specific requests such as corporate events or "
"wellbeing retreats."
msgstr ""
"<strong>Personnaliser le formulaire \"Nous contacter\"</strong> : sur le "
"site web de votre studio, ajustez le formulaire pour traiter des demandes "
"spécifiques, comme des événements d’entreprise ou des retraites bien-être."

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong>Define instructor expertise: </strong>In the <strong>Work "
"Information</strong> section of an employee, define employee's expertise by "
"using the <strong>Role</strong> field."
msgstr ""
"<strong>Définir l’expertise d’un instructeur : </strong>dans la section "
"<strong>Informations professionnelles</strong> d’un employé, définissez l’"
"expertise de l’employé via le champ <strong>Rôle</strong>."

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid "<strong>Do you want to go further?</strong>"
msgstr "<strong>Souhaitez-vous aller plus loin ?</strong>"

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong>Enable easy online bookings</strong>: Utilize <strong>eCommerce "
"features</strong> to set up online booking and secure payment options for "
"classes."
msgstr ""
"<strong>Activer des réservations en ligne faciles</strong> : utilisez les "
"<strong>fonctionnalités eCommerce</strong> pour configurer les réservations "
"en ligne et des options de paiement sécurisé pour les cours."

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong>Generate customized quotations:</strong> Use the \"Private Yoga "
"Class – Group Session (15+ People) Quotation Template\" to quickly create "
"tailored proposals for private or group bookings based on client requests."
msgstr ""
"<strong>Générer des devis personnalisés :</strong>utilisez le "
"\"modèle de devis cours de yoga privé – séance de groupe (15+ personnes)\" "
"pour créer rapidement des propositions sur mesure pour des réservations "
"privées ou de groupe selon les demandes des clients."

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong>Manage Cancellations</strong><br/>\n"
"                    Set an end date for the subscription to close "
"automatically, or let clients cancel their subscription anytime via their "
"<strong>Odoo portal</strong>."
msgstr ""
"<strong>Gérer les annulations</strong><br/>\n"
"Définissez une date de fin pour que l’abonnement se clôture automatiquement, "
"ou laissez les clients résilier leur abonnement à tout moment via leur "
"<strong>portail Odoo</strong>."

#. module: yoga_pilates
#: model_terms:ir.ui.view,arch_db:yoga_pilates.welcome_article_body
msgid ""
"<strong>Present studio offerings</strong>: In the <strong>Website app</"
"strong>, showcase your wellbeing approach and membership options."
msgstr ""
"<strong>Présenter l’offre du studio</strong> : dans l’<strong>app Site Web</"
"strong>, mettez en avant votre approche du bien-être et vos options "
"d’adhésion."

