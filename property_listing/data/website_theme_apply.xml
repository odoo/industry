<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
        <function model="website.menu" name="write">
            <value model="website.menu" eval="obj().search([
                ('website_id', '=', ref('base.default_website')),
                ('url', '=', '/shop'),
            ], limit=1).id"/>
            <value eval="{'name': 'Properties'}"/>
        </function>
    </data>
    <function model="ir.ui.view" name="write">
        <value model="ir.ui.view" eval="obj().env.ref('property_listing.information_request').id"/>
        <value model="ir.ui.view" eval="{'arch': obj().env.ref('property_listing.information_request').arch.replace('*crm_team_id*', str(obj().env.ref('property_listing.crm_team_4', raise_if_not_found=False).id))
        }"/>
    </function>
</odoo>
