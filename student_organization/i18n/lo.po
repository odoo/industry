#. module: student_organization
#: model_terms:ir.ui.view,arch_db:student_organization.welcome_article_body
#, fuzzy
msgid ""
"<strong><b>Accounting App</b>: </strong>Keep track of the organization's "
"budget, managing expenses and income\n"
"                    from fees and fundraising.<br/>"
