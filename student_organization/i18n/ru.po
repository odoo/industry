msgstr "<strong>Что вы получаете:</strong>"

#. module: student_organization
#: model_terms:event.event,description:student_organization.event_event_1
msgid "<strong>Your student year starts <em>right here</em>!</strong>"
msgstr "<strong>Ваш студенческий год начинается <em>прямо здесь</em>!</strong>"

#. module: student_organization
#: model_terms:ir.ui.view,arch_db:student_organization.welcome_article_body
msgid ""
"<strong>eCommerce</strong>: Sell memberships online, integrated with payment "
"and\n"
"                    member accounts."
msgstr ""
"<strong>eCommerce</strong>: Продавайте членство онлайн с мгновенной оплатой "
"и\n"
"                    созданием личного кабинета."

#. module: student_organization
#: model_terms:ir.ui.view,arch_db:student_organization.homepage
msgid "A place for students to learn, share, collaborate.&amp;nbsp;"
msgstr ""
"Пространство, где студенты учатся, делятся опытом и работают "
"вместе.&amp;nbsp;"

#. module: student_organization
#: model_terms:event.event,description:student_organization.event_event_2
msgid "A red carpet welcome"
msgstr "Красная ковровая дорожка"

#. module: student_organization
#: model_terms:product.template,description_ecommerce:student_organization.product_template_41
msgid "A thank-you post on our Instagram page (2,000+ followers)"
msgstr "Пост-благодарность в нашем Instagram (более 2,000 подписчиков)"

#. module: student_organization
#: model_terms:product.template,description:student_organization.product_template_33
#: model_terms:product.template,description:student_organization.product_template_7
msgid "Access to the student union welcome party. Includes one drink voucher."
msgstr ""
"Вход на приветственную вечеринку студсоюза. Включает один купон на напиток."

#. module: student_organization
#: model_terms:product.template,description_ecommerce:student_organization.product_template_41
