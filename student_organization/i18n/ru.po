#. module: student_organization
#: model_terms:ir.ui.view,arch_db:student_organization.welcome_article_body
msgid ""
"<strong>Website</strong>: Build a beautiful site that reflects your student "
"org's\n"
"                    energy and values."
msgstr ""
"<strong>Вебсайт</strong>: Создайте стильную страницу, отражающую\n"
"                    энергию и ценности вашего студсоюза."

#. module: student_organization
#: model_terms:ir.ui.view,arch_db:student_organization.welcome_article_body
msgid ""
"<strong>Website</strong>: Promote your event with compelling pages and "
"embedded\n"
"                    ticket sales."
msgstr ""
"<strong>Веб-сайт</strong>: Продвигайте свое мероприятие с помощью эффектных "
"страниц и встроенной\n"
"                    системы продажи билетов."

#. module: student_organization
