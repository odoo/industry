#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong>Capture inquiries automatically</strong> from your website's contact "
"forms."
msgstr ""
"<strong>Collectez automatiquement les demandes</strong> depuis les "
"formulaires de contact de votre site web."

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong>Configure consent forms</strong> as reusable <strong>Sign document "
"templates</strong> for different camps."
msgstr ""
"<strong>Configurez des formulaires de consentement</strong> sous forme de "
"<strong>modèles de documents Signature</strong> réutilisables pour "
"différents camps."

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong>Create dedicated summer camp pages</strong> with detailed "
"information, schedules, and visuals."
msgstr ""
"<strong>Créez des pages dédiées aux camps d’été</strong> avec des "
"informations détaillées, des horaires et des visuels."

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong>Create quotations</strong> directly from the CRM when the lead is "
"ready to book, linking seamlessly with the Sales app."
msgstr ""
"<strong>Créez des devis</strong> directement depuis le CRM lorsque la piste "
"est prête à réserver, avec une intégration fluide à l’application Ventes."

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid "<strong>Customized pricing per attendee</strong>"
msgstr "<strong>Tarification personnalisée par participant</strong>"

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong>Drag and drop signature, text, and date fields</strong> to collect "
"all necessary information (e.g., emergency contact, medical permissions)."
msgstr ""
"<strong>Glissez-déposez des champs de signature, de texte et de date</"
"strong> pour collecter toutes les informations nécessaires (par ex. contact "
"d’urgence, autorisations médicales)."

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong>Email Marketing 🌟</strong>: Promote upcoming camps or send follow-"
"ups post-camp."
msgstr ""
"<strong>E-mail Marketing 🌟</strong> : Faites la promotion des camps à venir "
"ou envoyez des communications de suivi après les camps."

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid "<strong>Events 🏨</strong>"
msgstr "<strong>Événements 🏨</strong>"

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong>Experiment ! </strong>Did you know you can create a copy of your "
"database to try things out ? Simply go to"
msgstr ""
