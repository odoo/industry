#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong><b>Appointments App</b>:</strong> Let families book meetings to "
"discuss camp options easily, reducing no-shows with automatic reminders.<br/>"
msgstr ""
"<strong><b>Ajanvaraukset-sovellus</b>:</strong> Anna perheiden varata "
"tapaamisia leirivaihtoehdoista keskustelemiseksi ja vähennä peruutuksia "
"automaattisten muistutusten avulla.<br/>"

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong><b>CRM App</b>: </strong>Capture inquiries from your website, "
"qualify leads in a visual pipeline, and convert interest into confirmed "
"bookings.<br/>"
msgstr ""
"<strong><b>CRM-sovellus</b>: </strong>Kerää tiedustelut verkkosivuiltasi, "
"luokittele liidit visuaalisessa myyntiputkessa ja muokkaa kiinnostus "
"vahvistetuiksi varauksiksi.<br/>"

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong><b>Events App</b>: </strong>Create and manage every camp session "
"with custom forms, capacity tracking, and automated emails to keep parents "
"informed.<br/>"
msgstr ""
"<strong><b>Tapahtumat-sovellus</b>: </strong>Luo ja hallinnoi jokaista "
"leiriä mukautettujen lomakkeiden, osallistujamäärien seurannan sekä "
"automaattisten sähköpostiviestien avulla, jotta vanhemmat pysyvät ajan "
"tasalla.<br/>"

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong><b>Projects App</b>: </strong>Organize the behind-the-scenes "
"logistics using task lists and deadlines to ensure every activity is "
"prepared to perfection.<br/>"
msgstr ""
"<strong><b>Projekti-sovellus</b>: </strong>Järjestä kulissien logistiikka "
"tehtävälistojen ja määräaikojen avulla varmistaaksesi, että jokainen "
"toimenpide on valmisteltu täydellisesti.<br/>"

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong><b>Sign App</b>: </strong>Collect parental consent securely with "
"reusable digital signature templates, ensuring all legal documents are "
"signed and stored centrally.<br/>"
msgstr ""
"<strong><b>Allekirjoita-sovellus</b>: </strong>Kerää vanhempien suostumus "
"turvallisesti uudelleenkäytettävillä digitaalisilla allekirjoituspohjilla "
"varmistaaksesi, että kaikki oikeudelliset asiakirjat allekirjoitetaan ja "
"tallennetaan keskitetysti.<br/>"

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong><b>Website App</b>: </strong>Showcase your camps online with mobile-"
"friendly pages, integrated registration, and secure payment processing to "
"boost enrollments.<br/>"
msgstr ""
"<strong><b>Verkkosivu-sovellus</b>: </strong>Esittele leirisi verkossa "
"mobiiliystävällisillä sivuilla, integroidulla ilmoittautumisella ja "
"turvallisella maksunkäsittelyllä kasvattaaksesi ilmoittautuneiden "
"määrää.<br/>"

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong>Accounting 📈</strong>: Handle invoicing, revenue tracking, and full "
"financial reporting in one place."
msgstr ""
"<strong>Kirjanpito 📈</strong>: Hoida laskutus, liikevaihdon seuranta sekä "
"kaikenkattava taloudellinen raportointi yhdestä paikasta."

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong>Add custom tags</strong> like “IT Camp,” “Group Booking,” or "
"“Special Needs” to filter and segment leads."
msgstr ""
"<strong>Lisää räätälöityjä tunnisteita</strong> kuten \"IT-leiri\", "
"\"Ryhmävaraus\" tai \"Erityistarpeet\" suodattaaksesi ja segmentoidaksesi "
"liidejä."

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid "<strong>Appointments 📅</strong>"
msgstr "<strong>Ajanvaraukset 📅</strong>"

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong>Assign opportunities to the right team members</strong> based on "
"region, language, or camp type."
msgstr ""
"<strong>Määritä mahdollisuudet oikeille tiimin jäsenille</strong> alueen, "
"kielen tai leirityypin perusteella."

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong>Automated email and SMS reminders</strong> reduce no-shows and keep "
"everyone informed."
msgstr ""
"<strong>Automaattiset sähköposti- ja tekstiviestimuistutukset</strong> "
"vähentävät peruutuksia ja pitävät kaikki ajan tasalla."

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong>Built-in payment integration</strong> allows smooth and secure "
"transactions."
msgstr ""
"<strong>Sisäänrakennettu maksujen integraatio</strong> mahdollistaa sujuvat "
"ja turvalliset maksutapahtumat."

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid "<strong>CRM 🎯</strong>"
msgstr "<strong>CRM 🎯</strong>"

#. module: summer_camps
#: model_terms:event.event,ticket_instructions:summer_camps.event_event_1
#: model_terms:event.event,ticket_instructions:summer_camps.event_event_2
