#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong><b>Appointments App</b>:</strong> Let families book meetings to "
"discuss camp options easily, reducing no-shows with automatic reminders.<br/>"
msgstr ""

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong><b>CRM App</b>: </strong>Capture inquiries from your website, "
"qualify leads in a visual pipeline, and convert interest into confirmed "
"bookings.<br/>"
msgstr ""

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong><b>Events App</b>: </strong>Create and manage every camp session "
"with custom forms, capacity tracking, and automated emails to keep parents "
"informed.<br/>"
msgstr ""

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong><b>Projects App</b>: </strong>Organize the behind-the-scenes "
"logistics using task lists and deadlines to ensure every activity is "
"prepared to perfection.<br/>"
msgstr ""

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong><b>Sign App</b>: </strong>Collect parental consent securely with "
"reusable digital signature templates, ensuring all legal documents are "
"signed and stored centrally.<br/>"
msgstr ""

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong><b>Website App</b>: </strong>Showcase your camps online with mobile-"
"friendly pages, integrated registration, and secure payment processing to "
"boost enrollments.<br/>"
msgstr ""

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong>Accounting 📈</strong>: Handle invoicing, revenue tracking, and full "
"financial reporting in one place."
msgstr ""
"<strong>Kế toán 📈</strong>: Quản lý hóa đơn, theo dõi doanh thu và báo cáo "
"tài chính đầy đủ trong một nền tảng duy nhất."

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong>Add custom tags</strong> like “IT Camp,” “Group Booking,” or "
"“Special Needs” to filter and segment leads."
msgstr ""
"<strong>Thêm thẻ tùy chỉnh</strong> như “IT Camp,” “Group Booking,” hoặc "
"“Special Needs” để lọc và phân loại khách hàng tiềm năng."

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid "<strong>Appointments 📅</strong>"
msgstr "<strong>Lịch hẹn 📅</strong>"

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong>Assign opportunities to the right team members</strong> based on "
"region, language, or camp type."
msgstr ""
"<strong>Giao cơ hội cho các thành viên phù hợp trong nhóm</strong> dựa trên "
"khu vực, ngôn ngữ hoặc loại trại."

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong>Automated email and SMS reminders</strong> reduce no-shows and keep "
"everyone informed."
msgstr ""
"<strong>Nhắc nhở tự động qua email và tin nhắn SMS</strong> giúp giảm tỷ lệ "
"vắng mặt và đảm bảo mọi người đều được thông báo."

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong>Built-in payment integration</strong> allows smooth and secure "
"transactions."
msgstr ""
"<strong>Tích hợp thanh toán tích hợp sẵn</strong> cho phép thực hiện các "
"giao dịch mượt mà và an toàn."

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid "<strong>CRM 🎯</strong>"
msgstr "<strong>CRM 🎯</strong>"

#. module: summer_camps
#: model_terms:event.event,ticket_instructions:summer_camps.event_event_1
#: model_terms:event.event,ticket_instructions:summer_camps.event_event_2
#: model_terms:event.event,ticket_instructions:summer_camps.event_event_3
#: model_terms:event.event,ticket_instructions:summer_camps.event_event_4
#: model_terms:event.type,ticket_instructions:summer_camps.event_type_1
msgid "<strong>Camp Adventure – La Roche-en-Ardenne</strong>"
msgstr "<strong>Trại Hè Mạo Hiểm – La Roche-en-Ardenne</strong>"

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong>Capture inquiries automatically</strong> from your website's contact "
"forms."
msgstr ""
"<strong>Tự động thu thập thông tin liên hệ từ các biểu mẫu liên hệ trên "
"trang web của bạn</strong>."

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong>Configure consent forms</strong> as reusable <strong>Sign document "
"templates</strong> for different camps."
msgstr ""
"<strong>Cấu hình biểu mẫu đồng ý</strong> thành biểu mẫu có thể tái sử dụng "
"<strong>Ký mẫu tài liệu</strong> cho các nhóm khác nhau."

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong>Create dedicated summer camp pages</strong> with detailed "
"information, schedules, and visuals."
msgstr ""
"<strong>Tạo các trang web chuyên dụng cho trại hè tại</strong> với thông tin "
"chi tiết, lịch trình và hình ảnh minh họa."

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong>Create quotations</strong> directly from the CRM when the lead is "
"ready to book, linking seamlessly with the Sales app."
msgstr ""
"<strong>Tạo báo giá</strong> trực tiếp từ CRM khi lead sẵn sàng đặt chỗ, "
"liên kết liền mạch với ứng dụng Bán hàng."

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid "<strong>Customized pricing per attendee</strong>"
msgstr ""

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong>Drag and drop signature, text, and date fields</strong> to collect "
"all necessary information (e.g., emergency contact, medical permissions)."
msgstr ""
"<strong>Kéo và thả các trường chữ ký, văn bản và ngày tháng</strong> để thu "
"thập tất cả thông tin cần thiết (ví dụ: liên hệ khẩn cấp, giấy phép y tế)."

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong>Email Marketing 🌟</strong>: Promote upcoming camps or send follow-"
"ups post-camp."
msgstr ""
"<strong>Tiếp thị qua email 🌟</strong>: Quảng bá các trại hè sắp tới hoặc "
"gửi email theo dõi sau khi trại hè kết thúc."

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid "<strong>Events 🏨</strong>"
msgstr "<strong>Sự kiện 🏨</strong>"

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong>Experiment ! </strong>Did you know you can create a copy of your "
"database to try things out ? Simply go to"
msgstr ""
"<strong>Hãy thử nghiệm!</strong> Bạn có biết rằng bạn có thể tạo bản sao cơ "
"sở dữ liệu để thử nghiệm không? Chỉ cần đi đến"

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong>Generate a public share link</strong> for each template that can be "
"reused."
msgstr ""
"<strong>Tạo liên kết chia sẻ công khai</strong> cho mỗi mẫu có thể tái sử "
"dụng."

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong>Insert the share link directly into your confirmation emails</"
"strong> so parents can sign the document easily before arrival."
msgstr ""
"<strong>Chèn liên kết chia sẻ trực tiếp vào email xác nhận</strong> để phụ "
"huynh có thể ký tài liệu một cách dễ dàng trước khi đến."

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong>Integrated \"Register Now\" buttons</strong> link to event "
"registration."
msgstr ""
"<strong>Các nút \"Đăng ký ngay\" tích hợp</strong> dẫn đến trang đăng ký sự "
"kiện."

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong>Let customers self-schedule</strong> discovery calls or info "
"sessions at a time that suits them."
msgstr ""
"<strong>Cho phép khách hàng tự đặt lịch các cuộc gọi khám phá hoặc buổi "
"thông tin củ</strong> vào thời gian phù hợp với họ."

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong>Mobile-friendly experience</strong> ensures easy booking from any "
"device."
msgstr ""
"<strong>Trải nghiệm thân thiện với thiết bị di động</strong> đảm bảo việc "
"đặt chỗ dễ dàng từ bất kỳ thiết bị nào."

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid "<strong>Odoo helps you:</strong>"
msgstr "<strong>Odoo giúp bạn:</strong>"

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong>Organize opportunities by stage</strong> (e.g., New, Contacted, "
"Quotation Sent, Confirmed) using a visual kanban pipeline."
msgstr ""
"<strong>Sắp xếp các cơ hội theo giai đoạn (</strong> ) (ví dụ: Mới, Đã liên "
"hệ, Đã gửi báo giá, Đã xác nhận) bằng cách sử dụng một hệ thống kanban trực "
"quan."

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid "<strong>Projects 📋</strong>"
msgstr "<strong>Dự án 📋</strong>"

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong>Schedule meetings or calls</strong> directly from the CRM and sync "
"with your calendar."
msgstr ""
"<strong>Lên lịch cuộc họp hoặc cuộc gọi</strong> trực tiếp từ hệ thống CRM "
"và đồng bộ hóa với lịch của bạn."

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid "<strong>Sign ✍️</strong>"
msgstr "<strong>Ký tên ✍️</strong>"

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong>Social Marketing 💊</strong>: Share updates and stories across "
"social media platforms."
msgstr ""
"<strong>Marketing trên Mạng xã hội 💊</strong>: Chia sẻ các cập nhật và câu "
"chuyện trên các nền tảng mạng xã hội."

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong>Survey 📊</strong>: Collect feedback from parents and campers to "
"improve future sessions."
msgstr ""
"<strong>Khảo sát 📊</strong>: Thu thập phản hồi từ phụ huynh và học viên để "
"cải thiện các kỳ trại trong tương lai."

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong>Sync with Google or Outlook calendars</strong> to prevent conflicts "
"and stay updated."
msgstr ""
"<strong>Đồng bộ hóa với lịch Google hoặc Outlook</strong> để tránh xung đột "
"và luôn cập nhật."

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid ""
"<strong>Take notes, log calls, and attach documents</strong> on the "
"opportunity record to centralize communication."
msgstr ""
"<strong>Ghi chú, ghi lại cuộc gọi và đính kèm tài liệu</strong> vào hồ sơ cơ "
"hội để tập trung hóa giao tiếp."

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid "<strong>Visit our E-Learning platform </strong>on"
msgstr "<strong>Truy cập nền tảng Học trực tuyến của chúng tôi </strong>trên"

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid "<strong>Website 🌐</strong>"
