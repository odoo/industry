msgstr ""
"<strong>Organiza las oportunidades por etapa</strong> (por ejemplo, Nuevo, "
"Contactado, Presupuesto enviado, Confirmado) mediante un flujo visual tipo "
"kanban."

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
msgid "<strong>Projects 📋</strong>"
msgstr "<strong>Proyectos 📋</strong>"

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
