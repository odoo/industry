msgstr ""
"<strong>Encuestas 📊</strong>: recoge opiniones de las familias y de los "
"participantes para mejorar futuras ediciones del campamento."

#. module: summer_camps
#: model_terms:ir.ui.view,arch_db:summer_camps.welcome_article_body
