"Take advantage of the power of <strong>\n"
"          <font class=\"text-o-color-1\">Manufacturing App</font>\n"
"        </strong> with Manufacture To\n"
"        Order (MTO) capabilities."
msgstr ""
"Aprovecha el poder de <strong>\n"
"          <font class=\"text-o-color-1\">la aplicación Manufactura</font>\n"
"        </strong> con capacidad de fabricar\n"
"        bajo pedido."

#. module: food_distribution
#: model_terms:ir.ui.view,arch_db:food_distribution.welcome_article_body
msgid ""
"The Bill of Material is accessible from the Manufacturing App Products menu."
msgstr ""
