#. module: food_distribution
#: model_terms:ir.ui.view,arch_db:food_distribution.welcome_article_body
msgid ""
"<b>Documents App</b>: Centralize supplier certificates, quality control "
"reports, and shipping manifests for easy\n"
"          retrieval during audits."
msgstr ""

#. module: food_distribution
#: model_terms:ir.ui.view,arch_db:food_distribution.welcome_article_body
msgid ""
"<b>Fleet App</b>: Manage your delivery trucks and vans, tracking fuel logs, "
"maintenance schedules, and driver\n"
"          assignments in one place."
msgstr ""

#. module: food_distribution
#: model_terms:ir.ui.view,arch_db:food_distribution.welcome_article_body
msgid ""
"<b>Inventory App</b>: Master your stock with advanced features like Lots "
"&amp; Serial Numbers for traceability\n"
"          and Expiration Dates to enforce FEFO (First Expired, First Out) "
"removal strategies."
msgstr ""

#. module: food_distribution
#: model_terms:ir.ui.view,arch_db:food_distribution.welcome_article_body
msgid ""
"<b>Invoicing App</b>: Streamline your billing with automated invoicing based "
"on delivered quantities, ensuring\n"
"          accurate financial records."
msgstr ""

#. module: food_distribution
#: model_terms:ir.ui.view,arch_db:food_distribution.welcome_article_body
msgid ""
"<b>Purchase App</b>: Automate your procurement process with reordering rules "
"that account for vendor lead times\n"
"          and seasonal demand spikes."
msgstr ""

#. module: food_distribution
#: model_terms:ir.ui.view,arch_db:food_distribution.welcome_article_body
msgid ""
"<b>Sales App</b>: Manage complex pricing structures with Pricelists, "
"allowing you to offer specific deals to\n"
"          restaurants, retailers, or wholesalers."
msgstr ""

