<?xml version='1.0' encoding='UTF-8'?>
<odoo>
  <record id="field_product_template_label_note" model="ir.model.fields">
    <field name="ttype">text</field>
    <field name="field_description">Label Note</field>
    <field name="model_id" ref="product.model_product_template"/>
    <field name="name">x_label_note</field>
  </record>
  <record id="field_product_template_is_allergen" model="ir.model.fields">
    <field name="ttype">boolean</field>
    <field name="field_description">Is Allergen</field>
    <field name="model_id" ref="product.model_product_template"/>
    <field name="name">x_is_allergen</field>
  </record>
  <record id="field_x_nutritional_facts_name" model="ir.model.fields">
    <field name="ttype">char</field>
    <field name="field_description">Description</field>
    <field name="model_id" ref="model_x_nutritional_facts"/>
    <field name="name">x_name</field>
    <field name="required" eval="True"/>
    <field name="tracking">1</field>
    <field name="translate">standard</field>
  </record>
  <record id="field_x_nutritional_facts_active" model="ir.model.fields">
    <field name="ttype">boolean</field>
    <field name="field_description">Active</field>
    <field name="model_id" ref="model_x_nutritional_facts"/>
    <field name="name">x_active</field>
    <field name="tracking">1</field>
  </record>
  <record id="field_x_nutritional_facts_sequence" model="ir.model.fields">
    <field name="ttype">integer</field>
    <field name="field_description">Sequence</field>
    <field name="model_id" ref="model_x_nutritional_facts"/>
    <field name="name">x_sequence</field>
  </record>
  <record id="field_x_nutritional_facts_parent" model="ir.model.fields">
    <field name="ttype">many2one</field>
    <field name="field_description">Parent</field>
    <field name="model_id" ref="model_x_nutritional_facts"/>
    <field name="name">x_parent</field>
    <field name="relation">x_nutritional_facts</field>
  </record>
  <record id="field_x_nutritional_facts_unit" model="ir.model.fields">
    <field name="ttype">many2one</field>
    <field name="field_description">Unit</field>
    <field name="model_id" ref="model_x_nutritional_facts"/>
    <field name="name">x_unit_id</field>
    <field name="relation">uom.uom</field>
  </record>
  <record id="field_x_product_template_nutritional_fact_product_template_id" model="ir.model.fields">
    <field name="ttype">many2one</field>
    <field name="field_description">Product</field>
    <field name="model_id" ref="model_x_product_template_nutritional_fact"/>
    <field name="name">x_product_template_id</field>
    <field name="relation">product.template</field>
  </record>
  <record id="field_x_product_template_nutritional_fact_nutritional_fact_id" model="ir.model.fields">
    <field name="ttype">many2one</field>
    <field name="field_description">Nutritional Fact</field>
    <field name="model_id" ref="model_x_product_template_nutritional_fact"/>
    <field name="name">x_nutritional_fact_id</field>
    <field name="relation">x_nutritional_facts</field>
  </record>
  <record id="field_x_product_template_nutritional_fact_per_100g" model="ir.model.fields">
    <field name="ttype">float</field>
    <field name="field_description">Per 100g</field>
    <field name="model_id" ref="model_x_product_template_nutritional_fact"/>
    <field name="name">x_per_100g</field>
    <field name="required" eval="True"/>
  </record>
  <record id="field_x_product_template_nutritional_fact_unit" model="ir.model.fields">
    <field name="ttype">many2one</field>
    <field name="related">x_nutritional_fact_id.x_unit_id</field>
    <field name="field_description">Unit</field>
    <field name="model_id" ref="model_x_product_template_nutritional_fact"/>
    <field name="name">x_unit_id</field>
    <field name="readonly" eval="True"/>
    <field name="relation">uom.uom</field>
    <field name="store" eval="False"/>
  </record>
  <record id="field_x_product_template_nutritional_fact_sequence" model="ir.model.fields">
    <field name="ttype">integer</field>
    <field name="field_description">Sequence</field>
    <field name="model_id" ref="model_x_product_template_nutritional_fact"/>
    <field name="name">x_sequence</field>
    <field name="related">x_nutritional_fact_id.x_sequence</field>
    <field name="store" eval="False"/>
  </record>
  <record id="field_x_product_template_ingredients_product_template_id" model="ir.model.fields">
    <field name="ttype">many2one</field>
    <field name="field_description">Product</field>
    <field name="model_id" ref="model_x_product_template_ingredients"/>
    <field name="name">x_product_template_id</field>
    <field name="relation">product.template</field>
  </record>
  <record id="field_x_product_template_ingredients_ingredient_id" model="ir.model.fields">
    <field name="ttype">many2one</field>
    <field name="field_description">Ingredient</field>
    <field name="model_id" ref="model_x_product_template_ingredients"/>
    <field name="name">x_ingredient_id</field>
    <field name="relation">product.template</field>
  </record>
  <record id="field_x_product_template_ingredients_is_allergen" model="ir.model.fields">
    <field name="ttype">boolean</field>
    <field name="related">x_ingredient_id.x_is_allergen</field>
    <field name="field_description">Is Allergen</field>
    <field name="model_id" ref="model_x_product_template_ingredients"/>
    <field name="name">x_is_allergen</field>
    <field name="readonly" eval="True"/>
    <field name="store" eval="False"/>
  </record>
  <record id="field_x_product_template_ingredients_sequence" model="ir.model.fields">
    <field name="ttype">integer</field>
    <field name="field_description">Sequence</field>
    <field name="model_id" ref="model_x_product_template_ingredients"/>
    <field name="name">x_sequence</field>
  </record>
  <record id="field_x_product_template_ingredients_share" model="ir.model.fields">
    <field name="ttype">integer</field>
    <field name="field_description">Proportion (%)</field>
    <field name="model_id" ref="model_x_product_template_ingredients"/>
    <field name="name">x_share</field>
  </record>
  <record id="field_product_template_nutritional_facts" model="ir.model.fields">
    <field name="ttype">one2many</field>
    <field name="field_description">Nutritional Facts</field>
    <field name="model_id" ref="product.model_product_template"/>
    <field name="name">x_nutritional_fact_ids</field>
    <field name="relation">x_product_template_nutritional_fact</field>
    <field name="relation_field">x_product_template_id</field>
  </record>
  <record id="field_product_template_ingredients" model="ir.model.fields">
    <field name="ttype">one2many</field>
    <field name="field_description">Ingredients</field>
    <field name="model_id" ref="product.model_product_template"/>
    <field name="name">x_ingredient_ids</field>
    <field name="relation">x_product_template_ingredients</field>
    <field name="relation_field">x_product_template_id</field>
  </record>
  <record id="field_sale_order_is_mto_without_date" model="ir.model.fields">
    <field name="ttype">boolean</field>
    <field name="field_description">Is MTO without date</field>
    <field name="model_id" ref="sale.model_sale_order"/>
    <field name="name">x_is_mto_without_date</field>
    <field name="depends">commitment_date,order_line.product_template_id.route_ids</field>
    <field name="compute"><![CDATA[
mto_route = self.env.ref('stock.route_warehouse0_mto', raise_if_not_found=False)
for rec in self:
    routes = rec.order_line.mapped('product_template_id.route_ids')
    rec['x_is_mto_without_date'] = (mto_route in routes and not rec.commitment_date)
]]></field>
  </record>
</odoo>
