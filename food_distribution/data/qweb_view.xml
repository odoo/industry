<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="food_distribution_inherit_report_lot_label" model="ir.ui.view">
        <field name="arch" type="xml">
            <xpath expr="//t[@t-call='web.basic_layout']" position="replace">
                <t t-call="web.basic_layout">
                    <style>
                        body { margin: 0 !important; padding: 0 !important; }
                        .o_label_sheet { padding: 0 !important; margin: 0 !important; }
                        .page {
                            width: 57mm;
                            height: 102mm;
                            padding: 0 !important;
                            margin: 0 !important;
                            overflow: hidden;
                            page-break-after: always;
                            font-family: sans-serif;
                        }
                    </style>
                    <t t-set="nRows" t-value="1"/>
                    <t t-set="nCols" t-value="1"/>
                    <div class="page">
                        <div t-foreach="[docs[x:x + nRows * nCols] for x in range(0, len(docs), nRows * nCols)]" t-as="page_docs" class="o_label_sheet">
                            <div t-att-style="'padding: 0; margin: 0;'">
                                <table class="my-0 table table-sm table-borderless">
                                    <t t-foreach="range(nRows)" t-as="row">
                                        <tr>
                                            <t t-foreach="range(nCols)" t-as="col">
                                                <t t-set="barcode_index" t-value="(row * nCols + col)"/>
                                                <t t-if="barcode_index &lt; len(page_docs)">
                                                    <t t-set="o" t-value="page_docs[barcode_index]"/>
                                                </t>
                                                <t t-else="">
                                                    <t t-set="o" t-value="page_docs[0]"/>
                                                </t>
                                                <td class="label-main-container" t-att-style="barcode_index &gt;= len(page_docs) and 'visibility:hidden'">
                                                    <div t-att-style="'position:relative; width:55mm; height:100mm; border: 1px solid %s;' % (o.env.user.company_id.primary_color or 'black')">
                                                    <t t-set="final_barcode" t-value="''"/>
                                                    <t t-if="env.user.has_group('stock.group_stock_lot_print_gs1')">
                                                        <t t-if="o.product_id.valid_ean" t-set="final_barcode" t-value="'01' + '0' * (14 - len(o.product_id.barcode)) + o.product_id.barcode"/>
                                                        <t name="gs1_datamatrix_lot" t-if="o.product_id.tracking == 'lot'" t-set="final_barcode" t-value="(final_barcode or '') + '10' + o.name"/>
                                                        <t t-elif="o.product_id.tracking == 'serial'" t-set="final_barcode" t-value="(final_barcode or '') + '21' + o.name"/>
                                                    </t>
                                                    <div t-if="o.product_id.default_code" t-att-style="'width:22mm' if final_barcode else ''">[<t t-out="o.product_id.default_code"/>]</div>
                                                    <strong style="font-size: 12px;">
                                                        <div t-field="o.product_id.name" t-att-style="'width:22mm' if final_barcode else ''">Demo Product</div>
                                                    </strong>
                                                    <div style="font-size: 8px;" name="ingredients_list">
                                                        <strong>Ingredients: </strong>
                                                        <t t-foreach="o.product_id.x_ingredient_ids" t-as="line"><span t-out="line.x_ingredient_id.name.upper() if line.x_ingredient_id.x_is_allergen else line.x_ingredient_id.name"/>
                                                            <span t-out="'(' + str(line.x_share) + '%)' if line.x_share &gt; 0 else ''"/><t t-if="not line_last">, </t>
                                                        </t>
                                                    </div>
                                                    <strong>
                                                        <div style="font-size: 7px;" name="label_note" t-field="o.product_id.x_label_note">Label Note</div>
                                                    </strong>
                                                    <br/>
                                                    <br/>
                                                    <table style="width: 100%; border-collapse: collapse;">
                                                        <tbody>
                                                            <tr>
                                                                <td style="width: 30%; vertical-align: top;">
                                                                    <div style="font-size: 6px;">
                                                                        <strong t-field="res_company.name"/>
                                                                        <br/>
                                                                        <span t-field="res_company.street"/>
                                                                        <br/>
                                                                        <t t-if="res_company.street2">
                                                                        <span t-field="res_company.street2"/>
                                                                        <br/>
                                                                        </t>
                                                                        <span t-field="res_company.zip"/>
                                                                        <span t-field="res_company.city"/>
                                                                        <br/>
                                                                        <span t-field="res_company.country_id.name"/>
                                                                    </div>
                                                                    <div>
                                                                        <img t-if="res_company.logo" t-att-src="image_data_uri(res_company.logo)" style="width: 65px; height: 65px; object-fit: contain;"/>
                                                                    </div>
                                                                </td>
                                                                <td style="width: 45%; vertical-align: top;">
                                                                    <table style="width: 100%; border: 1px solid black; border-collapse: collapse;">
                                                                        <thead>
                                                                            <tr style="border-bottom: 1px solid black; background-color: #f2f2f2; font-size: 6px;">
                                                                                <th style="padding: 1px; text-align: left;">
                                                                                <strong>Nutritional Fact</strong>
                                                                                </th>
                                                                                <th style="padding: 1px; text-align: right;">
                                                                                <strong>Per 100g</strong>
                                                                                </th>
                                                                            </tr>
                                                                        </thead>
                                                                        <tbody>
                                                                            <t t-foreach="o.product_id.x_nutritional_fact_ids" t-as="fact">
                                                                                <tr style="border-bottom: 0.5px solid #eee; font-size: 6px;">
                                                                                <td style="padding: 2px; text-align: left;">
                                                                                    <span t-field="fact.x_nutritional_fact_id"/>
                                                                                </td>
                                                                                <td style="padding: 2px; text-align: right;">
                                                                                    <span t-field="fact.x_per_100g"/>
                                                                                </td>
                                                                                </tr>
                                                                            </t>
                                                                        </tbody>
                                                                    </table>
                                                                </td>
                                                            </tr>
                                                        </tbody>
                                                    </table>
                                                    <br/>
                                                    <table style="width: 100%; border-collapse: collapse; table-layout: fixed;">
                                                        <tbody>
                                                            <tr>
                                                                <td style="width: 40%; vertical-align: top; padding-right: 2px;">
                                                                    <div style="font-size: 6px;">
                                                                        <div name="lot_name" t-if="o.name">
                                                                        <span>Batch/Lot: </span>
                                                                        <br/>
                                                                        <span t-field="o.name"/>
                                                                        </div>
                                                                        <t t-if="o.use_expiration_date">
                                                                            <div t-if="o.use_date">
                                                                                B.b. <t t-out="o.use_date" t-options="{&quot;widget&quot;: &quot;date&quot;}"/>
                                                                            </div>
                                                                            <div t-if="o.expiration_date">
                                                                                Exp. <t t-out="o.expiration_date" t-options="{&quot;widget&quot;: &quot;date&quot;}"/>
                                                                            </div>
                                                                        </t>
                                                                    </div>
                                                                </td>
                                                                <td style="width: 50%; vertical-align: top; text-align: center;">
                                                                    <div>
                                                                        <span t-field="o.product_id.barcode" t-options="{'widget': 'barcode', 'img_style': 'width:100%; height:35%'}">Demo Lot/SN</span>
                                                                        <br/>
                                                                        <span t-field="o.product_id.barcode" style="horizontal-align: top; font-size: 6px;"/>
                                                                    </div>
                                                                </td>
                                                            </tr>
                                                        </tbody>
                                                    </table>
                                                    </div>
                                                </td>
                                            </t>
                                        </tr>
                                    </t>
                                </table>
                            </div>
                            <div class="oe_structure"/>
                        </div>
                    </div>
                </t>
            </xpath>
        </field>
        <field name="inherit_id" ref="stock.report_lot_label"/>
        <field name="key">food_distribution.food_distribution_report_lot_label</field>
        <field name="mode">extension</field>
        <field name="name">food_distribution_inherit_report_lot_label</field>
        <field name="type">qweb</field>
        <field name="active" eval="True"/>
    </record>

    <record id="food_distribution_inherit_report_lot_label_expiry" model="ir.ui.view">
        <field name="arch" type="xml">
            <xpath expr="//div[@name='lot_name']/following-sibling::t[@t-if='o.use_expiration_date']" position="replace"/>
        </field>
        <field name="inherit_id" ref="product_expiry.report_lot_label_expiry"/>
        <field name="key">food_distribution.food_distribution_report_lot_label_expiry</field>
        <field name="mode">extension</field>
        <field name="name">food_distribution_inherit_report_lot_label_expiry</field>
        <field name="type">qweb</field>
        <field name="active" eval="True"/>
    </record>
</odoo>
