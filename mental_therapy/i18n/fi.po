#: model_terms:ir.ui.view,arch_db:mental_therapy.welcome_article_body
msgid "academy"
msgstr "akatemia"

#. module: mental_therapy
#: model_terms:ir.ui.view,arch_db:mental_therapy.welcome_article_body
msgid "and"
msgstr "ja"

#. module: mental_therapy
#: model_terms:ir.ui.view,arch_db:mental_therapy.welcome_article_body
msgid "documentation"
msgstr "dokumentaatio"

#. module: mental_therapy
#: model_terms:ir.ui.view,arch_db:mental_therapy.welcome_article_body
msgid "if you need help!<br/>"
msgstr "jos tarvitset apua!<br/>"

