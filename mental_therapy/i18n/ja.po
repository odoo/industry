#. module: mental_therapy
#: model:mail.template,body_html:mental_therapy.booking_suggestion
msgid ""
"<p>\n"
"                Hello,\n"
"            </p>\n"
"            <p>\n"
"                Thank you for your presence. May I invite you to schedule your next appointment if needed?\n"
"            </p>\n"
"            <p>\n"
"                Looking forward to meeting you.\n"
"            </p>\n"
"            \n"
"            <p>\n"
"                <a class=\"btn btn-secondary\" href=\"/book/therapy_session\">Schedule an Appointment</a>\n"
"            </p>\n"
