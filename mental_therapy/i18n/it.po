#: model_terms:ir.ui.view,arch_db:mental_therapy.welcome_article_body
msgid "<span class=\"h1-fs\"><strong>Basics</strong></span>"
msgstr "<span class=\"h1-fs\"><strong>Informazioni di base</strong></span>"

#. module: mental_therapy
#: model_terms:ir.ui.view,arch_db:mental_therapy.welcome_article_body
