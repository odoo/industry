msgstr "Смотреть всё<span class=\"fa fa-long-arrow-right ms-2\"/>"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid "Sell them via <strong>Website or POS</strong>."
msgstr "Продавайте их через модули <strong>Вебсайт или POS</strong>."

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid "Set up <strong>schedules and time slots</strong> per room and per day."
msgstr ""
