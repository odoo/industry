#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid ""
"<strong>Accounting</strong>: Automatically log payments, close sessions, and "
"generate tax reports."
msgstr ""
"<strong>Kirjanpito</strong>: Kirjaa automaattisesti maksut, sulkee istunnot "
"ja luo veroraportteja."

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid ""
"<strong>Appointments 📅:</strong> Let guests pick room, date, time from your "
"live calendar, turns choices into confirmed slots, locks room capacity."
msgstr ""
"<strong>Ajanvaraukset 📅:</strong> Anna vieraiden valita huone, päivämäärä "
"ja kellonaika reaaliaikaisesta kalenteristasi, muuntaa valinnat "
"vahvistetuiksi ajoiksi ja lukitse huone täksi ajaksi."

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid "<strong>Appointments 📅</strong>"
msgstr "<strong>Ajanvaraukset 📅</strong>"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid "<strong>Apps &amp; What They Do:</strong>"
msgstr "<strong>Sovellukset&amp;mitä ne tekevät:</strong>"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.ir_ui_view_3760
msgid ""
"<strong>Are your escape rooms scary?</strong>\n"
"                          <br/>"
msgstr ""
"<strong>Ovatko pakohuoneenne pelottavia?</strong>\n"
"                          <br/>"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.ir_ui_view_3760
msgid ""
"<strong>Are your rooms suitable for kids or families?</strong>\n"
"                          <br/>"
msgstr ""
"<strong>Sopivatko huoneenne lapsille tai perheille?</strong>\n"
"                          <br/>"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid ""
"<strong>CRM 🎯: </strong>Track inquiries, group events, corporate deals, "
"repeat-player campaigns."
msgstr ""
"<strong>CRM 🎯: </strong>Seuraa tiedusteluja, ryhmätapahtumia, "
"yritystarjouksia ja palaavien pelaajien kampanjoita."

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.ir_ui_view_3760
msgid ""
"<strong>Can we play with fewer players than the recommended minimum?</"
"strong>\n"
"                          <br/>"
msgstr ""
"<strong>Voiko pelaajia olla vähemmän kuin suositeltu vähimmäismäärä?</"
"strong>\n"
"                          <br/>"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.ir_ui_view_3760
msgid ""
"<strong>Do I need any special knowledge or skills to play?</strong>\n"
"                          <br/>"
msgstr ""
"<strong>Tarvitsenko pelaamiseen mitään aiempia tietoja tai taitoja?</"
"strong>\n"
"                          <br/>"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid "<strong>Gift Cards 🎁 </strong>"
msgstr "<strong>Lahjakortit 🎁 </strong>"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.ir_ui_view_3760
msgid ""
"<strong>How long does an escape room last?</strong>\n"
"                          <br/>"
msgstr ""
"<strong>Kauanko pakohuonepeli kestää?</strong>\n"
"                          <br/>"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid "<strong>How to use it</strong>"
msgstr "<strong>Käyttöohjeet:</strong>"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid ""
"<strong>Planning</strong>: Build your weekly staff schedule based on room "
"bookings and predicted attendance."
msgstr ""
"<strong>Suunnittelu</strong>: Laadi viikoittaiset työvuorot huonevarausten "
"ja ennustetun läsnäolon perusteella."

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid ""
"<strong>Point of Sale 🛒:</strong> Sell walk-ins, snacks, drinks, souvenirs "
"with barcode speed."
msgstr ""
"<strong>Kassajärjestelmä 🛒:</strong> Myy varauksia ilman ajanvarausta, "
"välipaljoa, matkamuistoja viivakoodien siivittämällä nopeudella."

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid ""
"<strong>Project</strong>: Manage the development of your next room — from "
"concept to construction to launch."
msgstr ""
"<strong>Projekti</strong>: Hallinnoi seuraavan huoneesi kehitystyötä — "
"konseptista rakennukseen."

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid ""
"<strong>Sign</strong>: Send and receive digital contracts for team events, "
"partnerships, or corporate clients."
msgstr ""
"<strong>Allekirjoita</strong>: Lähetä ja vastaanota tiimitapahtumien, "
"kumppanuuksien ja yritysasiakkaiden sähköisiä sopimuksia."

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid "<strong>Tips for Success</strong>"
msgstr "<strong>Onnistumisvinkit</strong>"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid ""
"<strong>Website 🌐:</strong> Show rooms, stories, prices; capture "
"reservations in real time, sell gift cards"
msgstr ""
"<strong>verkkosivu 🌐:</strong> Esittele huoneet, niiden juonet ja hinnat; "
"houkuta varaamaan reaaliajassa, myy lahjakortteja"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.ir_ui_view_3760
msgid ""
"<strong>What happens if we don’t escape in time?</strong>\n"
"                          <br/>"
msgstr ""
"<strong>Mitä jos emme pääse ajoissa ulos?</strong>\n"
"                                                    <br/>"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.homepage
msgid "<strong>You’re Not Playing a Game. You’re Living a Story.</strong>"
msgstr "<strong>Et vain pelaa peliä. Elät sen tarinassa.</strong>"

#. module: escape_rooms
#: model_terms:product.template,description:escape_rooms.product_product_27_product_template
msgid "A tasty chocolate bar to enjoy after your escape."
msgstr "Maukas suklaapatukka nautittavaksi pakosi jälkeen."

