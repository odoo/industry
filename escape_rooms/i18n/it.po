#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid ""
"<strong>Accounting</strong>: Automatically log payments, close sessions, and "
"generate tax reports."
msgstr ""
"<strong>Contabilità</strong>: registra automaticamente i pagamenti, chiudi "
"le sessioni e genera resoconti fiscali"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid ""
"<strong>Appointments 📅:</strong> Let guests pick room, date, time from your "
"live calendar, turns choices into confirmed slots, locks room capacity."
msgstr ""
"<strong>Appuntamenti 📅:</strong> consenti agli ospiti di scegliere la "
"stanza, la data e l'orario dal tuo calendario in tempo reale, trasforma le "
"scelte in slot confermati e blocca la capienza della stanza"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid "<strong>Appointments 📅</strong>"
msgstr "<strong>Appuntamenti 📅</strong>"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid "<strong>Apps &amp; What They Do:</strong>"
msgstr "<strong>Applicazioni e utilità:</strong>"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.ir_ui_view_3760
msgid ""
"<strong>Are your escape rooms scary?</strong>\n"
"                          <br/>"
msgstr ""
"<strong>Le escape room sono spaventose?</strong>\n"
"                          <br/>"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.ir_ui_view_3760
msgid ""
"<strong>Are your rooms suitable for kids or families?</strong>\n"
"                          <br/>"
msgstr ""
"<strong>Le escape room sono adatte a bambini o famiglie?</strong>\n"
"                          <br/>"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid ""
"<strong>CRM 🎯: </strong>Track inquiries, group events, corporate deals, "
"repeat-player campaigns."
msgstr ""
"<strong>CRM 🎯: </strong>traccia richieste, eventi di gruppo, accordi "
"aziendali, campagne per giocatori abituali."

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.ir_ui_view_3760
msgid ""
"<strong>Can we play with fewer players than the recommended minimum?</"
"strong>\n"
"                          <br/>"
msgstr ""
"<strong>È possibile giocare con meno giocatori rispetto al numero minimo "
"suggerito?</strong>\n"
"                          <br/>"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.ir_ui_view_3760
msgid ""
"<strong>Do I need any special knowledge or skills to play?</strong>\n"
"                          <br/>"
msgstr ""
"<strong>Sono necessarie conoscenze o competenze speciali per partecipare?</"
"strong>\n"
"                          <br/>"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid "<strong>Gift Cards 🎁 </strong>"
msgstr "<strong>Carte regalo 🎁 </strong>"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.ir_ui_view_3760
msgid ""
"<strong>How long does an escape room last?</strong>\n"
"                          <br/>"
msgstr ""
"<strong>Quanto dura un'escape room?</strong>\n"
"                          <br/>"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid "<strong>How to use it</strong>"
msgstr "<strong>Utilizzo</strong>"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid ""
"<strong>Planning</strong>: Build your weekly staff schedule based on room "
"bookings and predicted attendance."
msgstr ""
"<strong>Pianificazione</strong>: crea il programma settimanale del personale "
"in base alle prenotazioni delle camere e alla partecipazione prevista"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid ""
"<strong>Point of Sale 🛒:</strong> Sell walk-ins, snacks, drinks, souvenirs "
"with barcode speed."
msgstr ""
"<strong>Punto vendita 🛒:</strong> vendi prodotti da banco, snack, bevande e "
"souvenir grazie alla velocità dei codici a barre"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid ""
"<strong>Project</strong>: Manage the development of your next room — from "
"concept to construction to launch."
msgstr ""
"<strong>Progetti</strong>: gestisci lo sviluppo della prossima stanza, "
"dall'ideazione alla costruzione fino al lancio."

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid ""
"<strong>Sign</strong>: Send and receive digital contracts for team events, "
"partnerships, or corporate clients."
msgstr ""
"<strong>Firma</strong>: invia e ricevi contratti in formato digitale per "
"eventi di team, partnership o clienti aziendali"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
#, fuzzy
msgid "<strong>Tips for Success</strong>"
msgstr "<strong>Consigli</strong>"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid ""
"<strong>Website 🌐:</strong> Show rooms, stories, prices; capture "
"reservations in real time, sell gift cards"
msgstr ""
"<strong>Sito web 🌐:</strong> mostra stanze, storie, prezzi; acquisisci "
"prenotazioni in tempo reale, vendi buoni regalo"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.ir_ui_view_3760
