#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid ""
"<strong>Accounting</strong>: Automatically log payments, close sessions, and"
" generate tax reports."
msgstr ""
"<strong>ການບັນຊີ</strong>: ບັນທຶກການຊຳລະເງິນໂດຍອັດຕະໂນມັດ, ປິດຮອບການຂາຍ, ແລະ ສ້າງລາຍງາ"
"ນພາສີ."

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid ""
"<strong>Appointments 📅:</strong> Let guests pick room, date, time from your "
"live calendar, turns choices into confirmed slots, locks room capacity."
msgstr ""
"<strong>ການນັດໝາຍ 📅:</strong> ໃຫ້ລູກຄ້າເລືອກຫ້ອງ, ວັນທີ, ແລະ ເວລາ ຈາກປະຕິທິນຂອງທ່ານ, ປ່ຽ"
"ນການເລືອກໃຫ້ເປັນການຈອງທີ່ຢືນຢັນແລ້ວ, ແລະ ລັອກຈຳນວນຄົນທີ່ເຂົ້າໄດ້."

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid "<strong>Appointments 📅</strong>"
msgstr "<strong>ການນັດໝາຍ 📅</strong>"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid "<strong>Apps &amp; What They Do:</strong>"
msgstr "<strong>ແອັບຯ ແລະ ໜ້າທີ່ຂອງມັນ:</strong>"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.ir_ui_view_3760
msgid ""
"<strong>Are your escape rooms scary?</strong>\n"
"                          <br/>"
msgstr ""
"<strong>ຫ້ອງປິດສະໜາຂອງທ່ານໜ້າຢ້ານບໍ່?</strong>\n"
"                          <br/>"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.ir_ui_view_3760
msgid ""
"<strong>Are your rooms suitable for kids or families?</strong>\n"
"                          <br/>"
msgstr ""
"<strong>ຫ້ອງຂອງທ່ານເໝາະສຳລັບເດັກນ້ອຍ ຫຼື ຄອບຄົວບໍ່?</strong>\n"
"                          <br/>"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid ""
"<strong>CRM 🎯: </strong>Track inquiries, group events, corporate deals, "
"repeat-player campaigns."
msgstr ""
"<strong>CRM 🎯: </strong>ຕິດຕາມການສອບຖາມ, ກິດຈະກຳກຸ່ມ, ຂໍ້ຕົກລົງຂອງບໍລິສັດ, ແລະ ແຄມເປນສຳ"
"ລັບລູກຄ້າເກົ່າ."

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.ir_ui_view_3760
msgid ""
"<strong>Can we play with fewer players than the recommended minimum?</strong>\n"
"                          <br/>"
msgstr ""
"<strong>ພວກເຮົາສາມາດຫຼິ້ນໄດ້ບໍ່ ຖ້າມີຄົນໜ້ອຍກວ່າຈຳນວນຂັ້ນຕ່ຳທີ່ແນະນຳ?</strong>\n"
"                          <br/>"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.ir_ui_view_3760
msgid ""
"<strong>Do I need any special knowledge or skills to play?</strong>\n"
"                          <br/>"
msgstr ""
"<strong>ຂ້ອຍຈຳເປັນຕ້ອງມີຄວາມຮູ້ ຫຼື ທັກສະພິເສດເພື່ອຫຼິ້ນບໍ່?</strong>\n"
"                          <br/>"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid "<strong>Gift Cards 🎁 </strong>"
msgstr "<strong>ບັດຂອງຂວັນ 🎁 </strong>"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.ir_ui_view_3760
msgid ""
"<strong>How long does an escape room last?</strong>\n"
"                          <br/>"
msgstr ""
"<strong>ການຫຼິ້ນໃນຫ້ອງປິດສະໜາໃຊ້ເວລາດົນປານໃດ?</strong>\n"
"                          <br/>"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid "<strong>How to use it</strong>"
msgstr "<strong>ວິທີການນຳໃຊ້</strong>"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid ""
"<strong>Planning</strong>: Build your weekly staff schedule based on room "
"bookings and predicted attendance."
msgstr ""
"<strong>ການວາງແຜນ</strong>: ສ້າງຕາຕະລາງພະນັກງານປະຈຳອາທິດໂດຍອີງຕາມການຈອງຫ້ອງ ແລະ ກາ"
"ນຄາດຄະເນການເຂົ້າຫຼິ້ນ."

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid ""
"<strong>Point of Sale 🛒:</strong> Sell walk-ins, snacks, drinks, souvenirs "
"with barcode speed."
msgstr ""
"<strong>ຈຸດຂາຍ (POS) 🛒:</strong> ຂາຍໃຫ້ລູກຄ້າທີ່ຍ່າງເຂົ້າມາ, ຂາຍເຂົ້າໜົມ, ເຄື່ອງດື່ມ, ຂອງທີ່ລະ"
"ນຶກ ດ້ວຍຄວາມໄວຂອງລະບົບບາໂຄດ."

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid ""
"<strong>Project</strong>: Manage the development of your next room — from "
"concept to construction to launch."
msgstr ""
"<strong>ໂຄງການ</strong>: ຄຸ້ມຄອງການສ້າງຫ້ອງໃໝ່ — ຕັ້ງແຕ່ການວາງແນວຄິດ, ການກໍ່ສ້າງ ຈົນຮອດມື້ເປີ"
"ດຕົວ."

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid ""
"<strong>Sign</strong>: Send and receive digital contracts for team events, "
"partnerships, or corporate clients."
msgstr ""
"<strong>ເຊັນເອກະສານ</strong>: ສົ່ງ ແລະ ຮັບສັນຍາດິຈິຕອນສຳລັບກິດຈະກຳກຸ່ມ, ຄູ່ຮ່ວມງານ ຫຼື ລູກຄ້າບໍລິ"
"ສັດ."

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid "<strong>Tips for Success</strong>"
msgstr "<strong>ເຄັດລັບສູ່ຄວາມສຳເລັດ</strong>"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid ""
"<strong>Website 🌐:</strong> Show rooms, stories, prices; capture "
"reservations in real time, sell gift cards"
msgstr ""
"<strong>ເວັບໄຊ 🌐:</strong> ສະແດງຫ້ອງ, ເລື່ອງລາວ, ລາຄາ; ຮັບການຈອງແບບທັນທີ, ຂາຍບັດຂອງຂ"
"ວັນ"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.ir_ui_view_3760
msgid ""
"<strong>What happens if we don’t escape in time?</strong>\n"
"                          <br/>"
msgstr ""
"<strong>ຈະເກີດຫຍັງຂຶ້ນ ຖ້າພວກເຮົາອອກມາບໍ່ທັນເວລາ?</strong>\n"
"                          <br/>"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.homepage
msgid "<strong>You’re Not Playing a Game. You’re Living a Story.</strong>"
msgstr ""
"<strong>ທ່ານບໍ່ໄດ້ພຽງແຕ່ຫຼິ້ນເກມ, ແຕ່ທ່ານກຳລັງຢູ່ໃນເລື່ອງລາວແທ້ໆ.</strong>"

#. module: escape_rooms
#: model_terms:product.template,description:escape_rooms.product_product_27_product_template
msgid "A tasty chocolate bar to enjoy after your escape."
msgstr "ຊັອກໂກແລັດແທ່ງແຊບໆ ເພື່ອເພີດເພີນຫຼັງຈາກອອກຈາກຫ້ອງປິດສະໜາ."

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.ir_ui_view_3247
msgid "About us"
msgstr "ກ່ຽວກັບພວກເຮົາ"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.ir_ui_view_3760
msgid ""
"Absolutely! We welcome players of all ages, though some rooms have minimum "
"age suggestions due to complexity or themes. <em>Curse of the Pharaoh</em> "
"is a great pick for families and younger players. Just check the age limit "
"listed for each room."
msgstr ""
"ແນ່ນອນ! ພວກເຮົາຕ້ອນຮັບຜູ້ຫຼິ້ນທຸກເພດທຸກໄວ, ແຕ່ວ່າບາງຫ້ອງອາດມີການແນະນຳອາຍຸຂັ້ນຕ່ຳເນື່ອງຈາກຄວາມຍາກ "
"ຫຼື ເນື້ອຫາຂອງເລື່ອງ. <em>ຄຳສາບຂອງຟາໂຣ</em> ເປັນທາງເລືອກທີ່ດີສຳລັບຄອບຄົວ ແລະ ຜູ້ຫຼິ້ນໄວເດັກ. ທ່ານ"
"ສາມາດກວດເບິ່ງຂໍ້ກຳນົດອາຍຸໄດ້ໃນໜ້າຂອງແຕ່ລະຫ້ອງ."

