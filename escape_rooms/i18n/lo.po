msgstr "ຕິດຕໍ່ຫາພວກເຮົາ"

#. module: escape_rooms
#: model_terms:appointment.type,message_intro:escape_rooms.appointment_type_4
msgid "Red Wire Protocol"
msgstr "ພາລະກິດຕັດສາຍໄຟແດງ (Red Wire Protocol)"

#. module: escape_rooms
#: model_terms:ir.ui.view,arch_db:escape_rooms.welcome_article_body
msgid ""
"Regularly review your <strong>CRM pipeline</strong> to identify group deals "
"or repeat visitors."
msgstr ""
"ກວດສອບ <strong>ຂະບວນການຂາຍ (Pipeline) ໃນ CRM</strong> ເປັນປະຈຳເພື່ອຫາໂອກາດການຂາຍ"
