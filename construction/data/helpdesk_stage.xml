<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="helpdesk.stage_cancelled" model="helpdesk.stage">
        <field name="sequence">4</field>
        <field name="name">Canceled</field>
        <field name="team_ids" eval="[(6, 0, [ref('helpdesk.helpdesk_team1')])]"/>
    </record>
    <record id="helpdesk.stage_in_progress" model="helpdesk.stage">
        <field name="sequence">1</field>
        <field name="name">In Progress</field>
        <field name="team_ids" eval="[(6, 0, [ref('helpdesk.helpdesk_team1')])]"/>
    </record>
    <record id="helpdesk.stage_new" model="helpdesk.stage">
        <field name="sequence" eval="False"/>
        <field name="template_id" ref="helpdesk.new_ticket_request_email_template"/>
        <field name="name">New</field>
        <field name="team_ids" eval="[(6, 0, [ref('helpdesk.helpdesk_team1')])]"/>
    </record>
    <record id="helpdesk.stage_on_hold" model="helpdesk.stage">
        <field name="sequence">2</field>
        <field name="name">On Hold</field>
        <field name="team_ids" eval="[(6, 0, [ref('helpdesk.helpdesk_team1')])]"/>
    </record>
    <record id="helpdesk.stage_solved" model="helpdesk.stage">
        <field name="sequence">3</field>
        <field name="fold" eval="True"/>
        <field name="name">Solved</field>
        <field name="team_ids" eval="[(6, 0, [ref('helpdesk.helpdesk_team1')])]"/>
    </record>
</odoo>
