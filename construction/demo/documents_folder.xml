<?xml version='1.0' encoding='UTF-8'?>
<odoo noupdate="1">
    <!-- 
        fetch the 'Before / During / After Photos &amp; Records'
        documents folder defined in the project template in the project root 
        folder of the created project of S00002
        Everything was created by confirming the SO so the only way of
        getting the correct folder is by using the names 
    -->
    <function model="ir.model.data" name="_update_xmlids">
        <value model="documents.document" eval="[{'xml_id': 'construction.documents_folder_13', 'record': 
            obj().search([
                ('folder_id', '=', obj().search([
                        ('name', '=', obj().env['project.project'].browse(ref('construction.project_project_7')).name)
                    ], limit=1).id
                ),
                ('name', '=', obj().browse(ref('documents_document_31')).name)
            ], limit=1)
        }]"/>
    </function>

    <function model="ir.model.data" name="_update_xmlids">
        <value model="documents.document" eval="[{'xml_id': 'construction.documents_folder_6', 'record': 
            obj().search([
                ('folder_id', '=', obj().search([
                        ('name', '=', obj().env['project.project'].browse(ref('construction.project_project_7')).name)
                    ], limit=1).id
                ),
                ('name', '=', obj().browse(ref('documents_document_28')).name)
            ], limit=1)
        }]"/>
    </function>
</odoo>
