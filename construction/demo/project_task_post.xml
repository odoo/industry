    <!-- S00004: Project Management -->
    <!-- 
        This task also creates the project, so all its tasks are also assigned
        to the same SOL. Therefore, to get it, must filter by excluding the tags,
        since it's the only task of this SOL that doesn't have one because it's
        created from a product template.
    -->
    <!-- TO REWIRE TO PROJECT 4 -->
    <function model="ir.model.data" name="_update_xmlids">
        <value model="project.task" eval="[{
            'xml_id': 'construction.project_task_30', 
            'record': obj().search([('sale_line_id', '=', ref('construction.sale_order_line_129')), 
                                    ('project_id', '=', ref('construction.project_project_7')),
                                    ('tag_ids', 'not in', [ref('project_tags_1'), ref('project_tags_2'), ref('project_tags_3'), ref('project_tags_4'), ref('project_tags_5')])])}]"/>
    </function>
    <record id="project_task_30" model="project.task">
        <field name="stage_id" ref="planning_project_stage_2" />
        <field name="state">03_approved</field>
