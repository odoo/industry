#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Access Control:</strong> Limit sensitive files to relevant team "
"members."
msgstr "<strong>ການຄວບຄຸມການເຂົ້າເຖິງ:</strong> ຈຳກັດໄຟລ໌ທີ່ສຳຄັນໃຫ້ສະເພາະທີມງານທີ່ກ່ຽວຂ້ອງ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Accounting</strong> – Advanced financial management and reporting."
msgstr "<strong>ການບັນຊີ</strong> – ການຄຸ້ມຄອງການເງິນ ແລະ ການລາຍງານແບບລະອຽດ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Alerts &amp; Notifications:</strong> Ensure deadlines are met."
msgstr "<strong>ການແຈ້ງເຕືອນ:</strong> ເພື່ອໃຫ້ແນ່ໃຈວ່າວຽກສຳເລັດຕາມກຳນົດເວລາ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Assignments:</strong> Allocate engineers, site managers, and "
"subcontractors."
msgstr "<strong>ການມອບໝາຍ:</strong> ຈັດສັນວິສະວະກອນ, ຜູ້ຈັດການໜ້າວຽກ, ແລະ ຜູ້ຮັບເໝົາຊ່ວຍ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Billing:</strong> Invoice based on work completion or project\n"
"                    milestones."
msgstr ""
"<strong>ການເກັບເງິນ:</strong> ອອກໃບເກັບເງິນຕາມຜົນສຳເລັດຂອງວຽກ ຫຼື ຂັ້ນຕອນຂອງໂຄງການ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Calendar Views:</strong> Visualize overlapping tasks and adjust\n"
"                    workloads."
msgstr "<strong>ມຸມມອງປະຕິທິນ:</strong> ເບິ່ງພາບລວມຂອງວຽກທີ່ຊ້ອນກັນ ແລະ ປັບປ່ຽນປະລິມານວຽກ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Chatter &amp; Communication:</strong> Collaborate internally using "
"notes\n"
"                    and messages linked to opportunities."
msgstr ""
"<strong>ການສົນທະນາ &amp; ການສື່ສານ:</strong> ຮ່ວມມືກັນພາຍໃນໂດຍການໃຊ້ບັນທຶກ \n"
"                    ແລະ ຂໍ້ຄວາມທີ່ເຊື່ອມໂຍງກັບໂອກາດການຂາຍ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Client Portal:</strong> Allow customers to track the status of "
"their\n"
"                    requests."
msgstr "<strong>ພໍທໍລູກຄ້າ:</strong> ອະນຸຍາດໃຫ້ລູກຄ້າຕິດຕາມສະຖານະຂອງການຮ້ອງຂໍຂອງພວກເຂົາ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Construction Builder</strong>"
msgstr "<strong>Construction Builder (ລະບົບສ້າງການກໍ່ສ້າງ)</strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Construction Developer</strong>"
msgstr "<strong>Construction Developer (ລະບົບພັດທະນາການກໍ່ສ້າງ)</strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Cost Analysis:</strong> Link labour to project expenses."
msgstr "<strong>ການວິເຄາະຕົ້ນທຶນ:</strong> ເຊື່ອມໂຍງຄ່າແຮງງານກັບຄ່າໃຊ້ຈ່າຍຂອງໂຄງການ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Daily Logs:</strong> Employees enter hours per task."
msgstr "<strong>ບັນທຶກປະຈຳວັນ:</strong> ພະນັກງານປ້ອນຊົ່ວໂມງເຮັດວຽກຕາມແຕ່ລະໜ້າວຽກ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Document Requests:</strong> Send requests with follow up activities."
msgstr "<strong>ການຮ້ອງຂໍເອກະສານ:</strong> ສົ່ງຄຳຮ້ອງຂໍພ້ອມກັບກິດຈະກຳຕິດຕາມຜົນ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Employees</strong> – Manage workforce, skills, and certifications."
msgstr "<strong>ພະນັກງານ</strong> – ຄຸ້ມຄອງກຳລັງຄົນ, ທັກສະ, ແລະ ໃບຢັ້ງຢືນຕ່າງໆ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Fleet</strong> – Track machinery, vehicles, and maintenance "
"schedules."
msgstr ""
"<strong>ຍານພາຫະນະ</strong> – ຕິດຕາມເຄື່ອງຈັກ, ລົດຂົນສົ່ງ, ແລະ ຕາຕະລາງການບຳລຸງຮັກສາ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Helpdesk App</strong> provides responsive customer service, tracks "
"inquiries,\n"
"            and resolves issues efficiently."
msgstr ""
"<strong>ແອັບຊ່ວຍເຫຼືອ (Helpdesk)</strong> ໃຫ້ການບໍລິການລູກຄ້າທີ່ວ່ອງໄວ, ຕິດຕາມການສອບຖາມ, "
"ແລະ ແກ້ໄຂບັນຫາຢ່າງມີປະສິດທິພາບ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>How to use it:</strong>"
msgstr "<strong>ວິທີການນຳໃຊ້:</strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>In such situation, feel free to experiment with this database and "
"then\n"
"                        to create a new one for your own usage.</strong>"
msgstr ""
"<strong>ໃນກໍລະນີນີ້, ທ່ານສາມາດທົດລອງໃຊ້ຖານຂໍ້ມູນນີ້ໄດ້ຕາມສະບາຍ ແລະ ຫຼັງຈາກນັ້ນ "
"ຈຶ່ງສ້າງຖານຂໍ້ມູນໃໝ່ເພື່ອການນຳໃຊ້ຕົວຈິງຂອງທ່ານເອງ.</strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Inventory App</strong> manages materials, tracks deliveries, and "
"monitors site\n"
"            stock to prevent delays or shortages."
msgstr ""
"<strong>ແອັບສາງສິນຄ້າ</strong> ຄຸ້ມຄອງວັດສະດຸ, ຕິດຕາມການຈັດສົ່ງ, ແລະ ກວດກາສະຕັອກຢູ່ໜ້າວຽກ "
"ເພື່ອປ້ອງກັນການຊັກຊ້າ ຫຼື ການຂາດແຄນວັດສະດຸ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Invoice from Quotation:</strong> Convert approved quotes into "
"invoices."
msgstr ""
"<strong>ອອກໃບເກັບເງິນຈາກໃບສະເໜີລາຄາ:</strong> "
"ປ່ຽນໃບສະເໜີລາຄາທີ່ອະນຸມັດແລ້ວໃຫ້ເປັນໃບເກັບເງິນ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Invoicing App</strong> ensures timely billing, automates recurring "
"invoices, and\n"
"            integrates with project milestones."
msgstr ""
"<strong>ແອັບການອອກໃບເກັບເງິນ</strong> ຮັບປະກັນການເກັບເງິນທີ່ກົງເວລາ, "
"ສ້າງໃບເກັບເງິນແບບອັດຕະໂນມັດ, ແລະ ເຊື່ອມໂຍງກັບຂັ້ນຕອນສຳເລັດຂອງໂຄງການ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Keep documentation organized:</strong>\n"
"                            Centralize contracts, drawings, and permits for "
"easy access."
msgstr ""
"<strong>ຈັດລະບຽບເອກະສານ:</strong> ລວບລວມສັນຍາ, ແບບແຕ້ມ, ແລະ "
"ໃບອະນຸຍາດໄວ້ບ່ອນດຽວເພື່ອໃຫ້ເຂົ້າເຖິງໄດ້ງ່າຍ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Leads &amp; Opportunities:</strong> Record incoming inquiries from\n"
"                    emails, forms, or calls."
msgstr ""
"<strong>ຜູ້ສົນໃຈ &amp; ໂອກາດ:</strong> ບັນທຶກການສອບຖາມທີ່ເຂົ້າມາຈາກ \n"
"                    ອີເມລ, ແບບຟອມ, ຫຼື ໂທລະສັບ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Milestones:</strong> Define major project achievements."
msgstr "<strong>ຂັ້ນຕອນສຳເລັດ (Milestones):</strong> ກຳນົດຜົນສຳເລັດທີ່ສຳຄັນຂອງໂຄງການ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Mobile Execution:</strong> Record time, materials used, and capture "
"photos\n"
"                or client signatures on site."
msgstr ""
"<strong>ການເຮັດວຽກຜ່ານມືຖື:</strong> ບັນທຶກເວລາ, ວັດສະດຸທີ່ໃຊ້, ຖ່າຍຮູບ ຫຼື "
"ເກັບລາຍເຊັນລູກຄ້າຢູ່ໜ້າວຽກ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Monitor stock proactively:</strong> Avoid\n"
"                            project delays by tracking inventory in real-"
"time."
msgstr ""
"<strong>ກວດກາສະຕັອກຢ່າງຕໍ່ເນື່ອງ:</strong> "
"ຫຼີກລ່ຽງການຊັກຊ້າຂອງໂຄງການໂດຍການຕິດຕາມສິນຄ້າຄົງຄັງແບບທັນການ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Online Approval:</strong> Enable online customer approval."
msgstr "<strong>ການອະນຸມັດອອນລາຍ:</strong> ເປີດໃຫ້ລູກຄ້າອະນຸມັດຜ່ານລະບົບອອນລາຍ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>PDF Output:</strong> Send branded quotations for client approval."
msgstr "<strong>ໄຟລ໌ PDF:</strong> ສົ່ງໃບສະເໜີລາຄາທີ່ມີຍີ່ຫໍ້ຂອງທ່ານໃຫ້ລູກຄ້າອະນຸມັດ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Payment Tracking:</strong> Monitor outstanding client payments."
msgstr "<strong>ການຕິດຕາມການຊຳລະເງິນ:</strong> ຕິດຕາມຍອດຄ້າງຊຳລະຂອງລູກຄ້າ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Pipeline Management:</strong> Visualize lead stages and prioritize\n"
"                    follow-ups."
msgstr ""
"<strong>ການຄຸ້ມຄອງຂະບວນການຂາຍ:</strong> ເບິ່ງພາບລວມຂັ້ນຕອນຂອງຜູ້ສົນໃຈ ແລະ "
"ຈັດລຳດັບຄວາມສຳຄັນໃນການຕິດຕາມຜົນ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Pricing &amp; Discounts:</strong> Adjust based on project size or "
"client\n"
"                    agreements."
msgstr ""
"<strong>ລາຄາ &amp; ສ່ວນຫຼຸດ:</strong> ປັບປ່ຽນຕາມຂະໜາດຂອງໂຄງການ \n"
"                    ຫຼື ຂໍ້ຕົກລົງກັບລູກຄ້າ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Prioritization:</strong> Assign critical tickets to senior staff."
msgstr ""
"<strong>ການຈັດລຳດັບຄວາມສຳຄັນ:</strong> ມອບໝາຍວຽກທີ່ດ່ວນ ຫຼື ສຳຄັນໃຫ້ພະນັກງານອາວຸໂສ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Product Prices:</strong> Capture prices by suppliers to make the\n"
"                    best moves."
msgstr "<strong>ລາຄາສິນຄ້າ:</strong> ບັນທຶກລາຄາຈາກຜູ້ສະໜອງເພື່ອການຕັດສິນໃຈທີ່ດີທີ່ສຸດ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Progress Reporting:</strong> Compare actual time vs planned."
msgstr "<strong>ການລາຍງານຄວາມຄືບໜ້າ:</strong> ປຽບທຽບເວລາທີ່ໃຊ້ຈິງກັບເວລາທີ່ວາງແຜນໄວ້."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Project Files:</strong> Attach blueprints, permits, and contracts."
msgstr "<strong>ໄຟລ໌ໂຄງການ:</strong> ແນບແບບແຕ້ມ, ໃບອະນຸຍາດ, ແລະ ສັນຍາຕ່າງໆ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Project Updates</strong>: Capture project snapshots along the way "
"from the dashboard."
msgstr ""
"<strong>ການອັບເດດໂຄງການ</strong>: ບັນທຶກພາບລວມຄວາມຄືບໜ້າຂອງໂຄງການໄດ້ທັນທີຈາກແດຊບອດ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Purchase App </strong>helps you managing requests for proposal, your "
"suppliers\n"
"            and contractors."
msgstr ""
"<strong>ແອັບການຈັດຊື້</strong> ຊ່ວຍທ່ານໃນການຄຸ້ມຄອງການຮ້ອງຂໍລາຄາ, ຜູ້ສະໜອງ ແລະ "
"ຜູ້ຮັບເໝົາຂອງທ່ານ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Purchase Orders:</strong> Create purchase order for needed products\n"
"                    and services."
msgstr "<strong>ໃບສັ່ງຊື້:</strong> ສ້າງໃບສັ່ງຊື້ສຳລັບສິນຄ້າ ແລະ ການບໍລິການທີ່ຈຳເປັນ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Quotation Templates:</strong> Predefine templates for recurrent\n"
"                    offers."
msgstr ""
"<strong>ແບບຟອມໃບສະເໜີລາຄາ:</strong> ກຳນົດແບບຟອມໄວ້ລ່ວງໜ້າສຳລັບການສະເໜີລາຄາທີ່ໃຊ້ເລື້ອຍໆ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Reordering:</strong> Automate purchase orders for low-stock items."
msgstr "<strong>ການສັ່ງຊື້ຄືນ:</strong> ສ້າງໃບສັ່ງຊື້ອັດຕະໂນມັດສຳລັບສິນຄ້າທີ່ໃກ້ຈະໝົດສາງ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Reporting &amp; Invoicing:</strong> Generate detailed intervention "
"reports\n"
"                and invoice billable work when applicable."
msgstr ""
"<strong>ການລາຍງານ &amp; ການອອກໃບເກັບເງິນ:</strong> "
"ສ້າງລາຍງານການປະຕິບັດງານແບບລະອຽດ \n"
"                ແລະ ອອກໃບເກັບເງິນຕາມວຽກທີ່ເຮັດ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Resource Allocation:</strong> Assign workers, subcontractors, and\n"
"                    machinery."
msgstr "<strong>ການຈັດສັນຊັບພະຍາກອນ:</strong> ມອບໝາຍຄົນງານ, ຜູ້ຮັບເໝົາຊ່ວຍ, ແລະ ເຄື່ອງຈັກ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Roles:</strong> Assign roles to workers and leverage the auto-"
"assign\n"
"                    capability."
msgstr ""
"<strong>ບົດບາດ:</strong> ກຳນົດບົດບາດໃຫ້ຄົນງານ ແລະ ນຳໃຊ້ລະບົບມອບໝາຍວຽກອັດຕະໂນມັດ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Scheduling:</strong> Assign technicians to visits and optimize "
"their\n"
"                calendars."
msgstr ""
"<strong>ການວາງແຜນ:</strong> ມອບໝາຍຊ່າງເຕັກນິກໃຫ້ລົງໜ້າວຽກ ແລະ ຈັດຕາຕະລາງໃຫ້ເໝາະສົມ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Service Requests:</strong> Create tasks for maintenance, warranty\n"
"                interventions, or client modifications."
msgstr ""
"<strong>ການຮ້ອງຂໍບໍລິການ:</strong> ສ້າງວຽກສຳລັບການບຳລຸງຮັກສາ, ການຮັບປະກັນ ຫຼື "
"ການແກ້ໄຂຕາມຄວາມຕ້ອງການຂອງລູກຄ້າ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Sign</strong> – Collect digital signatures for contracts and "
"approvals."
msgstr ""
"<strong>ເຊັນເອກະສານ</strong> – ເກັບກຳລາຍເຊັນດິຈິຕອນສຳລັບສັນຍາ ແລະ ການອະນຸມັດຕ່າງໆ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Site Transfers:</strong> Allocate materials to specific "
"construction\n"
"                    sites."
msgstr ""
"<strong>ການໂອນຍ້າຍລະຫວ່າງໜ້າວຽກ:</strong> ຈັດສັນວັດສະດຸໃຫ້ແຕ່ລະສະຖານທີ່ກໍ່ສ້າງສະເພາະ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Standardize templates:</strong> Use\n"
"                            quotation and project templates to save time and "
"maintain consistency."
msgstr ""
"<strong>ສ້າງມາດຕະຖານແບບຟອມ:</strong> ໃຊ້ແບບຟອມໃບສະເໜີລາຄາ ແລະ "
"ແບບຟອມໂຄງການເພື່ອປະຢັດເວລາ ແລະ ຮັກສາຄວາມເປັນເອກະພາບ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Stock Monitoring:</strong> Check available materials and reserve "
"them for\n"
"                    projects."
msgstr "<strong>ການກວດກາສະຕັອກ:</strong> ກວດສອບວັດສະດຸທີ່ມີ ແລະ ຈອງໄວ້ສຳລັບໂຄງການ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Task Creation:</strong> Break down construction phases into "
"actionable items."
msgstr ""
"<strong>ການສ້າງວຽກ:</strong> ແບ່ງຂັ້ນຕອນການກໍ່ສ້າງອອກເປັນລາຍການວຽກທີ່ສາມາດປະຕິບັດໄດ້."

#. module: construction
#: model_terms:sale.order.template,note:construction.sale_order_template_1
msgid "<strong>Terms</strong>"
msgstr "<strong>ເງື່ອນໄຂ</strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Ticket Management:</strong> Record issues or change requests."
msgstr "<strong>ການຈັດການບັນຫາ:</strong> ບັນທຶກບັນຫາ ຫຼື ຄຳຮ້ອງຂໍການປ່ຽນແປງ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Timesheets App</strong> help track labour hours and project "
