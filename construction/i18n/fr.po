#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Access Control:</strong> Limit sensitive files to relevant team "
"members."
msgstr ""
"<strong>Contrôle d'accès :</strong> limitez les fichiers sensibles aux "
"membres pertinents de l'équipe."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Accounting</strong> – Advanced financial management and reporting."
msgstr "<strong>Comptabilité</strong> – gestion financière avancée et rapports."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Alerts &amp; Notifications:</strong> Ensure deadlines are met."
msgstr ""
"<strong>Alertes &amp; Notifications :</strong> assurez-vous que les "
"échéances sont respectées."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Alternativelly, from the Sales App, you can capture such work \"on "
"the fly\":</strong>"
msgstr ""
"<strong>Depuis l'app Ventes, vous pouvez également enregistrer ce type de "
"travail \"à la volée\" :</strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Assignments:</strong> Allocate engineers, site managers, and "
"subcontractors."
msgstr ""
"<strong>Affectations :</strong> affectez des ingénieurs, chefs de chantier "
"et sous-traitants."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Billing:</strong> Invoice based on work completion or project\n"
"                    milestones."
msgstr ""
"<strong>Facturation :</strong> facturez en fonction de l'achèvement du "
"travail ou des\n"
"                jalons du projet."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Calendar Views:</strong> Visualize overlapping tasks and adjust\n"
"                    workloads."
msgstr ""
"<strong>Vues du calendrier :</strong> visualisez les tâches qui se "
"chevauchent et ajustez\n"
"                les charges de travail."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Chatter &amp; Communication:</strong> Collaborate internally using "
"notes\n"
"                    and messages linked to opportunities."
msgstr ""
"<strong>Chatter &amp; Communication :</strong> collaborez en interne à "
"l'aide de notes\n"
"                et de messages liés aux opportunités."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Client Portal:</strong> Allow customers to track the status of "
"their\n"
"                    requests."
msgstr ""
"<strong>Portail client :</strong> permettez aux clients de suivre le statut "
"de leurs\n"
"                demandes."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Construction Builder</strong>"
msgstr "<strong>Constructeur</strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Construction Developer</strong>"
msgstr "<strong>Développeur immobilier</strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Cost Analysis:</strong> Link labour to project expenses."
msgstr ""
"<strong>Analyse des coûts :</strong> liez la main-d'œuvre aux dépenses du "
"projet."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Daily Logs:</strong> Employees enter hours per task."
msgstr ""
"<strong>Rapports quotidiens :</strong> les employés saisissent les heures "
"par tâche."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Document Requests:</strong> Send requests with follow up activities."
msgstr ""
"<strong>Demandes de documents :</strong> envoyez des demandes avec des "
"activités de suivi."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Employees</strong> – Manage workforce, skills, and certifications."
msgstr ""
"<strong>Employés</strong> – gérez les effectifs, les compétences et les "
"certifications."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Fleet</strong> – Track machinery, vehicles, and maintenance "
"schedules."
msgstr ""
"<strong>Parc Automobile</strong> – suivez les engins, les véhicules et les "
"calendriers de maintenance."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Helpdesk App</strong> provides responsive customer service, tracks "
"inquiries,\n"
"            and resolves issues efficiently."
msgstr ""
"L'app <strong>Assistance</strong> fournit un service client réactif, suit "
"les demandes\n"
"        et résout efficacement les problèmes."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>How to use it:</strong>"
msgstr "<strong>Comment l'utiliser :</strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>In such situation, feel free to experiment with this database and "
"then\n"
"                        to create a new one for your own usage.</strong>"
msgstr ""
"<strong>Dans cette situation, n'hésitez pas à expérimenter avec cette base "
"de données, puis\n"
"                    à en créer une nouvelle pour votre propre usage.</strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Inventory App</strong> manages materials, tracks deliveries, and "
"monitors site\n"
"            stock to prevent delays or shortages."
msgstr ""
"L'app <strong>Inventaire</strong> gère les matériaux, suit les livraisons et "
"surveille le stock sur site\n"
"        afin d'éviter les retards ou les ruptures."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Invoice from Quotation:</strong> Convert approved quotes into "
"invoices."
msgstr ""
"<strong>Facture à partir du devis :</strong> convertissez les devis "
"approuvés en factures."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Invoicing App</strong> ensures timely billing, automates recurring "
"invoices, and\n"
"            integrates with project milestones."
msgstr ""
"L'app <strong>Facturation</strong> garantit une facturation en temps voulu, "
"automatise les factures récurrentes et\n"
"        s'intègre aux jalons du projet."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Keep documentation organized:</strong>\n"
"                            Centralize contracts, drawings, and permits for "
"easy access."
msgstr ""
"<strong>Gardez la documentation organisée :</strong>\n"
"                        centralisez les contrats, dessins et permis pour un "
"accès facile."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Leads &amp; Opportunities:</strong> Record incoming inquiries from\n"
"                    emails, forms, or calls."
msgstr ""
"<strong>Pistes &amp; Opportunités :</strong> enregistrez les demandes "
"entrantes provenant\n"
"                d'e-mails, de formulaires ou d'appels."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Milestones:</strong> Define major project achievements."
msgstr ""
"<strong>Jalons :</strong> définissez les principales réalisations du projet."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Monitor stock proactively:</strong> Avoid\n"
"                            project delays by tracking inventory in real-"
"time."
msgstr ""
"<strong>Surveillez le stock de manière proactive :</strong> évitez\n"
"                        les retards de projet en suivant l'inventaire en "
"temps réel."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Online Approval:</strong> Enable online customer approval."
msgstr ""
"<strong>Approbation en ligne :</strong> permettez l'approbation en ligne par "
"le client."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>PDF Output:</strong> Send branded quotations for client approval."
msgstr ""
"<strong>Sortie PDF :</strong> envoyer des devis personnalisés aux couleurs "
"de votre marque pour approbation du client."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Payment Tracking:</strong> Monitor outstanding client payments."
msgstr ""
"<strong>Suivi des paiements :</strong> surveillez les paiements clients en "
"attente."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Pipeline Management:</strong> Visualize lead stages and prioritize\n"
"                    follow-ups."
msgstr ""
"<strong>Gestion du pipeline :</strong> visualisez les étapes des pistes et "
"priorisez\n"
"                les suivis."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Pricing &amp; Discounts:</strong> Adjust based on project size or "
"client\n"
"                    agreements."
msgstr ""
"<strong>Prix &amp; Remises :</strong> ajustez-les en fonction de la taille "
"du projet ou des accords avec le client."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Prioritization:</strong> Assign critical tickets to senior staff."
msgstr ""
"<strong>Priorisation :</strong> attribuer les tickets critiques au personnel "
"expérimenté."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Product Prices:</strong> Capture prices by suppliers to make the\n"
"                    best moves."
msgstr ""
"<strong>Prix des produits :</strong> enregistrez les prix par fournisseur "
"afin de prendre les\n"
"                meilleures décisions."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Progress Reporting:</strong> Compare actual time vs planned."
msgstr ""
"<strong>Rapport d'avancement :</strong> comparez le temps réel au temps "
"planifié."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Project Files:</strong> Attach blueprints, permits, and contracts."
msgstr ""
"<strong>Fichiers du projet :</strong> joignez les plans, permis et contrats."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Project Updates</strong>: Capture project snapshots along the way "
"from the dashboard."
msgstr ""
"<strong>Mises à jour du projet</strong> : enregistrez des instantanés du "
"projet depuis le tableau de bord tout au long de son avancement."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Purchase App </strong>helps you managing requests for proposal, your "
"suppliers\n"
"            and contractors."
msgstr ""
"L'app <strong>Achats </strong>vous aide à gérer les demandes de prix, vos "
"fournisseurs\n"
"        et vos entrepreneurs."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Purchase Orders:</strong> Create purchase order for needed products\n"
"                    and services."
msgstr ""
"<strong>Bons de commande :</strong> créez un bon de commande pour les "
"produits\n"
"                et services nécessaires."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Quotation Templates:</strong> Predefine templates for recurrent\n"
"                    offers."
msgstr ""
"<strong>Modèles de devis :</strong> prédéfinissez des modèles pour les "
"devis\n"
"                récurrents."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Reordering:</strong> Automate purchase orders for low-stock items."
msgstr ""
"<strong>Réapprovisionnement :</strong> automatisez les bons de commande pour "
"les articles à faible stock."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Resource Allocation:</strong> Assign workers, subcontractors, and\n"
"                    machinery."
msgstr ""
"<strong>Allocation des ressources :</strong> affectez des travailleurs, des "
"sous-traitants et\n"
"                des engins."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Roles:</strong> Assign roles to workers and leverage the auto-"
"assign\n"
"                    capability."
msgstr ""
"<strong>Rôles :</strong> attribuez des rôles aux travailleurs et exploitez "
"la fonctionnalité d'attribution\n"
"                automatique."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Sign</strong> – Collect digital signatures for contracts and "
"approvals."
msgstr ""
"<strong>Signature</strong> – obtenez des signatures numériques pour les "
"contrats et les approbations."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Site Transfers:</strong> Allocate materials to specific "
"construction\n"
"                    sites."
msgstr ""
"<strong>Transferts vers le chantier :</strong> affectez des matériaux à des "
"chantiers spécifiques."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Standardize templates:</strong> Use\n"
"                            quotation and project templates to save time and "
"maintain consistency."
msgstr ""
"<strong>Standardisez les modèles :</strong> utilisez\n"
"                        des modèles de devis et de projet pour gagner du "
"temps et maintenir la cohérence."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
