"                                ovat kunnossa seuraamalla niiden kuntoa <strong>\n"
"                                        <font class=\"text-o-color-1\">Huolto</font>-\n"
"                                </strong>\n"
"                                sovelluksessa."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
