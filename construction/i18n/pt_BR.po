#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Access Control:</strong> Limit sensitive files to relevant team "
"members."
msgstr ""
"<strong>Controle de acesso:</strong> Limite o acesso a arquivos "
"confidenciais aos membros relevantes da equipe."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Accounting</strong> – Advanced financial management and reporting."
msgstr "<strong>Financeiro</strong> – Gestão financeira avançada e relatórios."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Alerts &amp; Notifications:</strong> Ensure deadlines are met."
msgstr ""
"<strong>Alertas &amp; Notificações:</strong> Certifique-se de que os prazos "
"sejam cumpridos."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Assignments:</strong> Allocate engineers, site managers, and "
"subcontractors."
msgstr ""
"<strong>Atribuições:</strong> Alocar engenheiros, gerentes de obra e "
"subcontratados."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Billing:</strong> Invoice based on work completion or project\n"
"                    milestones."
msgstr ""
"<strong>Faturamento:</strong> Fatura baseada na conclusão do trabalho ou nos "
"marcos do Projeto."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Calendar Views:</strong> Visualize overlapping tasks and adjust\n"
"                    workloads."
msgstr ""
"<strong>Visualização do calendário:</strong> Visualize tarefas sobrepostas e "
"ajuste\n"
"                    as cargas de trabalho."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Chatter &amp; Communication:</strong> Collaborate internally using "
"notes\n"
"                    and messages linked to opportunities."
msgstr ""
"<strong>Chatter e Comunicação:</strong> Colabore internamente usando notas\n"
"e mensagens vinculadas a oportunidades."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Client Portal:</strong> Allow customers to track the status of "
"their\n"
"                    requests."
msgstr ""
"<strong>Portal do cliente:</strong> Permita que os clientes acompanhem o "
"status de suas\n"
"solicitações."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Construction Builder</strong>"
msgstr "<strong>Construtor Civil</strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Construction Developer</strong>"
msgstr "<strong>Empreiteiro de construção</strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Cost Analysis:</strong> Link labour to project expenses."
msgstr ""

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Daily Logs:</strong> Employees enter hours per task."
msgstr ""
"<strong>Registros diários:</strong> Os funcionários inserem as horas por "
"tarefa."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Document Requests:</strong> Send requests with follow up activities."
msgstr ""
"<strong>Solicitações de documentos:</strong> Envie solicitações com "
"atividades de acompanhamento."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Employees</strong> – Manage workforce, skills, and certifications."
msgstr ""
"<strong>Funcionários</strong> – Gerencie a força de trabalho, as habilidades "
"e as certificações."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Fleet</strong> – Track machinery, vehicles, and maintenance "
"schedules."
msgstr ""
"<strong>Frotas</strong> – Acompanhe máquinas, veículos e cronogramas de "
"manutenção."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Helpdesk App</strong> provides responsive customer service, tracks "
"inquiries,\n"
"            and resolves issues efficiently."
msgstr ""
"<strong>O app Central de Ajuda</strong> oferece atendimento ágil ao cliente, "
"rastreia consultas e\n"
"resolve problemas com eficiência."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>How to use it:</strong>"
msgstr "<strong>Como usar:</strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>In such situation, feel free to experiment with this database and "
"then\n"
"                        to create a new one for your own usage.</strong>"
msgstr ""
"<strong>Nesse caso, fique à vontade para fazer testes com essa base de dados "
"e, em seguida,\n"
"para criar uma nova para uso.</strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Inventory App</strong> manages materials, tracks deliveries, and "
"monitors site\n"
"            stock to prevent delays or shortages."
msgstr ""
"<strong>O app Inventário</strong> gerencia materiais, rastreia entregas e "
"monitora o estoque do local\n"
"para evitar atrasos ou faltas."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Invoice from Quotation:</strong> Convert approved quotes into "
"invoices."
msgstr ""
"<strong>Fatura da Cotação:</strong> Converta cotações aprovadas em faturas."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Invoicing App</strong> ensures timely billing, automates recurring "
"invoices, and\n"
"            integrates with project milestones."
msgstr ""
"<strong>App Faturamento</strong> garante o faturamento pontual, automatiza "
"faturas recorrentes e é integrado com os marcos do projeto."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Keep documentation organized:</strong>\n"
"                            Centralize contracts, drawings, and permits for "
"easy access."
msgstr ""
"<strong>Mantenha a documentação organizada:</strong>\n"
"Centralize contratos, desenhos e licenças para facilitar o acesso."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Leads &amp; Opportunities:</strong> Record incoming inquiries from\n"
"                    emails, forms, or calls."
msgstr ""
"<strong>Oportunidades de leads &amp;:</strong> Registre as consultas "
"recebidas por\n"
"                    e-mail, formulários ou chamadas."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Milestones:</strong> Define major project achievements."
msgstr "<strong>Marcos:</strong> Defina as principais realizações do projeto."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Mobile Execution:</strong> Record time, materials used, and capture "
"photos\n"
"                or client signatures on site."
msgstr ""
"<strong>Execução móvel:</strong> Registre o tempo, os materiais utilizados e "
"capture fotos\n"
"ou assinaturas de clientes no local."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Monitor stock proactively:</strong> Avoid\n"
"                            project delays by tracking inventory in real-"
"time."
msgstr ""
"<strong>Monitore o estoque de forma proativa:</strong> Evite atrasos no "
"projeto acompanhando o estoque em tempo real."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Online Approval:</strong> Enable online customer approval."
msgstr ""
"<strong>Aprovação online:</strong> Habilite a aprovação online do cliente."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>PDF Output:</strong> Send branded quotations for client approval."
msgstr ""
"<strong>Saída em PDF:</strong> Envie cotações com a marca da empresa para "
"aprovação do cliente."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Payment Tracking:</strong> Monitor outstanding client payments."
msgstr ""
"<strong>Acompanhamento de pagamentos:</strong> Monitore os pagamentos "
"pendentes dos clientes."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Pipeline Management:</strong> Visualize lead stages and prioritize\n"
"                    follow-ups."
msgstr ""
"<strong>Gerenciamento de funil:</strong> Visualize os estágios dos leads e "
"priorize\n"
"                    os acompanhamentos."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Pricing &amp; Discounts:</strong> Adjust based on project size or "
"client\n"
"                    agreements."
msgstr ""
"<strong>Preços &amp; Descontos:</strong> Ajustar com base no tamanho do "
"projeto ou nos acordos com o cliente."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Prioritization:</strong> Assign critical tickets to senior staff."
msgstr ""
"<strong>Priorização:</strong> Atribua chamados críticos a funcionários "
"seniores."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Product Prices:</strong> Capture prices by suppliers to make the\n"
"                    best moves."
msgstr ""
"<strong>Preços dos produtos:</strong> Capture os preços dos fornecedores "
"para tomar as melhores decisões."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Progress Reporting:</strong> Compare actual time vs planned."
msgstr ""
"<strong>Relatório de progresso:</strong> Compare o tempo real com o "
"planejado."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Project Files:</strong> Attach blueprints, permits, and contracts."
msgstr ""
"<strong>Arquivos do projeto:</strong> Anexe plantas, licenças e contratos."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Project Updates</strong>: Capture project snapshots along the way "
"from the dashboard."
msgstr ""
"<strong>Atualizações do projeto</strong>: Capture instantâneos do projeto ao "
"longo do caminho a partir do Painel."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Purchase App </strong>helps you managing requests for proposal, your "
"suppliers\n"
"            and contractors."
msgstr ""
"<strong>O app Compras</strong>ajuda você a gerenciar solicitações de "
"propostas, seus fornecedores\n"
"            e prestadores de serviços."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Purchase Orders:</strong> Create purchase order for needed products\n"
"                    and services."
msgstr ""
"<strong>Pedidos de compra:</strong> Crie um pedido de compra para os "
"produtos\n"
"e serviços necessários."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Quotation Templates:</strong> Predefine templates for recurrent\n"
"                    offers."
msgstr ""
"<strong>Modelos de cotação:</strong> Predefina modelos para ofertas "
"recorrentes."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Reordering:</strong> Automate purchase orders for low-stock items."
msgstr ""
"<strong>Reposição:</strong> Automatize os pedidos de compra para itens com "
"estoque baixo."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Reporting &amp; Invoicing:</strong> Generate detailed intervention "
"reports\n"
"                and invoice billable work when applicable."
msgstr ""
"<strong>Relatórios &amp; Faturamento:</strong> Gere relatórios detalhados de "
"intervenção\n"
"e fature trabalhos cobráveis quando aplicável."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Resource Allocation:</strong> Assign workers, subcontractors, and\n"
"                    machinery."
msgstr ""
"<strong>Alocação de recursos:</strong> Designe trabalhadores, subcontratados "
"e\n"
"                    maquinário."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Roles:</strong> Assign roles to workers and leverage the auto-"
"assign\n"
"                    capability."
msgstr ""
"<strong>Funções:</strong> Atribua funções aos trabalhadores e aproveite o "
"recurso de atribuição automática."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Scheduling:</strong> Assign technicians to visits and optimize "
"their\n"
"                calendars."
msgstr ""
"<strong>Agendamento:</strong> Designe técnicos para visitas e otimize suas "
"agendas."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Service Requests:</strong> Create tasks for maintenance, warranty\n"
"                interventions, or client modifications."
msgstr ""
"<strong>Solicitações de Serviço:</strong> Crie tarefas para manutenção, "
"intervenções de garantia\n"
"ou modificações do cliente."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Sign</strong> – Collect digital signatures for contracts and "
"approvals."
msgstr ""
"<strong>Assinar</strong> – Colete assinaturas digitais para contratos e "
"aprovações."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Site Transfers:</strong> Allocate materials to specific "
"construction\n"
"                    sites."
msgstr ""
"<strong>Transferências de locais:</strong> Alocar materiais para locais de "
"construção específicos.\n"
