#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<b>Documents App</b>: Centralize blueprints, contracts, and permits, "
"ensuring that the latest versions are\n"
"                    always available to the team."
msgstr ""
"<b>Aplicativo Documentos</b>: centralize plantas, contratos e licenças, "
"garantindo que as versões mais recentes estejam\n"
"sempre disponíveis para a equipe."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<b>Field Service App</b>: Schedule and dispatch specialized crews for "
"specific interventions, tracking their\n"
"                    location and job status in real-time."
msgstr ""
"<b>Aplicativo Serviços de Campo</b>: Programe e envie equipes especializadas "
"para intervenções específicas, rastreando sua\n"
"localização e status do trabalho em tempo real."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<b>Fleet App</b>: Manage your heavy machinery and vehicle fleet, tracking "
"maintenance schedules, fuel costs,\n"
"                    and driver assignments."
msgstr ""
"<b>App Frota</b>: Gerencie sua frota de veículos e máquinas pesadas, "
"acompanhando cronogramas de manutenção, custos de combustível e atribuições "
"dos motoristas."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<b>Inventory App</b>: Keep track of tools, equipment, and consumables across "
"multiple sites or warehouses,\n"
"                    reducing loss and theft."
msgstr ""
"<b>Aplicativo Inventário</b>: acompanhe ferramentas, equipamentos e "
"consumíveis em vários locais ou armazéns,\n"
"reduzindo perdas e roubos."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<b>Invoicing App</b>: Handle complex billing scenarios like milestone "
"invoicing, down payments, and\n"
"                    retention based on project progress."
msgstr ""
"<b>Aplicativo Faturamento</b>: lide com cenários complexos de faturamento, "
"como faturamento por etapas, adiantamentos e retenção com base no andamento "
"do projeto."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<b>Project App</b>: Manage construction sites as projects, organizing tasks "
"into stages like \"Foundation,\"\n"
"                    \"Framing,\" and \"Finishing\" with clear deadlines."
msgstr ""
"<b>Aplicativo Projeto</b>: Gerencie canteiros de obras como projetos, "
"organizando tarefas em etapas como “Fundação”,\n"
"“Estrutura” e “Acabamento” com prazos claros."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<b>Purchase App</b>: Automate the procurement of building materials, "
"managing RFQs and purchase orders to\n"
"                    ensure timely delivery to the site."
msgstr ""
"<b>Aplicativo Compras</b>: Automatize a aquisição de materiais de "
"construção, gerenciando solicitações de cotação e pedidos de compra para\n"
"garantir a entrega pontual no local."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<b>Timesheets App</b>: Track labour hours accurately with a mobile app that "
"allows workers to log time\n"
"                    against specific tasks or cost codes on-site."
msgstr ""

