#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Access Control:</strong> Limit sensitive files to relevant team "
"members."
msgstr ""
"<strong>Control de acceso:</strong> Limita los archivos confidenciales a los "
"miembros relevantes del equipo."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Accounting</strong> – Advanced financial management and reporting."
msgstr "<strong>Contabilidad</strong>: Gestión financiera avanzada y reportes."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Alerts &amp; Notifications:</strong> Ensure deadlines are met."
msgstr ""
"<strong>Alertas y notificaciones:</strong> Asegúrate de que se cumplan las "
"fechas límite."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Assignments:</strong> Allocate engineers, site managers, and "
"subcontractors."
msgstr ""
"<strong>Asignaciones:</strong> Asigna ingenieros, responsables de obra y "
"subcontratistas."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Billing:</strong> Invoice based on work completion or project\n"
"                    milestones."
msgstr ""
"<strong>Facturación:</strong> Emite facturas basadas en el avance del "
"trabajo o los objetivos del\n"
"                    proyecto."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Calendar Views:</strong> Visualize overlapping tasks and adjust\n"
"                    workloads."
msgstr ""
"<strong>Vistas de calendario:</strong> Visualiza las tareas superpuestas y "
"ajusta las\n"
"                    cargas de trabajo."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Chatter &amp; Communication:</strong> Collaborate internally using "
"notes\n"
"                    and messages linked to opportunities."
msgstr ""
"<strong>Chatter y comunicación:</strong> Colabora de forma interna mediante "
"notas \n"
"                    y mensajes vinculados a las oportunidades."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Client Portal:</strong> Allow customers to track the status of "
"their\n"
"                    requests."
msgstr ""
"<strong>Portal del cliente:</strong> Permite que los clientes lleven "
"seguimiento del estado de sus\n"
"                    solicitudes."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Construction Builder</strong>"
msgstr "<strong>Constructor</strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Construction Developer</strong>"
msgstr "<strong>Promotor inmobiliario</strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
#, fuzzy
#| msgid "<strong>Cost Analysis:</strong> Link labor to project expenses."
msgid "<strong>Cost Analysis:</strong> Link labour to project expenses."
msgstr ""
"<strong>Análisis de costos:</strong> Vincula la mano de obra con los gastos "
"del proyecto."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Daily Logs:</strong> Employees enter hours per task."
msgstr ""
"<strong>Registros diarios:</strong> Los empleados registran las horas por "
"tarea."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Document Requests:</strong> Send requests with follow up activities."
msgstr ""
"<strong>Solicitudes de documentos:</strong> Envía solicitudes con "
"actividades de seguimiento."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Employees</strong> – Manage workforce, skills, and certifications."
msgstr ""
"<strong>Empleados</strong>: Gestiona a tu personal, sus habilidades y sus "
"certificaciones."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Fleet</strong> – Track machinery, vehicles, and maintenance "
"schedules."
msgstr ""
"<strong>Flotilla</strong>: Lleva seguimiento de tus máquinas, vehículos y "
"planes de mantenimiento."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Helpdesk App</strong> provides responsive customer service, tracks "
"inquiries,\n"
"            and resolves issues efficiently."
msgstr ""
"<strong>La aplicación Soporte al cliente</strong> te ayuda a ofrecer "
"excelente atención al cliente, registrar consultas\n"
"            y resolver incidencias de forma eficiente."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>How to use it:</strong>"
msgstr "<strong>Uso:</strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>In such situation, feel free to experiment with this database and "
"then\n"
"                        to create a new one for your own usage.</strong>"
msgstr ""
"<strong>En este caso, prueba con esta base de datos y después \n"
"                        crea una para utilizarla.</strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Inventory App</strong> manages materials, tracks deliveries, and "
"monitors site\n"
"            stock to prevent delays or shortages."
msgstr ""
"<strong>La aplicación Inventario</strong> gestiona materiales, lleva "
"seguimiento de las entregas y controla\n"
"            las existencias en la obra para evitar que retrasos o falten "
"piezas."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Invoice from Quotation:</strong> Convert approved quotes into "
"invoices."
msgstr ""
"<strong>Facturar desde las cotizaciones:</strong> Convierte las cotizaciones "
"aprobadas en facturas."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Invoicing App</strong> ensures timely billing, automates recurring "
"invoices, and\n"
"            integrates with project milestones."
msgstr ""
"<strong>La aplicación Facturación</strong> garantiza que factures a tiempo, "
"automatiza las facturas recurrentes e\n"
"            integra los objetivos del proyecto."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Keep documentation organized:</strong>\n"
"                            Centralize contracts, drawings, and permits for "
"easy access."
msgstr ""
"<strong>Mantén la documentación organizada:</strong>\n"
"                            Centraliza tus contratos, planos y permisos para "
"acceder a ellos con facilidad."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Leads &amp; Opportunities:</strong> Record incoming inquiries from\n"
"                    emails, forms, or calls."
msgstr ""
"<strong>Leads y oportunidades:</strong> Registra las consultas entrantes "
"desde \n"
"                    correos, formularios o llamadas."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Milestones:</strong> Define major project achievements."
msgstr ""
"<strong>Objetivos:</strong> Define los principales logros del proyecto."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Mobile Execution:</strong> Record time, materials used, and capture "
"photos\n"
"                or client signatures on site."
msgstr ""
"<strong>Ejecución móvil:</strong> Registra el tiempo y los materiales "
"usados. Toma fotografías\n"
"                y obtén las firmas del cliente de forma presencial."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Monitor stock proactively:</strong> Avoid\n"
"                            project delays by tracking inventory in real-"
"time."
msgstr ""
"<strong>Supervisa el inventario de forma proactiva:</strong> Evita\n"
"                            retrasos en el proyecto al darle seguimiento al "
"inventario en tiempo real."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Online Approval:</strong> Enable online customer approval."
msgstr ""
"<strong>Aprobación en línea:</strong> Habilita la aprobación del cliente en "
"línea."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>PDF Output:</strong> Send branded quotations for client approval."
msgstr ""
"<strong>Resultados en PDF:</strong> Envía cotizaciones con tu marca para que "
"el cliente las apruebe."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Payment Tracking:</strong> Monitor outstanding client payments."
msgstr ""
"<strong>Seguimiento de pagos:</strong> Monitorea los pagos pendientes de tus "
"clientes."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Pipeline Management:</strong> Visualize lead stages and prioritize\n"
"                    follow-ups."
msgstr ""
"<strong>Gestión del flujo:</strong> Visualiza las etapas de tus leads y "
"prioriza \n"
"                    su seguimiento."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Pricing &amp; Discounts:</strong> Adjust based on project size or "
"client\n"
"                    agreements."
msgstr ""
"<strong>Precios y descuentos:</strong> Ajústalos según el tamaño del "
"proyecto o los contratos\n"
"                    con el cliente."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Prioritization:</strong> Assign critical tickets to senior staff."
msgstr ""
"<strong>Priorización:</strong> Asigna los tickets más importantes al "
"personal con más experiencia."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Product Prices:</strong> Capture prices by suppliers to make the\n"
"                    best moves."
msgstr ""
"<strong>Precio de los productos:</strong> Registra los precios por proveedor "
"para tomar\n"
"                    mejores decisiones."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Progress Reporting:</strong> Compare actual time vs planned."
msgstr ""
"<strong>Reportes de progreso:</strong> Compara el tiempo real con el tiempo "
"planificado."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Project Files:</strong> Attach blueprints, permits, and contracts."
msgstr ""
"<strong>Archivos del proyecto:</strong> Adjunta planos, permisos y contratos."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Project Updates</strong>: Capture project snapshots along the way "
"from the dashboard."
msgstr ""
"<strong>Actualizaciones del proyecto</strong>: Registra los avances del "
"proyecto desde el tablero a lo largo del proceso."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Purchase App </strong>helps you managing requests for proposal, your "
"suppliers\n"
"            and contractors."
msgstr ""
"<strong>La aplicación Compras</strong> te ayuda a gestionar las solicitudes "
"de cotización, a tus proveedores\n"
"            y a tus contratistas."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Purchase Orders:</strong> Create purchase order for needed products\n"
"                    and services."
msgstr ""
"<strong>Órdenes de compra:</strong> Crea órdenes de compra para los "
"productos\n"
"                    y servicios necesarios."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Quotation Templates:</strong> Predefine templates for recurrent\n"
"                    offers."
msgstr ""
"<strong>Plantillas de cotización:</strong> Define plantillas para las "
"ofertas \n"
"                    recurrentes."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Reordering:</strong> Automate purchase orders for low-stock items."
msgstr ""
"<strong>Reordenamiento:</strong> Automatiza las órdenes de compra para los "
"artículos con pocas existencias."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Reporting &amp; Invoicing:</strong> Generate detailed intervention "
"reports\n"
"                and invoice billable work when applicable."
msgstr ""
"<strong>Reportes y facturación:</strong> Genera reportes detallados de "
"intervenciones \n"
"                y factura los trabajos correspondientes cuando aplique."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Resource Allocation:</strong> Assign workers, subcontractors, and\n"
"                    machinery."
msgstr ""
"<strong>Asignación de recursos:</strong> Asigna trabajadores, "
"subcontratistas y\n"
"                    máquinas."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Roles:</strong> Assign roles to workers and leverage the auto-"
"assign\n"
"                    capability."
msgstr ""
"<strong>Funciones:</strong> Asigna funciones a tu personal y aprovecha la "
"asignación\n"
"                    automática."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Scheduling:</strong> Assign technicians to visits and optimize "
"their\n"
"                calendars."
msgstr ""
"<strong>Programación:</strong> Asigna técnicos a las visitas y optimiza sus\n"
"                calendarios."

#. module: construction
