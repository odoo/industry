#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<b>Documents App</b>: Centralize blueprints, contracts, and permits, "
"ensuring that the latest versions are\n"
"                    always available to the team."
msgstr ""
"<b>Documentos</b>: Centraliza planos, contratos y permisos, y asegúrate de "
"que las versiones más recientes siempre estén\n"
"                disponibles para el equipo."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<b>Field Service App</b>: Schedule and dispatch specialized crews for "
"specific interventions, tracking their\n"
"                    location and job status in real-time."
msgstr ""
"<b>Servicio externo</b>: Programa y asigna equipos especializados para "
"intervenciones específicas, da seguimiento a su\n"
"                ubicación y al estado del trabajo en tiempo real."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<b>Fleet App</b>: Manage your heavy machinery and vehicle fleet, tracking "
"maintenance schedules, fuel costs,\n"
"                    and driver assignments."
msgstr ""
"<b>Flotilla</b>: Gestiona tu maquinaria pesada y tu flotilla de vehículos, "
"da seguimiento a los calendarios de mantenimiento, costos de combustible\n"
"                y asignaciones de conductores."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<b>Inventory App</b>: Keep track of tools, equipment, and consumables across "
"multiple sites or warehouses,\n"
"                    reducing loss and theft."
msgstr ""
"<b>Inventario</b>: Lleva control de tus herramientas, equipos y consumibles "
"en varios sitios o almacenes,\n"
"                reduce las pérdidas y los robos."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<b>Invoicing App</b>: Handle complex billing scenarios like milestone "
"invoicing, down payments, and\n"
"                    retention based on project progress."
msgstr ""
"<b>Facturación</b>: Gestiona situaciones de facturación complejas como "
"facturación por objetivos, anticipos y\n"
"                retenciones basadas en el avance del proyecto."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<b>Project App</b>: Manage construction sites as projects, organizing tasks "
"into stages like \"Foundation,\"\n"
"                    \"Framing,\" and \"Finishing\" with clear deadlines."
msgstr ""
"<b>Proyectos</b>: Gestiona obras de construcción como proyectos y organiza "
"tareas en etapas como \"Cimentación\",\n"
"                \"Estructura\" y \"Acabados\" con fechas límite claras."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<b>Purchase App</b>: Automate the procurement of building materials, "
"managing RFQs and purchase orders to\n"
"                    ensure timely delivery to the site."
msgstr ""
"<b>Compras</b>: Automatiza el aprovisionamiento de materiales de "
"construcción y gestiona solicitudes de cotización y órdenes de compra para\n"
"                asegurar entregas a tiempo en la obra."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<b>Timesheets App</b>: Track labor hours accurately with a mobile app that "
"allows workers to log time\n"
"                    against specific tasks or cost codes on-site."
msgstr ""
"<b>Registro de horas</b>: Registra las horas de trabajo con precisión "
"mediante una aplicación para dispositivos móviles que permite a los "
"trabajadores registrar el tiempo\n"
"                dedicado a las tareas o códigos de costo específicos en el "
"sitio."

