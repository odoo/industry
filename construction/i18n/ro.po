#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Access Control:</strong> Limit sensitive files to relevant team "
"members."
msgstr ""
"<strong>Control Acces:</strong> Limitează fișierele sensibile la membrii "
"echipei relevanți."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Accounting</strong> – Advanced financial management and reporting."
msgstr ""
"<strong>Contabilitate</strong> – Gestionare financiară avansată și raportare."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Alerts &amp; Notifications:</strong> Ensure deadlines are met."
msgstr ""
"<strong>Alerte &amp; Notificări:</strong> Asigură respectarea termenelor "
"limită."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Assignments:</strong> Allocate engineers, site managers, and "
"subcontractors."
msgstr ""

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Billing:</strong> Invoice based on work completion or project\n"
"                    milestones."
msgstr ""
"<strong>Facturare:</strong> Facturează pe baza finalizării lucrărilor sau\n"
"                    etapelor proiectului."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Calendar Views:</strong> Visualize overlapping tasks and adjust\n"
"                    workloads."
msgstr ""
"<strong>Vizualizări Calendar:</strong> Vizualizează sarcinile suprapuse și "
"ajustează\n"
"                    volumul de muncă."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Chatter &amp; Communication:</strong> Collaborate internally using "
"notes\n"
"                    and messages linked to opportunities."
msgstr ""
"<strong>Conversație &amp; Comunicare:</strong> Colaborează intern folosind "
"notițe\n"
"                    și mesaje legate de oportunități."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Client Portal:</strong> Allow customers to track the status of "
"their\n"
"                    requests."
msgstr ""
"<strong>Portal Client:</strong> Permite clienților să urmărească starea\n"
"                    cererilor lor."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Construction Builder</strong>"
msgstr "<strong>Constructor Edificii</strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Construction Developer</strong>"
msgstr "<strong>Dezvoltator Construcții</strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Cost Analysis:</strong> Link labour to project expenses."
msgstr ""

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Daily Logs:</strong> Employees enter hours per task."
msgstr ""
"<strong>Rapoarte Zilnice:</strong> Angajații introduc orele pe sarcină."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Document Requests:</strong> Send requests with follow up activities."
msgstr ""
"<strong>Cereri de Documente:</strong> Trimite cereri cu activități de "
"urmărire."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Employees</strong> – Manage workforce, skills, and certifications."
msgstr ""
"<strong>Angajați</strong> – Gestionează forța de muncă, competențele și "
"certificările."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Fleet</strong> – Track machinery, vehicles, and maintenance "
"schedules."
msgstr ""
"<strong>Flotă</strong> – Urmărește utilajele, vehiculele și programele de "
"întreținere."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Helpdesk App</strong> provides responsive customer service, tracks "
"inquiries,\n"
"            and resolves issues efficiently."
msgstr ""
"<strong>Aplicația Helpdesk</strong> oferă servicii de asistență clienți "
"receptive, urmărește solicitările,\n"
"            și rezolvă problemele eficient."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>How to use it:</strong>"
msgstr "<strong>Cum să îl folosești:</strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>In such situation, feel free to experiment with this database and "
"then\n"
"                        to create a new one for your own usage.</strong>"
msgstr ""
"<strong>În această situație, nu ezitați să experimentați cu această bază de "
"date și apoi\n"
"                        să creați una nouă pentru propriul dumneavoastră uz."
"</strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Inventory App</strong> manages materials, tracks deliveries, and "
"monitors site\n"
"            stock to prevent delays or shortages."
msgstr ""
"<strong>Aplicația Inventar</strong> gestionează materialele, urmărește "
"livrările și monitorizează stocul de pe șantier\n"
"            pentru a preveni întârzierile sau lipsurile."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Invoice from Quotation:</strong> Convert approved quotes into "
"invoices."
msgstr ""
"<strong>Factură din Cotație:</strong> Convertește cotațiile aprobate în "
"facturi."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Invoicing App</strong> ensures timely billing, automates recurring "
"invoices, and\n"
"            integrates with project milestones."
msgstr ""
"<strong>Aplicația Facturare</strong> asigură facturarea la timp, "
"automatizează facturile recurente și\n"
"            se integrează cu etapele proiectului."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Keep documentation organized:</strong>\n"
"                            Centralize contracts, drawings, and permits for "
"easy access."
msgstr ""
"<strong>Păstrează documentația organizată:</strong>\n"
"                            Centralizează contractele, desenele și "
"autorizațiile pentru acces facil."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Leads &amp; Opportunities:</strong> Record incoming inquiries from\n"
"                    emails, forms, or calls."
msgstr ""
"<strong>Potențiali Clienți &amp; Oportunități:</strong> Înregistrează "
"solicitările primite prin\n"
"                    email-uri, formulare sau apeluri."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Milestones:</strong> Define major project achievements."
msgstr "<strong>Etape:</strong> Definește realizările majore ale proiectului."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Mobile Execution:</strong> Record time, materials used, and capture "
"photos\n"
"                or client signatures on site."
msgstr ""
"<strong>Execuție Mobilă:</strong> Înregistrează timpul, materialele folosite "
"și capturează fotografii\n"
"                sau semnăturile clienților pe șantier."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Monitor stock proactively:</strong> Avoid\n"
"                            project delays by tracking inventory in real-"
"time."
msgstr ""
"<strong>Monitorizează stocul proactiv:</strong> Evită\n"
"                            întârzierile proiectului urmărind inventarul în "
"timp real."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Online Approval:</strong> Enable online customer approval."
msgstr ""
"<strong>Aprobare Online:</strong> Permite aprobarea online a clientului."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>PDF Output:</strong> Send branded quotations for client approval."
msgstr ""
"<strong>Ieșire PDF:</strong> Trimite cotații cu brandul pentru aprobarea "
"clientului."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Payment Tracking:</strong> Monitor outstanding client payments."
msgstr ""
"<strong>Urmărire Plăți:</strong> Monitorizează plățile restante ale "
"clienților."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Pipeline Management:</strong> Visualize lead stages and prioritize\n"
"                    follow-ups."
msgstr ""
"<strong>Gestionare Pipeline:</strong> Vizualizează etapele potențialilor "
"clienți și prioritizează\n"
"                    urmărirea."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Pricing &amp; Discounts:</strong> Adjust based on project size or "
"client\n"
"                    agreements."
msgstr ""
"<strong>Prețuri &amp; Reduceri:</strong> Ajustează pe baza dimensiunii "
"proiectului sau acordurilor\n"
"                    cu clientul."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Prioritization:</strong> Assign critical tickets to senior staff."
msgstr ""
"<strong>Prioritizare:</strong> Atribuie tichetele critice personalului "
"senior."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Product Prices:</strong> Capture prices by suppliers to make the\n"
"                    best moves."
msgstr ""
"<strong>Prețuri Produse:</strong> Capturează prețurile de la furnizori "
"pentru a face\n"
"                    cele mai bune mișcări."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Progress Reporting:</strong> Compare actual time vs planned."
msgstr ""
"<strong>Raportare Progres:</strong> Compară timpul real cu cel planificat."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Project Files:</strong> Attach blueprints, permits, and contracts."
msgstr ""
"<strong>Fișiere Proiect:</strong> Atașează planurile, autorizațiile și "
"contractele."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Project Updates</strong>: Capture project snapshots along the way "
"from the dashboard."
msgstr ""

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Purchase App </strong>helps you managing requests for proposal, your "
"suppliers\n"
"            and contractors."
msgstr ""
"<strong>Aplicația Achiziții </strong>te ajută să gestionezi cererile de "
"propunere, furnizorii\n"
"            și contractorii tăi."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Purchase Orders:</strong> Create purchase order for needed products\n"
"                    and services."
msgstr ""
"<strong>Comenzi de Achiziție:</strong> Creează comanda de achiziție pentru "
"produsele\n"
"                    și serviciile necesare."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Quotation Templates:</strong> Predefine templates for recurrent\n"
"                    offers."
msgstr ""
"<strong>Șabloane de Cotație:</strong> Predefinește șabloane pentru ofertele\n"
"                    recurente."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Reordering:</strong> Automate purchase orders for low-stock items."
msgstr ""
"<strong>Recomandare:</strong> Automatizează comenzile de achiziție pentru "
"articolele cu stoc scăzut."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Reporting &amp; Invoicing:</strong> Generate detailed intervention "
"reports\n"
"                and invoice billable work when applicable."
msgstr ""
"<strong>Raportare &amp; Facturare:</strong> Generează rapoarte detaliate de "
"intervenție\n"
"                și facturează lucrul taxabil când este cazul."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Resource Allocation:</strong> Assign workers, subcontractors, and\n"
"                    machinery."
msgstr ""
"<strong>Alocare Resurse:</strong> Atribuie lucrători, subcontractori și\n"
"                    utilaje."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Roles:</strong> Assign roles to workers and leverage the auto-"
"assign\n"
"                    capability."
msgstr ""
"<strong>Roluri:</strong> Atribuie roluri lucrătorilor și folosește "
"capacitatea de\n"
"                    atribuire automată."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Scheduling:</strong> Assign technicians to visits and optimize "
"their\n"
"                calendars."
msgstr ""
"<strong>Programare:</strong> Atribuie tehnicieni pentru vizite și "
"optimizează\n"
"                calendarele lor."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Service Requests:</strong> Create tasks for maintenance, warranty\n"
"                interventions, or client modifications."
msgstr ""
"<strong>Cereri de Service:</strong> Creează sarcini pentru întreținere, "
"intervenții\n"
"                de garanție sau modificări ale clientului."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
