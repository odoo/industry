"Dateien auf relevante Teammitglieder."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Accounting</strong> – Advanced financial management and reporting."
msgstr ""
"<strong>Buchhaltungs-</strong> – Fortgeschrittenes Finanzmanagement und "
"Berichterstattung."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Alerts &amp; Notifications:</strong> Ensure deadlines are met."
msgstr ""
"<strong>Alarme &amp; Benachrichtigungen:</strong> Stellen Sie sicher, dass "
"Fristen eingehalten werden."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Assignments:</strong> Allocate engineers, site managers, and "
"subcontractors."
msgstr ""
"<strong>Zuweisungen:</strong> Weisen Sie Ingenieure, Bauleiter und "
"Subunternehmer zu."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Billing:</strong> Invoice based on work completion or project\n"
"                    milestones."
msgstr ""
"<strong>Rechnungsstellung:</strong> Rechnen Sie auf Basis der "
"abgeschlossenen Arbeiten oder der Projektmeilensteine.\n"
"                    ab."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Calendar Views:</strong> Visualize overlapping tasks and adjust\n"
"                    workloads."
msgstr ""
"<strong>Kalenderansichten:</strong> Visualisieren Sie überlappende Aufgaben "
"und\n"
"                    passen Sie die Arbeitslast an."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Chatter &amp; Communication:</strong> Collaborate internally using "
"notes\n"
"                    and messages linked to opportunities."
msgstr ""
"<strong>Chatter &amp; Kommunikation:</strong> Interne Zusammenarbeit "
"mithilfe von Notizen\n"
"und Nachrichten, die mit Verkaufschancen verknüpft sind."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Client Portal:</strong> Allow customers to track the status of "
"their\n"
"                    requests."
msgstr ""
"<strong>Kundenportal:</strong> Ermöglichen Sie Kunden, den Status ihrer\n"
"Anfragen zu verfolgen."

