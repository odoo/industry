#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Document Requests:</strong> Send requests with follow up activities."
msgstr ""
"<strong>Dokumentenanfragen:</strong> Senden Sie Anfragen mit "
"Folgeaktivitäten."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Employees</strong> – Manage workforce, skills, and certifications."
msgstr ""
"<strong>Mitarbeiter</strong> – Verwalten Sie Personal, Kompetenzen und "
"Zertifizierungen."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Fleet</strong> – Track machinery, vehicles, and maintenance "
"schedules."
msgstr ""
"<strong>Fuhrpark</strong> – Verfolgen Sie Maschinen, Fahrzeuge und "
"Wartungspläne."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Helpdesk App</strong> provides responsive customer service, tracks "
"inquiries,\n"
"            and resolves issues efficiently."
msgstr ""
"<strong>Die Kundendienstapp </strong> bietet reaktionsschnellen "
"Kundenservice, verfolgt Anfragen und\n"
"löst Probleme effizient."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>How to use it:</strong>"
msgstr "<strong>Verwendung:</strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>In such situation, feel free to experiment with this database and "
"then\n"
"                        to create a new one for your own usage.</strong>"
msgstr ""
"<strong>In einem solchen Fall können Sie gerne mit dieser Datenbank "
"experimentieren und\n"
"                        anschließend eine neue Datenbank für Ihren eigenen "
"Gebrauch erstellen.</strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Inventory App</strong> manages materials, tracks deliveries, and "
"monitors site\n"
"            stock to prevent delays or shortages."
msgstr ""
"<strong>Die Lager-App</strong> verwaltet Materialien, verfolgt Lieferungen "
"und überwacht den Lagerbestand vor Ort, um Verzögerungen oder Engpässe zu "
"vermeiden."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Invoice from Quotation:</strong> Convert approved quotes into "
"invoices."
msgstr ""
"<strong>Rechnung aus Angebot:</strong> Wandeln Sie genehmigte Angebote in "
"Rechnungen um."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Invoicing App</strong> ensures timely billing, automates recurring "
"invoices, and\n"
"            integrates with project milestones."
msgstr ""
"<strong>Die Rechnungsstellungsapp </strong> sorgt für eine zeitnahe "
"Rechnungsstellung, automatisiert wiederkehrende Rechnungen und\n"
"            lässt sich in Projektmeilensteine integrieren."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Keep documentation organized:</strong>\n"
"                            Centralize contracts, drawings, and permits for "
"easy access."
msgstr ""
"<strong>Dokumente übersichtlich organisieren:</strong>\n"
"                            Zentralisieren Sie Verträge, Zeichnungen und "
"Genehmigungen, um den Zugriff zu vereinfachen."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Leads &amp; Opportunities:</strong> Record incoming inquiries from\n"
"                    emails, forms, or calls."
msgstr ""
"<strong>Leads &amp; Verkaufschancen:</strong> Erfassen Sie eingehende "
"Anfragen aus\n"
"E-Mails, Formularen oder Anrufen."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Milestones:</strong> Define major project achievements."
msgstr "<strong>Meilensteine:</strong> Definieren Sie wichtige Projekterfolge."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Mobile Execution:</strong> Record time, materials used, and capture "
"photos\n"
"                or client signatures on site."
msgstr ""
"<strong>Mobile Ausführung:</strong> Erfassen Sie Zeitaufwand, verwendete "
"Materialien und Fotos\n"
"oder Kundenunterschriften auf der Baustelle."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Monitor stock proactively:</strong> Avoid\n"
"                            project delays by tracking inventory in real-"
"time."
msgstr ""
"<strong>Lager proaktiv überwachen:</strong> Vermeiden Sie\n"
"                            Projektverzögerungen durch die "
"Echtzeitverfolgung Ihres Lagers."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Online Approval:</strong> Enable online customer approval."
msgstr ""
"<strong>Online-Genehmigung:</strong> Aktivieren Sie die Online-"
"Kundengenehmigung."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>PDF Output:</strong> Send branded quotations for client approval."
msgstr ""
"<strong>PDF-Dateien:</strong> Senden Sie Angebote mit Ihrem Logo zur "
"Genehmigung an den Kunden."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Payment Tracking:</strong> Monitor outstanding client payments."
msgstr ""
"<strong>Zahlungsübersicht:</strong> Überwachen Sie ausstehende "
"Kundenzahlungen."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Pipeline Management:</strong> Visualize lead stages and prioritize\n"
"                    follow-ups."
msgstr ""
"<strong>Pipeline-Verwaltung:</strong> Visualisieren Sie Lead-Phasen und "
"priorisieren Sie\n"
"Folgeaktionen."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Pricing &amp; Discounts:</strong> Adjust based on project size or "
"client\n"
"                    agreements."
msgstr ""
"<strong>Preis &amp; Rabatte:</strong> Passen Sie Preise je nach "
"Projektumfang oder\n"
"Kundenvereinbarungen an."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Prioritization:</strong> Assign critical tickets to senior staff."
msgstr ""
"<strong>Priorisierung:</strong> Weisen Sie kritische Tickets den leitenden "
"Mitarbeitern zu."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Product Prices:</strong> Capture prices by suppliers to make the\n"
"                    best moves."
msgstr ""
"<strong>Produktpreise:</strong> Erfassen Sie die Preise der Lieferanten, um "
"die\n"
"                    besten Entscheidungen zu treffen."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Progress Reporting:</strong> Compare actual time vs planned."
msgstr ""
"<strong>Fortschrittsberichte:</strong> Vergleichen Sie die tatsächliche Zeit "
"mit der geplanten Zeit."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Project Files:</strong> Attach blueprints, permits, and contracts."
msgstr ""
"<strong>Projektdateien:</strong> Fügen Sie Baupläne, Genehmigungen und "
"Verträge bei."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Project Updates</strong>: Capture project snapshots along the way "
"from the dashboard."
msgstr ""
"<strong>Projektaktualisierungen</strong>: Erfassen Sie Projektüberblicke "
"über das Dashboard während des gesamten Prozesses."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Purchase App </strong>helps you managing requests for proposal, your "
"suppliers\n"
"            and contractors."
msgstr ""
"<strong>Mit der Einkaufsapp</strong> können Sie Angebotsanfragen, Ihre "
"Lieferanten\n"
"            und Auftragnehmer verwalten."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Purchase Orders:</strong> Create purchase order for needed products\n"
"                    and services."
msgstr ""
"<strong>Bestellungen:</strong> Erstellen Sie Bestellungen für benötigte "
"Produkte\n"
"und Dienstleistungen."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Quotation Templates:</strong> Predefine templates for recurrent\n"
"                    offers."
msgstr ""
"<strong>Angebotsvorlagen:</strong> Legen Sie vordefinierte Vorlagen für "
"wiederkehrende\n"
"                    Angebote fest."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Reordering:</strong> Automate purchase orders for low-stock items."
msgstr ""
"<strong>Nachbestellung:</strong> Automatisieren Sie Bestellungen für Artikel "
"mit geringem Lagerbestand."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Reporting &amp; Invoicing:</strong> Generate detailed intervention "
"reports\n"
"                and invoice billable work when applicable."
msgstr ""
"<strong>Berichterstattung &amp; Rechnungsstellung:</strong> Erstellen Sie "
"detaillierte Einsatzberichte\n"
"und stellen Sie gegebenenfalls abrechnungsfähige Arbeiten in Rechnung."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Resource Allocation:</strong> Assign workers, subcontractors, and\n"
"                    machinery."
msgstr ""
"<strong>Ressourcenverteilung:</strong> Weisen Sie Arbeiter, Subunternehmer "
"und\n"
"                    Maschinen zu."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Roles:</strong> Assign roles to workers and leverage the auto-"
"assign\n"
"                    capability."
msgstr ""
"<strong>Rollen:</strong> Weisen Sie den Mitarbeitern Rollen zu und nutzen "
"Sie die automatische\n"
"                     Zuweisungsfunktion"

#. module: construction
