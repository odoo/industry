#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Access Control:</strong> Limit sensitive files to relevant team "
"members."
msgstr ""
"<strong>Toegangscontrole:</strong> Beperk gevoelige bestanden tot relevante "
"teamleden."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Accounting</strong> – Advanced financial management and reporting."
msgstr ""
"<strong>Boekhouding</strong> – Geavanceerd financieel beheer en rapportage."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Alerts &amp; Notifications:</strong> Ensure deadlines are met."
msgstr ""
"<strong>Waarschuwingen &amp; Meldingen:</strong> Zorg ervoor dat deadlines "
"worden gehaald."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Assignments:</strong> Allocate engineers, site managers, and "
"subcontractors."
msgstr ""
"<strong>Toewijzingen:</strong> Wijs ingenieurs, werfleiders en "
"onderaannemers toe."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Billing:</strong> Invoice based on work completion or project\n"
"                    milestones."
msgstr ""
"<strong>Facturatie:</strong> Factureer op basis van voltooide werkzaamheden "
"of projectmijlpalen."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Calendar Views:</strong> Visualize overlapping tasks and adjust\n"
"                    workloads."
msgstr ""
"<strong>Agenda-weergaven:</strong> Visualiseer overlappende taken en pas de "
"werkdruk aan."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Chatter &amp; Communication:</strong> Collaborate internally using "
"notes\n"
"                    and messages linked to opportunities."
msgstr ""
"<strong>Chatter &amp; Communicatie:</strong> Werk intern samen met behulp "
"van notities en berichten die aan verkoopkansen zijn gekoppeld."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Client Portal:</strong> Allow customers to track the status of "
"their\n"
"                    requests."
msgstr ""
"<strong>Klantenportaal:</strong> Geef klanten de mogelijkheid om de status "
"van hun verzoeken te volgen."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Construction Builder</strong>"
msgstr "<strong>Kleine aannemer</strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Construction Developer</strong>"
msgstr "<strong>Projectontwikkelaar</strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Cost Analysis:</strong> Link labour to project expenses."
msgstr "<strong>Kostenanalyse:</strong> Koppel werk aan Project-onkosten."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Daily Logs:</strong> Employees enter hours per task."
msgstr ""
"<strong>Dagelijkse registraties</strong> Werknemers voeren de gewerkte uren "
"per taak in."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Document Requests:</strong> Send requests with follow up activities."
msgstr ""
"<strong>Documentaanvragen:</strong> Stuur aanvragen met vervolgactiviteiten."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Employees</strong> – Manage workforce, skills, and certifications."
msgstr ""
"<strong>Werknemers</strong> – Beheer personeel, vaardigheden en "
"certificeringen."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Fleet</strong> – Track machinery, vehicles, and maintenance "
"schedules."
msgstr ""
"<strong>Wagenpark</strong> – Houd machines, voertuigen en onderhoudsschema's "
"bij."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Helpdesk App</strong> provides responsive customer service, tracks "
"inquiries,\n"
"            and resolves issues efficiently."
msgstr ""
"De <strong>Helpdesk-app</strong> zorgt voor een responsieve klantenservice, "
"opvolging van vragen en efficiënt oplossen van problemen."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>How to use it:</strong>"
msgstr "<strong>Gebruik:</strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>In such situation, feel free to experiment with this database and "
"then\n"
"                        to create a new one for your own usage.</strong>"
msgstr ""
"<strong>Experimenteer in zo'n geval met deze database en maak vervolgens een "
"nieuwe voor eigen gebruik.</strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Inventory App</strong> manages materials, tracks deliveries, and "
"monitors site\n"
"            stock to prevent delays or shortages."
msgstr ""
"De <strong>Voorraad-app</strong> beheert materialen, volgt leveringen en "
"controleert de voorraad op locatie om vertragingen of tekorten te voorkomen."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Invoice from Quotation:</strong> Convert approved quotes into "
"invoices."
msgstr ""
"<strong>Factuur op basis van offerte:</strong> Zet goedgekeurde offertes om "
"in facturen."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Invoicing App</strong> ensures timely billing, automates recurring "
"invoices, and\n"
"            integrates with project milestones."
msgstr ""
"De <strong>Facturatie-app</strong> zorgt voor tijdige facturatie, "
"automatiseert terugkerende facturen en kan gecombineerd worden met "
"projectmijlpalen."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Keep documentation organized:</strong>\n"
"                            Centralize contracts, drawings, and permits for "
"easy access."
msgstr ""
"<strong>Houd je documentatie georganiseerd:</strong> Centraliseer "
"contracten, tekeningen en vergunningen voor snelle toegang."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Leads &amp; Opportunities:</strong> Record incoming inquiries from\n"
"                    emails, forms, or calls."
msgstr ""
"<strong>Leads &amp; Verkoopkansen:</strong> Registreer aanvragen die "
"binnenkomen via e-mail, formulieren of telefoon."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Milestones:</strong> Define major project achievements."
msgstr "<strong>Mijlpalen:</strong> Definieer belangrijke projectmijlpalen."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Mobile Execution:</strong> Record time, materials used, and capture "
"photos\n"
"                or client signatures on site."
msgstr ""
"<strong>Mobiel registreren:</strong> Registreer tijd, gebruikte materialen "
"en maak foto'sof verzamel handtekeningen van klanten ter plaatse."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Monitor stock proactively:</strong> Avoid\n"
"                            project delays by tracking inventory in real-"
"time."
msgstr ""
"<strong>Monitor je voorraad proactief:</strong> Voorkom projectvertragingen "
"door je voorraad realtime bij te houden."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Online Approval:</strong> Enable online customer approval."
msgstr "<strong>Online goedkeuring:</strong> Laat klanten online goedkeuren."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>PDF Output:</strong> Send branded quotations for client approval."
msgstr ""
"<strong>Pdf-bestanden:</strong> Stuur offertes met je bedrijfslogo ter "
"goedkeuring naar je klanten."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Payment Tracking:</strong> Monitor outstanding client payments."
msgstr ""
"<strong>Betalingen volgen:</strong> Controleer openstaande betalingen van "
"klanten."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Pipeline Management:</strong> Visualize lead stages and prioritize\n"
"                    follow-ups."
msgstr ""
"<strong>Beheer met pijplijn:</strong> Visualiseer leadfasen en prioriseer "
"follow-ups."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Pricing &amp; Discounts:</strong> Adjust based on project size or "
"client\n"
"                    agreements."
msgstr ""
"<strong>Prijzen &amp; Kortingen:</strong> Pas prijzen aan op basis van "
"projectomvang of afspraken met de klant."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Prioritization:</strong> Assign critical tickets to senior staff."
msgstr ""
"<strong>Prioriteiten:</strong> Wijs belangrijke tickets toe aan senior "
"medewerkers."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Product Prices:</strong> Capture prices by suppliers to make the\n"
"                    best moves."
msgstr ""
"<strong>Productprijzen:</strong> Leg de prijzen van leveranciers vast om "
"weloverwogen beslissingen te nemen."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Progress Reporting:</strong> Compare actual time vs planned."
msgstr ""
"<strong>Voortgangsrapportage:</strong> Vergelijk de werkelijke tijd met de "
"geplande tijd."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Project Files:</strong> Attach blueprints, permits, and contracts."
msgstr ""
"<strong>Projectbestanden:</strong> Voeg bouwtekeningen, vergunningen en "
"contracten toe."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Project Updates</strong>: Capture project snapshots along the way "
"from the dashboard."
msgstr ""
"<strong>Projectupdates</strong>: Leg tussentijdse projectupdates van het "
"project vast via het dashboard."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Purchase App </strong>helps you managing requests for proposal, your "
"suppliers\n"
"            and contractors."
msgstr ""
"De <strong>Inkoop-app </strong>helpt je bij het beheren van "
"offerteaanvragen, leveranciers en aannemers."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Purchase Orders:</strong> Create purchase order for needed products\n"
"                    and services."
msgstr ""
"<strong>Inkooporders:</strong> Maak een inkooporder aan voor benodigde "
"producten en diensten."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Quotation Templates:</strong> Predefine templates for recurrent\n"
"                    offers."
msgstr ""
"<strong>Offerte-sjablonen:</strong> Vooraf gedefinieerde sjablonen voor "
"terugkerende offertes."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Reordering:</strong> Automate purchase orders for low-stock items."
msgstr ""
"<strong>Aanvullen:</strong> Automatiseer inkooporders voor artikelen met een "
"lage voorraad."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Reporting &amp; Invoicing:</strong> Generate detailed intervention "
"reports\n"
"                and invoice billable work when applicable."
msgstr ""
"<strong>Rapportage &amp; Facturatie:</strong> Genereer gedetailleerde "
"interventierapporten en factureer factureerbaar werk indien van toepassing."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Resource Allocation:</strong> Assign workers, subcontractors, and\n"
"                    machinery."
msgstr ""
"<strong>Resources toewijzen:</strong> Wijs werknemers, onderaannemers en "
"machines toe."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Roles:</strong> Assign roles to workers and leverage the auto-"
"assign\n"
"                    capability."
msgstr ""
"<strong>Rollen:</strong> Wijs rollen toe aan werknemers en gebruik de "
"functie voor automatisch toewijzen."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Scheduling:</strong> Assign technicians to visits and optimize "
"their\n"
"                calendars."
msgstr ""
"<strong>Planning:</strong> Wijs technici toe aan bezoeken en optimaliseer "
"hun agenda's."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Service Requests:</strong> Create tasks for maintenance, warranty\n"
"                interventions, or client modifications."
msgstr ""
"<strong>Serviceverzoeken:</strong> Maak taken aan voor onderhoud, garantie-"
"interventies of aanpassingen door klanten."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Sign</strong> – Collect digital signatures for contracts and "
"approvals."
msgstr ""
"<strong>Ondertekenen</strong> – Verzamel digitale handtekeningen voor "
"contracten en goedkeuringen."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Site Transfers:</strong> Allocate materials to specific "
"construction\n"
"                    sites."
