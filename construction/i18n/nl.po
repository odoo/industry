#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<b>Documents App</b>: Centralize blueprints, contracts, and permits, "
"ensuring that the latest versions are\n"
"                    always available to the team."
msgstr ""
"<b>Documenten-app</b>: Centraliseer blauwdrukken, contracten en "
"vergunningen, zodat het team altijd toegang heeft tot de recentste versies."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<b>Field Service App</b>: Schedule and dispatch specialized crews for "
"specific interventions, tracking their\n"
"                    location and job status in real-time."
msgstr ""
"<b>Buitendienst-app</b>: Plan en stuur gespecialiseerde teams voor "
"specifieke interventies, waarbij hun locatie en de status van hun werk "
"realtime worden bijgehouden."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<b>Fleet App</b>: Manage your heavy machinery and vehicle fleet, tracking "
"maintenance schedules, fuel costs,\n"
"                    and driver assignments."
msgstr ""
"<b>Wagenpark-app</b>: Beheer je zware machines en voertuigen, volg "
"onderhoudsschema's, brandstofkosten en de toewijzing van bestuurders."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<b>Inventory App</b>: Keep track of tools, equipment, and consumables across "
"multiple sites or warehouses,\n"
"                    reducing loss and theft."
msgstr ""
"<b>Voorraad-app</b>: Behoud het overzicht over gereedschap, apparatuur en "
"verbruiksartikelen op meerdere bouwplaatsen of in meerdere magazijnen en "
"verminder zo verlies en diefstal."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<b>Invoicing App</b>: Handle complex billing scenarios like milestone "
"invoicing, down payments, and\n"
"                    retention based on project progress."
msgstr ""
"<b>Facturatie-app</b>: Beheer complexe facturatiescenario's zoals facturatie "
"op basis van bereikte mijlpalen, aanbetalingen en retentie op basis van de "
"voortgang van het project."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<b>Project App</b>: Manage construction sites as projects, organizing tasks "
"into stages like \"Foundation,\"\n"
"                    \"Framing,\" and \"Finishing\" with clear deadlines."
msgstr ""
"<b>Project-app</b>: Beheer bouwplaatsen als projecten en organiseer taken in "
"fasen zoals 'Fundering', 'Ruwbouw' en 'Afwerking' met duidelijke deadlines."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<b>Purchase App</b>: Automate the procurement of building materials, "
"managing RFQs and purchase orders to\n"
"                    ensure timely delivery to the site."
msgstr ""
"<b>Inkoop-app</b>: Automatiseer de inkoop van bouwmaterialen en verwerk "
"offerteaanvragen en inkooporders om tijdige levering op de bouwplaats te "
"garanderen."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<b>Timesheets App</b>: Track labour hours accurately with a mobile app that "
"allows workers to log time\n"
"                    against specific tasks or cost codes on-site."
msgstr ""
"<b>Urenstaten-app</b>: Houd werkuren nauwkeurig bij met een mobiele app "
"waarmee werknemers ter plaatse tijd kunnen registreren\n"
"                    voor specifieke taken of kostencodes."

