#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Access Control:</strong> Limit sensitive files to relevant team "
"members."
msgstr ""
"<strong>controllo degli accessi:</strong> limita l'accesso ai file sensibili "
"ai membri del team interessati"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Accounting</strong> – Advanced financial management and reporting."
msgstr ""
"<strong>Contabilità</strong> – gestisci le tue finanze e sfrutta gli "
"strumenti per la reportistica"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Alerts &amp; Notifications:</strong> Ensure deadlines are met."
msgstr ""
"<strong>avvisi e notifiche:</strong> assicurati che le scadenze siano "
"rispettate."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Alternativelly, from the Sales App, you can capture such work \"on "
"the fly\":</strong>"
msgstr ""
"<strong>In alternativa, dall'app Vendite, è possibile acquisire tale lavoro "
"\"al volo\":</strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Assignments:</strong> Allocate engineers, site managers, and "
"subcontractors."
msgstr ""
"<strong>Incarichi:</strong> assegna ingegneri, responsabili di cantiere e "
"subappaltatori."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Billing:</strong> Invoice based on work completion or project\n"
"                    milestones."
msgstr ""
"<strong>fatturazione:</strong> emetti fatture basate sul completamento dei "
"lavori o sulle tappe fondamentali dei progetti"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Calendar Views:</strong> Visualize overlapping tasks and adjust\n"
"                    workloads."
msgstr ""
"<strong>viste calendario:</strong> visualizza i lavori che si accavallano e "
"regola\n"
"                    i carichi di lavoro"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Chatter &amp; Communication:</strong> Collaborate internally using "
"notes\n"
"                    and messages linked to opportunities."
msgstr ""
"<strong>chatter e comunicazioni:</strong> collabora internamente grazie alle "
"note\n"
"                    e ai messaggi collegati alle opportunità."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Client Portal:</strong> Allow customers to track the status of "
"their\n"
"                    requests."
msgstr ""
"<strong>portale clienti:</strong> consenti ai clienti di monitorare lo stato "
"delle loro\n"
"                    richieste."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Construction Builder</strong>"
msgstr "<strong>Impresa di costruzioni</strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Construction Developer</strong>"
msgstr "<strong>Sviluppatore immobiliare</strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Cost Analysis:</strong> Link labour to project expenses."
msgstr ""
"<strong>Analisi dei costi:</strong> collega la manodopera alle spese dei "
"progetti."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Daily Logs:</strong> Employees enter hours per task."
msgstr ""
"<strong>registrazioni giornaliere:</strong> i dipendenti inseriscono le ore "
"per ogni lavoro"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Document Requests:</strong> Send requests with follow up activities."
msgstr ""
"<strong>richieste di documenti:</strong> invia le richieste con attività di "
"follow-up."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Employees</strong> – Manage workforce, skills, and certifications."
msgstr ""
"<strong>Dipendenti</strong> – Gestisci la forza lavoro, le competenze e le "
"certificazioni"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Fleet</strong> – Track machinery, vehicles, and maintenance "
"schedules."
msgstr ""
"<strong>Parco veicoli</strong>: monitora macchinari, veicoli e attività di "
"manutenzione"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Helpdesk App</strong> provides responsive customer service, tracks "
"inquiries,\n"
"            and resolves issues efficiently."
msgstr ""
"<strong>L'app Helpdesk</strong> fornisce un servizio clienti reattivo, tiene "
"traccia delle richieste\n"
"            e risolve i problemi in modo efficiente."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>How to use it:</strong>"
msgstr "<strong>Come utilizzare il modulo:</strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>In such situation, feel free to experiment with this database and "
"then\n"
"                        to create a new one for your own usage.</strong>"
msgstr ""
"<strong>In situazioni del genere, non esitare a testare questo database e\n"
"                        a crearne un altro in seguito per la tua attività.</"
"strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Inventory App</strong> manages materials, tracks deliveries, and "
"monitors site\n"
"            stock to prevent delays or shortages."
msgstr ""
"<strong>L'app Magazzino</strong> permette di gestire i materiali, tracciare "
"le consegne e monitorare le scorte in loco per evitare ritardi o carenze."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Invoice from Quotation:</strong> Convert approved quotes into "
"invoices."
msgstr ""
"<strong>emetti fatture dai preventivi:</strong> converti i preventivi "
"approvati in fatture"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Invoicing App</strong> ensures timely billing, automates recurring "
"invoices, and\n"
"            integrates with project milestones."
msgstr ""
"<strong>L'app Fatturazione</strong> garantisce una fatturazione puntuale, "
"l'automatizzazione delle fatture ricorrenti e\n"
"            si integra con le tappe fondamentali dei progetti."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Keep documentation organized:</strong>\n"
"                            Centralize contracts, drawings, and permits for "
"easy access."
msgstr ""
"<strong>Mantieni la documentazione organizzata:</strong>\n"
"                            centralizza contratti, disegni e permessi per un "
"facile accesso."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Leads &amp; Opportunities:</strong> Record incoming inquiries from\n"
"                    emails, forms, or calls."
msgstr ""
"<strong>Lead e pportunità:</strong> registra le richieste in arrivo da\n"
"                    e-mail, moduli o chiamate."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Milestones:</strong> Define major project achievements."
msgstr ""
"<strong>milestone:</strong> definisci i risultati principali dei progetti"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Monitor stock proactively:</strong> Avoid\n"
"                            project delays by tracking inventory in real-"
"time."
msgstr ""
"<strong>Monitora il magazzino in modo proattivo:</strong> evita\n"
"                            ritardi nei progetti monitorando il magazzino in "
"tempo reale."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Online Approval:</strong> Enable online customer approval."
msgstr ""
"<strong>approvazione online:</strong> abilita l'approvazione online da parte "
"dei clienti"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>PDF Output:</strong> Send branded quotations for client approval."
msgstr ""
"<strong>file in PDF:</strong> invia preventivi da far approvare ai clienti"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Payment Tracking:</strong> Monitor outstanding client payments."
msgstr ""
"<strong>monitoraggio dei pagamenti:</strong> monitoraggio dei pagamenti in "
"sospeso dei clienti."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Pipeline Management:</strong> Visualize lead stages and prioritize\n"
"                    follow-ups."
msgstr ""
"<strong>gestione della pipeline:</strong> visualizza le fasi dei lead e "
"assegna priorità ai\n"
"                    follow-up"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Pricing &amp; Discounts:</strong> Adjust based on project size or "
"client\n"
"                    agreements."
msgstr ""
"<strong>prezzi e sconti:</strong> adeguati in base alle dimensioni del "
"progetto o agli accordi con il cliente"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Prioritization:</strong> Assign critical tickets to senior staff."
msgstr ""
"<strong>Priorità:</strong> assegna i ticket critici al personale più esperto"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Product Prices:</strong> Capture prices by suppliers to make the\n"
"                    best moves."
msgstr ""
"<strong>Prezzi prodotti:</strong> acquisisci i prezzi dei fornitori per fare "
"le\n"
"                    scelte migliori."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Progress Reporting:</strong> Compare actual time vs planned."
msgstr ""
"<strong>reportistica sullo stato di avanzamento:</strong> confronta il tempo "
"effettivo con quello pianificato"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Project Files:</strong> Attach blueprints, permits, and contracts."
msgstr ""
"<strong>file di progetto:</strong> allega progetti, permessi e contratti"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Project Updates</strong>: Capture project snapshots along the way "
"from the dashboard."
msgstr ""
"<strong>Aggiornamenti dei progetti</strong>: acquisisci istantanee dei "
"progetti durante lo svolgimento dalla dashboard."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Purchase App </strong>helps you managing requests for proposal, your "
"suppliers\n"
"            and contractors."
msgstr ""
"<strong>L'app Acquisti</strong>ti aiuta a gestire le richieste di "
"preventivo, i tuoi fornitori\n"
"            e appaltatori."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Purchase Orders:</strong> Create purchase order for needed products\n"
"                    and services."
msgstr ""
"<strong>ordini di acquisto:</strong> crea ordini di acquisto per i prodotti\n"
"                    e servizi necessari"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Quotation Templates:</strong> Predefine templates for recurrent\n"
"                    offers."
msgstr ""
"<strong>modelli di preventivo:</strong> modelli predefiniti per offerte "
"ricorrenti"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Reordering:</strong> Automate purchase orders for low-stock items."
msgstr ""
"<strong>riordino:</strong> automatizza gli ordini di acquisto per gli "
"articoli in esaurimento"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Resource Allocation:</strong> Assign workers, subcontractors, and\n"
"                    machinery."
msgstr ""
"<strong>assegnazione risorse:</strong> assegna lavoratori, subappaltatori e\n"
"                    macchinari"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Roles:</strong> Assign roles to workers and leverage the auto-"
"assign\n"
"                    capability."
msgstr ""
"<strong>ruoli:</strong> assegna i ruoli ai lavoratori e sfrutta la "
"funzionalità di assegnazione automatica"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Sign</strong> – Collect digital signatures for contracts and "
"approvals."
msgstr ""
"<strong>Firma</strong> – Raccogli firme digitali per contratti e "
"approvazioni."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Site Transfers:</strong> Allocate materials to specific "
"construction\n"
"                    sites."
msgstr ""
"<strong>trasferimenti in cantiere:</strong> assegna i materiali a specifici "
"cantieri edili\n"
"                    ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Standardize templates:</strong> Use\n"
"                            quotation and project templates to save time and "
"maintain consistency."
msgstr ""
"<strong>Standardizza i modelli:</strong> utilizza\n"
"                            modelli di preventivo e di progetto per "
"risparmiare tempo ed essere coerente."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Stock Monitoring:</strong> Check available materials and reserve "
"them for\n"
"                    projects."
msgstr ""
"<strong>monitoraggio delle scorte:</strong> controlla i materiali "
"disponibili e prenotali per i\n"
