#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Access Control:</strong> Limit sensitive files to relevant team "
"members."
msgstr ""
"<strong>Erişim Kontrolü:</strong> Hassas dosyalara erişimi ilgili ekip "
"üyeleriyle sınırlayın."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Accounting</strong> – Advanced financial management and reporting."
msgstr "<strong>Muhasebe</strong> – İleri düzey finansal yönetim ve raporlama."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Alerts &amp; Notifications:</strong> Ensure deadlines are met."
msgstr ""
"<strong>Uyarılar &amp; Bildirimler:</strong> Son teslim tarihlerine "
"uyulduğundan emin olun."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Assignments:</strong> Allocate engineers, site managers, and "
"subcontractors."
msgstr ""
"<strong>Görevler:</strong> Mühendisleri, şantiye yöneticilerini ve alt "
"yüklenicileri atayın."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Billing:</strong> Invoice based on work completion or project\n"
"                    milestones."
msgstr ""
"<strong>Faturalama:</strong> İşin tamamlanmasına veya proje\n"
"                    aşamalarına göre faturalandırılır."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Calendar Views:</strong> Visualize overlapping tasks and adjust\n"
"                    workloads."
msgstr ""
"<strong>Takvim Görünümleri:</strong> Çakışan görevleri görselleştirin ve\n"
"                    iş yüklerini ayarlayın."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Chatter &amp; Communication:</strong> Collaborate internally using "
"notes\n"
"                    and messages linked to opportunities."
msgstr ""
"<strong>Sohbet &amp; İletişim:</strong> Fırsatlara bağlı notlar\n"
"                    ve mesajlar aracılığıyla şirket içinde işbirliği yapın."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Client Portal:</strong> Allow customers to track the status of "
"their\n"
"                    requests."
msgstr ""
"<strong>Müşteri Portalı:</strong> Müşterilerin taleplerinin durumunu\n"
"                    takip etmelerine olanak tanıyın."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Construction Builder</strong>"
msgstr "<strong>Yapı Oluşturucu</strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Construction Developer</strong>"
msgstr "<strong>İnşaat Geliştiricisi</strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Cost Analysis:</strong> Link labour to project expenses."
msgstr ""
"<strong>Maliyet Analizi:</strong> İşgücü maliyetlerini proje masraflarıyla "
"ilişkilendirin."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Daily Logs:</strong> Employees enter hours per task."
msgstr ""
"<strong>Günlük Kayıtlar:</strong> Çalışanlar görev başına çalışma saatlerini "
"girer."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Document Requests:</strong> Send requests with follow up activities."
msgstr ""
"<strong>Belge Talepleri:</strong> Taleplerinizi takip faaliyetleriyle "
"birlikte gönderin."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Employees</strong> – Manage workforce, skills, and certifications."
msgstr ""
"<strong></strong> 'daki Çalışanlar – İşgücünü, becerileri ve sertifikaları "
"yönetin."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Fleet</strong> – Track machinery, vehicles, and maintenance "
"schedules."
msgstr ""
"<strong></strong> Filo Yönetimi – Makine, araç ve bakım programlarını takip "
"edin."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Helpdesk App</strong> provides responsive customer service, tracks "
"inquiries,\n"
"            and resolves issues efficiently."
msgstr ""
"<strong></strong> Yardım Masası uygulaması, hızlı müşteri hizmetleri sunar, "
"talepleri takip eder\n"
"            ve sorunları verimli bir şekilde çözer."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>How to use it:</strong>"
msgstr "<strong>Nasıl kullanılır</strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>In such situation, feel free to experiment with this database and "
"then\n"
"                        to create a new one for your own usage.</strong>"
msgstr ""
"<strong>Böyle bir durumda, bu veritabanını denemekten çekinmeyin ve "
"ardından\n"
"                        kendi kullanımınız için yeni bir tane oluşturun.</"
"strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Inventory App</strong> manages materials, tracks deliveries, and "
"monitors site\n"
"            stock to prevent delays or shortages."
msgstr ""
"<strong>Stok Uygulaması</strong>, gecikmeleri veya stok eksikliklerini "
"önlemek için malzemeleri yönetir, teslimatları takip eder ve şantiye\n"
"            stokunu izler."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Invoice from Quotation:</strong> Convert approved quotes into "
"invoices."
msgstr ""
"<strong>Tekliften Fatura Oluşturma:</strong> Onaylanmış teklifleri faturaya "
"dönüştürün."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Invoicing App</strong> ensures timely billing, automates recurring "
"invoices, and\n"
"            integrates with project milestones."
msgstr ""
"<strong>Faturalama Uygulaması</strong>, zamanında faturalandırmayı sağlar, "
"tekrarlayan faturaları otomatikleştirir ve\n"
"            proje aşamalarıyla entegre olur."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Keep documentation organized:</strong>\n"
"                            Centralize contracts, drawings, and permits for "
"easy access."
msgstr ""
"<strong>Belgeleri düzenli tutun:</strong>\n"
"                            Kolay erişim için sözleşmeleri, çizimleri ve "
"izin belgelerini tek bir yerde toplayın."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Leads &amp; Opportunities:</strong> Record incoming inquiries from\n"
"                    emails, forms, or calls."
msgstr ""
"<strong> &amp; Fırsatları: E-postalar, formlar veya aramalardan gelen\n"
"                    sorguları kaydedin.</strong> "

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Milestones:</strong> Define major project achievements."
msgstr ""
"<strong>Kilometre Taşları:</strong> Projenin başlıca başarılarını tanımlayın."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Monitor stock proactively:</strong> Avoid\n"
"                            project delays by tracking inventory in real-"
"time."
msgstr ""
"<strong>Stokları proaktif olarak izleyin:</strong> Stokları\n"
"                            gerçek zamanlı olarak takip ederek proje "
"gecikmelerini önleyin."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Online Approval:</strong> Enable online customer approval."
msgstr ""
"<strong>Çevrimiçi Onay:</strong> Çevrimiçi müşteri onayını etkinleştirin."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>PDF Output:</strong> Send branded quotations for client approval."
msgstr ""
"<strong>PDF Çıktısı:</strong> Müşterinin onayına sunmak üzere markalı "
"teklifler gönderin."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Payment Tracking:</strong> Monitor outstanding client payments."
msgstr ""
"<strong>Ödeme Takibi:</strong> Ödenmemiş müşteri ödemelerini takip edin."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Pipeline Management:</strong> Visualize lead stages and prioritize\n"
"                    follow-ups."
msgstr ""
"<strong>Pipeline Yönetimi:</strong> Potansiyel müşteri aşamalarını "
"görselleştirin ve\n"
"                    takip işlemlerine öncelik verin."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Pricing &amp; Discounts:</strong> Adjust based on project size or "
"client\n"
"                    agreements."
msgstr ""
"<strong>Fiyatlandırma &amp; İndirimler:</strong> Proje büyüklüğüne veya "
"müşteri\n"
"                    anlaşmalarına göre ayarlayın."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Prioritization:</strong> Assign critical tickets to senior staff."
msgstr ""
"<strong>Önceliklendirme:</strong> Kritik biletleri kıdemli personele atayın."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Product Prices:</strong> Capture prices by suppliers to make the\n"
"                    best moves."
msgstr ""
"<strong>Ürün Fiyatları:</strong> Tedarikçilerin fiyatlarını takip ederek\n"
"                    en doğru hamleleri yapın."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Progress Reporting:</strong> Compare actual time vs planned."
msgstr ""
"<strong>İlerleme Raporlaması:</strong> Gerçek süre ile planlanan süreyi "
"karşılaştırın."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Project Files:</strong> Attach blueprints, permits, and contracts."
msgstr ""
"<strong>Proje Dosyaları:</strong> İnşaat planlarını, izin belgelerini ve "
"sözleşmeleri ekleyin."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Project Updates</strong>: Capture project snapshots along the way "
"from the dashboard."
msgstr ""
"<strong>Proje Güncellemeleri</strong>: Gösterge Paneli’nden proje sürecine "
"ait anlık görüntüleri yakalayın."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Purchase App </strong>helps you managing requests for proposal, your "
"suppliers\n"
"            and contractors."
msgstr ""
"<strong>Satınalma Uygulaması </strong>teklif taleplerini, tedarikçilerinizi\n"
"            ve yüklenicilerinizi yönetmenize yardımcı olur."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Purchase Orders:</strong> Create purchase order for needed products\n"
"                    and services."
msgstr ""
"<strong>Satınalma Siparişleri:</strong> İhtiyaç duyulan ürünler\n"
"                    ve hizmetler için satınalma siparişi oluşturun."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Quotation Templates:</strong> Predefine templates for recurrent\n"
"                    offers."
msgstr ""
"<strong>Alıntı Şablonları:</strong> Tekrarlanan\n"
"                    teklifler için önceden tanımlanmış şablonlar."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Reordering:</strong> Automate purchase orders for low-stock items."
msgstr ""
"<strong>Yeniden Sipariş Verme:</strong> Stoku azalan ürünler için satınalma "
"siparişlerini otomatikleştirin."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Resource Allocation:</strong> Assign workers, subcontractors, and\n"
"                    machinery."
msgstr ""
"<strong>Kaynak Tahsisi:</strong> İşçileri, alt yüklenicileri ve\n"
"                    makineleri tahsis edin."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Roles:</strong> Assign roles to workers and leverage the auto-"
"assign\n"
"                    capability."
msgstr ""
"<strong>Roller:</strong> Çalışanlara roller atayın ve otomatik atama\n"
"                    özelliğinden yararlanın."

#. module: construction
