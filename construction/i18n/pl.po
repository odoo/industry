#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "Keep an eye on materials 📦"
msgstr "Miej oko na materiały 📦"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"Know the skills of each employee by filling them in the\n"
"            <strong><font class=\"text-o-color-1\">Employees</font></strong> app. This will help you to find the right person to make a good work."
msgstr ""
"Poznaj umiejętności każdego pracownika, wpisując je w aplikacji\n"
"            <strong><font class=\"text-o-color-1\">Pracownicy</font></"
"strong> . Pomoże Ci to zawsze znaleźć odpowiednią osobę do wykonania zadania."

#. module: construction
#: model:product.template,name:construction.product_product_8_product_template
msgid "Labor hour with equipment"
msgstr "Godziny pracy z użyciem sprzętu"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "Make your customers happy 🆘"
msgstr "Spraw, by Twoi klienci byli zadowoleni 🆘"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"Manage your vehicles in the\n"
"            <strong><font class=\"text-o-color-1\">Fleet</font></strong> app."
msgstr ""
"Zarządzaj swoimi pojazdami w aplikacji\n"
"            <strong><font class=\"text-o-color-1\">Flota</font></strong> ."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "Manufacturing Orders"
msgstr "Zamówienia produkcji"

#. module: construction
#: model:product.template,name:construction.product_product_6_product_template
msgid "Masonry mortar 25kg"
msgstr "Zaprawa murarska 25 kg"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "Material that will be used to build the project."
msgstr "Materiał, który zostanie wykorzystany do zbudowania projektu."

