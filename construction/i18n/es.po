#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Access Control:</strong> Limit sensitive files to relevant team "
"members."
msgstr ""
"<strong>Control de acceso:</strong> limita el acceso a los archivos "
"confidenciales a los miembros del equipo pertinentes."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Accounting</strong> – Advanced financial management and reporting."
msgstr ""
"<strong>Contabilidad</strong>: gestión financiera y elaboración de informes."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Alerts &amp; Notifications:</strong> Ensure deadlines are met."
msgstr ""
"<strong>Alertas y notificaciones:</strong> asegúrate de que se cumplan los "
"plazos."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Assignments:</strong> Allocate engineers, site managers, and "
"subcontractors."
msgstr ""
"<strong>Asignaciones:</strong> asigna ingenieros, responsables de obra y "
"subcontratistas."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Billing:</strong> Invoice based on work completion or project\n"
"                    milestones."
msgstr ""
"<strong>Facturación:</strong> factura en función del avance del trabajo o de "
"los objetivos del\n"
"                    proyecto."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Calendar Views:</strong> Visualize overlapping tasks and adjust\n"
"                    workloads."
msgstr ""
"<strong>Vistas de calendario:</strong> visualiza las tareas que se solapan y "
"ajusta\n"
"                    la carga de trabajo."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Chatter &amp; Communication:</strong> Collaborate internally using "
"notes\n"
"                    and messages linked to opportunities."
msgstr ""
"<strong>Chatter y comunicación:</strong> colabora de forma interna mediante "
"notas \n"
"                    y mensajes vinculados a las oportunidades."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Client Portal:</strong> Allow customers to track the status of "
"their\n"
"                    requests."
msgstr ""
"<strong>Portal del cliente:</strong> permite que los clientes hagan "
"seguimiento del estado de sus\n"
"                    solicitudes."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Construction Builder</strong>"
msgstr "<strong>Constructor</strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Construction Developer</strong>"
msgstr "<strong>Promotor inmobiliario</strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Cost Analysis:</strong> Link labour to project expenses."
msgstr ""
"<strong>Análisis de costes:</strong> vincula la mano de obra a los gastos "
"del proyecto."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Daily Logs:</strong> Employees enter hours per task."
msgstr ""
"<strong>Registros diarios:</strong> los empleados registran las horas por "
"tarea."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Document Requests:</strong> Send requests with follow up activities."
msgstr ""
"<strong>Solicitudes de documentos:</strong> envía solicitudes con "
"actividades de seguimiento."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Employees</strong> – Manage workforce, skills, and certifications."
msgstr ""
"<strong>Empleados:</strong> gestiona la plantilla, las competencias y las "
"certificaciones."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Fleet</strong> – Track machinery, vehicles, and maintenance "
"schedules."
msgstr ""
"<strong>Flota</strong>: realiza un seguimiento de la maquinaria, los "
"vehículos y los calendarios de mantenimiento."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Helpdesk App</strong> provides responsive customer service, tracks "
"inquiries,\n"
"            and resolves issues efficiently."
msgstr ""
"<strong>Aplicación Soporte:</strong> ofrece un servicio de atención al "
"cliente ágil, realiza un seguimiento de las consultas\n"
"            y resuelve las incidencias de forma eficiente."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>How to use it:</strong>"
msgstr "<strong>Cómo utilizarlo:</strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>In such situation, feel free to experiment with this database and "
"then\n"
"                        to create a new one for your own usage.</strong>"
msgstr ""
"<strong>En este caso, prueba con esta base de datos y después\n"
"                        crea una nueva para tu propio uso.</strong>"

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Inventory App</strong> manages materials, tracks deliveries, and "
"monitors site\n"
"            stock to prevent delays or shortages."
msgstr ""
"<strong>La aplicación Inventario</strong> gestiona los materiales, realiza "
"un seguimiento de las entregas y supervisa las\n"
"            existencias en las instalaciones para evitar retrasos o faltas "
"de stock."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Invoice from Quotation:</strong> Convert approved quotes into "
"invoices."
msgstr ""
"<strong>Factura a partir de un presupuesto:</strong> convierte los "
"presupuestos aprobados en facturas."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Invoicing App</strong> ensures timely billing, automates recurring "
"invoices, and\n"
"            integrates with project milestones."
msgstr ""
"<strong>La aplicación Facturación</strong> garantiza una facturación "
"puntual, automatiza las facturas recurrentes y\n"
"            se integra con los hitos del proyecto."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Keep documentation organized:</strong>\n"
"                            Centralize contracts, drawings, and permits for "
"easy access."
msgstr ""
"<strong>Mantén la documentación organizada:</strong>\n"
"                            centraliza los contratos, planos y permisos para "
"acceder a ellos con facilidad."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Leads &amp; Opportunities:</strong> Record incoming inquiries from\n"
"                    emails, forms, or calls."
msgstr ""
"<strong>Leads y oportunidades:</strong> registra las consultas recibidas a "
"través de \n"
"                    correos, formularios o llamadas."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Milestones:</strong> Define major project achievements."
msgstr "<strong>Hitos:</strong> define los principales logros del proyecto."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Monitor stock proactively:</strong> Avoid\n"
"                            project delays by tracking inventory in real-"
"time."
msgstr ""
"<strong>Supervisa el inventario de forma proactiva:</strong> evita\n"
"                            retrasos en los proyectos al hacer seguimiento "
"del inventario en tiempo real."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Online Approval:</strong> Enable online customer approval."
msgstr ""
"<strong>Aprobación en línea:</strong> habilita la aprobación en línea por "
"parte del cliente."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>PDF Output:</strong> Send branded quotations for client approval."
msgstr ""
"<strong>Resultados en PDF:</strong> envía presupuestos con la marca de la "
"empresa para que el cliente los apruebe."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Payment Tracking:</strong> Monitor outstanding client payments."
msgstr ""
"<strong>Seguimiento de pagos:</strong> realiza un seguimiento de los pagos "
"pendientes de los clientes."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Pipeline Management:</strong> Visualize lead stages and prioritize\n"
"                    follow-ups."
msgstr ""
"<strong>Gestión del pipeline:</strong> visualiza las etapas de los leads y "
"prioriza\n"
"                    los seguimientos."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Pricing &amp; Discounts:</strong> Adjust based on project size or "
"client\n"
"                    agreements."
msgstr ""
"<strong>Precios y descuentos:</strong> ajústalos en función del tamaño del "
"proyecto o de los acuerdos\n"
"                    con el cliente."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Prioritization:</strong> Assign critical tickets to senior staff."
msgstr ""
"<strong>Priorización:</strong> asigna los tickets más importantes/urgentes "
"al personal que cuenta con más experiencia."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Product Prices:</strong> Capture prices by suppliers to make the\n"
"                    best moves."
msgstr ""
"<strong>Precios de los productos:</strong> registra los precios por "
"proveedor para tomar\n"
"                    mejores decisiones."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid "<strong>Progress Reporting:</strong> Compare actual time vs planned."
msgstr ""
"<strong>Informes de avance:</strong> compara el tiempo real con el tiempo "
"planificado."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Project Files:</strong> Attach blueprints, permits, and contracts."
msgstr ""
"<strong>Archivos del proyecto:</strong> adjunta planos, permisos y contratos."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Project Updates</strong>: Capture project snapshots along the way "
"from the dashboard."
msgstr ""
"<strong>Actualizaciones del proyecto</strong>: captura instantáneas del "
"proyecto a lo largo del proceso desde el tablero."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Purchase App </strong>helps you managing requests for proposal, your "
"suppliers\n"
"            and contractors."
msgstr ""
"<strong>La aplicación Compras</strong> te ayuda a gestionar las solicitudes "
"de presupuesto, tus proveedores\n"
"            y contratistas."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Purchase Orders:</strong> Create purchase order for needed products\n"
"                    and services."
msgstr ""
"<strong>Pedidos de compra:</strong> crea un pedido de compra para los "
"productos\n"
"                    y servicios necesarios."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Quotation Templates:</strong> Predefine templates for recurrent\n"
"                    offers."
msgstr ""
"<strong>Plantillas de presupuesto:</strong> plantillas predefinidas para\n"
"                    ofertas recurrentes."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Reordering:</strong> Automate purchase orders for low-stock items."
msgstr ""
"<strong>Reposición:</strong> automatiza los pedidos de compra para los "
"artículos con pocas existencias."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Resource Allocation:</strong> Assign workers, subcontractors, and\n"
"                    machinery."
msgstr ""
"<strong>Asignación de recursos:</strong> asigna trabajadores, "
"subcontratistas y\n"
"                    maquinaria."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Roles:</strong> Assign roles to workers and leverage the auto-"
"assign\n"
"                    capability."
msgstr ""
"<strong>Roles:</strong> asigna roles a los trabajadores y sácale partido a "
"la función de asignación\n"
"                    automática."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Sign</strong> – Collect digital signatures for contracts and "
"approvals."
msgstr ""
"<strong>Firma electrónica</strong>: recoge firmas digitales para contratos y "
"aprobaciones."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Site Transfers:</strong> Allocate materials to specific "
"construction\n"
"                    sites."
msgstr ""
"<strong>Traslados de obras:</strong> asigna materiales a obras\n"
"                    de construcción específicas."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Standardize templates:</strong> Use\n"
"                            quotation and project templates to save time and "
"maintain consistency."
msgstr ""
"<strong>Estandariza plantillas:</strong> utiliza\n"
"                            las plantillas de presupuesto y de proyecto para "
"ahorrar tiempo y hacer que todos tus documentos luzcan uniformes."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Stock Monitoring:</strong> Check available materials and reserve "
"them for\n"
"                    projects."
msgstr ""
"<strong>Seguimiento de existencias:</strong> comprueba los materiales "
"disponibles y resérvalos para\n"
"                    tus proyectos."

#. module: construction
#: model_terms:ir.ui.view,arch_db:construction.welcome_article_body
msgid ""
"<strong>Task Creation:</strong> Break down construction phases into "
"actionable items."
msgstr ""
"<strong>Creación de tareas:</strong> desglosa las fases de construcción en "
"acciones concretas."

#. module: construction
#: model_terms:sale.order.template,note:construction.sale_order_template_1
msgid "<strong>Terms</strong>"
