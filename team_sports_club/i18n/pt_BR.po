#. module: team_sports_club
#: model_terms:ir.ui.view,arch_db:team_sports_club.welcome_article_body
msgid "<strong>CRM</strong> — Manage sponsors and sales opportunities."
msgstr ""
"<strong>CRM</strong> — Gerencie patrocinadores e oportunidades de vendas."

#. module: team_sports_club
#: model_terms:ir.ui.view,arch_db:team_sports_club.welcome_article_body
msgid ""
"<strong>Dashboards</strong> to monitor sponsorship revenue, ticket sales, "
"recruitment pipeline, and bookings."
msgstr ""
"<strong>Painel</strong> para monitorar receitas de patrocínio, vendas de "
"ingressos, pipeline de recrutamento e reservas."

#. module: team_sports_club
#: model_terms:ir.ui.view,arch_db:team_sports_club.welcome_article_body
msgid ""
"<strong>Engage fans</strong>: Add newsletter signup and match highlights to "
"your website to boost retention."
msgstr ""
"<strong>Envolva os fãs</strong>: Adicione a opção de newsletter e os "
"destaques dos jogos ao seu site para aumentar a retenção."

#. module: team_sports_club
#: model_terms:ir.ui.view,arch_db:team_sports_club.welcome_article_body
msgid ""
"<strong>Events</strong> — Handle match tickets, special events, and "
"registrations."
msgstr ""
"<strong>Eventos</strong> — Administre ingressos para jogos, eventos "
"especiais e inscrições."

#. module: team_sports_club
#: model_terms:ir.ui.view,arch_db:team_sports_club.welcome_article_body
msgid ""
"<strong>Invoicing</strong> — Invoice sponsors, ticket purchases, and shop "
"orders."
msgstr ""
"<strong>Faturamento</strong> — Patrocinadores de faturas, compras de "
"ingressos e pedidos na loja."

#. module: team_sports_club
#: model_terms:ir.ui.view,arch_db:team_sports_club.welcome_article_body
msgid ""
"<strong>Keep sponsor data fresh</strong>: Use CRM activity templates for "
"scheduled check-ins or renewals."
msgstr ""
"<strong>Mantenha os dados dos patrocinadores atualizados</strong>: use "
"modelos de atividades de CRM para verificações ou renovações programadas."

#. module: team_sports_club
#: model_terms:ir.ui.view,arch_db:team_sports_club.welcome_article_body
msgid ""
"<strong>Keep your eCommerce slick</strong>: Use bundled offers—e.g., season "
"pass + team kit—to drive value."
msgstr ""
"<strong>Deixe seu e-Commerce mais eficiente</strong>: use ofertas combinadas "
"— por exemplo, passe de temporada + kit do time — para agregar valor."

#. module: team_sports_club
#: model_terms:ir.ui.view,arch_db:team_sports_club.welcome_article_body
msgid ""
"<strong>Marketing Automation</strong> to engage fans and sponsors over time."
msgstr ""
"<strong>Automação de marketing</strong> para engajar fãs e patrocinadores."

#. module: team_sports_club
#: model_terms:ir.ui.view,arch_db:team_sports_club.welcome_article_body
msgid ""
"<strong>Membership/subscription services</strong> with recurring billing via "
"Recurring Invoices."
msgstr ""
"<strong>Serviços de assinatura/associação</strong> com cobrança recorrente "
"em faturas recorrentes."

#. module: team_sports_club
#: model_terms:ir.ui.view,arch_db:team_sports_club.welcome_article_body
msgid ""
"<strong>Organize recruitment</strong>: Standardize evaluation forms in "
"Projects to compare prospects easily."
msgstr ""
"<strong>Organize o recrutamento</strong>: Padronize os formulários de "
"avaliação nos Projetos para comparar candidatos."

#. module: team_sports_club
#: model_terms:ir.ui.view,arch_db:team_sports_club.welcome_article_body
msgid ""
"<strong>Planning</strong> — Schedule and manage field or court bookings."
msgstr ""
"<strong>Planejamento</strong> — Programe e gerencie reservas de campos ou "
"quadras."

#. module: team_sports_club
#: model_terms:ir.ui.view,arch_db:team_sports_club.welcome_article_body
msgid ""
"<strong>Point of Sale</strong> — Operate the club bar and merchandise sales."
msgstr ""
"<strong>Ponto de Venda</strong> — Operar o bar do clube e as vendas de "
"mercadorias."

#. module: team_sports_club
#: model_terms:ir.ui.view,arch_db:team_sports_club.welcome_article_body
msgid ""
"<strong>Project &amp; Appointments</strong> — Coordinate player recruitment, "
"trials, and evaluations."
msgstr ""
"<strong>Projetos e Compromissos</strong> — Coordene recrutamento, testes e "
"avaliações dos jogadores."

#. module: team_sports_club
#: model_terms:ir.ui.view,arch_db:team_sports_club.welcome_article_body
msgid ""
"<strong>Promote events early</strong>: Link your Events app with your "
"website to boost ticket sales."
msgstr ""
"<strong>Divulgue os eventos com antecedência</strong>: vincule seu "
"aplicativo Eventos ao seu site para impulsionar as vendas de ingressos."

#. module: team_sports_club
#: model_terms:ir.ui.view,arch_db:team_sports_club.welcome_article_body
msgid ""
"<strong>SMS Marketing</strong> for last-minute match alerts or ticket "
"promotions."
msgstr ""
"<strong>Marketing por SMS</strong> para alertas de jogos de última hora ou "
"promoções de ingressos."

#. module: team_sports_club
#: model_terms:ir.ui.view,arch_db:team_sports_club.welcome_article_body
msgid ""
"<strong>Sales</strong> — Create sponsorship offers and annual contribution "
"proposals."
msgstr ""
"<strong>Vendas</strong> — Crie ofertas de patrocínio e propostas de "
"contribuição anual."

#. module: team_sports_club
#: model_terms:ir.ui.view,arch_db:team_sports_club.welcome_article_body
msgid ""
"<strong>Sign app</strong> to facilitate digital agreements with sponsors or "
"suppliers."
msgstr ""
"<strong>App Assinar</strong> para facilitar acordos digitais com "
"patrocinadores ou fornecedores."

#. module: team_sports_club
#: model_terms:ir.ui.view,arch_db:team_sports_club.welcome_article_body
msgid ""
"<strong>Simplify bookings</strong>: Share Planning booking links with "
"members or locals to reduce admin overhead."
msgstr ""
"<strong>Simplifique as reservas</strong>: Compartilhe links de reserva de "
"planejamento com membros ou moradores locais para reduzir a sobrecarga "
"administrativa."

#. module: team_sports_club
#: model_terms:ir.ui.view,arch_db:team_sports_club.welcome_article_body
msgid ""
"<strong>Teams</strong> — Organize players, rosters, and team assignments."
msgstr ""
"<strong>Equipes</strong> — Organize jogadores, escalações e atribuições das "
"equipes."

