<?xml version='1.0' encoding='UTF-8'?>
<odoo>
  <record id="res_partner_kanban_view" model="ir.ui.view">
    <field name="arch" type="xml">
      <data>
        <xpath expr="//kanban[1]" position="attributes">
          <attribute name="default_group_by">grade_id</attribute>
        </xpath>
        <xpath expr="//field[@name='complete_name']" position="after">
          <field name="x_jersey" display="full" widget="integer"/>
        </xpath>
      </data>
    </field>
    <field name="inherit_id" ref="base.res_partner_kanban_view"/>
    <field name="mode">extension</field>
    <field name="model">res.partner</field>
    <field name="name">Team Sports Club form view for Partner</field>
    <field name="priority">160</field>
    <field name="type">kanban</field>
    <field name="active" eval="True"/>
  </record>
  <record id="res_partner_grade_list_view" model="ir.ui.view">
    <field name="arch" type="xml">
      <data>
        <xpath expr="//list[1]/field[@name='name']" position="after">
          <field name="x_is_a_team" optional="show"/>
          <field name="default_pricelist_id" optional="show"/>
        </xpath>
      </data>
    </field>
    <field name="inherit_id" ref="partnership.view_partner_grade_tree"/>
    <field name="mode">extension</field>
    <field name="model">res.partner.grade</field>
    <field name="name">Team Sports Club list view for Partner Grade</field>
    <field name="priority">99</field>
    <field name="type">list</field>
    <field name="active" eval="True"/>
  </record>
  <record id="res_partner_list_view" model="ir.ui.view">
    <field name="arch" type="xml">
      <xpath expr="//field[@name='country_id']" position="after">
        <field name="is_published" optional="show"/>
      </xpath>
      <xpath expr="//field[@name='category_id']" position="replace">
        <field name="category_id" optional="show" widget="many2many_tags" options="{'color_field': 'color'}"/>
      </xpath>
      <xpath expr="//field[@name='avatar_128']" position="before">
        <header>
          <button string="Request Contribution" type="action" name="%(request_contibution_act_window)d"/>
        </header>
      </xpath>
    </field>
    <field name="inherit_id" ref="base.view_partner_tree"/>
    <field name="mode">extension</field>
    <field name="model">res.partner</field>
    <field name="name">Team Sports Club list view for Partner</field>
    <field name="priority">160</field>
    <field name="type">list</field>
    <field name="active" eval="True"/>
  </record>
  <record id="contri_form_view_custom" model="ir.ui.view">
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="x_product_id" required="1"/>
            <field name="x_tag_ids" widget="many2many_tags"/>
          </group>
        </sheet>
        <footer>
          <button name="%(generate_contribution_sale_order_action)d" string="Create SO" type="action" class="btn-primary mr8"/>
          <button string="Cancel" class="btn-default" special="cancel"/>
        </footer>
      </form>
    </field>
    <field name="model">x_contri</field>
    <field name="name">contri_form_view_custom</field>
    <field name="type">form</field>
    <field name="active" eval="True"/>
  </record>
  <record id="project_project_form_view" model="ir.ui.view">
    <field name="arch" type="xml">
      <data>
        <xpath expr="//field[@name='tag_ids']" position="after">
          <field name="x_player_recruitement"/>
        </xpath>
      </data>
    </field>
    <field name="inherit_id" ref="project.edit_project"/>
    <field name="mode">extension</field>
    <field name="model">project.project</field>
    <field name="name">Team Sports Club form view for Project Project</field>
    <field name="priority">160</field>
    <field name="type">form</field>
    <field name="active" eval="True"/>
  </record>
  <record id="res_partner_grade_form_view" model="ir.ui.view">
    <field name="arch" type="xml">
      <data>
        <xpath expr="//form[1]/sheet[1]/group[1]" position="replace"/>
        <xpath expr="//field[@name='default_pricelist_id']" position="after">
          <field name="x_type"/>
        </xpath>
      </data>
    </field>
    <field name="inherit_id" ref="partnership.view_partner_grade_form"/>
    <field name="mode">extension</field>
    <field name="model">res.partner.grade</field>
    <field name="name">Team Sports Club form view for Partner Grade</field>
    <field name="priority">160</field>
    <field name="type">form</field>
    <field name="active" eval="True"/>
  </record>
  <record id="appointment_type_form_view" model="ir.ui.view">
    <field name="arch" type="xml">
      <data>
        <xpath expr="//form[1]/sheet[1]/group[1]/group[@name='left_details']/div[5]" position="after">
          <field name="x_team"/>
        </xpath>
      </data>
    </field>
    <field name="inherit_id" ref="appointment.appointment_type_view_form"/>
    <field name="mode">extension</field>
    <field name="model">appointment.type</field>
    <field name="name">Team Sports Club form view for Appointment Type</field>
    <field name="priority">200</field>
    <field name="type">form</field>
    <field name="active" eval="True"/>
  </record>
  <record id="calender_event_form_view" model="ir.ui.view">
    <field name="arch" type="xml">
      <data>
        <xpath expr="//field[@name='categ_ids']" position="after">
          <field name="x_team"/>
        </xpath>
      </data>
    </field>
    <field name="inherit_id" ref="calendar.view_calendar_event_form"/>
    <field name="mode">extension</field>
    <field name="model">calendar.event</field>
    <field name="name">Team Sports Club Form view for Calendar Event</field>
    <field name="priority">160</field>
    <field name="type">form</field>
    <field name="active" eval="True"/>
  </record>
  <record id="ir_actions_act_window_form_view" model="ir.ui.view">
    <field name="arch" type="xml">
      <data>
        <xpath expr="//field[@name='cache']" position="after">
          <field name="binding_model_id"/>
          <field name="binding_type"/>
          <field name="binding_view_types"/>
        </xpath>
      </data>
    </field>
    <field name="inherit_id" ref="base.view_window_action_form"/>
    <field name="mode">extension</field>
    <field name="model">ir.actions.act_window</field>
    <field name="name">Team Sports Club form view for Ir Actions Act Window</field>
    <field name="priority">99</field>
    <field name="type">form</field>
    <field name="active" eval="True"/>
  </record>
  <record id="calender_event_list_view" model="ir.ui.view">
    <field name="arch" type="xml">
      <data>
        <xpath expr="//list[1]" position="attributes">
          <attribute name="default_group_by">x_team,start_date:day</attribute>
          <attribute name="default_order">start_date desc</attribute>
        </xpath>
      </data>
    </field>
    <field name="inherit_id" ref="calendar.view_calendar_event_tree"/>
    <field name="mode">extension</field>
    <field name="model">calendar.event</field>
    <field name="name">Team Sports Club list view for Calendar Event</field>
    <field name="priority">160</field>
    <field name="type">list</field>
    <field name="active" eval="True"/>
  </record>
  <record id="event_registeration_kanban_view" model="ir.ui.view">
    <field name="arch" type="xml">
      <data>
        <xpath expr="//kanban[1]/templates[1]/t[@t-name='card']/div[1]/div[2]/div[2]" position="replace"/>
        <xpath expr="//kanban[1]/templates[1]/t[@t-name='card']/div[1]/div[2]/div[1]" position="replace"/>
        <xpath expr="//kanban[1]" position="attributes">
          <attribute name="default_group_by">event_slot_id</attribute>
        </xpath>
      </data>
    </field>
    <field name="inherit_id" ref="event.event_registration_view_kanban"/>
    <field name="mode">extension</field>
    <field name="model">event.registration</field>
    <field name="name">Team Sports Club kanban view for Event Registeration</field>
    <field name="priority">160</field>
    <field name="type">kanban</field>
    <field name="active" eval="True"/>
  </record>
  <record id="event_registeration_form_view" model="ir.ui.view">
    <field name="arch" type="xml">
      <data>
        <xpath expr="//field[@name='company_name']" position="after">
          <field name="x_team"/>
        </xpath>
      </data>
    </field>
    <field name="inherit_id" ref="event.view_event_registration_form"/>
    <field name="mode">extension</field>
    <field name="model">event.registration</field>
    <field name="name">Team Sports Club form view for Event Registeration</field>
    <field name="priority">160</field>
    <field name="type">form</field>
    <field name="active" eval="True"/>
  </record>
  <record id="event_registeration_search_view" model="ir.ui.view">
    <field name="arch" type="xml">
      <data>
        <xpath expr="//filter[@name='group_by_registration_properties']" position="replace"/>
        <xpath expr="//filter[@name='group_by_utm_source_id']" position="replace"/>
        <xpath expr="//filter[@name='group_by_utm_medium_id']" position="replace"/>
        <xpath expr="//filter[@name='group_by_utm_campaign_id']" position="replace"/>
        <xpath expr="//filter[@name='group_event_ticket_id']" position="replace"/>
        <xpath expr="//field[@name='event_ticket_id']" position="replace"/>
        <xpath expr="//field[@name='registration_answer_ids']" position="replace"/>
        <xpath expr="//field[@name='partner_id']" position="replace"/>
        <xpath expr="//field[@name='company_id']" position="replace"/>
        <xpath expr="//field[@name='id']" position="replace">
          <field name="x_team"/>
        </xpath>
        <xpath expr="//field[@name='event_organizer_id']" position="after">
          <filter domain="[(&quot;create_date&quot;, &quot;&lt;&quot;, (context_today() - datetime.timedelta(days = 15)).strftime(&quot;%Y-%m-%d&quot;))]" name="studio_filter_5r0_1j2f44jv4" string="Upcoming trainings"/>
        </xpath>
      </data>
    </field>
    <field name="inherit_id" ref="event.view_registration_search"/>
    <field name="mode">extension</field>
    <field name="model">event.registration</field>
    <field name="name">Team Sports Club search view for Event Registeration</field>
    <field name="priority">320</field>
    <field name="type">search</field>
    <field name="active" eval="True"/>
  </record>
  <record id="event_registeration_list_view" model="ir.ui.view">
    <field name="arch" type="xml">
      <data>
        <xpath expr="//field[@name='event_ticket_id']" position="replace"/>
      </data>
    </field>
    <field name="inherit_id" ref="event.view_event_registration_tree"/>
    <field name="mode">extension</field>
    <field name="model">event.registration</field>
    <field name="name">Team Sports Club list view for Event Registeration</field>
    <field name="priority">160</field>
    <field name="type">list</field>
    <field name="active" eval="True"/>
  </record>
  <record id="res_partner_form_view" model="ir.ui.view">
    <field name="arch" type="xml">
      <data>
        <xpath expr="//field[@name='grade_id']" position="attributes">
          <attribute name="string">Team</attribute>
        </xpath>
        <xpath expr="//field[@name='grade_id']" position="after">
          <field name="x_jersey"/>
        </xpath>
      </data>
    </field>
    <field name="inherit_id" ref="base.view_partner_form"/>
    <field name="mode">extension</field>
    <field name="model">res.partner</field>
    <field name="name">Team Sports Club form view for Partner</field>
    <field name="priority">200</field>
    <field name="type">form</field>
    <field name="active" eval="True"/>
  </record>
  <record id="res_partner_search_view" model="ir.ui.view">
    <field name="arch" type="xml">
      <data>
        <xpath expr="//filter[@name='group_grade']" position="attributes">
          <attribute name="string">Team</attribute>
        </xpath>
      </data>
    </field>
    <field name="inherit_id" ref="base.view_res_partner_filter"/>
    <field name="mode">extension</field>
    <field name="model">res.partner</field>
    <field name="name">Team Sports Club search view for Partner</field>
    <field name="priority">160</field>
    <field name="type">search</field>
    <field name="active" eval="True"/>
  </record>
</odoo>
