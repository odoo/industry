#. module: wedding_planner
#: model_terms:ir.ui.view,arch_db:wedding_planner.welcome_article_body
msgid ""
"Optimize your procurement process by efficiently managing vendor quotations "
"and presenting the best options to your customers."
msgstr ""
"Optimoi hankintaprosessisi hallinnoimalla toimittajien tarjouksia "
"tehokkaasti ja esittämällä asiakkaillesi parhaat vaihtoehdot."

#. module: wedding_planner
#: model:sale.order.template.line,name:wedding_planner.sale_order_template_line_27
msgid "Organization"
msgstr "Organisaatio"

#. module: wedding_planner
#: model_terms:ir.ui.view,arch_db:wedding_planner.welcome_article_body
msgid ""
"Our CRM is designed to streamline your sales process, ensuring seamless management of leads, opportunities, and client interactions. With intuitive tools and automation, you can stay organized, improve efficiency, and close deals\n"
"        faster."
msgstr ""
"CRM-järjestelmämme on suunniteltu tehostamaan myyntiprosessiasi, varmistaen "
"sujuvan liidien, myyntimahdollisuuksien ja asiakaskohtaamisten hallinnan. "
"Intuitiivisten työkalujen ja automaation avulla pysyt järjestäytyneenä, "
"parannat tehokkuutta ja saat kaupat nopeammin päätökseen."

#. module: wedding_planner
#: model:crm.tag,name:wedding_planner.crm_tag_2
msgid "Partial Service Wedding"
msgstr "Osittainen palvelu häihin"

#. module: wedding_planner
#: model:product.template,name:wedding_planner.product_product_17_product_template
msgid "Photography Coverage"
msgstr "Valokuvaus "

#. module: wedding_planner
#: model:sale.order.template.line,name:wedding_planner.sale_order_template_line_11
msgid "Planning & Coordination"
