msgstr "Igangværende"

#. module: wedding_planner
#: model_terms:ir.ui.view,arch_db:wedding_planner.welcome_article_body
msgid ""
"Optimize your procurement process by efficiently managing vendor quotations "
"and presenting the best options to your customers."
msgstr ""
"Optimér din indkøbsproces ved at administrere tilbud fra leverandører "
"effektivt og præsentere dine kunder for de bedste muligheder."

#. module: wedding_planner
