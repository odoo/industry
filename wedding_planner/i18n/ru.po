#. module: wedding_planner
#: model_terms:ir.ui.view,arch_db:wedding_planner.welcome_article_body
msgid ""
"<b>CRM App</b>: Capture the details of engaged couples and manage the sales "
"pipeline from the first inquiry to the\n"
"                signed contract."
msgstr ""

#. module: wedding_planner
#: model_terms:ir.ui.view,arch_db:wedding_planner.welcome_article_body
msgid ""
"<b>Contacts App</b>: Maintain a comprehensive directory of trusted vendors, "
"venues, and suppliers to quickly connect\n"
"                them with your clients."
msgstr ""

#. module: wedding_planner
#: model_terms:ir.ui.view,arch_db:wedding_planner.welcome_article_body
msgid ""
"<b>Documents App</b>: Centralize contracts, mood boards, and floor plans in "
"one secure location for easy sharing and\n"
"                retrieval."
msgstr ""

#. module: wedding_planner
#: model_terms:ir.ui.view,arch_db:wedding_planner.welcome_article_body
msgid ""
"<b>Events App</b>: Orchestrate the flow of the wedding day itself, managing "
"schedules and on-site logistics with\n"
"                precision."
msgstr ""

#. module: wedding_planner
#: model_terms:ir.ui.view,arch_db:wedding_planner.welcome_article_body
msgid ""
"<b>Invoicing App</b>: Keep the budget on track by generating professional "
"invoices for your services and tracking\n"
"                vendor payments."
msgstr ""

#. module: wedding_planner
#: model_terms:ir.ui.view,arch_db:wedding_planner.welcome_article_body
msgid ""
"<b>Project App</b>: Create detailed planning checklists and timelines, "
"ensuring every task—from cake tasting to\n"
"                venue booking—is completed on schedule."
msgstr ""

#. module: wedding_planner
#: model_terms:ir.ui.view,arch_db:wedding_planner.welcome_article_body
msgid ""
"<b>Sales App</b>: Create beautiful, itemized quotations for different "
"wedding packages and manage down payments\n"
"                easily."
msgstr ""

