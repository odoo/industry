#. module: condominium
#: model_terms:ir.ui.view,arch_db:condominium.report_calendar_event_general_meeting_document
msgid ""
"<strong>\n"
"\t\t\t\t\t\t\t\tGENERAL MEETING REPORT\n"
"\t\t\t\t\t\t\t</strong>"
msgstr ""
"<strong>\n"
