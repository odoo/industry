<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="model_x_motion" model="ir.model">
      <field name="model">x_motion</field>
      <field name="name">Motion</field>
    </record>
    <record id="model_x_motion_vote" model="ir.model">
      <field name="model">x_motion_vote</field>
      <field name="name">Vote</field>
    </record>
    <record id="model_x_vote_criteria" model="ir.model">
      <field name="is_mail_thread" eval="True"/>
      <field name="is_mail_activity" eval="True"/>
      <field name="model">x_vote_criteria</field>
      <field name="name">Vote Criteria</field>
    </record>
    <record id="ratios_model" model="ir.model">
      <field name="model">x_ratios</field>
      <field name="name">Ratios</field>
    </record>
    <record id="model_x_split_analytic_items_wizard" model="ir.model">
      <field name="model">x_split_analytic_items_wizard</field>
      <field name="name">Split Analytic Items</field>
    </record>
    <record id="model_x_account_analytic_split_line" model="ir.model">
      <field name="model">x_account_analytic_split_line</field>
      <field name="name">Account Analytic Line Split</field>
    </record>
    <record id="model_x_distribution_key" model="ir.model">
      <field name="is_mail_thread" eval="True"/>
      <field name="is_mail_activity" eval="True"/>
      <field name="model">x_distribution_key</field>
      <field name="name">Distribution Key</field>
    </record>
</odoo>
