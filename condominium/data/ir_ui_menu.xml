<?xml version='1.0' encoding='UTF-8'?>
<odoo auto_sequence="1">
  <menuitem id="condo_menu" name="Condominium">

    <menuitem id="infra_menu" name="Infrastructure">
        <menuitem id="infra_condominium_menu" name="Condominium" action="action_view_company_partner"/>
        <menuitem id="building_menu" name="Buildings" action="property_assets_distribution.buildings_act_window"/>
        <menuitem id="infra_properties_menu" name="Properties" action="property_actions_window"/>
        <menuitem id="infra_distribution_menu" name="Distribution Keys" action="distribution_keys_actions_window"/>
    </menuitem>

    <menuitem id="owners_menu" name="Owners">
        <menuitem id="condominium_owners_menu" name="Owners" action="owners_act_window"/>
        <menuitem id="owners_properties_menu" name="Accounts" action="properties_act_window_account"/>
        <menuitem id="owners_help_menu" name="Helpdesk" action="helpdesk.helpdesk_team_dashboard_action_main"/>
        <menuitem id="owners_docs_menu" name="Documents" action="documents.document_action"/>
        <menuitem id="owners_sales_menu" name="Sales" action="sale.action_quotations_with_onboarding"/>
        <menuitem id="condominium_meetings_menu" name="Meetings" action="meeting_action_window"/>
    </menuitem>

    <menuitem id="purchase_menu" name="Purchase">
        <menuitem id="condominium_invoices_menu" name="Distribution" action="distribution_action_window"/>
        <menuitem id="purchase_vendor_menu" name="Vendors" action="vendors_act_window"/>
        <menuitem id="purchase_employee_menu" name="Employees" action="employees_act_window"/>
    </menuitem>

    <menuitem id="config_menu" name="Configuration">
        <menuitem id="conf_prop_menu" name="Properties">
            <menuitem id="conf_prop_type" name="Type" action="property_assets_distribution.property_types_act_window"/>
            <menuitem id="conf_prop_tag_menu" name="Tags" action="property_assets_distribution.properties_tags_act_window"/>
        </menuitem>
        <menuitem id="conf_building_menu" name="Buildings">
            <menuitem id="conf_tags_menu" name="Tags" action="property_assets_distribution.buildings_tags_act_window"/>
        </menuitem>
        <menuitem id="condominium_costs_menu" name="Costs">
            <menuitem id="condominium_meters_menu" name="Meters" action="property_assets_distribution.action_configuration_meters"/>
        </menuitem>
        <menuitem id="condominium_general_meeting_menu" name="Meetings">
            <menuitem id="condominium_motion_criteria_menu" name="Motion Criteria" action="motion_criteria_action_window"/>
        </menuitem>
    </menuitem>

  </menuitem>

  <record model="ir.ui.menu" id="condo_menu">
      <field name="web_icon_data" type="base64" file="condominium/static/description/icon.png"/>
  </record>
</odoo>
