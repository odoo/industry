    <record id="odoo_studio_default__43c89979-7f2e-485c-a144-75468c68743e" model="ir.ui.view">
        <field name="name">Default search view for x_units customization</field>
        <field name="inherit_id" ref="default_search_view__03c5f233-ae56-44ca-8644-f14948e797e0"/>
        <field name="mode">extension</field>
        <field name="model">x_units</field>
        <field name="priority">99</field>
        <field name="type">search</field>
        <field name="arch" type="xml">
            <data>
                <xpath expr="//field[@name='x_partner_id']" position="before">
                    <field name="x_condominium_id"/>
                </xpath>
                <xpath expr="//field[@name='x_partner_id']" position="after">
                    <field name="x_tenant_id"/>
                </xpath>
                <xpath expr="//field[@name='x_tag_ids']" position="after">
                    <xpath expr="//field[@name='x_name']" position="move"/>
                </xpath>
                <xpath expr="//search[1]/separator[2]" position="after">
                    <filter name="studio_group_by_555_1hn3icbit" string="Condominium" context="{'group_by': 'x_condominium_id'}"/>
                </xpath>
            </data>
        </field>
    </record>
    <record id="odoo_studio_default__8a8e16da-0210-4a6d-8a1f-544ee29561a3" model="ir.ui.view">
        <field name="name">Default form view for x_units customization</field>
        <field name="inherit_id" ref="default_form_view_fo_9221ebf0-aa0d-4812-b824-ead5687c8610"/>
        <field name="mode">extension</field>
        <field name="model">x_units</field>
        <field name="priority">99</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <data>
                <xpath expr="//field[@name='x_partner_email']" position="replace">
                    <field name="x_tenant_id" options="{&quot;no_create&quot;:true}"/>
                </xpath>
                <xpath expr="//field[@name='x_partner_phone']" position="replace"/>
                <xpath expr="//field[@name='x_partner_id']" position="before">
                    <field name="x_condominium_id" options="{&quot;no_create&quot;:true}" domain="[(&quot;x_related_companies_ids&quot;, &quot;!=&quot;, False)]" required="True"/>
                </xpath>
                <xpath expr="//field[@name='x_partner_id']" position="attributes">
                    <attribute name="options">{"no_create":true}</attribute>
                    <attribute name="required">True</attribute>
                    <attribute name="string">Owner</attribute>
                </xpath>
                <xpath expr="//field[@name='x_tag_ids']" position="before">
                    <field name="x_area" required="True"/>
                    <field name="x_area_percent" widget="percentage"/>
                </xpath>
            </data>
        </field>
    </record>
    <record id="odoo_studio_default__d3bd48c1-df2e-45c6-9653-db3266fc4756" model="ir.ui.view">
        <field name="name">Default list view for x_units customization</field>
        <field name="inherit_id" ref="default_list_view_fo_0e27c1db-7959-456c-bf3b-e908575f3d36"/>
        <field name="mode">extension</field>
        <field name="model">x_units</field>
        <field name="priority">99</field>
        <field name="type">tree</field>
        <field name="arch" type="xml">
            <data>
                <xpath expr="//field[@name='x_sequence']" position="after">
                    <field name="x_condominium_id" optional="show"/>
                </xpath>
                <xpath expr="//field[@name='x_name']" position="attributes">
                    <attribute name="optional">show</attribute>
                </xpath>
                <xpath expr="//field[@name='x_partner_id']" position="attributes">
                    <attribute name="optional">show</attribute>
                </xpath>
                <xpath expr="//field[@name='x_partner_id']" position="after">
                    <field name="x_tenant_id" optional="hide"/>
                </xpath>
                <xpath expr="//field[@name='x_tag_ids']" position="attributes">
                    <attribute name="optional">show</attribute>
                </xpath>
                <xpath expr="//field[@name='x_tag_ids']" position="after">
                    <field name="x_area" optional="show"/>
                    <field name="x_area_percent" optional="show"/>
                </xpath>
            </data>
        </field>
    </record>
    <record id="odoo_studio_res_part_604442d1-4847-42bc-b94a-66a37b6fd4f6" model="ir.ui.view">
        <field name="name">res.partner.form customization</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="mode">extension</field>
        <field name="model">res.partner</field>
        <field name="priority">160</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <data>
                <xpath expr="//field[@name='vat']" position="after">
                    <field name="x_condominiums_ids" invisible="False" widget="many2many_tags" options="{&quot;no_create&quot;:true}" force_save="1" readonly="True"/>
                </xpath>
                <xpath expr="//page[@name='contact_addresses']" position="attributes">
                    <attribute name="invisible">not x_condominium_units_ids</attribute>
                </xpath>
                <xpath expr="//form[1]/sheet[1]/notebook[1]" position="inside">
                    <page string="Properties" name="studio_page_partner_condominium_units" invisible="not x_condominium_units_ids">
                        <field name="x_condominium_units_ids" string="Condominium Units">
                            <tree default_order="x_area desc" create="false" edit="false" delete="false">
                                <field name="x_name" optional="show"/>
                                <field name="x_partner_id" optional="show" options="{&quot;no_create&quot;:true}"/>
                                <field name="x_tenant_id" optional="hide"/>
                                <field name="x_tag_ids" widget="many2many_tags" options="{&quot;color_field&quot;: &quot;x_color&quot;, &quot;no_create&quot;: true}" optional="show"/>
                                <field name="x_area" optional="show" sum="Sum of Area"/>
                                <field name="x_area_percent" optional="show" sum="Sum of Area %" widget="percentage"/>
                            </tree>
                        </field>
                    </page>
                    <page string="Properties" name="studio_page_partner_units_owner" invisible="not x_units_owner_ids">
                        <field name="x_units_owner_ids" string="Units Owner">
                            <tree create="false" edit="false" delete="false" default_order="x_area desc">
                                <field name="x_sequence" widget="handle"/>
                                <field name="x_condominium_id" optional="show"/>
                                <field name="x_name" optional="show"/>
                                <field name="x_tenant_id" optional="hide"/>
                                <field name="x_tag_ids" widget="many2many_tags" options="{'color_field': 'x_color'}" optional="show"/>
                                <field name="x_area" optional="show" sum="Sum of Area"/>
                                <field name="x_area_percent" optional="show" sum="Sum of Area %" widget="percentage"/>
                            </tree>
                        </field>
                    </page>
                </xpath>
            </data>
        </field>
    </record>
    <record id="odoo_studio_res_part_840d60c0-c099-494f-988b-ee82e1f854ac" model="ir.ui.view">
        <field name="name">res.partner.kanban customization</field>
        <field name="inherit_id" ref="base.res_partner_kanban_view"/>
        <field name="mode">extension</field>
        <field name="model">res.partner</field>
        <field name="priority">200</field>
        <field name="type">kanban</field>
        <field name="arch" type="xml">
            <data>
                <xpath expr="//kanban[1]/templates[1]/t[1]/div[1]/div[2]/div[1]/ul[1]/li[4]/t[2]/field[@name='country_id']" position="after">
