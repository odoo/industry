<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="default_form_view_fo_81a7220b-0d38-43b9-824b-672f8c5d6b08" model="ir.ui.view">
        <field name="arch" type="xml">
            <form>
                <header/>
                <sheet string="Units Tags">
                    <div class="oe_title">
                        <h1>
                            <field name="x_name" required="1" placeholder="Name..."/>
                        </h1>
                    </div>
                    <group name="studio_group_dae2bf">
                        <group name="studio_group_dae2bf_left"/>
                        <group name="studio_group_dae2bf_right"/>
                    </group>
                </sheet>
            </form>
        </field>
        <field name="model">x_units_tag</field>
        <field name="name">Default form view for x_units_tag</field>
        <field name="type">form</field>
    </record>
    <record id="default_form_view_fo_9221ebf0-aa0d-4812-b824-ead5687c8610" model="ir.ui.view">
        <field name="arch" type="xml">
            <form>
                <header/>
                <sheet string="Units">
                    <widget name="web_ribbon" text="Archived" bg_color="text-bg-danger" invisible="x_active"/>
                    <field name="x_active" invisible="1"/>
                    <field class="oe_avatar" widget="image" name="x_image"/>
                    <div class="oe_title">
                        <h1>
                            <field name="x_name" required="1" placeholder="Name..."/>
                        </h1>
                    </div>
                    <group name="studio_group_d10900">
                        <group name="studio_group_d10900_left">
                            <field name="x_partner_id"/>
                            <field name="x_partner_phone" widget="phone" options="{'enable_sms': True}"/>
                            <field name="x_partner_email" widget="email"/>
                        </group>
                        <group name="studio_group_d10900_right">
                            <field name="x_tag_ids" widget="many2many_tags" options="{'color_field': 'x_color'}"/>
                        </group>
                    </group>
                    <group>
                        <field name="x_notes" placeholder="Type down your notes here..." nolabel="1" colspan="2"/>
                    </group>
                </sheet>
                <div class="oe_chatter" name="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                    <field name="activity_ids"/>
                </div>
            </form>
        </field>
        <field name="model">x_units</field>
        <field name="name">Default form view for x_units</field>
        <field name="type">form</field>
    </record>
    <record id="default_list_view_fo_0e27c1db-7959-456c-bf3b-e908575f3d36" model="ir.ui.view">
        <field name="arch" type="xml">
            <tree>
                <field name="x_sequence" widget="handle"/>
                <field name="x_name"/>
                <field name="x_partner_id"/>
                <field name="x_tag_ids" widget="many2many_tags" options="{'color_field': 'x_color'}"/>
            </tree>
        </field>
        <field name="model">x_units</field>
        <field name="name">Default list view for x_units</field>
        <field name="type">tree</field>
    </record>
    <record id="default_list_view_fo_4ad5f83c-bc85-4844-80b0-c15128ef9165" model="ir.ui.view">
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="x_name"/>
                <field name="x_color" widget="color_picker"/>
