#. module: photography
#: model:mail.template,body_html:photography.email_template_wedding_event_quote
msgid ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Dear <t t-out=\"object.partner_id.name or '''John Doe'''\"/>,</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Congratulations on your\n"
"                    engagement! We're thrilled you're considering <t t-out=\"object.company_id.name or '''us'''\">Frozen Moments</t> to capture the\n"
"                    magic of your wedding day..</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">We would be honored to be part of\n"
"                    this significant\n"
"                    chapter in your lives.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">If you have any questions or\n"
"                    require further customization, please don't hesitate to reach out to us.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Best wishes,</p>\n"
"            \n"
"        "
msgstr ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">ຮຽນ <t t-"
"out=\"object.partner_id.name or '''John Doe'''\"/>,</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">ຂໍສະແດ"
"ງຄວາມຍິນດີກັບການໝັ້ນໝາຍຂອງທ່ານ!\n"
"                    ພວກເຮົາດີໃຈຫຼາຍທີ່ທ່ານໃຫ້ຄວາມສົນໃຈ <t t-"
"out=\"object.company_id.name or '''us'''\">Frozen Moments</t> ເພື່ອບັນທຶກ\n"
"                    ຄວາມມຫັດສະຈັນຂອງວັນແຕ່ງດອງຂອງທ່ານ..</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">ພວກເຮົ"
"າຮູ້ສຶກເປັນກຽດທີ່ຈະໄດ້ເປັນສ່ວນໜຶ່ງຂອງ\n"
"                    ບົດບາດທີ່ສຳຄັນນີ້\n"
"                    ໃນຊີວິດຂອງທ່ານ.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">ຫາກທ່າ"
"ນມີຄຳຖາມ ຫຼື\n"
"                    ຕ້ອງການປັບແຕ່ງເພີ່ມເຕີມ, ກະລຸນາຕິດຕໍ່ຫາພວກເຮົາໄດ້ທຸກເວລາ.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">ດ້ວຍຄວ"
"າມປາດຖະໜາດີ,</p>\n"
"            \n"
"        "

#. module: photography
#: model:mail.template,body_html:photography.email_template_pro_event_quote
msgid ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Dear <t t-out=\"object.partner_id.name or '''John Doe'''\"/>,</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">I hope this email finds you well.\n"
"                    Thank you for considering <t t-out=\"object.company_id.name or '''Frozen Moments'''\"/>\n"
"                    for your upcoming event.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">We would be honoured to capture\n"
"                    the special moments of your event and provide high-quality photographs that you can\n"
"                    cherish for years to come.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">If you have any questions or\n"
"                    require further customization, please don't hesitate to reach out to us.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Best regards,</p>\n"
"            \n"
"        "
msgstr ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">ຮຽນ <t t-"
"out=\"object.partner_id.name or '''John Doe'''\"/>,</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">ຫວັງວ່າ"
"ທ່ານຈະສະບາຍດີ.\n"
"                    ຂອບໃຈທີ່ທ່ານໃຫ້ຄວາມສົນໃຈ <t t-out=\"object.company_id.name or "
"'''Frozen Moments'''\"/>\n"
"                    ສຳລັບງານທີ່ກຳລັງຈະມາເຖິງຂອງທ່ານ.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">ພວກເຮົ"
"າຮູ້ສຶກເປັນກຽດທີ່ຈະໄດ້ບັນທຶກ\n"
"                    ຊ່ວງເວລາພິເສດຂອງງານ ແລະ ມອບຮູບພາບທີ່ມີຄຸນນະພາບສູງໃຫ້ທ່ານ\n"
"                    ເພື່ອເກັບໄວ້ເປັນຄວາມຊົງຈຳທີ່ດີຕະຫຼອດໄປ.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">ຫາກທ່າ"
"ນມີຄຳຖາມ ຫຼື\n"
"                    ຕ້ອງການປັບແຕ່ງເພີ່ມເຕີມ, ກະລຸນາຕິດຕໍ່ຫາພວກເຮົາໄດ້ທຸກເວລາ.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">ດ້ວຍຄວ"
"າມນັບຖື,</p>\n"
"            \n"
"        "

#. module: photography
#: model:mail.template,body_html:photography.email_template_confirmation
msgid ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Dear <t t-out=\"object.partner_id.name or '''John Doe'''\"/>,</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Thank you for choosin <t t-out=\"object.company_id.name or '''us'''\">Frozen Moments</t> for your upcoming\n"
"                    photography needs. We are pleased to confirm your booking!</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Note: Upon confirmation, we will\n"
"                    contact you\n"
"                    shortly to discuss scheduling and any specific requirements you may have.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">More details will follow soon.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">If you have any questions or need\n"
"                    to make changes,\n"
"                    please contact us as soon as possible.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Best regards,</p>\n"
"            \n"
"        "
msgstr ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">ຮຽນ <t t-"
"out=\"object.partner_id.name or '''John Doe'''\"/>,</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">ຂອບໃຈ"
"ທີ່ເລືອກ <t t-out=\"object.company_id.name or '''us'''\">Frozen Moments</t> ສຳລັບ"
"ການຖ່າຍຮູບ\n"
"                    ຂອງທ່ານ.ພວກເຮົາມີຄວາມຍິນດີທີ່ຈະຢືນຢັນການຈອງຂອງທ່ານ!</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">ໝາຍເຫ"
"ດ: ຫຼັງຈາກການຢືນຢັນ, ພວກເຮົາຈະ\n"
"                    ຕິດຕໍ່ຫາທ່ານ\n"
"                    ໃນໄວໆນີ້ເພື່ອສົນທະນາກ່ຽວກັບຕາຕະລາງເວລາ ແລະ ຂໍ້ກຳນົດສະເພາະທີ່ທ່ານຕ້ອງກາ"
"ນ.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">ລາຍລະ"
"ອຽດເພີ່ມເຕີມຈະສົ່ງໃຫ້ໃນໄວໆນີ້.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">ຫາກທ່າ"
"ນມີຄຳຖາມ ຫຼື ຕ້ອງການ\n"
"                    ປ່ຽນແປງຂໍ້ມູນ,\n"
"                    ກະລຸນາຕິດຕໍ່ຫາພວກເຮົາໂດຍໄວທີ່ສຸດ.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">ດ້ວຍຄວ"
"າມນັບຖື,</p>\n"
"            \n"
"        "

#. module: photography
#: model:mail.template,body_html:photography.email_template_studio_quote
msgid ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Dear <t t-out=\"object.partner_id.name or '''John Doe'''\"/>,</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Thank you for considering <t t-out=\"object.company_id.name or '''us'''\">Frozen Moments</t> for your studio\n"
"                    photography needs. We look forward to capturing your essence in high-quality\n"
"                    photographs.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Note: Upon confirmation, we will\n"
"                    contact you\n"
"                    shortly to discuss scheduling and any specific requirements you may have.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">If you have any questions or need\n"
"                    further details,\n"
"                    don't hesitate to reach out. </p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Best regards,</p>\n"
"            \n"
"        "
msgstr ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">ຮຽນ <t t-"
"out=\"object.partner_id.name or '''John Doe'''\"/>,</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">ຂອບໃຈ"
"ທີ່ໃຫ້ຄວາມສົນໃຈ <t t-out=\"object.company_id.name or '''us'''\">Frozen Moments</"
"t> ສຳລັບການຖ່າຍຮູບ\n"
"                    ໃນສະຕູດິໂອຂອງທ່ານ. ພວກເຮົາຫວັງຢ່າງຍິ່ງທີ່ຈະໄດ້ບັນທຶກພາບຂອງທ່ານ\n"
"                    ດ້ວຍຮູບພາບທີ່ມີຄຸນນະພາບສູງ.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">ໝາຍເຫ"
"ດ: ຫຼັງຈາກການຢືນຢັນ, ພວກເຮົາຈະ\n"
"                    ຕິດຕໍ່ຫາທ່ານ\n"
"                    ໃນໄວໆນີ້ເພື່ອສົນທະນາກ່ຽວກັບຕາຕະລາງເວລາ ແລະ ຂໍ້ກຳນົດສະເພາະທີ່ທ່ານຕ້ອງກາ"
"ນ.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">ຫາກທ່າ"
"ນມີຄຳຖາມ ຫຼື ຕ້ອງການ\n"
"                    ລາຍລະອຽດເພີ່ມເຕີມ,\n"
"                    ຢ່າລັງເລທີ່ຈະຕິດຕໍ່ຫາພວກເຮົາ. </p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">ດ້ວຍຄວ"
"າມນັບຖື,</p>\n"
"            \n"
"        "

#. module: photography
#: model:mail.template,body_html:photography.email_calendar_reminder
msgid ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Dear <t t-out=\"object.partner_id.name or '''John Doe'''\"/>,</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">We're looking forward to capturing\n"
"                    your photographs\n"
"                    during our studio session tomorrow. Here are the details for your reference:\n"
"                </p>\n"
"                <ul style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"                    <li>\n"
"                        <b>When:<t t-out=\"format_datetime(object.event_id.start, tz=object.mail_tz, dt_format=&quot;long&quot;, lang_code=object.env.lang) or &quot;&quot;\">Tue,\n"
"                            Oct 31st - 11:00 AM</t></b>\n"
"                    </li>\n"
"                    <li>\n"
"                        <b>Where:<t t-out=\"object.event_id.location or ''\">Frozen Moments Studio</t></b>\n"
"                    </li>\n"
"                </ul>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Please arrive on time to make the\n"
"                    most out\n"
"                    of your session.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">More details will follow soon.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">If you have any questions or need\n"
"                    to reschedule,\n"
"                    please contact us as soon as possible. </p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Best regards,</p>\n"
"            \n"
"        "
msgstr ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">ຮຽນ <t t-"
"out=\"object.partner_id.name or '''John Doe'''\"/>,</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">ພວກເຮົ"
"າຫວັງຢ່າງຍິ່ງທີ່ຈະໄດ້ບັນທຶກ\n"
"                    ຮູບພາບຂອງທ່ານ\n"
"                    ໃນຮອບການຖ່າຍໃນສະຕູດິໂອມື້ອື່ນນີ້. ນີ້ແມ່ນລາຍລະອຽດສຳລັບທ່ານ:\n"
"                </p>\n"
"                <ul style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"                    <li>\n"
"                        <b>ເວລາ:<t t-out=\"format_datetime"
"(object.event_id.start, tz=object.mail_tz, dt_format=&quot;long&quot;, "
"lang_code=object.env.lang) or &quot;&quot;\">ວັນອັງຄານ,\n"
"                            31 ຕຸລາ - 11:00 ໂມງເຊົ້າ</t></b>\n"
"                    </li>\n"
"                    <li>\n"
"                        <b>ສະຖານທີ່:<t t-out=\"object.event_id.location or "
"''\">ສະຕູດິໂອ Frozen Moments</t></b>\n"
"                    </li>\n"
"                </ul>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">ກະລຸນາ"
"ມາໃຫ້ຕົງເວລາເພື່ອໃຫ້ໄດ້\n"
"                    ຜົນປະໂຫຍດສູງສຸດ\n"
"                    ຈາກຮອບການຖ່າຍຂອງທ່ານ.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">ລາຍລະ"
"ອຽດເພີ່ມເຕີມຈະຕາມມາໃນໄວໆນີ້.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">ຫາກທ່າ"
"ນມີຄຳຖາມ ຫຼື ຕ້ອງການ\n"
"                    ປ່ຽນເວລາ,\n"
"                    ກະລຸນາຕິດຕໍ່ຫາພວກເຮົາໂດຍໄວທີ່ສຸດ. </p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">ດ້ວຍຄວ"
"າມນັບຖື,</p>\n"
"            \n"
"        "

#. module: photography
#: model:mail.template,body_html:photography.order_appointment_booking
msgid ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Hi <t t-out=\"object.partner_id.name or '''John Doe'''\"/>!</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">You've recently confirmed a Studio\n"
"                    Session with us - we're super glad you chose to work with <t t-out=\"object.company_id.name or '''us'''\">Frozen Moments</t>!</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">You can book your Studio session\n"
"                    directly via our website by following <a href=\"/book/studio\" style=\"text-decoration:none;box-sizing:border-box;color:#017e84;\">this link</a>\n"
"                </p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Sessions are 1h30 long, with\n"
"                    usually 20-30min of setup and\n"
"                    45min-1h of proper shooting (with small breaks if needed).</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">If you have a scheduling issue,\n"
"                    please contact us as soon as\n"
"                    possible and we'll be more than happy to make adaptations!</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Kind regards,</p>\n"
"             \n"
"        "
msgstr ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">ສະບາຍດີ <t t-"
"out=\"object.partner_id.name or '''John Doe'''\"/>!</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">ທ່ານຫາ"
"ກໍ່ຢືນຢັນຮອບການຖ່າຍໃນສະຕູດິໂອ\n"
"                    ກັບພວກເຮົາ - ພວກເຮົາດີໃຈຫຼາຍທີ່ທ່ານເລືອກໃຊ້ບໍລິການກັບ <t t-"
"out=\"object.company_id.name or '''us'''\">Frozen Moments</t>!</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">ທ່ານສາ"
"ມາດຈອງຮອບການຖ່າຍໃນສະຕູດິໂອ\n"
"                    ໄດ້ໂດຍກົງຜ່ານເວັບໄຊທ໌ຂອງພວກເຮົາໂດຍການກົດ <a href=\"/book/"
"studio\" style=\"text-decoration:none;box-sizing:border-box;color:#017e84;\">"
"ລິ້ງນີ້</a>\n"
"                </p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">ແຕ່ລະຮ"
"ອບໃຊ້ເວລາ 1 ຊົ່ວໂມງ 30 ນາທີ, ໂດຍ\n"
"                    ປົກກະຕິຈະໃຊ້ເວລາ 20-30 ນາທີໃນການຈັດສະຖານທີ່ ແລະ\n"
"                    45 ນາທີ - 1 ຊົ່ວໂມງສຳລັບການຖ່າຍຮູບ (ພ້ອມເວລາພັກຜ່ອນຖ້າຈຳເປັນ).</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">ຫາກທ່າ"
"ນມີບັນຫາເລື່ອງຕາຕະລາງເວລາ,\n"
"                    ກະລຸນາຕິດຕໍ່ຫາພວກເຮົາໂດຍໄວທີ່ສຸດ\n"
"                    ພວກເຮົາຍິນດີທີ່ຈະປັບປ່ຽນໃຫ້ຕາມຄວາມເໝາະສົມ!</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">ດ້ວຍຄວ"
"າມນັບຖື,</p>\n"
"             \n"
"        "

