#. module: photography
#: model:mail.template,body_html:photography.email_template_wedding_event_quote
msgid ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Dear <t t-"
"out=\"object.partner_id.name or '''John Doe'''\"/>,</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Congratulations on your\n"
"                    engagement! We're thrilled you're considering <t t-"
"out=\"object.company_id.name or '''us'''\">Frozen Moments</t> to capture "
"the\n"
"                    magic of your wedding day..</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">We "
"would be honored to be part of\n"
"                    this significant\n"
"                    chapter in your lives.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">If "
"you have any questions or\n"
"                    require further customization, please don't hesitate to "
"reach out to us.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Best "
"wishes,</p>\n"
"            \n"
"        "
msgstr ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Здравствуйте, <t t-"
"out=\"object.partner_id.name or '''John Doe'''\"/>!</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Поздравляем с \n"
"                    помолвкой! Мы очень рады, что вы готовы доверить <t t-"
"out=\"object.company_id.name or '''us'''\">Frozen Moments</t> запечатлеть\n"
"                     волшебство вашего праздника.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Для "
"нас будет большой честью стать частью\n"
"                    этой важной\n"
"                    главы в вашей жизни.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Если "
"у вас возникнут вопросы или\n"
"                    потребуется дополнительная настройка, пожалуйста, "
"обращайтесь к нам.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">С "
"наилучшими пожеланиями,</p>\n"
"            \n"
"        "

#. module: photography
#: model:mail.template,body_html:photography.email_template_pro_event_quote
msgid ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Dear <t t-"
"out=\"object.partner_id.name or '''John Doe'''\"/>,</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">I "
"hope this email finds you well.\n"
"                    Thank you for considering <t t-"
"out=\"object.company_id.name or '''Frozen Moments'''\"/>\n"
"                    for your upcoming event.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">We "
"would be honoured to capture\n"
"                    the special moments of your event and provide high-"
"quality photographs that you can\n"
"                    cherish for years to come.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">If "
"you have any questions or\n"
"                    require further customization, please don't hesitate to "
"reach out to us.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Best "
"regards,</p>\n"
"            \n"
"        "
msgstr ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Здравствуйте, <t t-"
"out=\"object.partner_id.name or '''John Doe'''\"/>!</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Благодарим вас за интерес к <t t-out=\"object.company_id.name or "
"'''Frozen Moments'''\"/>\n"
"                    для проведения вашего мероприятия.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Для "
"нас будет честью запечатлеть\n"
"                     особенные моменты вашего мероприятия и предоставить вам "
"фотографии высокого качества, которые\n"
"                    останутся с вами на долгие годы.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Если "
"у вас есть вопросы или\n"
"                     нужна дополнительная кастомизация, пожалуйста, "
"свяжитесь с нами.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">С "
"уважением,</p>\n"
"            \n"
"        "

#. module: photography
#: model:mail.template,body_html:photography.email_template_confirmation
msgid ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Dear <t t-"
"out=\"object.partner_id.name or '''John Doe'''\"/>,</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Thank you for choosin <t t-out=\"object.company_id.name or "
"'''us'''\">Frozen Moments</t> for your upcoming\n"
"                    photography needs. We are pleased to confirm your "
"booking!</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Note: Upon confirmation, we will\n"
"                    contact you\n"
"                    shortly to discuss scheduling and any specific "
"requirements you may have.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">More "
"details will follow soon.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">If "
"you have any questions or need\n"
"                    to make changes,\n"
"                    please contact us as soon as possible.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Best "
"regards,</p>\n"
"            \n"
"        "
msgstr ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Здравствуйте, <t t-"
"out=\"object.partner_id.name or '''John Doe'''\"/>!</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Спасибо, что выбрали <t t-out=\"object.company_id.name or "
"'''us'''\">Frozen Moments</t> для вашей предстоящей\n"
"                    фотосессии. Рады сообщить, что ваше бронирование "
"подтверждено.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Мы "
"свяжемся с вами в\n"
"                    ближайшее время,\n"
"                    чтобы согласовать график и детали съемки.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Более подробная информация будет выслана в ближайшее время.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Если "
"у вас есть вопросы или вы хотите\n"
"                    внести изменения,\n"
"                    пожалуйста, свяжитесь с нами как можно скорее.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">С "
"уважением,</p>\n"
"            \n"
"        "

#. module: photography
#: model:mail.template,body_html:photography.email_template_studio_quote
msgid ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Dear <t t-"
"out=\"object.partner_id.name or '''John Doe'''\"/>,</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Thank you for considering <t t-out=\"object.company_id.name or "
"'''us'''\">Frozen Moments</t> for your studio\n"
"                    photography needs. We look forward to capturing your "
"essence in high-quality\n"
"                    photographs.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Note: Upon confirmation, we will\n"
"                    contact you\n"
"                    shortly to discuss scheduling and any specific "
"requirements you may have.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">If "
"you have any questions or need\n"
"                    further details,\n"
"                    don't hesitate to reach out. </p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Best "
"regards,</p>\n"
"            \n"
"        "
msgstr ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Здравствуйте, <t t-"
"out=\"object.partner_id.name or '''John Doe'''\"/>!</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Спасибо, что рассматриваете <t t-out=\"object.company_id.name or "
"'''us'''\">Frozen Moments</t> для вашей предстоящей\n"
"                    фотосессии. Мы с нетерпением ждем возможности "
"запечатлеть вашу уникальность в наших высококачественных\n"
"                    снимках.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Примечание: После подтверждения мы\n"
"                    свяжемся с вами\n"
"                    в ближайшее время, чтобы обсудить расписание и любые "
"ваши пожелания.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Если "
"у вас возникнут вопросы или потребуется\n"
"                    уточнить детали,\n"
"                    просто свяжитесь с нами. </p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">С "
"уважением,</p>\n"
"            \n"
"        "

#. module: photography
#: model:mail.template,body_html:photography.email_calendar_reminder
msgid ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Dear <t t-"
"out=\"object.partner_id.name or '''John Doe'''\"/>,</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">We're looking forward to capturing\n"
"                    your photographs\n"
"                    during our studio session tomorrow. Here are the details "
"for your reference:\n"
"                </p>\n"
"                <ul style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"                    <li>\n"
"                        <b>When:<t t-"
"out=\"format_datetime(object.event_id.start, tz=object.mail_tz, "
"dt_format=&quot;long&quot;, lang_code=object.env.lang) or &quot;&quot;"
"\">Tue,\n"
"                            Oct 31st - 11:00 AM</t></b>\n"
"                    </li>\n"
"                    <li>\n"
"                        <b>Where:<t t-out=\"object.event_id.location or "
"''\">Frozen Moments Studio</t></b>\n"
"                    </li>\n"
"                </ul>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Please arrive on time to make the\n"
"                    most out\n"
"                    of your session.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">More "
"details will follow soon.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">If "
"you have any questions or need\n"
"                    to reschedule,\n"
"                    please contact us as soon as possible. </p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Best "
"regards,</p>\n"
"            \n"
"        "
msgstr ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Здравствуйте, <t t-"
"out=\"object.partner_id.name or '''John Doe'''\"/>!</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Мы с "
"нетерпением ждем\n"
"                    завтрашней\n"
"                    фотосессии. Вот вся необходимая информация:\n"
"                </p>\n"
"                <ul style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"                    <li>\n"
"                        <b>Когда:<t t-"
"out=\"format_datetime(object.event_id.start, tz=object.mail_tz, "
"dt_format=&quot;long&quot;, lang_code=object.env.lang) or &quot;&quot;"
"\">Вт,\n"
"                            Окт 31 – 11:00</t></b>\n"
"                    </li>\n"
"                    <li>\n"
"                        <b>Где:<t t-out=\"object.event_id.location or "
"''\">Frozen Moments Studio</t></b>\n"
"                    </li>\n"
"                </ul>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Пожалуйста, не опаздывайте, чтобы успеть сделать\n"
"                    как можно больше\n"
"                    красивых снимков.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Более подробная информация будет выслана в ближайшее время.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Если "
"у вас есть вопросы или вы хотите\n"
"                     перенести фотосессию,\n"
"                    пожалуйста, свяжитесь с нами как можно скорее. </p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">С "
"уважением,</p>\n"
"            \n"
"        "

#. module: photography
#: model:mail.template,body_html:photography.task_appointment_booking
msgid ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Hi <t t-"
"out=\"object.partner_id.name or '''John Doe'''\"/>!</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">You've recently confirmed a Studio\n"
"                    Session with us - we're super glad you chose to work "
"with <t t-out=\"object.company_id.name or '''us'''\">Frozen Moments</t>!</"
"p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">You "
"can book your Studio session\n"
"                    directly via our website by following <a href=\"/book/"
"studio\" style=\"text-decoration:none;box-sizing:border-"
"box;color:#017e84;\">this link</a>\n"
"                </p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Sessions are 1h30 long, with\n"
"                    usually 20-30min of setup and\n"
"                    45min-1h of proper shooting (with small breaks if "
"needed).</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">If "
"you have a scheduling issue,\n"
"                    please contact us as soon as\n"
"                    possible and we'll be more than happy to make "
"adaptations!</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Kind "
"regards,</p>\n"
"            \n"
"        "
msgstr ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Здравствуйте, <t t-"
"out=\"object.partner_id.name or '''John Doe'''\"/>!</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Вы "
"недавно подтвердили фотосессию\n"
"                    в нашей студии – мы очень рады, что вы выбрали <t t-"
"out=\"object.company_id.name or '''us'''\">Frozen Moments</t>!</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Вы "
"можете забронировать фотосессию в студии\n"
"                    прямо на нашем сайте, перейдя по этой ссылке: <a href=\"/"
"book/studio\" style=\"text-decoration:none;box-sizing:border-"
"box;color:#017e84;\">.</a>\n"
"                </p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Фотосессия длится 1 час 30 минут, обычно \n"
"                    20–30 минут уходит на подготовку и\n"
"                    45 минут – 1 час на саму съемку (с небольшими "
"перерывами, если это необходимо).</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Если "
"вам понадобится перенести съемку,\n"
"                    просто свяжитесь с нами –\n"
"                    мы всегда готовы помочь!</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">С "
"уважением,</p>\n"
"            \n"
"        "

#. module: photography
#: model:mail.template,body_html:photography.order_appointment_booking
msgid ""
