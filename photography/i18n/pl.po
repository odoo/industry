#. module: photography
#: model:mail.template,body_html:photography.email_template_wedding_event_quote
msgid ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Dear <t t-"
"out=\"object.partner_id.name or '''John Doe'''\"/>,</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Congratulations on your\n"
"                    engagement! We're thrilled you're considering <t t-"
"out=\"object.company_id.name or '''us'''\">Frozen Moments</t> to capture "
"the\n"
"                    magic of your wedding day..</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">We "
"would be honored to be part of\n"
"                    this significant\n"
"                    chapter in your lives.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">If "
"you have any questions or\n"
"                    require further customization, please don't hesitate to "
"reach out to us.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Best "
"wishes,</p>\n"
"            \n"
"        "
msgstr ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Drogi/-a <t t-"
"out=\"object.partner_id.name or '''John Doe'''\"/>,</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Gratulacje z okazji\n"
"                    zaręczyn! Gratulacje z okazji\n"
"zaręczyn! Cieszymy się, że rozważasz <t t-out=\"object.company_id.name or "
"'''us'''\">Frozen Moments</t> aby uchwycić\n"
"                    magię Waszego ślubu.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Będziemy zaszczyceni mogąc być częścią\n"
"                    tego ważnego\n"
"                    rozdziału w Waszym życiu.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Jeśli masz jakieś pytania lub\n"
"                    potrzebujesz dalszych dostosowań, nie wahaj się z nami "
"skontaktować.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Najlepsze życzenia,</p>\n"
"            \n"
"        "

#. module: photography
#: model:mail.template,body_html:photography.email_template_pro_event_quote
msgid ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Dear <t t-"
"out=\"object.partner_id.name or '''John Doe'''\"/>,</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">I "
"hope this email finds you well.\n"
"                    Thank you for considering <t t-out=\"object.company_id."
"name or '''Frozen Moments'''\"/>\n"
"                    for your upcoming event.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">We "
"would be honoured to capture\n"
"                    the special moments of your event and provide high-"
"quality photographs that you can\n"
"                    cherish for years to come.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">If "
"you have any questions or\n"
"                    require further customization, please don't hesitate to "
"reach out to us.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Best "
"regards,</p>\n"
"            \n"
"        "
msgstr ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Drogi/-a <t t-"
"out=\"object.partner_id.name or '''John Doe'''\"/>,</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Mamy "
"nadzieję, że masz się dobrze.\n"
"                    Dziękujemy za rozważenie usług <t t-out=\"object."
"company_id.name or '''Frozen Moments'''\"/>\n"
"                    podczas nadchodzącego wydarzenia.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Z "
"przyjemnością pomożemy Ci uchwycić\n"
"                    niezapomniane momenty Twojego wydarzenia i zapewnimy "
"wysokiej jakości fotografie, którymi\n"
"                    będziesz się cieszyć latami.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Jeśli masz jakiekolwiek pytania lub\n"
"                    uwagi, nie wahaj się z nami skontaktować.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Z "
"pozdrowieniami,</p>\n"
"            \n"
"        "

#. module: photography
#: model:mail.template,body_html:photography.email_template_confirmation
msgid ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Dear <t t-"
"out=\"object.partner_id.name or '''John Doe'''\"/>,</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Thank you for choosin <t t-out=\"object.company_id.name or "
"'''us'''\">Frozen Moments</t> for your upcoming\n"
"                    photography needs. We are pleased to confirm your "
"booking!</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Note: Upon confirmation, we will\n"
"                    contact you\n"
"                    shortly to discuss scheduling and any specific "
"requirements you may have.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">More "
"details will follow soon.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">If "
"you have any questions or need\n"
"                    to make changes,\n"
"                    please contact us as soon as possible.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Best "
"regards,</p>\n"
"            \n"
"        "
msgstr ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Drogi/-a <t t-"
"out=\"object.partner_id.name or '''John Doe'''\"/>,</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Dziękujemy za wybranie usług <t t-out=\"object.company_id.name or "
"'''us'''\">Frozen Moments</t> na Twoje nadchodzące\n"
"                    potrzeby fotograficzne. Z przyjemnością potwierdzamy "
"rezerwację!</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Uwaga: Po potwierdzeniu skontaktujemy się\n"
"                    z Tobą\n"
"                    w celu omówienia harmonogramu i wszelkich szczegółów "
"zlecenia.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Wkrótce otrzymasz więcej informacji.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Jeśli masz jakieś pytania, lub potrzebujesz\n"
"                    dokonać zmian,\n"
"                    skontaktuj się z nami tak szybko, jak to możliwe.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Z "
"pozdrowieniami,</p>\n"
"            \n"
"        "

