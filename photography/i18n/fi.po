#. module: photography
#: model:mail.template,body_html:photography.email_template_wedding_event_quote
msgid ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Dear <t t-"
"out=\"object.partner_id.name or '''John Doe'''\"/>,</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Congratulations on your\n"
"                    engagement! We're thrilled you're considering <t t-"
"out=\"object.company_id.name or '''us'''\">Frozen Moments</t> to capture "
"the\n"
"                    magic of your wedding day..</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">We "
"would be honored to be part of\n"
"                    this significant\n"
"                    chapter in your lives.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">If "
"you have any questions or\n"
"                    require further customization, please don't hesitate to "
"reach out to us.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Best "
"wishes,</p>\n"
"            \n"
"        "
msgstr ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Hyvä <t t-"
"out=\"object.partner_id.name or '''John Doe'''\"/>,</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Onnittulemme\n"
"                    kihlauksenne johdosta! On ilo kuulla, että harkitset <t "
"t-out=\"object.company_id.name or '''us'''\">Frozen Momentsia</t> "
"ikuistamaan\n"
"                    taianomaisen hääpäivänne.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Olemme mielellämme mukana juhlistamassa\n"
"                    uuden luvun\n"
"                    alkua elämässänne.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Jos "
"teillä on kysymyksiä tai\n"
"                    erikoistoiveita, olkaa meihin yhteydessä.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Lämpimin terveisin,</p>\n"
"            \n"
"        "

#. module: photography
#: model:mail.template,body_html:photography.email_template_pro_event_quote
msgid ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Dear <t t-"
"out=\"object.partner_id.name or '''John Doe'''\"/>,</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">I "
"hope this email finds you well.\n"
"                    Thank you for considering <t t-"
"out=\"object.company_id.name or '''Frozen Moments'''\"/>\n"
"                    for your upcoming event.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">We "
"would be honoured to capture\n"
"                    the special moments of your event and provide high-"
"quality photographs that you can\n"
"                    cherish for years to come.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">If "
"you have any questions or\n"
"                    require further customization, please don't hesitate to "
"reach out to us.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Best "
"regards,</p>\n"
"            \n"
"        "
msgstr ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Hyvä <t t-"
"out=\"object.partner_id.name or '''John Doe'''\"/>,</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Toivon, että sähköposti tavoittaa teidät.\n"
"                    Kiitos, että harkitsette palveluitamme <t t-"
"out=\"object.company_id.name or '''Frozen Moments'''\"/>\n"
"                    tulevaa tapahtumaanne varten.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Olemme mielellämme mukana\n"
"                    tapahtumanne tähtihetkissä ja ikuistamassa niitä "
"korkealaatuisin kuvin, jotta voit  \n"
"                    muistella tapahtumaa vielä vuosien päästä.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Jos "
"teillä on kysymyksiä tai\n"
"                    erikoistoiveita, olkaa meihin yhteydessä.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Parhain terveisin,</p>\n"
"            \n"
"        "

#. module: photography
#: model:mail.template,body_html:photography.email_template_confirmation
