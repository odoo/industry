#. module: photography
#: model:mail.template,body_html:photography.email_calendar_reminder
msgid ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Dear <t t-"
"out=\"object.partner_id.name or '''John Doe'''\"/>,</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">We're looking forward to capturing\n"
"                    your photographs\n"
"                    during our studio session tomorrow. Here are the details "
"for your reference:\n"
"                </p>\n"
"                <ul style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"                    <li>\n"
"                        <b>When:<t t-"
"out=\"format_datetime(object.event_id.start, tz=object.mail_tz, "
"dt_format=&quot;long&quot;, lang_code=object.env.lang) or &quot;&quot;"
"\">Tue,\n"
"                            Oct 31st - 11:00 AM</t></b>\n"
"                    </li>\n"
"                    <li>\n"
"                        <b>Where:<t t-out=\"object.event_id.location or "
"''\">Frozen Moments Studio</t></b>\n"
"                    </li>\n"
"                </ul>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Please arrive on time to make the\n"
"                    most out\n"
"                    of your session.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">More "
"details will follow soon.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">If "
"you have any questions or need\n"
"                    to reschedule,\n"
"                    please contact us as soon as possible. </p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Best "
"regards,</p>\n"
"            \n"
"        "
msgstr ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Hyvä <t t-"
"out=\"object.partner_id.name or '''John Doe'''\"/>,</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Odotamme innolla saapumistanne\n"
"                    kuvaamollemme\n"
"                    ja itse kuvauksia huomenna. Tässä vielä varauksenne "
"tiedot:\n"
"                </p>\n"
"                <ul style=\"margin:0px 0 16px 0;box-sizing:border-box;\">\n"
"                    <li>\n"
"                        <b>Aika:<t t-"
"out=\"format_datetime(object.event_id.start, tz=object.mail_tz, "
"dt_format=&quot;long&quot;, lang_code=object.env.lang) or &quot;&quot;"
"\">Tiistai,\n"
"                            31. lokakuuta 11:00</t></b>\n"
"                    </li>\n"
"                    <li>\n"
"                        <b>Paikka:<t t-out=\"object.event_id.location or "
"''\">Frozen Moments Studio</t></b>\n"
"                    </li>\n"
"                </ul>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Saavuttehan ajoissa paikalle, jotta saamme\n"
"                    mahdollisimman paljon irti\n"
"                    kuvauksista.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Lähetämme pian lisätietoja.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Jos "
"teillä on kysymyksiä tai kuvauksen\n"
"                    ajankohtaa tarvitsee siirtää,\n"
"                    olettehan meihin yhteydessä mahdollisimman pien. </p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Parhain terveisin,</p>\n"
"            \n"
"        "

#. module: photography
#: model:mail.template,body_html:photography.order_appointment_booking
msgid ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Hi <t t-"
"out=\"object.partner_id.name or '''John Doe'''\"/>!</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">You've recently confirmed a Studio\n"
"                    Session with us - we're super glad you chose to work "
"with <t t-out=\"object.company_id.name or '''us'''\">Frozen Moments</t>!</"
"p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">You "
"can book your Studio session\n"
"                    directly via our website by following <a href=\"/book/"
"studio\" style=\"text-decoration:none;box-sizing:border-"
"box;color:#017e84;\">this link</a>\n"
"                </p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Sessions are 1h30 long, with\n"
"                    usually 20-30min of setup and\n"
"                    45min-1h of proper shooting (with small breaks if "
"needed).</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">If "
"you have a scheduling issue,\n"
"                    please contact us as soon as\n"
"                    possible and we'll be more than happy to make "
"adaptations!</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Kind "
"regards,</p>\n"
"             \n"
"        "
