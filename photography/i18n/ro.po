#. module: photography
#: model:mail.template,body_html:photography.email_template_wedding_event_quote
msgid ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Dear <t t-"
"out=\"object.partner_id.name or '''John Doe'''\"/>,</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Congratulations on your\n"
"                    engagement! We're thrilled you're considering <t t-"
"out=\"object.company_id.name or '''us'''\">Frozen Moments</t> to capture "
"the\n"
"                    magic of your wedding day..</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">We "
"would be honored to be part of\n"
"                    this significant\n"
"                    chapter in your lives.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">If "
"you have any questions or\n"
"                    require further customization, please don't hesitate to "
"reach out to us.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Best "
"wishes,</p>\n"
"            \n"
"        "
msgstr ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Dragă <t t-"
"out=\"object.partner_id.name or '''John Doe'''\"/>,</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Felicitări pentru logodnă!\n"
"                    Suntem încântați că luați în considerare <t t-"
"out=\"object.company_id.name or '''us'''\">Frozen Moments</t> pentru a "
"surprinde\n"
"                    magia zilei nunții dumneavoastră.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Ne-"
"ar face o deosebită plăcere să facem parte din\n"
"                    acest capitol important din viața voastră.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Dacă "
"aveți întrebări sau\n"
"                    doriți personalizări suplimentare, nu ezitați să ne "
"contactați.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Cu "
"cele mai bune gânduri,</p>\n"
"            \n"
"        "

#. module: photography
#: model:mail.template,body_html:photography.email_template_pro_event_quote
msgid ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Dear <t t-"
"out=\"object.partner_id.name or '''John Doe'''\"/>,</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">I "
"hope this email finds you well.\n"
"                    Thank you for considering <t t-"
"out=\"object.company_id.name or '''Frozen Moments'''\"/>\n"
"                    for your upcoming event.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">We "
"would be honoured to capture\n"
"                    the special moments of your event and provide high-"
"quality photographs that you can\n"
"                    cherish for years to come.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">If "
"you have any questions or\n"
"                    require further customization, please don't hesitate to "
"reach out to us.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Best "
"regards,</p>\n"
"            \n"
"        "
msgstr ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Stimate <t t-"
"out=\"object.partner_id.name or '''John Doe'''\"/>,</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Sperăm că acest email vă găsește bine.\n"
"                    Vă mulțumim că ați ales <t t-"
"out=\"object.company_id.name or '''Frozen Moments'''\"/>\n"
"                    pentru evenimentul dumneavoastră.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Ne-"
"ar onora să surprindem\n"
"                    momentele speciale ale evenimentului și să vă oferim "
"fotografii de înaltă calitate pe care să le prețuiți ani la rând.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Dacă "
"aveți întrebări sau\n"
"                    doriți personalizări suplimentare, nu ezitați să ne "
"contactați.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Cu "
"stimă,</p>\n"
"            \n"
"        "

#. module: photography
#: model:mail.template,body_html:photography.email_template_confirmation
msgid ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Dear <t t-"
"out=\"object.partner_id.name or '''John Doe'''\"/>,</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Thank you for choosin <t t-out=\"object.company_id.name or "
"'''us'''\">Frozen Moments</t> for your upcoming\n"
"                    photography needs. We are pleased to confirm your "
"booking!</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Note: Upon confirmation, we will\n"
"                    contact you\n"
"                    shortly to discuss scheduling and any specific "
"requirements you may have.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">More "
"details will follow soon.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">If "
"you have any questions or need\n"
"                    to make changes,\n"
"                    please contact us as soon as possible.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Best "
"regards,</p>\n"
"            \n"
"        "
msgstr ""
"<p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Dragă <t t-"
"out=\"object.partner_id.name or '''John Doe'''\"/>,</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Vă "
"mulțumim că ați ales <t t-out=\"object.company_id.name or '''us'''\">Frozen "
"Moments</t> pentru nevoile dumneavoastră fotografice. Suntem bucuroși să vă "
"confirmăm rezervarea!</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;"
"\">Notă: După confirmare, vă vom contacta\n"
"                    în scurt timp pentru a discuta programarea și orice "
"cerințe specifice pe care le aveți.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Mai "
"multe detalii vor urma în curând.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Dacă "
"aveți întrebări sau doriți să faceți modificări,\n"
"                    vă rugăm să ne contactați cât mai curând posibil.</p>\n"
"                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\">Cu "
"stimă,</p>\n"
"            \n"
"        "

