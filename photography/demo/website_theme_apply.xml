<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <function name="button_immediate_install" model="ir.module.module" eval="[ref('base.module_theme_nano', raise_if_not_found=False)]" />

    <function model="ir.module.module" name="_theme_load" context="{'apply_new_theme': True}">
        <value model="ir.module.module" eval="obj().env['ir.module.module'].search([('name', '=', 'theme_nano')]).ids" />
        <value model="ir.module.module" eval="obj().env.ref('website.default_website')" />
    </function>

    <function model="web_editor.assets" name="make_scss_customization">
        <value eval="'/website/static/src/scss/options/user_values.scss'"/>
        <value eval="{
            'header-template': 'null',
            'layout': 'full',
            'menu-gradient': 'null',
            'menu-secondary-gradient': 'null',
            'footer-gradient': 'NULL',
            'copyright-gradient': 'null',
            'o-cc1-bg-gradient': 'null',
            'o-cc2-bg-gradient': 'null',
            'o-cc3-bg-gradient': 'null',
            'o-cc4-bg-gradient': 'null',
            'o-cc5-bg-gradient': 'null',
            'font': 'null',
            'headings-font': 'null',
            'navbar-font': 'null',
            'buttons-font': 'null',
            'color-palettes-number': 'null',
            'color-palettes-name': 'null',
            'btn-ripple': 'null',
            'footer-template': 'centered',
            'footer-scrolltop': 'null',
        }"/>
    </function>

    <function model="web_editor.assets" name="make_scss_customization" context="{'website_id': ref('website.default_website')}">
        <value eval="'/website/static/src/scss/options/colors/user_color_palette.scss'"/>
        <value eval="{
            'footer': 1,
            'footer-custom': 'NULL',
        }"/>
    </function>

    <function model="web_editor.assets" name="make_scss_customization" context="{'website_id': ref('website.default_website')}">
        <value eval="'/website/static/src/scss/options/colors/user_theme_color_palette.scss'"/>
        <value eval="{
            'success': 'null',
            'info': 'null',
            'warning': 'null',
            'danger': 'null',
        }"/>
    </function>

    <function model="ir.ui.view" name="write">
        <value model="ir.ui.view" eval="obj().env['website'].with_context(website_id=obj().env.ref('website.default_website').id).viewref('website.homepage').id"/>
        <value model="ir.ui.view" eval="{'arch': obj().env.ref('photography.contactus').arch}"/>
    </function>
</odoo>
